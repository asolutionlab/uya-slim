// 测试块注释（规范 uya.md §1）

use std.testing.expect;
use std.testing.test_suite_begin;
use std.testing.test_suite_end;
use std.testing.run_test;

/* 单行块注释 */

fn test_single_line_block_comment() !void {
    /* 函数内块注释 */
    const a: i32 = 10; /* 行尾块注释 */
    try expect(a == 10);
}

fn test_multi_line_block_comment() !void {
    /*
        多行块注释
        可以跨越多行
    */
    const b: i32 = 20;
    try expect(b == 20);
}

fn test_nested_block_comment() !void {
    /* 嵌套块注释 - 级别1
        /* 嵌套块注释 - 级别2 */
        继续级别1
    */
    const c: i32 = 30;
    try expect(c == 30);
}

fn test_deep_nested_block_comment() !void {
    /* 深层嵌套
        /* 级别2
            /* 级别3 */
            继续级别2
        */
        继续级别1
    */
    const d: i32 = 40;
    try expect(d == 40);
}

fn test_mixed_comments() !void {
    // 混合单行和块注释
    /* 块 */ const e: i32 = 50; // 单行
    try expect(e == 50);
}

fn test_comment_sum() !void {
    const a: i32 = 10;
    const b: i32 = 20;
    const c: i32 = 30;
    const d: i32 = 40;
    const e: i32 = 50;
    try expect(a + b + c + d + e == 150);
}

fn main() i32 {
    test_suite_begin("Block Comment Tests");
    
    run_test("single line block comment", test_single_line_block_comment);
    run_test("multi line block comment", test_multi_line_block_comment);
    run_test("nested block comment", test_nested_block_comment);
    run_test("deep nested block comment", test_deep_nested_block_comment);
    run_test("mixed comments", test_mixed_comments);
    run_test("comment sum", test_comment_sum);
    
    return test_suite_end();
}
