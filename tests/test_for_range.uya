// 测试 for 整数范围

use std.testing.assert_eq_i32;
use std.testing.test_suite_begin;
use std.testing.test_suite_end;
use std.testing.run_test;

fn test_for_range_sum() !void {
    var sum: i32 = 0;
    for 0..5 |i| {
        sum = sum + i;
    }
    try assert_eq_i32(sum, 10);  // 0+1+2+3+4 = 10
}

fn test_for_range_discard() !void {
    var count: i32 = 0;
    for 0..3 {
        count = count + 1;
    }
    try assert_eq_i32(count, 3);
}

fn test_for_range_prod() !void {
    var prod: i32 = 1;
    for 1..4 |k| {
        prod = prod * k;
    }
    try assert_eq_i32(prod, 6);  // 1*1*2*3 = 6
}

fn main() i32 {
    test_suite_begin("For Range Tests");
    
    run_test("for range sum", test_for_range_sum);
    run_test("for range discard", test_for_range_discard);
    run_test("for range prod", test_for_range_prod);
    
    return test_suite_end();
}
