// 饱和运算 +| -| *| 与包装运算 +% -% *% 测试，规范 uya.md §10、§16
use std.runtime.entry;

use std.testing.expect;
use std.testing.assert_eq_i32;
use std.testing.test_suite_begin;
use std.testing.test_suite_end;
use std.testing.run_test;

fn test_saturating_add() !void {
    const max_i32: i32 = 2147483647;
    const a: i32 = 2000000000;
    const b: i32 = 2000000000;
    const sat_add: i32 = a +| b;  // 溢出，饱和到 INT32_MAX
    try assert_eq_i32(sat_add, max_i32);
    
    const c: i32 = -2000000000;
    const d: i32 = -2000000000;
    const sat_add_neg: i32 = c +| d;  // 下溢，饱和到 INT32_MIN
    const min_i32: i32 = (-2147483647 - 1);
    try assert_eq_i32(sat_add_neg, min_i32);
    
    const normal_add: i32 = 10 +| 20;
    try assert_eq_i32(normal_add, 30);
}

fn test_saturating_sub() !void {
    const max_i32: i32 = 2147483647;
    const min_i32: i32 = (-2147483647 - 1);
    
    const e: i32 = -2000000000;
    const f: i32 = 2000000000;
    const sat_sub: i32 = e -| f;  // 下溢，饱和到 INT32_MIN
    try assert_eq_i32(sat_sub, min_i32);
    
    const g: i32 = 2000000000;
    const h: i32 = -2000000000;
    const sat_sub_pos: i32 = g -| h;  // 上溢，饱和到 INT32_MAX
    try assert_eq_i32(sat_sub_pos, max_i32);
    
    const normal_sub: i32 = 50 -| 8;
    try assert_eq_i32(normal_sub, 42);
}

fn test_saturating_mul() !void {
    const max_i32: i32 = 2147483647;
    
    const m1: i32 = 50000;
    const m2: i32 = 50000;
    const sat_mul: i32 = m1 *| m2;  // 溢出，饱和到 INT32_MAX
    try assert_eq_i32(sat_mul, max_i32);
    
    const normal_mul: i32 = 3 *| 7;
    try assert_eq_i32(normal_mul, 21);
}

fn test_wrapping_add() !void {
    const max_i32: i32 = 2147483647;
    const min_i32: i32 = (-2147483647 - 1);
    
    const w1: i32 = max_i32;
    const w2: i32 = 1;
    const wrap_add: i32 = w1 +% w2;  // 包装到 INT32_MIN
    try assert_eq_i32(wrap_add, min_i32);
    
    const wrap_add2: i32 = 100 +% 200;
    try assert_eq_i32(wrap_add2, 300);
}

fn test_wrapping_sub() !void {
    const max_i32: i32 = 2147483647;
    const min_i32: i32 = (-2147483647 - 1);
    
    const w3: i32 = min_i32;
    const w4: i32 = 1;
    const wrap_sub: i32 = w3 -% w4;  // 包装到 2147483647
    try assert_eq_i32(wrap_sub, max_i32);
}

fn test_wrapping_mul() !void {
    const w5: i32 = 65536;
    const w6: i32 = 65536;
    const wrap_mul: i32 = w5 *% w6;  // 包装
    try assert_eq_i32(wrap_mul, 0);
}

export fn main() i32 {
    test_suite_begin("Saturating Wrapping Tests");
    run_test("saturating add", test_saturating_add);
    run_test("saturating sub", test_saturating_sub);
    run_test("saturating mul", test_saturating_mul);
    run_test("wrapping add", test_wrapping_add);
    run_test("wrapping sub", test_wrapping_sub);
    run_test("wrapping mul", test_wrapping_mul);
    return test_suite_end();
}
