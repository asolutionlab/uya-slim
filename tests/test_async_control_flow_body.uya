// test_async_control_flow_body.uya
// 同步 / async 成对覆盖函数体控制流：if、while、for、break、continue、块语句和 return。

use std.async;
use std.testing.assert_eq_i32;

fn sync_control_flow(seed: i32) i32 {
    if seed < 0 {
        return 100 - seed;
    }

    var total: i32 = 0;
    var i: i32 = 0;

    while i < 6 {
        i = i + 1;
        if i == 2 {
            continue;
        }
        if i == 5 {
            break;
        }
        {
            const bump: i32 = seed + i;
            total = total + bump;
        }
    }

    for 0..5 |k| {
        if k == 1 {
            continue;
        }
        if k == 4 {
            break;
        }
        {
            const add: i32 = k as i32;
            total = total + add;
        }
    }

    if total > 20 {
        return total + 7;
    }
    return total - 3;
}

@async_fn
fn async_control_flow(seed: i32) Future<!i32> {
    if seed < 0 {
        return 100 - seed;
    }

    var total: i32 = 0;
    var i: i32 = 0;

    while i < 6 {
        i = i + 1;
        if i == 2 {
            continue;
        }
        if i == 5 {
            break;
        }
        {
            const bump: i32 = seed + i;
            total = total + bump;
        }
    }

    for 0..5 |k| {
        if k == 1 {
            continue;
        }
        if k == 4 {
            break;
        }
        {
            const add: i32 = k as i32;
            total = total + add;
        }
    }

    if total > 20 {
        return total + 7;
    }
    return total - 3;
}

test "async_control_flow_matches_sync_success" {
    const sync_value: i32 = sync_control_flow(4);
    const async_result: !i32 = block_on<i32>(async_control_flow(4));
    const async_value: i32 = async_result catch { -1; };

    try assert_eq_i32(sync_value, 32);
    try assert_eq_i32(async_value, 32);
}

test "async_control_flow_matches_sync_low_total" {
    const sync_value: i32 = sync_control_flow(0);
    const async_result: !i32 = block_on<i32>(async_control_flow(0));
    const async_value: i32 = async_result catch { -1; };

    try assert_eq_i32(sync_value, 10);
    try assert_eq_i32(async_value, 10);
}

test "async_control_flow_matches_sync_early_return" {
    const sync_value: i32 = sync_control_flow(-5);
    const async_result: !i32 = block_on<i32>(async_control_flow(-5));
    const async_value: i32 = async_result catch { -1; };

    try assert_eq_i32(sync_value, 105);
    try assert_eq_i32(async_value, 105);
}
