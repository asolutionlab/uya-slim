// 测试 @ptr_from_usize 内置函数
use std.runtime.entry;

use std.testing.expect;
use std.testing.test_suite_begin;
use std.testing.test_suite_end;
use std.testing.run_test;

fn test_ptr_from_usize_zero() !void {
    const addr: usize = 0x1000;
    const ptr: &void = @ptr_from_usize(addr);
    // 编译通过即测试通过
}

fn test_ptr_from_usize_nonzero() !void {
    const addr2: usize = 0x2000;
    const ptr2: &void = @ptr_from_usize(addr2);
    // 编译通过即测试通过
}

fn test_ptr_from_usize_roundtrip() !void {
    const addr3: usize = 0x3000;
    const ptr3: &void = @ptr_from_usize(addr3);
    const addr_back: usize = @usize_from_ptr(ptr3);
    try expect(addr_back == addr3);
}

export fn main() i32 {
    test_suite_begin("Ptr From Usize Tests");
    run_test("ptr from usize zero", test_ptr_from_usize_zero);
    run_test("ptr from usize nonzero", test_ptr_from_usize_nonzero);
    run_test("ptr from usize roundtrip", test_ptr_from_usize_roundtrip);
    return test_suite_end();
}
