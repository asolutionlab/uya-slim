// 算术运算测试
// 测试所有算术运算符（+ - * / %）

use std.testing.assert_eq_i32;
use std.testing.test_suite_begin;
use std.testing.test_suite_end;
use std.testing.run_test;

fn test_addition() !void {
    const a: i32 = 10;
    const b: i32 = 5;
    var sum: i32 = a + b;
    try assert_eq_i32(sum, 15);
}

fn test_subtraction() !void {
    const a: i32 = 10;
    const b: i32 = 5;
    var diff: i32 = a - b;
    try assert_eq_i32(diff, 5);
}

fn test_multiplication() !void {
    const a: i32 = 10;
    const b: i32 = 5;
    var prod: i32 = a * b;
    try assert_eq_i32(prod, 50);
}

fn test_division() !void {
    const a: i32 = 10;
    const b: i32 = 5;
    var quot: i32 = a / b;
    try assert_eq_i32(quot, 2);
}

fn test_modulo() !void {
    const a: i32 = 10;
    const b: i32 = 5;
    var mod: i32 = a % b;
    try assert_eq_i32(mod, 0);
}

fn main() i32 {
    test_suite_begin("Arithmetic Tests");
    run_test("addition", test_addition);
    run_test("subtraction", test_subtraction);
    run_test("multiplication", test_multiplication);
    run_test("division", test_division);
    run_test("modulo", test_modulo);
    return test_suite_end();
}
