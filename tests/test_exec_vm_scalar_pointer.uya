use std.runtime.entry;

fn pointer_bits(ptr: &const byte) usize {
    if ptr == null {
        return 0 as usize;
    }
    return @usize_from_ptr(ptr as &void);
}

export fn main() i32 {
    const small: u8 = 200 as u8;
    if small != 200 as u8 {
        return 1;
    }

    const wide: u16 = 60000 as u16;
    if wide != 60000 as u16 {
        return 2;
    }

    const len: usize = 4096 as usize + 32 as usize;
    if len != 4128 as usize {
        return 3;
    }

    const neg_three: isize = 0 as isize - 3 as isize;
    const delta: isize = 5 as isize - 8 as isize;
    if delta != neg_three {
        return 4;
    }

    const raw: &void = @ptr_from_usize(4096 as usize);
    if @usize_from_ptr(raw) != 4096 as usize {
        return 5;
    }

    const text_ptr: &const byte = "phase18";
    if pointer_bits(text_ptr) == 0 as usize {
        return 6;
    }
    if text_ptr[0 as usize] != 112 as byte {
        return 7;
    }

    const null_ptr: &const byte = null;
    if pointer_bits(null_ptr) != 0 as usize {
        return 8;
    }

    return 0;
}
