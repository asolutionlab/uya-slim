// else if 语句测试
use std.runtime.entry;
// 测试 else if 语法和多个条件分支

use std.testing.expect;
use std.testing.test_suite_begin;
use std.testing.test_suite_end;
use std.testing.run_test;

fn test_simple_else_if() !void {
    const x: i32 = 2;
    var result: i32 = 0;
    if x == 1 {
        result = 10;
    } else if x == 2 {
        result = 20;
    } else {
        result = 30;
    }
    try expect(result == 20);
}

fn test_multiple_else_if_chain() !void {
    const y: i32 = 3;
    var result: i32 = 0;
    if y == 1 {
        result = 100;
    } else if y == 2 {
        result = 200;
    } else if y == 3 {
        result = 300;
    } else if y == 4 {
        result = 400;
    } else {
        result = 500;
    }
    try expect(result == 300);
}

fn test_first_condition_true() !void {
    const z: i32 = 1;
    var result: i32 = 0;
    if z == 1 {
        result = 1000;
    } else if z == 2 {
        result = 2000;
    } else if z == 3 {
        result = 3000;
    } else {
        result = 4000;
    }
    try expect(result == 1000);
}

fn test_all_conditions_false() !void {
    const w: i32 = 99;
    var result: i32 = 0;
    if w == 1 {
        result = 10000;
    } else if w == 2 {
        result = 20000;
    } else if w == 3 {
        result = 30000;
    } else {
        result = 40000;
    }
    try expect(result == 40000);
}

fn test_no_final_else() !void {
    const v: i32 = 2;
    var result: i32 = 0;
    if v == 1 {
        result = 100000;
    } else if v == 2 {
        result = 200000;
    }
    try expect(result == 200000);
}

export fn main() i32 {
    test_suite_begin("Else If Tests");
    
    run_test("simple else if", test_simple_else_if);
    run_test("multiple else if chain", test_multiple_else_if_chain);
    run_test("first condition true", test_first_condition_true);
    run_test("all conditions false", test_all_conditions_false);
    run_test("no final else", test_no_final_else);
    
    return test_suite_end();
}
