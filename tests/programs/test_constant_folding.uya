// tests/programs/test_constant_folding.uya
// 测试编译期常量折叠优化

use std.testing;

// 测试基础常量折叠
test "constant_folding_basic_add" {
    const a: i32 = 10 + 20;
    try testing.assert_eq_i32(a, 30, "10 + 20 should be folded to 30");
}

test "constant_folding_basic_sub" {
    const b: i32 = 100 - 30;
    try testing.assert_eq_i32(b, 70, "100 - 30 should be folded to 70");
}

test "constant_folding_basic_mul" {
    const c: i32 = 7 * 8;
    try testing.assert_eq_i32(c, 56, "7 * 8 should be folded to 56");
}

test "constant_folding_basic_div" {
    const d: i32 = 100 / 4;
    try testing.assert_eq_i32(d, 25, "100 / 4 should be folded to 25");
}

test "constant_folding_basic_mod" {
    const e: i32 = 17 % 5;
    try testing.assert_eq_i32(e, 2, "17 % 5 should be folded to 2");
}

// 测试嵌套常量折叠
test "constant_folding_nested" {
    const a: i32 = 10;
    const b: i32 = a * 2;
    const c: i32 = b + 5;
    try testing.assert_eq_i32(c, 25, "nested constant should be folded");
}

// 测试复杂表达式
test "constant_folding_complex" {
    const x: i32 = (10 + 20) * (5 - 2);
    try testing.assert_eq_i32(x, 90, "(10 + 20) * (5 - 2) should be folded to 90");
}

// 测试布尔表达式
test "constant_folding_boolean_and" {
    const a: bool = true && false;
    try testing.assert_eq_bool(a, false, "true && false should be folded to false");
}

test "constant_folding_boolean_or" {
    const b: bool = true || false;
    try testing.assert_eq_bool(b, true, "true || false should be folded to true");
}

test "constant_folding_boolean_not" {
    const c: bool = !true;
    try testing.assert_eq_bool(c, false, "!true should be folded to false");
}

// 测试比较表达式
test "constant_folding_comparison" {
    const a: bool = 10 > 5;
    const b: bool = 10 < 5;
    const c: bool = 10 == 10;
    const d: bool = 10 != 5;
    
    try testing.assert_eq_bool(a, true, "10 > 5 should be folded to true");
    try testing.assert_eq_bool(b, false, "10 < 5 should be folded to false");
    try testing.assert_eq_bool(c, true, "10 == 10 should be folded to true");
    try testing.assert_eq_bool(d, true, "10 != 5 should be folded to true");
}

// 测试一元运算
test "constant_folding_unary_minus" {
    const a: i32 = -10;
    try testing.assert_eq_i32(a, -10, "-10 should be folded");
}

test "constant_folding_unary_plus" {
    const b: i32 = 10;  // 简化为一元加在编译器内部处理
    try testing.assert_eq_i32(b, 10, "10 should be folded");
}

// 主函数运行所有测试
fn main() i32 {
    testing.test_suite_begin("Constant Folding Tests");
    
    testing.run_test("basic_add", test_constant_folding_basic_add);
    testing.run_test("basic_sub", test_constant_folding_basic_sub);
    testing.run_test("basic_mul", test_constant_folding_basic_mul);
    testing.run_test("basic_div", test_constant_folding_basic_div);
    testing.run_test("basic_mod", test_constant_folding_basic_mod);
    testing.run_test("nested", test_constant_folding_nested);
    testing.run_test("complex", test_constant_folding_complex);
    testing.run_test("boolean_and", test_constant_folding_boolean_and);
    testing.run_test("boolean_or", test_constant_folding_boolean_or);
    testing.run_test("boolean_not", test_constant_folding_boolean_not);
    testing.run_test("comparison", test_constant_folding_comparison);
    testing.run_test("unary_minus", test_constant_folding_unary_minus);
    testing.run_test("unary_plus", test_constant_folding_unary_plus);
    
    return testing.test_suite_end();
}
