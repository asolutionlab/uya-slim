// test_null_check.uya - 空指针检测测试
// 
// 功能：验证编译器能够识别空指针检查后的非空状态
//
// 预期：编译成功，指针解引用安全

fn main() i32 {
    var val: i32 = 10;
    var ptr: &i32 = &val;
    
    // 添加空指针检查后，编译器应识别 ptr 非空
    if ptr != null {
        // 在这里 ptr 已知非空，可以安全解引用
        ptr[0] = 42;
        // 验证值是否正确
        if ptr[0] == 42 {
            return 0;  // 成功
        }
    }
    
    return 1;  // 失败
}
