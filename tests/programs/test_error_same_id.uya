// 相同错误名在任意位置得到相同 error_id

use std.testing.check_eq_i32;
use std.testing.check_eq_bool;
use std.testing.check_true;

error SameName;

fn ret_a() !i32 { return error.SameName; }
fn ret_b() !i32 { return error.SameName; }

test "test_same_error_id" {
    const a: i32 = ret_a() catch { 1; };
    const b: i32 = ret_b() catch { 2; };
    const c: i32 = ret_a() catch |e| {
        if (e == error.SameName) { return 3; }
        0;
    };
    check_eq_i32(a, 1);
    check_eq_i32(b, 2);
    check_eq_i32(c, 3);
}
