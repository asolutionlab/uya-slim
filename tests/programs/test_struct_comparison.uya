// 结构体比较完整测试程序
// 测试结构体的 == 和 != 比较运算符（逐字段比较）

use std.testing.expect;
use std.testing.assert_eq_i32;
use std.testing.test_suite_begin;
use std.testing.test_suite_end;
use std.testing.run_test;

struct Point {
    x: i32,
    y: i32,
}

struct Data {
    value: i32,
    flag: bool,
}

struct Nested {
    point: Point,
    count: i32,
}

struct ArrayStruct {
    items: [i32: 3],
    size: i32,
}

struct Empty {
}

fn test_struct_equal() !void {
    var p1: Point = Point{ x: 10, y: 20 };
    var p2: Point = Point{ x: 10, y: 20 };
    try expect(p1 == p2);
}

fn test_struct_not_equal() !void {
    var p1: Point = Point{ x: 10, y: 20 };
    var p3: Point = Point{ x: 10, y: 30 };
    try expect(p1 != p3);
    
    var p4: Point = Point{ x: 20, y: 20 };
    try expect(p1 != p4);
}

fn test_struct_different_fields() !void {
    var d1: Data = Data{ value: 42, flag: true };
    var d2: Data = Data{ value: 100, flag: true };
    try expect(d1 != d2);
    
    var d3: Data = Data{ value: 42, flag: false };
    try expect(d1 != d3);
    
    var d4: Data = Data{ value: 42, flag: true };
    try expect(d1 == d4);
}

fn test_nested_struct_compare() !void {
    var n1: Nested = Nested{
        point: Point{ x: 1, y: 2 },
        count: 10,
    };
    var n2: Nested = Nested{
        point: Point{ x: 1, y: 2 },
        count: 10,
    };
    try expect(n1 == n2);
    
    var n3: Nested = Nested{
        point: Point{ x: 1, y: 3 },
        count: 10,
    };
    try expect(n1 != n3);
    
    var n4: Nested = Nested{
        point: Point{ x: 1, y: 2 },
        count: 20,
    };
    try expect(n1 != n4);
}

fn test_array_field_compare() !void {
    var a1: ArrayStruct = ArrayStruct{
        items: [1, 2, 3],
        size: 3,
    };
    var a2: ArrayStruct = ArrayStruct{
        items: [1, 2, 3],
        size: 3,
    };
    try expect(a1 == a2);
    
    var a3: ArrayStruct = ArrayStruct{
        items: [1, 2, 4],
        size: 3,
    };
    try expect(a1 != a3);
}

fn test_struct_in_conditional() !void {
    var p5: Point = Point{ x: 5, y: 6 };
    var p6: Point = Point{ x: 5, y: 6 };
    var result: i32 = 0;
    if p5 == p6 {
        result = 100;
    } else {
        result = 200;
    }
    try assert_eq_i32(result, 100);
}

fn test_struct_assignment_compare() !void {
    var p9: Point = Point{ x: 10, y: 20 };
    var p10: Point = p9;
    try assert_eq_i32(p10.x, 10);
    try assert_eq_i32(p10.y, 20);
    
    p10.x = 30;
    try assert_eq_i32(p10.x, 30);
    try assert_eq_i32(p10.y, 20);
}

fn test_struct_pointer_compare() !void {
    var p11: Point = Point{ x: 1, y: 2 };
    var ptr1: &Point = &p11;
    var ptr2: &Point = &p11;
    try expect(ptr1 == ptr2);
    
    var p12: Point = Point{ x: 1, y: 2 };
    var ptr3: &Point = &p12;
    try expect(ptr1 != ptr3);
}

fn test_empty_struct_compare() !void {
    var e1: Empty = Empty{};
    var e2: Empty = Empty{};
    try expect(e1 == e2);
}

fn main() i32 {
    test_suite_begin("Struct Comparison Tests");
    run_test("struct equal", test_struct_equal);
    run_test("struct not equal", test_struct_not_equal);
    run_test("struct different fields", test_struct_different_fields);
    run_test("nested struct compare", test_nested_struct_compare);
    run_test("array field compare", test_array_field_compare);
    run_test("struct in conditional", test_struct_in_conditional);
    run_test("struct assignment compare", test_struct_assignment_compare);
    run_test("struct pointer compare", test_struct_pointer_compare);
    run_test("empty struct compare", test_empty_struct_compare);
    return test_suite_end();
}
