// 测试 Uya 函数导出给 C 调用
// 演示如何使用 export fn 让 C 代码可以调用 Uya 函数

// 方式 1：使用 export fn 导出函数给 C 调用
// 生成的 C 代码：int uya_add(int a, int b) { ... }（没有 static）
export fn uya_add(a: i32, b: i32) i32 {
    return a + b;
}

// 方式 2：导出字符串处理函数
// 生成的 C 代码：void uya_print_hello(void) { ... }（没有 static）
export fn uya_print_hello() void {
    // 这里可以调用标准库函数
    // 注意：实际使用时需要链接 Uya 标准库
}

// 方式 3：导出带复杂类型的函数
export fn uya_get_answer() i32 {
    return 42;
}

// 对比：内部函数（C 无法调用）
// 生成的 C 代码：static int internal_func(int x) { ... }（有 static）
fn internal_func(x: i32) i32 {
    return x * 2;
}

fn main() i32 {
    // 测试导出函数
    const result1: i32 = uya_add(10, 20);
    if result1 != 30 {
        return 1;
    }
    
    const result2: i32 = uya_get_answer();
    if result2 != 42 {
        return 2;
    }
    
    // 测试内部函数（仅当前模块可用）
    const result3: i32 = internal_func(21);
    if result3 != 42 {
        return 3;
    }
    
    return 0;
}

