// 测试 union 包含各种指针类型字段
// 验证方案 A 可行性：union 变体可以是指针类型

use std.testing.expect;
use std.testing.assert_eq_i32;
use std.testing.test_suite_begin;
use std.testing.test_suite_end;
use std.testing.run_test;

// 测试 1：union 包含两个相同类型的变体
union SameTypeUnion {
    a: i32,
    b: i32,
}

fn test_union_same_type() !void {
    var u: SameTypeUnion = SameTypeUnion.a(42);
    const result: i32 = match u {
        .a(v) => v,
        .b(v) => v,
    };
    try assert_eq_i32(result, 42);
}

// 测试 2：union 包含指针和整数（不同大小）
union MixedUnion {
    ptr_val: &i32,
    int_val: i32,
}

fn test_union_mixed() !void {
    var u1: MixedUnion = MixedUnion.int_val(100);
    const r1: i32 = match u1 {
        .ptr_val(_) => 0,
        .int_val(v) => v,
    };
    try assert_eq_i32(r1, 100);
}

fn main() i32 {
    test_suite_begin("Union Fields Tests");
    run_test("union same type", test_union_same_type);
    run_test("union mixed", test_union_mixed);
    return test_suite_end();
}
