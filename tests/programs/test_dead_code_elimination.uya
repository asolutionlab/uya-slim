// tests/programs/test_dead_code_elimination.uya
// 测试死代码消除优化

use std.testing;

// 测试恒真条件
test "dead_code_true_condition" {
    var executed: i32 = 0;
    
    if true {
        executed = 1;
    } else {
        executed = 2;  // 死代码，应该被移除
    }
    
    try testing.assert_eq_i32(executed, 1, "true branch should be executed");
}

// 测试恒假条件
test "dead_code_false_condition" {
    var executed: i32 = 0;
    
    if false {
        executed = 1;  // 死代码，应该被移除
    } else {
        executed = 2;
    }
    
    try testing.assert_eq_i32(executed, 2, "false branch should not be executed");
}

// 测试常量布尔条件
test "dead_code_const_condition" {
    const debug: bool = false;
    var log_count: i32 = 0;
    
    if debug {
        log_count = 1;  // 死代码，应该被移除
    }
    
    try testing.assert_eq_i32(log_count, 0, "debug code should be eliminated");
}

// 测试嵌套条件
test "dead_code_nested_condition" {
    const flag: bool = true;
    var result: i32 = 0;
    
    if flag {
        if true {
            result = 1;
        } else {
            result = 2;  // 死代码
        }
    } else {
        result = 3;  // 死代码
    }
    
    try testing.assert_eq_i32(result, 1, "nested dead code should be eliminated");
}

// 测试 else if 链
test "dead_code_elseif_chain" {
    const mode: i32 = 2;
    var result: i32 = 0;
    
    if mode == 1 {
        result = 1;
    } else if mode == 2 {
        result = 2;
    } else {
        result = 3;
    }
    
    try testing.assert_eq_i32(result, 2, "correct branch should be executed");
}

// 测试常量比较条件
test "dead_code_comparison_condition" {
    const x: i32 = 10;
    var executed: i32 = 0;
    
    if x > 5 {
        executed = 1;
    }
    
    try testing.assert_eq_i32(executed, 1, "constant comparison should be optimized");
}

// 主函数运行所有测试
fn main() i32 {
    testing.test_suite_begin("Dead Code Elimination Tests");
    
    testing.run_test("true_condition", test_dead_code_true_condition);
    testing.run_test("false_condition", test_dead_code_false_condition);
    testing.run_test("const_condition", test_dead_code_const_condition);
    testing.run_test("nested_condition", test_dead_code_nested_condition);
    testing.run_test("elseif_chain", test_dead_code_elseif_chain);
    testing.run_test("comparison_condition", test_dead_code_comparison_condition);
    
    return testing.test_suite_end();
}
