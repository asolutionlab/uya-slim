// test_usize_from_ptr.uya - 测试 @usize_from_ptr 内置函数
// 测试从指针转换为 usize 的功能

fn main() i32 {
    // 测试 1: 从 null 指针转换
    const null_ptr: &void = null;
    const addr1: usize = @usize_from_ptr(null_ptr);
    if addr1 != 0 {
        return 1;  // 失败：null 指针应该转换为 0
    }
    
    // 测试 2: 从变量地址转换
    var value: i32 = 42;
    const value_ptr: &i32 = &value;
    const addr2: usize = @usize_from_ptr(value_ptr as &void);
    
    // 验证地址不为 0（变量应该有有效地址）
    if addr2 == 0 {
        return 2;  // 失败：变量地址不应该为 0
    }
    
    // 测试 3: 从数组地址转换
    var arr: [i32: 10] = [];
    const arr_ptr: &i32 = &arr[0];
    const addr3: usize = @usize_from_ptr(arr_ptr as &void);
    
    if addr3 == 0 {
        return 3;  // 失败：数组地址不应该为 0
    }
    
    // 测试 4: 指针算术（配合 @ptr_from_usize）
    const base_addr: usize = @usize_from_ptr(arr_ptr as &void);
    const offset: usize = 4;  // 一个 i32 的大小
    const next_addr: usize = base_addr + offset;
    const next_ptr: &void = @ptr_from_usize(next_addr);
    const verify_addr: usize = @usize_from_ptr(next_ptr);
    
    if verify_addr != next_addr {
        return 4;  // 失败：地址应该一致
    }
    
    return 0;
}

