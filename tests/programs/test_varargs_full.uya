// 可变参数与 @params 全面测试

use std.testing;

fn add_two(a: i32, b: i32) i32 {
    const p: (i32, i32) = @params;
    return p.0 + p.1;
}

fn mul_two(x: i32, y: i32) i32 {
    return @params.0 * @params.1;
}

fn identity_one(n: i32) i32 {
    return n;
}

fn sum_three(a: i32, b: i32, c: i32) i32 {
    const t: (i32, i32, i32) = @params;
    return t.0 + t.1 + t.2;
}

test "test_add_two" {
    testing.assert_eq(add_two(10, 20), 30);
}

test "test_mul_two" {
    testing.assert_eq(mul_two(5, 6), 30);
}

test "test_identity_one" {
    testing.assert_eq(identity_one(42), 42);
}

test "test_sum_three" {
    testing.assert_eq(sum_three(1, 2, 3), 6);
}
