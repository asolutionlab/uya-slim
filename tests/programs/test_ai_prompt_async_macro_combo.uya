// 与 docs/uya_ai_prompt.md「综合示例」同步：
// - export fn main 须为 i32（与 std.runtime.entry 的 main_main() i32 一致，勿用 main() !i32）
// - main 内无 try：!Future / !i32 用 catch 早退

use std.async;

error DivideByZero;

export mc add(a: expr, b: expr) expr {
    @mc_code(@mc_ast({
        const left: i32 = ${a};
        const right: i32 = ${b};
        left + right;
    }));
}

@async_fn
fn async_calculate(a: i32, b: i32) Future<!i32> {
    const sum: i32 = add(a, b);
    return sum;
}

@async_fn
fn async_divide(a: i32, b: i32) Future<!i32> {
    if b == 0 {
        return error.DivideByZero;
    }
    return a / b;
}

export fn main() i32 {
    const macro_chk: i32 = add(1, 2);
    if macro_chk != 3 {
        return 10;
    }

    const calc_fut: Future<!i32> = async_calculate(20, 30);
    const calc_bo: !i32 = block_on<i32>(calc_fut);
    const calc_result: i32 = calc_bo catch |_| {
        return 1;
    };
    @println("加法异步结果 ${calc_result}");

    const divide_fut: Future<!i32> = async_divide(100, 20);
    const divide_bo: !i32 = block_on<i32>(divide_fut);
    const divide_result: i32 = divide_bo catch |_| {
        return 2;
    };
    @println("除法异步结果 ${divide_result}");

    if divide_result != 5 {
        return 3;
    }

    const zdiv_fut: Future<!i32> = async_divide(1, 0);
    const zdiv_bo: !i32 = block_on<i32>(zdiv_fut);
    const _z: i32 = zdiv_bo catch |_| {
        return 0;
    };
    return 12;
}
