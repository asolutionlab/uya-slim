// 测试结构体方法返回错误联合类型

use std.testing;

error TestError;

struct Counter {
    value: i32
}

Counter {
    fn try_inc(self: &Self) !i32 {
        if self.value >= 10 {
            return error.TestError;
        }
        self.value = self.value + 1;
        return self.value;
    }
}

test "test_struct_method_error" {
    var c: Counter = Counter{ value: 5 };
    
    const v1: i32 = c.try_inc() catch {
        return;
    };
    testing.assert_eq(v1, 6);
    testing.assert_eq(c.value, 6);
}
