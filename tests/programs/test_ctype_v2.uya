// test_ctype_v2.uya - ctype 模块测试（新框架版本）
// 使用 lib/std/testing.uya 测试框架

use libc.isalpha;
use libc.isdigit;
use libc.isalnum;
use libc.isspace;
use libc.isupper;
use libc.islower;
use libc.isxdigit;
use libc.isprint;
use libc.toupper;
use libc.tolower;

// 导入测试框架
use std.testing.*;

// ============================================================
// isalpha 测试
// ============================================================

fn test_isalpha() !void {
    // 小写字母应该返回真（非零）
    try expect(isalpha(97) != 0);   // 'a'
    try expect(isalpha(122) != 0);  // 'z'
    try expect(isalpha(110) != 0);  // 'n'
    
    // 大写字母应该返回真
    try expect(isalpha(65) != 0);   // 'A'
    try expect(isalpha(90) != 0);   // 'Z'
    try expect(isalpha(78) != 0);   // 'N'
    
    // 非字母应该返回假（零）
    try expect(isalpha(48) == 0);   // '0'
    try expect(isalpha(57) == 0);   // '9'
    try expect(isalpha(32) == 0);   // ' '
    try expect(isalpha(64) == 0);   // '@'
    try expect(isalpha(123) == 0);  // '{'
}

// ============================================================
// isdigit 测试
// ============================================================

fn test_isdigit() !void {
    // 数字应该返回真
    try expect(isdigit(48) != 0);   // '0'
    try expect(isdigit(57) != 0);   // '9'
    try expect(isdigit(53) != 0);   // '5'
    
    // 非数字应该返回假
    try expect(isdigit(47) == 0);   // '/'
    try expect(isdigit(58) == 0);   // ':'
    try expect(isdigit(65) == 0);   // 'A'
    try expect(isdigit(97) == 0);   // 'a'
}

// ============================================================
// isalnum 测试
// ============================================================

fn test_isalnum() !void {
    // 字母和数字应该返回真
    try expect(isalnum(48) != 0);   // '0'
    try expect(isalnum(57) != 0);   // '9'
    try expect(isalnum(65) != 0);   // 'A'
    try expect(isalnum(90) != 0);   // 'Z'
    try expect(isalnum(97) != 0);   // 'a'
    try expect(isalnum(122) != 0);  // 'z'
    
    // 非字母数字应该返回假
    try expect(isalnum(32) == 0);   // ' '
    try expect(isalnum(64) == 0);   // '@'
    try expect(isalnum(123) == 0);  // '{'
}

// ============================================================
// isspace 测试
// ============================================================

fn test_isspace() !void {
    // 空白字符应该返回真
    try expect(isspace(32) != 0);   // ' '
    try expect(isspace(9) != 0);    // '\t'
    try expect(isspace(10) != 0);   // '\n'
    try expect(isspace(11) != 0);   // '\v'
    try expect(isspace(12) != 0);   // '\f'
    try expect(isspace(13) != 0);   // '\r'
    
    // 非空白字符应该返回假
    try expect(isspace(65) == 0);   // 'A'
    try expect(isspace(48) == 0);   // '0'
}

// ============================================================
// isupper/islower 测试
// ============================================================

fn test_isupper() !void {
    try expect(isupper(65) != 0);   // 'A'
    try expect(isupper(90) != 0);   // 'Z'
    try expect(isupper(97) == 0);   // 'a'
    try expect(isupper(48) == 0);   // '0'
}

fn test_islower() !void {
    try expect(islower(97) != 0);   // 'a'
    try expect(islower(122) != 0);  // 'z'
    try expect(islower(65) == 0);   // 'A'
    try expect(islower(48) == 0);   // '0'
}

// ============================================================
// toupper/tolower 测试
// ============================================================

fn test_toupper() !void {
    // 小写转大写
    try assert_eq_i32(toupper(97), 65, "'a' -> 'A'");
    try assert_eq_i32(toupper(122), 90, "'z' -> 'Z'");
    try assert_eq_i32(toupper(110), 78, "'n' -> 'N'");
    
    // 大写保持不变
    try assert_eq_i32(toupper(65), 65, "'A' -> 'A'");
    try assert_eq_i32(toupper(90), 90, "'Z' -> 'Z'");
    
    // 非字母保持不变
    try assert_eq_i32(toupper(48), 48, "'0' -> '0'");
    try assert_eq_i32(toupper(32), 32, "' ' -> ' '");
}

fn test_tolower() !void {
    // 大写转小写
    try assert_eq_i32(tolower(65), 97, "'A' -> 'a'");
    try assert_eq_i32(tolower(90), 122, "'Z' -> 'z'");
    try assert_eq_i32(tolower(78), 110, "'N' -> 'n'");
    
    // 小写保持不变
    try assert_eq_i32(tolower(97), 97, "'a' -> 'a'");
    try assert_eq_i32(tolower(122), 122, "'z' -> 'z'");
    
    // 非字母保持不变
    try assert_eq_i32(tolower(48), 48, "'0' -> '0'");
    try assert_eq_i32(tolower(32), 32, "' ' -> ' '");
}

// ============================================================
// isxdigit 测试
// ============================================================

fn test_isxdigit() !void {
    // 十六进制数字
    try expect(isxdigit(48) != 0);  // '0'
    try expect(isxdigit(57) != 0);  // '9'
    try expect(isxdigit(97) != 0);  // 'a'
    try expect(isxdigit(102) != 0); // 'f'
    try expect(isxdigit(65) != 0);  // 'A'
    try expect(isxdigit(70) != 0);  // 'F'
    
    // 非十六进制数字
    try expect(isxdigit(103) == 0); // 'g'
    try expect(isxdigit(71) == 0);  // 'G'
    try expect(isxdigit(32) == 0);  // ' '
}

// ============================================================
// isprint 测试
// ============================================================

fn test_isprint() !void {
    // 可打印字符 (0x20-0x7E)
    try expect(isprint(32) != 0);   // ' '
    try expect(isprint(126) != 0);  // '~'
    try expect(isprint(65) != 0);   // 'A'
    
    // 非可打印字符
    try expect(isprint(31) == 0);   // 控制字符
    try expect(isprint(127) == 0);  // DEL
}

// ============================================================
// 主函数
// ============================================================

fn main() i32 {
    test_suite_begin("libc.ctype");
    
    run_test("isalpha", test_isalpha);
    run_test("isdigit", test_isdigit);
    run_test("isalnum", test_isalnum);
    run_test("isspace", test_isspace);
    run_test("isupper", test_isupper);
    run_test("islower", test_islower);
    run_test("toupper", test_toupper);
    run_test("tolower", test_tolower);
    run_test("isxdigit", test_isxdigit);
    run_test("isprint", test_isprint);
    
    return test_suite_end();
}
