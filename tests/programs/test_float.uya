// f32 和 f64 浮点类型测试程序

use std.testing.expect;
use std.testing.assert_eq_i32;
use std.testing.test_suite_begin;
use std.testing.test_suite_end;
use std.testing.run_test;

fn test_f32_basic() !void {
    const x: f32 = 3.14;
    const y: f32 = 2.0;
    var sum: f32 = x + y;
    try expect(sum > 5.13 && sum < 5.15);
}

fn test_f64_basic() !void {
    const a: f64 = 1.5;
    const b: f64 = 2.5;
    var product: f64 = a * b;
    try expect(product > 3.74 && product < 3.76);
}

fn test_mixed_float() !void {
    var f32_val: f32 = 1.0;
    var f64_val: f64 = 2.0;
    var mixed: f64 = f32_val as f64 + f64_val;
    try expect(mixed > 2.99 && mixed < 3.01);
}

fn test_float_comparison() !void {
    try expect(3.14 > 3.0);
    try expect(1.0 == 1.0);
}

fn test_float_unary_neg() !void {
    var neg: f32 = -2.5;
    try expect(neg > -2.51 && neg < -2.49);
}

fn test_float_int_cast() !void {
    const int_val: i32 = 42;
    var f_from_int: f64 = int_val as f64;
    try expect(f_from_int > 41.99 && f_from_int < 42.01);
    
    var i2: i32 = f_from_int as i32;
    try assert_eq_i32(i2, 42);
}

fn test_float_sizeof() !void {
    try assert_eq_i32(@size_of(f32), 4);
    try assert_eq_i32(@size_of(f64), 8);
}

fn test_float_literal() !void {
    var lit: f64 = 1.5e1;  // 15.0
    try expect(lit > 14.99 && lit < 15.01);
}

fn main() i32 {
    test_suite_begin("Float Tests");
    
    run_test("f32 basic", test_f32_basic);
    run_test("f64 basic", test_f64_basic);
    run_test("mixed float", test_mixed_float);
    run_test("float comparison", test_float_comparison);
    run_test("float unary neg", test_float_unary_neg);
    run_test("float int cast", test_float_int_cast);
    run_test("float sizeof", test_float_sizeof);
    run_test("float literal", test_float_literal);
    
    return test_suite_end();
}
