// 测试函数调用和返回值

use std.testing.expect;
use std.testing.test_suite_begin;
use std.testing.test_suite_end;
use std.testing.run_test;

fn get_true() bool {
    return true;
}

fn test_func_return() !void {
    const b: bool = get_true();
    try expect(b);
}

fn main() i32 {
    test_suite_begin("Func Return Tests");
    
    run_test("func return", test_func_return);
    
    return test_suite_end();
}
