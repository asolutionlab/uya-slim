// 测试程序：验证指针类型的成员访问

use std.testing.expect;
use std.testing.assert_eq_i32;
use std.testing.test_suite_begin;
use std.testing.test_suite_end;
use std.testing.run_test;

struct Point {
    x: i32,
    y: i32,
}

struct Rectangle {
    top_left: Point,
    bottom_right: Point,
}

fn test_pointer_param(rect: &Rectangle) !void {
    try assert_eq_i32(rect.top_left.x, 0);
    try assert_eq_i32(rect.top_left.y, 0);
    try assert_eq_i32(rect.bottom_right.x, 10);
    try assert_eq_i32(rect.bottom_right.y, 20);
    
    rect.top_left.x = 5;
    rect.top_left.y = 5;
    rect.bottom_right.x = 15;
    rect.bottom_right.y = 25;
    
    try assert_eq_i32(rect.top_left.x, 5);
    try assert_eq_i32(rect.top_left.y, 5);
    try assert_eq_i32(rect.bottom_right.x, 15);
    try assert_eq_i32(rect.bottom_right.y, 25);
}

fn test_nested_pointer(point: &Point) !void {
    try assert_eq_i32(point.x, 0);
    try assert_eq_i32(point.y, 0);
    
    point.x = 100;
    point.y = 200;
    
    try assert_eq_i32(point.x, 100);
    try assert_eq_i32(point.y, 200);
}

struct Container {
    point: &Point,
}

fn test_struct_with_pointer_field(container: &Container) !void {
    try assert_eq_i32(container.point.x, 0);
    try assert_eq_i32(container.point.y, 0);
    
    container.point.x = 50;
    container.point.y = 60;
    
    try assert_eq_i32(container.point.x, 50);
    try assert_eq_i32(container.point.y, 60);
}

fn main() i32 {
    var rect: Rectangle = Rectangle{
        top_left: Point{ x: 0, y: 0 },
        bottom_right: Point{ x: 10, y: 20 },
    };
    
    var point: Point = Point{ x: 0, y: 0 };
    
    var container_point: Point = Point{ x: 0, y: 0 };
    var container: Container = Container{ point: &container_point };
    
    test_suite_begin("Pointer Member Access Tests");
    
    // 内联测试，因为测试函数需要参数
    run_test("pointer param inline", struct {
        fn test() !void {
            try test_pointer_param(&rect);
            try assert_eq_i32(rect.top_left.x, 5);
            try assert_eq_i32(rect.bottom_right.x, 15);
        }
    }.test);
    
    run_test("nested pointer inline", struct {
        fn test() !void {
            try test_nested_pointer(&point);
            try assert_eq_i32(point.x, 100);
            try assert_eq_i32(point.y, 200);
        }
    }.test);
    
    run_test("struct with pointer field inline", struct {
        fn test() !void {
            try test_struct_with_pointer_field(&container);
            try assert_eq_i32(container_point.x, 50);
        }
    }.test);
    
    return test_suite_end();
}
