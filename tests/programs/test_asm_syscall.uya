// test_asm_syscall.uya - @asm 基本语法测试
// 测试 @asm 基本功能，不依赖特定汇编指令

// 测试空指令
fn test_nop() void {
    @asm {
        "nop" ();
    }
}

// 测试单条指令
fn test_single_instruction() void {
    var x: i32 = 10;
    @asm {
        "nop" (x);
    }
}

// 测试输出参数
fn test_output() i32 {
    var result: i32 = 0;
    @asm {
        "nop" (-> result);
    }
    return result;
}

// 测试输入和输出
fn test_input_output() i32 {
    var a: i32 = 10;
    var result: i32 = 0;
    @asm {
        "nop" (a, -> result);
    }
    return result;
}

// 测试多条指令
fn test_multiple_instructions() i32 {
    var x: i32 = 0;
    @asm {
        "nop" (-> x);
        "nop" (x, -> x);
        "nop" (x, -> x);
    }
    return x;
}

// 测试多个输出
fn test_multiple_outputs() i32 {
    var a: i32 = 0;
    var b: i32 = 0;
    @asm {
        "nop" (-> a);
    }
    @asm {
        "nop" (-> b);
    }
    return a + b;
}

// 测试控制流中使用 @asm
fn test_in_if() i32 {
    var x: i32 = 10;
    var result: i32 = 0;
    
    if x > 5 {
        @asm {
            "nop" (x, -> result);
        }
    }
    
    return result;
}

// 测试在循环中使用 @asm
fn test_in_loop() i32 {
    var sum: i32 = 0;
    var i: i32 = 0;
    
    while i < 3 {
        @asm {
            "nop" (sum, -> sum);
        }
        i = i + 1;
    }
    
    return sum;
}

// 主函数
export fn main() i32 {
    // 测试 nop
    test_nop();
    
    // 测试单条指令
    test_single_instruction();
    
    // 测试输出参数
    const out: i32 = test_output();
    
    // 测试输入和输出
    const io: i32 = test_input_output();
    
    // 测试多条指令
    const multi: i32 = test_multiple_instructions();
    
    // 测试多个输出
    const multi_out: i32 = test_multiple_outputs();
    
    // 测试在 if 中使用
    const in_if: i32 = test_in_if();
    
    // 测试在循环中使用
    const in_loop: i32 = test_in_loop();
    
    // 如果到这里没有崩溃，测试通过
    return 0;
}
