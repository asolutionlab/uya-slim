// as! 强转：返回 !T，需 try 或 catch 处理
// 规范 uya.md §11.3

use std.testing;

test "test_as_force_f32" {
    const x: f64 = 3.14;
    const y: f32 = try (x as! f32);
    testing.assert_eq(y > 3.13, true);
    testing.assert_eq(y < 3.15, true);
}

test "test_as_force_with_catch" {
    const large: i32 = 100;
    const f: f32 = large as! f32 catch |_| { 0.0 };
    testing.assert_eq(f > 99.0, true);
    testing.assert_eq(f < 101.0, true);
}

test "test_as_force_f64_to_i32" {
    const pi: f64 = 3.14;
    const n: i32 = try (pi as! i32);
    testing.assert_eq(n, 3);
}
