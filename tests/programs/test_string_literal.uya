// 测试字符串字面量支持

use std.testing;

test "test_string_literal" {
    // 字符串字面量类型为 *byte（FFI 指针类型）
    const s1: *byte = "hello";
    const s2: *byte = "world";
    
    // 验证字符串字面量可以创建
    testing.assert_eq(s1 != null, true);
    testing.assert_eq(s2 != null, true);
}

test "test_string_literal_array" {
    // 字符串作为数组
    const arr: [byte: 6] = "hello";
    testing.assert_eq(arr[0], 104);  // 'h'
    testing.assert_eq(arr[4], 111);  // 'o'
}
