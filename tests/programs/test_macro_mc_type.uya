// 测试 @mc_type 编译时类型反射

use std.testing;

// 定义简化版 TypeInfo 结构体
struct TypeInfo {
    name: *i8,      // 使用指针而非 slice
    size: i32,
    align: i32,
    kind: i32,
    is_integer: bool,
    is_float: bool,
    is_bool: bool,
    is_pointer: bool,
    is_array: bool,
    is_void: bool,
}

// 宏：获取类型信息
mc get_type_info(T: type) expr {
    @mc_type(T);
}

// 宏：获取类型大小
mc get_size(T: type) expr {
    const info: TypeInfo = @mc_type(T);
    info.size;
}

// 宏：检查是否为整数类型
mc is_int(T: type) expr {
    const info: TypeInfo = @mc_type(T);
    info.is_integer;
}

@test
fn test_type_info() void {
    // 测试直接获取类型信息
    const i32_info: TypeInfo = get_type_info(i32);
    testing.assert_eq(i32_info.size, 4);
    testing.assert_eq(i32_info.is_integer, true);
}

@test
fn test_get_size() void {
    testing.assert_eq(get_size(i32), 4);
    testing.assert_eq(get_size(i64), 8);
    testing.assert_eq(get_size(i8), 1);
}

@test
fn test_is_int() void {
    testing.assert_eq(is_int(i32), true);
}

@test
fn test_float_type() void {
    const f64_info: TypeInfo = get_type_info(f64);
    testing.assert_eq(f64_info.size, 8);
    testing.assert_eq(f64_info.is_float, true);
    testing.assert_eq(f64_info.is_integer, false);
}

@test
fn test_bool_type() void {
    const bool_info: TypeInfo = get_type_info(bool);
    testing.assert_eq(bool_info.size, 1);
    testing.assert_eq(bool_info.is_bool, true);
}
