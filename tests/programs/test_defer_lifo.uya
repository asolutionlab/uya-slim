// defer 同作用域内 LIFO：后声明的先执行

use std.testing.expect;
use std.testing.test_suite_begin;
use std.testing.test_suite_end;
use std.testing.run_test;

fn test_defer_lifo() !void {
    var x: i32 = 0;
    {
        defer { x = x + 1; }   // 第2个执行：x = 0+1 = 1
        defer { x = x + 10; }  // 第1个执行：x = 0+10 = 10，然后上面 x = 10+1 = 11
    }
    try expect(x == 11);
}

fn main() i32 {
    test_suite_begin("Defer LIFO Tests");
    
    run_test("defer lifo order", test_defer_lifo);
    
    return test_suite_end();
}
