// null 字面量作为函数返回值测试程序
// 测试 null 字面量在 return 语句中的使用，验证可以返回给任意类型的指针

use std.testing;

struct Node {
    value: i32,
    next: &Node,
}

struct Point {
    x: i32,
    y: i32,
}

// 全局变量用于测试返回指针
var global_x: i32 = 42;

// 返回各种类型的 null
fn return_null_i32() &i32 { return null; }
fn return_null_void() &void { return null; }
fn return_null_node() &Node { return null; }
fn return_null_point() &Point { return null; }
fn return_null_usize() &usize { return null; }
fn return_null_bool() &bool { return null; }
fn return_null_byte() &byte { return null; }

fn conditional_return_null(condition: bool) &i32 {
    if condition { return null; }
    global_x = 42;
    return &global_x;
}

fn multiple_return_null(flag: i32) &Node {
    if flag == 0 { return null; }
    if flag == 1 { return null; }
    return null;
}

@test
fn test_null_i32() void {
    var ptr: &i32 = return_null_i32();
    testing.assert_eq(ptr == null, true);
}

@test
fn test_null_void() void {
    var ptr: &void = return_null_void();
    testing.assert_eq(ptr == null, true);
}

@test
fn test_null_struct() void {
    var node_ptr: &Node = return_null_node();
    testing.assert_eq(node_ptr == null, true);
    
    var point_ptr: &Point = return_null_point();
    testing.assert_eq(point_ptr == null, true);
}

@test
fn test_null_basic_types() void {
    testing.assert_eq(return_null_usize() == null, true);
    testing.assert_eq(return_null_bool() == null, true);
    testing.assert_eq(return_null_byte() == null, true);
}

@test
fn test_conditional_return() void {
    var ptr1: &i32 = conditional_return_null(true);
    testing.assert_eq(ptr1 == null, true);
    
    var ptr2: &i32 = conditional_return_null(false);
    testing.assert_eq(ptr2 == null, false);
    testing.assert_eq(*ptr2, 42);
}

@test
fn test_multiple_return_null() void {
    testing.assert_eq(multiple_return_null(0) == null, true);
    testing.assert_eq(multiple_return_null(1) == null, true);
    testing.assert_eq(multiple_return_null(2) == null, true);
}
