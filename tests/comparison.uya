// 比较运算符测试
// 测试所有比较运算符（<, >, <=, >=, ==, !=）

use std.testing.check_true;

test "test_less_than" {
    const a: i32 = 10;
    const b: i32 = 20;
    check_true(a < b);
}

test "test_greater_than" {
    const a: i32 = 10;
    const b: i32 = 20;
    check_true(b > a);
}

test "test_less_equal" {
    const a: i32 = 10;
    const c: i32 = 10;
    check_true(a <= c);
}

test "test_greater_equal" {
    const a: i32 = 10;
    const b: i32 = 20;
    check_true(b >= a);
}

test "test_equal" {
    const a: i32 = 10;
    const c: i32 = 10;
    check_true(a == c);
}

test "test_not_equal" {
    const a: i32 = 10;
    const b: i32 = 20;
    check_true(a != b);
}
