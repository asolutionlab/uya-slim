// 全局变量测试程序
use std.runtime.entry;

use std.testing.assert_eq_i32;
use std.testing.test_suite_begin;
use std.testing.test_suite_end;
use std.testing.run_test;

var global_value: i32 = 100;

fn read_global() i32 {
    return global_value;
}

fn test_global_read() !void {
    const value: i32 = read_global();
    try assert_eq_i32(value, 100);
}

export fn main() i32 {
    test_suite_begin("Global Var Tests");
    
    run_test("global read", test_global_read);
    
    return test_suite_end();
}
