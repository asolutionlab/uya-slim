// test_pthread_cond.uya - pthread 条件变量测试

use std.runtime.entry;
use libc.pthread;
use std.testing.test_suite_begin;
use std.testing.test_suite_end;
use std.testing.test_pass;
use std.testing.test_fail;
use std.testing.expect;

// 共享数据结构
struct SharedData {
    ready: i32,
    value: i32,
}

// 线程启动函数：等待条件变量
fn thread_wait_cond(arg: &void) &void {
    const data: &SharedData = arg as &SharedData;
    var mutex: pthread_mutex_t = pthread_mutex_t{ state: 0 };
    var cond: pthread_cond_t = pthread_cond_t{ waiters: 0, seq: 0 };

    pthread_mutex_init(&mutex, null as &const pthread_mutexattr_t);
    pthread_cond_init(&cond, null as &const pthread_condattr_t);
    pthread_mutex_lock(&mutex);

    // 等待 ready 变为 1
    while data.ready == 0 {
        pthread_cond_wait(&cond, &mutex);
    }

    // 验证值
    if data.value != 42 {
        pthread_mutex_unlock(&mutex);
        return (1 as &void);
    }

    pthread_mutex_unlock(&mutex);
    pthread_mutex_destroy(&mutex);
    pthread_cond_destroy(&cond);
    return (0 as &void);
}

fn test_pthread_cond_signal_basic() !void {
    var data: SharedData = SharedData{ ready: 0, value: 0 };
    var mutex: pthread_mutex_t = pthread_mutex_t{ state: 0 };
    var cond: pthread_cond_t = pthread_cond_t{ waiters: 0, seq: 0 };

    pthread_mutex_init(&mutex, null as &const pthread_mutexattr_t);
    pthread_cond_init(&cond, null as &const pthread_condattr_t);

    pthread_mutex_lock(&mutex);
    data.value = 42;
    data.ready = 1;
    pthread_cond_signal(&cond);
    pthread_mutex_unlock(&mutex);

    pthread_cond_destroy(&cond);
    pthread_mutex_destroy(&mutex);
    try expect(true);
}

fn test_pthread_cond_broadcast_basic() !void {
    var cond: pthread_cond_t = pthread_cond_t{ waiters: 0, seq: 0 };

    pthread_cond_init(&cond, null as &const pthread_condattr_t);
    pthread_cond_broadcast(&cond);
    pthread_cond_destroy(&cond);

    try expect(true);
}

fn test_pthread_cond_init_destroy() !void {
    var cond: pthread_cond_t = pthread_cond_t{ waiters: 0, seq: 0 };
    try expect(pthread_cond_init(&cond, null as &const pthread_condattr_t) == 0);
    try expect(pthread_cond_destroy(&cond) == 0);
}

export fn main() i32 {
    test_suite_begin("pthread_cond");

    test_pthread_cond_init_destroy() catch {
        test_fail("pthread_cond_init_destroy");
        return test_suite_end();
    };
    test_pass("pthread_cond_init_destroy");

    test_pthread_cond_signal_basic() catch {
        test_fail("pthread_cond_signal_basic");
        return test_suite_end();
    };
    test_pass("pthread_cond_signal_basic");

    test_pthread_cond_broadcast_basic() catch {
        test_fail("pthread_cond_broadcast_basic");
        return test_suite_end();
    };
    test_pass("pthread_cond_broadcast_basic");

    return test_suite_end();
}
