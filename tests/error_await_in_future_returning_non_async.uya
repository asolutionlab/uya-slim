// error_await_in_future_returning_non_async.uya
//
// 功能：验证普通函数即使返回 Future<!T>，也不能使用 @await
// 预期：编译失败，报告 "@await 只能在 @async_fn 函数内使用"

use std.async;

@async_fn
fn async_get() Future<!i32> {
    return Future<!i32>{ state: Poll<!i32>.Ready(ok<i32>(42)) };
}

fn not_async_future() Future<!i32> {
    const result: i32 = try @await async_get();
    return Future<!i32>{ state: Poll<!i32>.Ready(ok<i32>(result)) };
}
