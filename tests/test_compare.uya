// test_compare.uya - 比较运算符测试
// 使用 lib/std/testing.uya 测试框架

use std.testing.assert;
use std.testing.test_suite_begin;
use std.testing.test_suite_end;
use std.testing.run_test;

// ============================================================
// 测试用例
// ============================================================

fn test_compare_gt() !void {
    const x: i32 = 10;
    const result: bool = x > 5;
    try assert(result, "10 > 5 should be true");
    try assert((x > 10) == false, "10 > 10 should be false");
}

fn test_compare_lt() !void {
    const x: i32 = 10;
    try assert((x < 20), "10 < 20 should be true");
    try assert((x < 10) == false, "10 < 10 should be false");
}

fn test_compare_eq() !void {
    const x: i32 = 10;
    try assert(x == 10, "10 == 10 should be true");
    try assert((x == 5) == false, "10 == 5 should be false");
}

fn test_compare_ne() !void {
    const x: i32 = 10;
    try assert(x != 5, "10 != 5 should be true");
    try assert((x != 10) == false, "10 != 10 should be false");
}

fn test_compare_ge() !void {
    const x: i32 = 10;
    try assert(x >= 5, "10 >= 5 should be true");
    try assert(x >= 10, "10 >= 10 should be true");
    try assert((x >= 20) == false, "10 >= 20 should be false");
}

fn test_compare_le() !void {
    const x: i32 = 10;
    try assert(x <= 20, "10 <= 20 should be true");
    try assert(x <= 10, "10 <= 10 should be true");
    try assert((x <= 5) == false, "10 <= 5 should be false");
}

// ============================================================
// 主函数
// ============================================================

fn main() i32 {
    test_suite_begin("Comparison Tests");
    
    run_test("compare_gt", test_compare_gt);
    run_test("compare_lt", test_compare_lt);
    run_test("compare_eq", test_compare_eq);
    run_test("compare_ne", test_compare_ne);
    run_test("compare_ge", test_compare_ge);
    run_test("compare_le", test_compare_le);
    
    return test_suite_end();
}
