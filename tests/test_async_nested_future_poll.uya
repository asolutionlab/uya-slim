// test_async_nested_future_poll.uya
// dedicated 正向回归：nested future poll 与无 await 的 !Future<Future<T>> 返回路径。
//
// 现状边界：
// - `Future<Future<i32>>` 这个值类型本身可以双层 poll，见 `tests/test_async_nested.uya`
// - 无 await 的 `@async_fn` 若返回 `!Future<Future<i32>>`，且 return 表达式里同步 `try`
//   另一个 `!Future<i32>`，当前应能生成通过宿主 cc 编译的 C，并在 poll 后得到内层值
//
// 验证脚本：
//   tests/verify_async_nested_future_boundary.sh

use std.async;
use std.testing.assert_eq_i32;

@async_fn
fn inner_value() !Future<i32> {
    return 42;
}

@async_fn
fn outer_future() !Future<Future<i32>> {
    return try inner_value();
}

test "async_nested_future_poll" {
    const outer: Future<Future<i32>> = try outer_future();
    const w: Waker = Waker{};
    const outer_poll: Poll<Future<i32>> = outer.poll(&w);
    var got: i32 = 0 - 1;

    match outer_poll {
        .Ready(inner) => {
            const inner_poll: Poll<i32> = inner.poll(&w);
            match inner_poll {
                .Ready(value) => { got = value; },
                .Pending(_) => { got = 0 - 2; },
            };
        },
        .Pending(_) => { got = 0 - 3; },
    };

    try assert_eq_i32(got, 42);
}
