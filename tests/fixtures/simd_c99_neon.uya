// 夹具：触发 emit_simd_* 运行时助手，供 AArch64/ARM NEON 交叉编译 C 验证
type Vec4i32 = @vector(i32, 4);
type Vec4i16 = @vector(i16, 4);
type Vec4u32 = @vector(u32, 4);
type Vec4f32 = @vector(f32, 4);
type Mask4 = @mask(4);

export fn main() i32 {
    const a: Vec4i32 = @vector.splat(1);
    const b: Vec4i32 = @vector.splat(2);
    const c: Vec4i32 = a + b;
    const m: Mask4 = c == @vector.splat(3);
    if @vector.all(m) == false {
        return 1;
    }
    const u: Vec4u32 = @vector.splat(1 as u32);
    const mu: Mask4 = u < @vector.splat(2 as u32);
    if @vector.all(mu) == false {
        return 2;
    }
    const ten: Vec4i32 = @vector.splat(10);
    const two_i: Vec4i32 = @vector.splat(2);
    const qi: Vec4i32 = ten / two_i;
    if @vector.all(qi == @vector.splat(5)) == false {
        return 4;
    }
    const u3: Vec4u32 = @vector.splat(3 as u32);
    const u4: Vec4u32 = @vector.splat(4 as u32);
    const pm: Vec4u32 = u3 * u4;
    const qru: Vec4u32 = pm / @vector.splat(2 as u32);
    if @vector.all(qru == @vector.splat(6 as u32)) == false {
        return 5;
    }
    const rmi: Vec4i32 = @vector.splat(17) % @vector.splat(5);
    if @vector.all(rmi == @vector.splat(2)) == false {
        return 6;
    }
    const rmu: Vec4u32 = @vector.splat(17 as u32) % @vector.splat(5 as u32);
    if @vector.all(rmu == @vector.splat(2 as u32)) == false {
        return 7;
    }
    const shl_i: Vec4i32 = @vector.splat(2) << @vector.splat(2);
    if @vector.all(shl_i == @vector.splat(8)) == false {
        return 8;
    }
    const shr_i: Vec4i32 = @vector.splat(8) >> @vector.splat(1);
    if @vector.all(shr_i == @vector.splat(4)) == false {
        return 9;
    }
    const shl_u: Vec4u32 = @vector.splat(2 as u32) << @vector.splat(2 as u32);
    if @vector.all(shl_u == @vector.splat(8 as u32)) == false {
        return 10;
    }
    const shr_u: Vec4u32 = @vector.splat(8 as u32) >> @vector.splat(1 as u32);
    if @vector.all(shr_u == @vector.splat(4 as u32)) == false {
        return 11;
    }
    const i16a: Vec4i16 = @vector.splat(10);
    const i16b: Vec4i16 = @vector.splat(3);
    const i16s: Vec4i16 = i16a - i16b;
    if @vector.all(i16s == @vector.splat(7)) == false {
        return 12;
    }
    const i16m: Vec4i16 = i16b * @vector.splat(4);
    if @vector.all(i16m == @vector.splat(12)) == false {
        return 13;
    }
    const x: Vec4f32 = @vector.splat(1.0f32);
    const y: Vec4f32 = @vector.splat(2.0f32);
    const mf: Mask4 = x < y;
    if @vector.all(mf) == false {
        return 3;
    }
    return 0;
}
