// test_https_google.uya - 测试 Google HTTPS

use tls.https;
use libc.unistd;
use libc.syscall;

fn debug(msg: &[byte]) void {
    _ = sys_write(2, msg.ptr, msg.len) catch {};
}

export fn main() i32 {
    debug(&"Testing Google HTTPS...\n"[0: 25]);
    
    var host: [byte: 11] = "google.com";
    var resp: HttpsResponse = https_get(&host[0], 10, 443, &"/"[0: 1]) catch {
        debug(&"Failed\n"[0: 7]);
        return 1;
    };
    
    debug(&"Success! Status="[0: 19]);
    // Print status
    if resp.status == 200 {
        debug(&"200\n"[0: 4]);
    } else {
        debug(&"other\n"[0: 6]);
    }
    return 0;
}
