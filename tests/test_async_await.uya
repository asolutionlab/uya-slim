// test_async_await.uya
// try @await 基本使用：
// - Ready Future：try @await 返回 !T 的成功值
// - Pending Future：try @await 触发 error.AsyncPending（当前最小闭环语义）

use std.async;
use std.testing.assert_eq_i32;
use std.testing.expect;

fn ready_7() !Future<i32> {
    const p: Poll<i32> = Poll<i32>.Ready(7);
    return Future<i32>{ state: p };
}

fn pending_i32() !Future<i32> {
    const p: Poll<i32> = Poll<i32>.Pending();
    return Future<i32>{ state: p };
}

@async_fn
fn await_ready_7() !Future<i32> {
    const x: i32 = try @await ready_7();
    return x;
}

@async_fn
fn await_pending_should_error() !Future<i32> {
    const _x: i32 = try @await pending_i32();
    _ = _x;
    return 1;
}

fn call_pending_should_error() !void {
    const _f: Future<i32> = try await_pending_should_error();
    _ = _f;
}

test "async_await_ready_returns_value" {
    const f: Future<i32> = try await_ready_7();
    const w: Waker = Waker{};
    const p: Poll<i32> = f.poll(&w);
    var result: i32 = 0 - 1;
    match p {
        .Ready(v) => { result = v; },
        .Pending(_) => { result = 0 - 2; },
    };
    try assert_eq_i32(result, 7);
}

test "async_await_pending_propagates_error" {
    var got_error: bool = false;
    call_pending_should_error() catch {
        got_error = true;
    };
    try expect(got_error);
}

