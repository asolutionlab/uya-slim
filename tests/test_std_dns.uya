test "dns_init_parses_nameserver_port" {
    var client: DnsClient = DnsClient{ nameserver: [0:16], nameserver_len: 0, nameserver_port: 0, timeout_ms: 0, query_id: 0, prefer_family: 0 };
    var resolver: [byte: 16] = "127.0.0.1:53053";
    dns_client_init(&client, &resolver[0: 16]);
    try assert_eq_i32(client.nameserver_len as i32, 4);
    try assert_eq_i32(client.nameserver_port as i32, 53053);
}

test "dns_tcp_fallback_on_truncated_udp" {
    var udp_packet: [byte: 12] = [0x12, 0x34, 0x83, 0x00, 0, 1, 0, 0, 0, 0, 0, 0];
    var tcp_packet: [byte: 45] = [0x12, 0x34, 0x81, 0x00, 0, 1, 0, 1, 0, 0, 0, 0, 7, 101, 120, 97, 109, 112, 108, 101, 3, 99, 111, 109, 0, 0, 1, 0, 1, 0xC0, 0x0C, 0, 1, 0, 1, 0, 0, 0, 60, 0, 4, 5, 6, 7, 8];
    const udp_len: usize = 12;
    const tcp_len: usize = 45;
    var out: [byte: 4] = [0:4];
    var out_len: usize = 0;
    var ttl: usize = 0;
    var n: usize = 0;
    n = dns_client_query_a_with_tcp_fallback_packets(&udp_packet[0], udp_len, &tcp_packet[0], tcp_len, &out[0], 4, &out_len, &ttl) catch {
        try assert_eq_i32(0, 1);
        0 as usize;
    };
    try assert_eq_i32(n as i32, 4);
    try assert_eq_i32(out_len as i32, 4);
    try assert_eq_i32(ttl as i32, 60);
    var expect: [byte: 4] = [5, 6, 7, 8];
    if !bytes_eq(&out[0], &expect[0], 4) {
        try assert_eq_i32(0, 1);
    }
}

test "dns_query_a_with_ttl_from_tcp_fallback" {
    var udp_packet: [byte: 12] = [0x12, 0x34, 0x83, 0x00, 0, 1, 0, 0, 0, 0, 0, 0];
    var tcp_packet: [byte: 45] = [0x12, 0x34, 0x81, 0x00, 0, 1, 0, 1, 0, 0, 0, 0, 7, 101, 120, 97, 109, 112, 108, 101, 3, 99, 111, 109, 0, 0, 1, 0, 1, 0xC0, 0x0C, 0, 1, 0, 1, 0, 0, 0, 60, 0, 4, 5, 6, 7, 8];
    const udp_len: usize = 12;
    const tcp_len: usize = 45;
    var ttl: usize = 0;
    var out: [byte: 4] = [0:4];
    var out_len: usize = 0;
    const n: usize = dns_client_query_a_with_tcp_fallback_packets(&udp_packet[0], udp_len, &tcp_packet[0], tcp_len, &out[0], 4, &out_len, &ttl) catch {
        try assert_eq_i32(0, 1);
        return;
    };
    try assert_eq_i32(n as i32, 4);
    try assert_eq_i32(out_len as i32, 4);
    try assert_eq_i32(ttl as i32, 60);
    var expect: [byte: 4] = [5, 6, 7, 8];
    if !bytes_eq(&out[0], &expect[0], 4) {
        try assert_eq_i32(0, 1);
    }
}

