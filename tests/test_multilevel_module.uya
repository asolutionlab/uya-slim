// test_multilevel_module.uya - 测试多级模块路径（std.io）
use std.runtime.entry;

// 须拉取定义模块，否则仅 `use std.io.file_open` 可能不合并 file.uya，catch 会按非 !T 解析失败
use std.io.file;
use std.io.file_open;
use std.io.file_close;

export fn main() i32 {
    // 测试多级模块路径：std.io
    // 使用实际存在的导出项进行测试
    const path: &const byte = "/dev/null" as &const byte;
    const fd: i32 = file_open(path, 0) catch |err| {
        // 预期返回 -1（暂未实现）
        return 0;
    };
    if fd == -1 {
        return 0;
    }
    
    file_close(fd);
    return 0;
}

