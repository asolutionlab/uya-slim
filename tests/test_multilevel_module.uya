// test_multilevel_module.uya - 测试多级模块路径（std.io）
use std.runtime.entry;

use std.io.fopen;
use std.io.fclose;

export fn main() i32 {
    // 测试多级模块路径：std.io
    // 使用实际存在的导出项进行测试
    const path: &const byte = "/dev/null" as &const byte;
    const handle: &void = fopen(path, 0, 0);
    if handle == null {
        return 1;
    }
    
    const result: i32 = fclose(handle);
    if result != 0 {
        return 1;
    }
    
    return 0;
}

