// 赋值测试
use std.runtime.entry;
// 测试变量赋值（var 变量）

use std.testing.assert_eq_i32;
use std.testing.test_suite_begin;
use std.testing.test_suite_end;
use std.testing.run_test;

fn test_basic_assignment() !void {
    var x: i32 = 10;
    try assert_eq_i32(x, 10);
}

fn test_reassignment() !void {
    var x: i32 = 10;
    x = 20;
    try assert_eq_i32(x, 20);
}

fn test_assignment_with_expr() !void {
    var x: i32 = 10;
    x = x + 5;
    try assert_eq_i32(x, 15);
}

export fn main() i32 {
    test_suite_begin("Assignment Tests");
    run_test("basic assignment", test_basic_assignment);
    run_test("reassignment", test_reassignment);
    run_test("assignment with expr", test_assignment_with_expr);
    return test_suite_end();
}
