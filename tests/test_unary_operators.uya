// 一元运算符完整测试程序
use std.runtime.entry;
// 测试所有一元运算符：!（逻辑非）、-（负号）、&（取地址）、*（解引用）

use std.testing.expect;
use std.testing.assert_eq_i32;
use std.testing.test_suite_begin;
use std.testing.test_suite_end;
use std.testing.run_test;

struct Point {
    x: i32,
    y: i32,
}

fn test_logical_not() !void {
    var bool_val1: bool = true;
    var result1: bool = !bool_val1;
    try expect(result1 == false);
    
    var bool_val2: bool = false;
    var result2: bool = !bool_val2;
    try expect(result2 == true);
    
    var bool_val3: bool = true;
    var result3: bool = !!bool_val3;
    try expect(result3 == true);
}

fn test_logical_not_in_conditional() !void {
    if !true {
        try expect(false);
    }
    if !false {
        // expected
    } else {
        try expect(false);
    }
}

fn test_negation() !void {
    var i32_val1: i32 = 42;
    var result4: i32 = -i32_val1;
    try assert_eq_i32(result4, -42);
    
    var i32_val2: i32 = -10;
    var result5: i32 = -i32_val2;
    try assert_eq_i32(result5, 10);
    
    var i32_val3: i32 = 0;
    var result6: i32 = -i32_val3;
    try assert_eq_i32(result6, 0);
}

fn test_negation_in_expr() !void {
    var i32_val4: i32 = 5;
    var result7: i32 = -i32_val4 + 10;
    try assert_eq_i32(result7, 5);
    
    var i32_val5: i32 = 20;
    var result8: i32 = --i32_val5;
    try assert_eq_i32(result8, 20);
}

fn test_address_of() !void {
    var x: i32 = 42;
    var ptr1: &i32 = &x;
    try expect(ptr1 != null);
    
    *ptr1 = 100;
    try assert_eq_i32(x, 100);
}

fn test_address_of_struct() !void {
    var p: Point = Point{ x: 10, y: 20 };
    var ptr2: &Point = &p;
    try expect(ptr2 != null);
    
    ptr2.x = 30;
    try assert_eq_i32(p.x, 30);
}

fn test_address_of_array() !void {
    var arr: [i32: 3] = [1, 2, 3];
    var ptr3: &i32 = &arr[0];
    try expect(ptr3 != null);
    try assert_eq_i32(*ptr3, 1);
}

fn test_dereference() !void {
    var y: i32 = 50;
    var ptr4: &i32 = &y;
    var value1: i32 = *ptr4;
    try assert_eq_i32(value1, 50);
    
    *ptr4 = 60;
    try assert_eq_i32(y, 60);
}

fn test_dereference_struct() !void {
    var q: Point = Point{ x: 100, y: 200 };
    var ptr5: &Point = &q;
    var point_value: Point = *ptr5;
    try assert_eq_i32(point_value.x, 100);
    try assert_eq_i32(point_value.y, 200);
}

fn test_dereference_array() !void {
    var arr2: [i32: 3] = [10, 20, 30];
    var ptr6: &i32 = &arr2[1];
    var value2: i32 = *ptr6;
    try assert_eq_i32(value2, 20);
    
    *ptr6 = 25;
    try assert_eq_i32(arr2[1], 25);
}

fn test_unary_precedence() !void {
    var i32_val6: i32 = 5;
    var result9: i32 = -i32_val6 * 2;
    try assert_eq_i32(result9, -10);
    
    var i32_val7: i32 = 10;
    var result10: i32 = --i32_val7;
    try assert_eq_i32(result10, 10);
    
    var bool_val4: bool = false;
    var result11: bool = !bool_val4 && true;
    try expect(result11 == true);
}

fn test_combo_address_and_deref() !void {
    var z: i32 = 70;
    var value3: i32 = *&z;
    try assert_eq_i32(value3, 70);
}

export fn main() i32 {
    test_suite_begin("Unary Operators Tests");
    run_test("logical not", test_logical_not);
    run_test("logical not in conditional", test_logical_not_in_conditional);
    run_test("negation", test_negation);
    run_test("negation in expr", test_negation_in_expr);
    run_test("address of", test_address_of);
    run_test("address of struct", test_address_of_struct);
    run_test("address of array", test_address_of_array);
    run_test("dereference", test_dereference);
    run_test("dereference struct", test_dereference_struct);
    run_test("dereference array", test_dereference_array);
    run_test("unary precedence", test_unary_precedence);
    run_test("combo address and deref", test_combo_address_and_deref);
    return test_suite_end();
}
