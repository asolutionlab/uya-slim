// test_setjmp.uya - 测试 libc.setjmp 模块
// 注意：setjmp/longjmp 的完整实现需要编译器内置函数支持
// 这里只测试基础功能

use std.runtime.entry;
// 使用 lib/std/testing.uya 测试框架

use libc.setjmp;
use libc.longjmp;
use libc.sigsetjmp;
use libc.siglongjmp;
use libc._setjmp;
use libc._longjmp;
use libc.jmp_buf;
use libc.sigjmp_buf;
use libc._JB_SIZE;

// 导入测试框架
use std.testing.expect;

test "jmp_buf_size" {
    // 验证 jmp_buf 大小正确 (8 * 8 bytes = 64 bytes)
    var actual_size: usize = @size_of(jmp_buf);
    
    try expect(actual_size == 64);
}

test "sigjmp_buf_size" {
    // 验证 sigjmp_buf 大小正确 (16 * 8 bytes = 128 bytes)
    var actual_size: usize = @size_of(sigjmp_buf);
    
    try expect(actual_size == 128);
}

test "setjmp_initializes_to_zero" {
    var env: jmp_buf = jmp_buf{ data: [0: 8] };
    
    var result: i32 = setjmp(&env);
    
    // setjmp 首次调用应返回 0
    try expect(result == 0);
    
    // 验证 env.data[0] 被初始化为 0
    try expect(env.data[0] == 0);
}

test "setjmp_null_env" {
    // null 环境应返回 0
    var result: i32 = setjmp(null);
    try expect(result == 0);
}

test "sigsetjmp_initializes" {
    var env: sigjmp_buf = sigjmp_buf{ data: [0: 16] };
    
    var result: i32 = sigsetjmp(&env, 0);
    
    // sigsetjmp 首次调用应返回 0
    try expect(result == 0);
}

test "sigsetjmp_null_env" {
    var result: i32 = sigsetjmp(null, 0);
    try expect(result == 0);
}

test "_setjmp_calls_setjmp" {
    var env: jmp_buf = jmp_buf{ data: [0: 8] };
    
    var result: i32 = _setjmp(&env);
    
    // _setjmp 应该与 setjmp 行为相同
    try expect(result == 0);
}

test "jmp_buf_data_access" {
    var env: jmp_buf = jmp_buf{ data: [0: 8] };
    
    // 设置一些数据
    env.data[0] = 1;
    env.data[1] = 2;
    env.data[7] = 8;
    
    try expect(env.data[0] == 1);
    try expect(env.data[1] == 2);
    try expect(env.data[7] == 8);
}

test "sigjmp_buf_data_access" {
    var env: sigjmp_buf = sigjmp_buf{ data: [0: 16] };
    
    // 设置一些数据
    env.data[0] = 100;
    env.data[15] = 200;
    
    try expect(env.data[0] == 100);
    try expect(env.data[15] == 200);
}

test "const_jb_size" {
    // 验证常量定义
    try expect(_JB_SIZE == 8);
}
