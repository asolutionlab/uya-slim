// 深层嵌套if语句测试
use std.runtime.entry;
// 测试4层嵌套的if-else语句

use std.testing.assert_eq_i32;
use std.testing.test_suite_begin;
use std.testing.test_suite_end;
use std.testing.run_test;

fn test_deep_nested_if() !void {
    var result: i32 = 0;
    const a: i32 = 1;
    const b: i32 = 2;
    const c: i32 = 3;
    const d: i32 = 4;
    
    if a > 0 {
        if b > 1 {
            if c > 2 {
                if d > 3 {
                    result = 100;
                } else {
                    result = 200;
                }
            } else {
                result = 300;
            }
        } else {
            result = 400;
        }
    } else {
        result = 500;
    }
    
    try assert_eq_i32(result, 100);
}

fn test_nested_else() !void {
    const e: i32 = 0;
    const a: i32 = 1;
    const b: i32 = 2;
    const c: i32 = 3;
    var result2: i32 = 0;
    
    if e > 0 {
        result2 = 10;
    } else {
        if a > 0 {
            if b > 1 {
                if c > 2 {
                    result2 = 20;
                } else {
                    result2 = 30;
                }
            } else {
                result2 = 40;
            }
        } else {
            result2 = 50;
        }
    }
    
    try assert_eq_i32(result2, 20);
}

export fn main() i32 {
    test_suite_begin("Deep Nested If Tests");
    run_test("deep nested if", test_deep_nested_if);
    run_test("nested else", test_nested_else);
    return test_suite_end();
}
