// error_async_for_iterator_ref_await.uya
// 验证：@async_fn 中带 @await 的迭代器 for 支持 |&item| 引用绑定
// 改为正向回归：value() 返回 &i32，for iter |&item| + @await 应在 async 中正常工作

use std.async;
use std.testing.assert_eq_i32;

error IterEnd;

struct AsyncRangeIterator {
    current: i32,
    end_val: i32,
    started: i32
}

AsyncRangeIterator {
    fn next(self: &Self) !void {
        if self.started == 0 {
            self.started = 1;
        } else {
            self.current = self.current + 1;
        }
        if self.current >= self.end_val {
            return error.IterEnd;
        }
    }

    fn value(self: &Self) &i32 {
        return &self.current;
    }
}

fn make_async_range(start: i32, end_val: i32) AsyncRangeIterator {
    return AsyncRangeIterator{ current: start, end_val: end_val, started: 0 };
}

fn ready_1() Future<!i32> {
    const p: Poll<!i32> = Poll<!i32>.Ready(ok<i32>(1));
    return Future<!i32>{ state: p };
}

@async_fn
fn iterator_ref_with_await() Future<!i32> {
    var iter: AsyncRangeIterator = make_async_range(0, 2);
    var total: i32 = 0;
    for iter |&item| {
        const x: i32 = try @await ready_1();
        total = total + *item + x;
    }
    return total;
}

test "async_for_iterator_ref_await" {
    const fut: Future<!i32> = iterator_ref_with_await();
    const result: !i32 = block_on<i32>(fut);
    const value: i32 = result catch {
        return;
    };
    // iter 0..2: item=0, x=1, total=1; item=1, x=1, total=3
    try assert_eq_i32(value, 3);
}
