// 最简单的 FFI 指针转换测试

use std.testing.check_eq_i32;
use std.testing.check_eq_bool;
use std.testing.check_true;

struct Node {
    id: i32,
}

test "test_ptr_conversion" {
    var node: Node = Node{ id: 1 };
    var node_ptr: &Node = &node;
    var ffi_ptr: *Node = node_ptr as *Node;
    check_eq_i32(ffi_ptr == null, false);
}
