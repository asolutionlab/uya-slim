// 布尔逻辑测试
use std.runtime.entry;
// 测试布尔类型、逻辑运算符（&&, ||, !）和比较运算符

use std.testing.expect;
use std.testing.test_suite_begin;
use std.testing.test_suite_end;
use std.testing.run_test;

fn is_positive(n: i32) bool {
    return n > 0;
}

fn is_even(n: i32) bool {
    return (n % 2) == 0;
}

fn test_is_positive() !void {
    try expect(is_positive(10));
    try expect(!is_positive(-5));
    try expect(!is_positive(0));
}

fn test_is_even() !void {
    try expect(is_even(10));
    try expect(!is_even(7));
}

fn test_logical_or() !void {
    const x: i32 = 10;
    const pos: bool = is_positive(x);
    try expect(false || pos);
}

fn test_logical_and() !void {
    try expect(true && true);
    try expect(!(true && false));
}

fn test_logical_not() !void {
    try expect(!false);
    try expect(!!true);
}

export fn main() i32 {
    test_suite_begin("Boolean Logic Tests");
    run_test("is positive", test_is_positive);
    run_test("is even", test_is_even);
    run_test("logical or", test_logical_or);
    run_test("logical and", test_logical_and);
    run_test("logical not", test_logical_not);
    return test_suite_end();
}
