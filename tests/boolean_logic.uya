// 布尔逻辑测试
// 测试布尔类型、逻辑运算符（&&, ||, !）和比较运算符

use std.testing.check_true;

fn is_positive(n: i32) bool {
    return n > 0;
}

fn is_even(n: i32) bool {
    return (n % 2) == 0;
}

test "test_is_positive" {
    check_true(is_positive(10));
    check_true(!is_positive(-5));
    check_true(!is_positive(0));
}

test "test_is_even" {
    check_true(is_even(10));
    check_true(!is_even(7));
}

test "test_logical_or" {
    const x: i32 = 10;
    const pos: bool = is_positive(x);
    check_true(false || pos);
}

test "test_logical_and" {
    check_true(true && true);
    check_true(!(true && false));
}

test "test_logical_not" {
    check_true(!false);
    check_true(!!true);
}
