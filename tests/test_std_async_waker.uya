// test_std_async_waker.uya - 验证 std.async 模块与 Waker 占位类型可用
// 模块路径：lib/std/async.uya → use std.async

use std.async;
use std.testing.assert_eq_i32;

test "std_async_waker_placeholder" {
    var w: Waker = Waker {};
    _ = w;
    try assert_eq_i32(1, 1);
}

test "std_async_waker_ref" {
    var w: Waker = Waker {};
    const p: &Waker = &w;
    _ = p;
    try assert_eq_i32(1, 1);
}
