// test_async_runtime_shared_semantics.uya - HTTP/DNS/TLS/async_compute shared runtime gate

use std.async;
use std.async_event;
use std.async_scheduler;
use std.http.http1_async;
use std.net.dns;
use std.string.strlen;
use std.thread;
use tls.https;
use std.testing.assert_eq_i32;
use libc.syscall;

error SharedRuntimePipeCreateFailed;
error SharedRuntimeChildSpawnFailed;
error SharedRuntimeSourceOpenFailed;
error SharedRuntimeSourceReadFailed;

const SHARED_RUNTIME_SYS_PIPE2: i64 = 293;
const SHARED_RUNTIME_O_NONBLOCK: i32 = 0x800;
const DNS_SOURCE_PATH: &const byte = "lib/std/net/dns.uya\0" as &const byte;
const HTTPS_SOURCE_PATH: &const byte = "lib/tls/https.uya\0" as &const byte;
const SHARED_RUNTIME_SOURCE_MAX: usize = 131072;

var shared_loop_poll_count: i32 = 0;
var shared_register_count: i32 = 0;
var shared_deregister_count: i32 = 0;
var shared_registered_count: i32 = 0;
var shared_registered_wakers: [usize: 16] = [];
var shared_seen_fd: [i32: 16] = [];
var shared_seen_interest: [i32: 16] = [];
var shared_cancel_seen_count: i32 = 0;

fn shared_runtime_sys_pipe2(pipefd: &i32, flags: i32) !i32 {
    return @syscall(SHARED_RUNTIME_SYS_PIPE2, pipefd as i64, flags as i64) as! i32;
}

fn shared_reset_state() void {
    shared_loop_poll_count = 0;
    shared_register_count = 0;
    shared_deregister_count = 0;
    shared_registered_count = 0;
    shared_cancel_seen_count = 0;
    var i: usize = 0;
    while i < 16 {
        shared_registered_wakers[i] = 0;
        shared_seen_fd[i] = 0;
        shared_seen_interest[i] = 0;
        i = i + 1;
    }
}

fn shared_interest_code(interest: EventKind) i32 {
    match interest {
        .Readable(_) => { return 1; },
        .Writable(_) => { return 2; },
        .ReadWrite(_) => { return 3; },
    };
}

struct SharedRuntimeLoop : EventLoop {
    fn register(self: &Self, fd: i32, interest: EventKind, waker: &Waker) !i32 {
        _ = self;
        const idx: usize = shared_register_count as usize;
        if idx < 16 {
            shared_seen_fd[idx] = fd;
            shared_seen_interest[idx] = shared_interest_code(interest);
        }
        if shared_registered_count < 16 {
            shared_registered_wakers[shared_registered_count as usize] = (waker as &void) as usize;
            shared_registered_count = shared_registered_count + 1;
        }
        shared_register_count = shared_register_count + 1;
        return 0;
    }

    fn deregister(self: &Self, fd: i32) !i32 {
        _ = self;
        _ = fd;
        shared_deregister_count = shared_deregister_count + 1;
        return 0;
    }

    fn poll(self: &Self, timeout_ms: i32) !i32 {
        _ = self;
        _ = timeout_ms;
        shared_loop_poll_count = shared_loop_poll_count + 1;
        var i: i32 = 0;
        while i < shared_registered_count {
            const w: &Waker = (shared_registered_wakers[i as usize] as &void) as &Waker;
            w.wake();
            i = i + 1;
        }
        const woke: i32 = shared_registered_count;
        shared_registered_count = 0;
        return woke;
    }
}

struct SharedRuntimeFuture : Future<!i32> {
    fd: i32,
    interest: i32,
    value: i32,

    fn poll(self: &Self, waker: &Waker) Poll<!i32> {
        if waker.is_cancelled() {
            shared_cancel_seen_count = shared_cancel_seen_count + 1;
            return Poll<!i32>.Ready(error.Cancelled);
        }
        if shared_loop_poll_count == 0 {
            if self.interest == 1 {
                waker.wait_readable(self.fd);
            } else if self.interest == 2 {
                waker.wait_writable(self.fd);
            } else {
                waker.wait_readable(self.fd);
                waker.wait_writable(self.fd);
            }
            return Poll<!i32>.Pending({});
        }
        return Poll<!i32>.Ready(ok<i32>(self.value));
    }

    fn release(self: &Self) void {
        _ = self;
    }
}

fn shared_runtime_future(fd: i32, interest: i32, value: i32) Future<!i32> {
    return SharedRuntimeFuture{ fd: fd, interest: interest, value: value };
}

fn shared_seen(fd: i32, interest: i32) i32 {
    var i: usize = 0;
    var count: i32 = 0;
    while i < 16 {
        if shared_seen_fd[i] == fd && shared_seen_interest[i] == interest {
            count = count + 1;
        }
        i = i + 1;
    }
    return count;
}

fn shared_double_usize(v: usize) usize {
    return v * 2;
}

fn shared_spawn_writer(write_fd: i32) !i32 {
    const fork_result: !i64 = sys_fork();
    const child_pid: i64 = fork_result catch {
        return error.SharedRuntimeChildSpawnFailed;
    };
    if child_pid == 0 {
        const req: TimeSpec = TimeSpec{ tv_sec: 0, tv_nsec: 5 * 1000 * 1000 };
        var rem: TimeSpec = TimeSpec{ tv_sec: 0, tv_nsec: 0 };
        _ = sys_nanosleep(&req, &rem) catch {};
        var src: [byte: 4] = [ 41, 42, 43, 44 ];
        _ = sys_write(write_fd, &src[0] as *const byte, 4) catch {};
        _ = sys_close(write_fd) catch {};
        sys_exit(0);
    }
    return child_pid as i32;
}

fn shared_wait_child(pid: i32) void {
    if pid > 0 {
        var status: i32 = 0;
        _ = sys_waitpid(pid, &status, 0) catch {};
    }
}

fn shared_epoll_registered_count(loop: &LinuxEpoll) i32 {
    var count: i32 = 0;
    var i: i32 = 0;
    while i < loop.slot_capacity {
        if loop.slot_states[i as usize] != 0 {
            count = count + 1;
        }
        i = i + 1;
    }
    return count;
}

fn bytes_equal_at(hay: &const byte, hay_len: usize, start: usize, needle: &const byte, needle_len: usize) bool {
    if start + needle_len > hay_len {
        return false;
    }
    var i: usize = 0;
    while i < needle_len {
        if hay[start + i] != needle[i] {
            return false;
        }
        i = i + 1;
    }
    return true;
}

fn source_contains(hay: &const byte, hay_len: usize, needle: &const byte, needle_len: usize) bool {
    if needle_len == 0 {
        return true;
    }
    if hay_len < needle_len {
        return false;
    }
    var i: usize = 0;
    while i + needle_len <= hay_len {
        if bytes_equal_at(hay, hay_len, i, needle, needle_len) {
            return true;
        }
        i = i + 1;
    }
    return false;
}

fn source_contains_cstr(hay: &const byte, hay_len: usize, needle: &const byte) bool {
    return source_contains(hay, hay_len, needle, strlen(needle));
}

fn read_source(path: &const byte, buf: &byte, cap: usize) !usize {
    const fd: i32 = sys_open(path, O_RDONLY as i32, 0) catch {
        return error.SharedRuntimeSourceOpenFailed;
    };
    const n: isize = sys_read(fd, buf as *byte, cap) catch {
        _ = sys_close(fd) catch {};
        return error.SharedRuntimeSourceReadFailed;
    };
    _ = sys_close(fd) catch {};
    if n < 0 {
        return error.SharedRuntimeSourceReadFailed;
    }
    return (n as! usize).value;
}

test "shared_runtime_matrix_keeps_readiness_wake_cancel_and_cleanup_separate" {
    _ = @size_of(Http1AsyncResponse);
    _ = @size_of(DnsClient);
    _ = @size_of(ThreadPool);
    _ = https_client_config_default();

    shared_reset_state();

    var scheduler: Scheduler = scheduler_new();
    var queue: TaskQueue_i32 = task_queue_i32_new();
    const http_idx: i32 = try queue.push(shared_runtime_future(2101, 2, 11));
    const dns_idx: i32 = try queue.push(shared_runtime_future(2102, 1, 13));
    const tls_idx: i32 = try queue.push(shared_runtime_future(2103, 2, 17));
    const compute_idx: i32 = try queue.push(shared_runtime_future(2104, 1, 19));
    const cancelled_idx: i32 = try queue.push(shared_runtime_future(2105, 1, 23));
    _ = queue.cancel(cancelled_idx);

    const loop: EventLoop = SharedRuntimeLoop{};
    const completed: i32 = try scheduler_run_task_queue_i32_with_event_loop(&scheduler, loop, &queue, 0);

    try assert_eq_i32(completed, 5);
    try assert_eq_i32(shared_loop_poll_count, 1);
    try assert_eq_i32(shared_register_count > 6, true);
    try assert_eq_i32(shared_cancel_seen_count, 1);
    try assert_eq_i32(shared_deregister_count > 0, true);
    try assert_eq_i32(queue.result(http_idx), 11);
    try assert_eq_i32(queue.result(dns_idx), 13);
    try assert_eq_i32(queue.result(tls_idx), 17);
    try assert_eq_i32(queue.result(compute_idx), 19);
    try assert_eq_i32(queue.is_cancelled(cancelled_idx) as i32, 1);
    try assert_eq_i32(queue.error_id(cancelled_idx) as i32, @error_id(error.Cancelled) as i32);
    try assert_eq_i32(shared_seen(2101, 2) > 0, true);
    try assert_eq_i32(shared_seen(2102, 1) > 0, true);
    try assert_eq_i32(shared_seen(2103, 2) > 0, true);
    try assert_eq_i32(shared_seen(2104, 1) > 0, true);
}

test "shared_runtime_linux_epoll_runs_io_future_with_async_compute" {
    var fds: [i32: 2] = [];
    _ = shared_runtime_sys_pipe2(&fds[0], SHARED_RUNTIME_O_NONBLOCK) catch {
        return error.SharedRuntimePipeCreateFailed;
    };
    const read_fd: i32 = fds[0];
    const write_fd: i32 = fds[1];
    const child_pid: i32 = try shared_spawn_writer(write_fd);

    var pool: ThreadPool = thread_pool_new(2);
    defer {
        thread_pool_shutdown(&pool);
    }

    var reader: AsyncFd = async_fd_new(read_fd);
    var buf: [byte: 4] = [];
    var queue: TaskQueue_usize = task_queue_usize_new();
    const compute_idx: i32 = try queue.push(async_compute<usize>(&pool, &shared_double_usize as &void, 21 as usize));
    const fd_idx: i32 = try queue.push(reader.read_exact(&buf[0], 4));

    var scheduler: Scheduler = scheduler_new();
    var epoll_impl: LinuxEpoll = try linux_epoll_create(0);
    const loop: EventLoop = epoll_impl;
    const completed: i32 = try scheduler_run_task_queue_usize_with_event_loop(&scheduler, loop, &queue, 1000);

    try assert_eq_i32(completed, 2);
    try assert_eq_i32(queue.result(compute_idx) as i32, 42);
    try assert_eq_i32(queue.result(fd_idx) as i32, 4);
    try assert_eq_i32(buf[0] as i32, 41);
    try assert_eq_i32(buf[3] as i32, 44);
    try assert_eq_i32(shared_epoll_registered_count(&epoll_impl), 0);

    shared_wait_child(child_pid);
    _ = sys_close(read_fd) catch {};
    _ = sys_close(write_fd) catch {};
    _ = sys_close(epoll_impl.epfd) catch {};
}

test "shared_runtime_dns_and_tls_async_boundaries_use_future_wakers" {
    var dns_src: [byte: SHARED_RUNTIME_SOURCE_MAX] = [0:SHARED_RUNTIME_SOURCE_MAX];
    const dns_len: usize = try read_source(DNS_SOURCE_PATH, &dns_src[0], SHARED_RUNTIME_SOURCE_MAX);
    try assert_eq_i32(source_contains_cstr(&dns_src[0], dns_len, "export fn dns_client_query_a_async(ctx: &DnsClient, host: &const byte, host_len: usize, out: &byte, out_max: usize, out_len: &usize) Future<!usize>\0" as &const byte) as i32, 1);
    try assert_eq_i32(source_contains_cstr(&dns_src[0], dns_len, "struct DnsQueryTransportFuture : Future<!usize>\0" as &const byte) as i32, 1);
    try assert_eq_i32(source_contains_cstr(&dns_src[0], dns_len, "waker.wait_readable\0" as &const byte) as i32, 1);
    try assert_eq_i32(source_contains_cstr(&dns_src[0], dns_len, "waker.wait_writable\0" as &const byte) as i32, 1);

    var https_src: [byte: SHARED_RUNTIME_SOURCE_MAX] = [0:SHARED_RUNTIME_SOURCE_MAX];
    const https_len: usize = try read_source(HTTPS_SOURCE_PATH, &https_src[0], SHARED_RUNTIME_SOURCE_MAX);
    try assert_eq_i32(source_contains_cstr(&https_src[0], https_len, "export fn https_handshake_async(fd: i32, ctx: &SslContext, role: i32) Future<!usize>\0" as &const byte) as i32, 1);
    try assert_eq_i32(source_contains_cstr(&https_src[0], https_len, "export fn https_read_some_async(fd: i32, out: &byte, out_max: usize) Future<!usize>\0" as &const byte) as i32, 1);
    try assert_eq_i32(source_contains_cstr(&https_src[0], https_len, "waker.wait_readable\0" as &const byte) as i32, 1);
    try assert_eq_i32(source_contains_cstr(&https_src[0], https_len, "waker.wait_writable\0" as &const byte) as i32, 1);
}
