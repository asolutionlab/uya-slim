// defer 绑定到当前作用域；嵌套块内层 defer 先于外层执行

use std.testing.expect;
use std.testing.test_suite_begin;
use std.testing.test_suite_end;
use std.testing.run_test;

fn test_defer_nested_scope() !void {
    var a: i32 = 0;
    var b: i32 = 0;
    defer { a = 1; }       // 外层：函数返回时执行
    {
        defer { b = 1; }   // 内层：离开内层块时执行
        a = 10;
    }                     // 离开内层：执行 b=1
    try expect(b == 1);
    // 返回时 a 会被设为 1
}

fn main() i32 {
    test_suite_begin("Defer Scope Tests");
    
    run_test("defer nested scope", test_defer_nested_scope);
    
    return test_suite_end();
}
