// test_pthread.uya - pthread 模块基础测试（零 libpthread 依赖）

use std.runtime.entry;
use libc.pthread;
use std.testing.test_suite_begin;
use std.testing.test_suite_end;
use std.testing.test_pass;
use std.testing.test_fail;
use std.testing.expect;

// 线程启动函数：void* (*)(void*) 兼容
fn thread_start(arg: &void) &void {
    return arg;
}

// 测试 pthread_once 的初始化函数
var _once_init_called: i32 = 0;
fn init_routine(arg: &void) &void {
    _ = arg;
    _once_init_called = _once_init_called + 1;
}

fn test_pthread_once() !void {
    var once: pthread_once_t = pthread_once_t{ state: 0 };
    pthread_once(&once, &init_routine as &void);
    try expect(_once_init_called == 1);

    // 再次调用，不应该重新初始化
    pthread_once(&once, &init_routine as &void);
    try expect(_once_init_called == 1);
}

fn test_pthread_mutex_init_destroy() !void {
    var mutex: pthread_mutex_t = pthread_mutex_t{ state: 0, owner: 0, type: 0 };
    const init_ret: i32 = pthread_mutex_init(&mutex, null as &const pthread_mutexattr_t);
    try expect(init_ret == 0);
    const destroy_ret: i32 = pthread_mutex_destroy(&mutex);
    try expect(destroy_ret == 0);
}

fn test_pthread_create_join() !void {
    var th: pthread_t = pthread_t{ tid: 0, stack: null, stack_size: 0, detached: 0 };
    const create_ret: i32 = pthread_create(&th, null as &const pthread_attr_t, &thread_start as &void, null);
    try expect(create_ret == 0);
    const join_ret: i32 = pthread_join(&th, null as & &void);
    try expect(join_ret == 0);
}

fn test_pthread_mutex_lock_unlock() !void {
    var mutex: pthread_mutex_t = pthread_mutex_t{ state: 0, owner: 0, type: 0 };
    try expect(pthread_mutex_init(&mutex, null as &const pthread_mutexattr_t) == 0);
    try expect(pthread_mutex_lock(&mutex) == 0);
    try expect(pthread_mutex_unlock(&mutex) == 0);
    try expect(pthread_mutex_destroy(&mutex) == 0);
}

fn test_pthread_self_equal() !void {
    const self: pthread_t = pthread_self();
    try expect(pthread_equal(self, self) != 0);
}

fn test_pthread_detach() !void {
    var th: pthread_t = pthread_t{ tid: 0, stack: null, stack_size: 0, detached: 0 };
    try expect(pthread_create(&th, null as &const pthread_attr_t, &thread_start as &void, null) == 0);

    // 测试 detach
    const detach_ret: i32 = pthread_detach(&th);
    try expect(detach_ret == 0);

    // 分离的线程不能再次 join
    const join_ret: i32 = pthread_join(&th, null as & &void);
    try expect(join_ret == 22);
}

fn test_pthread_yield() !void {
    // 测试 pthread_yield 不崩溃
    const ret: i32 = pthread_yield();
    try expect(ret == 0);
}

fn test_pthread_mutex_timedlock() !void {
    var mutex: pthread_mutex_t = pthread_mutex_t{ state: 0, owner: 0, type: 0 };
    try expect(pthread_mutex_init(&mutex, null as &const pthread_mutexattr_t) == 0);

    // 尝试带超时加锁（当前简化实现会立即返回 ETIMEDOUT）
    var timeout: timespec = timespec{ tv_sec: 0, tv_nsec: 1000 };
    const ret: i32 = pthread_mutex_timedlock(&mutex, &timeout);
    // 简化实现可能成功或超时，都不应该返回错误码
    try expect(ret == 0 || ret == 110);

    pthread_mutex_destroy(&mutex);
}

fn test_pthread_cond_timedwait() !void {
    var cond: pthread_cond_t = pthread_cond_t{ waiters: 0, seq: 0 };
    var mutex: pthread_mutex_t = pthread_mutex_t{ state: 0, owner: 0, type: 0 };
    try expect(pthread_cond_init(&cond, null as &const pthread_condattr_t) == 0);
    try expect(pthread_mutex_init(&mutex, null as &const pthread_mutexattr_t) == 0);

    pthread_mutex_lock(&mutex);
    var timeout: timespec = timespec{ tv_sec: 0, tv_nsec: 1000000 };  // 1ms 超时
    const ret: i32 = pthread_cond_timedwait(&cond, &mutex, &timeout);
    // 应该超时返回 ETIMEDOUT (110)，因为没有线程调用 signal
    try expect(ret == 110);

    pthread_mutex_unlock(&mutex);
    pthread_cond_destroy(&cond);
    pthread_mutex_destroy(&mutex);
}

fn test_pthread_spinlock() !void {
    var spin: pthread_spinlock_t = pthread_spinlock_t{ lock: 0 };
    try expect(pthread_spin_init(&spin, 0) == 0);
    // 简化测试：不实际加锁，避免忙等待问题
    try expect(pthread_spin_trylock(&spin) == 0);
    try expect(pthread_spin_unlock(&spin) == 0);
    try expect(pthread_spin_destroy(&spin) == 0);
}

// 测试 pthread_mutexattr
fn test_pthread_mutexattr() !void {
    var attr: pthread_mutexattr_t = pthread_mutexattr_t{ type: 0 };
    try expect(pthread_mutexattr_init(&attr) == 0);

    // 设置普通锁类型
    try expect(pthread_mutexattr_settype(&attr, PTHREAD_MUTEX_NORMAL) == 0);
    var type: i32 = 0;
    try expect(pthread_mutexattr_gettype(&attr, &type) == 0);
    try expect(type == PTHREAD_MUTEX_NORMAL);

    // 设置递归锁类型
    try expect(pthread_mutexattr_settype(&attr, PTHREAD_MUTEX_RECURSIVE) == 0);
    try expect(pthread_mutexattr_gettype(&attr, &type) == 0);
    try expect(type == PTHREAD_MUTEX_RECURSIVE);

    try expect(pthread_mutexattr_destroy(&attr) == 0);
}

// 测试递归锁
fn test_pthread_recursive_mutex() !void {
    var attr: pthread_mutexattr_t = pthread_mutexattr_t{ type: 0 };
    try expect(pthread_mutexattr_init(&attr) == 0);
    try expect(pthread_mutexattr_settype(&attr, PTHREAD_MUTEX_RECURSIVE) == 0);

    var mutex: pthread_mutex_t = pthread_mutex_t{ state: 0, owner: 0, type: 0 };
    try expect(pthread_mutex_init(&mutex, &attr) == 0);

    // 递归加锁应该成功
    try expect(pthread_mutex_lock(&mutex) == 0);
    try expect(pthread_mutex_lock(&mutex) == 0);
    try expect(pthread_mutex_lock(&mutex) == 0);

    // 对应解锁
    pthread_mutex_unlock(&mutex);
    pthread_mutex_unlock(&mutex);
    pthread_mutex_unlock(&mutex);

    pthread_mutex_destroy(&mutex);
    pthread_mutexattr_destroy(&attr);
}

// 测试 pthread_attr
fn test_pthread_attr() !void {
    var attr: pthread_attr_t = pthread_attr_t{ stack_size: 0, detached: 0 };
    try expect(pthread_attr_init(&attr) == 0);

    // 测试默认栈大小
    var stacksize: usize = 0;
    try expect(pthread_attr_getstacksize(&attr, &stacksize) == 0);
    try expect(stacksize > 0);  // 应该返回默认大小

    // 测试设置栈大小
    try expect(pthread_attr_setstacksize(&attr, 1024 * 1024) == 0);  // 1MB
    try expect(pthread_attr_getstacksize(&attr, &stacksize) == 0);
    try expect(stacksize == 1024 * 1024);

    // 测试最小栈大小限制
    try expect(pthread_attr_setstacksize(&attr, 4096) == 22);  // 太小，应该失败

    // 测试分离状态
    var detachstate: i32 = 0;
    try expect(pthread_attr_getdetachstate(&attr, &detachstate) == 0);
    try expect(detachstate == PTHREAD_CREATE_JOINABLE);

    try expect(pthread_attr_setdetachstate(&attr, PTHREAD_CREATE_DETACHED) == 0);
    try expect(pthread_attr_getdetachstate(&attr, &detachstate) == 0);
    try expect(detachstate == PTHREAD_CREATE_DETACHED);

    // 测试无效分离状态
    try expect(pthread_attr_setdetachstate(&attr, 2) == 22);  // 无效值

    try expect(pthread_attr_destroy(&attr) == 0);
}

// 测试使用 attr 创建分离线程
fn test_pthread_attr_detached() !void {
    var attr: pthread_attr_t = pthread_attr_t{ stack_size: 0, detached: 0 };
    try expect(pthread_attr_init(&attr) == 0);
    try expect(pthread_attr_setdetachstate(&attr, PTHREAD_CREATE_DETACHED) == 0);

    var th: pthread_t = pthread_t{ tid: 0, stack: null, stack_size: 0, detached: 0 };
    try expect(pthread_create(&th, &attr, &thread_start as &void, null) == 0);

    // 分离线程不需要 join，应该已经设置 detached 标志
    try expect(th.detached == PTHREAD_CREATE_DETACHED);

    try expect(pthread_attr_destroy(&attr) == 0);
}

// 测试读写锁
fn test_pthread_rwlock() !void {
    var rwlock: pthread_rwlock_t = pthread_rwlock_t{ readers: 0, writer: 0, writer_tid: 0 };
    try expect(pthread_rwlock_init(&rwlock, null) == 0);

    // 测试读锁
    try expect(pthread_rwlock_rdlock(&rwlock) == 0);
    try expect(pthread_rwlock_unlock(&rwlock) == 0);

    // 测试写锁
    try expect(pthread_rwlock_wrlock(&rwlock) == 0);
    try expect(pthread_rwlock_unlock(&rwlock) == 0);

    // 测试尝试读锁
    try expect(pthread_rwlock_tryrdlock(&rwlock) == 0);
    try expect(pthread_rwlock_unlock(&rwlock) == 0);

    // 测试尝试写锁
    try expect(pthread_rwlock_trywrlock(&rwlock) == 0);
    try expect(pthread_rwlock_unlock(&rwlock) == 0);

    try expect(pthread_rwlock_destroy(&rwlock) == 0);
}

// 用于测试取消的线程函数
var _cancel_test_flag: i32 = 0;
fn cancel_test_thread(arg: &void) &void {
    _ = arg;
    // 循环检查取消请求
    var i: i32 = 0;
    while i < 100 {
        pthread_testcancel();
        i = i + 1;
    }
    _cancel_test_flag = 1;
    return null;
}

// 测试线程取消
fn test_pthread_cancel() !void {
    _cancel_test_flag = 0;
    
    var th: pthread_t = pthread_t{ tid: 0, stack: null, stack_size: 0, detached: 0 };
    try expect(pthread_create(&th, null as &const pthread_attr_t, &cancel_test_thread as &void, null) == 0);
    
    // 发送取消请求
    try expect(pthread_cancel(&th) == 0);
    
    // 等待线程结束
    const join_ret: i32 = pthread_join(&th, null as & &void);
    // 线程应该被取消，但我们的简化实现可能无法正确返回 PTHREAD_CANCELED
    // 所以只检查 join 是否成功
    try expect(join_ret == 0);
}

// 测试设置取消状态
fn test_pthread_setcancelstate() !void {
    // 测试设置使能状态
    var oldstate: i32 = 0;
    try expect(pthread_setcancelstate(PTHREAD_CANCEL_ENABLE, &oldstate) == 0);
    
    // 测试设置禁止状态
    try expect(pthread_setcancelstate(PTHREAD_CANCEL_DISABLE, &oldstate) == 0);
    try expect(oldstate == PTHREAD_CANCEL_ENABLE);
    
    // 测试无效参数
    try expect(pthread_setcancelstate(2, null) == 22); // EINVAL
    
    // 测试设置取消类型
    var oldtype: i32 = 0;
    try expect(pthread_setcanceltype(PTHREAD_CANCEL_DEFERRED, &oldtype) == 0);
    try expect(pthread_setcanceltype(PTHREAD_CANCEL_ASYNCHRONOUS, &oldtype) == 0);
    try expect(oldtype == PTHREAD_CANCEL_DEFERRED);
    
    // 测试无效参数
    try expect(pthread_setcanceltype(2, null) == 22); // EINVAL
}

// 用于测试 TLS 的线程函数
var _tls_test_value: i32 = 42;
var _tls_thread_result: i64 = 0;
var _tls_key_seq: i32 = 0;
fn tls_test_thread(arg: &void) &void {
    _ = arg;
    
    // 设置线程特定值
    var key1: pthread_key_t = pthread_key_t{ seq: _tls_key_seq, destructor: null };
    pthread_setspecific(key1, (&_tls_test_value) as &void);
    
    // 获取线程特定值（使用新的副本避免移动问题）
    var key2: pthread_key_t = pthread_key_t{ seq: _tls_key_seq, destructor: null };
    const val: &void = pthread_getspecific(key2);
    const val_ptr: &i32 = val as &i32;
    _tls_thread_result = val_ptr[0] as i64;
    
    return null;
}

// 测试线程特定数据（TLS）
fn test_pthread_key() !void {
    // 测试创建键
    var key: pthread_key_t = pthread_key_t{ seq: 0, destructor: null };
    try expect(pthread_key_create(&key, null) == 0);
    try expect(key.seq > 0);  // 序列号应该被设置
    
    // 测试设置和获取特定于线程的数据
    const test_value: i32 = 123;
    var key_copy: pthread_key_t = pthread_key_t{ seq: key.seq, destructor: key.destructor };
    const set_ret: i32 = pthread_setspecific(key_copy, (&test_value) as &void);
    try expect(set_ret == 0);
    
    var key_copy2: pthread_key_t = pthread_key_t{ seq: key.seq, destructor: key.destructor };
    const retrieved: &void = pthread_getspecific(key_copy2);
    try expect(retrieved != null);
    
    // 使用指针解引用
    const retrieved_ptr: &i32 = retrieved as &i32;
    const val: i32 = retrieved_ptr[0];
    try expect(val == 123);
    
    // 测试删除键
    try expect(pthread_key_delete(&key) == 0);
    
    // 测试无效参数
    try expect(pthread_key_create(null as &pthread_key_t, null) == 22); // EINVAL
    try expect(pthread_key_delete(null as &pthread_key_t) == 22); // EINVAL
    var invalid_key: pthread_key_t = pthread_key_t{ seq: 0, destructor: null };
    try expect(pthread_setspecific(invalid_key, null) == 22); // EINVAL
}

export fn main() i32 {
    test_suite_begin("pthread");

    test_pthread_mutex_init_destroy() catch {
        test_fail("pthread_mutex_init_destroy");
        return test_suite_end();
    };
    test_pass("pthread_mutex_init_destroy");

    test_pthread_create_join() catch {
        test_fail("pthread_create_join");
        return test_suite_end();
    };
    test_pass("pthread_create_join");

    test_pthread_once() catch {
        test_fail("pthread_once");
        return test_suite_end();
    };
    test_pass("pthread_once");

    test_pthread_mutex_lock_unlock() catch {
        test_fail("pthread_mutex_lock_unlock");
        return test_suite_end();
    };
    test_pass("pthread_mutex_lock_unlock");

    test_pthread_self_equal() catch {
        test_fail("pthread_self_equal");
        return test_suite_end();
    };
    test_pass("pthread_self_equal");

    test_pthread_detach() catch {
        test_fail("pthread_detach");
        return test_suite_end();
    };
    test_pass("pthread_detach");

    test_pthread_yield() catch {
        test_fail("pthread_yield");
        return test_suite_end();
    };
    test_pass("pthread_yield");

    test_pthread_mutex_timedlock() catch {
        test_fail("pthread_mutex_timedlock");
        return test_suite_end();
    };
    test_pass("pthread_mutex_timedlock");

    test_pthread_cond_timedwait() catch {
        test_fail("pthread_cond_timedwait");
        return test_suite_end();
    };
    test_pass("pthread_cond_timedwait");

    test_pthread_spinlock() catch {
        test_fail("pthread_spinlock");
        return test_suite_end();
    };
    test_pass("pthread_spinlock");

    test_pthread_mutexattr() catch {
        test_fail("pthread_mutexattr");
        return test_suite_end();
    };
    test_pass("pthread_mutexattr");

    test_pthread_recursive_mutex() catch {
        test_fail("pthread_recursive_mutex");
        return test_suite_end();
    };
    test_pass("pthread_recursive_mutex");

    test_pthread_attr() catch {
        test_fail("pthread_attr");
        return test_suite_end();
    };
    test_pass("pthread_attr");

    test_pthread_attr_detached() catch {
        test_fail("pthread_attr_detached");
        return test_suite_end();
    };
    test_pass("pthread_attr_detached");

    test_pthread_rwlock() catch {
        test_fail("pthread_rwlock");
        return test_suite_end();
    };
    test_pass("pthread_rwlock");

    test_pthread_cancel() catch {
        test_fail("pthread_cancel");
        return test_suite_end();
    };
    test_pass("pthread_cancel");

    test_pthread_setcancelstate() catch {
        test_fail("pthread_setcancelstate");
        return test_suite_end();
    };
    test_pass("pthread_setcancelstate");

    test_pthread_key() catch {
        test_fail("pthread_key");
        return test_suite_end();
    };
    test_pass("pthread_key");

    return test_suite_end();
}
