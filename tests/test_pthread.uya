// test_pthread.uya - pthread 模块基础测试（零 libpthread 依赖）

use std.runtime.entry;
use libc.pthread;
use std.testing.test_suite_begin;
use std.testing.test_suite_end;
use std.testing.test_pass;
use std.testing.test_fail;
use std.testing.expect;

// 线程启动函数：void* (*)(void*) 兼容
fn thread_start(arg: &void) &void {
    return arg;
}

fn test_pthread_mutex_init_destroy() !void {
    var mutex: pthread_mutex_t = pthread_mutex_t{ state: 0 };
    const init_ret: i32 = pthread_mutex_init(&mutex, null as &const pthread_mutexattr_t);
    try expect(init_ret == 0);
    const destroy_ret: i32 = pthread_mutex_destroy(&mutex);
    try expect(destroy_ret == 0);
}

fn test_pthread_create_join() !void {
    var th: pthread_t = pthread_t{ tid: 0, stack: null, stack_size: 0 };
    const create_ret: i32 = pthread_create(&th, null as &const pthread_attr_t, &thread_start as &void, null);
    try expect(create_ret == 0);
    const join_ret: i32 = pthread_join(th, null as & &void);
    try expect(join_ret == 0);
}

fn test_pthread_mutex_lock_unlock() !void {
    var mutex: pthread_mutex_t = pthread_mutex_t{ state: 0 };
    try expect(pthread_mutex_init(&mutex, null as &const pthread_mutexattr_t) == 0);
    try expect(pthread_mutex_lock(&mutex) == 0);
    try expect(pthread_mutex_unlock(&mutex) == 0);
    try expect(pthread_mutex_destroy(&mutex) == 0);
}

export fn main() i32 {
    test_suite_begin("pthread");

    test_pthread_mutex_init_destroy() catch {
        test_fail("pthread_mutex_init_destroy");
        return test_suite_end();
    };
    test_pass("pthread_mutex_init_destroy");

    test_pthread_create_join() catch {
        test_fail("pthread_create_join");
        return test_suite_end();
    };
    test_pass("pthread_create_join");

    test_pthread_mutex_lock_unlock() catch {
        test_fail("pthread_mutex_lock_unlock");
        return test_suite_end();
    };
    test_pass("pthread_mutex_lock_unlock");

    return test_suite_end();
}
