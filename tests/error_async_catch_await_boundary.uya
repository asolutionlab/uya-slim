// error_async_catch_await_boundary.uya
// 记录当前 async 状态机对 catch 表达式处理的已知硬限制。
// 这些用例目前预期失败：当 @await 返回错误联合且 catch 体需要执行时，
// async 状态机尚未正确分发错误路径。
// 后续补齐 async lowering 对 CATCH_EXPR 的支持后，应将本文件中的用例
// 迁移到 test_async_catch_await.uya 中并更新本文件。

use std.async;
use std.testing.assert_eq_i32;

error BoundaryErr;

struct FlipErr : Future<!i32> {
    value: i32,
    fail: i32,
    polled: i32,

    fn poll(self: &Self, waker: &Waker) Poll<!i32> {
        _ = waker;
        if self.polled == 0 {
            self.polled = 1;
            return Poll<!i32>.Pending({});
        }
        if self.fail != 0 {
            return Poll<!i32>.Ready(error.BoundaryErr);
        }
        return Poll<!i32>.Ready(ok<i32>(self.value));
    }

    fn release(self: &Self) void {
        _ = self;
    }
}

fn flip(v: i32, fail: i32) Future<!i32> {
    return FlipErr{ value: v, fail: fail, polled: 0 };
}

// 已知失败：catch 体对 @await 错误结果的恢复路径（return 从 catch 中返回）
@async_fn
fn catch_return_from_error(fail: i32) Future<!i32> {
    const raw: !i32 = @await flip(42, fail);
    const v: i32 = raw catch |err| {
        _ = err;
        return 999;
    };
    return v;
}

// 已知失败：catch 体含 @await
@async_fn
fn catch_with_await_inside(fail: i32) Future<!i32> {
    const raw: !i32 = @await flip(42, fail);
    const v: i32 = raw catch |err| {
        _ = err;
        const fallback: i32 = try @await flip(100, 0);
        return fallback;
    };
    return v;
}

// 已知失败：catch 后继续（非提前返回的值表达式）
@async_fn
fn catch_and_continue(fail: i32) Future<!i32> {
    const raw: !i32 = @await flip(10, fail);
    const a: i32 = raw catch |err| {
        _ = err;
        0;
    };
    return a;
}

// 已知失败：多次 @await + catch 组合
@async_fn
fn multi_catch(fail_a: i32, fail_b: i32) Future<!i32> {
    const raw_a: !i32 = @await flip(5, fail_a);
    const a: i32 = raw_a catch |err| {
        _ = err;
        100;
    };
    const raw_b: !i32 = @await flip(6, fail_b);
    const b: i32 = raw_b catch |err| {
        _ = err;
        200;
    };
    return a + b;
}

// 已知失败：catch + @await + 提前 return
@async_fn
fn catch_early_return_with_await(fail: i32) Future<!i32> {
    const raw: !i32 = @await flip(1, fail);
    const x: i32 = raw catch |err| {
        _ = err;
        const rescue: i32 = try @await flip(777, 0);
        return rescue;
    };
    return x + 1000;
}

// 以下测试当前预期失败：它们触发了状态机对 catch 表达式的处理缺口

test "boundary_catch_return_from_error" {
    const f: Future<!i32> = catch_return_from_error(1);
    const r: !i32 = block_on<i32>(f);
    const v: i32 = r catch { -1; };
    try assert_eq_i32(v, 999);
}

test "boundary_catch_with_await_inside" {
    const f: Future<!i32> = catch_with_await_inside(1);
    const r: !i32 = block_on<i32>(f);
    const v: i32 = r catch { -1; };
    try assert_eq_i32(v, 100);
}

test "boundary_catch_and_continue" {
    const f: Future<!i32> = catch_and_continue(1);
    const r: !i32 = block_on<i32>(f);
    const v: i32 = r catch { -1; };
    try assert_eq_i32(v, 0);
}

test "boundary_multi_catch" {
    const f: Future<!i32> = multi_catch(1, 1);
    const r: !i32 = block_on<i32>(f);
    const v: i32 = r catch { -1; };
    try assert_eq_i32(v, 300);
}

test "boundary_catch_early_return_with_await" {
    const f: Future<!i32> = catch_early_return_with_await(1);
    const r: !i32 = block_on<i32>(f);
    const v: i32 = r catch { -1; };
    try assert_eq_i32(v, 777);
}
