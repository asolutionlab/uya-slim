// Tests for kernel image validation (3-stage)

use kernel.errors;
use kernel.image;
use kernel.rv32_scan;
use std.testing.assert_eq_i32;
use std.crypto.sha256;

// ── Helper: write LE u32/u16 into array ──

fn w32(buf: &[byte], off: usize, val: u32) void {
    buf.ptr[off] = (val & 255u32) as byte;
    buf.ptr[off + 1] = ((val >> 8) & 255u32) as byte;
    buf.ptr[off + 2] = ((val >> 16) & 255u32) as byte;
    buf.ptr[off + 3] = ((val >> 24) & 255u32) as byte;
}

fn w16(buf: &[byte], off: usize, val: u16) void {
    buf.ptr[off] = (val & 255u16) as byte;
    buf.ptr[off + 1] = ((val >> 8) & 255u16) as byte;
}

// Build minimal valid image: 96-byte header + 4-byte code (ecall) = 100 bytes
fn build_test_image(buf: &[byte]) void {
    // Zero out
    var i: usize = 0;
    while i < 100 && i < buf.len {
        buf.ptr[i] = 0;
        i = i + 1;
    }

    w32(buf, 0, IMAGE_MAGIC);       // magic
    w16(buf, 4, 1);                  // format_version
    w16(buf, 6, 1);                  // api_version
    w32(buf, 8, 100);               // image_size
    w32(buf, 12, 0);                // entry_offset
    w32(buf, 16, 4);                // code_size
    w32(buf, 20, 0);                // rodata_size
    w32(buf, 24, 0);                // reloc_count
    buf.ptr[64] = 1;                // build_mode = container
    buf.ptr[65] = image_target_arch_to_byte(ImageTargetArch.ita_rv32);
    w32(buf, 60, 0);                // required_caps

    // Code: ecall = 0x00000073 (LE)
    w32(buf, 96, 115);

    // Compute SHA-256 (sha256 field at offset 28 is already zeroed)
    var digest: [byte: 32] = [];
    sha256_digest(buf, digest[0: 32]);

    // Write hash
    i = 0;
    while i < 32 {
        buf.ptr[28 + i] = digest[i];
        i = i + 1;
    }
}

// ── Header Parse Tests ──

test "image_parse_header_valid" {
    var buf: [byte: 100] = [];
    build_test_image(buf[0: 100]);

    const hdr: ImageHeader = try image_parse_header(buf[0: 100]);
    try assert_eq_i32(hdr.magic as i32, IMAGE_MAGIC as i32);
    try assert_eq_i32(hdr.code_size as i32, 4);
    try assert_eq_i32(hdr.entry_offset as i32, 0);
    try assert_eq_i32(hdr.build_mode as i32, 1);
    try assert_eq_i32(hdr.target_arch as i32, ImageTargetArch.ita_rv32 as i32);
}

test "image_parse_header_bad_magic" {
    var buf: [byte: 100] = [];
    build_test_image(buf[0: 100]);
    buf[1] = 0;  // corrupt magic byte (0x41 → 0x00)
    var failed: i32 = 0;
    const hdr: ImageHeader = image_parse_header(buf[0: 100]) catch |err| {
        failed = 1;
        ImageHeader{ magic: 0, format_version: 0, container_api_version: 0,
            image_size: 0, entry_offset: 0, code_size: 0, rodata_size: 0,
            reloc_count: 0, sha256: [], required_caps: 0, build_mode: 0,
            target_arch: ImageTargetArch.ita_unknown };
    };
    try assert_eq_i32(failed, 1);
}

// ── Stage 1: Integrity Tests ──

test "image_verify_integrity_pass" {
    var buf: [byte: 100] = [];
    build_test_image(buf[0: 100]);
    try image_verify_integrity(buf[0: 100]);
}

test "image_verify_integrity_tampered" {
    var buf: [byte: 100] = [];
    build_test_image(buf[0: 100]);
    buf[97] = 255;  // tamper code byte
    var failed: i32 = 0;
    image_verify_integrity(buf[0: 100]) catch |err| { failed = 1; };
    try assert_eq_i32(failed, 1);
}

// ── Stage 2: Structure Tests ──

test "image_verify_structure_pass" {
    var buf: [byte: 100] = [];
    build_test_image(buf[0: 100]);
    const hdr: ImageHeader = try image_parse_header(buf[0: 100]);
    try image_verify_structure(&hdr, 100);
}

test "image_verify_structure_bad_size" {
    var buf: [byte: 100] = [];
    build_test_image(buf[0: 100]);
    const hdr: ImageHeader = try image_parse_header(buf[0: 100]);
    var failed: i32 = 0;
    image_verify_structure(&hdr, 200) catch |err| { failed = 1; };
    try assert_eq_i32(failed, 1);
}

test "image_verify_structure_bad_arch" {
    var buf: [byte: 100] = [];
    build_test_image(buf[0: 100]);
    buf[65] = image_target_arch_to_byte(ImageTargetArch.ita_unknown);
    var digest: [byte: 32] = [];
    var i: usize = 0;
    while i < 32 {
        buf[28 + i] = 0;
        i = i + 1;
    }
    sha256_digest(buf[0: 100], digest[0: 32]);
    i = 0;
    while i < 32 {
        buf[28 + i] = digest[i];
        i = i + 1;
    }
    const hdr: ImageHeader = try image_parse_header(buf[0: 100]);
    var failed: i32 = 0;
    image_verify_structure(&hdr, 100) catch |err| { failed = 1; };
    try assert_eq_i32(failed, 1);
}

test "image_verify_structure_x86_64_pass" {
    var buf: [byte: 100] = [];
    build_test_image(buf[0: 100]);
    buf[65] = image_target_arch_to_byte(ImageTargetArch.ita_x86_64);
    var digest: [byte: 32] = [];
    var i: usize = 0;
    while i < 32 {
        buf[28 + i] = 0;
        i = i + 1;
    }
    sha256_digest(buf[0: 100], digest[0: 32]);
    i = 0;
    while i < 32 {
        buf[28 + i] = digest[i];
        i = i + 1;
    }
    const hdr: ImageHeader = try image_parse_header(buf[0: 100]);
    try image_verify_structure(&hdr, 100);
}

// ── Stage 3: RV32 Instruction Policy Tests ──

test "rv32_scan_ecall_allowed" {
    var code: [byte: 4] = [115, 0, 0, 0];  // ecall
    try rv32_scan_policy(code[0: 4]);
}

test "rv32_scan_mret_denied" {
    // mret = 0x30200073 → LE: [0x73, 0x00, 0x20, 0x30]
    var code: [byte: 4] = [115, 0, 32, 48];
    var denied: i32 = 0;
    rv32_scan_policy(code[0: 4]) catch |err| { denied = 1; };
    try assert_eq_i32(denied, 1);
}

test "rv32_scan_csrr_denied" {
    // csrrw: opcode=0x73, funct3=001 → insn = 0x1073
    var code: [byte: 4] = [115, 16, 0, 0];
    var denied: i32 = 0;
    rv32_scan_policy(code[0: 4]) catch |err| { denied = 1; };
    try assert_eq_i32(denied, 1);
}

test "rv32_scan_fence_i_denied" {
    // fence.i: opcode=0x0F, funct3=001 → insn = 0x100F
    var code: [byte: 4] = [15, 16, 0, 0];
    var denied: i32 = 0;
    rv32_scan_policy(code[0: 4]) catch |err| { denied = 1; };
    try assert_eq_i32(denied, 1);
}

test "rv32_scan_wfi_denied" {
    // wfi = 0x10500073 → LE: [0x73, 0x00, 0x50, 0x10]
    var code: [byte: 4] = [115, 0, 80, 16];
    var denied: i32 = 0;
    rv32_scan_policy(code[0: 4]) catch |err| { denied = 1; };
    try assert_eq_i32(denied, 1);
}

test "rv32_scan_normal_insn_allowed" {
    // addi x1, x0, 42 = 0x02A00013 → LE: [0x13, 0x00, 0xA0, 0x02]
    var code: [byte: 4] = [19, 0, 160, 2];
    try rv32_scan_policy(code[0: 4]);
}

// ── Full 3-stage Validation ──

test "image_validate_full_pass" {
    var buf: [byte: 100] = [];
    build_test_image(buf[0: 100]);
    const hdr: ImageHeader = try image_validate(buf[0: 100]);
    try assert_eq_i32(hdr.code_size as i32, 4);
}
