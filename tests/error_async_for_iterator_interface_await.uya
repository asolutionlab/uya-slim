// error_async_for_iterator_interface_await.uya
// 预期：编译失败。接口类型变量的 for 迭代是通用语言边界；
// 同步对照见 error_for_iterator_interface_value.uya，不能误报为 async 独有缺口。

use std.async;

error IterEnd;

interface AsyncI32Iterator {
    fn next(self: &Self) !void;
    fn value(self: &Self) i32;
}

struct AsyncRangeIterator : AsyncI32Iterator {
    current: i32,
    end_val: i32,
    started: i32
}

AsyncRangeIterator {
    fn next(self: &Self) !void {
        if self.started == 0 {
            self.started = 1;
        } else {
            self.current = self.current + 1;
        }
        if self.current >= self.end_val {
            return error.IterEnd;
        }
    }

    fn value(self: &Self) i32 {
        return self.current;
    }
}

fn make_async_range_iface(start: i32, end_val: i32) AsyncI32Iterator {
    return AsyncRangeIterator{ current: start, end_val: end_val, started: 0 };
}

fn ready_1() Future<!i32> {
    const p: Poll<!i32> = Poll<!i32>.Ready(ok<i32>(1));
    return Future<!i32>{ state: p };
}

@async_fn
fn fail_interface_iterator_with_await() Future<!i32> {
    var iter: AsyncI32Iterator = make_async_range_iface(0, 2);
    var total: i32 = 0;
    for iter |item| {
        const x: i32 = try @await ready_1();
        total = total + item + x;
    }
    return total;
}

fn main() i32 {
    return 0;
}
