// 测试字符串字面量支持

use std.testing.assert_eq_i32;
use std.testing.assert_eq_bool;
use std.testing.assert_true;

test "test_string_literal" {
    // 字符串字面量类型为 *byte（FFI 指针类型）
    const s1: *byte = "hello";
    const s2: *byte = "world";
    
    // 验证字符串字面量可以创建
    try assert_eq_i32(s1 != null, true);
    try assert_eq_i32(s2 != null, true);
}

test "test_string_literal_array" {
    // 字符串作为数组
    const arr: [byte: 6] = "hello";
    try assert_eq_i32(arr[0], 104);  // 'h'
    try assert_eq_i32(arr[4], 111);  // 'o'
}

test "string_literal_escape_cr_lf" {
    const crlf: [byte: 8] = "a\r\nb";
    try assert_eq_i32(crlf[0], 97);
    try assert_eq_i32(crlf[1], 13);
    try assert_eq_i32(crlf[2], 10);
    try assert_eq_i32(crlf[3], 98);
}

test "string_literal_slice_subslice" {
    const s: &[byte] = &"hello"[0:3];
    try assert_eq_i32(s.len, 3);
    try assert_eq_i32(s.ptr[0], 104);
    try assert_eq_i32(s.ptr[1], 101);
    try assert_eq_i32(s.ptr[2], 108);
}
