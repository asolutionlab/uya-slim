// test_async_await_parse.uya
// 验证 @async_fn 与 @await 解析及 @await 上下文校验（仅允许在 async 函数内）

use std.testing.assert_eq_i32;

@async_fn
fn async_return_value() i32 {
    return 42;
}

@async_fn
fn async_call_async() i32 {
    const val: i32 = @await async_return_value();
    return val;
}

test "async_fn_definition" {
    const result: i32 = async_return_value();
    try assert_eq_i32(result, 42);
}

test "async_call_async_with_await" {
    const result: i32 = async_call_async();
    try assert_eq_i32(result, 42);
}
