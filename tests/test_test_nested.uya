// 嵌套块中的测试单元
use std.runtime.entry;

use std.testing.assert_eq_i32;
use std.testing.test_suite_begin;
use std.testing.test_suite_end;
use std.testing.run_test;

fn test_in_function() !void {
    const x: i32 = 42;
    try assert_eq_i32(x, 42);
}

fn test_in_nested_block() !void {
    const y: i32 = 100;
    try assert_eq_i32(y, 100);
}

export fn main() i32 {
    test_suite_begin("Test Nested Tests");
    run_test("in function", test_in_function);
    run_test("in nested block", test_in_nested_block);
    return test_suite_end();
}
