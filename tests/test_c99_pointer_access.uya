// 测试程序：专门测试 C99 代码生成器中的指针访问
// 验证生成的 C 代码是否正确使用 -> 操作符

use std.testing.expect;
use std.testing.assert_eq_i32;
use std.testing.test_suite_begin;
use std.testing.test_suite_end;
use std.testing.run_test;

struct CodeGen {
    count: i32,
    name: &byte,
}

struct Parser {
    codegen: &CodeGen,
    token_count: i32,
}

fn test_single_pointer() !void {
    var codegen: CodeGen = CodeGen{ count: 0, name: null };
    const count: i32 = codegen.count;
    try assert_eq_i32(count, 0);
    
    codegen.count = 10;
    try assert_eq_i32(codegen.count, 10);
}

fn test_nested_pointer() !void {
    var codegen: CodeGen = CodeGen{ count: 0, name: null };
    var parser: Parser = Parser{ codegen: &codegen, token_count: 0 };
    
    const count: i32 = parser.codegen.count;
    try assert_eq_i32(count, 0);
    
    parser.codegen.count = 20;
    try assert_eq_i32(parser.codegen.count, 20);
    
    const cg: &CodeGen = parser.codegen;
    cg.count = 30;
    try assert_eq_i32(parser.codegen.count, 30);
    cg.count = 20;
    
    parser.token_count = 5;
    try assert_eq_i32(parser.token_count, 5);
}

fn test_local_pointer() !void {
    var codegen: CodeGen = CodeGen{ count: 0, name: null };
    const ptr: &CodeGen = &codegen;
    
    try expect(ptr.count == 0);
    
    ptr.count = 30;
    try assert_eq_i32(codegen.count, 30);
}

fn test_struct_pointer_field() !void {
    var codegen: CodeGen = CodeGen{ count: 0, name: null };
    var parser: Parser = Parser{ codegen: &codegen, token_count: 0 };
    
    const count: i32 = parser.codegen.count;
    try assert_eq_i32(count, 0);
    
    parser.codegen.count = 40;
    try assert_eq_i32(parser.codegen.count, 40);
}

fn main() i32 {
    test_suite_begin("C99 Pointer Access Tests");
    run_test("single pointer", test_single_pointer);
    run_test("nested pointer", test_nested_pointer);
    run_test("local pointer", test_local_pointer);
    run_test("struct pointer field", test_struct_pointer_field);
    return test_suite_end();
}
