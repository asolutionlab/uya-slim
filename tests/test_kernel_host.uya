    try assert_eq_i32(big, 1);
}

test "paging_pt_find_free_skips_valid" {
    var pt: PageTable = PageTable{ entries: [] };
    pt_init(&pt);
    try pt_map(&pt, 0, 0, PTE_R | PTE_U);
    const v: u32 = try pt_find_free_vpn(&pt);
    try assert_eq_i32(v as i32, 1);
}
