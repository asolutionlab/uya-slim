use std.runtime.entry;

enum ExprKind {
    EXPR_IDENT,
    EXPR_UNARY,
    EXPR_BINARY,
    EXPR_CALL
}

enum StmtKind {
    STMT_RETURN
}

struct ExprUnary {
    value: &Expr
}

struct ExprBinary {
    left: &Expr,
    right: &Expr
}

struct ExprCall {
    callee: &Expr,
    args: &Expr,
    arg_count: usize
}

struct Expr {
    kind: ExprKind,
    unary: ExprUnary,
    binary: ExprBinary,
    call: ExprCall
}

struct ReturnStmt {
    value: &Expr
}

struct Stmt {
    kind: StmtKind,
    return_stmt: ReturnStmt
}

struct BlockStmt {
    stmts: &Stmt,
    stmt_count: usize
}

struct FnDecl {
    body: BlockStmt
}

struct Decl {
    fn_decl: FnDecl
}

struct FmtFile {
    decls: &Decl,
    decl_count: usize
}

fn simplify_expr_ast(expr: &Expr) &Expr {
    if expr.kind == ExprKind.EXPR_UNARY {
        expr.unary.value = simplify_expr_ast(expr.unary.value);
        return expr;
    }
    if expr.kind == ExprKind.EXPR_BINARY {
        expr.binary.left = simplify_expr_ast(expr.binary.left);
        expr.binary.right = simplify_expr_ast(expr.binary.right);
        return expr;
    }
    if expr.kind == ExprKind.EXPR_CALL {
        expr.call.callee = simplify_expr_ast(expr.call.callee);
        return expr;
    }
    return expr;
}

export fn simplify_file(file: &FmtFile) void {
    var di: usize = 0;
    while di < file.decl_count {
        var si: usize = 0;
        while si < file.decls[di].fn_decl.body.stmt_count {
            const stmt: &Stmt = &file.decls[di].fn_decl.body.stmts[si];
            if stmt.kind == StmtKind.STMT_RETURN {
                stmt.return_stmt.value = simplify_expr_ast(stmt.return_stmt.value);
            }
            si = si + 1;
        }
        di = di + 1;
    }
}

fn main() i32 { return 0; }
