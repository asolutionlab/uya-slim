// 预期：编译失败。当前 @async_fn 还未实现 CPS/状态机生成，先限制最多 1 个 @await。

use std.async;

fn ready(v: i32) !Future<i32> {
    const p: Poll<i32> = Poll<i32>.Ready(v);
    return Future<i32>{ state: p };
}

@async_fn
fn two_awaits() !Future<i32> {
    const a: i32 = try @await ready(1);
    const b: i32 = try @await ready(2);
    return a + b;
}

test "expect_compile_fail" {
