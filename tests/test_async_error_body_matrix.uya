// Regression: async function bodies handle try/catch/error return/!T like sync bodies.

use std.async;
use std.testing.assert_eq_i32;

error AsyncBodyMatrixBoom;

fn ready_matrix(value: i32, fail: i32) Future<!i32> {
    if fail != 0 {
        return Future<!i32>{ state: Poll<!i32>.Ready(error.AsyncBodyMatrixBoom) };
    }
    return Future<!i32>{ state: Poll<!i32>.Ready(ok<i32>(value)) };
}

fn sync_matrix_value(value: i32, fail: i32) !i32 {
    if fail != 0 {
        return error.AsyncBodyMatrixBoom;
    }
    return value;
}

fn sync_error_body_matrix(mode: i32) !i32 {
    if mode == 4 {
        return error.AsyncBodyMatrixBoom;
    }
    var fail_try: i32 = 0;
    if mode == 1 {
        fail_try = 1;
    }
    var total: i32 = 1;
    const a: i32 = try sync_matrix_value(10, fail_try);
    total = total + a;

    var fail_catch: i32 = 0;
    if mode == 2 {
        fail_catch = 1;
    }
    const raw: !i32 = sync_matrix_value(20, fail_catch);
    const b: i32 = raw catch |err| {
        _ = err;
        total = total + 100;
        5;
    };
    total = total + b;

    if mode == 3 {
        return error.AsyncBodyMatrixBoom;
    }
    return total;
}

@async_fn
fn async_error_body_matrix(mode: i32) Future<!i32> {
    if mode == 4 {
        return error.AsyncBodyMatrixBoom;
    }
    var fail_try: i32 = 0;
    if mode == 1 {
        fail_try = 1;
    }
    var total: i32 = 1;
    const a: i32 = try @await ready_matrix(10, fail_try);
    total = total + a;

    var fail_catch: i32 = 0;
    if mode == 2 {
        fail_catch = 1;
    }
    const raw: !i32 = @await ready_matrix(20, fail_catch);
    const b: i32 = raw catch |err| {
        _ = err;
        total = total + 100;
        5;
    };
    total = total + b;

    if mode == 3 {
        return error.AsyncBodyMatrixBoom;
    }
    return total;
}

fn normalize_matrix_result(result: !i32) i32 {
    return result catch |err| {
        if @error_id(err) == @error_id(error.AsyncBodyMatrixBoom) {
            return 0 - 700;
        }
        return 0 - 701;
    };
}

fn assert_sync_async_mode(mode: i32) !void {
    const sync_value: i32 = normalize_matrix_result(sync_error_body_matrix(mode));
    const async_value: i32 = normalize_matrix_result(block_on<i32>(async_error_body_matrix(mode)));
    try assert_eq_i32(async_value, sync_value);
}

test "async_error_body_matches_sync_success" {
    try assert_sync_async_mode(0);
}

test "async_error_body_try_propagates" {
    try assert_sync_async_mode(1);
}

test "async_error_body_catch_recovers_await_result" {
    try assert_sync_async_mode(2);
}

test "async_error_body_return_error_after_await" {
    try assert_sync_async_mode(3);
}

test "async_error_body_return_error_before_await" {
    try assert_sync_async_mode(4);
}
