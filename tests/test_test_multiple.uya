// 多个测试单元
use std.runtime.entry;

use std.testing.assert_eq_i32;
use std.testing.test_suite_begin;
use std.testing.test_suite_end;
use std.testing.run_test;

fn test_1() !void {
    const x: i32 = 1;
    try assert_eq_i32(x, 1);
}

fn test_2() !void {
    const y: i32 = 2;
    try assert_eq_i32(y, 2);
}

fn test_3() !void {
    const z: i32 = 3;
    try assert_eq_i32(z, 3);
}

export fn main() i32 {
    test_suite_begin("Test Multiple Tests");
    run_test("test 1", test_1);
    run_test("test 2", test_2);
    run_test("test 3", test_3);
    return test_suite_end();
}
