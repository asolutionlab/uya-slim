test "async_compute_specific_bool" {
    var pool: ThreadPool = thread_pool_new(2);
    defer {
        thread_pool_shutdown(&pool);
    }
    var s: Scheduler = scheduler_new();
    var loop_impl: LinuxEpoll = try thread_test_epoll();
    defer {
        _ = sys_close(loop_impl.epfd);
    }
    const loop: EventLoop = loop_impl;
    var f: AsyncComputeBoolFuture = async_compute_bool(&pool, &bool_not as &void, false);
    const boxed: Future<!bool> = f;
    const result: bool = try scheduler_run_bool_with_event_loop(&s, loop, boxed, 200);
    try assert_eq_i32(result as i32, 1 as i32);
}
