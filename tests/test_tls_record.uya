// test_tls_record.uya - TLS 记录层单元测试
// 阶段 4.1：记录加解密（当前为明文分片）

use std.runtime.entry;
use tls.ssl.record;
use tls.common;

fn test_record_roundtrip() i32 {
    var ctx: RecordCtx = RecordCtx{ write_seq: 0, read_seq: 0, version: 0 };
    record_ctx_init(&ctx, TLS_VERSION_1_2);
    var plain: [byte: 16] = [0x48, 0x69, 0x20, 0x54, 0x4c, 0x53, 0x21, 0x0a, 0, 0, 0, 0, 0, 0, 0, 0];
    const plain_len: usize = 8;
    var cipher: [byte: 64] = [0:64];
    var out_len: usize = 0;
    record_encrypt(&ctx, TLS_RECORD_APPLICATION_DATA, &plain[0], plain_len, &cipher[0], &out_len) catch {
        return 1;
    };
    if out_len != RECORD_HEADER_LEN + plain_len {
        return 2;
    }
    if cipher[0] != TLS_RECORD_APPLICATION_DATA {
        return 3;
    }
    var plain2: [byte: 16] = [0:16];
    var plain2_len: usize = 0;
    var consumed: usize = 0;
    record_decrypt(&ctx, &cipher[0], out_len, &plain2[0], 16, &plain2_len, &consumed) catch {
        return 4;
    };
    if plain2_len != plain_len || consumed != out_len {
        return 5;
    }
    var i: usize = 0;
    while i < plain_len {
        if plain2[i] != plain[i] {
            return 6;
        }
        i = i + 1;
    }
    return 0;
}

export fn main() i32 {
    if test_record_roundtrip() != 0 {
        return 1;
    }
    return 0;
}
