// test_async_event_config.uya - 验证 LinuxEpoll slot / event 容量可配置

use std.async;
use std.async_event;
use std.testing.assert_eq_i32;
use libc.syscall;

const TEST_O_NONBLOCK: i32 = 0x800;

fn test_sys_pipe2(pipefd: &i32, flags: i32) !i32 {
    return @syscall(SYS_pipe2, pipefd as i64, flags as i64) as! i32;
}

fn test_sys_close(fd: i32) !i32 {
    return @syscall(SYS_close, fd as i64) as! i32;
}

test "linux_epoll_configurable_capacity" {
    const ep: LinuxEpoll = try linux_epoll_create_config(0, 2, 1);
    try assert_eq_i32(linux_epoll_slot_capacity(&ep), 2);
    try assert_eq_i32(linux_epoll_event_capacity(&ep), 1);

    var fds1: [i32: 2] = [];
    var fds2: [i32: 2] = [];
    var fds3: [i32: 2] = [];
    _ = try test_sys_pipe2(&fds1[0], TEST_O_NONBLOCK);
    _ = try test_sys_pipe2(&fds2[0], TEST_O_NONBLOCK);
    _ = try test_sys_pipe2(&fds3[0], TEST_O_NONBLOCK);

    var w1: Waker = Waker{};
    var w2: Waker = Waker{};
    var w3: Waker = Waker{};
    _ = try ep.register(fds1[0], EventKind.Readable({}), &w1);
    _ = try ep.register(fds2[0], EventKind.Readable({}), &w2);

    const third: !i32 = ep.register(fds3[0], EventKind.Readable({}), &w3);
    if third.error_id == 0 {
        _ = test_sys_close(fds1[0]);
        _ = test_sys_close(fds1[1]);
        _ = test_sys_close(fds2[0]);
        _ = test_sys_close(fds2[1]);
        _ = test_sys_close(fds3[0]);
        _ = test_sys_close(fds3[1]);
        try assert_eq_i32(0, 1);
        return;
    }

    try assert_eq_i32(linux_epoll_registered_count(&ep), 2);

    _ = ep.deregister(fds1[0]) catch {};
    _ = ep.deregister(fds2[0]) catch {};
    _ = test_sys_close(fds1[0]);
    _ = test_sys_close(fds1[1]);
    _ = test_sys_close(fds2[0]);
    _ = test_sys_close(fds2[1]);
    _ = test_sys_close(fds3[0]);
    _ = test_sys_close(fds3[1]);
}

test "linux_epoll_default_capacity_is_compatible" {
    const ep: LinuxEpoll = try linux_epoll_create(0);
    try assert_eq_i32(linux_epoll_slot_capacity(&ep), 1024);
    try assert_eq_i32(linux_epoll_event_capacity(&ep), 1024);
}
