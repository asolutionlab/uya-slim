// error_await_outside_async.uya
//
// 功能：验证 @await 只能在 @async_fn 函数内使用
// 预期：编译失败，报告 "@await 只能在 @async_fn 函数内使用"

use std.async;

@async_fn
fn async_get() Future<!i32> {
    return Future<!i32>{ state: Poll<!i32>.Ready(ok<i32>(42)) };
}

fn not_async() i32 {
    const result: !i32 = @await async_get();
    return result catch { 0; };
}
