// 联合体（union）测试：定义、创建、match 访问
use std.runtime.entry;

use std.testing.expect;
use std.testing.assert_eq_i32;
use std.testing.test_suite_begin;
use std.testing.test_suite_end;
use std.testing.run_test;

union IntOrFloat {
    i: i32,
    f: f64,
}

fn test_union_create() !void {
    const vi: IntOrFloat = IntOrFloat.i(42);
    const vf: IntOrFloat = IntOrFloat.f(3.14);
    try expect(true);
}

fn test_union_match_extract() !void {
    const vi: IntOrFloat = IntOrFloat.i(42);
    const ri: i32 = match vi {
        .i(x) => x,
        .f(_) => 0,
    };
    try assert_eq_i32(ri, 42);
}

fn test_union_match_float() !void {
    const vf: IntOrFloat = IntOrFloat.f(3.14);
    const rf: f64 = match vf {
        .i(_) => 0.0,
        .f(x) => x,
    };
    try expect(rf >= 3.13 && rf <= 3.15);
}

fn test_union_match_stmt() !void {
    const vi: IntOrFloat = IntOrFloat.i(42);
    var n: i32 = 0;
    match vi {
        .i(x) => { n = x; },
        .f(_) => { n = -1; },
    };
    try assert_eq_i32(n, 42);
}

export fn main() i32 {
    test_suite_begin("Union Tests");
    run_test("union create", test_union_create);
    run_test("union match extract", test_union_match_extract);
    run_test("union match float", test_union_match_float);
    run_test("union match stmt", test_union_match_stmt);
    return test_suite_end();
}
