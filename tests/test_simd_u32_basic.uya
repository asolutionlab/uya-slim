// SIMD：无符号 u32 向量 splat、*、/
type Vec4u32 = @vector(u32, 4);
type Mask4 = @mask(4);

export fn main() i32 {
    const a: Vec4u32 = @vector.splat(5);
    const b: Vec4u32 = @vector.splat(3);
    const p: Vec4u32 = a * b;
    const ok1: Mask4 = p == @vector.splat(15);
    if @vector.all(ok1) == false {
        return 1;
    }
    const q: Vec4u32 = p / @vector.splat(3);
    const ok2: Mask4 = q == @vector.splat(5);
    if @vector.all(ok2) == false {
        return 2;
    }
    return 0;
}
