// 测试 main 函数首语句可以是 try 表达式
use std.runtime.entry;

use std.testing.assert_eq_i32;
use std.testing.test_suite_begin;
use std.testing.test_suite_end;
use std.testing.run_test;

fn divide(a: i32, b: i32) !i32 { 
    return a / b; 
}

fn test_main_first_stmt_try() !void {
    // 测试 try 表达式可以在函数首语句使用
    const x: i32 = try divide(10, 2);
    try assert_eq_i32(x, 5);
}

export fn main() i32 {
    test_suite_begin("Main First Stmt Tests");
    run_test("main first stmt try", test_main_first_stmt_try);
    return test_suite_end();
}
