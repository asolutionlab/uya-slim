use std.testing.expect;
use std.runtime.entry;
use std.testing.test_suite_begin;
use std.testing.test_suite_end;
use std.testing.run_test;

fn test_if_return_simple() !void {
    const pos: bool = true;
    var result: i32 = 1;
    if pos {
        result = 0;
    }
    try expect(result == 0);
}

export fn main() i32 {
    test_suite_begin("If Return Simple Tests");
    run_test("if return simple", test_if_return_simple);
    return test_suite_end();
}
