// 数组访问测试
use std.runtime.entry;

use std.testing.assert_eq_i32;
use std.testing.test_suite_begin;
use std.testing.test_suite_end;
use std.testing.run_test;

fn test_array_access() !void {
    const arr: [i32: 5] = [1, 2, 3, 4, 5];
    const x: i32 = arr[0];
    const y: i32 = arr[1];
    const sum: i32 = x + y;
    try assert_eq_i32(sum, 3);
}

fn test_array_element() !void {
    const arr: [i32: 5] = [1, 2, 3, 4, 5];
    try assert_eq_i32(arr[0], 1);
    try assert_eq_i32(arr[4], 5);
}

export fn main() i32 {
    test_suite_begin("Array Access Tests");
    run_test("array access", test_array_access);
    run_test("array element", test_array_element);
    return test_suite_end();
}
