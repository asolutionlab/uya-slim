// match 表达式示例：错误类型匹配

fn example(result: !i32) i32 {
    const value: i32 = match result {
        error.FileNotFound => -1,      // 预定义错误
        error.PermissionDenied => -2,  // 预定义错误
        error.OutOfMemory => -3,       // 运行时错误，无需预定义
        v => v,  // 成功值绑定
        else => -4
    };
    return value;
}
       