    // 声明 3x4 的未初始化 i32 二维数组
    var matrix: [[i32: 4]: 3] = [];
    
    // 手动初始化每个元素
    var i: i32 = 0;
    while i < 3 {
        var j: i32 = 0;
        while j < 4 {
            matrix[i][j] = i * 4 + j;  // 编译器可以证明边界安全
            j = j + 1;
        }
        i = i + 1;
    }
    
    // 使用数组
    const val: i32 = matrix[0][0];
    