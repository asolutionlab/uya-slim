struct Counter {
  value: atomic i32
}

Counter {
  fn inc(self: &Self) i32 {
    self.value += 1;
    return self.value;
  }
}

fn main() i32 {
  var counter: Counter = Counter{ value: 0 };
  const value: i32 = counter.inc();
  if value != 1 {
    return 1;
  }
  if counter.value != 1 {
    return 2;
  }
  return 0;
}
