extern "libc" fn printf(fmt: *byte, ...) i32;

error ReadFailed;

fn read_file(path: &[byte]) !i32 {
    if path.len == 0 {
        return error.ReadFailed;
    }
    return 42;
}

fn main() i32 {
    const result: i32 = read_file(&"test.txt"[0: 8]) catch {
        printf("Failed to read file\n");
        return 1;
    };
    printf("Read %d bytes\n", result);
    return 0;
}
