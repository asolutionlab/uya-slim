// 文件移动示例（需要声明外部函数）
extern fn open(path: *byte, flags: i32) i32;
extern fn close(fd: i32) i32;

struct File {
    fd: i32
}

fn drop(self: &File) void {
    close(self.fd);
}

fn example() void {
    const file1: File = File{ fd: open("test.txt", 0) };
    const file2: File = file1;  // ✅ 移动
    
    // file2 离开作用域时自动调用 drop，关闭文件
}
