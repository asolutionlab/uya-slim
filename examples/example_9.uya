extern fn printf(fmt: *byte, ...) i32;

fn some_operation() !i32 {
    return 42;
}

fn example() !i32 {
    defer {
        printf("Always cleanup\n");  // 总是执行
    }
    errdefer {
        printf("Error cleanup\n");  // 仅错误时执行
    }
    
    const result: i32 = try some_operation();
    return result;
    
    // 正常返回时：只执行 defer
    // 错误返回时：先执行 errdefer，再执行 defer
}
