// Portable microapp example: relocated data pointer chain

use std.runtime.entry;
use std.microapp.io.write_stdout_bytes;

var g_value: i32 = 7;
var g_ptr: &i32 = &g_value;
var g_ptr2: &&i32 = &g_ptr;

export fn main() i32 {
    if **g_ptr2 != 7 {
        return 1;
    }
    _ = write_stdout_bytes("reloc64 ok\n", 11) catch {
        return 2;
    };
    return 0;
}
