extern "libc" fn write(fd: i32, buf: *byte, len: i32) i32;

interface IWriter {
  fn write(self: &Self, buf: *byte, len: i32) i32;
}

struct Console : IWriter {
  fd: i32,

  fn write(self: &Self, buf: *byte, len: i32) i32 {
    return write(self.fd, buf, len);
  }
}

fn echo(w: IWriter) void {
  const msg: [byte: 7] = "hello\n";
  _ = w.write(&msg[0], 6);
}

fn main() i32 {
  const cons: Console = Console{ fd: 1 };
  echo(cons);
  return 0;
}
