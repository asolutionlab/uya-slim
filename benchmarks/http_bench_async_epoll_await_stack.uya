// benchmarks/http_bench_async_epoll_await_stack.uya - stack-root @async_fn / raw-storage @await benchmark
//
// Based on http_bench_async_epoll_await.uya, but exercises the stack-root
// allocation path enabled by frame_start / frame_stop helpers and
// caller-owned inline await.
//
// Key characteristics:
// 1) The root worker async frame is stack-owned in bench_worker_thread via
//    @frame(bench_worker_async) + root_frame.start()/poll().
// 2) The hot client coroutine is also stack-owned: BenchClientHandle owns raw
//    caller-owned storage for @frame(handle_bench_client) and drives the
//    generated frame.start()/poll()/stop() methods directly.
// 3) Child async frames are inlined into parent frame fields via @await, while
//    read/write futures come from a worker-local stack buffer.
// 4) No heap-backed async frame wrapper is used in the hot path.

use std.async;
use std.async_event;
use std.async_frame.AsyncFramePool;
use std.async_frame.async_frame_pool_init_with_buffer;
use libc.mem;
use libc.heap;
use libc.syscall;
use libc.errno;
use libc.signal;
use libc.pthread;

use std.runtime.get_argc;
use std.runtime.get_argv;
use std.runtime.entry.set_process_stack_limit_bytes;
use libc.atoi;

const BENCH_PORT: u16 = 8876;
const BENCH_MAIN_STACK_BYTES: u64 = 64 as u64 * 1024 * 1024;
const BENCH_WORKER_STACK_BYTES: usize = 8 * 1024 * 1024;
const BACKLOG: i32 = 8192;
const SLOT_READ_CAP: usize = 2048;
const MAX_PATH_LEN: usize = 256;
const SIGPIPE: i32 = 13;
const SIG_IGN: usize = 1;
const BENCH_THREAD_COUNT: i32 = 28;
const BENCH_MAX_THREADS: i32 = 64;
const BENCH_CONTEXT_STACK_BYTES: usize = 512 * 1024;
const BENCH_ASYNC_FRAME_POOL_BYTES: usize = 1024 * 1024;
const BENCH_ASYNC_FRAME_POOL_WORDS: usize = BENCH_ASYNC_FRAME_POOL_BYTES / @size_of(usize);

const g_hello_body: [byte: 6] = "hello";
const g_json_body: [byte: 12] = "{\"ok\":true}";

const BENCH_ASYNC_ERR_EAGAIN: u32 = 11;
const BENCH_ASYNC_ERR_EWOULDBLOCK: u32 = 11;

struct BenchAcceptFuture : Future<!i32> {
    fd: i32,
    nonblocking_ready: i32 = 0,

    fn poll(self: &Self, waker: &Waker) Poll<!i32> {
        if self.nonblocking_ready == 0 {
            const flags_result: !i32 = sys_fcntl(self.fd, F_GETFL, 0);
            const flags: i32 = flags_result catch {
                const err_value: !i32 = flags_result as! i32;
                return Poll<!i32>.Ready(err_value);
            };
            if (flags & O_NONBLOCK) == 0 {
                const set_result: !i32 = sys_fcntl(self.fd, F_SETFL, flags | O_NONBLOCK);
                _ = set_result catch {
                    const err_value: !i32 = set_result as! i32;
                    return Poll<!i32>.Ready(err_value);
                };
            }
            self.nonblocking_ready = 1;
        }
        const result: !i32 = sys_accept(self.fd, null, 0);
        const cfd: i32 = result catch |err| {
            const err_id: u32 = @error_id(err);
            if err_id == BENCH_ASYNC_ERR_EAGAIN || err_id == BENCH_ASYNC_ERR_EWOULDBLOCK {
                waker.wait_readable(self.fd);
                return Poll<!i32>.Pending({});
            }
            const err_value: !i32 = result as! i32;
            return Poll<!i32>.Ready(err_value);
        };
        return async_poll_ready_ok_i32(cfd);
    }

    fn release(self: &Self) void {
        _ = self;
    }
}

fn bench_accept_future(listen_fd: i32) BenchAcceptFuture {
    return BenchAcceptFuture{ fd: listen_fd, nonblocking_ready: 0 };
}

@align(8)
@async_fn fn handle_bench_client(ctx: &BenchContext, cfd: i32, slot: usize) Future<!usize> {
    var read_filled: usize = 0;
    while true {
        if read_filled >= SLOT_READ_CAP {
            return 0 as usize;
        }
        const base: &byte = ctx.bench_slot_buf_base(slot);
        while find_header_end(base, read_filled) == 0 {
            const rn: usize = try @await async_fd_read_future(
                cfd,
                @ptr_from_usize(@usize_from_ptr(base as &void) + read_filled) as &byte,
                SLOT_READ_CAP - read_filled,
            );
            if rn == 0 {
                return 0 as usize;
            }
            read_filled = read_filled + rn;
            if read_filled >= SLOT_READ_CAP {
                return 0 as usize;
            }
        }

        if !ctx.prepare_bench_client_response(slot, read_filled) {
            return 0 as usize;
        }

        const slot_ref: &BenchSlot = &ctx.slots[slot];
        while slot_ref.cli_woff < slot_ref.cli_resp_len {
            const wn: usize = try @await async_fd_write_future(
                cfd,
                @ptr_from_usize(@usize_from_ptr(slot_ref.cli_hdr_line_base() as &void) + slot_ref.cli_woff) as &const byte,
                slot_ref.cli_resp_len - slot_ref.cli_woff,
            );
            if wn == 0 {
                return 0 as usize;
            }
            slot_ref.cli_woff = slot_ref.cli_woff + wn;
        }

        if slot_ref.cli_wants_close != 0 {
            return 0 as usize;
        }

        if slot_ref.cli_http11 == 0 {
            slot_ref.http10_session_keep_alive = 1;
        }

        const consumed: usize = slot_ref.cli_req_consumed;
        const remain: usize = ctx.cli_compact_unconsumed(slot, consumed, read_filled);
        read_filled = remain;
        slot_ref.cli_filled = remain;
        slot_ref.cli_header_end = 0;
        slot_ref.cli_content_len = 0;
        slot_ref.cli_wants_close = 0;
        slot_ref.cli_req_consumed = 0;
        slot_ref.cli_http11 = 0;
        slot_ref.cli_hdr_len = 0;
        slot_ref.cli_woff = 0;
        slot_ref.cli_resp_len = 0;
        slot_ref.cli_body_len = 0;
        slot_ref.cli_body_woff = 0;
        slot_ref.cli_body_kind = 0;
    }
}

// Conservative raw storage for the client async frame.
// This benchmark wants stack-owned caller storage; using a fixed buffer keeps
// it independent of compile-time folding for @size_of(@frame(...)).
const HANDLE_BENCH_CLIENT_FRAME_BYTES: usize = 512;
const HANDLE_BENCH_CLIENT_FRAME_WORDS: usize =
    (HANDLE_BENCH_CLIENT_FRAME_BYTES + @size_of(usize) - 1) / @size_of(usize);

struct BenchClientHandle {
    live: i32 = 0,
    frame_storage: [usize: HANDLE_BENCH_CLIENT_FRAME_WORDS] = [],
}

struct BenchSlot {
    future: BenchClientHandle = BenchClientHandle{},
    waker: Waker = Waker{},
    active: i32 = 0,
    epoll_fd: i32 = 0,
    epoll_interest: i32 = 0,
    cfd: i32 = 0 - 1,
    cli_filled: usize = 0,
    cli_hdr_len: usize = 0,
    cli_woff: usize = 0,
    cli_resp_len: usize = 0,
    cli_body_len: usize = 0,
    cli_body_woff: usize = 0,
    cli_body_kind: i32 = 0,
    cli_discard_remain: usize = 0,
    cli_hdr_line: [byte: 256] = [],
    cli_header_end: usize = 0,
    cli_content_len: usize = 0,
    cli_wants_close: i32 = 0,
    cli_req_consumed: usize = 0,
    cli_http11: i32 = 0,
    http10_session_keep_alive: i32 = 0,

    fn cli_hdr_line_base(self: &Self) &byte {
        return @ptr_from_usize(@usize_from_ptr(&self.cli_hdr_line[0] as &void)) as &byte;
    },
}

struct BenchContext {
    epoll: LinuxEpoll = LinuxEpoll{ epfd: 0 - 1, slot_capacity: 1024, event_capacity: 1024 },
    listen_fd: i32 = 0 - 1,
    listen_waker: Waker = Waker{},
    accept_future: BenchAcceptFuture = BenchAcceptFuture{},
    accept_enabled: i32 = 0,
    slot_cap: i32 = 0,
    slots: [BenchSlot: BENCH_MAX_THREADS as usize] = [],
    active_slots: [i32: BENCH_MAX_THREADS as usize] = [],
    active_count: i32 = 0,
    slot_read: [byte: SLOT_READ_CAP * BENCH_MAX_THREADS as usize] = [],

    fn bench_slot_buf_base(self: &Self, slot: usize) &byte {
        const off: usize = slot * SLOT_READ_CAP;
        return @ptr_from_usize(@usize_from_ptr(&self.slot_read[0] as &void) + off) as &byte;
    },

    fn cli_body_const_base(self: &Self, kind: i32) &const byte {
        if kind == 1 {
            return &g_json_body[0] as &const byte;
        }
        return &g_hello_body[0] as &const byte;
    },

    fn cli_compact_unconsumed(self: &Self, slot: usize, consumed: usize, filled: usize) usize {
        if slot >= self.slot_cap as usize || consumed >= filled {
            return 0;
        }
        const tail: usize = filled - consumed;
        const base: &byte = self.bench_slot_buf_base(slot);
        _ = memmove(base as *byte, @ptr_from_usize(@usize_from_ptr(base as &void) + consumed) as &const byte, tail);
        return tail;
    },

    fn prepare_bench_client_response(self: &Self, slot: usize, first_read_n: usize) bool {
        if slot >= self.slot_cap as usize {
            return false;
        }
        if first_read_n == 0 || first_read_n > SLOT_READ_CAP {
            return false;
        }
        const slot_ref: &BenchSlot = &self.slots[slot];
        slot_ref.cli_filled = first_read_n;
        const he: usize = find_header_end(self.bench_slot_buf_base(slot), slot_ref.cli_filled);
        if he == 0 {
            return false;
        }
        slot_ref.cli_header_end = he;
        slot_ref.cli_content_len = scan_content_length(self.bench_slot_buf_base(slot), he);
        slot_ref.cli_req_consumed = he + slot_ref.cli_content_len;
        var ps: usize = 0;
        var pl: usize = 0;
        if !parse_request_line_path(self.bench_slot_buf_base(slot), he, &ps, &pl) {
            return false;
        }
        const http11: bool = request_is_http11(self.bench_slot_buf_base(slot), he);
        if http11 {
            slot_ref.cli_http11 = 1;
        } else {
            slot_ref.cli_http11 = 0;
        }
        const wants_close: bool = bench_wants_close_with_session(
            self.bench_slot_buf_base(slot),
            he,
            slot_ref.http10_session_keep_alive != 0,
        );
        if wants_close {
            slot_ref.cli_wants_close = 1;
        } else {
            slot_ref.cli_wants_close = 0;
        }
        var body_len: usize = 5;
        var body_kind: i32 = 0;
        if path_is_json(self.bench_slot_buf_base(slot), ps, pl) {
            body_len = 11;
            body_kind = 1;
        } else if !path_is_slash(self.bench_slot_buf_base(slot), ps, pl) {
            return false;
        }
        var hl_out: usize = 0;
        if !build_http_ok_response(slot_ref.cli_hdr_line_base(), 256, body_len, wants_close, &hl_out) {
            return false;
        }
        slot_ref.cli_hdr_len = hl_out;
        slot_ref.cli_woff = 0;
        var bi: usize = 0;
        const body_src: &const byte = self.cli_body_const_base(body_kind);
        while bi < body_len {
            slot_ref.cli_hdr_line[hl_out + bi] = body_src[bi];
            bi = bi + 1;
        }
        slot_ref.cli_resp_len = hl_out + body_len;
        slot_ref.cli_body_len = body_len;
        slot_ref.cli_body_kind = body_kind;
        slot_ref.cli_body_woff = 0;
        return true;
    },

    fn close_client_fd_quiet(self: &Self, fd: i32) void {
        if fd < 0 {
            return;
        }
        const flags_r: !i32 = sys_fcntl(fd, F_GETFL, 0);
        if flags_r.error_id == 0 {
            const flags: i32 = flags_r.value;
            if (flags & O_NONBLOCK) == 0 {
                _ = sys_fcntl(fd, F_SETFL, flags | O_NONBLOCK);
            }
        }
        var junk: [byte: 4096] = [];
        while true {
            const rr: !isize = sys_read(fd, &junk[0] as *byte, 4096);
            if rr.error_id != 0 {
                break;
            }
            if rr.value <= 0 {
                break;
            }
        }
        _ = sys_close(fd) catch {};
    },

    fn find_free_slot(self: &Self) i32 {
        var i: i32 = 0;
        while i < self.slot_cap {
            if self.slots[i as usize].active == 0 {
                return i;
            }
            i = i + 1;
        }
        return 0 - 1;
    },

    fn setup_listen_and_epoll(self: &Self) !void {
        const sock: !i32 = sys_socket(2, 1, 6);
        const lfd: i32 = sock catch {
            return sock as! void;
        };
        self.listen_fd = lfd;
        var one: i32 = 1;
        _ = try sys_setsockopt(lfd, SOL_SOCKET, SO_REUSEADDR, &one as &void, 4);
        _ = try sys_setsockopt(lfd, SOL_SOCKET, SO_REUSEPORT, &one as &void, 4);
        var addr: [byte: 16] = [];
        addr[0] = 2;
        addr[1] = 0;
        addr[2] = (((BENCH_PORT >> 8) & (0xff as u16)) as! byte).value;
        addr[3] = ((BENCH_PORT & (0xff as u16)) as! byte).value;
        addr[4] = 127;
        addr[7] = 1;
        _ = try sys_bind(lfd, &addr[0] as &void, 16);
        _ = try sys_listen(lfd, BACKLOG);
        const fl: !i32 = sys_fcntl(lfd, F_GETFL, 0);
        const flags: i32 = fl catch {
            return fl as! void;
        };
        _ = try sys_fcntl(lfd, F_SETFL, flags | O_NONBLOCK);
        const ep: !LinuxEpoll = linux_epoll_create(0);
        self.epoll = ep catch {
            return ep as! void;
        };
        self.listen_waker = Waker{};
        const loop: EventLoop = self.epoll;
        const reg_result: !i32 = loop.register(lfd, EventKind.Readable({}), &self.listen_waker);
        _ = reg_result catch {
            return reg_result as! void;
        };
    },

}

fn bench_client_handle_frame(self: &BenchClientHandle) &@frame(handle_bench_client) {
    return @ptr_from_usize(@usize_from_ptr(&self.frame_storage[0] as &void)) as &@frame(handle_bench_client);
}

fn bench_client_handle_release(self: &BenchClientHandle) void {
    if self.live == 0 {
        return;
    }
    bench_client_handle_frame(self).stop();
    self.live = 0;
}

fn bench_client_handle_init(self: &BenchClientHandle, ctx: &BenchContext, cfd: i32, slot: usize) void {
    if self.live != 0 {
        bench_client_handle_release(self);
    }
    bench_client_handle_frame(self).start(ctx, cfd, slot);
    self.live = 1;
}

fn bench_client_handle_poll(self: &BenchClientHandle, waker: &Waker) Poll<!usize> {
    if self.live == 0 {
        return async_poll_ready_ok_usize(0);
    }
    return bench_client_handle_frame(self).poll(waker);
}

fn bench_context_spawn_accepted_client(self: &BenchContext, cfd: i32) bool {
    const si: i32 = self.find_free_slot();
    if si < 0 || si >= self.slot_cap {
        return false;
    }
    const su: usize = (si as! usize).value;
    if su >= self.slot_cap as usize {
        return false;
    }
    const slot: &BenchSlot = &self.slots[su];
    slot.cfd = cfd;
    slot.active = 1;
    slot.epoll_fd = 0;
    slot.epoll_interest = 0;
    slot.waker = Waker{};
    slot.cli_filled = 0;
    slot.cli_hdr_len = 0;
    slot.cli_woff = 0;
    slot.cli_resp_len = 0;
    slot.cli_body_len = 0;
    slot.cli_body_woff = 0;
    slot.cli_body_kind = 0;
    slot.cli_discard_remain = 0;
    slot.cli_header_end = 0;
    slot.cli_content_len = 0;
    slot.cli_wants_close = 0;
    slot.cli_req_consumed = 0;
    slot.cli_http11 = 0;
    slot.http10_session_keep_alive = 0;
    bench_client_handle_init(&slot.future, self, cfd, su);
    if self.active_count < self.slot_cap {
        self.active_slots[self.active_count as usize] = si;
        self.active_count = self.active_count + 1;
    }
    return true;
}

fn bench_context_slot_release(self: &BenchContext, slot_idx: i32) void {
    if slot_idx < 0 || slot_idx >= self.slot_cap {
        return;
    }
    const s: usize = (slot_idx as! usize).value;
    const slot: &BenchSlot = &self.slots[s];
    if slot.epoll_fd != 0 {
        const loop: EventLoop = self.epoll;
        const dereg_result: !i32 = loop.deregister(slot.cfd);
        _ = dereg_result catch {};
    }
    self.close_client_fd_quiet(slot.cfd);
    bench_client_handle_release(&slot.future);
    slot.active = 0;
    slot.epoll_fd = 0;
    slot.epoll_interest = 0;
    slot.cfd = 0 - 1;
    slot.future = BenchClientHandle{};
    slot.cli_filled = 0;
    slot.cli_hdr_len = 0;
    slot.cli_woff = 0;
    slot.cli_resp_len = 0;
    slot.cli_body_len = 0;
    slot.cli_body_woff = 0;
    slot.cli_body_kind = 0;
    slot.cli_discard_remain = 0;
    slot.cli_header_end = 0;
    slot.cli_content_len = 0;
    slot.cli_wants_close = 0;
    slot.cli_req_consumed = 0;
    slot.cli_http11 = 0;
    slot.http10_session_keep_alive = 0;
    var i: i32 = 0;
    while i < self.active_count {
        if self.active_slots[i as usize] == slot_idx {
            const last_idx: i32 = self.active_count - 1;
            if i != last_idx {
                self.active_slots[i as usize] = self.active_slots[last_idx as usize];
            }
            self.active_count = last_idx;
            break;
        }
        i = i + 1;
    }
}

fn bench_context_poll_accepts(self: &BenchContext) i32 {
    var accepted: i32 = 0;
    self.listen_waker.reset();
    self.listen_waker.clear_io_interest();
    const p: Poll<!i32> = self.accept_future.poll(&self.listen_waker);
    match p {
        .Ready(v) => {
            const cfd_res: !i32 = v;
            const cfd: i32 = cfd_res catch {
                self.accept_future.release();
                self.accept_future = bench_accept_future(self.listen_fd);
                return accepted;
            };
            self.accept_future.release();
            self.accept_future = bench_accept_future(self.listen_fd);
            if bench_context_spawn_accepted_client(self, cfd) {
                accepted = accepted + 1;
            } else {
                self.close_client_fd_quiet(cfd);
            }
        },
        .Pending(_) => {
            return accepted;
        },
    }
    return accepted;
}

fn bench_context_bench_poll_slots(self: &BenchContext, timeout_ms: i32) void {
    while true {
        var made_progress: i32 = 0;
        var need_retry: i32 = 0;
        if self.accept_enabled != 0 {
            const acc: i32 = bench_context_poll_accepts(self);
            if acc != 0 {
                made_progress = 1;
            }
        }
        var i: i32 = 0;
        while i < self.active_count {
            const slot_idx: i32 = self.active_slots[i as usize];
            const slot: &BenchSlot = &self.slots[slot_idx as usize];
            if slot.active == 0 {
                i = i + 1;
                continue;
            }
            slot.waker.reset();
            slot.waker.clear_io_interest();
            const p: Poll<!usize> = bench_client_handle_poll(&slot.future, &slot.waker);
            match p {
                .Ready(_) => {
                    bench_context_slot_release(self, slot_idx);
                    made_progress = 1;
                },
                .Pending(_) => {
                    if slot.waker.is_woken() {
                        made_progress = 1;
                    } else if slot.waker.has_io_interest() {
                        const fd0: i32 = slot.waker.io_fd();
                        const ic: i32 = slot.waker.io_interest_code();
                        if slot.epoll_fd == 0 || slot.epoll_interest != ic {
                            const ik: EventKind = event_kind_from_waker(&slot.waker);
                            const loop: EventLoop = self.epoll;
                            const reg_result: !i32 = loop.register(fd0, ik, &slot.waker);
                            _ = reg_result catch {};
                            slot.epoll_fd = fd0;
                            slot.epoll_interest = ic;
                        }
                    } else {
                        need_retry = 1;
                    }
                },
            };
            i = i + 1;
        }
        if made_progress != 0 {
            continue;
        }
        if need_retry != 0 {
            continue;
        }
        const loop: EventLoop = self.epoll;
        const poll_result: !i32 = loop.poll(timeout_ms);
        _ = poll_result catch {};
    }
}

fn bench_context_run_once_single(self: &BenchContext) i32 {
    const sock: !i32 = sys_socket(2, 1, 6);
    const lfd: i32 = sock catch {
        return 1;
    };
    var one: i32 = 1;
    _ = sys_setsockopt(lfd, SOL_SOCKET, SO_REUSEADDR, &one as &void, 4);
    var addr: [byte: 16] = [];
    addr[0] = 2;
    addr[1] = 0;
    addr[2] = (((BENCH_PORT >> 8) & (0xff as u16)) as! byte).value;
    addr[3] = ((BENCH_PORT & (0xff as u16)) as! byte).value;
    addr[4] = 127;
    addr[7] = 1;
    const br: !i32 = sys_bind(lfd, &addr[0] as &void, 16);
    _ = br catch {
        _ = sys_close(lfd) catch {};
        return 1;
    };
    _ = sys_listen(lfd, 1);
    const ar: !i32 = sys_accept(lfd, null, 0);
    const cfd: i32 = ar catch {
        _ = sys_close(lfd) catch {};
        return 1;
    };
    _ = sys_close(lfd) catch {};
    const ep_r: !LinuxEpoll = linux_epoll_create(0);
    const ep0: LinuxEpoll = ep_r catch {
        self.close_client_fd_quiet(cfd);
        return 1;
    };
    self.epoll = ep0;
    self.accept_enabled = 0;
    self.slots[0].cfd = cfd;
    self.slots[0].active = 1;
    self.slots[0].epoll_fd = 0;
    self.slots[0].epoll_interest = 0;
    self.slots[0].waker = Waker{};
    bench_client_handle_init(&self.slots[0].future, self, cfd, 0);
    self.slots[0].cli_filled = 0;
    self.slots[0].cli_hdr_len = 0;
    self.slots[0].cli_woff = 0;
    self.slots[0].cli_resp_len = 0;
    self.slots[0].cli_body_len = 0;
    self.slots[0].cli_body_woff = 0;
    self.slots[0].cli_body_kind = 0;
    self.slots[0].cli_discard_remain = 0;
    self.slots[0].cli_header_end = 0;
    self.slots[0].cli_content_len = 0;
    self.slots[0].cli_wants_close = 0;
    self.slots[0].cli_req_consumed = 0;
    self.slots[0].cli_http11 = 0;
    self.slots[0].http10_session_keep_alive = 0;
    self.active_slots[0] = 0;
    self.active_count = 1;
    bench_context_bench_poll_slots(self, 0 - 1);
    return 0;
}

fn bench_context_run(self: &BenchContext) i32 {
    const keep_handle_async: &void = &handle_bench_client as &void;
    _ = keep_handle_async;
    self.active_count = 0;
    var z: i32 = 0;
    while z < self.slot_cap {
        self.slots[z as usize].active = 0;
        self.slots[z as usize].epoll_fd = 0;
        self.slots[z as usize].epoll_interest = 0;
        self.slots[z as usize].cfd = 0 - 1;
        bench_client_handle_release(&self.slots[z as usize].future);
        self.slots[z as usize].future = BenchClientHandle{};
        self.slots[z as usize].cli_filled = 0;
        self.slots[z as usize].cli_hdr_len = 0;
        self.slots[z as usize].cli_woff = 0;
        self.slots[z as usize].cli_resp_len = 0;
        self.slots[z as usize].cli_body_len = 0;
        self.slots[z as usize].cli_body_woff = 0;
        self.slots[z as usize].cli_body_kind = 0;
        self.slots[z as usize].cli_discard_remain = 0;
        self.slots[z as usize].cli_header_end = 0;
        self.slots[z as usize].cli_content_len = 0;
        self.slots[z as usize].cli_wants_close = 0;
        self.slots[z as usize].cli_req_consumed = 0;
        self.slots[z as usize].cli_http11 = 0;
        self.slots[z as usize].http10_session_keep_alive = 0;
        z = z + 1;
    }
    if argv_is_once() {
        return bench_context_run_once_single(self);
    }
    self.setup_listen_and_epoll() catch {
        return 1;
    };
    self.accept_enabled = 1;
    self.accept_future = bench_accept_future(self.listen_fd);
    bench_context_bench_poll_slots(self, 0 - 1);
    return 0;
}

var g_bench_slot_cap: i32 = BENCH_THREAD_COUNT;
var g_worker_contexts: [BenchContext: BENCH_MAX_THREADS as usize] = [];

fn bench_thread_slot_cap(arg: &void) i32 {
    _ = arg;
    return g_bench_slot_cap;
}

@align(8)
@async_fn fn bench_worker_async(arg: &void) Future<!i32> {
    if arg == null {
        return 0 as i32;
    }
    const worker_id: i32 = *(arg as &i32);
    if worker_id < 0 || worker_id >= BENCH_MAX_THREADS {
        return 0 as i32;
    }
    const ptr: &BenchContext = &g_worker_contexts[worker_id as usize];
    const slot_cap: i32 = bench_thread_slot_cap(arg);
    ptr.slot_cap = slot_cap;
    return bench_context_run(ptr);
}

fn bench_worker_thread(_arg: &void) &void {
    const keep_worker_async: &void = &bench_worker_async as &void;
    _ = keep_worker_async;
    var frame_pool_storage: [usize: BENCH_ASYNC_FRAME_POOL_WORDS] = [];
    var frame_pool: AsyncFramePool = AsyncFramePool{};
    async_frame_pool_init_with_buffer(
        &frame_pool,
        &frame_pool_storage[0] as &byte,
        BENCH_ASYNC_FRAME_POOL_BYTES,
        0,
        65536,
    );
    set_async_frame_allocator(&frame_pool);
    var root_frame: @frame(bench_worker_async);
    root_frame.start(_arg);
    const w: Waker = Waker{};
    const p: Poll<!i32> = root_frame.poll(&w);
    match p {
        .Ready(_) => {},
        .Pending(_) => {},
    }
    return null as &void;
}

fn event_kind_from_waker(w: &Waker) EventKind {
    const interest: i32 = w.io_interest_code();
    if interest == 1 {
        return EventKind.Readable({});
    }
    if interest == 2 {
        return EventKind.Writable({});
    }
    return EventKind.ReadWrite({});
}

fn argv_is_once() bool {
    if get_argc() < 2 {
        return false;
    }
    const p: &byte = get_argv(1);
    if p == null {
        return false;
    }
    if p[0] != '-' as byte || p[1] != '-' as byte {
        return false;
    }
    if p[2] != 'o' as byte || p[3] != 'n' as byte ||
       p[4] != 'c' as byte || p[5] != 'e' as byte {
        return false;
    }
    return p[6] == 0 as byte;
}

fn argv_thread_count() i32 {
    if get_argc() < 2 {
        return BENCH_THREAD_COUNT;
    }
    const p: &byte = get_argv(1);
    if p == null {
        return BENCH_THREAD_COUNT;
    }
    if p[0] == '-' as byte && p[1] == '-' as byte &&
       p[2] == 'o' as byte && p[3] == 'n' as byte &&
       p[4] == 'c' as byte && p[5] == 'e' as byte && p[6] == 0 as byte {
        return BENCH_THREAD_COUNT;
    }
    if p[0] == '-' as byte && p[1] == '-' as byte &&
       p[2] == 't' as byte && p[3] == 'h' as byte &&
       p[4] == 'r' as byte && p[5] == 'e' as byte &&
       p[6] == 'a' as byte && p[7] == 'd' as byte &&
       p[8] == 's' as byte && p[9] == 0 as byte {
        if get_argc() < 3 {
            return BENCH_THREAD_COUNT;
        }
        const n: i32 = atoi(get_argv(2));
        if n > 0 {
            if n > BENCH_MAX_THREADS {
                return BENCH_MAX_THREADS;
            }
            return n;
        }
        return BENCH_THREAD_COUNT;
    }
    const n2: i32 = atoi(p as &const byte);
    if n2 > 0 {
        if n2 > BENCH_MAX_THREADS {
            return BENCH_MAX_THREADS;
        }
        return n2;
    }
    return BENCH_THREAD_COUNT;
}

fn find_header_end(buf: &byte, len: usize) usize {
    if len < 4 {
            return 0 as usize;
    }
    var k: usize = 0;
    while k + 4 <= len {
        if buf[k] == '\r' as byte && buf[k + 1] == '\n' as byte &&
           buf[k + 2] == '\r' as byte && buf[k + 3] == '\n' as byte {
            return k + 4;
        }
        k = k + 1;
    }
    return 0;
}

fn is_get_prefix(buf: &byte, len: usize) bool {
    return len >= 4 && buf[0] == 'G' as byte && buf[1] == 'E' as byte &&
        buf[2] == 'T' as byte && buf[3] == ' ' as byte;
}

fn parse_request_line_path(buf: &byte, len: usize, path_start: &usize, path_len: &usize) bool {
    if !is_get_prefix(buf, len) {
        return false;
    }
    var pe: usize = 4;
    while pe < len && buf[pe] != ' ' as byte {
        pe = pe + 1;
    }
    if pe >= len {
        return false;
    }
    const pl: usize = pe - 4;
    if pl == 0 || pl > MAX_PATH_LEN {
        return false;
    }
    *path_start = 4;
    *path_len = pl;
    return true;
}

fn scan_content_length(buf: &byte, len: usize) usize {
    var i: usize = 0;
    while i + 15 < len {
        if (buf[i] == 'C' as byte || buf[i] == 'c' as byte) &&
           (buf[i + 1] == 'O' as byte || buf[i + 1] == 'o' as byte) {
            var ok: bool = true;
            const pat: &[byte] = &"ontent-Length:"[0: 14];
            var t: usize = 0;
            while t < 14 {
                const c: byte = buf[i + 2 + t];
                const e: byte = pat.ptr[t];
                if c != e && c != (e - 32 as u32) as byte && c != (e + 32 as u32) as byte {
                    ok = false;
                    break;
                }
                t = t + 1;
            }
            if ok {
                var vs: usize = i + 16;
                while vs < len && (buf[vs] == ' ' as byte || buf[vs] == '\t' as byte) {
                    vs = vs + 1;
                }
                var cl: usize = 0;
                while vs < len && buf[vs] >= '0' as byte && buf[vs] <= '9' as byte {
                    cl = cl * 10 + ((buf[vs] as i32) - 48) as usize;
                    vs = vs + 1;
                }
                return cl;
            }
        }
        i = i + 1;
    }
    return 0;
}

fn request_is_http11(buf: &byte, len: usize) bool {
    var j: usize = 0;
    while j + 8 < len {
        if buf[j] == 'H' as byte && buf[j + 1] == 'T' as byte &&
           buf[j + 2] == 'T' as byte && buf[j + 3] == 'P' as byte &&
           buf[j + 4] == '/' as byte && buf[j + 5] == '1' as byte &&
           buf[j + 6] == '.' as byte && buf[j + 7] == '1' as byte {
            return true;
        }
        j = j + 1;
    }
    return false;
}

fn bench_wants_close_with_session(buf: &byte, he: usize, http10_session_keep_alive: bool) bool {
    const http11: bool = request_is_http11(buf, he);
    var wants_close: bool = true;
    var has_connection: bool = false;
    var i: usize = 0;
    while i + 11 < he {
        if (buf[i] == 'C' as byte || buf[i] == 'c' as byte) &&
           (buf[i + 1] == 'O' as byte || buf[i + 1] == 'o' as byte) &&
           (buf[i + 2] == 'N' as byte || buf[i + 2] == 'n' as byte) &&
           (buf[i + 3] == 'N' as byte || buf[i + 3] == 'n' as byte) &&
           (buf[i + 4] == 'E' as byte || buf[i + 4] == 'e' as byte) &&
           (buf[i + 5] == 'C' as byte || buf[i + 5] == 'c' as byte) &&
           (buf[i + 6] == 'T' as byte || buf[i + 6] == 't' as byte) &&
           (buf[i + 7] == 'I' as byte || buf[i + 7] == 'i' as byte) &&
           (buf[i + 8] == 'O' as byte || buf[i + 8] == 'o' as byte) &&
           (buf[i + 9] == 'N' as byte || buf[i + 9] == 'n' as byte) &&
           buf[i + 10] == ':' as byte {
            var val_start: usize = i + 11;
            while val_start < he && (buf[val_start] == ' ' as byte || buf[val_start] == '\t' as byte) {
                val_start = val_start + 1;
            }
            has_connection = true;
            if val_start + 9 < he &&
               (buf[val_start] == 'k' as byte || buf[val_start] == 'K' as byte) &&
               (buf[val_start + 1] == 'e' as byte || buf[val_start + 1] == 'E' as byte) &&
               (buf[val_start + 2] == 'e' as byte || buf[val_start + 2] == 'E' as byte) &&
               (buf[val_start + 3] == 'p' as byte || buf[val_start + 3] == 'P' as byte) &&
               buf[val_start + 4] == '-' as byte &&
               (buf[val_start + 5] == 'a' as byte || buf[val_start + 5] == 'A' as byte) &&
               (buf[val_start + 6] == 'l' as byte || buf[val_start + 6] == 'L' as byte) &&
               (buf[val_start + 7] == 'i' as byte || buf[val_start + 7] == 'I' as byte) &&
               (buf[val_start + 8] == 'v' as byte || buf[val_start + 8] == 'V' as byte) &&
               (buf[val_start + 9] == 'e' as byte || buf[val_start + 9] == 'E' as byte) {
                wants_close = false;
            }
            if val_start + 4 < he &&
               (buf[val_start] == 'c' as byte || buf[val_start] == 'C' as byte) &&
               (buf[val_start + 1] == 'l' as byte || buf[val_start + 1] == 'L' as byte) &&
               (buf[val_start + 2] == 'o' as byte || buf[val_start + 2] == 'O' as byte) &&
               (buf[val_start + 3] == 's' as byte || buf[val_start + 3] == 'S' as byte) &&
               (buf[val_start + 4] == 'e' as byte || buf[val_start + 4] == 'E' as byte) {
                wants_close = true;
            }
            break;
        }
        i = i + 1;
    }
    if !has_connection {
        if http10_session_keep_alive {
            wants_close = false;
        } else {
            wants_close = !http11;
        }
    }
    return wants_close;
}

fn path_is_slash(buf: &byte, path_start: usize, path_len: usize) bool {
    return path_len == 1 && buf[path_start] == '/' as byte;
}

fn path_is_json(buf: &byte, path_start: usize, path_len: usize) bool {
    if path_len != 5 {
        return false;
    }
    const p: &byte = @ptr_from_usize(@usize_from_ptr(buf as &void) + path_start) as &byte;
    return p[0] == '/' as byte && p[1] == 'j' as byte && p[2] == 's' as byte &&
        p[3] == 'o' as byte && p[4] == 'n' as byte;
}

fn fmt_usize_dec(buf: &byte, n: usize) usize {
    if n == 0 {
        buf[0] = '0' as byte;
        return 1;
    }
    var tmp: [byte: 24] = [];
    var t: usize = 0;
    var x: usize = n;
    while x > 0 && t < 24 {
        tmp[t] = ((x % (10 as usize)) as! byte).value + ('0' as byte);
        t = t + 1;
        x = x / (10 as usize);
    }
    var i: usize = 0;
    while i < t {
        buf[i] = tmp[t - 1 - i];
        i = i + 1;
    }
    return t;
}

fn build_http_ok_response(
    hdr_buf: &byte,
    hdr_cap: usize,
    body_len: usize,
    close_after: bool,
    out_hdr_len: &usize,
) bool {
    var pos: usize = 0;
    const line1: &[byte] = &"HTTP/1.1 200 OK\r\n"[0: 17];
    var u: usize = 0;
    while u < line1.len && pos < hdr_cap {
        hdr_buf[pos] = line1.ptr[u];
        pos = pos + 1;
        u = u + 1;
    }
    if close_after {
        const ck: &[byte] = &"Connection: close\r\n"[0: 19];
        u = 0;
        while u < ck.len && pos < hdr_cap {
            hdr_buf[pos] = ck.ptr[u];
            pos = pos + 1;
            u = u + 1;
        }
    } else {
        const ck2: &[byte] = &"Connection: keep-alive\r\n"[0: 24];
        u = 0;
        while u < ck2.len && pos < hdr_cap {
            hdr_buf[pos] = ck2.ptr[u];
            pos = pos + 1;
            u = u + 1;
        }
    }
    const ct: &[byte] = &"Content-Type: text/plain\r\nContent-Length: "[0: 42];
    u = 0;
    while u < ct.len && pos < hdr_cap {
        hdr_buf[pos] = ct.ptr[u];
        pos = pos + 1;
        u = u + 1;
    }
    const dl: usize = fmt_usize_dec(@ptr_from_usize(@usize_from_ptr(hdr_buf as &void) + pos) as &byte, body_len);
    pos = pos + dl;
    if pos + 4 > hdr_cap {
        return false;
    }
    hdr_buf[pos] = '\r' as byte;
    hdr_buf[pos + 1] = '\n' as byte;
    hdr_buf[pos + 2] = '\r' as byte;
    hdr_buf[pos + 3] = '\n' as byte;
    pos = pos + 4;
    *out_hdr_len = pos;
    return pos <= hdr_cap;
}

export fn main() i32 {
    set_process_stack_limit_bytes(BENCH_MAIN_STACK_BYTES);
    _ = signal(SIGPIPE, SIG_IGN as &void);

    var n_threads: i32 = argv_thread_count();
    g_bench_slot_cap = n_threads;
    var threads: [pthread_t: BENCH_MAX_THREADS as usize] = [];
    var thread_ids: [i32: BENCH_MAX_THREADS as usize] = [];
    var i: i32 = 1;
    while i < n_threads && i < BENCH_MAX_THREADS {
        var attr: pthread_attr_t = pthread_attr_t{};
        _ = pthread_attr_init(&attr);
        _ = pthread_attr_setstacksize(&attr, BENCH_WORKER_STACK_BYTES);
        thread_ids[i as usize] = i;
        const ret: i32 = pthread_create(&threads[i], &attr as &const pthread_attr_t, &bench_worker_thread as &void, &thread_ids[i as usize] as &void);
        _ = pthread_attr_destroy(&attr);
        if ret != 0 {
            return 1;
        }
        i = i + 1;
    }

    thread_ids[0] = 0;
    _ = bench_worker_thread(&thread_ids[0] as &void);

    i = 1;
    while i < n_threads && i < BENCH_MAX_THREADS {
        _ = pthread_join(&threads[i], null as &&void);
        i = i + 1;
    }
    return 0;
}
