// libc.stdio - 标准 I/O 操作
// 版本：v0.4.0
// 说明：基于系统调用的标准 I/O 函数（零外部依赖）
// 注意：函数名使用下划线分隔风格，避免与 C 标准库冲突

// ============================================================
// 标准流：与 C 标准库完全兼容，可替代系统 libc 供其它 C 程序使用（outlibc）
// FILE 为流类型（含 fd），stdin/stdout/stderr 由 Uya 初始化，--nostdlib 时由我们提供
// ============================================================

// C 标准库兼容的流类型（outlibc 时对应 C 的 FILE* 所指类型）
export struct FILE {
    fd: i64,
    buffer: [byte: 4096],      // 添加缓冲区
    buf_pos: usize,            // 当前缓冲区位置
    buf_len: usize,            // 缓冲区中有效数据长度
    buf_mode: i32,             // 缓冲模式：0-无缓冲，1-行缓冲，2-全缓冲
}

var _stdin: FILE = FILE{ fd: 0, buf_pos: 0, buf_len: 0, buf_mode: 0 };
var _stdout: FILE = FILE{ fd: 1, buf_pos: 0, buf_len: 0, buf_mode: 1 };  // 行缓冲
var _stderr: FILE = FILE{ fd: 2, buf_pos: 0, buf_len: 0, buf_mode: 0 };  // 无缓冲

export var stdin: &FILE = &_stdin;
export var stdout: &FILE = &_stdout;
export var stderr: &FILE = &_stderr;

// ============================================================
// 缓冲区操作函数
// ============================================================

// flush_buffer - 刷新流的缓冲区
export fn flush_buffer(stream: &FILE) i32 {
    if stream.buf_len == 0 {
        return 0;  // 没有需要刷新的数据
    }
    
    // 写入缓冲区中的所有数据
    const result: !i64 = @syscall(SYS_write, stream.fd, stream.buffer as i64, stream.buf_len as i64);
    const written: i64 = result catch {
        return -1;  // 写入失败
    };
    
    if written < 0 {
        return -1;
    }
    
    // 重置缓冲区
    stream.buf_pos = 0;
    stream.buf_len = 0;
    
    return 0;
}

// write_to_buffer - 将数据写入流的缓冲区
export fn write_to_buffer(stream: &FILE, buf: &const byte, n: usize) i64 {
    if n == 0 {
        return 0;
    }
    
    // 如果禁用了缓冲或缓冲区太小，直接写入
    if stream.buf_mode == 0 || n >= 4096 {
        const result: !i64 = @syscall(SYS_write, stream.fd, buf as i64, n as i64);
        const written: i64 = result catch {
            return -1;
        };
        return written;
    }
    
    // 尝试将数据放入缓冲区
    var bytes_written: usize = 0;
    var remaining: usize = n;
    var src_offset: usize = 0;

    while remaining > 0 {
        var space_left: usize = 4096 - stream.buf_len;

        if space_left == 0 {
            // 缓冲区满了，先刷新
            if flush_buffer(stream) < 0 {
                return -1;
            }
        }

        var to_copy: usize = 0;
        if remaining < space_left {
            to_copy = remaining;
        } else {
            to_copy = space_left;
        }

        // 复制数据到缓冲区
        var i: usize = 0;
        while i < to_copy {
            stream.buffer[stream.buf_len + i] = buf[src_offset + i];
            i = i + 1;
        }

        // 先复制数据到缓冲区
        stream.buf_len = stream.buf_len + to_copy;
        src_offset = src_offset + to_copy;
        bytes_written = bytes_written + to_copy;
        remaining = remaining - to_copy;

        // 如果是行缓冲且遇到了换行符，则刷新
        if stream.buf_mode == 1 {
            // 只检查本次写入的数据（从 buf_start 到当前 buf_len）
            var buf_start: usize = stream.buf_len - to_copy;
            var j: usize = buf_start;
            var need_flush: bool = false;
            while j < stream.buf_len {
                // 添加边界检查以满足 safety-proof
                if j < 4096 {
                    if stream.buffer[j] == 10 {  // '\n'
                        need_flush = true;
                        break;
                    }
                }
                j = j + 1;
            }
            if need_flush {
                if flush_buffer(stream) < 0 {
                    return -1;
                }
            }
        }
    }

    return bytes_written as i64;
}

// ============================================================
// 标准文件描述符
// ============================================================

export const STDIN: i64 = 0;
export const STDOUT: i64 = 1;
export const STDERR: i64 = 2;

// ============================================================
// 基础输出函数
// ============================================================

// put_char - 向标准输出写入一个字符
// 返回：写入的字符（成功）或 -1（失败）
export fn put_char(c: i32) i32 {
    return put_char_fd(c, STDOUT);
}

// put_char_fd - 吐定文件描述符写入一个字符
// 返回：写入的字符（成功）或 -1（失败）
export fn put_char_fd(c: i32, fd: i64) i32 {
    // 查找对应的FILE流
    var target_stream: &FILE = null;
    if fd == 0 { target_stream = stdin; }
    else if fd == 1 { target_stream = stdout; }
    else if fd == 2 { target_stream = stderr; }
    
    if target_stream != null {
        // 对于标准流，使用缓冲机制
        const ch: byte = c as byte;
        const result: i64 = write_to_buffer(target_stream, &ch, 1);
        if result < 0 {
            return -1;
        }
        
        // 如果是行缓冲且是换行符，刷新缓冲区
        if target_stream.buf_mode == 1 && ch == 10 {
            if flush_buffer(target_stream) < 0 {
                return -1;
            }
        }
        
        return c;
    } else {
        // 非标准流，直接写入
        var ch: byte = c as byte;
        const result: !i64 = @syscall(SYS_write, fd, &ch as i64, 1);
        const written: i64 = result catch {
            return 0 - 1;
        };
        if written == 1 {
            return c;
        }
        return 0 - 1;
    }
}

// write_bytes - 向标准输出写入 n 个字节
// 返回：写入的字节数，失败返回 -1
export fn write_bytes(buf: &const byte, n: usize) i64 {
    return write_bytes_fd(buf, n, STDOUT);
}

// write_bytes_fd - 向指定文件描述符写入 n 个字节
// 返回：写入的字节数，失败返回 -1
export fn write_bytes_fd(buf: &const byte, n: usize, fd: i64) i64 {
    // 查找对应的FILE流
    var target_stream: &FILE = null;
    if fd == 0 { target_stream = stdin; }
    else if fd == 1 { target_stream = stdout; }
    else if fd == 2 { target_stream = stderr; }
    
    if target_stream != null {
        // 对于标准流，使用缓冲机制
        return write_to_buffer(target_stream, buf, n);
    } else {
        // 非标准流，直接写入
        const result: !i64 = @syscall(SYS_write, fd, buf as i64, n as i64);
        const written: i64 = result catch {
            return 0 - 1;
        };
        return written;
    }
}

// put_str_len - 向标准输出写入指定长度的字符串并换行
// 返回：0 成功，-1 失败
export fn put_str_len(s: &const byte, len: usize) i32 {
    // 写入字符串内容
    const result: i64 = write_bytes(s, len);
    if result < 0 {
        return 0 - 1;
    }
    
    // 写入换行符
    var newline: byte = 10 as byte;
    const nl_result: i64 = write_bytes(&newline, 1);
    if nl_result < 0 {
        return 0 - 1;
    }
    
    return 0;
}

// ============================================================
// 基础输入函数
// ============================================================

// get_char - 从标准输入读取一个字符
// 返回：读取的字符，EOF 或错误返回 -1
export fn get_char() i32 {
    var ch: byte = 0 as byte;
    const result: !i64 = @syscall(SYS_read, STDIN, &ch as i64, 1);
    const bytes_read: i64 = result catch {
        return 0 - 1;
    };
    if bytes_read == 1 {
        return ch as i32;
    }
    return 0 - 1;
}

// read_bytes - 从标准输入读取最多 n 个字节
// 返回：读取的字节数，EOF 或错误返回 -1
export fn read_bytes(buf: &byte, n: usize) i64 {
    const result: !i64 = @syscall(SYS_read, STDIN, buf as i64, n as i64);
    const bytes_read: i64 = result catch {
        return 0 - 1;
    };
    return bytes_read;
}

// read_bytes_fd - 从指定文件描述符读取最多 n 个字节
// 返回：读取的字节数，EOF 或错误返回 -1
export fn read_bytes_fd(buf: &byte, n: usize, fd: i64) i64 {
    const result: !i64 = @syscall(SYS_read, fd, buf as i64, n as i64);
    const bytes_read: i64 = result catch {
        return 0 - 1;
    };
    return bytes_read;
}

// ============================================================
// 整数转字符串辅助函数
// ============================================================

// i32_to_str - 将 i32 转换为十进制字符串
// 返回：写入的字符数
export fn i32_to_str(value: i32, buf: &byte) usize {
    var v: i32 = value;
    var len: usize = 0;
    var is_neg: bool = false;

    if v < 0 {
        is_neg = true;
        v = 0 - v;
    }

    // 特殊情况：值为 0
    if v == 0 {
        buf[0] = 48 as byte;  // '0'
        return 1;
    }

    // 逆序写入数字
    while v > 0 {
        buf[len] = (v % 10 + 48) as byte;  // '0' = 48
        v = v / 10;
        len = len + 1;
    }

    if is_neg {
        buf[len] = 45 as byte;  // '-'
        len = len + 1;
    }

    // 反转字符串
    var left: usize = 0;
    var right: usize = len - 1;
    while left < right {
        const tmp: byte = buf[left];
        buf[left] = buf[right];
        buf[right] = tmp;
        left = left + 1;
        right = right - 1;
    }

    return len;
}

// i64_to_str - 将 i64 转换为十进制字符串
// 返回：写入的字符数
export fn i64_to_str(value: i64, buf: &byte) usize {
    var v: i64 = value;
    var len: usize = 0;
    var is_neg: bool = false;

    if v < 0 {
        is_neg = true;
        v = 0 - v;
    }

    // 特殊情况：值为 0
    if v == 0 {
        buf[0] = 48 as byte;  // '0'
        return 1;
    }

    // 逆序写入数字
    while v > 0 {
        buf[len] = (v % 10 + 48) as byte;  // '0' = 48
        v = v / 10;
        len = len + 1;
    }

    if is_neg {
        buf[len] = 45 as byte;  // '-'
        len = len + 1;
    }

    // 反转字符串
    var left: usize = 0;
    var right: usize = len - 1;
    while left < right {
        const tmp: byte = buf[left];
        buf[left] = buf[right];
        buf[right] = tmp;
        left = left + 1;
        right = right - 1;
    }

    return len;
}

// print_i32 - 将 i32 值打印到标准输出
// 返回：写入的字符数
export fn print_i32(value: i32) usize {
    var buf: [byte: 12] = [];
    const len: usize = i32_to_str(value, &buf[0] as &byte);
    _ = write_bytes(&buf[0] as &byte, len);
    return len;
}

// print_i64 - 将 i64 值打印到标准输出
// 返回：写入的字符数
export fn print_i64(value: i64) usize {
    var buf: [byte: 21] = [];
    const len: usize = i64_to_str(value, &buf[0] as &byte);
    _ = write_bytes(&buf[0] as &byte, len);
    return len;
}

// ============================================================
// C 标准库兼容函数（用于 --nostdlib 模式）
// ============================================================

// 全局 FILE 存储（用于 fopen/fclose，最多 64 个文件）
var fopen_fd_storage: [FILE: 64] = [];

// fopen - 打开文件（C 标准库兼容）
// 返回：FILE*，失败返回 null
export fn fopen(filename: &const byte, mode: &const byte) &FILE {
    if filename == null || mode == null {
        return null;
    }
    
    // 解析模式字符串
    var flags: i64 = 0;
    var create_mode: i64 = 0;
    var i: usize = 0;
    const mode_len: usize = strlen(mode);
    
    while i < mode_len {
        const c: byte = mode[i];
        if c == 114 {  // 'r'
            flags = O_RDONLY;
        } else if c == 119 {  // 'w'
            flags = O_WRONLY | O_CREAT | O_TRUNC;
            create_mode = S_IRWXU;
        } else if c == 97 {  // 'a'
            flags = O_WRONLY | O_CREAT | O_APPEND;
            create_mode = S_IRWXU;
        } else if c == 43 {  // '+'
            // 读写模式
            if flags == O_RDONLY {
                flags = O_RDWR;
            } else {
                flags = flags | O_RDWR;
            }
        } else if c == 98 {  // 'b' (binary mode, ignored on Linux)
            // 忽略
        }
        i = i + 1;
    }
    
    // 打开文件
    const result: !i32 = sys_open(filename, flags as i32, create_mode as i32);
    const fd: i32 = result catch {
        return null;
    };
    
    // 使用全局数组存储 FILE（简化实现，最多支持 64 个打开的文件）
    var j: usize = 0;
    while j < 64 {
        // 查找空闲槽位（fd <= 0 表示未使用）
        if fopen_fd_storage[j].fd <= 0 {
            fopen_fd_storage[j].fd = fd as i64;
            return &fopen_fd_storage[j];
        }
        j = j + 1;
    }
    
    // 如果数组满了，关闭文件描述符并返回 null
    _ = sys_close(fd);
    return null;
}

// fclose - 关闭文件（C 标准库兼容）
// 返回：0 成功，EOF (-1) 失败
export fn fclose(stream: &FILE) i32 {
    if stream == null {
        return 0 - 1;  // EOF
    }
    const fd: i64 = stream.fd;
    if fd < 0 {
        return 0 - 1;  // EOF
    }
    const result: !i32 = sys_close(fd as i32);
    _ = result catch {
        return 0 - 1;  // EOF
    };
    stream.fd = 0 - 1;
    return 0;
}

// fread - 从文件读取（C 标准库兼容）
// 返回：读取的元素数
export fn fread(ptr: &byte, size: usize, nmemb: usize, stream: &FILE) usize {
    if ptr == null || stream == null || size == 0 || nmemb == 0 {
        return 0;
    }
    const fd: i64 = stream.fd;
    if fd < 0 {
        return 0;
    }
    
    const total_size: usize = size * nmemb;
    const result: !isize = sys_read(fd as i32, ptr, total_size);
    const bytes_read: isize = result catch {
        return 0;
    };
    
    if bytes_read < 0 as isize {
        return 0;
    }

    // 返回读取的元素数（向下取整）
    return (bytes_read as usize) / size;
}

// fgetc - 从文件读取一个字符（C 标准库兼容）
// 返回：读取的字符，EOF (-1) 表示错误或文件结束
export fn fgetc(stream: &FILE) i32 {
    if stream == null {
        return 0 - 1;  // EOF
    }
    const fd: i64 = stream.fd;
    if fd < 0 {
        return 0 - 1;  // EOF
    }
    
    var ch: byte = 0 as byte;
    const result: !isize = sys_read(fd as i32, &ch, 1);
    const bytes_read: isize = result catch {
        return 0 - 1;  // EOF
    };
    
    if bytes_read == 1 as isize {
        return ch as i32;
    }
    
    return 0 - 1;  // EOF
}

// _fmt_f64_to_buf - 将 f64 格式化为字符串追加到 buf，返回新的 buf_pos
fn _fmt_f64_to_buf(buf: &byte, buf_pos: usize, buf_max: usize, val: f64, precision: i32) usize {
    var pos: usize = buf_pos;
    if pos >= buf_max { return pos; }
    var x: f64 = val;
    if x != x {
        const nan: &const byte = "nan" as &const byte;
        var i: i32 = 0;
        while nan[i] != 0 && pos < buf_max {
            buf[pos] = nan[i];
            pos = pos + 1;
            i = i + 1;
        }
        return pos;
    }
    if x < 0.0 {
        buf[pos] = 45;
        pos = pos + 1;
        x = 0.0 - x;
    }
    if x == 0.0 {
        buf[pos] = 48;
        pos = pos + 1;
        if precision > 0 && pos < buf_max {
            buf[pos] = 46;
            pos = pos + 1;
            var i: i32 = 0;
            while i < precision && pos < buf_max {
                buf[pos] = 48;
                pos = pos + 1;
                i = i + 1;
            }
        }
        return pos;
    }
    var int_part: i64 = x as i64;
    var frac: f64 = x - (int_part as f64);
    var digits: [byte: 24] = [];
    var di: usize = 0;
    if int_part == 0 {
        digits[di] = 48;
        di = di + 1;
    } else {
        var t: i64 = int_part;
        if t < 0 { t = 0 - t; }
        while t > 0 && di < 24 {
            digits[di] = (48 + (t % 10) as i32) as byte;
            di = di + 1;
            t = t / 10;
        }
    }
    var i: usize = 0;
    while i < di && pos < buf_max {
        buf[pos] = digits[di - 1 - i];
        pos = pos + 1;
        i = i + 1;
    }
    var prec: i32 = precision;
    if prec < 0 { prec = 6; }
    if prec > 0 && pos < buf_max {
        buf[pos] = 46;
        pos = pos + 1;
        i = 0;
        while i < prec && pos < buf_max {
            frac = frac * 10.0;
            const d: i32 = frac as i32;
            buf[pos] = (48 + d) as byte;
            pos = pos + 1;
            frac = frac - (d as f64);
            i = i + 1;
        }
    }
    return pos;
}

// fprintf - C 标准库兼容，stream 为 FILE*（stdin/stdout/stderr）
// 支持 %s、%d、%%、%g、%.17g
export fn fprintf(stream: &FILE, format: &const byte, ...) i32 {
    if stream == null || format == null {
        return 0 - 1;
    }
    const fd: i64 = stream.fd;
    if fd < 0 {
        return 0 - 1;
    }
    var ap_buf: [byte: 32] = [];
    var ap: &void = &ap_buf[0] as &void;
    @va_start(ap, format);
    var buf: [byte: 4096] = [];
    var buf_pos: usize = 0;
    var format_pos: usize = 0;
    const format_len: usize = strlen(format);
    const buf_max: usize = 4095;
    while format_pos < format_len && buf_pos < buf_max {
        const c: byte = format[format_pos];
        if c == 37 {
            format_pos = format_pos + 1;
            if format_pos < format_len {
                const spec: byte = format[format_pos];
                // 处理 %*s（宽度从参数获取）
                if spec == 42 && format_pos + 1 < format_len && format[format_pos + 1] == 115 {
                    format_pos = format_pos + 1;
                    const width: i32 = @va_arg(ap, i32);
                    const s: &const byte = @va_arg(ap, &const byte);
                    if s != null {
                        const len: usize = strlen(s);
                        // 左侧填充空格
                        var pad: i32 = width - (len as i32);
                        while pad > 0 && buf_pos < buf_max {
                            buf[buf_pos] = 32;
                            buf_pos = buf_pos + 1;
                            pad = pad - 1;
                        }
                        var i: usize = 0;
                        while i < len && buf_pos < buf_max {
                            buf[buf_pos] = s[i];
                            buf_pos = buf_pos + 1;
                            i = i + 1;
                        }
                    }
                } else if spec == 115 {
                    const s: &const byte = @va_arg(ap, &const byte);
                    if s != null {
                        const len: usize = strlen(s);
                        var i: usize = 0;
                        while i < len && buf_pos < buf_max {
                            buf[buf_pos] = s[i];
                            buf_pos = buf_pos + 1;
                            i = i + 1;
                        }
                    }
                } else if spec == 100 {
                    const d: i32 = @va_arg(ap, i32);
                    var num: i32 = d;
                    var is_neg: i32 = 0;
                    if num < 0 {
                        is_neg = 1;
                        num = 0 - num;
                    }
                    var digits: [byte: 16] = [];
                    var digit_idx: usize = 0;
                    if num == 0 {
                        digits[0] = 48;
                        digit_idx = 1;
                    } else {
                        var temp: i32 = num;
                        while temp > 0 {
                            const digit: i32 = temp % 10;
                            digits[digit_idx] = (48 + digit) as byte;
                            digit_idx = digit_idx + 1;
                            temp = temp / 10;
                        }
                    }
                    if is_neg > 0 && buf_pos < buf_max {
                        buf[buf_pos] = 45;
                        buf_pos = buf_pos + 1;
                    }
                    var i: usize = 0;
                    while i < digit_idx && buf_pos < buf_max {
                        buf[buf_pos] = digits[digit_idx - 1 - i];
                        buf_pos = buf_pos + 1;
                        i = i + 1;
                    }
                } else if spec == 108 && format_pos + 1 < format_len && format[format_pos + 1] == 100 {
                    // %ld - long (i64)
                    format_pos = format_pos + 1;
                    const ld: i64 = @va_arg(ap, i64);
                    var num64: i64 = ld;
                    var is_neg64: i32 = 0;
                    if num64 < 0 {
                        is_neg64 = 1;
                        num64 = 0 - num64;
                    }
                    var digits64: [byte: 24] = [];
                    var digit_idx64: usize = 0;
                    if num64 == 0 {
                        digits64[0] = 48;
                        digit_idx64 = 1;
                    } else {
                        var temp64: i64 = num64;
                        while temp64 > 0 {
                            const digit: i64 = temp64 % (10 as i64);
                            digits64[digit_idx64] = (48 + digit) as byte;
                            digit_idx64 = digit_idx64 + 1;
                            temp64 = temp64 / (10 as i64);
                        }
                    }
                    if is_neg64 > 0 && buf_pos < buf_max {
                        buf[buf_pos] = 45;
                        buf_pos = buf_pos + 1;
                    }
                    var i: usize = 0;
                    while i < digit_idx64 && buf_pos < buf_max {
                        buf[buf_pos] = digits64[digit_idx64 - 1 - i];
                        buf_pos = buf_pos + 1;
                        i = i + 1;
                    }
                } else if spec == 37 {
                    buf[buf_pos] = 37 as byte;
                    buf_pos = buf_pos + 1;
                } else if spec == 117 {
                    const uval: u32 = @va_arg(ap, u32);
                    var num: u32 = uval;
                    var digits: [byte: 16] = [];
                    var digit_idx: usize = 0;
                    if num == 0 {
                        digits[0] = 48;
                        digit_idx = 1;
                    } else {
                        const ten_u: u32 = 10;
                        while num > 0 && digit_idx < 16 {
                            const digit: i32 = (num % ten_u) as i32;
                            digits[digit_idx] = (48 + digit) as byte;
                            digit_idx = digit_idx + 1;
                            num = num / ten_u;
                        }
                    }
                    var i: usize = 0;
                    while i < digit_idx && buf_pos < buf_max {
                        buf[buf_pos] = digits[digit_idx - 1 - i];
                        buf_pos = buf_pos + 1;
                        i = i + 1;
                    }
                } else if spec == 122 && format_pos + 1 < format_len && format[format_pos + 1] == 117 {
                    format_pos = format_pos + 1;
                    const zu_val: usize = @va_arg(ap, usize);
                    var num: usize = zu_val;
                    const ten: usize = 10;
                    var digits: [byte: 24] = [];
                    var digit_idx: usize = 0;
                    if num == 0 {
                        digits[0] = 48;
                        digit_idx = 1;
                    } else {
                        while num > 0 && digit_idx < 24 {
                            const digit: i32 = (num % ten) as i32;
                            digits[digit_idx] = (48 + digit) as byte;
                            digit_idx = digit_idx + 1;
                            num = num / ten;
                        }
                    }
                    var i: usize = 0;
                    while i < digit_idx && buf_pos < buf_max {
                        buf[buf_pos] = digits[digit_idx - 1 - i];
                        buf_pos = buf_pos + 1;
                        i = i + 1;
                    }
                } else if spec == 103 {
                    const fval: f64 = @va_arg(ap, f64);
                    buf_pos = _fmt_f64_to_buf(buf, buf_pos, buf_max, fval, 6);
                } else if spec == 46 {
                    format_pos = format_pos + 1;
                    var prec: i32 = 0;
                    while format_pos < format_len && format[format_pos] >= 48 && format[format_pos] <= 57 {
                        prec = prec * 10 + (format[format_pos] - 48) as i32;
                        format_pos = format_pos + 1;
                    }
                    if format_pos < format_len && format[format_pos] == 103 {
                        format_pos = format_pos + 1;
                        const fval: f64 = @va_arg(ap, f64);
                        buf_pos = _fmt_f64_to_buf(buf, buf_pos, buf_max, fval, prec);
                    } else {
                        buf[buf_pos] = 37 as byte;
                        buf_pos = buf_pos + 1;
                        if buf_pos < buf_max {
                            buf[buf_pos] = spec;
                            buf_pos = buf_pos + 1;
                        }
                        format_pos = format_pos - 1;
                    }
                } else {
                    buf[buf_pos] = 37 as byte;
                    buf_pos = buf_pos + 1;
                    if buf_pos < buf_max {
                        buf[buf_pos] = spec;
                        buf_pos = buf_pos + 1;
                    }
                }
            }
        } else {
            buf[buf_pos] = c;
            buf_pos = buf_pos + 1;
        }
        format_pos = format_pos + 1;
    }
    @va_end(ap);
    buf[buf_pos] = 0 as byte;
    const result: !isize = sys_write(fd as i32, &buf[0], buf_pos);
    const written: isize = result catch {
        return 0 - 1;
    };
    return written as i32;
}

// fwrite - 向文件流写入数据
// 参数：ptr - 数据指针，size - 单个元素大小，nmemb - 元素数量，stream - 文件流
// 返回：成功写入的元素数量
export fn fwrite(ptr: &const byte, size: usize, nmemb: usize, stream: &FILE) usize {
    if stream == null || ptr == null || size == 0 || nmemb == 0 {
        return 0;
    }
    
    const total_size: usize = size * nmemb;
    
    // 使用缓冲写入
    const result: i64 = write_to_buffer(stream, ptr, total_size);
    if result < 0 {
        return 0;
    }
    
    return (result as usize) / size;
}

// fputc - 向文件流写入一个字符（C 标准库兼容）
// 返回：写入的字符，EOF (-1) 表示错误
export fn fputc(c: i32, stream: &FILE) i32 {
    if stream == null {
        return 0 - 1;  // EOF
    }
    const fd: i64 = stream.fd;
    if fd < 0 {
        return 0 - 1;  // EOF
    }
    
    var ch: byte = c as byte;
    const result: !isize = sys_write(fd as i32, &ch, 1);
    const bytes_written: isize = result catch {
        return 0 - 1;  // EOF
    };
    
    if bytes_written == 1 as isize {
        return c;
    }
    
    return 0 - 1;  // EOF
}

// fputs - 向文件流写入字符串（C 标准库兼容）
// 返回：非负值成功，EOF (-1) 失败
export fn fputs(s: &const byte, stream: &FILE) i32 {
    if s == null || stream == null {
        return 0 - 1;  // EOF
    }
    
    const len: usize = strlen(s);
    if len == 0 {
        return 0;
    }
    
    const written: usize = fwrite(s, 1, len, stream);
    
    if written == len {
        return 0;
    }
    
    return 0 - 1;  // EOF
}

// fflush - 刷新文件流缓冲区（C 标准库兼容）
// 注意：使用低级 I/O 无缓冲，直接返回成功
export fn fflush(stream: &FILE) i32 {
    if stream == null {
        return 0 - 1;
    }
    return 0;
}

// ============================================================
// 文件定位函数 (fseek, ftell, rewind, feof, ferror)
// ============================================================

// fseek - 设置文件位置指针
// 参数：stream - 文件流，offset - 偏移量，whence - 起始位置 (SEEK_SET/SEEK_CUR/SEEK_END)
// 返回：0 成功，-1 失败
export fn fseek(stream: &FILE, offset: i64, whence: i32) i32 {
    if stream == null { return -1; }
    // 简化实现：使用 lseek
    const result: !i64 = @syscall(SYS_lseek, stream.fd, offset, whence as i64);
    const ret: i64 = result catch { return -1; };
    if ret < 0 { return -1; }
    return 0;
}

// ftell - 获取当前文件位置
// 返回：当前位置，失败返回 -1
export fn ftell(stream: &FILE) i64 {
    if stream == null { return -1; }
    const result: !i64 = @syscall(SYS_lseek, stream.fd, 0, 1);  // SEEK_CUR = 1
    const ret: i64 = result catch { return -1; };
    return ret;
}

// rewind - 重置文件位置指针到开头
export fn rewind(stream: &FILE) void {
    if stream == null { return; }
    _ = @syscall(SYS_lseek, stream.fd, 0, 0);  // SEEK_SET = 0
}

// feof - 检查是否到达文件末尾
// 返回：非 0 表示 EOF，0 表示未到达
export fn feof(stream: &FILE) i32 {
    if stream == null { return 0; }
    // 简化实现：总是返回 0
    return 0;
}

// ferror - 检查文件流错误标志
// 返回：非 0 表示有错误，0 表示无错误
export fn ferror(stream: &FILE) i32 {
    if stream == null { return 0; }
    // 简化实现：总是返回 0
    return 0;
}

// clearerr - 清除文件流错误标志
export fn clearerr(stream: &FILE) void {
    if stream == null { return; }
    // 简化实现：无操作
}

// fgetpos - 获取文件位置 (POSIX)
export fn fgetpos(stream: &FILE, pos: &i64) i32 {
    if stream == null || pos == null { return -1; }
    pos[0] = ftell(stream);
    if pos[0] < 0 { return -1; }
    return 0;
}

// fsetpos - 设置文件位置 (POSIX)
export fn fsetpos(stream: &FILE, pos: &i64) i32 {
    if stream == null || pos == null { return -1; }
    return fseek(stream, pos[0], 0);  // SEEK_SET
}

// sprintf - 格式化字符串（简化版本，只支持 %s、%d、%%）
// 返回：写入的字符数（不包括 null 终止符），失败返回负数
export fn sprintf(buf: &byte, format: &const byte, ...) i32 {
    if buf == null || format == null {
        return 0 - 1;
    }
    
    var ap_buf: [byte: 32] = [];
    var ap: &void = &ap_buf[0] as &void;
    @va_start(ap, format);
    var buf_pos: usize = 0;
    var format_pos: usize = 0;
    const format_len: usize = strlen(format);
    const max_buf: usize = 4095;
    
    while format_pos < format_len && buf_pos < max_buf {
        const c: byte = format[format_pos];
        if c == 37 {
            format_pos = format_pos + 1;
            if format_pos < format_len {
                const spec: byte = format[format_pos];
                if spec == 115 {
                    const s: &const byte = @va_arg(ap, &const byte);
                    if s != null {
                        const len: usize = strlen(s);
                        var i: usize = 0;
                        while i < len && buf_pos < max_buf {
                            buf[buf_pos] = s[i];
                            buf_pos = buf_pos + 1;
                            i = i + 1;
                        }
                    }
                } else if spec == 100 {
                    const d: i32 = @va_arg(ap, i32);
                    var num: i32 = d;
                    var is_neg: i32 = 0;
                    if num < 0 {
                        is_neg = 1;
                        num = 0 - num;
                    }
                    var digits: [byte: 16] = [];
                    var digit_idx: usize = 0;
                    if num == 0 {
                        digits[0] = 48;
                        digit_idx = 1;
                    } else {
                        var temp: i32 = num;
                        while temp > 0 {
                            const digit: i32 = temp % 10;
                            digits[digit_idx] = (48 + digit) as byte;
                            digit_idx = digit_idx + 1;
                            temp = temp / 10;
                        }
                    }
                    if is_neg > 0 && buf_pos < max_buf {
                        buf[buf_pos] = 45;
                        buf_pos = buf_pos + 1;
                    }
                    var i: usize = 0;
                    while i < digit_idx && buf_pos < max_buf {
                        buf[buf_pos] = digits[digit_idx - 1 - i];
                        buf_pos = buf_pos + 1;
                        i = i + 1;
                    }
                } else if spec == 37 {
                    buf[buf_pos] = 37 as byte;
                    buf_pos = buf_pos + 1;
                } else if spec == 117 {
                    const uval: u32 = @va_arg(ap, u32);
                    var num: u32 = uval;
                    var digits: [byte: 16] = [];
                    var digit_idx: usize = 0;
                    if num == 0 {
                        digits[0] = 48;
                        digit_idx = 1;
                    } else {
                        const ten_u: u32 = 10;
                        while num > 0 && digit_idx < 16 {
                            const digit: i32 = (num % ten_u) as i32;
                            digits[digit_idx] = (48 + digit) as byte;
                            digit_idx = digit_idx + 1;
                            num = num / ten_u;
                        }
                    }
                    var i: usize = 0;
                    while i < digit_idx && buf_pos < max_buf {
                        buf[buf_pos] = digits[digit_idx - 1 - i];
                        buf_pos = buf_pos + 1;
                        i = i + 1;
                    }
                } else {
                    buf[buf_pos] = 37 as byte;
                    buf_pos = buf_pos + 1;
                    if buf_pos < max_buf {
                        buf[buf_pos] = spec;
                        buf_pos = buf_pos + 1;
                    }
                }
            }
        } else {
            buf[buf_pos] = c;
            buf_pos = buf_pos + 1;
        }
        format_pos = format_pos + 1;
    }
    
    @va_end(ap);
    buf[buf_pos] = 0 as byte;
    return buf_pos as i32;
}

// snprintf - 格式化字符串（带长度限制，支持 %s、%d、%%、%u）
// 返回：写入的字符数（不包括 null 终止符），失败返回负数
export fn snprintf(buf: &byte, n: usize, format: &const byte, ...) i32 {
    if buf == null || format == null || n == 0 {
        return 0 - 1;
    }
    
    var ap_buf: [byte: 32] = [];
    var ap: &void = &ap_buf[0] as &void;
    @va_start(ap, format);
    var buf_pos: usize = 0;
    var format_pos: usize = 0;
    const format_len: usize = strlen(format);
    var max_buf: usize = n - 1;
    if max_buf > 4096 {
        max_buf = 4096;
    }
    
    while format_pos < format_len && buf_pos < max_buf {
        const c: byte = format[format_pos];
        if c == 37 {
            format_pos = format_pos + 1;
            if format_pos < format_len {
                const spec: byte = format[format_pos];
                if spec == 115 {
                    const s: &const byte = @va_arg(ap, &const byte);
                    if s != null {
                        const len: usize = strlen(s);
                        var i: usize = 0;
                        while i < len && buf_pos < max_buf {
                            buf[buf_pos] = s[i];
                            buf_pos = buf_pos + 1;
                            i = i + 1;
                        }
                    }
                } else if spec == 100 {
                    const d: i32 = @va_arg(ap, i32);
                    var num: i32 = d;
                    var is_neg: i32 = 0;
                    if num < 0 {
                        is_neg = 1;
                        num = 0 - num;
                    }
                    var digits: [byte: 16] = [];
                    var digit_idx: usize = 0;
                    if num == 0 {
                        digits[0] = 48;
                        digit_idx = 1;
                    } else {
                        var temp: i32 = num;
                        while temp > 0 {
                            const digit: i32 = temp % 10;
                            digits[digit_idx] = (48 + digit) as byte;
                            digit_idx = digit_idx + 1;
                            temp = temp / 10;
                        }
                    }
                    if is_neg > 0 && buf_pos < max_buf {
                        buf[buf_pos] = 45;
                        buf_pos = buf_pos + 1;
                    }
                    var i: usize = 0;
                    while i < digit_idx && buf_pos < max_buf {
                        buf[buf_pos] = digits[digit_idx - 1 - i];
                        buf_pos = buf_pos + 1;
                        i = i + 1;
                    }
                } else if spec == 37 {
                    buf[buf_pos] = 37 as byte;
                    buf_pos = buf_pos + 1;
                } else if spec == 117 {
                    const uval: u32 = @va_arg(ap, u32);
                    var num: u32 = uval;
                    var digits: [byte: 16] = [];
                    var digit_idx: usize = 0;
                    if num == 0 {
                        digits[0] = 48;
                        digit_idx = 1;
                    } else {
                        const ten_u: u32 = 10;
                        while num > 0 && digit_idx < 16 {
                            const digit: i32 = (num % ten_u) as i32;
                            digits[digit_idx] = (48 + digit) as byte;
                            digit_idx = digit_idx + 1;
                            num = num / ten_u;
                        }
                    }
                    var i: usize = 0;
                    while i < digit_idx && buf_pos < max_buf {
                        buf[buf_pos] = digits[digit_idx - 1 - i];
                        buf_pos = buf_pos + 1;
                        i = i + 1;
                    }
                } else {
                    buf[buf_pos] = 37 as byte;
                    buf_pos = buf_pos + 1;
                    if buf_pos < max_buf {
                        buf[buf_pos] = spec;
                        buf_pos = buf_pos + 1;
                    }
                }
            }
        } else {
            buf[buf_pos] = c;
            buf_pos = buf_pos + 1;
        }
        format_pos = format_pos + 1;
    }
    
    @va_end(ap);
    if buf_pos < n {
        buf[buf_pos] = 0 as byte;
    } else if n > 0 {
        buf[n - 1] = 0 as byte;
    }
    
    return buf_pos as i32;
}

// ============================================================
// 高优先级新增函数
// ============================================================

// printf - 格式化输出到 stdout
export extern "libc" fn printf(format: &const byte, ...) i32 {
    var ap_buf: [byte: 32] = [];
    var ap: &void = &ap_buf[0] as &void;
    @va_start(ap, format);
    
    // 使用 fprintf 的核心逻辑
    var buf: [byte: 4096] = [];
    var buf_pos: usize = 0;
    var format_pos: usize = 0;
    const format_len: usize = strlen(format);
    const buf_max: usize = 4095;
    
    while format_pos < format_len && buf_pos < buf_max {
        const c: byte = format[format_pos];
        if c == 37 {
            format_pos = format_pos + 1;
            if format_pos < format_len {
                const spec: byte = format[format_pos];
                if spec == 115 {
                    const s: &const byte = @va_arg(ap, &const byte);
                    if s != null {
                        const len: usize = strlen(s);
                        var i: usize = 0;
                        while i < len && buf_pos < buf_max {
                            buf[buf_pos] = s[i];
                            buf_pos = buf_pos + 1;
                            i = i + 1;
                        }
                    }
                } else if spec == 100 {
                    const d: i32 = @va_arg(ap, i32);
                    var num: i32 = d;
                    var is_neg: i32 = 0;
                    if num < 0 {
                        is_neg = 1;
                        num = 0 - num;
                    }
                    var digits: [byte: 16] = [];
                    var digit_idx: usize = 0;
                    if num == 0 {
                        digits[0] = 48;
                        digit_idx = 1;
                    } else {
                        while num > 0 {
                            const digit: i32 = num % 10;
                            digits[digit_idx] = (48 + digit) as byte;
                            digit_idx = digit_idx + 1;
                            num = num / 10;
                        }
                    }
                    if is_neg > 0 && buf_pos < buf_max {
                        buf[buf_pos] = 45;
                        buf_pos = buf_pos + 1;
                    }
                    var i: usize = 0;
                    while i < digit_idx && buf_pos < buf_max {
                        buf[buf_pos] = digits[digit_idx - 1 - i];
                        buf_pos = buf_pos + 1;
                        i = i + 1;
                    }
                } else if spec == 37 {
                    buf[buf_pos] = 37 as byte;
                    buf_pos = buf_pos + 1;
                } else if spec == 99 {
                    const ch: i32 = @va_arg(ap, i32);
                    buf[buf_pos] = ch as byte;
                    buf_pos = buf_pos + 1;
                } else {
                    buf[buf_pos] = 37 as byte;
                    buf_pos = buf_pos + 1;
                    if buf_pos < buf_max {
                        buf[buf_pos] = spec;
                        buf_pos = buf_pos + 1;
                    }
                }
            }
        } else {
            buf[buf_pos] = c;
            buf_pos = buf_pos + 1;
        }
        format_pos = format_pos + 1;
    }
    
    @va_end(ap);
    
    // 写入 stdout
    if buf_pos > 0 {
        const result: !i64 = @syscall(SYS_write, STDOUT, &buf[0] as i64, buf_pos as i64);
        result catch {
            return 0 - 1;
        };
    }
    
    return buf_pos as i32;
}

// puts - 输出字符串并换行
export extern "libc" fn puts(s: &const byte) i32 {
    if s == null {
        return 0 - 1;
    }
    
    const len: usize = strlen(s);
    
    // 输出字符串
    if len > 0 {
        const result1: !i64 = @syscall(SYS_write, STDOUT, s as i64, len as i64);
        result1 catch {
            return 0 - 1;
        };
    }
    
    // 输出换行符
    var nl: byte = 10;
    const result2: !i64 = @syscall(SYS_write, STDOUT, &nl as i64, 1);
    result2 catch {
        return 0 - 1;
    };
    
    return 0;
}

// fgets - 从文件读取一行
export extern "libc" fn fgets(buf: &byte, n: i32, stream: &FILE) &byte {
    if buf == null || n <= 0 || stream == null {
        return null as &byte;
    }
    
    var i: i32 = 0;
    while i < n - 1 {
        const c: i32 = fgetc(stream);
        if c == 0 - 1 {  // EOF
            if i == 0 {
                return null as &byte;
            }
            break;
        }
        buf[i] = c as byte;
        i = i + 1;
        if c == 10 {  // '\n'
            break;
        }
    }
    
    buf[i] = 0;
    return buf;
}
