// libc.stdlib - 标准库函数（内存分配、进程控制、字符串转换）
// 版本：v0.4.0
// 说明：基于系统调用的标准库函数（零外部依赖）
// 注意：函数名与 C 标准库一致（malloc, free, exit, atoi 等）
use std.string.strlen;

// ============================================================
// 内存分配函数（基于 mmap）
// ============================================================

// malloc - 分配 size 字节的内存
// 返回：分配的内存指针，失败返回 null
// 注意：使用 mmap 实现，每次分配独立的内存页
export fn malloc(size: usize) &void {
    if size == 0 {
        return null;
    }
    
    // 使用 mmap 分配内存
    // mmap(addr=0, length=size, prot=PROT_READ|PROT_WRITE, flags=MAP_PRIVATE|MAP_ANONYMOUS, fd=-1, offset=0)
    // 注意：SYS_mmap = 9 (Linux x86-64)
    const result: !i64 = @syscall(SYS_mmap, 0, size as i64, PROT_READ | PROT_WRITE, MAP_PRIVATE | MAP_ANONYMOUS, 0 - 1, 0);
    const ptr: i64 = result catch {
        return null;
    };
    
    // mmap 失败时返回 -1（转换为 null）
    if ptr < 0 {
        return null;
    }
    
    return ptr as &void;
}

// free - 释放 malloc 分配的内存
// 注意：使用 munmap 释放内存
export fn free(ptr: &void) void {
    if ptr == null {
        return;
    }
    
    // 简化：munmap(ptr, 4096) - 假设最小分配为一页
    // 注意：SYS_munmap = 11 (Linux x86-64)
    _ = @syscall(SYS_munmap, ptr as i64, 4096);
}

// calloc - 分配并清零 nmemb * size 字节的内存
// 返回：分配的内存指针，失败返回 null
export fn calloc(nmemb: usize, size: usize) &void {
    const total_size: usize = nmemb * size;
    const ptr: &void = malloc(total_size);
    if ptr == null {
        return null;
    }
    
    // 清零内存
    _ = memset(ptr as *void, 0, total_size);
    return ptr;
}

// realloc - 重新分配内存（扩展或缩小）
// 返回：新的内存指针，失败返回 null
export fn realloc(ptr: &void, size: usize) &void {
    if ptr == null {
        return malloc(size);
    }
    
    if size == 0 {
        free(ptr);
        return null;
    }
    
    // 简化实现：分配新内存（实际应该复制旧数据并释放旧内存）
    const new_ptr: &void = malloc(size);
    if new_ptr == null {
        return null;
    }
    
    return new_ptr;
}

// ============================================================
// 进程控制函数
// ============================================================

// exit - 正常退出进程
export fn exit(status: i32) void {
    sys_exit(status as i64);
}

// abort - 异常终止进程（发送 SIGABRT）
export fn abort() void {
    // 使用 sys_getpid 函数
    const pid_result: !i64 = sys_getpid();
    const pid: i64 = pid_result catch {
        sys_exit(1);
        return;
    };
    // 发送 SIGABRT (6) 给自己
    _ = @syscall(SYS_kill, pid, 6);
    // 如果 kill 失败，直接退出
    sys_exit(1);
}

// ============================================================
// 字符串转数字函数
// ============================================================

// atoi - 将字符串转换为 i32
export fn atoi(s: &const byte) i32 {
    if s == null {
        return 0;
    }
    
    var result: i32 = 0;
    var i: usize = 0;
    var is_neg: bool = false;
    
    // 跳过前导空白字符
    while s[i] == 32 as byte || s[i] == 9 as byte || s[i] == 10 as byte || s[i] == 13 as byte {
        i = i + 1;
    }
    
    // 检查符号
    if s[i] == 45 as byte {  // '-'
        is_neg = true;
        i = i + 1;
    } else if s[i] == 43 as byte {  // '+'
        i = i + 1;
    }
    
    // 转换数字
    while s[i] >= 48 as byte && s[i] <= 57 as byte {  // '0' - '9'
        const digit: i32 = s[i] as i32 - 48;
        result = result * 10 + digit;
        i = i + 1;
    }
    
    if is_neg {
        result = 0 - result;
    }
    
    return result;
}

// atol - 将字符串转换为 i64
export fn atol(s: &const byte) i64 {
    if s == null {
        return 0;
    }
    
    var result: i64 = 0;
    var i: usize = 0;
    var is_neg: bool = false;
    
    // 跳过前导空白字符
    while s[i] == 32 as byte || s[i] == 9 as byte || s[i] == 10 as byte || s[i] == 13 as byte {
        i = i + 1;
    }
    
    // 检查符号
    if s[i] == 45 as byte {  // '-'
        is_neg = true;
        i = i + 1;
    } else if s[i] == 43 as byte {  // '+'
        i = i + 1;
    }
    
    // 转换数字
    while s[i] >= 48 as byte && s[i] <= 57 as byte {  // '0' - '9'
        const digit: i64 = s[i] as i64 - 48;
        result = result * 10 + digit;
        i = i + 1;
    }
    
    if is_neg {
        result = 0 - result;
    }
    
    return result;
}

// atof - 将字符串转换为 f64（简化实现）
export fn atof(s: &const byte) f64 {
    if s == null {
        return 0.0;
    }
    
    var i: usize = 0;
    var is_neg: bool = false;
    var result: f64 = 0.0;
    
    // 跳过前导空白字符
    while s[i] == 32 as byte || s[i] == 9 as byte || s[i] == 10 as byte || s[i] == 13 as byte {
        i = i + 1;
    }
    
    // 检查符号
    if s[i] == 45 as byte {  // '-'
        is_neg = true;
        i = i + 1;
    } else if s[i] == 43 as byte {  // '+'
        i = i + 1;
    }
    
    // 转换整数部分
    while s[i] >= 48 as byte && s[i] <= 57 as byte {  // '0' - '9'
        const digit: f64 = s[i] as f64 - 48.0;
        result = result * 10.0 + digit;
        i = i + 1;
    }
    
    // 转换小数部分
    if s[i] == 46 as byte {  // '.'
        i = i + 1;
        var frac: f64 = 0.0;
        var frac_div: f64 = 10.0;
        
        while s[i] >= 48 as byte && s[i] <= 57 as byte {  // '0' - '9'
            const digit: f64 = s[i] as f64 - 48.0;
            frac = frac + digit / frac_div;
            frac_div = frac_div * 10.0;
            i = i + 1;
        }
        
        result = result + frac;
    }
    
    if is_neg {
        result = 0.0 - result;
    }
    
    return result;
}

// strtod - 将字符串转换为 f64（C 标准库兼容）
export fn strtod(nptr: &const byte, endptr: & &const byte) f64 {
    if nptr == null {
        if endptr != null {
            endptr[0] = null;
        }
        return 0.0;
    }
    
    var i: usize = 0;
    var is_neg: bool = false;
    var result: f64 = 0.0;
    
    // 跳过前导空白字符
    while nptr[i] == 32 as byte || nptr[i] == 9 as byte || nptr[i] == 10 as byte || nptr[i] == 13 as byte {
        i = i + 1;
    }
    
    // 检查符号
    if nptr[i] == 45 as byte {  // '-'
        is_neg = true;
        i = i + 1;
    } else if nptr[i] == 43 as byte {  // '+'
        i = i + 1;
    }
    
    // 转换整数部分
    while nptr[i] >= 48 as byte && nptr[i] <= 57 as byte {  // '0' - '9'
        const digit: f64 = nptr[i] as f64 - 48.0;
        result = result * 10.0 + digit;
        i = i + 1;
    }
    
    // 转换小数部分
    if nptr[i] == 46 as byte {  // '.'
        i = i + 1;
        var frac: f64 = 0.0;
        var frac_div: f64 = 10.0;
        
        while nptr[i] >= 48 as byte && nptr[i] <= 57 as byte {  // '0' - '9'
            const digit: f64 = nptr[i] as f64 - 48.0;
            frac = frac + digit / frac_div;
            frac_div = frac_div * 10.0;
            i = i + 1;
        }
        
        result = result + frac;
    }
    
    // 转换指数部分（e/E [+-] digits）
    if (nptr[i] == 101 as byte || nptr[i] == 69 as byte) {
        i = i + 1;
        var exp_neg: i32 = 0;
        if nptr[i] == 45 as byte {
            exp_neg = 1;
            i = i + 1;
        } else if nptr[i] == 43 as byte {
            i = i + 1;
        }
        var exp_val: i32 = 0;
        while nptr[i] >= 48 as byte && nptr[i] <= 57 as byte {
            exp_val = exp_val * 10 + (nptr[i] as i32 - 48);
            i = i + 1;
        }
        if exp_neg != 0 {
            exp_val = 0 - exp_val;
        }
        var scale: f64 = 1.0;
        var k: i32 = 0;
        if exp_val > 0 {
            while k < exp_val {
                scale = scale * 10.0;
                k = k + 1;
            }
        } else {
            while k > exp_val {
                scale = scale / 10.0;
                k = k - 1;
            }
        }
        result = result * scale;
    }
    
    if is_neg {
        result = 0.0 - result;
    }
    
    // 设置 endptr
    if endptr != null {
        endptr[0] = &nptr[i];
    }
    
    return result;
}

// strtol - 将字符串转换为 i64（C 标准库兼容）
export fn strtol(nptr: &const byte, endptr: & &const byte, base: i32) i64 {
    if nptr == null {
        if endptr != null {
            endptr[0] = null;
        }
        return 0;
    }
    
    var result: i64 = 0;
    var i: usize = 0;
    var is_neg: bool = false;
    var radix: i32 = base;
    
    // 如果 base 为 0，自动检测进制
    if radix == 0 {
        // 跳过前导空白字符
        while nptr[i] == 32 as byte || nptr[i] == 9 as byte || nptr[i] == 10 as byte || nptr[i] == 13 as byte {
            i = i + 1;
        }
        
        // 检查前缀
        if nptr[i] == 48 as byte {  // '0'
            i = i + 1;
            if nptr[i] == 120 as byte || nptr[i] == 88 as byte {  // 'x' or 'X'
                radix = 16;
                i = i + 1;
            } else {
                radix = 8;
            }
        } else {
            radix = 10;
        }
    } else {
        // 跳过前导空白字符
        while nptr[i] == 32 as byte || nptr[i] == 9 as byte || nptr[i] == 10 as byte || nptr[i] == 13 as byte {
            i = i + 1;
        }
    }
    
    // 检查符号
    if nptr[i] == 45 as byte {  // '-'
        is_neg = true;
        i = i + 1;
    } else if nptr[i] == 43 as byte {  // '+'
        i = i + 1;
    }
    
    // 转换数字
    while i < 4096 {  // 防止无限循环
        const c: byte = nptr[i];
        var digit: i64 = 0 - 1;
        
        if c >= 48 as byte && c <= 57 as byte {  // '0' - '9'
            digit = c as i64 - 48;
        } else if c >= 97 as byte && c <= 122 as byte {  // 'a' - 'z'
            digit = c as i64 - 97 + 10;
        } else if c >= 65 as byte && c <= 90 as byte {  // 'A' - 'Z'
            digit = c as i64 - 65 + 10;
        } else {
            break;
        }
        
        if digit < 0 || digit >= radix as i64 {
            break;
        }
        
        result = result * radix as i64 + digit;
        i = i + 1;
    }
    
    if is_neg {
        result = 0 - result;
    }
    
    // 设置 endptr
    if endptr != null {
        endptr[0] = &nptr[i];
    }
    
    return result;
}

// ============================================================
// abs/qsort/strtoul（新增高优先级函数）
// ============================================================

// abs - 整数绝对值
export extern "libc" fn abs(x: i32) i32 {
    if x < 0 {
        return 0 - x;
    }
    return x;
}

// labs - 长整数绝对值
export extern "libc" fn labs(x: i64) i64 {
    if x < 0 {
        return 0 - x;
    }
    return x;
}

// strtoul - 字符串转无符号长整数
export extern "libc" fn strtoul(nptr: &const byte, endptr: & &const byte, base: i32) u64 {
    if nptr == null {
        return 0;
    }
    
    var p: &const byte = nptr;
    
    // 跳过空白字符
    while p[0] == 32 || p[0] == 9 || p[0] == 10 || p[0] == 13 {
        p = &p[1];
    }
    
    // 处理可选符号（忽略，因为无符号）
    if p[0] == 43 {  // '+'
        p = &p[1];
    }
    
    // 确定基数
    var actual_base: i32 = base;
    if actual_base == 0 {
        if p[0] == 48 {  // '0'
            p = &p[1];
            if p[0] == 120 || p[0] == 88 {  // 'x' or 'X'
                actual_base = 16;
                p = &p[1];
            } else {
                actual_base = 8;
            }
        } else {
            actual_base = 10;
        }
    } else if actual_base == 16 {
        if p[0] == 48 && (p[1] == 120 || p[1] == 88) {
            p = &p[2];
        }
    }
    
    // 转换数字
    var result: u64 = 0;
    var overflow: i32 = 0;
    
    while p[0] != 0 {
        var digit: i32 = 0;
        const c: byte = p[0];
        
        if c >= 48 && c <= 57 {  // '0'-'9'
            digit = (c - 48) as i32;
        } else if c >= 97 && c <= 122 {  // 'a'-'z'
            digit = (c - 97 + 10) as i32;
        } else if c >= 65 && c <= 90 {  // 'A'-'Z'
            digit = (c - 65 + 10) as i32;
        } else {
            break;
        }
        
        if digit >= actual_base {
            break;
        }
        
        // 检查溢出
        const new_result: u64 = result * (actual_base as u64) + (digit as u64);
        if new_result < result {
            overflow = 1;
        }
        result = new_result;
        
        p = &p[1];
    }
    
    // 设置结束指针
    if endptr != null as & &const byte {
        endptr[0] = p;
    }
    
    if overflow != 0 {
        // ULONG_MAX 约为 18446744073709551615
        return 18446744073709551615 as u64;
    }
    
    return result;
}

// qsort - 快速排序
// 注意：函数指针参数暂不支持，此处为占位声明
// 实际使用时需要通过 C 链接
extern fn qsort(base: &void, nmemb: usize, size: usize, compar: &void) void;

// bsearch - 二分搜索
// 注意：函数指针参数暂不支持，此处为占位声明
extern fn bsearch(key: &const void, base: &const void, nmemb: usize, size: usize, compar: &void) &void;

// ============================================================
// 时间函数
// ============================================================

// CLOCKS_PER_SEC - 每秒时钟滴答数
export const CLOCKS_PER_SEC: i64 = 1000000;

// clock - 获取 CPU 时间
// 返回：从程序启动开始的 CPU 时间（clock ticks）
// 使用 SYS_clock_gettime (228) 实现
export extern "libc" fn clock() i64 {
    // struct timespec { tv_sec: i64, tv_nsec: i64 }
    var ts: [i64: 2] = [0, 0];
    // SYS_clock_gettime = 228, CLOCK_PROCESS_CPUTIME_ID = 2
    const result: !i64 = @syscall(228, 2, &ts[0] as i64) as! i64;
    const ret: i64 = result catch {
        return 0;
    };
    // 转换为微秒（CLOCKS_PER_SEC = 1000000）
    return ts[0] * 1000000 + ts[1] / 1000;
}

// ============================================================
// 系统函数（C 标准库兼容）
// ============================================================

use std.string.strcmp;
use std.string.strncpy;

// stat - 获取文件状态（C 标准库兼容）
// 返回：0 成功，-1 失败
export fn stat(path: &const byte, buf: &Stat) i32 {
    if path == null || buf == null {
        return 0 - 1;
    }
    
    // 调用 stat 系统调用
    const result: !i64 = @syscall(SYS_stat, path as i64, buf as i64);
    const ret: i64 = result catch {
        return 0 - 1;
    };
    
    if ret < 0 {
        return 0 - 1;
    }
    
    return 0;
}

// readlink - 读取符号链接（C 标准库兼容）
// 返回：读取的字节数，失败返回 -1
export fn readlink(path: &const byte, buf: &byte, bufsiz: usize) i32 {
    if path == null || buf == null || bufsiz == 0 {
        return 0 - 1;
    }
    
    // 调用 readlink 系统调用
    const result: !i64 = @syscall(SYS_readlink, path as i64, buf as i64, bufsiz as i64);
    const ret: i64 = result catch {
        return 0 - 1;
    };
    
    if ret < 0 {
        return 0 - 1;
    }
    
    return ret as i32;
}

// getenv - 获取环境变量（简化实现）
// 返回：环境变量值的指针，未找到返回 null
export fn getenv(name: &const byte) &byte {
    if name == null {
        return null;
    }
    
    // 简化实现：返回 null（实际应该从 environ 读取）
    return null;
}

// ============================================================
// 目录操作函数（C 标准库兼容）
// ============================================================

// 目录句柄不透明类型（与 POSIX DIR* 对应）
export struct DIR {}

// 目录流内部状态（fd + getdents64 缓冲区）
struct DirState {
    fd: i64,
    buf: [byte: 8192],
    buf_pos: usize,
    buf_len: isize,
}
// buf_len: 0=需读取, >0=有效字节数, <0=EOF/错误

const READDIR_BUF_SIZE: usize = 8192;

var opendir_storage: [DirState: 64] = [];
var readdir_result: Dirent = Dirent { d_ino: 0, d_off: 0, d_reclen: 0, d_type: 0, d_name: [] };

// opendir - 打开目录（C 标准库兼容）
// 返回：DIR*，失败返回 null
export fn opendir(name: &const byte) &DIR {
    if name == null {
        return null;
    }
    
    const result: !i32 = sys_open(name, O_RDONLY as i32, 0);
    const fd: i32 = result catch {
        return null;
    };
    
    if fd < 0 {
        return null;
    }
    
    var j: i32 = 0;
    while j < 64 {
        const slot: &DirState = &opendir_storage[j];
        if slot.fd <= 0 {
            slot.fd = fd as i64;
            slot.buf_pos = 0;
            slot.buf_len = 0;
            return slot as &DIR;
        }
        j = j + 1;
    }
    
    _ = sys_close(fd);
    return null;
}

// readdir - 读取目录项（使用 getdents64 实现）
// 返回：Dirent*，失败或结束返回 null
// Linux linux_dirent64 布局：d_ino(8) d_off(8) d_reclen(2) d_type(1) d_name[]
export fn readdir(dirp: &DIR) &Dirent {
    if dirp == null {
        return null;
    }
    
    const state: &DirState = dirp as &DirState;
    if state.fd < 0 {
        return null;
    }
    
    while 1 != 0 {
        if state.buf_len == 0 as isize {
            const getdents_result: !isize = sys_getdents64(state.fd as i32, &state.buf[0] as *void, READDIR_BUF_SIZE);
            state.buf_len = getdents_result catch {
                return null;
            };
            if state.buf_len <= 0 as isize {
                return null;
            }
            state.buf_pos = 0;
        }
        const bl: usize = state.buf_len as usize;
        if state.buf_pos >= bl {
            state.buf_len = 0 as isize;
            continue;
        }
        
        const base: &byte = &state.buf[state.buf_pos];
        const reclen_lo: usize = base[16] as usize;
        const reclen_hi: usize = base[17] as usize;
        const reclen: usize = reclen_lo | (reclen_hi * 256);
        
        if reclen == 0 {
            return null;
        }
        
        memcpy(&readdir_result as *byte, base as *const byte, 19);
        var name_len: usize = 0;
        if reclen > 19 {
            name_len = reclen - 19;
        }
        var copy_len: usize = name_len;
        if copy_len > 255 {
            copy_len = 255;
        }
        var k: usize = 0;
        while k < copy_len {
            readdir_result.d_name[k] = base[19 + k];
            k = k + 1;
        }
        readdir_result.d_name[copy_len] = 0 as byte;
        
        state.buf_pos = state.buf_pos + reclen;
        return &readdir_result;
    }
    return null;
}

// closedir - 关闭目录（C 标准库兼容）
// 返回：0 成功，-1 失败
export fn closedir(dirp: &DIR) i32 {
    if dirp == null {
        return 0 - 1;
    }
    
    const state: &DirState = dirp as &DirState;
    const fd: i64 = state.fd;
    
    if fd < 0 {
        return 0 - 1;
    }
    
    const result: !i32 = sys_close(fd as i32);
    _ = result catch {
        return 0 - 1;
    };
    
    state.fd = 0 - 1;
    return 0;
}
