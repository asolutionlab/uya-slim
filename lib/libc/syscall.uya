// libc.syscall - Linux 系统调用封装
// 版本：v0.4.0
// 说明：基于 @syscall 内置函数的系统调用接口，支持 extern "libc" fn 语法

// ============================================================
// 系统调用号常量（Linux x86-64）
// ============================================================

export const SYS_read: i64 = 0;
export const SYS_write: i64 = 1;
export const SYS_open: i64 = 2;
export const SYS_close: i64 = 3;
export const SYS_stat: i64 = 4;
export const SYS_fstat: i64 = 5;
export const SYS_lseek: i64 = 8;
export const SYS_mmap: i64 = 9;
export const SYS_munmap: i64 = 11;
export const SYS_brk: i64 = 12;
export const SYS_ioctl: i64 = 16;
export const SYS_access: i64 = 21;
export const SYS_dup: i64 = 32;
export const SYS_dup2: i64 = 33;
export const SYS_getpid: i64 = 39;
export const SYS_getppid: i64 = 110;
export const SYS_fork: i64 = 57;
export const SYS_execve: i64 = 59;
export const SYS_exit: i64 = 60;
export const SYS_kill: i64 = 62;
export const SYS_getcwd: i64 = 79;
export const SYS_chdir: i64 = 80;
export const SYS_mkdir: i64 = 83;
export const SYS_rmdir: i64 = 84;
export const SYS_unlink: i64 = 87;
export const SYS_readlink: i64 = 89;
export const SYS_getdents64: i64 = 217;
export const SYS_setrlimit: i64 = 160;
export const SYS_getrlimit: i64 = 97;

// ============================================================
// 文件操作标志（open）
// ============================================================

export const O_RDONLY: i64 = 0;
export const O_WRONLY: i64 = 1;
export const O_RDWR: i64 = 2;
export const O_CREAT: i64 = 0x40;
export const O_EXCL: i64 = 0x80;
export const O_TRUNC: i64 = 0x200;
export const O_APPEND: i64 = 0x400;
export const O_DIRECTORY: i64 = 0x10000;

// ============================================================
// 文件权限模式
// ============================================================

export const S_IRWXU: i64 = 0o700;   // 用户读写执行
export const S_IRUSR: i64 = 0o400;   // 用户读
export const S_IWUSR: i64 = 0o200;   // 用户写
export const S_IXUSR: i64 = 0o100;   // 用户执行

export const S_IRWXG: i64 = 0o70;    // 组读写执行
export const S_IRGRP: i64 = 0o40;    // 组读
export const S_IWGRP: i64 = 0o20;    // 组写
export const S_IXGRP: i64 = 0o10;    // 组执行

export const S_IRWXO: i64 = 0o7;     // 其他读写执行
export const S_IROTH: i64 = 0o4;     // 其他读
export const S_IWOTH: i64 = 0o2;     // 其他写
export const S_IXOTH: i64 = 0o1;     // 其他执行

// ============================================================
// SEEK 标志（lseek）
// ============================================================
// SEEK_* 常量已移至 unistd.uya
// ============================================================

// ============================================================
// 标准文件描述符（兼容旧名称）
// 注意：STDIN_FILENO/STDOUT_FILENO/STDERR_FILENO 已移至 unistd.uya
// ============================================================

export const UYA_STDIN_FILENO: i64 = 0;
export const UYA_STDOUT_FILENO: i64 = 1;
export const UYA_STDERR_FILENO: i64 = 2;

// ============================================================
// mmap 标志
// ============================================================

export const MAP_PRIVATE: i32 = 2;
export const MAP_ANONYMOUS: i32 = 32;
export const PROT_READ: i32 = 1;
export const PROT_WRITE: i32 = 2;

// ============================================================
// 错误码常量已移至 lib/libc/errno.uya
// ============================================================

// ============================================================
// stat 结构体（Linux x86_64，与内核 stat 系统调用布局完全一致）
// 参考：arch/x86/include/uapi/asm/stat.h
// ============================================================

export struct Stat {
    st_dev: i64,
    st_ino: i64,
    st_nlink: i64,
    st_mode: i32,
    st_uid: i32,
    st_gid: i32,
    _pad0: i32,
    st_rdev: i64,
    st_size: i64,
    st_blksize: i64,
    st_blocks: i64,
    st_atime: i64,
    st_atime_nsec: i64,
    st_mtime: i64,
    st_mtime_nsec: i64,
    st_ctime: i64,
    st_ctime_nsec: i64,
    _unused0: i64,
    _unused1: i64,
    _unused2: i64,
}

// ============================================================
// dirent 结构体
// ============================================================

export struct Dirent {
    d_ino: i64,
    d_off: i64,
    d_reclen: i16,
    d_type: i8,
    d_name: [byte: 256],
}

// ============================================================
// 系统调用封装函数
// ============================================================

// sys_write - 写入文件描述符
export extern "libc" fn sys_write(fd: i32, buf: *const byte, count: usize) !isize {
    return @syscall(SYS_write, fd as i64, buf as i64, count as i64) as! isize;
}

// sys_read - 从文件描述符读取
export extern "libc" fn sys_read(fd: i32, buf: *byte, count: usize) !isize {
    return @syscall(SYS_read, fd as i64, buf as i64, count as i64) as! isize;
}

// sys_open - 打开文件
export extern "libc" fn sys_open(pathname: *const byte, flags: i32, mode: i32) !i32 {
    return @syscall(SYS_open, pathname as i64, flags as i64, mode as i64) as! i32;
}

// sys_close - 关闭文件描述符
export extern "libc" fn sys_close(fd: i32) !i32 {
    return @syscall(SYS_close, fd as i64) as! i32;
}

// sys_exit - 退出进程
export extern "libc" fn sys_exit(status: i32) void {
    _ = @syscall(SYS_exit, status as i64);
}

// sys_getpid - 获取当前进程 ID
export extern "libc" fn sys_getpid() !i64 {
    return @syscall(SYS_getpid);
}

// sys_lseek - 移动文件读写位置
export extern "libc" fn sys_lseek(fd: i32, offset: i64, whence: i32) !i64 {
    return @syscall(SYS_lseek, fd as i64, offset, whence as i64);
}

// sys_access - 检查文件访问权限
export extern "libc" fn sys_access(pathname: *const byte, mode: i32) !i32 {
    return @syscall(SYS_access, pathname as i64, mode as i64) as! i32;
}

// sys_unlink - 删除文件
export extern "libc" fn sys_unlink(pathname: *const byte) !i32 {
    return @syscall(SYS_unlink, pathname as i64) as! i32;
}

// sys_mkdir - 创建目录
export extern "libc" fn sys_mkdir(pathname: *const byte, mode: i32) !i32 {
    return @syscall(SYS_mkdir, pathname as i64, mode as i64) as! i32;
}

// sys_rmdir - 删除目录
export extern "libc" fn sys_rmdir(pathname: *const byte) !i32 {
    return @syscall(SYS_rmdir, pathname as i64) as! i32;
}

// sys_chdir - 切换当前工作目录
export extern "libc" fn sys_chdir(path: *const byte) !i32 {
    return @syscall(SYS_chdir, path as i64) as! i32;
}

// sys_getcwd - 获取当前工作目录
export extern "libc" fn sys_getcwd(buf: *byte, size: usize) !isize {
    return @syscall(SYS_getcwd, buf as i64, size as i64) as! isize;
}

// sys_mmap - 内存映射
export extern "libc" fn sys_mmap(addr: *void, length: usize, prot: i32, flags: i32, fd: i32, offset: i64) !*void {
    return @syscall(SYS_mmap, addr as i64, length as i64, prot as i64, flags as i64, fd as i64, offset as i64) as! *void;
}

// sys_munmap - 解除内存映射
export extern "libc" fn sys_munmap(addr: *void, length: usize) !i32 {
    return @syscall(SYS_munmap, addr as i64, length as i64) as! i32;
}

// sys_stat - 获取文件状态
export extern "libc" fn sys_stat(pathname: *const byte, statbuf: &Stat) !i32 {
    return @syscall(SYS_stat, pathname as i64, statbuf as i64) as! i32;
}

// sys_kill - 发送信号
export extern "libc" fn sys_kill(pid: i64, sig: i32) !i32 {
    return @syscall(SYS_kill, pid, sig as i64) as! i32;
}

// sys_readlink - 读取符号链接
export extern "libc" fn sys_readlink(pathname: *const byte, buf: *byte, bufsiz: usize) !isize {
    return @syscall(SYS_readlink, pathname as i64, buf as i64, bufsiz as i64) as! isize;
}

// ============================================================
// 资源限制（rlimit）
// ============================================================

// rlimit 结构体（Linux x86_64）
export struct RLimit {
    rlim_cur: u64,  // 软限制
    rlim_max: u64   // 硬限制
}

// RLIMIT_STACK - 堆栈大小限制
export const RLIMIT_STACK: i32 = 3;

// sys_setrlimit - 设置资源限制
export extern "libc" fn sys_setrlimit(resource: i32, rlim: &const RLimit) !i32 {
    return @syscall(SYS_setrlimit, resource as i64, rlim as i64) as! i32;
}

// sys_getrlimit - 获取资源限制
export extern "libc" fn sys_getrlimit(resource: i32, rlim: &RLimit) !i32 {
    return @syscall(SYS_getrlimit, resource as i64, rlim as i64) as! i32;
}

// sys_getdents64 - 读取目录项
export extern "libc" fn sys_getdents64(fd: i32, dirp: *void, count: usize) !isize {
    return @syscall(SYS_getdents64, fd as i64, dirp as i64, count as i64) as! isize;
}
