// ============================================================
// 宏定义（C 兼容）
// ============================================================

// 在 C 代码中，这些是宏：
// #define va_start(ap, last) __va_start(&(ap), last)
// #define va_arg(ap, type) __va_arg(&(ap), type)
// #define va_end(ap) __va_end(&(ap))
// #define va_copy(dest, src) __va_copy(&(dest), &(src))

// 在 Uya 中，我们使用函数调用：
// va_start(&ap, last_param);
// va_arg_i32(&ap)  // 或其他类型特定版本
// va_end(&ap);
// va_copy(&dest, src);
