// lib/std/io/file.uya - 文件 I/O 抽象层
// 基于 uya-dev-flow 规则设计

// 基础文件操作
export struct File {
    fd: i32,
    flags: u8,  // 文件标志位
}

// 文件标志位定义
const FILE_RDONLY: u8 = 1 << 0;
const FILE_WRONLY: u8 = 1 << 1;
const FILE_RDWR: u8 = FILE_RDONLY | FILE_WRONLY;
const FILE_APPEND: u8 = 1 << 2;
const FILE_CREATE: u8 = 1 << 3;

// 根据文档，文件 I/O 抽象层依赖 syscall 层（或 osal 层）
