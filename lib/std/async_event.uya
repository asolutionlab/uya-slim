// lib/std/async_event.uya - 异步事件循环抽象与 Linux epoll 实现
//
// 模块路径：use std.async_event
// 设计见 docs/std_async_design.md 阶段 3（std.async.event）。
//
// 版本：2.0 - 显式状态机 + generation 防止 fd 复用混淆

use std;
use std.async;
use libc.errno;
use libc.syscall;
use libc.stdlib;

error EventLoopSlotsFull;
error EventLoopInvalidCapacity;
error EventLoopAllocFailed;

const LINUX_EPOLL_DEFAULT_CAPACITY: i32 = 1024;
const LINUX_EPOLL_FD_EMPTY: i32 = 0 - 1;
const LINUX_EPOLL_FD_TOMBSTONE: i32 = 0 - 2;

/// 事件关注类型：可读、可写、可读可写
export union EventKind {
    Readable: void,
    Writable: void,
    ReadWrite: void,
}

/// Slot 状态常量
const SLOT_STATE_EMPTY: i32 = 0;        // 空闲槽位
const SLOT_STATE_REGISTERED: i32 = 1;   // 已注册到 epoll，可接收事件

/// 将 EventKind 转为 epoll 事件掩码（仅 Linux 实现使用）
fn event_kind_to_epoll(k: EventKind) i32 {
    std.cfg(std.target_os == .tos_macos, {
        return 0;
    }, {
    match k {
        .Readable(_) => { return EPOLLIN as i32; },
        .Writable(_) => { return EPOLLOUT as i32; },
        .ReadWrite(_) => { return (EPOLLIN | EPOLLOUT) as i32; },
    };
    return 0 as i32;
    })
}

fn event_kind_to_poll(k: EventKind) i16 {
    match k {
        .Readable(_) => { return POLLIN; },
        .Writable(_) => { return POLLOUT; },
        .ReadWrite(_) => { return POLLIN | POLLOUT; },
    };
    return 0 as i16;
}

fn epoll_interest_or_default(fd: i32, interest: EventKind) EpollEvent {
    return EpollEvent{
        events: event_kind_to_epoll(interest) as u32,
        _pad: 0,
        data: fd as u64,
    };
}

/// 事件循环统一接口：注册 fd、注销、轮询
export interface EventLoop {
    fn register(self: &Self, fd: i32, interest: EventKind, waker: &Waker) !i32;
    fn deregister(self: &Self, fd: i32) !i32;
    fn poll(self: &Self, timeout_ms: i32) !i32;
}

/// Linux epoll 事件循环实现（默认1024容量，可在构造时配置实例容量）
/// 
/// 线程安全：此实现非线程安全，所有操作应在单线程执行。
/// fd 生命周期：register -> (mod) -> deregister，deregister 后 fd 保留在 epoll 中但事件掩码为 0。
/// fd 复用：通过 generation 字段防止 fd 复用混淆。
export struct LinuxEpoll : EventLoop {
    epfd: i32,                          // epoll 实例文件描述符
    slot_capacity: i32,                 // 当前实例可使用的 slot 数量
    event_capacity: i32,                // 单次 poll 可接收的事件数量
    slot_states: &i32,                  // SLOT_STATE_EMPTY / SLOT_STATE_REGISTERED
    slot_fds: &i32,                     // 关联的文件描述符
    slot_wakers: &usize,                // Waker 指针（0 表示无）
    slot_interests: &i16,               // poll(2) 事件关注掩码（macOS fallback 使用）
    slot_generations: &u32,             // 代际计数，防止 fd 复用混淆
    slot_next_free: &i32,               // 空闲 slot 链表
    fd_keys: &i32,                      // fd -> slot 哈希表 key
    fd_slot_indices: &i32,              // fd -> slot 哈希表 value
    fd_map_capacity: i32,               // fd 哈希表容量
    free_slot_head: i32,                // 空闲 slot 链表头
    events: &EpollEvent,                // 单次 poll 复用的 event buffer
    poll_fds: &PollFd,                  // macOS poll(2) fallback 复用的 fd buffer
    next_generation: u32,               // 全局代际计数器

    /// 查找指定 fd 的 slot（通过 fd 哈希索引查找）
    fn find_slot(self: &Self, fd: i32) i32 {
        if self.fd_map_capacity <= 0 {
            return 0 - 1;
        }
        var idx: i32 = linux_epoll_fd_hash(fd, self.fd_map_capacity);
        var probes: i32 = 0;
        while probes < self.fd_map_capacity {
            const key: i32 = self.fd_keys[idx];
            if key == LINUX_EPOLL_FD_EMPTY {
                return 0 - 1;
            }
            if key == fd {
                const slot_idx: i32 = self.fd_slot_indices[idx];
                if slot_idx >= 0 && slot_idx < self.slot_capacity && self.slot_states[slot_idx] == SLOT_STATE_REGISTERED {
                    return slot_idx;
                }
                return 0 - 1;
            }
            idx = idx + 1;
            if idx >= self.fd_map_capacity {
                idx = 0;
            }
            probes = probes + 1;
        }
        return 0 - 1;
    }

    /// 分配空闲 slot（通过空闲链表 O(1) 弹出）
    fn alloc_slot(self: &Self) i32 {
        const slot_idx: i32 = self.free_slot_head;
        if slot_idx < 0 || slot_idx >= self.slot_capacity {
            return 0 - 1;
        }
        self.free_slot_head = self.slot_next_free[slot_idx];
        self.slot_next_free[slot_idx] = 0 - 1;
        return slot_idx;
    }

    /// 初始化 slot 为注册状态
    fn init_slot(self: &Self, slot_idx: i32, fd: i32, interest: EventKind, waker: &Waker) void {
        const idx: usize = (slot_idx as! usize).value;
        const gen: u32 = self.next_generation;
        self.next_generation = self.next_generation + 1;
        self.slot_states[idx] = SLOT_STATE_REGISTERED;
        self.slot_fds[idx] = fd;
        self.slot_wakers[idx] = (waker as &void) as usize;
        self.slot_interests[idx] = event_kind_to_poll(interest);
        self.slot_generations[idx] = gen;
        linux_epoll_fd_map_put(self, fd, slot_idx);
    }

    /// 清空 slot
    fn clear_slot(self: &Self, slot_idx: i32) void {
        if slot_idx < 0 || slot_idx >= self.slot_capacity {
            return;
        }
        const idx: usize = (slot_idx as! usize).value;
        const fd: i32 = self.slot_fds[idx];
        linux_epoll_fd_map_remove(self, fd);
        self.slot_states[idx] = SLOT_STATE_EMPTY;
        self.slot_fds[idx] = 0;
        self.slot_wakers[idx] = 0 as usize;
        self.slot_interests[idx] = 0 as i16;
        self.slot_generations[idx] = 0;
        self.slot_next_free[idx] = self.free_slot_head;
        self.free_slot_head = slot_idx;
    }

    /// 注册 fd 到 epoll
    /// 
    /// 行为：
    /// - 若 fd 已注册：修改关注事件（EPOLL_CTL_MOD）
    /// - 若 fd 未注册：新增到 epoll（EPOLL_CTL_ADD）
    /// - 容错：处理 EEXIST（已存在）、ENOENT（不存在）等边界情况
    fn register(self: &Self, fd: i32, interest: EventKind, waker: &Waker) !i32 {
        std.cfg(std.target_os == .tos_macos, {
            _ = interest;
            const slot: i32 = self.find_slot(fd);
            if slot >= 0 {
                self.slot_wakers[slot] = (waker as &void) as usize;
                self.slot_interests[slot] = event_kind_to_poll(interest);
                return 0;
            }
            const new_slot: i32 = self.alloc_slot();
            if new_slot < 0 {
                return error.EventLoopSlotsFull;
            }
            self.init_slot(new_slot, fd, interest, waker);
            return 0;
        }, {
        var ev: EpollEvent = epoll_interest_or_default(fd, interest);
        var slot: i32 = self.find_slot(fd);
        if slot >= 0 {
            const mod_result: !i32 = sys_epoll_ctl(self.epfd, EPOLL_CTL_MOD, fd, &ev);
            if mod_result.error_id != 0 {
                const eid: i32 = mod_result.error_id as i32;
                if eid == ENOENT || eid == EBADF {
                    self.clear_slot(slot);
                    slot = 0 - 1;
                } else {
                    return mod_result as! i32;
                }
            } else {
                self.slot_wakers[slot] = (waker as &void) as usize;
                self.slot_interests[slot] = event_kind_to_poll(interest);
                return 0;
            }
        }

        slot = self.alloc_slot();
        if slot < 0 {
            return error.EventLoopSlotsFull;
        }
        const add_result: !i32 = sys_epoll_ctl(self.epfd, EPOLL_CTL_ADD, fd, &ev);
        if add_result.error_id != 0 {
            const eid: i32 = add_result.error_id as i32;
            if eid == EEXIST {
                const mod_result: !i32 = sys_epoll_ctl(self.epfd, EPOLL_CTL_MOD, fd, &ev);
                if mod_result.error_id != 0 {
                    const mod_eid: i32 = mod_result.error_id as i32;
                    if mod_eid == ENOENT || mod_eid == EBADF {
                        const add_retry: !i32 = sys_epoll_ctl(self.epfd, EPOLL_CTL_ADD, fd, &ev);
                        if add_retry.error_id != 0 {
                            return add_retry as! i32;
                        }
                    } else {
                        return mod_result as! i32;
                    }
                }
                self.init_slot(slot, fd, interest, waker);
                return 0;
            }
            return add_result as! i32;
        }
        self.init_slot(slot, fd, interest, waker);
        return 0;
        })
    }

    /// 从 epoll 注销 fd
    ///
    /// 行为：
    /// - 使用 EPOLL_CTL_MOD 将事件掩码设为 0（fd 保留在 epoll 中）
    /// - 清理内部 slot 状态
    /// - 容错：ENOENT/EBADF 视为已注销，不报错
    fn deregister(self: &Self, fd: i32) !i32 {
        std.cfg(std.target_os == .tos_macos, {
            const slot: i32 = self.find_slot(fd);
            if slot >= 0 {
                self.clear_slot(slot);
            }
            return 0;
        }, {
        const del_result: !i32 = sys_epoll_ctl_del(self.epfd, fd);
        if del_result.error_id != 0 {
            const eid: i32 = del_result.error_id as i32;
            if eid != ENOENT && eid != EBADF {
                return del_result as! i32;
            }
        }
        // 清理 slot
        const slot: i32 = self.find_slot(fd);
        if slot >= 0 {
            self.clear_slot(slot);
        }
        return 0;
        })
    }

    /// 轮询 epoll 事件并唤醒对应的 waker
    fn poll(self: &Self, timeout_ms: i32) !i32 {
        std.cfg(std.target_os == .tos_macos, {
            var i: i32 = 0;
            var poll_count: i32 = 0;
            while i < self.slot_capacity {
                if self.slot_states[i] == SLOT_STATE_REGISTERED && self.slot_wakers[i] != 0 as usize {
                    self.poll_fds[poll_count].fd = self.slot_fds[i];
                    self.poll_fds[poll_count].events = self.slot_interests[i];
                    self.poll_fds[poll_count].revents = 0 as i16;
                    poll_count = poll_count + 1;
                }
                i = i + 1;
            }
            if poll_count <= 0 {
                return 0;
            }
            const ready_count: i32 = try sys_poll(self.poll_fds, poll_count as usize, timeout_ms);
            if ready_count <= 0 {
                return ready_count;
            }
            var woke_count: i32 = 0;
            i = 0;
            while i < poll_count {
                if self.poll_fds[i].revents != 0 as i16 {
                    const fd: i32 = self.poll_fds[i].fd;
                    const slot_idx: i32 = self.find_slot(fd);
                    if slot_idx >= 0 && self.slot_wakers[slot_idx] != 0 as usize {
                        const waker: &Waker = (self.slot_wakers[slot_idx] as &void) as &Waker;
                        waker.wake();
                        woke_count = woke_count + 1;
                    }
                }
                i = i + 1;
            }
            return woke_count;
        }, {
        const wait_result: !i32 = sys_epoll_wait(self.epfd, self.events, self.event_capacity, timeout_ms);
        const n: i32 = wait_result catch |err| {
            return wait_result as! i32;
        };
        var i: i32 = 0;
        while i >= 0 && i < n && i < self.event_capacity {
            const fd: i32 = self.events[i].data as i32;
            const slot_idx: i32 = self.find_slot(fd);
            if slot_idx >= 0 && self.slot_wakers[slot_idx] != 0 as usize {
                const waker: &Waker = (self.slot_wakers[slot_idx] as &void) as &Waker;
                waker.wake();
            }
            i = i + 1;
        }
        return n;
        })
    }
}

fn linux_epoll_capacity_is_valid(capacity: i32) bool {
    return capacity > 0;
}

fn linux_epoll_lookup_capacity_for_slots(slot_capacity: i32) i32 {
    var cap: i32 = 16;
    const target: i32 = slot_capacity * 2;
    while cap < target {
        cap = cap * 2;
    }
    return cap;
}

fn linux_epoll_fd_hash(fd: i32, capacity: i32) i32 {
    var h: i32 = fd;
    if h < 0 {
        h = 0 - h;
    }
    return h % capacity;
}

fn linux_epoll_init_free_slots(next_free: &i32, slot_capacity: i32) void {
    var i: i32 = 0;
    while i < slot_capacity {
        if i + 1 < slot_capacity {
            next_free[i] = i + 1;
        } else {
            next_free[i] = 0 - 1;
        }
        i = i + 1;
    }
}

fn linux_epoll_init_fd_keys(fd_keys: &i32, fd_map_capacity: i32) void {
    var i: i32 = 0;
    while i < fd_map_capacity {
        fd_keys[i] = LINUX_EPOLL_FD_EMPTY;
        i = i + 1;
    }
}

fn linux_epoll_fd_map_put(ep: &LinuxEpoll, fd: i32, slot_idx: i32) void {
    var idx: i32 = linux_epoll_fd_hash(fd, ep.fd_map_capacity);
    var probes: i32 = 0;
    var first_tombstone: i32 = 0 - 1;
    while probes < ep.fd_map_capacity {
        const key: i32 = ep.fd_keys[idx];
        if key == fd {
            ep.fd_slot_indices[idx] = slot_idx;
            return;
        }
        if key == LINUX_EPOLL_FD_TOMBSTONE && first_tombstone < 0 {
            first_tombstone = idx;
        }
        if key == LINUX_EPOLL_FD_EMPTY {
            var target: i32 = idx;
            if first_tombstone >= 0 {
                target = first_tombstone;
            }
            ep.fd_keys[target] = fd;
            ep.fd_slot_indices[target] = slot_idx;
            return;
        }
        idx = idx + 1;
        if idx >= ep.fd_map_capacity {
            idx = 0;
        }
        probes = probes + 1;
    }
    if first_tombstone >= 0 {
        ep.fd_keys[first_tombstone] = fd;
        ep.fd_slot_indices[first_tombstone] = slot_idx;
    }
}

fn linux_epoll_fd_map_remove(ep: &LinuxEpoll, fd: i32) void {
    if ep.fd_map_capacity <= 0 {
        return;
    }
    var idx: i32 = linux_epoll_fd_hash(fd, ep.fd_map_capacity);
    var probes: i32 = 0;
    while probes < ep.fd_map_capacity {
        const key: i32 = ep.fd_keys[idx];
        if key == LINUX_EPOLL_FD_EMPTY {
            return;
        }
        if key == fd {
            ep.fd_keys[idx] = LINUX_EPOLL_FD_TOMBSTONE;
            ep.fd_slot_indices[idx] = 0 - 1;
            return;
        }
        idx = idx + 1;
        if idx >= ep.fd_map_capacity {
            idx = 0;
        }
        probes = probes + 1;
    }
}

fn linux_epoll_alloc_i32(count: i32) !&i32 {
    const bytes: usize = @size_of(i32) * (count as usize);
    const ptr: &void = calloc(1 as usize, bytes);
    if ptr == null {
        return error.EventLoopAllocFailed;
    }
    return ptr as &i32;
}

fn linux_epoll_alloc_i16(count: i32) !&i16 {
    const bytes: usize = @size_of(i16) * (count as usize);
    const ptr: &void = calloc(1 as usize, bytes);
    if ptr == null {
        return error.EventLoopAllocFailed;
    }
    return ptr as &i16;
}

fn linux_epoll_alloc_u32(count: i32) !&u32 {
    const bytes: usize = @size_of(u32) * (count as usize);
    const ptr: &void = calloc(1 as usize, bytes);
    if ptr == null {
        return error.EventLoopAllocFailed;
    }
    return ptr as &u32;
}

fn linux_epoll_alloc_usize(count: i32) !&usize {
    const bytes: usize = @size_of(usize) * (count as usize);
    const ptr: &void = calloc(1 as usize, bytes);
    if ptr == null {
        return error.EventLoopAllocFailed;
    }
    return ptr as &usize;
}

fn linux_epoll_alloc_events(count: i32) !&EpollEvent {
    const bytes: usize = @size_of(EpollEvent) * (count as usize);
    const ptr: &void = calloc(1 as usize, bytes);
    if ptr == null {
        return error.EventLoopAllocFailed;
    }
    return ptr as &EpollEvent;
}

fn linux_epoll_alloc_pollfds(count: i32) !&PollFd {
    const bytes: usize = @size_of(PollFd) * (count as usize);
    const ptr: &void = calloc(1 as usize, bytes);
    if ptr == null {
        return error.EventLoopAllocFailed;
    }
    return ptr as &PollFd;
}

/// 创建 Linux epoll 实例（flags 传 0 或 EPOLL_CLOEXEC，默认容量 1024）
export fn linux_epoll_create(flags: i32) !LinuxEpoll {
    return linux_epoll_create_config(flags, LINUX_EPOLL_DEFAULT_CAPACITY, LINUX_EPOLL_DEFAULT_CAPACITY);
}

/// 创建 Linux epoll 实例，并配置可使用的 slot 容量和单次 poll event 容量。
///
/// 参数：
/// - `flags`：传给 `epoll_create1` 的 flags，通常为 0 或 EPOLL_CLOEXEC。
/// - `slot_capacity`：可注册 fd slot 数，必须大于 0。
/// - `event_capacity`：单次 `poll` 可接收事件数，必须大于 0。
/// 返回值：成功时返回配置后的 `LinuxEpoll`，容量非法或系统调用失败时返回错误。
export fn linux_epoll_create_config(flags: i32, slot_capacity: i32, event_capacity: i32) !LinuxEpoll {
    if !linux_epoll_capacity_is_valid(slot_capacity) || !linux_epoll_capacity_is_valid(event_capacity) {
        return error.EventLoopInvalidCapacity;
    }
    const fd_map_capacity: i32 = linux_epoll_lookup_capacity_for_slots(slot_capacity);
    const slot_states: &i32 = try linux_epoll_alloc_i32(slot_capacity);
    const slot_fds: &i32 = try linux_epoll_alloc_i32(slot_capacity);
    const slot_wakers: &usize = try linux_epoll_alloc_usize(slot_capacity);
    const slot_interests: &i16 = try linux_epoll_alloc_i16(slot_capacity);
    const slot_generations: &u32 = try linux_epoll_alloc_u32(slot_capacity);
    const slot_next_free: &i32 = try linux_epoll_alloc_i32(slot_capacity);
    const fd_keys: &i32 = try linux_epoll_alloc_i32(fd_map_capacity);
    const fd_slot_indices: &i32 = try linux_epoll_alloc_i32(fd_map_capacity);
    const events: &EpollEvent = try linux_epoll_alloc_events(event_capacity);
    const poll_fds: &PollFd = try linux_epoll_alloc_pollfds(slot_capacity);
    linux_epoll_init_free_slots(slot_next_free, slot_capacity);
    linux_epoll_init_fd_keys(fd_keys, fd_map_capacity);
    std.cfg(std.target_os == .tos_macos, {
        _ = flags;
        return LinuxEpoll{
            epfd: -1,
            slot_capacity: slot_capacity,
            event_capacity: event_capacity,
            slot_states: slot_states,
            slot_fds: slot_fds,
            slot_wakers: slot_wakers,
            slot_interests: slot_interests,
            slot_generations: slot_generations,
            slot_next_free: slot_next_free,
            fd_keys: fd_keys,
            fd_slot_indices: fd_slot_indices,
            fd_map_capacity: fd_map_capacity,
            free_slot_head: 0,
            events: events,
            poll_fds: poll_fds,
            next_generation: 1,
        };
    }, {
    const fd: i32 = try sys_epoll_create1(flags);
    return LinuxEpoll{
        epfd: fd,
        slot_capacity: slot_capacity,
        event_capacity: event_capacity,
        slot_states: slot_states,
        slot_fds: slot_fds,
        slot_wakers: slot_wakers,
        slot_interests: slot_interests,
        slot_generations: slot_generations,
        slot_next_free: slot_next_free,
        fd_keys: fd_keys,
        fd_slot_indices: fd_slot_indices,
        fd_map_capacity: fd_map_capacity,
        free_slot_head: 0,
        events: events,
        poll_fds: poll_fds,
        next_generation: 1,
    };
    })
}

// ============================================================================
// 测试与调试辅助函数
// ============================================================================

/// 获取当前已注册的 fd 数量（用于调试/测试）
export fn linux_epoll_registered_count(ep: &LinuxEpoll) i32 {
    var count: i32 = 0;
    var i: i32 = 0;
    while i < ep.slot_capacity {
        if ep.slot_states[i] == SLOT_STATE_REGISTERED {
            count = count + 1;
        }
        i = i + 1;
    }
    return count;
}

/// 检查指定 fd 是否已注册（用于调试/测试）
export fn linux_epoll_is_registered(ep: &LinuxEpoll, fd: i32) bool {
    const slot: i32 = ep.find_slot(fd);
    return slot >= 0;
}

/// 获取 LinuxEpoll 当前实例可使用的 slot 容量。
///
/// 参数：`ep` 为 LinuxEpoll 实例指针。
/// 返回值：当前实例可注册 fd slot 数。
export fn linux_epoll_slot_capacity(ep: &LinuxEpoll) i32 {
    return ep.slot_capacity;
}

/// 获取 LinuxEpoll 当前实例单次 poll 可接收的 event 容量。
///
/// 参数：`ep` 为 LinuxEpoll 实例指针。
/// 返回值：当前实例单次 poll 的最大事件数。
export fn linux_epoll_event_capacity(ep: &LinuxEpoll) i32 {
    return ep.event_capacity;
}

/// 获取 LinuxEpoll 当前实例 fd lookup 哈希表容量。
///
/// 参数：`ep` 为 LinuxEpoll 实例指针。
/// 返回值：当前实例 fd 到 slot 索引表容量，用于验证查找路径不依赖 slot 线性扫描。
export fn linux_epoll_lookup_capacity(ep: &LinuxEpoll) i32 {
    return ep.fd_map_capacity;
}
