/// 使用共享 EventLoop 运行两个 i32 任务，直到二者都完成。
/// 这是迈向通用任务队列前的最小多任务入口，可验证单轮统一注册/轮询/唤醒。
export fn scheduler_run_pair_i32_with_event_loop(self: &Scheduler, loop: EventLoop, first: Future<!i32>, second: Future<!i32>, first_result: &i32, second_result: &i32, timeout_ms: i32) !i32 {
    _ = self;
    var first_done: i32 = 0;
    var second_done: i32 = 0;
    var first_waker: Waker = Waker{};
    var second_waker: Waker = Waker{};

    while first_done == 0 || second_done == 0 {
        var registered_fds: [i32: 2] = [];
        var registered_count: i32 = 0;
        var made_progress: i32 = 0;
        var any_pending: i32 = 0;

        if first_done == 0 {
            first_waker.reset();
            first_waker.clear_io_interest();
            const first_poll: Poll<!i32> = first.poll(&first_waker);
            match first_poll {
                .Ready(ok_val) => {
                    *first_result = ok_val catch {
                        return ok_val as! i32;
                    };
                    first_done = 1;
                    made_progress = 1;
                },
                .Pending(_) => {
                    any_pending = 1;
                    if first_waker.is_woken() {
                        made_progress = 1;
                    } else if first_waker.has_io_interest() {
                        _ = try scheduler_register_waker_interest(loop, &first_waker, &registered_fds[0], &registered_count);
                    }
                },
            };
        }

        if second_done == 0 {
            second_waker.reset();
            second_waker.clear_io_interest();
            const second_poll: Poll<!i32> = second.poll(&second_waker);
            match second_poll {
                .Ready(ok_val) => {
                    *second_result = ok_val catch {
                        return ok_val as! i32;
                    };
                    second_done = 1;
                    made_progress = 1;
                },
                .Pending(_) => {
                    any_pending = 1;
                    if second_waker.is_woken() {
                        made_progress = 1;
                    } else if second_waker.has_io_interest() {
                        _ = try scheduler_register_waker_interest(loop, &second_waker, &registered_fds[0], &registered_count);
                    }
                },
            };
        }

        if first_done != 0 && second_done != 0 {
            return 2;
        }
        if made_progress != 0 {
            continue;
        }
        if registered_count != 0 {
            const poll_result: !i32 = loop.poll(timeout_ms);
            _ = poll_result catch {
                return poll_result as! i32;
            };
            _ = try scheduler_deregister_registered_fds(loop, &registered_fds[0], registered_count);
            continue;
        }
        if any_pending != 0 {
            const poll_result: !i32 = loop.poll(timeout_ms);
            _ = poll_result catch {
                return poll_result as! i32;
            };
        }
    }

    return 2;
}

/// 使用共享 EventLoop 运行固定容量的 i32 任务队列，直到全部完成。
/// 已注册 epoll 等待的 slot 持续保留注册状态，实现真正的多 fd 并发调度。
export fn scheduler_run_task_queue_i32_with_event_loop(self: &Scheduler, loop: EventLoop, queue: &TaskQueue_i32, timeout_ms: i32) !i32 {
    _ = self;
    var completed: i32 = 0;

    while completed < queue.len {
        var registered_count: i32 = 0;
        var made_progress: i32 = 0;
        var i: i32 = 0;

        // 轮询所有 slot（固定 8 容量）
        while i < 8 {
            const slot: &TaskQueueSlot_i32 = &queue.slots[i as usize];
            if slot.active == 0 || slot.done != 0 {
                i = i + 1;
                continue;
            }

            // epoll 中已注册的 slot 不 reset waker（保留 epoll 唤醒状态）
            if slot.epoll_fd == 0 {
                slot.waker.reset();
            }

            const p: Poll<!i32> = slot.future.poll(&slot.waker);
            match p {
                .Ready(ok_val) => {
                    const value: i32 = ok_val catch {
                        return ok_val as! i32;
                    };
                    slot.done = 1;
                    slot.result = value;
                    // 永远不 deregister：已完成任务的 fd 留在 epoll 中，
                    // 但 done=1 使其在下轮 inner loop 被跳过，不影响正确性。
                    slot.waker.reset();
                    completed = completed + 1;
                    made_progress = 1;
                },
                .Pending(_) => {
                    if slot.waker.is_woken() {
                        // 被其他任务唤醒，重试 poll
                        made_progress = 1;
                    } else if slot.waker.has_io_interest() {
                        // 如果还未注册 epoll，则注册（注意：永远不 deregister）
                        if slot.epoll_fd == 0 {
                            const fd: i32 = slot.waker.io_fd();
                            const interest: EventKind = scheduler_event_kind_from_waker(&slot.waker);
                            _ = try loop.register(fd, interest, &slot.waker);
                            slot.epoll_fd = fd;
                            registered_count = registered_count + 1;
                        }
                    }
                },
            };
            i = i + 1;
        }

        if completed >= queue.len {
            return completed;
        }
        if made_progress != 0 {
            continue;
        }
        if registered_count != 0 {
            // 有 slot 注册了 fd，等待 epoll 唤醒
            const poll_result: !i32 = loop.poll(timeout_ms);
            _ = poll_result catch {
                return poll_result as! i32;
            };
            // epoll 唤醒后，reset 所有已注册 slot 的 waker
            var ri: i32 = 0;
            while ri < 8 {
                const rs: &TaskQueueSlot_i32 = &queue.slots[ri as usize];
                if rs.active != 0 && rs.done == 0 && rs.epoll_fd != 0 {
                    rs.waker.reset();
                }
                ri = ri + 1;
            }
            // 不注销 fd！保持注册状态直到任务完成
            continue;
        }

        // 没有注册任何 fd，纯等待
        const poll_result: !i32 = loop.poll(timeout_ms);
        _ = poll_result catch {
            return poll_result as! i32;
        };
    }

    return completed;
}

