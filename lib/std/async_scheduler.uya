// lib/std/async_scheduler.uya - 异步调度器
//
// 模块路径：use std.async_scheduler
// 设计见 docs/std_async_design.md 阶段 5（std.async.scheduler）。
// 当前已支持 block_on 包装、单任务 EventLoop 驱动、双任务共享 EventLoop，
// 以及固定容量 TaskQueue_i32 的共享 EventLoop 多任务轮询。
// 后续仍需补齐通用泛型任务队列、更完整的 Waker 唤醒与多任务调度。

use std.async;
use std.async_event;

error TaskQueueFull;

export const TASK_QUEUE_I32_CAPACITY: i32 = 8;

fn scheduler_event_kind_from_waker(w: &Waker) EventKind {
    const interest: i32 = w.io_interest_code();
    if interest == 1 {
        return EventKind.Readable({});
    }
    if interest == 2 {
        return EventKind.Writable({});
    }
    return EventKind.ReadWrite({});
}

fn scheduler_registered_fd_contains(registered_fds: &i32, registered_count: i32, fd: i32) bool {
    var i: i32 = 0;
    while i < registered_count {
        if registered_fds[i] == fd {
            return true;
        }
        i = i + 1;
    }
    return false;
}

fn scheduler_register_waker_interest(loop: EventLoop, w: &Waker, registered_fds: &i32, registered_count: &i32) !i32 {
    if !w.has_io_interest() {
        return 0;
    }

    const fd: i32 = w.io_fd();
    const interest: EventKind = scheduler_event_kind_from_waker(w);
    const reg_result: !i32 = loop.register(fd, interest, w);
    _ = reg_result catch {
        return reg_result as! i32;
    };

    if scheduler_registered_fd_contains(registered_fds, *registered_count, fd) {
        return 1;
    }
    if *registered_count < 0 || *registered_count >= 8 {
        return 0;
    }
    registered_fds[*registered_count] = fd;
    *registered_count = *registered_count + 1;
    return 1;
}

fn scheduler_deregister_registered_fds(loop: EventLoop, registered_fds: &i32, registered_count: i32) !i32 {
    var i: i32 = 0;
    while i < registered_count {
        const dereg_result: !i32 = loop.deregister(registered_fds[i]);
        _ = dereg_result catch {
            return dereg_result as! i32;
        };
        i = i + 1;
    }
    return 0;
}

export struct TaskQueueSlot_i32 {
    future: Future<!i32>,
    waker: Waker,
    active: i32,
    done: i32,
    result: i32,
    epoll_fd: i32,            // 当前 epoll 中注册的 fd，0 表示未注册
}

export struct TaskQueue_i32 {
    len: i32,
    slots: [TaskQueueSlot_i32: 8] = [],

    fn push(self: &Self, f: Future<!i32>) !i32 {
        if self.len >= TASK_QUEUE_I32_CAPACITY {
            return error.TaskQueueFull;
        }

        const idx: i32 = self.len;
        if idx < 0 || idx >= 8 {
            return error.TaskQueueFull;
        }
        self.slots[idx as usize] = TaskQueueSlot_i32{
            future: f,
            waker: Waker{},
            active: 1,
            done: 0,
            result: 0,
            epoll_fd: 0,
        };
        self.len = idx + 1;
        return idx;
    }

    fn result(self: &Self, idx: i32) i32 {
        if idx < 0 || idx >= self.len || idx >= 8 {
            return 0;
        }
        return self.slots[idx as usize].result;
    }

    fn is_done(self: &Self, idx: i32) bool {
        if idx < 0 || idx >= self.len || idx >= 8 {
            return false;
        }
        return self.slots[idx as usize].done != 0;
    }
}

export fn task_queue_i32_new() TaskQueue_i32 {
    return TaskQueue_i32{ len: 0 };
}

/// 调度器。当前为单任务最小实现；后续可扩展为持有队列与 EventLoop 的完整运行时。
export struct Scheduler {}

/// 创建调度器。
export fn scheduler_new() Scheduler {
    return Scheduler{};
}

/// 同步运行 Future<!T> 直到 Ready，返回 !T。
/// 这是最简单的忙等待入口，仍委托 block_on。
export fn scheduler_run<T>(self: &Scheduler, f: Future<!T>) !T {
    _ = self;
    return block_on(f);
}

/// scheduler_run 的 i32 特化，便于无需显式泛型参数的调用。
export fn scheduler_run_i32(self: &Scheduler, f: Future<!i32>) !i32 {
    _ = self;
    return block_on_i32(f);
}

/// scheduler_run 的 u32 特化，便于无需显式泛型参数的调用。
export fn scheduler_run_u32(self: &Scheduler, f: Future<!u32>) !u32 {
    _ = self;
    return block_on_u32(f);
}

/// 运行 Future<!T>，当 poll 返回 Pending 时主动驱动 EventLoop 一次后再重试。
/// 当前仍是单任务/顺序轮询模型，后续再扩展为真正的任务队列与 Waker 调度。
export fn scheduler_run_with_event_loop<T>(self: &Scheduler, loop: EventLoop, f: Future<!T>, timeout_ms: i32) !T {
    _ = self;
    var w: Waker = Waker{};
    while true {
        w.reset();
        w.clear_io_interest();
        const p: Poll<!T> = f.poll(&w);
        match p {
            .Ready(ok_val) => { return ok_val; },
            .Pending(_) => {
                if w.is_woken() {
                    continue;
                }
                if w.has_io_interest() {
                    const fd: i32 = w.io_fd();
                    const interest: EventKind = scheduler_event_kind_from_waker(&w);
                    const reg_result: !i32 = loop.register(fd, interest, &w);
                    _ = reg_result catch {
                        return reg_result as! T;
                    };
                    const poll_result: !i32 = loop.poll(timeout_ms);
                    _ = poll_result catch {
                        return poll_result as! T;
                    };
                    const dereg_result: !i32 = loop.deregister(fd);
                    _ = dereg_result catch {
                        return dereg_result as! T;
                    };
                    continue;
                }
                const poll_result: !i32 = loop.poll(timeout_ms);
                _ = poll_result catch {
                    return poll_result as! T;
                };
            },
        };
    }
}

