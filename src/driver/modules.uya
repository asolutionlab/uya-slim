// driver/modules.uya - 编译器模块依赖收集
// 从 src/main.uya 拆分
// 在目录中查找包含 main 函数的文件
fn find_main_files_in_dir(
    dir_path: &byte,
    main_files: &(&byte),
    file_paths_buffer: &([byte: PATH_MAX]),
    max_files: i32,
    file_count: &i32
) i32 {
    if dir_path == null || main_files == null || file_count == null {
        return -1;
    }
    file_count[0] = 0;
    const dir: *DIR = opendir(dir_path as *byte);
    if dir == null {
        return -1;
    }
    var entry: *Dirent = readdir(dir);
    while entry != null && file_count[0] < max_files {
        if dirent_is_regular_file(entry as &byte) != 0 {
            const name: *byte = dirent_get_name(entry as &byte) as *byte;
            const name_len: usize = strlen(name);
            if name_len > 4 {
                const ext: *byte = name + (name_len - 4);
                if strcmp(ext, ".uya" as *byte) == 0 {
                    const len: i32 = snprintf(&file_paths_buffer[file_count[0]][0], PATH_MAX, "%s/%s" as *byte, dir_path as *byte, name);
                    if len > 0 && len < PATH_MAX as i32 {
                        if detect_main_function(&file_paths_buffer[file_count[0]][0] as &byte) != 0 {
                            main_files[file_count[0]] = &file_paths_buffer[file_count[0]][0] as &byte;
                            file_count[0] = file_count[0] + 1;
                        }
                    }
                }
            }
        }
        entry = readdir(dir);
    }
    closedir(dir);
    return 0;
}


fn package_mode_module_root_for_path(module_path: &byte, module_root: &byte, out_root: &byte, out_cap: usize) i32 {
    if module_path == null || module_root == null || out_root == null || out_cap == 0usize {
        return 1;
    }
    if module_root[0] == 0 as byte {
        return 1;
    }
    var first_seg: [byte: PATH_MAX] = [];
    var i: usize = 0;
    while module_path[i] != 0 as byte && module_path[i] != 46 as byte {
        if i + 1usize >= PATH_MAX {
            return 1;
        }
        first_seg[i] = module_path[i];
        i = i + 1usize;
    }
    if i == 0usize {
        return 1;
    }
    first_seg[i] = 0 as byte;

    var candidate: [byte: PATH_MAX] = [];
    if snprintf(&candidate[0], PATH_MAX, "%s%s/" as *byte, module_root as *byte, &first_seg[0] as *byte) <= 0 {
        return 1;
    }
    if is_directory(&candidate[0] as &byte) == 0 {
        return 1;
    }
    strcpy(out_root as *byte, &candidate[0] as *byte);
    return 0;
}

fn package_mode_is_top_level_alias_path(module_path: &byte) i32 {
    if module_path == null || module_path[0] == 0 as byte {
        return 0;
    }
    var i: usize = 0;
    while module_path[i] != 0 as byte {
        if module_path[i] == 46 as byte {
            return 0;
        }
        i = i + 1usize;
    }
    return 1;
}

const PACKAGE_MODE_ALIAS_ROOT_MAX: i32 = 128;

var g_package_mode_alias_root_count: i32 = 0;
var g_package_mode_alias_names: [[byte: PATH_MAX]: PACKAGE_MODE_ALIAS_ROOT_MAX] = [];
var g_package_mode_alias_roots: [[byte: PATH_MAX]: PACKAGE_MODE_ALIAS_ROOT_MAX] = [];

fn package_mode_alias_roots_clear() void {
    g_package_mode_alias_root_count = 0;
}

fn package_mode_alias_copy_root(src: &byte, out: &byte, out_cap: usize) i32 {
    if src == null || out == null || out_cap == 0usize {
        return 1;
    }
    const written: i32 = snprintf(out as *byte, out_cap, "%s" as *byte, src as *byte);
    if written <= 0 || written >= out_cap as i32 {
        return 1;
    }
    const len: usize = strlen(out as *byte);
    if len == 0usize {
        return 1;
    }
    if out[len - 1usize] != 47 as byte {
        if len + 1usize >= out_cap {
            return 1;
        }
        out[len] = 47 as byte;
        out[len + 1usize] = 0 as byte;
    }
    return 0;
}

fn package_mode_alias_roots_add(alias: &byte, source_root: &byte) i32 {
    if alias == null || source_root == null || alias[0] == 0 as byte || source_root[0] == 0 as byte {
        return 1;
    }
    if g_package_mode_alias_root_count >= PACKAGE_MODE_ALIAS_ROOT_MAX {
        return 1;
    }
    const idx: i32 = g_package_mode_alias_root_count;
    const idx_checked: !usize = idx as! usize;
    const idx_usize: usize = idx_checked catch {
        return 1;
    };
    if idx_usize >= PACKAGE_MODE_ALIAS_ROOT_MAX as usize {
        return 1;
    }
    const alias_written: i32 = snprintf(&g_package_mode_alias_names[idx_usize][0], PATH_MAX, "%s" as *byte, alias as *byte);
    if alias_written <= 0 || alias_written >= PATH_MAX {
        return 1;
    }
    if package_mode_alias_copy_root(source_root, &g_package_mode_alias_roots[idx_usize][0] as &byte, PATH_MAX as usize) != 0 {
        return 1;
    }
    g_package_mode_alias_root_count = g_package_mode_alias_root_count + 1;
    return 0;
}

fn package_mode_alias_matches(module_path: &byte, alias: &byte, alias_len_out: &usize) i32 {
    if module_path == null || alias == null || alias_len_out == null {
        return 0;
    }
    var i: usize = 0;
    while alias[i] != 0 as byte {
        if module_path[i] != alias[i] {
            return 0;
        }
        i = i + 1usize;
    }
    if i == 0usize {
        return 0;
    }
    if module_path[i] != 0 as byte && module_path[i] != 46 as byte {
        return 0;
    }
    alias_len_out[0] = i;
    return 1;
}

fn package_mode_alias_relative_path(module_path: &byte, alias_len: usize, out: &byte, out_cap: usize) i32 {
    if module_path == null || out == null || out_cap == 0usize {
        return 1;
    }
    out[0] = 0 as byte;
    if module_path[alias_len] == 0 as byte {
        return 0;
    }
    var src_idx: usize = alias_len + 1usize;
    var dst_idx: usize = 0;
    while module_path[src_idx] != 0 as byte {
        if dst_idx + 1usize >= out_cap {
            return 1;
        }
        if module_path[src_idx] == 46 as byte {
            out[dst_idx] = 47 as byte;
        } else {
            out[dst_idx] = module_path[src_idx];
        }
        src_idx = src_idx + 1usize;
        dst_idx = dst_idx + 1usize;
    }
    out[dst_idx] = 0 as byte;
    return 0;
}

fn package_mode_dependency_path_for_module(module_path: &byte, out_root: &byte, out_relative: &byte, out_cap: usize) i32 {
    if module_path == null || out_root == null || out_relative == null {
        return 1;
    }
    var i: i32 = 0;
    while i < g_package_mode_alias_root_count {
        var alias_len: usize = 0;
        const idx_checked: !usize = i as! usize;
        const idx_usize: usize = idx_checked catch {
            return 1;
        };
        if idx_usize >= PACKAGE_MODE_ALIAS_ROOT_MAX as usize {
            return 1;
        }
        if package_mode_alias_matches(module_path, &g_package_mode_alias_names[idx_usize][0] as &byte, &alias_len) != 0 {
            if package_mode_alias_copy_root(&g_package_mode_alias_roots[idx_usize][0] as &byte, out_root, out_cap) != 0 {
                return 1;
            }
            return package_mode_alias_relative_path(module_path, alias_len, out_relative, out_cap);
        }
        i = i + 1;
    }
    return 1;
}

fn package_mode_dependency_module_dir(module_path: &byte, out_dir: &byte, out_cap: usize) i32 {
    var dep_root: [byte: PATH_MAX] = [];
    var dep_relative: [byte: PATH_MAX] = [];
    if package_mode_dependency_path_for_module(module_path, &dep_root[0] as &byte, &dep_relative[0] as &byte, PATH_MAX as usize) != 0 {
        return 0;
    }
    if dep_relative[0] == 0 as byte {
        if out_dir != null && out_cap > 0usize {
            if package_mode_alias_copy_root(&dep_root[0] as &byte, out_dir, out_cap) != 0 {
                return 0;
            }
        }
        return is_directory(&dep_root[0] as &byte);
    }
    var candidate: [byte: PATH_MAX] = [];
    const len: i32 = snprintf(&candidate[0], PATH_MAX, "%s%s" as *byte, &dep_root[0] as *byte, &dep_relative[0] as *byte);
    if len <= 0 || len >= PATH_MAX {
        return 0;
    }
    if is_directory(&candidate[0] as &byte) == 0 {
        return 0;
    }
    if out_dir != null && out_cap > 0usize && len < out_cap as i32 {
        strcpy(out_dir as *byte, &candidate[0]);
    }
    return 1;
}

fn package_mode_dependency_module_file(module_path: &byte, out_file: &byte, out_cap: usize) i32 {
    var dep_root: [byte: PATH_MAX] = [];
    var dep_relative: [byte: PATH_MAX] = [];
    if package_mode_dependency_path_for_module(module_path, &dep_root[0] as &byte, &dep_relative[0] as &byte, PATH_MAX as usize) != 0 {
        return -1;
    }
    if dep_relative[0] == 0 as byte {
        return -1;
    }
    var candidate: [byte: PATH_MAX] = [];
    const len: i32 = snprintf(&candidate[0], PATH_MAX, "%s%s.uya" as *byte, &dep_root[0] as *byte, &dep_relative[0] as *byte);
    if len <= 0 || len >= PATH_MAX {
        return -1;
    }
    const f: *void = fopen(&candidate[0], "r" as *byte);
    if f == null {
        return -1;
    }
    fclose(f);
    if len >= out_cap as i32 {
        return -1;
    }
    strcpy(out_file as *byte, &candidate[0]);
    return 0;
}

// 根据模块路径查找文件
fn find_module_file(
    module_path: &byte,
    module_root: &byte,
    uya_root: &byte,
    buffer: &byte,
    buffer_size: usize
) i32 {
    if module_path == null || buffer == null || buffer_size == 0 {
        return -1;
    }

    if package_mode_dependency_module_file(module_path, buffer, buffer_size) == 0 {
        return 0;
    }

    // `use std;` 仅用于引入平台选择器与 `std.cfg` 语义，应该稳定映射到
    // lib/std/platform.uya，而不是从 lib/std/ 目录里任意挑一个 `.uya` 文件。
    if uya_root != null && strcmp(module_path as *byte, "std" as *byte) == 0 {
        var std_platform_path: [byte: PATH_MAX] = [];
        const std_platform_len: i32 = snprintf(&std_platform_path[0], PATH_MAX, "%sstd/platform.uya" as *byte, uya_root as *byte);
        if std_platform_len > 0 && std_platform_len < PATH_MAX as i32 {
            const std_platform_file: *void = fopen(&std_platform_path[0], "r" as *byte);
            if std_platform_file != null {
                fclose(std_platform_file);
                if (std_platform_len as usize) < buffer_size {
                    strcpy(buffer as *byte, &std_platform_path[0]);
                    return 0;
                }
            }
        }
    }
    
    // 将模块路径转换为文件路径（std.io -> std/io/）
    var file_path: [byte: PATH_MAX] = [];
    const path_len: usize = strlen(module_path as *byte);
    if path_len >= PATH_MAX {
        return -1;
    }
    strcpy(&file_path[0], module_path as *byte);
    // 将 '.' 替换为 '/'
    var i: usize = 0;
    while i < path_len {
        if file_path[i] == 46 {
            file_path[i] = 47;
        }
        i = i + 1;
    }
    
    // package mode：若顶层 alias 在 module_root 下映射为目录，则优先把该目录当成新的根。
    var package_mode_root: [byte: PATH_MAX] = [];
    var package_root_override: &byte = null;
    if module_root != null && module_root[0] != 0 {
        if package_mode_module_root_for_path(module_path, module_root, &package_mode_root[0] as &byte, PATH_MAX) == 0 {
            package_root_override = &package_mode_root[0] as &byte;
        }
    }

    var roots: [&byte: 3] = [null, null, null];
    var root_count: i32 = 0;
    if package_root_override != null {
        roots[root_count] = package_root_override;
        root_count = root_count + 1;
    }
    if module_root != null && module_root[0] != 0 {
        if !(package_root_override != null && package_mode_is_top_level_alias_path(module_path) != 0) {
            roots[root_count] = module_root;
            root_count = root_count + 1;
        }
    }
    if uya_root != null && uya_root[0] != 0 {
        roots[root_count] = uya_root;
        root_count = root_count + 1;
    }

    var ri: i32 = 0;
    while ri < root_count {
        const root: &byte = roots[ri];
        ri = ri + 1;
        if root == null || root[0] == 0 { continue; }
        
        var full_path: [byte: PATH_MAX] = [];
        const len: i32 = snprintf(&full_path[0], PATH_MAX, "%s%s" as *byte, root as *byte, &file_path[0]);
        if len <= 0 || len >= PATH_MAX as i32 { continue; }
        
        // 策略1：目录中查找 .uya 文件
        if is_directory(&full_path[0] as &byte) != 0 {
            const dir: *DIR = opendir(&full_path[0]);
            if dir != null {
                var entry: *Dirent = readdir(dir);
                while entry != null {
                    if dirent_is_regular_file(entry as &byte) != 0 {
                        const name: *byte = dirent_get_name(entry as &byte) as *byte;
                        const name_len: usize = strlen(name);
                        if name_len > 4 {
                            const ext: *byte = name + (name_len - 4);
                            if strcmp(ext, ".uya" as *byte) == 0 {
                                closedir(dir);
                                const result_len: i32 = snprintf(buffer as *byte, buffer_size, "%s%s/%s" as *byte, root as *byte, &file_path[0], name);
                                if result_len > 0 && result_len < buffer_size as i32 {
                                    return 0;
                                }
                            }
                        }
                    }
                    entry = readdir(dir);
                }
                closedir(dir);
            }
        }
        
        // 策略2：直接文件 path.uya
        var uya_path: [byte: PATH_MAX] = [];
        const ulen: i32 = snprintf(&uya_path[0], PATH_MAX, "%s%s.uya" as *byte, root as *byte, &file_path[0]);
        if ulen > 0 && ulen < PATH_MAX as i32 {
            const f: *void = fopen(&uya_path[0], "r" as *byte);
            if f != null {
                fclose(f);
                const ulen_sz_tmp: !usize = ulen as! usize;
                const ulen_sz: usize = ulen_sz_tmp catch { return 1; };
                if ulen_sz < buffer_size {
                    strcpy(buffer as *byte, &uya_path[0]);
                    return 0;
                }
            }
        }
    }
    
    return -1;
}

fn module_path_to_file_path(module_path: &byte, out: &byte, out_cap: usize) i32 {
    if module_path == null || out == null || out_cap == 0 {
        return -1;
    }
    const path_len: usize = strlen(module_path as *byte);
    if path_len >= out_cap {
        return -1;
    }
    strcpy(out as *byte, module_path as *byte);
    var i: usize = 0;
    while i < path_len {
        if out[i] == 46 {
            out[i] = 47;
        }
        i = i + 1;
    }
    return 0;
}

fn find_direct_module_file(
    module_path: &byte,
    module_root: &byte,
    uya_root: &byte,
    buffer: &byte,
    buffer_size: usize
) i32 {
    if module_path == null || buffer == null || buffer_size == 0 {
        return -1;
    }
    if package_mode_dependency_module_file(module_path, buffer, buffer_size) == 0 {
        return 0;
    }
    var file_path: [byte: PATH_MAX] = [];
    if module_path_to_file_path(module_path, &file_path[0] as &byte, PATH_MAX) != 0 {
        return -1;
    }

    var package_mode_root: [byte: PATH_MAX] = [];
    var package_root_override: &byte = null;
    if module_root != null && module_root[0] != 0 {
        if package_mode_module_root_for_path(module_path, module_root, &package_mode_root[0] as &byte, PATH_MAX) == 0 {
            package_root_override = &package_mode_root[0] as &byte;
        }
    }

    var roots: [&byte: 3] = [null, null, null];
    var root_count: i32 = 0;
    if package_root_override != null {
        roots[root_count] = package_root_override;
        root_count = root_count + 1;
    }
    if module_root != null && module_root[0] != 0 {
        if !(package_root_override != null && package_mode_is_top_level_alias_path(module_path) != 0) {
            roots[root_count] = module_root;
            root_count = root_count + 1;
        }
    }
    if uya_root != null && uya_root[0] != 0 {
        roots[root_count] = uya_root;
        root_count = root_count + 1;
    }

    var ri: i32 = 0;
    while ri < root_count {
        const root: &byte = roots[ri];
        ri = ri + 1;
        if root == null || root[0] == 0 { continue; }

        var uya_path: [byte: PATH_MAX] = [];
        const ulen: i32 = snprintf(&uya_path[0], PATH_MAX, "%s%s.uya" as *byte, root as *byte, &file_path[0]);
        if ulen > 0 && ulen < PATH_MAX as i32 {
            const f: *void = fopen(&uya_path[0], "r" as *byte);
            if f != null {
                fclose(f);
                if (ulen as usize) < buffer_size {
                    strcpy(buffer as *byte, &uya_path[0]);
                    return 0;
                }
            }
        }
    }
    return -1;
}

fn module_dir_exists(module_path: &byte, module_root: &byte, uya_root: &byte, out_dir: &byte, out_cap: usize) i32 {
    if module_path == null {
        return 0;
    }
    if package_mode_dependency_module_dir(module_path, out_dir, out_cap) != 0 {
        return 1;
    }
    var file_path: [byte: PATH_MAX] = [];
    if module_path_to_file_path(module_path, &file_path[0] as &byte, PATH_MAX) != 0 {
        return 0;
    }

    var package_mode_root: [byte: PATH_MAX] = [];
    var package_root_override: &byte = null;
    if module_root != null && module_root[0] != 0 {
        if package_mode_module_root_for_path(module_path, module_root, &package_mode_root[0] as &byte, PATH_MAX) == 0 {
            package_root_override = &package_mode_root[0] as &byte;
        }
    }

    var roots: [&byte: 3] = [null, null, null];
    var root_count: i32 = 0;
    if package_root_override != null {
        roots[root_count] = package_root_override;
        root_count = root_count + 1;
    }
    if module_root != null && module_root[0] != 0 {
        if !(package_root_override != null && package_mode_is_top_level_alias_path(module_path) != 0) {
            roots[root_count] = module_root;
            root_count = root_count + 1;
        }
    }
    if uya_root != null && uya_root[0] != 0 {
        roots[root_count] = uya_root;
        root_count = root_count + 1;
    }

    var ri: i32 = 0;
    while ri < root_count {
        const root: &byte = roots[ri];
        ri = ri + 1;
        if root == null || root[0] == 0 { continue; }

        var dir_path: [byte: PATH_MAX] = [];
        const len: i32 = snprintf(&dir_path[0], PATH_MAX, "%s%s" as *byte, root as *byte, &file_path[0]);
        if len > 0 && len < PATH_MAX as i32 && is_directory(&dir_path[0] as &byte) != 0 {
            if out_dir != null && out_cap > 0 && (len as usize) < out_cap {
                strcpy(out_dir as *byte, &dir_path[0]);
            }
            return 1;
        }
    }
    return 0;
}

// 从 AST 中提取 use 语句的模块路径
// 辅助函数：将 segments[0..count) 连接为 "a.b.c" 形式
fn join_segments_alloc(segs: &(&byte), count: i32, arena: &CompilerArena) &byte {
    var total_len: usize = 0;
    var j: i32 = 0;
    while j < count {
        if segs[j] != null {
            total_len = total_len + strlen(segs[j] as *byte);
            if j > 0 { total_len = total_len + 1; }
        }
        j = j + 1;
    }
    if total_len == 0 { return null; }
    const buf: &byte = compiler_arena_alloc(arena, total_len + 1) as &byte;
    if buf == null { return null; }
    var dst: &byte = buf;
    j = 0;
    while j < count {
        if segs[j] != null {
            if j > 0 { dst[0] = 46 as byte; dst = dst + 1; }
            const sl: usize = strlen(segs[j] as *byte);
            memcpy(dst as *void, segs[j] as *void, sl);
            dst = dst + sl;
        }
        j = j + 1;
    }
    dst[0] = 0 as byte;
    return buf;
}

fn extract_use_modules(
    ast: &ASTNode,
    modules: &(&byte),
    max_modules: i32,
    module_count: &i32,
    module_root: &byte,
    uya_root: &byte,
    arena: &CompilerArena
) i32 {
    if ast == null || ast.type != ASTNodeType.AST_PROGRAM || modules == null || module_count == null || arena == null {
        return -1;
    }
    module_count[0] = 0;
    var i: i32 = 0;
    while i < ast.program_decl_count && module_count[0] < max_modules {
        const decl: &ASTNode = ast.program_decls[i];
        if decl != null && decl.type == ASTNodeType.AST_USE_STMT {
            const seg_count: i32 = decl.use_stmt_path_segment_count;
            if seg_count > 0 {
                var module_name: &byte = null;
                
                if decl.use_stmt_item_name != null {
                    // item_name 已设置，所有 segments 都是模块路径
                    module_name = join_segments_alloc(decl.use_stmt_path_segments, seg_count, arena);
                } else if seg_count > 1 {
                    // use a.b.c 兼容两种模块模型：
                    // - 若 a/b/c.uya 或 a/b/c/ 存在，则整体作为模块 a.b.c；
                    // - 否则退回为模块 a.b 的导出项 c。
                    const full_path: &byte = join_segments_alloc(decl.use_stmt_path_segments, seg_count, arena);
                    if full_path != null {
                        var module_file: [byte: PATH_MAX] = [];
                        var module_dir: [byte: PATH_MAX] = [];
                        if find_direct_module_file(full_path, module_root, uya_root, &module_file[0] as &byte, PATH_MAX) == 0 ||
                            module_dir_exists(full_path, module_root, uya_root, &module_dir[0] as &byte, PATH_MAX) != 0 {
                            module_name = full_path;
                        } else {
                            module_name = join_segments_alloc(decl.use_stmt_path_segments, seg_count - 1, arena);
                        }
                    }
                } else {
                    module_name = join_segments_alloc(decl.use_stmt_path_segments, seg_count, arena);
                }
                
                if module_name != null {
                    // 去重
                    var duplicate: i32 = 0;
                    var k: i32 = 0;
                    while k < module_count[0] {
                        if modules[k] != null && strcmp(modules[k] as *byte, module_name as *byte) == 0 {
                            duplicate = 1;
                            break;
                        }
                        k = k + 1;
                    }
                    if duplicate == 0 {
                        modules[module_count[0]] = module_name;
                        module_count[0] = module_count[0] + 1;
                    }
                }
            }
        }
        i = i + 1;
    }
    return 0;
}

// 对路径指针数组按字符串排序（与 C 编译器 qsort 一致，保证自举比对顺序）
fn sort_paths(paths: &(&byte), count: i32) void {
    var i: i32 = 0;
    while i < count - 1 {
        var j: i32 = i + 1;
        while j < count {
            if strcmp(paths[i] as *byte, paths[j] as *byte) > 0 {
                const tmp: &byte = paths[i];
                paths[i] = paths[j];
                paths[j] = tmp;
            }
            j = j + 1;
        }
        i = i + 1;
    }
}

// 递归收集模块依赖
// 返回：成功返回新的文件列表大小，失败返回-1
fn collect_module_dependencies(
    filename: &byte,
    file_list: &(&byte),
    file_list_size: i32,
    max_files: i32,
    processed_files: &(&byte),
    processed_count: &i32,
    max_processed: i32,
    module_root: &byte,
    uya_root: &byte,
    arena: &CompilerArena
) i32 {
    if filename == null || file_list == null || processed_files == null || processed_count == null || arena == null {
        return -1;
    }
    
    // 使用局部变量存储可修改的 file_list_size（函数参数在 Uya 中不可修改）
    var current_size: i32 = file_list_size;
    
    // 检查是否已处理过（避免循环依赖）
    // 使用路径比较函数，考虑路径格式差异
    var i: i32 = 0;
    while i < processed_count[0] {
        if processed_files[i] != null && paths_equal(processed_files[i], filename) != 0 {
            return current_size;  // 已处理，直接返回
        }
        i = i + 1;
    }
    
    // 标记为已处理
    if processed_count[0] >= max_processed {
        return -1;
    }
    processed_files[processed_count[0]] = filename;
    processed_count[0] = processed_count[0] + 1;

    // 保存 arena 偏移量，用于解析后回滚释放 AST 内存
    const arena_save_offset: usize = compiler_arena_save(arena);

    // 读取文件并解析 AST
    const file_size: i32 = read_file_content(filename, &file_buffer[0], FILE_BUFFER_SIZE as usize);
    if file_size < 0 {
        compiler_arena_restore(arena, arena_save_offset);
        return -1;
    }

    const lexer: &Lexer = compiler_arena_alloc(arena, HOST_SIZE_LEXER_BYTES) as &Lexer;
    if lexer == null {
        compiler_arena_restore(arena, arena_save_offset);
        return -1;
    }
    if lexer_init(lexer, &file_buffer[0], file_size as usize, filename, arena) != 0 {
        compiler_arena_restore(arena, arena_save_offset);
        return -1;
    }

    var parser: Parser = Parser {
        lexer: null,
        current_token: null,
        arena: null,
        context: ParserContext.PARSER_CONTEXT_NORMAL,
        pending_greater_token: null,
        saw_use_std: 0,
        has_error: 0,
    };
    if parser_init(&parser, lexer, arena) != 0 {
        compiler_arena_restore(arena, arena_save_offset);
        return -1;
    }

    const ast: &ASTNode = parser_parse(&parser);
    if ast == null || ast.type != ASTNodeType.AST_PROGRAM {
        compiler_arena_restore(arena, arena_save_offset);
        return -1;
    }

    // 提取 use 语句中的模块路径
    var modules: [&byte: MAX_INPUT_FILES] = [];
    var module_count: i32 = 0;
    if extract_use_modules(ast, &modules[0], MAX_INPUT_FILES, &module_count, module_root, uya_root, arena) != 0 {
        compiler_arena_restore(arena, arena_save_offset);
        return -1;
    }

    // 将模块名复制到栈上（arena 回滚后 modules 指针会失效）
    var module_names_stack: [[byte: 256]: MAX_INPUT_FILES] = [];
    var mi: i32 = 0;
    while mi < module_count {
        if modules[mi] != null {
            var si: usize = 0;
            while si < 255 && modules[mi][si] != 0 {
                module_names_stack[mi][si] = modules[mi][si];
                si = si + 1;
            }
            module_names_stack[mi][si] = 0 as byte;
        }
        mi = mi + 1;
    }

    // 回滚 arena，释放 AST 内存（依赖收集阶段不需要保留 AST）
    compiler_arena_restore(arena, arena_save_offset);

    // 对于每个模块，查找文件并递归处理
    i = 0;
    while i < module_count {
        if module_names_stack[i][0] == 0 {
            i = i + 1;
            continue;
        }
        // 精确 `use std;` 只提供 std.cfg / 平台选择器，稳定映射到 lib/std/platform.uya。
        if strcmp(&module_names_stack[i][0] as *byte, "std" as *byte) == 0 && uya_root != null && uya_root[0] != 0 {
            var std_platform_file: [byte: PATH_MAX] = [];
            if find_module_file("std" as *byte, module_root, uya_root, &std_platform_file[0], PATH_MAX) == 0 {
                var in_list: i32 = 0;
                var j: i32 = 0;
                while j < current_size {
                    if file_list[j] != null && paths_equal(file_list[j], &std_platform_file[0] as &byte) != 0 {
                        in_list = 1;
                        break;
                    }
                    j = j + 1;
                }
                if in_list == 0 && current_size < max_files {
                    const path_copy: &byte = compiler_arena_alloc(arena, strlen(&std_platform_file[0]) + 1) as &byte;
                    if path_copy != null {
                        strcpy(path_copy as *byte, &std_platform_file[0]);
                        file_list[current_size] = path_copy;
                        current_size = current_size + 1;
                        current_size = collect_module_dependencies(path_copy, file_list, current_size, max_files, processed_files, processed_count, max_processed, module_root, uya_root, arena);
                        if current_size < 0 { return -1; }
                    }
                }
            }
            i = i + 1;
            continue;
        }

        // std 子模块：目录模块收集目录下所有 .uya；单文件模块优先走精确文件。
        if strncmp(&module_names_stack[i][0] as *byte, "std." as *byte, 4) == 0 && uya_root != null && uya_root[0] != 0 {
            var std_dir_exact: [byte: PATH_MAX] = [];
            const std_has_dir: i32 = module_dir_exists(&module_names_stack[i][0] as *byte, module_root, uya_root, &std_dir_exact[0] as &byte, PATH_MAX);
            // 约定目录内的 file.uya 代表该目录模块本身，例如 std.io -> lib/std/io/file.uya。
            // 只有没有 file.uya 聚合文件时，才把 std.xxx 当成目录模块展开。
            if std_has_dir != 0 {
                var std_file_module: [byte: PATH_MAX] = [];
                const std_file_len: i32 = snprintf(&std_file_module[0], PATH_MAX, "%s/file.uya" as *byte, &std_dir_exact[0]);
                if std_file_len > 0 && std_file_len < PATH_MAX && is_file(&std_file_module[0] as &byte) != 0 {
                    var in_list_file: i32 = 0;
                    var jf: i32 = 0;
                    while jf < current_size {
                        if file_list[jf] != null && paths_equal(file_list[jf], &std_file_module[0] as &byte) != 0 {
                            in_list_file = 1;
                            break;
                        }
                        jf = jf + 1;
                    }
                    if in_list_file == 0 && current_size < max_files {
                        const file_copy: &byte = compiler_arena_alloc(arena, strlen(&std_file_module[0]) + 1) as &byte;
                        if file_copy != null {
                            strcpy(file_copy as *byte, &std_file_module[0]);
                            file_list[current_size] = file_copy;
                            current_size = current_size + 1;
                            current_size = collect_module_dependencies(file_copy, file_list, current_size, max_files, processed_files, processed_count, max_processed, module_root, uya_root, arena);
                            if current_size < 0 { return -1; }
                        }
                    }
                    i = i + 1;
                    continue;
                }

                var module_base_name: &byte = &module_names_stack[i][0] as &byte;
                const module_last_dot: *byte = strrchr(&module_names_stack[i][0] as *byte, 46);
                if module_last_dot != null {
                    module_base_name = (module_last_dot + 1) as &byte;
                }
                var std_named_module: [byte: PATH_MAX] = [];
                const std_named_len: i32 = snprintf(&std_named_module[0], PATH_MAX, "%s/%s.uya" as *byte, &std_dir_exact[0], module_base_name as *byte);
                if std_named_len > 0 && std_named_len < PATH_MAX && is_file(&std_named_module[0] as &byte) != 0 {
                    var in_list_named: i32 = 0;
                    var jn: i32 = 0;
                    while jn < current_size {
                        if file_list[jn] != null && paths_equal(file_list[jn], &std_named_module[0] as &byte) != 0 {
                            in_list_named = 1;
                            break;
                        }
                        jn = jn + 1;
                    }
                    if in_list_named == 0 && current_size < max_files {
                        const named_copy: &byte = compiler_arena_alloc(arena, strlen(&std_named_module[0]) + 1) as &byte;
                        if named_copy != null {
                            strcpy(named_copy as *byte, &std_named_module[0]);
                            file_list[current_size] = named_copy;
                            current_size = current_size + 1;
                            current_size = collect_module_dependencies(named_copy, file_list, current_size, max_files, processed_files, processed_count, max_processed, module_root, uya_root, arena);
                            if current_size < 0 { return -1; }
                        }
                    }
                    i = i + 1;
                    continue;
                }
            }
            // 只有精确单文件模块优先走单文件；若存在同名目录，必须收集目录内全部 .uya。
            var single_file: [byte: PATH_MAX] = [];
            if std_has_dir == 0 && find_direct_module_file(&module_names_stack[i][0] as *byte, module_root, uya_root, &single_file[0], PATH_MAX) == 0 {
                var in_list: i32 = 0;
                var j: i32 = 0;
                while j < current_size {
                    if file_list[j] != null && paths_equal(file_list[j], &single_file[0] as &byte) != 0 {
                        in_list = 1;
                        break;
                    }
                    j = j + 1;
                }
                if in_list == 0 && current_size < max_files {
                    const path_copy: &byte = compiler_arena_alloc(arena, strlen(&single_file[0]) + 1) as &byte;
                    if path_copy != null {
                        strcpy(path_copy as *byte, &single_file[0]);
                        file_list[current_size] = path_copy;
                        current_size = current_size + 1;
                        current_size = collect_module_dependencies(path_copy, file_list, current_size, max_files, processed_files, processed_count, max_processed, module_root, uya_root, arena);
                        if current_size < 0 { return -1; }
                    }
                }
                i = i + 1;
                continue;
            }
            var std_dir: [byte: PATH_MAX] = [];
            var dlen: i32 = 0;
            if strcmp(&module_names_stack[i][0] as *byte, "std" as *byte) == 0 {
                dlen = snprintf(&std_dir[0], PATH_MAX, "%sstd/" as *byte, uya_root as *byte);
            } else {
                // std.xxx.yyy 模块 -> lib/std/xxx/yyy/
                // 需要将点号替换为斜杠
                var path_suffix: [byte: PATH_MAX] = [];
                const suffix: &byte = &module_names_stack[i][0] as *byte + 4;  // 跳过 "std."
                var k: usize = 0;
                while suffix[k] != 0 && k < PATH_MAX - 2 {
                    if suffix[k] == 46 {  // '.'
                        path_suffix[k] = 47;  // '/'
                    } else {
                        path_suffix[k] = suffix[k];
                    }
                    k = k + 1;
                }
                path_suffix[k] = 47;  // 添加末尾斜杠
                path_suffix[k + 1] = 0;
                dlen = snprintf(&std_dir[0], PATH_MAX, "%sstd/%s" as *byte, uya_root as *byte, &path_suffix[0]);
            }
            // 如果目录不存在，尝试去掉最后一段（可能是 item_name 被错误地当作模块路径）
            if dlen <= 0 || dlen >= PATH_MAX || is_directory(&std_dir[0] as &byte) == 0 {
                // 查找最后一个斜杠，截断路径
                var scan_len: i32 = dlen;
                if scan_len >= PATH_MAX {
                    scan_len = PATH_MAX - 1;
                }
                var last_slash: i32 = scan_len - 1;
                while last_slash > 0 {
                    const slash_idx: i32 = last_slash;
                    if slash_idx < 0 {
                        break;
                    }
                    if slash_idx >= @len(std_dir) {
                        last_slash = last_slash - 1;
                        continue;
                    }
                    if main_path_buf_char_at(std_dir, slash_idx) == 47 {  // '/'
                        break;
                    }
                    last_slash = last_slash - 1;
                }
                if last_slash > 0 {
                    const truncate_idx: i32 = last_slash + 1;
                    main_path_buf_set(std_dir, truncate_idx, 0);  // 截断到最后一个斜杠后
                    dlen = truncate_idx;
                }
            }
            if dlen > 0 && dlen < PATH_MAX && is_directory(&std_dir[0] as &byte) != 0 {
                const dir: *DIR = opendir(&std_dir[0]);
                if dir != null {
                    var pending: [&byte: MAX_INPUT_FILES] = [];
                    var pending_count: i32 = 0;
                    var entry: *Dirent = readdir(dir);
                    while entry != null && pending_count < max_files {
                        if dirent_may_be_regular_file(entry as &byte) != 0 {
                            const name: *byte = dirent_get_name(entry as &byte) as *byte;
                            const nlen: usize = strlen(name);
                            if nlen > 4 && strcmp(name + (nlen - 4), ".uya" as *byte) == 0 {
                                var fp: [byte: PATH_MAX] = [];
                                const flen: i32 = snprintf(&fp[0], PATH_MAX, "%s%s" as *byte, &std_dir[0], name);
                                if flen > 0 && flen < PATH_MAX {
                                    var in_list: i32 = 0;
                                    var j: i32 = 0;
                                    while j < current_size {
                                        if file_list[j] != null && paths_equal(file_list[j], &fp[0] as &byte) != 0 {
                                            in_list = 1;
                                            break;
                                        }
                                        j = j + 1;
                                    }
                                    // 同时检查 pending 数组中是否已存在（防止重复添加）
                                    if in_list == 0 {
                                        var pk: i32 = 0;
                                        while pk < pending_count {
                                            if pending[pk] != null && paths_equal(pending[pk], &fp[0] as &byte) != 0 {
                                                in_list = 1;
                                                break;
                                            }
                                            pk = pk + 1;
                                        }
                                    }
                                    if in_list == 0 {
                                        const path_copy: &byte = compiler_arena_alloc(arena, strlen(&fp[0]) + 1) as &byte;
                                        if path_copy != null {
                                            strcpy(path_copy as *byte, &fp[0]);
                                            pending[pending_count] = path_copy;
                                            pending_count = pending_count + 1;
                                        }
                                    }
                                }
                            }
                        }
                        entry = readdir(dir);
                    }
                    closedir(dir);
                    if pending_count > 0 {
                        sort_paths(&pending[0] as &(&byte), pending_count);
                        // 先把所有文件添加到 file_list（防止递归时重复添加）
                        var added_count: i32 = 0;
                        while added_count < pending_count && current_size < max_files {
                            file_list[current_size] = pending[added_count];
                            current_size = current_size + 1;
                            added_count = added_count + 1;
                        }
                        // 然后递归处理每个文件的依赖
                        var idx: i32 = 0;
                        while idx < added_count {
                            const pc: &byte = pending[idx];
                            current_size = collect_module_dependencies(pc, file_list, current_size, max_files, processed_files, processed_count, max_processed, module_root, uya_root, arena);
                            if current_size < 0 { return -1; }
                            idx = idx + 1;
                        }
                    }
                }
            }
            i = i + 1;
            continue;
        }
        // libc 模块：收集 lib/libc/ 目录下所有 .uya 文件（与 C 编译器一致）
        if strcmp(&module_names_stack[i][0] as *byte, "libc" as *byte) == 0 && uya_root != null && uya_root[0] != 0 {
            var libc_dir: [byte: PATH_MAX] = [];
            const dlen: i32 = snprintf(&libc_dir[0], PATH_MAX, "%slibc/" as *byte, uya_root as *byte);
            if dlen > 0 && dlen < PATH_MAX && is_directory(&libc_dir[0] as &byte) != 0 {
                const dir: *DIR = opendir(&libc_dir[0]);
                if dir != null {
                    var pending: [&byte: MAX_INPUT_FILES] = [];
                    var pending_count: i32 = 0;
                    var entry: *Dirent = readdir(dir);
                    while entry != null && pending_count < max_files {
                        if dirent_may_be_regular_file(entry as &byte) != 0 {
                            const name: *byte = dirent_get_name(entry as &byte) as *byte;
                            const nlen: usize = strlen(name);
                            if nlen > 4 && strcmp(name + (nlen - 4), ".uya" as *byte) == 0 {
                                var fp: [byte: PATH_MAX] = [];
                                const flen: i32 = snprintf(&fp[0], PATH_MAX, "%s%s" as *byte, &libc_dir[0], name);
                                if flen > 0 && flen < PATH_MAX {
                                    var in_list: i32 = 0;
                                    var j: i32 = 0;
                                    while j < current_size {
                                        if file_list[j] != null && paths_equal(file_list[j], &fp[0] as &byte) != 0 {
                                            in_list = 1;
                                            break;
                                        }
                                        j = j + 1;
                                    }
                                    if in_list == 0 {
                                        var in_proc: i32 = 0;
                                        j = 0;
                                        while j < processed_count[0] {
                                            if processed_files[j] != null && paths_equal(processed_files[j], &fp[0] as &byte) != 0 {
                                                in_proc = 1;
                                                break;
                                            }
                                            j = j + 1;
                                        }
                                        // 同时检查 pending 数组中是否已存在（防止重复添加）
                                        if in_proc == 0 {
                                            var k: i32 = 0;
                                            while k < pending_count {
                                                if pending[k] != null && paths_equal(pending[k], &fp[0] as &byte) != 0 {
                                                    in_proc = 1;
                                                    break;
                                                }
                                                k = k + 1;
                                            }
                                        }
                                        if in_proc == 0 {
                                            const path_copy: &byte = compiler_arena_alloc(arena, strlen(&fp[0]) + 1) as &byte;
                                            if path_copy != null {
                                                strcpy(path_copy as *byte, &fp[0]);
                                                pending[pending_count] = path_copy;
                                                pending_count = pending_count + 1;
                                            }
                                        }
                                    }
                                }
                            }
                        }
                        entry = readdir(dir);
                    }
                    closedir(dir);
                    if pending_count > 0 {
                        sort_paths(&pending[0] as &(&byte), pending_count);
                        // 先把所有文件添加到 file_list（防止递归时重复添加）
                        var added_count: i32 = 0;
                        while added_count < pending_count && current_size < max_files {
                            file_list[current_size] = pending[added_count];
                            current_size = current_size + 1;
                            added_count = added_count + 1;
                        }
                        // 然后递归处理每个文件的依赖
                        var idx: i32 = 0;
                        while idx < added_count {
                            const pc: &byte = pending[idx];
                            current_size = collect_module_dependencies(pc, file_list, current_size, max_files, processed_files, processed_count, max_processed, module_root, uya_root, arena);
                            if current_size < 0 { return -1; }
                            idx = idx + 1;
                        }
                    }
                }
            }
            i = i + 1;
            continue;
        }
        // syscall 模块：收集 lib/syscall/ 目录下所有 .uya 文件（标准库重构 syscall 层）
        if strcmp(&module_names_stack[i][0] as *byte, "syscall" as *byte) == 0 && uya_root != null && uya_root[0] != 0 {
            var syscall_dir: [byte: PATH_MAX] = [];
            const dlen: i32 = snprintf(&syscall_dir[0], PATH_MAX, "%ssyscall/" as *byte, uya_root as *byte);
            if dlen > 0 && dlen < PATH_MAX && is_directory(&syscall_dir[0] as &byte) != 0 {
                const dir: *DIR = opendir(&syscall_dir[0]);
                if dir != null {
                    var pending: [&byte: MAX_INPUT_FILES] = [];
                    var pending_count: i32 = 0;
                    var entry: *Dirent = readdir(dir);
                    while entry != null && pending_count < max_files {
                        if dirent_may_be_regular_file(entry as &byte) != 0 {
                            const name: *byte = dirent_get_name(entry as &byte) as *byte;
                            const nlen: usize = strlen(name);
                            if nlen > 4 && strcmp(name + (nlen - 4), ".uya" as *byte) == 0 {
                                var fp: [byte: PATH_MAX] = [];
                                const flen: i32 = snprintf(&fp[0], PATH_MAX, "%s%s" as *byte, &syscall_dir[0], name);
                                if flen > 0 && flen < PATH_MAX {
                                    var in_list: i32 = 0;
                                    var j: i32 = 0;
                                    while j < current_size {
                                        if file_list[j] != null && paths_equal(file_list[j], &fp[0] as &byte) != 0 {
                                            in_list = 1;
                                            break;
                                        }
                                        j = j + 1;
                                    }
                                    if in_list == 0 {
                                        var k: i32 = 0;
                                        while k < pending_count {
                                            if pending[k] != null && paths_equal(pending[k], &fp[0] as &byte) != 0 {
                                                in_list = 1;
                                                break;
                                            }
                                            k = k + 1;
                                        }
                                    }
                                    if in_list == 0 {
                                        const path_copy: &byte = compiler_arena_alloc(arena, strlen(&fp[0]) + 1) as &byte;
                                        if path_copy != null {
                                            strcpy(path_copy as *byte, &fp[0]);
                                            pending[pending_count] = path_copy;
                                            pending_count = pending_count + 1;
                                        }
                                    }
                                }
                            }
                        }
                        entry = readdir(dir);
                    }
                    closedir(dir);
                    if pending_count > 0 {
                        sort_paths(&pending[0] as &(&byte), pending_count);
                        var added_count: i32 = 0;
                        while added_count < pending_count && current_size < max_files {
                            file_list[current_size] = pending[added_count];
                            current_size = current_size + 1;
                            added_count = added_count + 1;
                        }
                        var idx: i32 = 0;
                        while idx < added_count {
                            const pc: &byte = pending[idx];
                            current_size = collect_module_dependencies(pc, file_list, current_size, max_files, processed_files, processed_count, max_processed, module_root, uya_root, arena);
                            if current_size < 0 { return -1; }
                            idx = idx + 1;
                        }
                    }
                }
            }
            i = i + 1;
            continue;
        }
        // use main：收集主工程目录下所有 .uya，排序后加入（与 C 编译器一致）
        if strcmp(&module_names_stack[i][0] as *byte, "main" as *byte) == 0 {
            var main_dir: [byte: PATH_MAX] = [];
            var dir_src: &byte = null;
            // 优先 module_root（主文件所在目录，一般为 src/），避免双输入时 processed_files[0] 为 entry 路径而误扫子目录
            if module_root != null && strlen(module_root) > 0 {
                dir_src = module_root;
            } else if processed_count[0] > 0 && processed_files[0] != null {
                const entry_file: &byte = processed_files[0];
                const slash: *byte = strrchr(entry_file as *byte, 47);
                if slash != null {
                    const dlen_tmp: !usize = (slash as i64 - entry_file as i64 + 1) as! usize;
                    const dlen: usize = dlen_tmp catch { return 1; };
                    if dlen < PATH_MAX as usize {
                        memcpy(&main_dir[0] as *void, entry_file as *void, dlen);
                        main_dir[dlen] = 0 as byte;
                    } else {
                        strcpy(&main_dir[0], "." as *byte);
                    }
                } else {
                    strcpy(&main_dir[0], "." as *byte);
                }
                dir_src = &main_dir[0] as &byte;
            }
            if dir_src != null {
                const dir: *DIR = opendir(dir_src as *byte);
                if dir != null {
                    var pending: [&byte: MAX_INPUT_FILES] = [];
                    var pending_count: i32 = 0;
                    var entry: *Dirent = readdir(dir);
                    while entry != null && pending_count < max_files {
                        const name: *byte = dirent_get_name(entry as &byte) as *byte;
                        if dirent_may_be_regular_file(entry as &byte) != 0 && strlen(name) > 4 {
                            if strcmp(name + (strlen(name) - 4), ".uya" as *byte) == 0 {
                                var fp: [byte: PATH_MAX] = [];
                                const flen: i32 = snprintf(&fp[0], PATH_MAX, "%s%s" as *byte, dir_src, name);
                                if flen > 0 && flen < PATH_MAX as i32 {
                                    var in_list: i32 = 0;
                                    var j: i32 = 0;
                                    while j < current_size {
                                        if file_list[j] != null && paths_equal(file_list[j], &fp[0] as &byte) != 0 {
                                            in_list = 1;
                                            break;
                                        }
                                        j = j + 1;
                                    }
                                    if in_list == 0 {
                                        var in_proc: i32 = 0;
                                        j = 0;
                                        while j < processed_count[0] {
                                            if processed_files[j] != null && paths_equal(processed_files[j], &fp[0] as &byte) != 0 {
                                                in_proc = 1;
                                                break;
                                            }
                                            j = j + 1;
                                        }
                                        if in_proc == 0 {
                                            const path_copy: &byte = compiler_arena_alloc(arena, strlen(&fp[0]) + 1) as &byte;
                                            if path_copy != null {
                                                strcpy(path_copy as *byte, &fp[0]);
                                                pending[pending_count] = path_copy;
                                                pending_count = pending_count + 1;
                                            }
                                        }
                                    }
                                }
                            }
                        }
                        entry = readdir(dir);
                    }
                    closedir(dir);
                    if pending_count > 0 {
                        sort_paths(&pending[0] as &(&byte), pending_count);
                        // 先把所有文件添加到 file_list（防止递归时重复添加）
                        var added_count: i32 = 0;
                        while added_count < pending_count && current_size < max_files {
                            file_list[current_size] = pending[added_count];
                            current_size = current_size + 1;
                            added_count = added_count + 1;
                        }
                        // 然后递归处理每个文件的依赖
                        var idx: i32 = 0;
                        while idx < added_count {
                            const pc: &byte = pending[idx];
                            current_size = collect_module_dependencies(pc, file_list, current_size, max_files, processed_files, processed_count, max_processed, module_root, uya_root, arena);
                            if current_size < 0 { return -1; }
                            idx = idx + 1;
                        }
                    }
                }
            }
            i = i + 1;
            continue;
        }
        // 目录模块：将模块路径转为目录路径，若存在则收集该目录下所有 .uya（与 C 一致）
        var file_path: [byte: PATH_MAX] = [];
        const path_len: usize = strlen(&module_names_stack[i][0] as *byte);
        if path_len >= PATH_MAX as usize {
            i = i + 1;
            continue;
        }
        strcpy(&file_path[0], &module_names_stack[i][0] as *byte);
        var k: usize = 0;
        while k < path_len {
            if file_path[k] == 46 as byte { file_path[k] = 47 as byte; }
            k = k + 1;
        }
        var found_dir: i32 = 0;
        var module_dir_path: [byte: PATH_MAX] = [];
        if package_mode_dependency_module_dir(&module_names_stack[i][0] as &byte, &module_dir_path[0] as &byte, PATH_MAX as usize) != 0 {
            found_dir = 1;
        } else {
            var ri: i32 = 0;
            while ri < 2 {
                var root: &byte = null;
                if ri == 0 { root = module_root; }
                if ri == 1 { root = uya_root; }
                ri = ri + 1;
                if root == null { continue; }
                const root_nonnull: &byte = root;  // 为安全证明建立非空引用
                if root_nonnull[0] == 0 { continue; }
                const len: i32 = snprintf(&module_dir_path[0], PATH_MAX, "%s%s" as *byte, root as *byte, &file_path[0]);
                if len > 0 && len < PATH_MAX as i32 && is_directory(&module_dir_path[0] as &byte) != 0 {
                    found_dir = 1;
                    break;
                }
            }
        }
        if found_dir != 0 {
            const dir_path: &byte = &module_dir_path[0] as &byte;
            const dir: *DIR = opendir(&module_dir_path[0]);
            if dir != null {
                var pending: [&byte: MAX_INPUT_FILES] = [];
                var pending_count: i32 = 0;
                var entry: *Dirent = readdir(dir);
                while entry != null && pending_count < max_files {
                    if dirent_is_regular_file(entry as &byte) != 0 {
                        const name: *byte = dirent_get_name(entry as &byte) as *byte;
                        const name_len: usize = strlen(name);
                        if name_len > 4 && strcmp(name + (name_len - 4), ".uya" as *byte) == 0 {
                            var full_path: [byte: PATH_MAX] = [];
                            const flen: i32 = snprintf(&full_path[0], PATH_MAX, "%s/%s" as *byte, dir_path as *byte, name);
                            if flen > 0 && flen < PATH_MAX as i32 {
                                var already_added: i32 = 0;
                                var j: i32 = 0;
                                while j < current_size {
                                    if file_list[j] != null && paths_equal(file_list[j], &full_path[0] as &byte) != 0 {
                                        already_added = 1;
                                        break;
                                    }
                                    j = j + 1;
                                }
                                // 同时检查 pending 数组中是否已存在（防止重复添加）
                                if already_added == 0 {
                                    var pk: i32 = 0;
                                    while pk < pending_count {
                                        if pending[pk] != null && paths_equal(pending[pk], &full_path[0] as &byte) != 0 {
                                            already_added = 1;
                                            break;
                                        }
                                        pk = pk + 1;
                                    }
                                }
                                if already_added == 0 {
                                    const path_copy: &byte = compiler_arena_alloc(arena, strlen(&full_path[0]) + 1) as &byte;
                                    if path_copy != null {
                                        strcpy(path_copy as *byte, &full_path[0]);
                                        pending[pending_count] = path_copy;
                                        pending_count = pending_count + 1;
                                    }
                                }
                            }
                        }
                    }
                    entry = readdir(dir);
                }
                closedir(dir);
                if pending_count > 0 {
                    sort_paths(&pending[0] as &(&byte), pending_count);
                    var idx: i32 = 0;
                    while idx < pending_count && current_size < max_files {
                        const path_copy: &byte = pending[idx];
                        file_list[current_size] = path_copy;
                        current_size = current_size + 1;
                        current_size = collect_module_dependencies(path_copy, file_list, current_size, max_files, processed_files, processed_count, max_processed, module_root, uya_root, arena);
                        if current_size < 0 { return -1; }
                        idx = idx + 1;
                    }
                }
            }
            i = i + 1;
            continue;
        }
        // 单文件模块：find_module_file
        var module_file: [byte: PATH_MAX] = [];
        if find_module_file(&module_names_stack[i][0] as &byte, module_root, uya_root, &module_file[0] as &byte, PATH_MAX) == 0 {
            var already_added: i32 = 0;
            var j: i32 = 0;
            while j < current_size {
                if file_list[j] != null && paths_equal(file_list[j], &module_file[0] as &byte) != 0 {
                    already_added = 1;
                    break;
                }
                j = j + 1;
            }
            if already_added == 0 && current_size < max_files {
                const path_copy: &byte = compiler_arena_alloc(arena, strlen(&module_file[0]) + 1) as &byte;
                if path_copy != null {
                    strcpy(path_copy as *byte, &module_file[0]);
                    file_list[current_size] = path_copy;
                    current_size = current_size + 1;
                    current_size = collect_module_dependencies(path_copy, file_list, current_size, max_files, processed_files, processed_count, max_processed, module_root, uya_root, arena);
                    if current_size < 0 { return -1; }
                }
            }
        }
        i = i + 1;
    }
    
    return current_size;
}
