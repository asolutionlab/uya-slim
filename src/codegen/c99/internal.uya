// internal.uya - C99 代码生成器内部类型定义和函数声明
// 生成 C99 源代码
//
// 注意：需要先包含 arena.uya、ast.uya、checker.uya 和 str_utils.uya
// 由于 Uya Mini 不支持模块系统，这里假设相关类型已经定义

// ===== 外部函数声明 =====
// 注意：C 标准库函数（strlen, strcmp, strcpy, memcpy, memset, fprintf, sprintf, snprintf 等）在 extern_decls.uya 中声明
// 编译时需要包含 extern_decls.uya 文件

// Arena 函数（来自 arena.uya，与 arena.uya 定义一致）
extern fn compiler_arena_alloc(arena: &CompilerArena, size: usize) &byte;

use libc.atoi;

// ===== 常量定义 =====

// 字符串常量表大小
const C99_MAX_STRING_CONSTANTS: i32 = 4096;

// 结构体定义表大小
const C99_MAX_STRUCT_DEFINITIONS: i32 = 1024;

// 枚举定义表大小
const C99_MAX_ENUM_DEFINITIONS: i32 = 512;

// 函数声明表大小
const C99_MAX_FUNCTION_DECLS: i32 = 512;
const C99_MAX_REACHABLE_FUNCTIONS: i32 = 2048;

// 全局变量表大小
const C99_MAX_GLOBAL_VARS: i32 = 512;

// 局部变量表大小
const C99_MAX_LOCAL_VARS: i32 = 1024;

// 循环栈大小
const C99_MAX_LOOP_STACK: i32 = 64;
const C99_MAX_CALL_ARGS: i32 = 64;
const C99_MAX_DEFER_STACK: i32 = 64;
const C99_MAX_DEFERS_PER_BLOCK: i32 = 128;
const C99_MAX_DROP_VARS_PER_BLOCK: i32 = 128;
const C99_MAX_SLICE_STRUCTS: i32 = 128;
const C99_MAX_ERR_UNION_STRUCTS: i32 = 256;
const C99_MAX_SIMD_STRUCTS: i32 = 128;
const C99_MAX_MONO_INSTANCES: i32 = 1024;
const C99_CHECKER_MAX_MONO_INSTANCES: i32 = 512;  // checker.mono_instances 数组大小
const C99_MAX_ERROR_IDS: i32 = 256;
const C99_ASYNC_MAX_AWAITS: i32 = 4096;
const C99_GENERIC_NAME_BUF_SIZE: i32 = 128;
const C99_MAX_INTERFACE_METHODS: i32 = 128;
const C99_TYPE_ARG_BUF_SIZE: i32 = 256;
const C99_TYPE_ARG_BUF_LIMIT: i32 = 250;
const C99_OUTPUT_FILENAME_BUF_SIZE: i32 = 100;
const C99_STRING_INTERP_BUF_SIZE: i32 = 2048;
const C99_STRING_INTERP_LIMIT: i32 = 2046;
const C99_SUFFIX_BUF_SIZE: i32 = 512;

// 声明缓存哈希表大小（应为 2 的幂以便用 & mask 取模）
// 4096 槽：降低自举等大程序中 find_*_c99 哈希冲突后的线性扫描代价
const C99_DECL_CACHE_BITS: i32 = 12;         // 4096 个槽
const C99_DECL_CACHE_SIZE: i32 = 4096;       // 哈希表槽数
const C99_DECL_CACHE_MASK: i32 = 4095;       // mask = SIZE - 1

// ===== 类型定义 =====

// 字符串常量表项
struct StringConstant {
    name: &byte,  // 常量名称（如 str0）
    value: &byte  // 字符串值
}

// 结构体定义表项
struct StructDefinition {
    name: &byte,  // 结构体名称
    defined: i32  // 是否已定义（1表示是，0表示否）
}

// 枚举定义表项
struct EnumDefinition {
    name: &byte,  // 枚举名称
    defined: i32  // 是否已定义（1表示是，0表示否）
}

// 函数声明表项
struct FunctionDeclaration {
    name: &byte,  // 函数名称
    declared: i32  // 是否已声明（1表示是，0表示否）
}

// 全局变量表项
struct GlobalVariable {
    name: &byte,  // C 中使用的名称（与系统宏冲突时带 uya_ 前缀）
    original_name: &byte,  // Uya 源码中的名称，用于按原名查找
    type_c: &byte,  // C 类型字符串
    is_const: i32  // 是否为 const
}

// 局部变量表项
struct LocalVariable {
    name: &byte,  // 变量名称
    type_c: &byte,  // C 类型字符串
    type_node: &ASTNode,  // 原始 AST 类型节点（用于 codegen 侧类型判定）
    depth: i32  // 嵌套深度
}

// 循环栈项
struct LoopStack {
    break_label: &byte,  // break 标签
    continue_label: &byte  // continue 标签
}

// 泛型单态化实例（用于代码生成）
struct MonoInstanceCodegen {
    generic_name: &byte,       // 泛型函数/结构体名称
    type_args: & & ASTNode,    // 类型实参 AST 节点数组
    type_arg_count: i32,       // 类型实参数量
    is_function: i32,          // 1 表示函数，0 表示结构体
}

// C99 代码生成器结构
struct C99CodeGenerator {
    arena: &CompilerArena,  // Arena 分配器
    checker: &TypeChecker,  // 类型检查器（用于单态体宏展开等）
    output: &void,  // 输出文件指针（FILE*），使用普通指针类型以便在普通函数中使用
    indent_level: i32,  // 当前缩进级别
    module_name: &byte,  // 模块名称
    
    // 字符串常量表
    string_constants: [StringConstant: C99_MAX_STRING_CONSTANTS],
    string_constant_count: i32,
    string_constants_emitted_count: i32,  // 第二步已输出的数量；宏展开等可能后续 add，末尾补输出
    // 结构体定义表
    struct_definitions: [StructDefinition: C99_MAX_STRUCT_DEFINITIONS],
    struct_definition_count: i32,
    
    // 枚举定义表
    enum_definitions: [EnumDefinition: C99_MAX_ENUM_DEFINITIONS],
    enum_definition_count: i32,
    
    // 函数声明表
    function_declarations: [FunctionDeclaration: C99_MAX_FUNCTION_DECLS],
    function_declaration_count: i32,
    reachable_function_decls: [&ASTNode: C99_MAX_REACHABLE_FUNCTIONS],
    reachable_function_decl_count: i32,

    // 声明缓存（一次性构建，用于加速 find_*_c99 系列查找）
    fn_decl_cache: [&ASTNode: C99_DECL_CACHE_SIZE],      // 函数名哈希缓存
    struct_decl_cache: [&ASTNode: C99_DECL_CACHE_SIZE],   // 结构体名哈希缓存
    enum_decl_cache: [&ASTNode: C99_DECL_CACHE_SIZE],     // 枚举名哈希缓存
    type_alias_cache: [&ASTNode: C99_DECL_CACHE_SIZE],    // 类型别名哈希缓存
    union_decl_cache: [&ASTNode: C99_DECL_CACHE_SIZE],    // 联合体名哈希缓存
    macro_decl_cache: [&ASTNode: C99_DECL_CACHE_SIZE],    // 宏名哈希缓存
    interface_decl_cache: [&ASTNode: C99_DECL_CACHE_SIZE], // 接口名哈希缓存
    decl_cache_initialized: i32,                          // 缓存是否已构建（1=已构建）
    
    // 全局变量表
    global_variables: [GlobalVariable: C99_MAX_GLOBAL_VARS],
    global_variable_count: i32,
    
    // 局部变量表
    local_variables: [LocalVariable: C99_MAX_LOCAL_VARS],
    local_variable_count: i32,
    current_depth: i32,  // 当前作用域深度
    
    // 循环栈
    loop_stack: [LoopStack: C99_MAX_LOOP_STACK],
    loop_stack_depth: i32,
    
    program_node: &ASTNode,  // 程序节点引用
    current_function_return_type: &ASTNode,  // 当前函数的返回类型
    current_function_decl: &ASTNode,  // 当前正在生成的函数声明（用于 @params 与 ... 转发，可为 null）
    current_method_struct_name: &byte,  // 当前方法所属结构体名（用于 self 写回时的 cast，可为 null）
    emitting_assign_lhs: i32,  // 1=正在生成赋值左端（self.field 需 cast 以支持 const self）
    // 1=原子成员访问输出裸左值（用于 &__atomic_store_n 首参、&atomic_field，避免生成 __atomic_load_n 右值）
    atomic_member_plain_lvalue: i32,
    
    // 用于优化 #line 指令生成
    current_line: i32,  // 当前行号
    current_filename: &byte,  // 当前文件名
    emit_line_directives: i32,  // 是否生成 #line 指令（1 表示是，0 表示否）
    string_interp_buf: &byte,
    interp_arg_temp_names: [&byte: C99_MAX_CALL_ARGS],
    interp_temp_counter: i32,
    interp_fill_counter: i32,
    test_count: i32,  // 测试语句数量（用于判断是否生成 uya_run_tests 调用）
    error_names: [&byte: 256],   // 错误集
    error_hashes: [u32: 256],    // 对应 error_id（hash 值）
    error_count: i32,
    // defer/errdefer 栈：扁平化为 [depth * C99_MAX_DEFERS_PER_BLOCK + index]
    defer_stack: [&ASTNode: C99_MAX_DEFER_STACK * C99_MAX_DEFERS_PER_BLOCK],
    defer_count: [i32: C99_MAX_DEFER_STACK],  // 每层的 defer 数量
    errdefer_stack: [&ASTNode: C99_MAX_DEFER_STACK * C99_MAX_DEFERS_PER_BLOCK],
    errdefer_count: [i32: C99_MAX_DEFER_STACK],  // 每层的 errdefer 数量
    defer_stack_depth: i32,
    // drop/RAII：当前块内需在作用域退出时 drop 的变量（规范 §12）
    current_drop_scope: i32,
    drop_var_count: [i32: C99_MAX_DEFER_STACK],
    drop_var_safe: [&byte: C99_MAX_DEFER_STACK * C99_MAX_DROP_VARS_PER_BLOCK],
    drop_struct_name: [&byte: C99_MAX_DEFER_STACK * C99_MAX_DROP_VARS_PER_BLOCK],
    // 待输出的切片结构体（&[T] -> struct uya_slice_X { T* ptr; size_t len; }）
    slice_struct_names: [&byte: C99_MAX_SLICE_STRUCTS],
    slice_struct_element_types: [&ASTNode: C99_MAX_SLICE_STRUCTS],
    slice_struct_count: i32,
    
    // 待输出的错误联合结构体（!T -> struct err_union_X { uint32_t error_id; T value; }）
    err_union_struct_names: [&byte: C99_MAX_ERR_UNION_STRUCTS],
    err_union_payload_types: [&ASTNode: C99_MAX_ERR_UNION_STRUCTS],
    err_union_struct_count: i32,
    // 与 err_union_struct_names 同下标：是否已在 emit_pending_err_union_structs 中输出完整 struct err_union_* { ... }
    err_union_body_emitted: [i32: C99_MAX_ERR_UNION_STRUCTS],

    // 待输出的 SIMD 结构体（@vector/@mask -> struct uya_simd_*）
    simd_struct_names: [&byte: C99_MAX_SIMD_STRUCTS],
    simd_struct_element_types: [&ASTNode: C99_MAX_SIMD_STRUCTS],
    simd_struct_lane_counts: [i32: C99_MAX_SIMD_STRUCTS],
    simd_struct_is_mask: [i32: C99_MAX_SIMD_STRUCTS],
    simd_struct_count: i32,
    // SIMD 运行库按需生成：已注册的向量结构体数量（不含仅 @mask）
    simd_vector_struct_reg_count: i32,
    simd_max_lanes_i8: i32,
    simd_max_lanes_u8: i32,
    simd_max_lanes_i64: i32,
    simd_max_lanes_u64: i32,
    simd_max_lanes_i16: i32,
    simd_max_lanes_u16: i32,
    simd_max_lanes_f64: i32,
    simd_max_lanes_i32: i32,
    simd_max_lanes_u32: i32,
    simd_max_lanes_f32: i32,
    // @vector.select 4× 快路径助手：仅在实际生成 uya_simd_*_select_*x4 调用时置 1，缩小输出 C 体积
    simd_emit_select_i32x2: i32,
    simd_emit_select_u32x2: i32,
    simd_emit_select_f32x2: i32,
    simd_emit_select_i32x4: i32,
    simd_emit_select_u32x4: i32,
    simd_emit_select_f32x4: i32,
    // @vector.reduce_add 快路径助手：仅在实际生成对应 uya_simd_sse_reduce_add_* 调用时置 1
    simd_emit_reduce_add_i32x2: i32,
    simd_emit_reduce_add_u32x2: i32,
    simd_emit_reduce_add_f32x2: i32,
    simd_emit_reduce_add_i32x4: i32,
    simd_emit_reduce_add_u32x4: i32,
    simd_emit_reduce_add_f32x4: i32,
    // @vector.reduce_mul 快路径助手：仅在实际生成 uya_simd_*_reduce_mul_*x4/x2 调用时置 1
    simd_emit_reduce_mul_i32x2: i32,
    simd_emit_reduce_mul_u32x2: i32,
    simd_emit_reduce_mul_f32x2: i32,
    simd_emit_reduce_mul_i32x4: i32,
    simd_emit_reduce_mul_u32x4: i32,
    simd_emit_reduce_mul_f32x4: i32,
    // @vector.reduce_min/@vector.reduce_max 助手：i32/u32/f32 ×2/×4
    simd_emit_reduce_min_i32x2: i32,
    simd_emit_reduce_min_u32x2: i32,
    simd_emit_reduce_min_f32x2: i32,
    simd_emit_reduce_min_i32x4: i32,
    simd_emit_reduce_min_u32x4: i32,
    simd_emit_reduce_min_f32x4: i32,
    simd_emit_reduce_max_i32x2: i32,
    simd_emit_reduce_max_u32x2: i32,
    simd_emit_reduce_max_f32x2: i32,
    simd_emit_reduce_max_i32x4: i32,
    simd_emit_reduce_max_u32x4: i32,
    simd_emit_reduce_max_f32x4: i32,
    
    // 泛型单态化实例（从 TypeChecker 传入）
    mono_instances: [MonoInstanceCodegen: C99_MAX_MONO_INSTANCES],
    mono_instance_count: i32,
    reachable_mono_instances: [i32: C99_MAX_MONO_INSTANCES],
    
    // 当前单态化上下文（生成泛型函数实例时使用）
    current_type_params: &TypeParam,    // 当前泛型的类型参数列表
    current_type_param_count: i32,       // 当前泛型的类型参数数量
    current_type_args: & & ASTNode,      // 当前实例化的类型实参
    current_type_arg_count: i32,         // 当前实例化的类型实参数量
    
    // 期望类型上下文（用于 &[array_literal] 类型推断）
    expected_type: &ASTNode,             // 当前表达式的期望类型（从变量声明/赋值推断）
    // try 的块操作数：期望块末尾产生该错误联合 C 类型（用于块末为 if 时生成可赋值的表达式）
    expected_block_union_type: &byte,
    
    // 结构体类型参数上下文（用于泛型方法）
    struct_type_params: &TypeParam,      // 结构体的类型参数列表
    struct_type_param_count: i32,         // 结构体的类型参数数量
    struct_type_args: & & ASTNode,        // 结构体的类型实参
    struct_type_arg_count: i32,           // 结构体的类型实参数量
    
    // 类型转换递归深度（防止 c99_type_to_c/c99_mono_type_to_c 无限递归）
    type_conv_depth: i32,
    
    // 跟踪是否需要包含标准库头文件
    needs_string_h: i32,                 // 1 表示需要 #include <string.h>
    needs_stdio_h: i32,                   // 1 表示需要 #include <stdio.h>
    needs_stdlib_h: i32,                 // 1 表示需要 #include <stdlib.h>
    needs_syscall_helpers: i32,          // 1 表示需要生成 uya_syscallN 辅助函数
    // 跟踪是否定义了与标准库冲突的函数（fopen, fclose, fread, fgetc, fprintf）
    has_stdio_conflicts: i32,             // 1 表示定义了与 stdio.h 冲突的函数
    
    // --nostdlib 模式：生成 _start 入口
    is_nostdlib: i32,                     // 1 表示生成 _start 内联汇编

    // --freestanding 模式：不包含任何标准库头文件
    freestanding: i32,                    // 1 表示完全独立，不包含 #include

    // 堆栈大小设置（KB）
    stack_size: i32,                      // 堆栈大小（KB），0 表示默认

    // async 状态机：在 poll 内生成表达式时，参数标识符应输出为 s->param
    async_state_var: &byte,               // 状态指针变量名（如 "s"），null 表示未在 async poll 中
    async_param_names: [&byte: 16],       // 捕获的参数名
    async_param_count: i32,               // 捕获参数数量
    async_loop_var_name: &byte,           // 循环内持久化变量名（如 "total"），null 表示无
    async_loop_var_c: &byte,              // 对应的 C 表达式（如 "s->_uya_total"）
    async_bind_names: [&byte: C99_ASYNC_MAX_AWAITS], // await 绑定变量名（如 "n", "written"）
    async_bind_count: i32,               // await 绑定变量数量
    async_collect_operands: [&ASTNode: C99_ASYNC_MAX_AWAITS],
    async_collect_names: [&byte: C99_ASYNC_MAX_AWAITS],
    async_collect_types: [&ASTNode: C99_ASYNC_MAX_AWAITS],
    async_collect_blocks: [&ASTNode: C99_ASYNC_MAX_AWAITS],
    async_collect_stmt_indices: [i32: C99_ASYNC_MAX_AWAITS],
    // try @await 所在的最内层 while（无则 null），用于 while+单 await 循环回跳与退出
    async_collect_enclosing_while: [&ASTNode: C99_ASYNC_MAX_AWAITS],
    // try @await 所在的最内层 for（无则 null）；与 while 互斥时以 while 为准（内层 while 优先）
    async_collect_enclosing_for: [&ASTNode: C99_ASYNC_MAX_AWAITS],
    async_collect_count: i32, // 实际支持最多 C99_ASYNC_MAX_AWAITS 个 await
    async_collect_ret_expr: &ASTNode,
    async_collect_has_loop: i32,
    async_state_size: i32,  // 编译期计算的状态机近似字节数；<=0 表示未知或需堆分配
    // return 之前、函数体顶层的 const/var（非 try @await 绑定），存入状态机供 poll 内 gen_expr(ret) 引用
    async_local_names: [&byte: 16],
    async_local_types: [&ASTNode: 16],
    async_local_inits: [&ASTNode: 16],
    async_local_root_stmt: [i32: 16],
    async_local_count: i32,
    // poll 内 try 传播：语义上为 Future 的 inner（如 !T），错误须 return Poll.Ready(err) 而非裸 err_union
    async_poll_try_propagate_type: &ASTNode,
    async_poll_ret_c: &byte,
    async_poll_union_c: &byte,
    // while 内多 await 间语句发射：1=gen_stmt 遇 return 时生成 Poll::Ready 包装
    async_emit_poll_return: i32,
    // Ready 载荷的 C 类型（如 "struct err_union_usize"），用于 gen_return_stmt 内 Poll 包装
    async_poll_ready_payload_c: &byte,
    // Ready 载荷是否为 error union（1=是：return expr 需包装为 { .error_id=0, .value=expr }）
    async_poll_inner_is_err_union: i32,
    // 通用协程变换上下文（emit_async_segment 递归使用）
    async_fn_decl: &ASTNode,                // 当前 async 函数声明
    async_fn_body: &ASTNode,                // 当前 async 函数体
    async_await_operand_is_err_future: i32,  // 首段 await 是否对 !Future<T> 做 try
    async_full_return_type: &ASTNode,        // 完整返回类型（如 !Future<T>）
    async_concrete_future_safe: &byte,       // 具体 Future struct 的 safe C 名
    async_state_slot_iface_c: &byte,         // await 槽位接口类型

    // --mode container：生成指针访问边界检查
    container_mode: i32,

    // 多文件 C 输出（--split-c-dir）：part1=前导+字符串常量，part2=其余；emit_stream 指向当前写入目标
    emit_stream: &void,
    split_enabled: i32,
    split_part2_out: &void,
    split_body_started: i32,
    split_dir: &byte,
    // uya_part2.c 磁盘路径（用于分 TU 链接前插入 extern 字符串声明）
    split_part2_path: [byte: 1024],
    // split_mirror：一源一 .c（uya_common + 镜像 .c），--split-c-dir 时默认 1；0 时用 uya_part2.c
    split_mirror: i32,
    split_mirror_count: i32,
    split_mirror_keys: [&byte: 128],
    // 计算镜像相对路径时的最长公共目录前缀长度（与 prepare 中一致）
    split_mirror_lcp: i32,
    split_mirror_handles: [&void: 128],
    split_common_out: &void,
    // 镜像模式：第七步函数原型写入 uya_split_protos.h（含 #include uya_part1_types.h），各 .c 首行 #include 该头
    split_protos_out: &void,
    // 镜像模式：前导（头文件与类型）写入 uya_part1_types.h；uya_part1.c 仅 #include 与字符串池
    split_part1_types_h: &void
}

// ===== 函数声明 =====
// 注意：Uya Mini 不支持普通函数的前向声明
// 所有函数定义都在对应的实现文件中，通过文件编译顺序保证依赖关系
// 只有 extern 函数可以前向声明（如上面的 arena_alloc）

