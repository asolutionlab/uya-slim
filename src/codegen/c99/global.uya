// global.uya - C99 代码生成器全局变量模块
// 提供全局变量生成功能
//
// 注意：需要先包含 internal.uya（包含类型定义和函数声明）
// 由于 Uya Mini 不支持模块系统，这里假设相关类型已经定义

// ===== 外部函数声明 =====
// C 标准库函数（在 extern_decls.uya 中声明）
extern fn hash_string(str: &byte) i32;
extern fn fopen(filename: *byte, mode: *byte) *void;
extern fn fflush(stream: *void) i32;
extern fn fclose(stream: *void) i32;

// get_c_name_for_identifier_ref 缓存：与 lookup_identifier_type_c_impl 相同的上下文键 + async 字段
const C99_IDENT_REF_CACHE_SIZE: i32 = 4096;
const C99_IDENT_REF_CACHE_MASK: i32 = 4095;

var g_c99_ident_ref_cached_codegen: &C99CodeGenerator = null;
var g_c99_ident_ref_keys: [&byte: C99_IDENT_REF_CACHE_SIZE] = [];
var g_c99_ident_ref_values: [&byte: C99_IDENT_REF_CACHE_SIZE] = [];
var g_c99_ident_ref_functions: [&ASTNode: C99_IDENT_REF_CACHE_SIZE] = [];
var g_c99_ident_ref_local_counts: [i32: C99_IDENT_REF_CACHE_SIZE] = [];
var g_c99_ident_ref_global_counts: [i32: C99_IDENT_REF_CACHE_SIZE] = [];
var g_c99_ident_ref_method_structs: [&byte: C99_IDENT_REF_CACHE_SIZE] = [];
var g_c99_ident_ref_async_sv: [&byte: C99_IDENT_REF_CACHE_SIZE] = [];
var g_c99_ident_ref_async_pc: [i32: C99_IDENT_REF_CACHE_SIZE] = [];
var g_c99_ident_ref_async_bc: [i32: C99_IDENT_REF_CACHE_SIZE] = [];
var g_c99_ident_ref_async_lc: [i32: C99_IDENT_REF_CACHE_SIZE] = [];
var g_c99_ident_ref_async_loop: [&byte: C99_IDENT_REF_CACHE_SIZE] = [];

export fn c99_ident_ref_cache_reset() void {
    var i: i32 = 0;
    while i < C99_IDENT_REF_CACHE_SIZE {
        g_c99_ident_ref_keys[i] = null;
        g_c99_ident_ref_values[i] = null;
        g_c99_ident_ref_functions[i] = null;
        g_c99_ident_ref_local_counts[i] = 0;
        g_c99_ident_ref_global_counts[i] = 0;
        g_c99_ident_ref_method_structs[i] = null;
        g_c99_ident_ref_async_sv[i] = null;
        g_c99_ident_ref_async_pc[i] = 0;
        g_c99_ident_ref_async_bc[i] = 0;
        g_c99_ident_ref_async_lc[i] = 0;
        g_c99_ident_ref_async_loop[i] = null;
        i = i + 1;
    }
    g_c99_ident_ref_cached_codegen = null;
}

fn c99_ident_ref_cache_ensure(codegen: &C99CodeGenerator) void {
    if codegen == null {
        return;
    }
    if g_c99_ident_ref_cached_codegen == codegen {
        return;
    }
    c99_ident_ref_cache_reset();
    g_c99_ident_ref_cached_codegen = codegen;
}

fn c99_ident_ref_cache_slot(codegen: &C99CodeGenerator, name: &byte) i32 {
    var h: i32 = hash_string(name);
    if codegen != null && codegen.current_function_decl != null {
        h = h + ((@usize_from_ptr(codegen.current_function_decl as &void) & 65535usize) as i32);
    }
    if codegen != null {
        h = h + (codegen.local_variable_count * 17);
        h = h + (codegen.global_variable_count * 29);
        if codegen.current_method_struct_name != null {
            h = h + (hash_string(codegen.current_method_struct_name) * 37);
        }
    }
    return (h & C99_IDENT_REF_CACHE_MASK) as i32;
}

// C 类型串已由 c99_type_to_c 带上前导 const（如 const uint8_t *）时返回 1，避免再写「const const …」触发 -Werror
fn c99_c_type_str_leading_const(tc: &byte) i32 {
    if tc == null {
        return 0;
    }
    if strncmp(tc as *byte, "const " as *byte, 6) == 0 {
        return 1;
    }
    return 0;
}

// 全局初始化上下文为「指向 const byte 的指针」时，字符串字面量需 (const uint8_t *) 转型以满足 -Werror=pointer-sign
fn global_init_ctx_is_const_ptr_to_byte(ctx: &ASTNode) i32 {
    if ctx == null || ctx.type != ASTNodeType.AST_TYPE_POINTER {
        return 0;
    }
    if ctx.type_pointer_is_const == 0 {
        return 0;
    }
    const pt: &ASTNode = ctx.type_pointer_pointed_type;
    if pt == null || pt.type != ASTNodeType.AST_TYPE_NAMED || pt.type_named_name == null {
        return 0;
    }
    if strcmp(pt.type_named_name as *byte, "byte" as *byte) != 0 {
        return 0;
    }
    return 1;
}

const C99_GLOBAL_INIT_MAX_EXPAND_DEPTH: i32 = 32;
var g_c99_global_init_expand_depth: i32 = 0;

fn c99_find_top_level_const_init_expr(codegen: &C99CodeGenerator, name: &byte, out_type: &&ASTNode) &ASTNode {
    if out_type != null {
        out_type[0] = null;
    }
    if codegen == null || name == null || codegen.program_node == null || codegen.program_node.type != ASTNodeType.AST_PROGRAM {
        return null;
    }
    var i: i32 = 0;
    while i < codegen.program_node.program_decl_count {
        const decl: &ASTNode = codegen.program_node.program_decls[i];
        if decl != null && decl.type == ASTNodeType.AST_VAR_DECL && decl.var_decl_name != null &&
            strcmp(decl.var_decl_name as *byte, name as *byte) == 0 && decl.var_decl_is_const != 0 &&
            decl.var_decl_init != null {
            if out_type != null {
                out_type[0] = decl.var_decl_type;
            }
            return decl.var_decl_init;
        }
        if decl != null && decl.type == ASTNodeType.AST_EXTERN_VAR_DECL && decl.extern_var_decl_name != null &&
            strcmp(decl.extern_var_decl_name as *byte, name as *byte) == 0 && decl.extern_var_decl_is_const != 0 &&
            decl.extern_var_decl_init_expr != null {
            if out_type != null {
                out_type[0] = decl.extern_var_decl_var_type;
            }
            return decl.extern_var_decl_init_expr;
        }
        i = i + 1;
    }
    return null;
}

fn c99_find_struct_init_field_expr(struct_init: &ASTNode, field_name: &byte) &ASTNode {
    if struct_init == null || struct_init.type != ASTNodeType.AST_STRUCT_INIT || field_name == null {
        return null;
    }
    var i: i32 = 0;
    while i < struct_init.struct_init_field_count {
        if struct_init.struct_init_field_names != null &&
            struct_init.struct_init_field_names[i] != null &&
            strcmp(struct_init.struct_init_field_names[i] as *byte, field_name as *byte) == 0 {
            if struct_init.struct_init_field_values != null {
                return struct_init.struct_init_field_values[i];
            }
            return null;
        }
        i = i + 1;
    }
    return null;
}

fn gen_global_init_expr(codegen: &C99CodeGenerator, expr: &ASTNode, init_ctx_type: &ASTNode) void {
    if expr == null {
        return;
    }

    if init_ctx_type != null && c99_emit_interface_box_global_init(codegen, init_ctx_type, expr) != 0 {
        return;
    }

    if g_c99_global_init_expand_depth < C99_GLOBAL_INIT_MAX_EXPAND_DEPTH &&
        expr.type == ASTNodeType.AST_IDENTIFIER && expr.identifier_name != null {
        var nested_type: &ASTNode = null;
        const nested_init: &ASTNode = c99_find_top_level_const_init_expr(codegen, expr.identifier_name, &nested_type);
        if nested_init != null && nested_init != expr {
            g_c99_global_init_expand_depth = g_c99_global_init_expand_depth + 1;
            var next_ctx: &ASTNode = init_ctx_type;
            if next_ctx == null {
                next_ctx = nested_type;
            }
            gen_global_init_expr(codegen, nested_init, next_ctx);
            g_c99_global_init_expand_depth = g_c99_global_init_expand_depth - 1;
            return;
        }
    }

    if g_c99_global_init_expand_depth < C99_GLOBAL_INIT_MAX_EXPAND_DEPTH &&
        expr.type == ASTNodeType.AST_MEMBER_ACCESS && expr.member_access_object != null &&
        expr.member_access_field_name != null &&
        expr.member_access_object.type == ASTNodeType.AST_IDENTIFIER &&
        expr.member_access_object.identifier_name != null {
        var nested_type_ma: &ASTNode = null;
        const base_init: &ASTNode = c99_find_top_level_const_init_expr(codegen, expr.member_access_object.identifier_name, &nested_type_ma);
        if base_init != null && base_init.type == ASTNodeType.AST_STRUCT_INIT {
            const field_init: &ASTNode = c99_find_struct_init_field_expr(base_init, expr.member_access_field_name);
            if field_init != null {
                g_c99_global_init_expand_depth = g_c99_global_init_expand_depth + 1;
                gen_global_init_expr(codegen, field_init, init_ctx_type);
                g_c99_global_init_expand_depth = g_c99_global_init_expand_depth - 1;
                return;
            }
        }
    }
    
    if expr.type == ASTNodeType.AST_STRUCT_INIT {
        // 对于全局作用域，生成标准初始化器列表，不使用复合字面量
        const field_count: i32 = expr.struct_init_field_count;
        var struct_decl: &ASTNode = null;
        if expr.struct_init_struct_name != null {
            struct_decl = find_struct_decl_c99(codegen, expr.struct_init_struct_name);
        }
        fputc(123, codegen.emit_stream as *void);  // '{'
        var i: i32 = 0;
        while i < field_count {
            const safe_field_name: &byte = get_safe_c_identifier(codegen, expr.struct_init_field_names[i]);
            var field_ctx: &ASTNode = null;
            if struct_decl != null {
                field_ctx = c99_find_struct_field_type(codegen, struct_decl, expr.struct_init_field_names[i]);
            }
            fprintf(codegen.emit_stream as *void, ".%s = " as *byte, safe_field_name as *byte);
            gen_global_init_expr(codegen, expr.struct_init_field_values[i], field_ctx);
            if i < field_count - 1 {
                c99_emit_comma_space(codegen);
            }
            i = i + 1;
        }
        fputc(125, codegen.emit_stream as *void);  // '}'
    } else if expr.type == ASTNodeType.AST_ARRAY_LITERAL {
        const element_count: i32 = expr.array_literal_element_count;
        const repeat_count_expr: &ASTNode = expr.array_literal_repeat_count_expr;
        var elem_ctx: &ASTNode = null;
        if init_ctx_type != null && init_ctx_type.type == ASTNodeType.AST_TYPE_ARRAY {
            elem_ctx = init_ctx_type.type_array_element_type;
        }
        fputc(123, codegen.emit_stream as *void);  // '{'
        if repeat_count_expr != null && element_count >= 1 {
            var nn: i32 = eval_const_expr(codegen, repeat_count_expr);
            if nn <= 0 {
                nn = 1;
            }
            var i: i32 = 0;
            while i < nn {
                gen_global_init_expr(codegen, expr.array_literal_elements[0], elem_ctx);
                if i < nn - 1 {
                    c99_emit_comma_space(codegen);
                }
                i = i + 1;
            }
        } else if element_count > 0 {
            var i: i32 = 0;
            while i < element_count {
                gen_global_init_expr(codegen, expr.array_literal_elements[i], elem_ctx);
                if i < element_count - 1 {
                    c99_emit_comma_space(codegen);
                }
                i = i + 1;
            }
        } else {
            // 空数组字面量：生成 0 避免 ISO C 警告
            fputs("0" as *byte, codegen.emit_stream as *void);
        }
        fputc(125, codegen.emit_stream as *void);  // '}'
    } else if expr.type == ASTNodeType.AST_STRING {
        // 全局数组用字符串字面量初始化：直接输出字符串字面量
        if global_init_ctx_is_const_ptr_to_byte(init_ctx_type) != 0 {
            fputs("(const uint8_t *)" as *byte, codegen.emit_stream as *void);
        }
        if expr.string_literal_value != null {
            fputc(34, codegen.emit_stream as *void);  // '"'
            escape_string_for_c(codegen.emit_stream, expr.string_literal_value);
            fputc(34, codegen.emit_stream as *void);  // '"'
        } else {
            fputs("\"\"" as *byte, codegen.emit_stream as *void);
        }
    } else if expr.type == ASTNodeType.AST_ERROR_NAME {
        const operand: &ASTNode = expr.error_name_operand;
        if operand != null && operand.type == ASTNodeType.AST_ERROR_VALUE && operand.error_value_name != null {
            fputs("(uint8_t *)\"" as *byte, codegen.emit_stream as *void);
            escape_string_for_c(codegen.emit_stream, operand.error_value_name);
            fputc(34, codegen.emit_stream as *void);
            return;
        }
        gen_expr(codegen, expr);
    } else if expr.type == ASTNodeType.AST_EMBED {
        c99_register_embed_slice_types(codegen, 0);
        const embed_name: &byte = add_embed_constant(codegen, expr.embed_resolved_path, expr.embed_data, expr.embed_size);
        fputs("{ .ptr = " as *byte, codegen.emit_stream as *void);
        if embed_name != null {
            fprintf(codegen.emit_stream as *void, "(uint8_t *)%s" as *byte, embed_name as *byte);
        } else {
            fputs("(uint8_t *)\"\"" as *byte, codegen.emit_stream as *void);
        }
        fprintf(codegen.emit_stream as *void, ", .len = (size_t)%d }" as *byte, expr.embed_size);
    } else if expr.type == ASTNodeType.AST_EMBED_DIR {
        c99_register_embed_slice_types(codegen, 1);
        const table_name: &byte = add_embed_dir_table(codegen, expr);
        fputs("{ .ptr = " as *byte, codegen.emit_stream as *void);
        if table_name != null {
            fprintf(codegen.emit_stream as *void, "(struct EmbedDirEntry *)%s" as *byte, table_name as *byte);
        } else {
            fputs("(struct EmbedDirEntry *)0" as *byte, codegen.emit_stream as *void);
        }
        fprintf(codegen.emit_stream as *void, ", .len = (size_t)%d }" as *byte, expr.embed_dir_entry_count);
    } else {
        // 对于其他表达式类型（数字、布尔值等），使用标准生成方式
        gen_expr(codegen, expr);
    }
}

// 生成全局变量定义
fn gen_global_var(codegen: &C99CodeGenerator, var_decl: &ASTNode) void {
    if var_decl == null || var_decl.type != ASTNodeType.AST_VAR_DECL {
        return;
    }
    
    const orig_name: &byte = var_decl.var_decl_name;
    const filename: &byte = var_decl.filename;
    const is_export: i32 = var_decl.var_decl_is_export;
    const var_name: &byte = get_c_name_for_global_constant(codegen, orig_name, filename, is_export);
    const var_type: &ASTNode = var_decl.var_decl_type;
    const init_expr: &ASTNode = var_decl.var_decl_init;
    const is_const: i32 = var_decl.var_decl_is_const;
    
    if var_name == null || var_type == null {
        return;
    }
    
    fputs("__attribute__((used)) " as *byte, codegen.emit_stream as *void);
    
    var type_c: &byte = null;
    
    // 检查是否为数组类型
    if var_type.type == ASTNodeType.AST_TYPE_ARRAY {
        // 对于数组类型（包括多维数组），使用 c99_type_to_c 处理整个类型
        // 它会正确处理多维数组，例如 [[byte: PATH_MAX]: MAX_INPUT_FILES] -> uint8_t[64][4096]
        const full_type_c: &byte = c99_type_to_c(codegen, var_type);
        
        // 解析类型字符串，分离基类型和数组维度
        // 例如："uint8_t[64][4096]" -> 基类型="uint8_t", 维度="[64][4096]"
        const first_bracket: *byte = strchr(full_type_c as *byte, 91);  // '['
        if first_bracket != null {
            // 找到第一个 '['，分割基类型和维度
            const base_len: i32 = ptr_diff(first_bracket, full_type_c as *byte);
            const base_type: &u8 = compiler_arena_alloc(codegen.arena, base_len + 1) as &u8;
            if base_type != null {
                memcpy(base_type as *void, full_type_c as *void, base_len);
                base_type[base_len] = 0;
                
                // 维度部分是从 '[' 开始到结尾
                const dimensions: *byte = full_type_c as *byte + base_len;
                
                // 生成数组声明：const base_type var_name dimensions（base 已含 const 则不再前缀 const）
                if is_const != 0 {
                    if c99_c_type_str_leading_const(base_type) != 0 {
                        fprintf(codegen.emit_stream as *void, "%s %s%s" as *byte, base_type as *byte, var_name as *byte, dimensions);
                    } else {
                        fprintf(codegen.emit_stream as *void, "const %s %s%s" as *byte, base_type as *byte, var_name as *byte, dimensions);
                    }
                } else {
                    fprintf(codegen.emit_stream as *void, "%s %s%s" as *byte, base_type as *byte, var_name as *byte, dimensions);
                }
                type_c = base_type;  // 保存基类型用于后续使用
            } else {
                // 分配失败，回退到简单处理
                type_c = full_type_c;
                if is_const != 0 {
                    if c99_c_type_str_leading_const(type_c) != 0 {
                        fprintf(codegen.emit_stream as *void, "%s %s" as *byte, type_c as *byte, var_name as *byte);
                    } else {
                        fprintf(codegen.emit_stream as *void, "const %s %s" as *byte, type_c as *byte, var_name as *byte);
                    }
                } else {
                    fprintf(codegen.emit_stream as *void, "%s %s" as *byte, type_c as *byte, var_name as *byte);
                }
            }
        } else {
            // 没有找到 '['，可能是错误情况，回退到简单处理
            type_c = full_type_c;
            if is_const != 0 {
                if c99_c_type_str_leading_const(type_c) != 0 {
                    fprintf(codegen.emit_stream as *void, "%s %s" as *byte, type_c as *byte, var_name as *byte);
                } else {
                    fprintf(codegen.emit_stream as *void, "const %s %s" as *byte, type_c as *byte, var_name as *byte);
                }
            } else {
                fprintf(codegen.emit_stream as *void, "%s %s" as *byte, type_c as *byte, var_name as *byte);
            }
        }
    } else {
        type_c = c99_type_to_c(codegen, var_type);
        if is_const != 0 {
            if c99_c_type_str_leading_const(type_c) != 0 {
                fprintf(codegen.emit_stream as *void, "%s %s", type_c as *byte, var_name as *byte);
            } else {
                fprintf(codegen.emit_stream as *void, "const %s %s", type_c as *byte, var_name as *byte);
            }
        } else {
            fprintf(codegen.emit_stream as *void, "%s %s", type_c as *byte, var_name as *byte);
        }
    }
    
    // 初始化表达式（使用全局作用域兼容的生成方式）
    if init_expr != null {
        fputs(" = " as *byte, codegen.emit_stream as *void);
        gen_global_init_expr(codegen, init_expr, var_type);
    }
    
    c99_emit_semi_newline(codegen);
    
    // 添加到全局变量表（可选，用于后续引用）
    const global_idx: i32 = codegen.global_variable_count;
    if global_idx >= 0 && global_idx < C99_MAX_GLOBAL_VARS {
        codegen.global_variables[global_idx].name = var_name;
        codegen.global_variables[global_idx].original_name = orig_name;
        codegen.global_variables[global_idx].type_c = type_c;
        codegen.global_variables[global_idx].is_const = is_const;
        codegen.global_variable_count = global_idx + 1;
    }
}

// 按 Uya 名称匹配全局变量（比较 original_name 或 name）
fn global_var_name_matches(codegen: &C99CodeGenerator, i: i32, name: &byte) i32 {
    if codegen == null {
        return 0;
    }
    if i < 0 {
        return 0;
    }
    if i >= codegen.global_variable_count {
        return 0;
    }
    if i >= C99_MAX_GLOBAL_VARS {
        return 0;
    }
    if name == null {
        return 0;
    }
    var key: &byte = codegen.global_variables[i].original_name;
    if key == null {
        key = codegen.global_variables[i].name;
    }
    if key != null && strcmp(key as *byte, name as *byte) == 0 {
        return 1;
    }
    return 0;
}

fn c99_local_var_name_at(codegen: &C99CodeGenerator, idx: i32) &byte {
    if codegen == null {
        return null;
    }
    if idx < 0 {
        return null;
    }
    if idx >= C99_MAX_LOCAL_VARS {
        return null;
    }
    return codegen.local_variables[idx].name;
}

fn c99_local_var_type_c_at(codegen: &C99CodeGenerator, idx: i32) &byte {
    if codegen == null {
        return null;
    }
    if idx < 0 {
        return null;
    }
    if idx >= C99_MAX_LOCAL_VARS {
        return null;
    }
    return codegen.local_variables[idx].type_c;
}

fn c99_local_var_type_node_at(codegen: &C99CodeGenerator, idx: i32) &ASTNode {
    if codegen == null {
        return null;
    }
    if idx < 0 {
        return null;
    }
    if idx >= C99_MAX_LOCAL_VARS {
        return null;
    }
    return codegen.local_variables[idx].type_node;
}

fn c99_push_local_variable(codegen: &C99CodeGenerator, name: &byte, type_c: &byte, type_node: &ASTNode, depth: i32) i32 {
    if codegen == null || name == null || type_c == null {
        return 0;
    }
    const local_idx: i32 = codegen.local_variable_count;
    if local_idx >= 0 && local_idx < C99_MAX_LOCAL_VARS {
        codegen.local_variables[local_idx].name = name;
        codegen.local_variables[local_idx].type_c = type_c;
        codegen.local_variables[local_idx].type_node = type_node;
        codegen.local_variables[local_idx].depth = depth;
        codegen.local_variables[local_idx].is_error_value = 0;
        codegen.local_variable_count = local_idx + 1;
        return 1;
    }
    return 0;
}

fn c99_mark_local_variable_error_value(codegen: &C99CodeGenerator, name: &byte) i32 {
    if codegen == null || name == null {
        return 0;
    }
    const safe_name: &byte = get_safe_c_identifier(codegen, name);
    var i: i32 = codegen.local_variable_count - 1;
    while i >= 0 {
        if i < C99_MAX_LOCAL_VARS && codegen.local_variables[i].name != null {
            if strcmp(codegen.local_variables[i].name as *byte, name as *byte) == 0 ||
                (safe_name != null && strcmp(codegen.local_variables[i].name as *byte, safe_name as *byte) == 0) {
                codegen.local_variables[i].is_error_value = 1;
                return 1;
            }
        }
        i = i - 1;
    }
    return 0;
}

fn c99_identifier_is_error_value(codegen: &C99CodeGenerator, name: &byte) i32 {
    if codegen == null || name == null {
        return 0;
    }
    const safe_name: &byte = get_safe_c_identifier(codegen, name);
    var i: i32 = codegen.local_variable_count - 1;
    while i >= 0 {
        if i < C99_MAX_LOCAL_VARS && codegen.local_variables[i].name != null {
            if strcmp(codegen.local_variables[i].name as *byte, name as *byte) == 0 ||
                (safe_name != null && strcmp(codegen.local_variables[i].name as *byte, safe_name as *byte) == 0) {
                return codegen.local_variables[i].is_error_value;
            }
        }
        i = i - 1;
    }
    return 0;
}

// 引用标识符时使用的 C 名称（全局常量与系统宏冲突时返回 uya_ 前缀名）
// 在 async 状态机 poll 内：参数标识符输出为 s->param
fn get_c_name_for_identifier_ref(codegen: &C99CodeGenerator, name: &byte) &byte {
    if codegen == null || name == null {
        return get_safe_c_identifier(codegen, name);
    }
    if codegen.async_state_var != null && codegen.async_loop_var_name != null &&
        strcmp(codegen.async_loop_var_name as *byte, name as *byte) == 0 {
        return codegen.async_loop_var_c;
    }
    if codegen.async_state_var != null && codegen.async_param_count > 0 {
        var ai: i32 = 0;
        while ai < codegen.async_param_count && ai < 16 {
            if codegen.async_param_names[ai] != null &&
                strcmp(codegen.async_param_names[ai] as *byte, name as *byte) == 0 {
                const s_len: i32 = strlen(codegen.async_state_var as *byte);
                const n_len: i32 = strlen(name as *byte);
                const buf: &byte = compiler_arena_alloc(codegen.arena, (s_len + 2 + n_len + 1) as usize) as &byte;
                if buf != null {
                    snprintf(buf as *byte, s_len + 2 + n_len + 1, "%s->%s" as *byte,
                        codegen.async_state_var as *byte, name as *byte);
                    return buf;
                }
                break;
            }
            ai = ai + 1;
        }
    }
    // return 前顶层局部（状态机字段 _uya_loc_*）
    if codegen.async_state_var != null && codegen.async_local_count > 0 {
        var li: i32 = 0;
        while li < codegen.async_local_count && li < @len(codegen.async_local_names) {
            if codegen.async_local_names[li] != null &&
                strcmp(codegen.async_local_names[li] as *byte, name as *byte) == 0 {
                const loc_safe: &byte = get_safe_c_identifier(codegen, codegen.async_local_names[li]);
                if loc_safe != null {
                    const s_len: i32 = strlen(codegen.async_state_var as *byte);
                    const pfx: &byte = "_uya_loc_" as &byte;
                    const plen: i32 = strlen(pfx as *byte);
                    const nl: i32 = strlen(loc_safe as *byte);
                    const buf_len: i32 = s_len + 2 + plen + nl + 1;
                    const buf2: &byte = compiler_arena_alloc(codegen.arena, buf_len as usize) as &byte;
                    if buf2 != null {
                        snprintf(buf2 as *byte, buf_len, "%s->_uya_loc_%s" as *byte,
                            codegen.async_state_var as *byte, loc_safe as *byte);
                        return buf2;
                    }
                }
                break;
            }
            li = li + 1;
        }
    }
    // await 绑定变量：输出为 s->_uya_bind_name
    if codegen.async_state_var != null && codegen.async_bind_count > 0 {
        var bi: i32 = 0;
        while bi < codegen.async_bind_count && bi < C99_ASYNC_MAX_AWAITS {
            if codegen.async_bind_names[bi] != null &&
                strcmp(codegen.async_bind_names[bi] as *byte, name as *byte) == 0 {
                const s_len: i32 = strlen(codegen.async_state_var as *byte);
                const n_len: i32 = strlen(name as *byte);
                // 格式：s->_uya_bind_NAME（需要额外 8 字节 for "_uya_bind_")
                const buf_len: i32 = s_len + 2 + 10 + n_len + 1;
                const buf: &byte = compiler_arena_alloc(codegen.arena, buf_len as usize) as &byte;
                if buf != null {
                    snprintf(buf as *byte, buf_len, "%s->_uya_bind_%s" as *byte,
                        codegen.async_state_var as *byte, name as *byte);
                    return buf;
                }
                break;
            }
            bi = bi + 1;
        }
    }
    // poll 体的状态指针固定使用 async_state_var（当前为 s）。用户在 await 之后声明局部变量 s 时，
    // 需要给该局部变量换一个 C 名，避免初始化表达式里的 s->_uya_loc_* 被新局部变量遮蔽。
    if codegen.async_state_var != null && codegen.local_variable_count > 0 {
        const safe_name: &byte = get_safe_c_identifier(codegen, name);
        if safe_name != null && strcmp(safe_name as *byte, codegen.async_state_var as *byte) == 0 {
            var li: i32 = 0;
            while li < codegen.local_variable_count && li < C99_MAX_LOCAL_VARS {
                if codegen.local_variables[li].name != null &&
                    (strcmp(codegen.local_variables[li].name as *byte, name as *byte) == 0 ||
                     strcmp(codegen.local_variables[li].name as *byte, safe_name as *byte) == 0) {
                    return "__uya_local_s" as &byte;
                }
                li = li + 1;
            }
        }
    }
    // 普通局部变量与参数：直接返回安全名，避免被全局函数前缀解析覆盖
    if codegen.local_variable_count > 0 {
        var li: i32 = 0;
        while li < codegen.local_variable_count && li < C99_MAX_LOCAL_VARS {
            if codegen.local_variables[li].name != null &&
                strcmp(codegen.local_variables[li].name as *byte, name as *byte) == 0 {
                return get_safe_c_identifier(codegen, name);
            }
            li = li + 1;
        }
    }
    c99_ident_ref_cache_ensure(codegen);
    const slot: i32 = c99_ident_ref_cache_slot(codegen, name);
    if slot < 0 {
        return get_safe_c_identifier(codegen, name);
    }
    if slot >= C99_IDENT_REF_CACHE_SIZE {
        return get_safe_c_identifier(codegen, name);
    }
    if g_c99_ident_ref_keys[slot] != null &&
        strcmp(g_c99_ident_ref_keys[slot] as *byte, name as *byte) == 0 &&
        g_c99_ident_ref_functions[slot] == codegen.current_function_decl &&
        g_c99_ident_ref_local_counts[slot] == codegen.local_variable_count &&
        g_c99_ident_ref_global_counts[slot] == codegen.global_variable_count &&
        (g_c99_ident_ref_method_structs[slot] == codegen.current_method_struct_name ||
            (g_c99_ident_ref_method_structs[slot] != null && codegen.current_method_struct_name != null &&
                strcmp(g_c99_ident_ref_method_structs[slot] as *byte, codegen.current_method_struct_name as *byte) == 0)) &&
        g_c99_ident_ref_async_sv[slot] == codegen.async_state_var &&
        g_c99_ident_ref_async_pc[slot] == codegen.async_param_count &&
        g_c99_ident_ref_async_bc[slot] == codegen.async_bind_count &&
        g_c99_ident_ref_async_lc[slot] == codegen.async_local_count &&
        (g_c99_ident_ref_async_loop[slot] == codegen.async_loop_var_name ||
            (g_c99_ident_ref_async_loop[slot] != null && codegen.async_loop_var_name != null &&
                strcmp(g_c99_ident_ref_async_loop[slot] as *byte, codegen.async_loop_var_name as *byte) == 0)) {
        return g_c99_ident_ref_values[slot];
    }
    var i: i32 = 0;
    var result: &byte = null;
    while i < codegen.global_variable_count {
        if global_var_name_matches(codegen, i, name) != 0 {
            result = codegen.global_variables[i].name;
            break;
        }
        i = i + 1;
    }
    // 镜像分 TU：vtable/测试等可能在「公共」.c 中先于其它源文件里的全局定义生成，
    // global_variables 尚未登记；从合并 program 解析与 gen_global_var / gen_extern_var_decl 一致的 C 名
    if result == null && codegen.split_mirror != 0 && codegen.program_node != null &&
        codegen.program_node.type == ASTNodeType.AST_PROGRAM {
        var pdi: i32 = 0;
        while pdi < codegen.program_node.program_decl_count {
            const pdecl: &ASTNode = codegen.program_node.program_decls[pdi];
            if pdecl != null && pdecl.type == ASTNodeType.AST_VAR_DECL && pdecl.var_decl_name != null &&
                strcmp(pdecl.var_decl_name as *byte, name as *byte) == 0 {
                result = get_c_name_for_global_constant(codegen, pdecl.var_decl_name, pdecl.filename, pdecl.var_decl_is_export);
                pdi = codegen.program_node.program_decl_count;
            }
            if pdecl != null && pdecl.type == ASTNodeType.AST_EXTERN_VAR_DECL && pdecl.extern_var_decl_name != null &&
                strcmp(pdecl.extern_var_decl_name as *byte, name as *byte) == 0 {
                // 与 gen_extern_var_decl 保持一致：仅 lib/libc 与 lib/syscall 的导出变量使用模块前缀名。
                var use_prefixed_name: i32 = 0;
                if pdecl.extern_var_decl_is_export != 0 && pdecl.filename != null {
                    if strstr(pdecl.filename as *byte, "/lib/libc/" as *byte) != null ||
                        strstr(pdecl.filename as *byte, "\\lib\\libc\\" as *byte) != null ||
                        strstr(pdecl.filename as *byte, "/lib/syscall/" as *byte) != null ||
                        strstr(pdecl.filename as *byte, "\\lib\\syscall\\" as *byte) != null {
                        use_prefixed_name = 1;
                    }
                }
                if use_prefixed_name != 0 {
                    result = get_c_name_for_global_constant(codegen, pdecl.extern_var_decl_name, pdecl.filename, pdecl.extern_var_decl_is_export);
                } else {
                    result = get_safe_c_identifier(codegen, pdecl.extern_var_decl_name);
                }
                pdi = codegen.program_node.program_decl_count;
            }
            pdi = pdi + 1;
        }
    }
    if result == null {
        result = get_c_name_for_global_function(codegen, name, 0);
    }
    g_c99_ident_ref_keys[slot] = name;
    g_c99_ident_ref_values[slot] = result;
    g_c99_ident_ref_functions[slot] = codegen.current_function_decl;
    g_c99_ident_ref_local_counts[slot] = codegen.local_variable_count;
    g_c99_ident_ref_global_counts[slot] = codegen.global_variable_count;
    g_c99_ident_ref_method_structs[slot] = codegen.current_method_struct_name;
    g_c99_ident_ref_async_sv[slot] = codegen.async_state_var;
    g_c99_ident_ref_async_pc[slot] = codegen.async_param_count;
    g_c99_ident_ref_async_bc[slot] = codegen.async_bind_count;
    g_c99_ident_ref_async_lc[slot] = codegen.async_local_count;
    g_c99_ident_ref_async_loop[slot] = codegen.async_loop_var_name;
    return result;
}

// 生成 extern 变量声明
// extern const name: type;           -> extern const type name;
// extern var name: type;             -> extern type name;
// export const name: type = value;   -> const type name = value;
// export var name: type = value;     -> type name = value;
// export extern const name: type;    -> (不生成，链接到 C 库)
fn gen_extern_var_decl(codegen: &C99CodeGenerator, node: &ASTNode) void {
    if node == null || node.type != ASTNodeType.AST_EXTERN_VAR_DECL {
        return;
    }

    const name: &byte = node.extern_var_decl_name;
    const var_type: &ASTNode = node.extern_var_decl_var_type;
    const init_expr: &ASTNode = node.extern_var_decl_init_expr;
    const is_const: i32 = node.extern_var_decl_is_const;
    const is_extern: i32 = node.extern_var_decl_is_extern;
    const is_export: i32 = node.extern_var_decl_is_export;
    const extern_lib_name: &byte = node.extern_var_decl_extern_lib_name;
    var use_prefixed_name: i32 = 0;
    if is_export != 0 && node.filename != null {
        if strstr(node.filename as *byte, "/lib/libc/" as *byte) != null ||
            strstr(node.filename as *byte, "\\lib\\libc\\" as *byte) != null ||
            strstr(node.filename as *byte, "/lib/syscall/" as *byte) != null ||
            strstr(node.filename as *byte, "\\lib\\syscall\\" as *byte) != null {
            use_prefixed_name = 1;
        }
    }
    var var_name: &byte = name;
    if use_prefixed_name != 0 {
        var_name = get_c_name_for_global_constant(codegen, name, node.filename, is_export);
    }

    if name == null || var_type == null {
        return;
    }

    // 检查变量是否已经生成过（避免重复定义）
    var i: i32 = 0;
    while i < codegen.global_variable_count {
        if codegen.global_variables[i].name != null && str_equals(codegen.global_variables[i].name, var_name) != 0 {
            return;  // 已生成，跳过
        }
        i = i + 1;
    }

    // export extern const/var name: type; -> 不生成代码，链接到 C 库
    if is_export != 0 && is_extern != 0 && init_expr == null && extern_lib_name == null {
        return;
    }

    // extern "libc" const/var name: type; -> 不生成代码，链接到 C 库
    if extern_lib_name != null && init_expr == null {
        return;
    }

    const type_c: &byte = c99_type_to_c(codegen, var_type);

    // 生成声明
    if is_extern != 0 && init_expr == null {
        // extern 声明（无初始化）
        if is_const != 0 {
            if c99_c_type_str_leading_const(type_c) != 0 {
                fprintf(codegen.emit_stream as *void, "extern %s %s;\n" as *byte, type_c as *byte, var_name as *byte);
            } else {
                fprintf(codegen.emit_stream as *void, "extern const %s %s;\n" as *byte, type_c as *byte, var_name as *byte);
            }
        } else {
            fprintf(codegen.emit_stream as *void, "extern %s %s;\n" as *byte, type_c as *byte, var_name as *byte);
        }
    } else {
        // 变量定义（有初始化）
        if is_const != 0 {
            if c99_c_type_str_leading_const(type_c) != 0 {
                fprintf(codegen.emit_stream as *void, "%s %s" as *byte, type_c as *byte, var_name as *byte);
            } else {
                fprintf(codegen.emit_stream as *void, "const %s %s" as *byte, type_c as *byte, var_name as *byte);
            }
        } else {
            fprintf(codegen.emit_stream as *void, "%s %s" as *byte, type_c as *byte, var_name as *byte);
        }

        if init_expr != null {
            fputs(" = " as *byte, codegen.emit_stream as *void);
            gen_global_init_expr(codegen, init_expr, var_type);
        }

        c99_emit_semi_newline(codegen);

        // 添加到全局变量表
        const global_idx2: i32 = codegen.global_variable_count;
        if global_idx2 >= 0 && global_idx2 < C99_MAX_GLOBAL_VARS {
            codegen.global_variables[global_idx2].name = var_name;
            codegen.global_variables[global_idx2].original_name = name;
            codegen.global_variables[global_idx2].type_c = type_c;
            codegen.global_variables[global_idx2].is_const = is_const;
            codegen.global_variable_count = global_idx2 + 1;
        }
    }
}

// 镜像分 TU：c99_type_to_c 对数组得到 "uint8_t[4096]"，C 的 extern 须写为 "extern uint8_t name[4096];"
fn c99_mirror_emit_extern_global_line(codegen: &C99CodeGenerator, tc: &byte, cname: &byte, is_const: i32) void {
    if codegen == null || tc == null || cname == null {
        return;
    }
    const first_bracket: *byte = strchr(tc as *byte, 91);
    if first_bracket != null {
        const base_len: i32 = ptr_diff(first_bracket, tc as *byte);
        const base_type: &u8 = compiler_arena_alloc(codegen.arena, base_len + 1) as &u8;
        if base_type != null {
            memcpy(base_type as *void, tc as *void, base_len);
            base_type[base_len] = 0;
            if is_const != 0 {
                if c99_c_type_str_leading_const(base_type) != 0 {
                    fprintf(codegen.emit_stream as *void, "extern %s %s%s;\n" as *byte, base_type as *byte, cname as *byte, first_bracket);
                } else {
                    fprintf(codegen.emit_stream as *void, "extern const %s %s%s;\n" as *byte, base_type as *byte, cname as *byte, first_bracket);
                }
            } else {
                fprintf(codegen.emit_stream as *void, "extern %s %s%s;\n" as *byte, base_type as *byte, cname as *byte, first_bracket);
            }
            return;
        }
    }
    if is_const != 0 {
        if c99_c_type_str_leading_const(tc) != 0 {
            fprintf(codegen.emit_stream as *void, "extern %s %s;\n" as *byte, tc as *byte, cname as *byte);
        } else {
            fprintf(codegen.emit_stream as *void, "extern const %s %s;\n" as *byte, tc as *byte, cname as *byte);
        }
    } else {
        fprintf(codegen.emit_stream as *void, "extern %s %s;\n" as *byte, tc as *byte, cname as *byte);
    }
}

// 镜像模式：vtable 等可能引用其它源文件中的全局；在 vtable 之前为各顶层变量生成 extern 前向声明（名称与 gen_global_var / gen_extern_var_decl 一致）
export fn c99_mirror_emit_extern_const_fwd(codegen: &C99CodeGenerator, program: &ASTNode) void {
    if codegen == null || codegen.split_mirror == 0 || program == null || program.type != ASTNodeType.AST_PROGRAM {
        return;
    }
    if codegen.split_dir == null || codegen.split_dir[0] == 0 as byte {
        return;
    }
    var gpath: [byte: 1024] = [];
    const gl: i32 = snprintf(&gpath[0] as *byte, 1024, "%s/uya_mirror_globals.h" as *byte, codegen.split_dir as *byte);
    if gl <= 0 || gl >= 1024 {
        return;
    }
    const gh: *void = fopen(&gpath[0] as *byte, "w" as *byte);
    if gh == null {
        return;
    }
    fputs("#ifndef UYA_MIRROR_GLOBALS_H\n#define UYA_MIRROR_GLOBALS_H\n\n" as *byte, gh as *void);
    fputs("/* 镜像分 TU：全局 extern（须在 uya_split_protos.h 之后包含，以便类型已可见） */\n" as *byte, gh as *void);
    const saved: &void = codegen.emit_stream;
    codegen.emit_stream = gh as &void;
    var di: i32 = 0;
    while di < program.program_decl_count {
        const decl: &ASTNode = program.program_decls[di];
        if decl != null && decl.type == ASTNodeType.AST_VAR_DECL && decl.var_decl_name != null {
            const cname: &byte = get_c_name_for_global_constant(codegen, decl.var_decl_name, decl.filename, decl.var_decl_is_export);
            if decl.var_decl_type != null {
                const tc: &byte = c99_type_to_c(codegen, decl.var_decl_type);
                // has_stdio_conflicts 时 stdin/stdout/stderr 宏与「extern struct FILE * stdin」类前向冲突；仅用 _stdin + 宏
                if codegen.has_stdio_conflicts != 0 && cname != null &&
                    (strcmp(cname as *byte, "stdin" as *byte) == 0 || strcmp(cname as *byte, "stdout" as *byte) == 0 ||
                     strcmp(cname as *byte, "stderr" as *byte) == 0) {
                    di = di + 1;
                    continue;
                }
                // 某些项目会同时给 CLOCKS_PER_SEC 生成不同底层类型（如 int64_t 与 clock_t），
                // 镜像前向声明中统一跳过，避免同名异型冲突。
                if cname != null && strstr(cname as *byte, "CLOCKS_PER_SEC" as *byte) != null {
                    di = di + 1;
                    continue;
                }
                c99_mirror_emit_extern_global_line(codegen, tc, cname, decl.var_decl_is_const);
            }
        } else if decl != null && decl.type == ASTNodeType.AST_EXTERN_VAR_DECL && decl.extern_var_decl_name != null &&
            decl.extern_var_decl_var_type != null {
            const is_extern: i32 = decl.extern_var_decl_is_extern;
            const init_expr: &ASTNode = decl.extern_var_decl_init_expr;
            const is_export: i32 = decl.extern_var_decl_is_export;
            const extern_lib_name: &byte = decl.extern_var_decl_extern_lib_name;
            // 与 gen_extern_var_decl 相同的跳过条件；其余且会生成「定义」的 export var/const 需在本 TU 前向声明
            if is_export != 0 && is_extern != 0 && init_expr == null && extern_lib_name == null {
                di = di + 1;
                continue;
            }
            if extern_lib_name != null && init_expr == null {
                di = di + 1;
                continue;
            }
            if is_extern != 0 && init_expr == null {
                di = di + 1;
                continue;
            }
            var cname: &byte = get_safe_c_identifier(codegen, decl.extern_var_decl_name);
            if decl.extern_var_decl_is_export != 0 && decl.filename != null {
                if strstr(decl.filename as *byte, "/lib/libc/" as *byte) != null ||
                    strstr(decl.filename as *byte, "\\lib\\libc\\" as *byte) != null ||
                    strstr(decl.filename as *byte, "/lib/syscall/" as *byte) != null ||
                    strstr(decl.filename as *byte, "\\lib\\syscall\\" as *byte) != null {
                    cname = get_c_name_for_global_constant(codegen, decl.extern_var_decl_name, decl.filename, decl.extern_var_decl_is_export);
                }
            }
            const tc: &byte = c99_type_to_c(codegen, decl.extern_var_decl_var_type);
            if codegen.has_stdio_conflicts != 0 && cname != null &&
                (strcmp(cname as *byte, "stdin" as *byte) == 0 || strcmp(cname as *byte, "stdout" as *byte) == 0 ||
                 strcmp(cname as *byte, "stderr" as *byte) == 0) {
                di = di + 1;
                continue;
            }
            // libc/stdlib 的 RAND_MAX 与系统 stdlib.h 宏同名；镜像前向声明中跳过避免冲突。
            if cname != null && strcmp(cname as *byte, "RAND_MAX" as *byte) == 0 {
                di = di + 1;
                continue;
            }
            if cname != null && strstr(cname as *byte, "CLOCKS_PER_SEC" as *byte) != null {
                di = di + 1;
                continue;
            }
            c99_mirror_emit_extern_global_line(codegen, tc, cname, decl.extern_var_decl_is_const);
        }
        di = di + 1;
    }
    c99_emit_newline(codegen);
    fputs("\n#endif /* UYA_MIRROR_GLOBALS_H */\n" as *byte, codegen.emit_stream as *void);
    _ = fflush(codegen.emit_stream as *void);
    _ = fclose(codegen.emit_stream as *void);
    codegen.emit_stream = saved;
}
