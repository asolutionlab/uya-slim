        fputs("    __asm__ volatile(\n" as *byte, codegen.emit_stream as *void);
        fputs("        \"mov %[sc_tmp], r7\\n\\tmov r7, %[sc_nr]\\n\\tsvc 0\\n\\tmov r7, %[sc_tmp]\"\n" as *byte, codegen.emit_stream as *void);
        fputs("        : \"+r\"(r0), [sc_tmp]\"=&r\"((int){0})\n" as *byte, codegen.emit_stream as *void);
        fputs("        : [sc_nr]\"r\"(nr), \"r\"(r1), \"r\"(r2), \"r\"(r3), \"r\"(r4), \"r\"(r5)\n" as *byte, codegen.emit_stream as *void);
        fputs("        : \"memory\", \"cc\"\n" as *byte, codegen.emit_stream as *void);
        fputs("    );\n" as *byte, codegen.emit_stream as *void);
        fputs("    return r0;\n}\n\n" as *byte, codegen.emit_stream as *void);
        fputs("#else\n" as *byte, codegen.emit_stream as *void);
        fputs("#error \"@syscall C99 backend: supported Linux targets are x86-64, AArch64, and ARM32 EABI. Other OS/arch need a backend.\"\n" as *byte, codegen.emit_stream as *void);
        fputs("#endif\n\n" as *byte, codegen.emit_stream as *void);
        if codegen.split_mirror != 0 && codegen.emit_stream != saved_syscall_emit {
            _ = fflush(codegen.emit_stream as *void);
            _ = fclose(codegen.emit_stream as *void);
            codegen.emit_stream = saved_syscall_emit;
        }
    }
    if prof_codegen != 0 {
        t_mk4 = clock();
        prof_ms_step6_mid = ((t_mk4 as i64) - (t_mk3 as i64)) * 1000 / (CLOCKS_PER_SEC as i64);
    }
    
    // 第六步 e：收集所有单态化函数和方法签名（返回/参数）中的错误联合结构体
    // 必须在生成单态化函数原型之前收集
    {
        var j: i32 = 0;
        while j < codegen.mono_instance_count {
            if codegen.mono_instances[j].generic_name != null && codegen.mono_instances[j].is_function != 0 {
                const gn: &byte = codegen.mono_instances[j].generic_name;
                // 首先检查是否是普通泛型函数
                var k: i32 = 0;
                var found: i32 = 0;
                while k < decl_count && found == 0 {
                    const decl: &ASTNode = ast.program_decls[k];
                    if decl != null && decl.type == ASTNodeType.AST_FN_DECL &&
                        c99_mono_fn_name_matches_decl(codegen, gn, decl) != 0 {
                        if has_unresolved_mono_type_args(decl, codegen.mono_instances[j].type_args, codegen.mono_instances[j].type_arg_count) != 0 {
                            found = 1;
                            break;
                        }
                        preregister_err_union_from_mono_signature(codegen, decl,
                            codegen.mono_instances[j].type_args, codegen.mono_instances[j].type_arg_count);
                        found = 1;
                    }
                    k = k + 1;
                }
                // 如果不是普通函数，检查是否是方法块中的泛型方法
                if found == 0 {
                    k = 0;
                    while k < decl_count && found == 0 {
                        const decl: &ASTNode = ast.program_decls[k];
                        if decl != null && decl.type == ASTNodeType.AST_METHOD_BLOCK {
                            var type_name: &byte = null;
                            if decl.method_block_struct_name != null {
                                type_name = decl.method_block_struct_name;
                            } else {
                                type_name = decl.method_block_union_name;
                            }
                            if type_name != null {
                                var mi: i32 = 0;
                                while mi < decl.method_block_method_count && found == 0 {
                                    const m: &ASTNode = decl.method_block_methods[mi];
                                    if m != null && m.type == ASTNodeType.AST_FN_DECL && m.fn_decl_name != null && m.fn_decl_type_param_count > 0 {
                                        // 检查单态化实例名称是否匹配 "TypeName_method_name" 格式
                                        var expected_prefix: [byte: NAME_BUF_SIZE] = [];
                                        var prefix_len: i32 = snprintf(&expected_prefix[0] as *byte, NAME_BUF_SIZE, "%s_%s" as *byte, type_name as *byte, m.fn_decl_name as *byte);
                                        if strncmp(gn as *byte, &expected_prefix[0] as *byte, prefix_len) == 0 && (gn[prefix_len] == 95 || gn[prefix_len] == 0) {
                                            preregister_err_union_from_mono_signature(codegen, m,
                                                codegen.mono_instances[j].type_args, codegen.mono_instances[j].type_arg_count);
                                            found = 1;
                                        }
                                    }
                                    mi = mi + 1;
                                }
                            }
                        } else if decl != null && decl.type == ASTNodeType.AST_STRUCT_DECL && decl.struct_decl_name != null {
                            // 处理结构体内部定义的泛型方法
                            const struct_name: &byte = decl.struct_decl_name;
                            if decl.struct_decl_methods != null {
                                var mi: i32 = 0;
                                while mi < decl.struct_decl_method_count && found == 0 {
                                    const m: &ASTNode = decl.struct_decl_methods[mi];
                                    if m != null && m.type == ASTNodeType.AST_FN_DECL && m.fn_decl_name != null && m.fn_decl_type_param_count > 0 {
                                        // 检查单态化实例名称是否匹配 "StructName_method_name" 格式
                                        var expected_prefix: [byte: NAME_BUF_SIZE] = [];
                                        var prefix_len: i32 = snprintf(&expected_prefix[0] as *byte, NAME_BUF_SIZE, "%s_%s" as *byte, struct_name as *byte, m.fn_decl_name as *byte);
                                        if strncmp(gn as *byte, &expected_prefix[0] as *byte, prefix_len) == 0 && (gn[prefix_len] == 95 || gn[prefix_len] == 0) {
                                            preregister_err_union_from_mono_signature(codegen, m,
                                                codegen.mono_instances[j].type_args, codegen.mono_instances[j].type_arg_count);
                                            found = 1;
                                        }
                                    }
                                    mi = mi + 1;
                                }
                            }
                        }
                        k = k + 1;
                    }
                }
            }
            j = j + 1;
        }
    }
    // 第六步 e1：收集泛型结构体单态化实例的方法签名（返回/参数）中的错误联合与接口类型
    {
        var mi: i32 = 0;
        while mi < codegen.mono_instance_count {
            if codegen.mono_instances[mi].generic_name != null && codegen.mono_instances[mi].is_function == 0 {
                var di: i32 = 0;
                while di < decl_count {
                    const decl: &ASTNode = ast.program_decls[di];
                    if decl != null && decl.type == ASTNodeType.AST_STRUCT_DECL && decl.struct_decl_name != null &&
                        strcmp(decl.struct_decl_name as *byte, codegen.mono_instances[mi].generic_name as *byte) == 0 &&
                        has_unresolved_mono_type_args(decl, codegen.mono_instances[mi].type_args, codegen.mono_instances[mi].type_arg_count) == 0 {
                        const mono_name: &byte = get_mono_struct_name(codegen, decl.struct_decl_name,
                            codegen.mono_instances[mi].type_args, codegen.mono_instances[mi].type_arg_count);
                        var mj: i32 = 0;
                        while mj < decl.struct_decl_method_count {
                            const m: &ASTNode = decl.struct_decl_methods[mj];
                            if m != null && m.type == ASTNodeType.AST_FN_DECL && m.fn_decl_type_param_count == 0 {
                                preregister_err_union_from_mono_struct_method_signature(codegen, m, mono_name, decl,
                                    codegen.mono_instances[mi].type_args, codegen.mono_instances[mi].type_arg_count);
                            }
                            mj = mj + 1;
                        }
                    }
                    di = di + 1;
                }
            }
            mi = mi + 1;
        }
    }
    // 第六步 e2：遍历所有函数体中的 try 表达式，注册其类型（如 from_json 内层 !Point），便于后续 emit 时类型已定义
    if codegen.checker != null {
        const from_json_decl: &ASTNode = find_function_decl_c99(codegen, "from_json" as *byte);
        var j: i32 = 0;
        while j < codegen.mono_instance_count {
            if codegen.mono_instances[j].generic_name != null && codegen.mono_instances[j].is_function != 0 &&
                strcmp(codegen.mono_instances[j].generic_name as *byte, "from_json" as *byte) == 0 &&
                codegen.mono_instances[j].type_args != null && codegen.mono_instances[j].type_arg_count >= 1 {
                const ta0: &ASTNode = codegen.mono_instances[j].type_args[0];
                if ta0 != null && ta0.type == ASTNodeType.AST_TYPE_NAMED && ta0.type_named_name != null {
                    const body_to_walk: &ASTNode = build_from_json_reflect_body(codegen.checker, ta0, 0, 0, null);
                    if body_to_walk != null {
                        if from_json_decl != null {
                            collect_err_union_from_function_body(codegen, from_json_decl, body_to_walk,
                                codegen.mono_instances[j].type_args, codegen.mono_instances[j].type_arg_count);
                        } else {
                            collect_err_union_from_ast(codegen, body_to_walk);
                        }
                    }
                    const struct_decl: &ASTNode = find_struct_decl_from_program(ast, ta0.type_named_name);
                    if struct_decl != null && struct_decl.struct_decl_fields != null && struct_decl.struct_decl_field_count > 0 {
                        var fi: i32 = 0;
                        while fi < struct_decl.struct_decl_field_count {
                            const fd: &ASTNode = struct_decl.struct_decl_fields[fi];
                            if fd != null && fd.type == ASTNodeType.AST_VAR_DECL && fd.var_decl_type != null {
                                const ft: &ASTNode = fd.var_decl_type;
                                var need_err_union: i32 = 0;
                                if ft.type == ASTNodeType.AST_TYPE_ARRAY { need_err_union = 1; }
                                if ft.type == ASTNodeType.AST_TYPE_SLICE { need_err_union = 1; }
                                if ft.type == ASTNodeType.AST_TYPE_NAMED && ft.type_named_name != null {
                                    const inner: &ASTNode = find_struct_decl_from_program(ast, ft.type_named_name);
                                    if inner != null && inner.struct_decl_fields != null && inner.struct_decl_field_count > 0 {
                                        need_err_union = 1;
                                    }
                                }
                                if need_err_union != 0 {
                                    const eu_node: &ASTNode = ast_new_node(ASTNodeType.AST_TYPE_ERROR_UNION, 0, 0, codegen.arena, null);
                                    if eu_node != null {
                                        eu_node.type_error_union_payload_type = ft;
                                        c99_type_to_c(codegen, eu_node);
                                    }
                                }
                            }
                            fi = fi + 1;
                        }
                    }
                }
            }
            j = j + 1;
        }
        i = 0;
        while i < decl_count {
            const decl: &ASTNode = ast.program_decls[i];
            if decl != null && decl.type == ASTNodeType.AST_FN_DECL && decl.fn_decl_body != null {
                if is_generic_function_c99(decl) != 0 {
                    j = 0;
                    while j < codegen.mono_instance_count {
                        if codegen.mono_instances[j].generic_name != null &&
                            c99_mono_fn_name_matches_decl(codegen, codegen.mono_instances[j].generic_name, decl) != 0 &&
                            codegen.mono_instances[j].is_function != 0 &&
                            has_unresolved_mono_type_args(decl, codegen.mono_instances[j].type_args, codegen.mono_instances[j].type_arg_count) == 0 {
                            if strcmp(decl.fn_decl_name as *byte, "from_json" as *byte) != 0 {
                                const expanded: &ASTNode = prepare_mono_body_expand_macros(codegen.checker, decl.fn_decl_body,
                                    decl.fn_decl_type_params, decl.fn_decl_type_param_count,
                                    codegen.mono_instances[j].type_args, codegen.mono_instances[j].type_arg_count);
                                if expanded != null {
                                    collect_err_union_from_function_body(codegen, decl, expanded,
                                        codegen.mono_instances[j].type_args, codegen.mono_instances[j].type_arg_count);
                                }
                            }
                        }
                        j = j + 1;
                    }
                } else {
                    collect_err_union_from_function_body(codegen, decl, decl.fn_decl_body, null, 0);
                }
            }
            i = i + 1;
        }
    }
    // 再次输出新收集的错误联合结构体
    emit_pending_err_union_structs(codegen);
    if codegen.err_union_struct_count > 0 {
        c99_emit_newline(codegen);
    }
    if prof_codegen != 0 {
        const t_prelude_end: clock_t = clock();
        prof_ms_prelude = ((t_prelude_end as i64) - (prof_t0 as i64)) * 1000 / (CLOCKS_PER_SEC as i64);
        prof_ms_step6e_tail = ((t_prelude_end as i64) - (t_mk4 as i64)) * 1000 / (CLOCKS_PER_SEC as i64);
    }
    
    // 镜像分 TU：第七步函数原型写入 uya_split_protos.h（各镜像 .c 首行 #include）
    if codegen.split_mirror != 0 && codegen.split_dir != null {
        var pp: [byte: 1024] = [];
        const pl: i32 = snprintf(&pp[0] as *byte, 1024, "%s/uya_split_protos.h" as *byte, codegen.split_dir as *byte);
        if pl > 0 && pl < 1024 {
            const pf: *void = fopen(&pp[0] as *byte, "w" as *byte);
            if pf != null {
                fputs("#ifndef UYA_SPLIT_PROTOS_H\n#define UYA_SPLIT_PROTOS_H\n#include \"uya_part1_types.h\"\n\n" as *byte, pf as *void);
                codegen.split_protos_out = pf as &void;
            }
        }
    }
    
    // 第七步：生成所有函数的前向声明（解决相互递归调用）
    c99_mirror_emit_common(codegen);
    i = 0;
    while i < decl_count {
        const decl: &ASTNode = ast.program_decls[i];
        if decl != null && decl.type == ASTNodeType.AST_FN_DECL {
            if should_emit_top_level_function_decl(codegen, decl) == 0 {
                i = i + 1;
                continue;
            }
            // 跳过泛型函数模板，为单态化实例生成原型
            if is_generic_function_c99(decl) != 0 {
                const fn_name: &byte = decl.fn_decl_name;
                var j: i32 = 0;
                while j < codegen.mono_instance_count {
                    if codegen.mono_instances[j].generic_name != null &&
                        c99_mono_fn_name_matches_decl(codegen, codegen.mono_instances[j].generic_name, decl) != 0 &&
                        codegen.mono_instances[j].is_function != 0 &&
                        codegen.reachable_mono_instances[j] != 0 &&
                        has_unresolved_mono_type_args(decl, codegen.mono_instances[j].type_args, codegen.mono_instances[j].type_arg_count) == 0 {
                        gen_mono_function_prototype(codegen, decl,
                            codegen.mono_instances[j].type_args,
                            codegen.mono_instances[j].type_arg_count);
                    }
                    j = j + 1;
                }
            } else {
                gen_function_prototype(codegen, decl);
            }
        } else if decl != null && decl.type == ASTNodeType.AST_METHOD_BLOCK {
            var type_name: &byte = null;
            if decl.method_block_struct_name != null {
                type_name = decl.method_block_struct_name;
            } else {
                type_name = decl.method_block_union_name;
            }
            if type_name != null {
                var j: i32 = 0;
                while j < decl.method_block_method_count {
                    const m: &ASTNode = decl.method_block_methods[j];
                    if m != null && m.type == ASTNodeType.AST_FN_DECL {
                        // 检查是否是泛型方法
                        if m.fn_decl_type_param_count > 0 {
                            // 泛型方法：为每个单态化实例生成原型
                            var k: i32 = 0;
                            while k < codegen.mono_instance_count {
                                if codegen.mono_instances[k].generic_name != null && codegen.mono_instances[k].is_function != 0 {
                                    // 检查单态化实例名称是否匹配 "TypeName_method_name" 格式
                                    var expected_prefix: [byte: NAME_BUF_SIZE] = [];
                                    var prefix_len: i32 = snprintf(&expected_prefix[0] as *byte, NAME_BUF_SIZE, "%s_%s_" as *byte, type_name as *byte, m.fn_decl_name as *byte);
                                    
                                    const gn: &byte = codegen.mono_instances[k].generic_name;
                                    if gn != null && strncmp(gn as *byte, &expected_prefix[0] as *byte, prefix_len) == 0 {
                                        gen_mono_method_prototype(codegen, m, type_name,
                                            codegen.mono_instances[k].type_args,
                                            codegen.mono_instances[k].type_arg_count);
                                    }
                                }
                                k = k + 1;
                            }
                        } else {
                            // 非泛型方法
                            gen_method_prototype(codegen, m, type_name);
                        }
                    }
                    j = j + 1;
                }
            }
        } else if decl != null && decl.type == ASTNodeType.AST_STRUCT_DECL {
            // 生成结构体内部定义的方法的前向声明
            const struct_name: &byte = decl.struct_decl_name;
            // 跳过泛型结构体模板的内部方法，为单态化实例生成方法原型
            if is_generic_struct_c99(decl) != 0 {
                var k: i32 = 0;
                while k < codegen.mono_instance_count {
                    if codegen.mono_instances[k].generic_name != null &&
                        strcmp(codegen.mono_instances[k].generic_name as *byte, struct_name as *byte) == 0 &&
                        codegen.mono_instances[k].is_function == 0 {
                        // 跳过包含未解析类型参数的实例
                        if has_unresolved_mono_type_args(decl,
                            codegen.mono_instances[k].type_args,
                            codegen.mono_instances[k].type_arg_count) == 0 {
                            // 为该单态化实例生成方法原型
                            const mono_name: &byte = get_mono_struct_name(codegen, struct_name,
                                codegen.mono_instances[k].type_args,
                                codegen.mono_instances[k].type_arg_count);
                            // 设置结构体的类型参数上下文（用于二级查找）
                            const saved_stp: &TypeParam = codegen.struct_type_params;
                            const saved_stpc: i32 = codegen.struct_type_param_count;
                            const saved_sta: & & ASTNode = codegen.struct_type_args;
                            const saved_stac: i32 = codegen.struct_type_arg_count;
                            codegen.struct_type_params = decl.struct_decl_type_params;
                            codegen.struct_type_param_count = decl.struct_decl_type_param_count;
                            codegen.struct_type_args = codegen.mono_instances[k].type_args;
                            codegen.struct_type_arg_count = codegen.mono_instances[k].type_arg_count;
                            
                            var j: i32 = 0;
                            while j < decl.struct_decl_method_count {
                                const m: &ASTNode = decl.struct_decl_methods[j];
                                if m != null && m.type == ASTNodeType.AST_FN_DECL {
                                    // 跳过泛型方法（它们通过方法单态化机制处理）
                                    if m.fn_decl_type_param_count > 0 {
                                        // 为泛型方法生成单态化原型
                                        var mi: i32 = 0;
                                        while mi < codegen.mono_instance_count {
                                            if codegen.mono_instances[mi].generic_name != null && codegen.mono_instances[mi].is_function != 0 {
                                                // 检查单态化实例名称是否匹配 "StructName_method_name" 格式
                                                var expected_prefix: [byte: NAME_BUF_SIZE] = [];
                                                var prefix_len: i32 = snprintf(&expected_prefix[0] as *byte, NAME_BUF_SIZE, "%s_%s_" as *byte, mono_name as *byte, m.fn_decl_name as *byte);
                                                
                                                const gn: &byte = codegen.mono_instances[mi].generic_name;
                                                if gn != null && strncmp(gn as *byte, &expected_prefix[0] as *byte, prefix_len) == 0 {
                                                    gen_mono_method_prototype(codegen, m, mono_name,
                                                        codegen.mono_instances[mi].type_args,
                                                        codegen.mono_instances[mi].type_arg_count);
                                                }
                                            }
                                            mi = mi + 1;
                                        }
                                    } else {
                                        gen_method_prototype(codegen, m, mono_name);
                                    }
                                }
                                j = j + 1;
                            }
                            
                            // 恢复结构体类型参数上下文
                            codegen.struct_type_params = saved_stp;
                            codegen.struct_type_param_count = saved_stpc;
                            codegen.struct_type_args = saved_sta;
                            codegen.struct_type_arg_count = saved_stac;
                        }
                    }
                    k = k + 1;
                }
            } else {
                // 非泛型结构体：需要处理内部定义的泛型方法单态化
                var j: i32 = 0;
                while j < decl.struct_decl_method_count {
                    const m: &ASTNode = decl.struct_decl_methods[j];
                    if m != null && m.type == ASTNodeType.AST_FN_DECL {
                        // 检查是否是泛型方法
                        if m.fn_decl_type_param_count > 0 {
                            // 泛型方法：为每个单态化实例生成原型
                            var expected_prefix: [byte: NAME_BUF_SIZE] = [];
                            const prefix_len: i32 = snprintf(&expected_prefix[0] as *byte, NAME_BUF_SIZE, "%s_%s_" as *byte, struct_name as *byte, m.fn_decl_name as *byte);
                            var k: i32 = 0;
                            while k < codegen.mono_instance_count {
                                if codegen.mono_instances[k].generic_name != null && codegen.mono_instances[k].is_function != 0 {
                                    // 检查单态化实例名称是否匹配 "StructName_method_name" 格式
                                    const gn: &byte = codegen.mono_instances[k].generic_name;
                                    if gn != null && strncmp(gn as *byte, &expected_prefix[0] as *byte, prefix_len) == 0 {
                                        gen_mono_method_prototype(codegen, m, struct_name,
                                            codegen.mono_instances[k].type_args,
                                            codegen.mono_instances[k].type_arg_count);
                                    }
                                }
                                k = k + 1;
                            }
                        } else {
                            gen_method_prototype(codegen, m, struct_name);
                        }
                    }
                    j = j + 1;
                }
            }
        } else if decl != null && decl.type == ASTNodeType.AST_UNION_DECL {
            // 生成联合体内部方法的前向声明
            const union_name: &byte = decl.union_decl_name;
            var j: i32 = 0;
            while j < decl.union_decl_method_count {
                const m: &ASTNode = decl.union_decl_methods[j];
                if m != null && m.type == ASTNodeType.AST_FN_DECL {
                    gen_method_prototype(codegen, m, union_name);
                }
                j = j + 1;
            }
        }
        i = i + 1;
    }
    
    if codegen.split_mirror != 0 && codegen.split_protos_out != null {
        fputs("\n#endif /* UYA_SPLIT_PROTOS_H */\n" as *byte, codegen.split_protos_out as *void);
        _ = fflush(codegen.split_protos_out as *void);
        _ = fclose(codegen.split_protos_out as *void);
        codegen.split_protos_out = null;
        if codegen.split_common_out != null {
            codegen.emit_stream = codegen.split_common_out;
        }
    }
    
    // 第八步 b：生成 vtable 常量（依赖方法前向声明）
    c99_mirror_emit_extern_const_fwd(codegen, ast);
    emit_vtable_constants(codegen);
    c99_emit_newline(codegen);
    
    // 第八步 c：生成测试函数前向声明
    if test_count > 0 {
        i = 0;
        while i < test_count {
            const test_node: &ASTNode = tests_array[i];
            if test_node != null && test_node.type == ASTNodeType.AST_TEST_STMT {
                const func_name: &byte = get_test_function_name(codegen, test_node.test_stmt_description);
                if func_name != null {
                    fprintf(codegen.emit_stream as *void, "static struct err_union_void %s(void);\n" as *byte, func_name as *byte);
                }
            }
            i = i + 1;
        }
        fputs("static void uya_run_tests(void);\n" as *byte, codegen.emit_stream as *void);
        c99_emit_newline(codegen);
        
        // 生成测试计数变量（必须在 uya_run_tests 定义之前）
        // 检查是否导入了 std.testing 模块（会定义 _test_passed 和 _test_failed）
        var has_std_testing: i32 = 0;
        i = 0;
        while i < decl_count {
            const decl: &ASTNode = ast.program_decls[i];
            if decl != null && decl.type == ASTNodeType.AST_USE_STMT {
                // 检查路径段是否是 std.testing
                const seg_count: i32 = decl.use_stmt_path_segment_count;
                const segs: &(&byte) = decl.use_stmt_path_segments;
                // std.testing 至少有 2 个路径段
                if seg_count >= 2 && segs != null {
                    const seg0: &byte = segs[0];
                    const seg1: &byte = segs[1];
                    if seg0 != null && seg1 != null && strcmp(seg0 as *byte, "std" as *byte) == 0 && strcmp(seg1 as *byte, "testing" as *byte) == 0 {
                        has_std_testing = 1;
                        break;
                    }
                }
            }
            i = i + 1;
        }
        
        // 如果没有导入 std.testing，需要定义测试计数变量
        if has_std_testing == 0 {
            fputs("static int32_t _test_passed = 0;\n" as *byte, codegen.emit_stream as *void);
            fputs("static int32_t _test_failed = 0;\n" as *byte, codegen.emit_stream as *void);
            fputs("static int32_t _test_case_passed = 0;\n" as *byte, codegen.emit_stream as *void);
            c99_emit_newline(codegen);
        }
        saved_has_std_testing = has_std_testing;
    }
    
    // 前向声明：stdin/stdout/stderr（单文件或非镜像分 TU）。镜像模式已在各镜像 .c 头中写入，避免仅落入 uya_common.c
    if codegen.split_mirror == 0 {
        fputs("extern struct FILE _stdin, _stdout, _stderr;\n" as *byte, codegen.emit_stream as *void);
    }
    
    // 第九步 a：先生成所有常量（确保在函数之前定义）
    i = 0;
    while i < decl_count {
        const decl: &ASTNode = ast.program_decls[i];
        if decl != null {
            c99_mirror_emit_for_node(codegen, decl);
            // 跳过 use 语句（模块导入，不需要生成代码）
            if decl.type == ASTNodeType.AST_USE_STMT {
                i = i + 1;
                continue;
            }
            // 跳过宏声明（宏在 checker 阶段已展开，不需要生成代码）
            if decl.type == ASTNodeType.AST_MACRO_DECL {
                i = i + 1;
                continue;
            }
            // 只生成常量（const 变量）
            if decl.type == ASTNodeType.AST_VAR_DECL && decl.var_decl_is_const != 0 {
                gen_global_var(codegen, decl);
                c99_emit_newline(codegen);
            }
            // 生成 extern 变量声明
            if decl.type == ASTNodeType.AST_EXTERN_VAR_DECL {
                gen_extern_var_decl(codegen, decl);
            }
        }
        i = i + 1;
    }
    
    // 第九步 b0：先生成非常量、非 export 的全局变量（保证被 export 变量初始器引用的符号先定义）
    i = 0;
    while i < decl_count {
        const decl: &ASTNode = ast.program_decls[i];
        if decl != null && decl.type == ASTNodeType.AST_VAR_DECL && decl.var_decl_is_const == 0 && decl.var_decl_is_export == 0 {
            c99_mirror_emit_for_node(codegen, decl);
            gen_global_var(codegen, decl);
            c99_emit_newline(codegen);
        }
        i = i + 1;
    }
    
    // 第九步 b：生成所有声明（export 非常量全局变量、函数定义）
    i = 0;
    while i < decl_count {
        const decl: &ASTNode = ast.program_decls[i];
        if decl != null {
            c99_mirror_emit_for_node(codegen, decl);
            // 跳过 use 语句（模块导入，不需要生成代码）
            if decl.type == ASTNodeType.AST_USE_STMT {
                i = i + 1;
                continue;
            }
            // 跳过宏声明（宏在 checker 阶段已展开，不需要生成代码）
            if decl.type == ASTNodeType.AST_MACRO_DECL {
                i = i + 1;
                continue;
            }
            if decl.type == ASTNodeType.AST_STRUCT_DECL {
                // 生成结构体内部定义的方法
                const struct_name: &byte = decl.struct_decl_name;
                // 跳过泛型结构体模板的内部方法，为单态化实例生成方法定义
                if is_generic_struct_c99(decl) != 0 {
                    var k: i32 = 0;
                    while k < codegen.mono_instance_count {
                        if codegen.mono_instances[k].generic_name != null &&
                            strcmp(codegen.mono_instances[k].generic_name as *byte, struct_name as *byte) == 0 &&
                            codegen.mono_instances[k].is_function == 0 {
                            // 跳过包含未解析类型参数的实例
                            if has_unresolved_mono_type_args(decl,
                                codegen.mono_instances[k].type_args,
                                codegen.mono_instances[k].type_arg_count) == 0 {
                                // 为该单态化实例生成方法定义
                                const mono_name: &byte = get_mono_struct_name(codegen, struct_name,
                                    codegen.mono_instances[k].type_args,
                                    codegen.mono_instances[k].type_arg_count);
                                // 设置结构体的类型参数上下文（用于二级查找）
                                const saved_stp: &TypeParam = codegen.struct_type_params;
                                const saved_stpc: i32 = codegen.struct_type_param_count;
                                const saved_sta: & & ASTNode = codegen.struct_type_args;
                                const saved_stac: i32 = codegen.struct_type_arg_count;
                                codegen.struct_type_params = decl.struct_decl_type_params;
                                codegen.struct_type_param_count = decl.struct_decl_type_param_count;
                                codegen.struct_type_args = codegen.mono_instances[k].type_args;
                                codegen.struct_type_arg_count = codegen.mono_instances[k].type_arg_count;
                                
                                var j: i32 = 0;
                                while j < decl.struct_decl_method_count {
                                    const m: &ASTNode = decl.struct_decl_methods[j];
                                    if m != null && m.type == ASTNodeType.AST_FN_DECL && m.fn_decl_body != null {
                                        c99_mirror_emit_for_node(codegen, m);
                                        // 跳过泛型方法（它们通过方法单态化机制处理）
                                        if m.fn_decl_type_param_count > 0 {
                                            // 预先计算 expected_prefix（在外层循环中只计算一次）
                                            var expected_prefix: [byte: NAME_BUF_SIZE] = [];
                                            var prefix_len: i32 = snprintf(&expected_prefix[0] as *byte, NAME_BUF_SIZE, "%s_%s_" as *byte, mono_name as *byte, m.fn_decl_name as *byte);
                                            // 为泛型方法生成单态化定义
                                            var mi: i32 = 0;
                                            while mi < codegen.mono_instance_count {
                                                if codegen.mono_instances[mi].generic_name != null && codegen.mono_instances[mi].is_function != 0 {
                                                    // 检查单态化实例名称是否匹配 "StructName_method_name" 格式
                                                    const gn: &byte = codegen.mono_instances[mi].generic_name;
                                                    if gn != null && strncmp(gn as *byte, &expected_prefix[0] as *byte, prefix_len) == 0 {
                                                        gen_mono_method_function(codegen, m, mono_name,
                                                            codegen.mono_instances[mi].type_args,
                                                            codegen.mono_instances[mi].type_arg_count);
                                                        c99_emit_newline(codegen);
                                                    }
                                                }
                                                mi = mi + 1;
                                            }
                                        } else {
                                            gen_method_function(codegen, m, mono_name);
                                            c99_emit_newline(codegen);
                                        }
                                    }
                                    j = j + 1;
                                }
                                
                                // 恢复结构体类型参数上下文
                                codegen.struct_type_params = saved_stp;
                                codegen.struct_type_param_count = saved_stpc;
                                codegen.struct_type_args = saved_sta;
                                codegen.struct_type_arg_count = saved_stac;
                            }
                        }
                        k = k + 1;
                    }
                } else {
                    // 非泛型结构体：需要处理内部定义的泛型方法单态化
                    var j: i32 = 0;
                    while j < decl.struct_decl_method_count {
                        const m: &ASTNode = decl.struct_decl_methods[j];
                        if m != null && m.type == ASTNodeType.AST_FN_DECL && m.fn_decl_body != null {
                            c99_mirror_emit_for_node(codegen, m);
                            // 检查是否是泛型方法
                            if m.fn_decl_type_param_count > 0 {
                                // 预先计算 expected_prefix（在外层循环中只计算一次）
                                var expected_prefix: [byte: NAME_BUF_SIZE] = [];
                                var prefix_len: i32 = snprintf(&expected_prefix[0] as *byte, NAME_BUF_SIZE, "%s_%s_" as *byte, struct_name as *byte, m.fn_decl_name as *byte);
                                // 泛型方法：为每个单态化实例生成定义
                                var k: i32 = 0;
                                while k < codegen.mono_instance_count {
                                    if codegen.mono_instances[k].generic_name != null && codegen.mono_instances[k].is_function != 0 {
                                        // 检查单态化实例名称是否匹配 "StructName_method_name" 格式
                                        const gn: &byte = codegen.mono_instances[k].generic_name;
                                        if gn != null && strncmp(gn as *byte, &expected_prefix[0] as *byte, prefix_len) == 0 {
                                            gen_mono_method_function(codegen, m, struct_name,
                                                codegen.mono_instances[k].type_args,
                                                codegen.mono_instances[k].type_arg_count);
                                            c99_emit_newline(codegen);
                                        }
                                    }
                                    k = k + 1;
                                }
                            } else {
                                gen_method_function(codegen, m, struct_name);
                                c99_emit_newline(codegen);
                            }
                        }
                        j = j + 1;
                    }
                }
            } else if decl.type == ASTNodeType.AST_UNION_DECL {
                // 生成联合体内部方法定义
                const union_name: &byte = decl.union_decl_name;
                var j: i32 = 0;
                while j < decl.union_decl_method_count {
                    const m: &ASTNode = decl.union_decl_methods[j];
                    if m != null && m.type == ASTNodeType.AST_FN_DECL && m.fn_decl_body != null {
                        c99_mirror_emit_for_node(codegen, m);
                        gen_method_function(codegen, m, union_name);
                        c99_emit_newline(codegen);
                    }
                    j = j + 1;
                }
            } else if decl.type == ASTNodeType.AST_ENUM_DECL {
                // 已在前面生成
            } else if decl.type == ASTNodeType.AST_VAR_DECL {
                // 常量已在第九步 a 生成；非常量非 export 已在第九步 b0 生成，这里只生成 export 非常量变量
                if decl.var_decl_is_const == 0 && decl.var_decl_is_export != 0 {
                    gen_global_var(codegen, decl);
                    c99_emit_newline(codegen);
                }
            } else if decl.type == ASTNodeType.AST_EXTERN_VAR_DECL {
                // extern 变量已在第九步 a 生成声明，这里不重复生成
            } else if decl.type == ASTNodeType.AST_FN_DECL {
                // 特殊处理：main 函数在后面生成（需要添加测试运行器调用）
                const func_name: &byte = decl.fn_decl_name;
                var is_main: i32 = 0;
                if func_name != null && strcmp(func_name as *byte, "main" as *byte) == 0 {
                    is_main = 1;
                }
                if is_main == 0 {
                    if should_emit_top_level_function_decl(codegen, decl) == 0 {
                        i = i + 1;
                        continue;
                    }
                    // 跳过泛型函数模板，为单态化实例生成定义（跳过未解析类型参数如 T、void）
                    if is_generic_function_c99(decl) != 0 {
                        var j: i32 = 0;
                        while j < codegen.mono_instance_count {
                            if codegen.mono_instances[j].generic_name != null &&
                                c99_mono_fn_name_matches_decl(codegen, codegen.mono_instances[j].generic_name, decl) != 0 &&
                                codegen.mono_instances[j].is_function != 0 &&
                                codegen.reachable_mono_instances[j] != 0 &&
                                has_unresolved_mono_type_args(decl, codegen.mono_instances[j].type_args, codegen.mono_instances[j].type_arg_count) == 0 {
                                gen_mono_function(codegen, decl,
                                    codegen.mono_instances[j].type_args,
                                    codegen.mono_instances[j].type_arg_count);
                                c99_emit_newline(codegen);
                            }
                            j = j + 1;
                        }
                    } else {
                        // 只生成有函数体的定义（外部函数由前向声明处理）
                        gen_function(codegen, decl);
                        c99_emit_newline(codegen);
                    }
                }
            } else if decl.type == ASTNodeType.AST_METHOD_BLOCK {
                var type_name: &byte = null;
                if decl.method_block_struct_name != null {
                    type_name = decl.method_block_struct_name;
                } else {
                    type_name = decl.method_block_union_name;
                }
                if type_name != null {
                    var j: i32 = 0;
                    while j < decl.method_block_method_count {
                        const m: &ASTNode = decl.method_block_methods[j];
                        if m != null && m.type == ASTNodeType.AST_FN_DECL && m.fn_decl_body != null {
                            c99_mirror_emit_for_node(codegen, m);
                            // 检查是否是泛型方法
                            if m.fn_decl_type_param_count > 0 {
                                // 泛型方法：为每个单态化实例生成代码
                                var k: i32 = 0;
                                while k < codegen.mono_instance_count {
                                    if codegen.mono_instances[k].generic_name != null && codegen.mono_instances[k].is_function != 0 {
                                        // 检查单态化实例名称是否匹配 "TypeName_method_name" 格式
                                        var expected_prefix: [byte: NAME_BUF_SIZE] = [];
                                        var prefix_len: i32 = snprintf(&expected_prefix[0] as *byte, NAME_BUF_SIZE, "%s_%s_" as *byte, type_name as *byte, m.fn_decl_name as *byte);
                                        
                                        // 检查 generic_name 是否以 expected_prefix 开头
                                        const gn: &byte = codegen.mono_instances[k].generic_name;
                                        if gn != null && strncmp(gn as *byte, &expected_prefix[0] as *byte, prefix_len) == 0 {
                                            // 找到匹配的单态化实例，生成方法代码
                                            gen_mono_method_function(codegen, m, type_name,
                                                codegen.mono_instances[k].type_args,
                                                codegen.mono_instances[k].type_arg_count);
                                            c99_emit_newline(codegen);
                                        }
                                    }
                                    k = k + 1;
                                }
                            } else {
                                // 非泛型方法
                                gen_method_function(codegen, m, type_name);
                                c99_emit_newline(codegen);
                            }
                        }
                        j = j + 1;
                    }
                }
            } else {
                // 忽略其他声明类型（暂时）
            }
        }
        i = i + 1;
    }
    
    // 第十步：生成测试函数和运行器（镜像模式下全部在 uya_common.c，以便 static 测试函数与运行器同 TU）
    if test_count > 0 {
        c99_mirror_emit_common(codegen);
        if codegen.split_mirror != 0 && saved_has_std_testing != 0 {
            fputs("extern int32_t _test_passed;\n" as *byte, codegen.emit_stream as *void);
            fputs("extern int32_t _test_failed;\n" as *byte, codegen.emit_stream as *void);
            fputs("extern int32_t _test_case_passed;\n" as *byte, codegen.emit_stream as *void);
            c99_emit_newline(codegen);
        }
        i = 0;
        while i < test_count {
            gen_test_function(codegen, tests_array[i]);
            c99_emit_newline(codegen);
            i = i + 1;
        }
        gen_test_runner(codegen, tests_array, test_count);
        c99_emit_newline(codegen);
    }
    
    // 第十一步：生成 main 函数（uya_main）
    // 如果没有用户 main 函数但有 test 语句，生成 main_main 调用测试运行器
    // 注意：has_main 只计算用户提供的 main（非 export extern），不包括 std.runtime.entry 的 C main
    var has_user_main: i32 = 0;  // 跟踪是否找到用户 main 函数
    i = 0;
    while i < decl_count {
        const decl: &ASTNode = ast.program_decls[i];
        if decl != null && decl.type == ASTNodeType.AST_FN_DECL {
            const func_name: &byte = decl.fn_decl_name;
            if func_name != null && strcmp(func_name as *byte, "main" as *byte) == 0 && decl.fn_decl_body != null {
                const is_export: i32 = decl.fn_decl_is_export;
                const is_extern_keyword: i32 = decl.fn_decl_is_extern;  // extern 关键字（含 export extern fn main）
                var is_c_main: i32 = 0;
                if is_export != 0 && is_extern_keyword != 0 {
                    is_c_main = 1;
                }
                var is_app_main: i32 = 0;
                if is_export != 0 && is_extern_keyword == 0 {
                    is_app_main = 1;
                }
                // 只有用户 main 才计入 has_user_main（排除 C main）
                if is_c_main == 0 {
                    has_user_main = 1;
                }
                c99_mirror_emit_for_node(codegen, decl);
                emit_line_directive(codegen, decl.line, decl.filename);
                var return_c: &byte = convert_array_return_type(codegen, decl.fn_decl_return_type);
                return_c = normalize_poll_return_type(codegen, return_c);
                var main_c_name: &byte = "uya_main" as *byte;
                if is_app_main != 0 {
                    main_c_name = "main_main" as *byte;
                } else if is_c_main == 0 {
                    main_c_name = "uya_main" as *byte;
                }
                if is_c_main != 0 {
                    fprintf(codegen.emit_stream as *void, "%s main(" as *byte, return_c as *byte);
                    var pj: i32 = 0;
                    const pcount: i32 = decl.fn_decl_param_count;
                    while pj < pcount {
                        const p: &ASTNode = decl.fn_decl_params[pj];
                        if p != null && p.type == ASTNodeType.AST_VAR_DECL {
                            const pname: &byte = get_safe_c_identifier(codegen, p.var_decl_name);
                            if pj == 1 {
                                if codegen.is_nostdlib != 0 {
                                    fprintf(codegen.emit_stream as *void, "uint8_t **%s" as *byte, pname as *byte);
                                } else {
                                    fprintf(codegen.emit_stream as *void, "char **%s" as *byte, pname as *byte);
                                }
                            } else {
                                const ptype: &ASTNode = p.var_decl_type;
                                const ptype_c: &byte = c99_type_to_c(codegen, ptype);
                                format_param_type(codegen, ptype_c, pname, codegen.emit_stream as *void);
                            }
                            if pj < pcount - 1 {
                                fputs(", " as *byte, codegen.emit_stream as *void);
                            }
                        }
                        pj = pj + 1;
                    }
                    fputs(") {\n" as *byte, codegen.emit_stream as *void);
                } else {
                    fprintf(codegen.emit_stream as *void, "%s %s(void) {\n" as *byte, return_c as *byte, main_c_name as *byte);
                }

                // 保存并设置当前函数的返回类型
                const saved_return_type: &ASTNode = codegen.current_function_return_type;
                codegen.current_function_return_type = decl.fn_decl_return_type;

                // 如果有测试，在函数体开始处调用测试运行器（仅 uya_main）
                if test_count > 0 && is_app_main == 0 && is_c_main == 0 {
                    fputs("    uya_run_tests();\n" as *byte, codegen.emit_stream as *void);
                }

                // 生成函数体（使用 gen_stmt 触发 gen_block_stmt 的完整逻辑，包括 defer 和 drop 清理）
                const body: &ASTNode = decl.fn_decl_body;
                if body != null {
                    codegen.indent_level = codegen.indent_level + 1;
                    gen_stmt(codegen, body);
                    codegen.indent_level = codegen.indent_level - 1;
                }
                
                // 恢复之前的返回类型
                codegen.current_function_return_type = saved_return_type;
                
                c99_emit_close_brace_newline(codegen);
            }
        }
        i = i + 1;
    }
    
    // 如果没有用户 main 函数但有 test 语句，生成 main_main 调用测试运行器
    // std.runtime.entry 的 main 会调用 main_main()
    if has_user_main == 0 && test_count > 0 {
        c99_mirror_emit_common(codegen);
        // 测试计数变量已在第八步 c 中定义
        fputs("int32_t main_main(void) {\n" as *byte, codegen.emit_stream as *void);
        fprintf(codegen.emit_stream as *void, "    printf(\"\\n=== Running %d tests ===\\n\");\n" as *byte, test_count);
        fputs("    uya_run_tests();\n" as *byte, codegen.emit_stream as *void);
        fputs("    printf(\"\\n=== Results ===\\n\");\n" as *byte, codegen.emit_stream as *void);
        if codegen.is_nostdlib != 0 {
            fputs("    printf(\"  Tests Passed:       \");\n" as *byte, codegen.emit_stream as *void);
            fputs("    uya_print_i32(_test_case_passed);\n" as *byte, codegen.emit_stream as *void);
            fputs("    printf(\"\\n\");\n" as *byte, codegen.emit_stream as *void);
            fputs("    printf(\"  Tests Failed:       \");\n" as *byte, codegen.emit_stream as *void);
            fputs("    uya_print_i32(_test_failed);\n" as *byte, codegen.emit_stream as *void);
            fputs("    printf(\"\\n\");\n" as *byte, codegen.emit_stream as *void);
            fputs("    printf(\"  Assertions Passed:  \");\n" as *byte, codegen.emit_stream as *void);
            fputs("    uya_print_i32(_test_passed);\n" as *byte, codegen.emit_stream as *void);
            fputs("    printf(\"\\n\");\n" as *byte, codegen.emit_stream as *void);
        } else {
            fputs("    printf(\"  Tests Passed:       %d\\n\", _test_case_passed);\n" as *byte, codegen.emit_stream as *void);
            fputs("    printf(\"  Tests Failed:       %d\\n\", _test_failed);\n" as *byte, codegen.emit_stream as *void);
            fputs("    printf(\"  Assertions Passed:  %d\\n\", _test_passed);\n" as *byte, codegen.emit_stream as *void);
        }
        fputs("    return _test_failed;\n" as *byte, codegen.emit_stream as *void);
        c99_emit_close_brace_newline(codegen);
    }
    
    // 输出宏展开等阶段才加入的字符串常量（如 encode_to_to_json 中的 "id"/"name"）
    emit_pending_string_constants(codegen);
    
    if prof_codegen != 0 {
        const t1: clock_t = clock();
        const total_ms: i64 = ((t1 as i64) - (prof_t0 as i64)) * 1000 / (CLOCKS_PER_SEC as i64);
        var body_ms: i64 = total_ms - prof_ms_prelude;
        if body_ms < 0 {
            body_ms = 0;
        }
        fprintf(libc.stderr, "[UYA_PROFILE_CODEGEN] simd_ms=%ld precollect_ms=%ld header_ms=%ld step1_typedef_ms=%ld step6_mid_ms=%ld step6e_tail_ms=%ld prelude_ms=%ld body_ms=%ld total_ms=%ld\n" as *byte,
            prof_simd_ms, prof_ms_precollect, prof_ms_header, prof_ms_step1_typedef, prof_ms_step6_mid, prof_ms_step6e_tail, prof_ms_prelude, body_ms, total_ms);
    }
    
    c99_split_finish_part2_externs(codegen);
    c99_write_mirror_manifest(codegen, ast);
    c99_write_split_makefile(codegen);
    return 0;
}
