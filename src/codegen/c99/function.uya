// function.uya - C99 代码生成器函数模块
// 提供函数声明和定义生成功能
//
// 注意：需要先包含 internal.uya（包含类型定义和函数声明）
// 由于 Uya Mini 不支持模块系统，这里假设相关类型已经定义

// ===== 外部函数声明 =====
// C 标准库函数（在 extern_decls.uya 中声明）

// 查找函数声明
fn find_function_decl_c99(codegen: &C99CodeGenerator, func_name: &byte) &ASTNode {
    if codegen == null || func_name == null || codegen.program_node == null {
        return null;
    }
    
    const decl_count: i32 = codegen.program_node.program_decl_count;
    
    var i: i32 = 0;
    while i < decl_count {
        const decl: &ASTNode = codegen.program_node.program_decls[i];
        if decl != null && decl.type == ASTNodeType.AST_FN_DECL {
            const decl_name: &byte = decl.fn_decl_name;
            if decl_name != null && strcmp(decl_name as *byte, func_name as *byte) == 0 {
                return decl;
            }
        }
        i = i + 1;
    }
    
    return null;
}

// 检查函数是否是 extern "libc" fn（用于决定字符串参数类型）
fn is_extern_libc_function(codegen: &C99CodeGenerator, func_name: &byte) i32 {
    if codegen == null || func_name == null {
        return 0;
    }
    const fn_decl: &ASTNode = find_function_decl_c99(codegen, func_name);
    if fn_decl != null && fn_decl.type == ASTNodeType.AST_FN_DECL {
        if fn_decl.fn_decl_extern_lib_name != null {
            return 1;
        }
    }
    return 0;
}

// 从文件名提取模块前缀（lib/libc/ -> libc_, lib/std/io/ -> std_io_）
fn get_module_prefix_from_filename(codegen: &C99CodeGenerator, filename: &byte) &byte {
    if codegen == null || filename == null || codegen.arena == null {
        return ("" as *byte) as &byte;
    }
    if strstr(filename as *byte, "/lib/libc/" as *byte) != null || strstr(filename as *byte, "lib/libc/" as *byte) != null {
        return ("libc_" as *byte) as &byte;
    }
    var lib_std: *byte = strstr(filename as *byte, "/lib/std/" as *byte);
    if lib_std == null {
        lib_std = strstr(filename as *byte, "lib/std/" as *byte);
    }
    if lib_std != null {
        var rel: &byte = lib_std as &byte;
        if rel[0] == 47 { rel = &rel[1]; }
        if strncmp(rel as *byte, "lib/std/" as *byte, 8) == 0 {
            rel = &rel[8];
        }
        const rel_len: usize = strlen(rel as *byte);
        var base_len: usize = rel_len;
        if rel_len > 4 && strcmp((rel as *byte + (rel_len - 4)) as *byte, ".uya" as *byte) == 0 {
            base_len = rel_len - 4;
        }
        var si: usize = base_len;
        var last_slash: &byte = null;
        while si > 0 {
            si = si - 1;
            if rel[si] == 47 || rel[si] == 92 {
                last_slash = &rel[si];
                break;
            }
        }
        if last_slash != null {
            const slash_pos: usize = ptr_diff(last_slash as *byte, rel as *byte) as usize;
            const total_len: usize = 4 + slash_pos + 2;
            const prefix: &byte = arena_alloc(codegen.arena, total_len) as &byte;
            if prefix != null {
                strcpy(prefix as *byte, "std_" as *byte);
                memcpy((prefix as *byte + 4) as *void, rel as *void, slash_pos);
                prefix[4 + slash_pos] = 95 as byte;
                prefix[4 + slash_pos + 1] = 0 as byte;
                var idx: usize = 4;
                while idx < 4 + slash_pos {
                    if prefix[idx] == 47 || prefix[idx] == 92 {
                        prefix[idx] = 95 as byte;
                    }
                    idx = idx + 1;
                }
                return prefix;
            }
        }
        return ("std_" as *byte) as &byte;
    }
    // 检查是否是 src/ 文件（应用程序主文件）
    var src_path: *byte = strstr(filename as *byte, "/src/" as *byte);
    if src_path == null {
        src_path = strstr(filename as *byte, "src/" as *byte);
    }
    if src_path == null {
        src_path = strstr(filename as *byte, "\\src\\" as *byte);
    }
    if src_path != null {
        var rel: &byte = src_path as &byte;
        if rel[0] == 47 { rel = &rel[1]; }
        if strncmp(rel as *byte, "src/" as *byte, 4) == 0 {
            rel = &rel[4];
        } else if strncmp(rel as *byte, "src\\" as *byte, 4) == 0 {
            rel = &rel[4];
        }
        const rel_len: usize = strlen(rel as *byte);
        var base_len: usize = rel_len;
        if rel_len > 4 && strcmp((rel as *byte + (rel_len - 4)) as *byte, ".uya" as *byte) == 0 {
            base_len = rel_len - 4;
        }
        const prefix: &byte = arena_alloc(codegen.arena, base_len + 2) as &byte;
        if prefix != null {
            memcpy(prefix as *void, rel as *void, base_len);
            prefix[base_len] = 95 as byte;
            prefix[base_len + 1] = 0 as byte;
            // 将路径分隔符 / 和 \ 替换为 _
            var idx: i32 = 0;
            while idx < base_len as i32 {
                if prefix[idx] == 47 || prefix[idx] == 92 {  // '/' or '\'
                    prefix[idx] = 95 as byte;  // '_'
                }
                idx = idx + 1;
            }
            return prefix;
        }
    }
    return ("" as *byte) as &byte;
}

fn get_export_function_c_name(codegen: &C99CodeGenerator, name: &byte, filename: &byte) &byte {
    if name == null {
        return get_safe_c_identifier(codegen, (" " as *byte) as &byte);
    }
    const prefix: &byte = get_module_prefix_from_filename(codegen, filename);
    if prefix == null || prefix[0] == 0 {
        return get_safe_c_identifier(codegen, name);
    }
    const safe_name: &byte = get_safe_c_identifier(codegen, name);
    const prefix_len: usize = strlen(prefix as *byte);
    const name_len: usize = strlen(safe_name as *byte);
    const result: &byte = arena_alloc(codegen.arena, prefix_len + name_len + 1) as &byte;
    if result == null {
        return safe_name;
    }
    strcpy(result as *byte, prefix as *byte);
    strcpy((result as *byte + prefix_len) as *byte, safe_name as *byte);
    return result;
}

// 全局函数在 C 中的名称（export 函数带模块前缀，但 extern "libc" fn 除外）
fn get_c_name_for_global_function(codegen: &C99CodeGenerator, name: &byte, for_definition: i32) &byte {
    if name == null {
        return get_safe_c_identifier(codegen, (" " as *byte) as &byte);
    }
    if for_definition == 0 && codegen != null && codegen.program_node != null && codegen.program_node.type == ASTNodeType.AST_PROGRAM {
        var di: i32 = 0;
        while di < codegen.program_node.program_decl_count {
            const d: &ASTNode = codegen.program_node.program_decls[di];
            if d != null && d.type == ASTNodeType.AST_FN_DECL && d.fn_decl_name != null &&
               strcmp(d.fn_decl_name as *byte, name as *byte) == 0 &&
               d.fn_decl_is_export != 0 && d.filename != null {
                // extern "libc" fn 不添加模块前缀
                if d.fn_decl_extern_lib_name != null {
                    return get_safe_c_identifier(codegen, name);
                }
                return get_export_function_c_name(codegen, name, d.filename);
            }
            di = di + 1;
        }
    }
    return get_safe_c_identifier(codegen, name);
}

// 全局常量在 C 中的名称（lib/libc/ 和 lib/syscall/ 下的 export 变量加模块前缀）
fn get_c_name_for_global_constant(codegen: &C99CodeGenerator, name: &byte, filename: &byte, is_export: i32) &byte {
    if name == null {
        return get_safe_c_identifier(codegen, (" " as *byte) as &byte);
    }
    // 仅对 lib/libc/ 和 lib/syscall/ 下的 export 变量添加模块前缀
    // 但排除 stderr/stdin/stdout，因为它们需要链接到系统 libc
    if filename != null && is_export != 0 {
        const is_std_stream: i32 = (strcmp(name as *byte, "stderr" as *byte) == 0) ||
                                   (strcmp(name as *byte, "stdin" as *byte) == 0) ||
                                   (strcmp(name as *byte, "stdout" as *byte) == 0);
        if is_std_stream == 0 {
            const prefix: &byte = get_module_prefix_from_filename(codegen, filename);
            if prefix != null && prefix[0] != 0 {
                const safe_name: &byte = get_safe_c_identifier(codegen, name);
                const prefix_len: usize = strlen(prefix as *byte);
                const name_len: usize = strlen(safe_name as *byte);
                const result: &byte = arena_alloc(codegen.arena, prefix_len + name_len + 1) as &byte;
                if result != null {
                    strcpy(result as *byte, prefix as *byte);
                    strcpy((result as *byte + prefix_len) as *byte, safe_name as *byte);
                    return result;
                }
            }
        }
    }
    return get_safe_c_identifier(codegen, name);
}

fn format_param_type(codegen: &C99CodeGenerator, type_c: &byte, param_name: &byte, output: &void) void {
    // codegen 参数未使用，但保留以保持接口一致性
    if type_c == null || param_name == null {
        return;
    }
    
    // 特殊处理：如果是 copy_type 函数的第一个参数且类型是 "struct Type *" 或 "const struct Type *"，则改为 "const struct Type *"
    // 检查当前函数名是否为 copy_type（通过 codegen.current_function_decl）
    var is_copy_type_param: i32 = 0;
    if codegen != null && codegen.current_function_decl != null {
        const fn_name: &byte = codegen.current_function_decl.fn_decl_name;
        if fn_name != null && strcmp(fn_name as *byte, "copy_type" as *byte) == 0 {
            // 检查参数类型是否为 "struct Type *" 或已经是 "const struct Type *"
            if strcmp(type_c as *byte, "struct Type *" as *byte) == 0 {
                is_copy_type_param = 1;
            } else if strcmp(type_c as *byte, "const struct Type *" as *byte) == 0 {
                is_copy_type_param = 1;
            }
        }
    }
    
    // 检查是否是指向数组的指针（包含 "(*)" 和 "[数字]"）
    // 例如：uint8_t (*)[4096] -> uint8_t (*param_name)[4096]
    const paren_star: *byte = strstr(type_c as *byte, "(*)" as *byte);
    if paren_star != null {
        // 是指向数组的指针，需要将 param_name 插入到 (*) 中
        const before_paren: i32 = ptr_diff(paren_star, type_c as *byte);
        const after_paren: *byte = paren_star + 3;  // 跳过 "(*)"
        // 输出：base_type (*param_name)[dims]
        var temp_buf: [byte: TEMP_BUF_SIZE] = [];
        var i: i32 = 0;
        while i < before_paren && i < TEMP_BUF_LIMIT {
            temp_buf[i] = type_c[i];
            i = i + 1;
        }
        if i >= 0 && i < TEMP_BUF_SIZE {
            temp_buf[i] = 0;
        }
        fprintf(output, "%s (*%s)%s" as *byte, &temp_buf[0] as *byte, param_name as *byte, after_paren);
    } else {
        // 检查是否是数组类型（包含 [数字]）
        const bracket: *byte = strchr(type_c as *byte, 91);  // '['
        if bracket != null {
            // 提取元素类型（bracket之前的部分）
            const str_len: i32 = ptr_diff(bracket, type_c as *byte);
            // 注意：Uya Mini 不支持 %.*s，需要手动处理
            // 简化处理：使用临时缓冲区
            var temp_buf: [byte: TEMP_BUF_SIZE] = [];
            var i: i32 = 0;
            while i < str_len && i < TEMP_BUF_LIMIT {
                temp_buf[i] = type_c[i];
                i = i + 1;
            }
            if i >= 0 && i < TEMP_BUF_SIZE {
                temp_buf[i] = 0;
            }
            fprintf(output, "%s %s%s" as *byte, &temp_buf[0] as *byte, param_name as *byte, bracket);
        } else {
            // 非数组类型
            // 检查是否是指针类型（包含 '*'）
            // 如果是指针类型，格式应该是 "type * name"（* 紧跟在类型后面）
            // c99_type_to_c 已经返回了正确的格式（如 "struct Type *"），所以直接输出即可
            // 特殊处理 copy_type 函数：将 "struct Type *" 改为 "const struct Type *"
            if is_copy_type_param != 0 {
                fprintf(output, "const struct Type * %s" as *byte, param_name as *byte);
            } else {
                fprintf(output, "%s %s" as *byte, type_c as *byte, param_name as *byte);
            }
        }
    }
}

// 生成函数原型（前向声明）
// 注意：此函数在 main.uya 中被调用，但由于 function.uya 在 main.uya 之前编译，函数已经可见
fn gen_function_prototype(codegen: &C99CodeGenerator, fn_decl: &ASTNode) void {
    if fn_decl == null || fn_decl.type != ASTNodeType.AST_FN_DECL {
        return;
    }
    
    // 设置当前函数声明（用于 format_param_type 中的 copy_type 检查）
    const saved_current_function_decl: &ASTNode = codegen.current_function_decl;
    codegen.current_function_decl = fn_decl;
    
    const extern_lib_name: &byte = fn_decl.fn_decl_extern_lib_name;  // extern "libc" fn 的库名
    
    // extern "libc" fn 不添加模块前缀，直接使用原始函数名
    var func_name: &byte = get_c_name_for_global_function(codegen, fn_decl.fn_decl_name, 1);
    if fn_decl.fn_decl_is_export != 0 && fn_decl.filename != null && extern_lib_name == null {
        func_name = get_export_function_c_name(codegen, fn_decl.fn_decl_name, fn_decl.filename);
    }
    const return_type: &ASTNode = fn_decl.fn_decl_return_type;
    const param_count: i32 = fn_decl.fn_decl_param_count;
    const is_varargs: i32 = fn_decl.fn_decl_is_varargs;
    const body: &ASTNode = fn_decl.fn_decl_body;
    
    // 检查是否为extern函数（body为NULL表示extern函数）
    var is_extern: i32 = 0;
    if body == null && extern_lib_name == null {
        // 只有当没有 extern_lib_name 时才标记为 is_extern
        // extern "libc" fn 带函数体时，is_extern 应该为 0
        is_extern = 1;
    }
    
    // extern "libc" fn 无函数体：不生成声明，链接到系统 libc
    if extern_lib_name != null && body == null {
        return;
    }
    
    // 返回类型（如果是数组类型，转换为指针类型）
    var return_c: &byte = convert_array_return_type(codegen, return_type);
    return_c = normalize_poll_return_type(codegen, return_c);

    // 特殊处理：main 函数需要重命名为 uya_main（符合 Uya 规范：main 函数无参数）
    // 注意：Uya Mini 不支持三元运算符，使用 if-else 代替
    var is_main: i32 = 0;
    if fn_decl.fn_decl_name != null && strcmp(fn_decl.fn_decl_name as *byte, "main" as *byte) == 0 {
        is_main = 1;
    }

    // 检查是否为标准 C main 函数（export extern fn main）
    var is_c_main: i32 = 0;
    if is_main != 0 && fn_decl.fn_decl_is_export != 0 && fn_decl.fn_decl_is_extern != 0 && extern_lib_name == null {
        is_c_main = 1;
    }

    // export extern fn main：生成裸名 main 的前向声明，不带模块前缀
    if is_c_main != 0 {
        var j: i32 = 0;
        fprintf(codegen.output, "extern %s main(" as *byte, return_c as *byte);
        while j < param_count {
            const param: &ASTNode = fn_decl.fn_decl_params[j];
            if param != null && param.type == ASTNodeType.AST_VAR_DECL {
                const param_name: &byte = get_safe_c_identifier(codegen, param.var_decl_name);
                const param_type: &ASTNode = param.var_decl_type;
                const param_type_c: &byte = c99_type_to_c(codegen, param_type);
                format_param_type(codegen, param_type_c, param_name, codegen.output as *void);
                if j < param_count - 1 {
                    fputs(", " as *byte, codegen.output);
                }
            }
            j = j + 1;
        }
        fputs(");\n" as *byte, codegen.output);
        codegen.current_function_decl = saved_current_function_decl;
        return;
    }

    // 仅 fn main（非 export）提前返回生成 uya_main(void)；export fn main 走通用路径生成 main_main()
    if is_main != 0 && is_c_main == 0 && fn_decl.fn_decl_is_export == 0 {
        fprintf(codegen.output, "%s uya_main(void);\n" as *byte, return_c as *byte);
        return;
    }
    
    // 读取 is_export 标志；若有同名 extern 声明则不能加 static
    const is_export: i32 = fn_decl.fn_decl_is_export;
    var has_extern_same: i32 = 0;
    if is_extern == 0 && fn_decl.fn_decl_name != null && codegen.program_node != null && codegen.program_node.type == ASTNodeType.AST_PROGRAM {
        var di: i32 = 0;
        while di < codegen.program_node.program_decl_count {
            const d: &ASTNode = codegen.program_node.program_decls[di];
            if d != null && d.type == ASTNodeType.AST_FN_DECL && d.fn_decl_name != null &&
               strcmp(d.fn_decl_name as *byte, fn_decl.fn_decl_name as *byte) == 0 && d.fn_decl_body == null {
                has_extern_same = 1;
                break;
            }
            di = di + 1;
        }
    }
    // 若程序中已有同名函数定义（如 libc 实现），跳过 extern 声明，避免与 GCC built-in 冲突
    if is_extern != 0 && fn_decl.fn_decl_name != null && codegen.program_node != null && codegen.program_node.type == ASTNodeType.AST_PROGRAM {
        var di: i32 = 0;
        while di < codegen.program_node.program_decl_count {
            const d: &ASTNode = codegen.program_node.program_decls[di];
            if d != null && d != fn_decl && d.type == ASTNodeType.AST_FN_DECL && d.fn_decl_name != null &&
               strcmp(d.fn_decl_name as *byte, fn_decl.fn_decl_name as *byte) == 0 && d.fn_decl_body != null {
                codegen.current_function_decl = saved_current_function_decl;
                return;
            }
            di = di + 1;
        }
    }
    if is_extern != 0 {
        fprintf(codegen.output, "extern %s %s(" as *byte, return_c as *byte, func_name as *byte);
    } else {
        if is_export == 0 && has_extern_same == 0 {
            fprintf(codegen.output, "static " as *byte);
        }
        fprintf(codegen.output, "%s %s(" as *byte, return_c as *byte, func_name as *byte);
    }
    
    // 检查是否为 copy_type 函数（需要 const 限定符）
    var is_copy_type: i32 = 0;
    if fn_decl.fn_decl_name != null && strcmp(fn_decl.fn_decl_name as *byte, "copy_type" as *byte) == 0 {
        is_copy_type = 1;
    }

    // 检查是否为标准库函数（extern "libc" fn）
    var is_stdlib: i32 = 0;
    if extern_lib_name != null {
        is_stdlib = 1;
    }

    // 参数列表
    var i: i32 = 0;
    while i < param_count {
        const param: &ASTNode = fn_decl.fn_decl_params[i];
        if param != null && param.type == ASTNodeType.AST_VAR_DECL {
            const param_name: &byte = get_safe_c_identifier(codegen, param.var_decl_name);
            const param_type: &ASTNode = param.var_decl_type;
            var param_type_c: &byte = c99_type_to_c(codegen, param_type);
            
            // 特殊处理 copy_type 函数：将第一个参数类型改为 const struct Type *
            if is_copy_type != 0 && i == 0 {
                // 对于 copy_type 函数，第一个参数类型必须是 const struct Type *
                // 直接替换，不检查原始类型（因为 copy_type 的参数类型总是 &Type，即 struct Type *）
                param_type_c = ("const struct Type *" as *byte) as &byte;
            }
            
            // 对于 extern 函数，检查大结构体参数（>16字节），转换为指针类型
            // 根据 x86-64 System V ABI，大于 16 字节的结构体通过指针传递
            if is_extern != 0 && param_type.type == ASTNodeType.AST_TYPE_NAMED {
                const struct_size: i32 = calculate_struct_size(codegen, param_type);
                if struct_size > 16 {
                    // 大结构体：转换为指针类型
                    // 注意：如果是 copy_type 函数，保持 const struct Type *
                    if is_copy_type != 0 && i == 0 {
                        param_type_c = ("const struct Type *" as *byte) as &byte;
                    } else {
                        param_type_c = c99_type_to_c(codegen, param_type);
                    }
                    fprintf(codegen.output, "%s *%s" as *byte, param_type_c as *byte, param_name as *byte);
                    if i < param_count - 1 {
                        fputs(", " as *byte, codegen.output);
                    }
                    i = i + 1;
                    continue;
                }
            }
            
            // 对于 extern "libc" fn 的 byte 指针，仅 strlen 使用 const；sprintf/snprintf/vsprintf/vsnprintf 第一参可修改
            // 与 C 版一致：其他保持 c99_type_to_c 的默认输出（uint8_t *）
            var is_libc: i32 = is_extern_libc_function(codegen, fn_decl.fn_decl_name);
            if is_libc != 0 && param_type.type == ASTNodeType.AST_TYPE_POINTER {
                const pointed_type: &ASTNode = param_type.type_pointer_pointed_type;
                if pointed_type != null && pointed_type.type == ASTNodeType.AST_TYPE_NAMED {
                    const pointed_name: &byte = pointed_type.type_named_name;
                    if pointed_name != null && strcmp(pointed_name as *byte, "byte" as *byte) == 0 {
                        if fn_decl.fn_decl_name != null && strcmp(fn_decl.fn_decl_name as *byte, "strlen" as *byte) == 0 {
                            param_type_c = ("const uint8_t *" as *byte) as &byte;
                        } else if fn_decl.fn_decl_name != null && ((strcmp(fn_decl.fn_decl_name as *byte, "sprintf" as *byte) == 0 ||
                                   strcmp(fn_decl.fn_decl_name as *byte, "snprintf" as *byte) == 0 ||
                                   strcmp(fn_decl.fn_decl_name as *byte, "vsprintf" as *byte) == 0 ||
                                   strcmp(fn_decl.fn_decl_name as *byte, "vsnprintf" as *byte) == 0) && i == 0) {
                            param_type_c = ("uint8_t *" as *byte) as &byte;
                        }
                    }
                }
            }
            
            // 数组参数：在参数名后添加 _param 后缀，函数内部会创建副本
            if param_type.type == ASTNodeType.AST_TYPE_ARRAY {
                // 数组参数格式：T name_param[N]
                const bracket: *byte = strchr(param_type_c as *byte, 91);  // '['
                if bracket != null {
                    const str_len: i32 = ptr_diff(bracket, param_type_c as *byte);
                    // 注意：Uya Mini 不支持 %.*s，需要手动处理
                    var temp_buf: [byte: TEMP_BUF_SIZE] = [];
                    var j: i32 = 0;
                    while j < str_len && j < TEMP_BUF_LIMIT {
                        temp_buf[j] = param_type_c[j];
                        j = j + 1;
                    }
                    if j >= 0 && j < TEMP_BUF_SIZE {
                        temp_buf[j] = 0;
                    }
                    fprintf(codegen.output, "%s %s_param%s" as *byte, &temp_buf[0] as *byte, param_name as *byte, bracket);
                } else {
                    fprintf(codegen.output, "%s %s_param" as *byte, param_type_c as *byte, param_name as *byte);
                }
            } else if param_type.type == ASTNodeType.AST_TYPE_SLICE {
                // Slice 类型参数：通过指针传递（slice 是引用类型）
                fprintf(codegen.output, "%s *%s" as *byte, param_type_c as *byte, param_name as *byte);
            } else {
                // 对于 copy_type 函数，直接输出 const struct Type *，不调用 format_param_type
                if is_copy_type != 0 && i == 0 {
                    fprintf(codegen.output, "const struct Type * %s" as *byte, param_name as *byte);
                } else {
                    format_param_type(codegen, param_type_c, param_name, codegen.output);
                }
            }
            if i < param_count - 1 {
                fputs(", " as *byte, codegen.output);
            }
        }
        i = i + 1;
    }
    
    // 处理可变参数
    if is_varargs != 0 {
        if param_count > 0 {
            fputs(", " as *byte, codegen.output);
        }
        fputs("..." as *byte, codegen.output);
    }
    
    fputs(");\n" as *byte, codegen.output);
    
    // 恢复当前函数声明
    codegen.current_function_decl = saved_current_function_decl;
}

// 生成函数定义
// 注意：此函数在 main.uya 中被调用，但由于 function.uya 在 main.uya 之前编译，函数已经可见
fn gen_function(codegen: &C99CodeGenerator, fn_decl: &ASTNode) void {
    if fn_decl == null || fn_decl.type != ASTNodeType.AST_FN_DECL {
        return;
    }
    
    const orig_name: &byte = fn_decl.fn_decl_name;
    const extern_lib_name: &byte = fn_decl.fn_decl_extern_lib_name;  // extern "libc" fn 的库名
    
    // extern "libc" fn 不添加模块前缀，直接使用原始函数名
    var func_name: &byte = get_c_name_for_global_function(codegen, orig_name, 1);
    if fn_decl.fn_decl_is_export != 0 && fn_decl.filename != null && extern_lib_name == null {
        func_name = get_export_function_c_name(codegen, orig_name, fn_decl.filename);
    }
    const return_type: &ASTNode = fn_decl.fn_decl_return_type;
    const param_count: i32 = fn_decl.fn_decl_param_count;
    const is_varargs: i32 = fn_decl.fn_decl_is_varargs;
    const body: &ASTNode = fn_decl.fn_decl_body;
    
    // 如果没有函数体（外部函数），则不生成定义
    if body == null {
        return;
    }

    // @async_fn：
    // - 形式一（阶段 B）：返回 Future<!T> 或 !Future<T>，使用状态机生成 async
    // - 形式二（阶段 A 兼容）：其他返回类型走普通函数代码生成
    if fn_decl.fn_decl_is_async != 0 {
        var use_stage_b: i32 = 0;
        var effective_return_type: &ASTNode = return_type;
        if return_type != null && return_type.type == ASTNodeType.AST_TYPE_NAMED &&
            return_type.type_named_name != null &&
            strcmp(return_type.type_named_name as *byte, "Future" as *byte) == 0 &&
            return_type.type_named_type_arg_count == 1 &&
            return_type.type_named_type_args != null {
            const a0: &ASTNode = return_type.type_named_type_args[0];
            if a0 != null && a0.type == ASTNodeType.AST_TYPE_ERROR_UNION &&
                a0.type_error_union_payload_type != null {
                use_stage_b = 1;
            }
        }
        if use_stage_b == 0 && return_type != null && return_type.type == ASTNodeType.AST_TYPE_ERROR_UNION &&
            return_type.type_error_union_payload_type != null {
            const pl: &ASTNode = return_type.type_error_union_payload_type;
            if pl.type == ASTNodeType.AST_TYPE_NAMED && pl.type_named_name != null &&
                strcmp(pl.type_named_name as *byte, "Future" as *byte) == 0 &&
                pl.type_named_type_arg_count == 1 && pl.type_named_type_args != null {
                use_stage_b = 1;
                effective_return_type = pl;
            }
        }
        if use_stage_b != 0 {
            gen_async_function_stage_b(codegen, fn_decl, func_name, return_type, effective_return_type);
            return;
        }
        // 否则继续走普通函数定义路径
    }
    
    // 生成 #line 指令，指向函数定义的位置
    emit_line_directive(codegen, fn_decl.line, fn_decl.filename);
    
    // 特殊处理：main 函数需要重命名为 uya_main（符合 Uya 规范：main 函数无参数）
    // 注意：Uya Mini 不支持三元运算符，使用 if-else 代替
    var is_main: i32 = 0;
    if fn_decl.fn_decl_name != null && strcmp(fn_decl.fn_decl_name as *byte, "main" as *byte) == 0 {
        is_main = 1;
    }
    
    // 返回类型（如果是数组类型，转换为指针类型）
    var return_c: &byte = convert_array_return_type(codegen, return_type);
    return_c = normalize_poll_return_type(codegen, return_c);
    
    // 声明循环变量 i（在 if-else 之前声明，确保在所有分支都可见）
    var i: i32 = 0;
    
    // 检查是否为extern函数（body为NULL表示extern函数）
    var is_extern: i32 = 0;
    if body == null && extern_lib_name == null {
        // 只有当没有 extern_lib_name 时才标记为 is_extern
        // extern "libc" fn 带函数体时，is_extern 应该为 0
        is_extern = 1;
    }
    
    // 读取 is_export 标志
    const is_export: i32 = fn_decl.fn_decl_is_export;
    // 若程序中存在同名 extern 声明（如 parser 的 extern fn lexer_next_token），定义处不能加 static
    var has_extern_decl_same_name: i32 = 0;
    if is_extern == 0 && fn_decl.fn_decl_name != null && codegen.program_node != null && codegen.program_node.type == ASTNodeType.AST_PROGRAM {
        var di: i32 = 0;
        while di < codegen.program_node.program_decl_count {
            const d: &ASTNode = codegen.program_node.program_decls[di];
            if d != null && d.type == ASTNodeType.AST_FN_DECL && d.fn_decl_name != null &&
               strcmp(d.fn_decl_name as *byte, fn_decl.fn_decl_name as *byte) == 0 && d.fn_decl_body == null {
                has_extern_decl_same_name = 1;
                break;
            }
            di = di + 1;
        }
    }
    // extern "libc" fn 带函数体时，不使用 static，不使用模块前缀
    var is_static: i32 = 0;
    if is_main == 0 && is_extern == 0 && is_export == 0 && has_extern_decl_same_name == 0 && extern_lib_name == null {
        is_static = 1;
    }

    // 检查是否为标准 C main 函数（export extern fn main）
    var is_c_main: i32 = 0;
    if is_main != 0 && fn_decl.fn_decl_is_export != 0 && fn_decl.fn_decl_is_extern != 0 {
        is_c_main = 1;
    }

    if is_main != 0 && is_c_main == 0 {
        // export fn main → main_main，fn main → uya_main
        var main_def_name: &byte = "uya_main" as *byte;
        if fn_decl.fn_decl_is_export != 0 {
            main_def_name = "main_main" as *byte;
        }
        fprintf(codegen.output, "%s %s(void)" as *byte, return_c as *byte, main_def_name as *byte);
    } else {
        // 非 extern 函数：根据 is_export 决定是否添加 static
        // fn foo() void → static void foo(void)（内部函数，不导出）
        // export fn foo() void → void foo(void)（导出函数，供其他模块使用）
        // @naked_fn 函数添加 __attribute__((naked))
        if fn_decl.fn_decl_is_naked != 0 {
            fprintf(codegen.output, "__attribute__((naked)) " as *byte);
        }
        if is_static != 0 {
            fprintf(codegen.output, "static __attribute__((unused)) " as *byte);
        }
        fprintf(codegen.output, "%s %s(" as *byte, return_c as *byte, func_name as *byte);
        
        // 检查是否为 copy_type 函数（需要 const 限定符）
        var is_copy_type: i32 = 0;
        if fn_decl.fn_decl_name != null && strcmp(fn_decl.fn_decl_name as *byte, "copy_type" as *byte) == 0 {
            is_copy_type = 1;
        }

        // 参数列表
        i = 0;
        while i < param_count {
            const param: &ASTNode = fn_decl.fn_decl_params[i];
            if param != null && param.type == ASTNodeType.AST_VAR_DECL {
                const param_name: &byte = get_safe_c_identifier(codegen, param.var_decl_name);
                const param_type: &ASTNode = param.var_decl_type;
                var param_type_c: &byte = c99_type_to_c(codegen, param_type);
                
                // 特殊处理 copy_type 函数：将第一个参数类型改为 const struct Type *
                if is_copy_type != 0 && i == 0 {
                    // 对于 copy_type 函数，第一个参数类型必须是 const struct Type *
                    // 直接替换，不检查原始类型（因为 copy_type 的参数类型总是 &Type，即 struct Type *）
                    param_type_c = ("const struct Type *" as *byte) as &byte;
                }
                
                // 对于 extern "libc" fn 的 byte 指针，仅 strlen 使用 const；sprintf/snprintf 第一参可修改
                var is_libc_def: i32 = is_extern_libc_function(codegen, orig_name);
                if is_libc_def != 0 && param_type.type == ASTNodeType.AST_TYPE_POINTER {
                    const pointed_type: &ASTNode = param_type.type_pointer_pointed_type;
                    if pointed_type != null && pointed_type.type == ASTNodeType.AST_TYPE_NAMED {
                        const pointed_name: &byte = pointed_type.type_named_name;
                        if pointed_name != null && strcmp(pointed_name as *byte, "byte" as *byte) == 0 {
                            if orig_name != null && strcmp(orig_name as *byte, "strlen" as *byte) == 0 {
                                param_type_c = ("const uint8_t *" as *byte) as &byte;
                            } else if orig_name != null && ((strcmp(orig_name as *byte, "sprintf" as *byte) == 0 ||
                                       strcmp(orig_name as *byte, "snprintf" as *byte) == 0) && i == 0) {
                                param_type_c = ("uint8_t *" as *byte) as &byte;
                            }
                        }
                    }
                }
                
                // 数组参数：在参数名后添加 _param 后缀，函数内部会创建副本
                if param_type.type == ASTNodeType.AST_TYPE_ARRAY {
                    // 数组参数格式：T name_param[N]
                    const bracket: *byte = strchr(param_type_c as *byte, 91);  // '['
                    if bracket != null {
                        const str_len: i32 = ptr_diff(bracket, param_type_c as *byte);
                        // 注意：Uya Mini 不支持 %.*s，需要手动处理
                        var temp_buf: [byte: TEMP_BUF_SIZE] = [];
                        var j: i32 = 0;
                        while j < str_len && j < TEMP_BUF_LIMIT {
                            temp_buf[j] = param_type_c[j];
                            j = j + 1;
                        }
                        if j >= 0 && j < TEMP_BUF_SIZE {
                            temp_buf[j] = 0;
                        }
                        fprintf(codegen.output, "%s %s_param%s" as *byte, &temp_buf[0] as *byte, param_name as *byte, bracket);
                    } else {
                        fprintf(codegen.output, "%s %s_param" as *byte, param_type_c as *byte, param_name as *byte);
                    }
                } else if param_type.type == ASTNodeType.AST_TYPE_SLICE {
                    // Slice 类型参数：通过指针传递（slice 是引用类型）
                    fprintf(codegen.output, "%s *%s" as *byte, param_type_c as *byte, param_name as *byte);
                } else {
                    // 对于 copy_type 函数，直接输出 const struct Type *，不调用 format_param_type
                    if is_copy_type != 0 && i == 0 {
                        fprintf(codegen.output, "const struct Type * %s" as *byte, param_name as *byte);
                    } else {
                        format_param_type(codegen, param_type_c, param_name, codegen.output);
                    }
                }
                if i < param_count - 1 {
                    fputs(", " as *byte, codegen.output);
                }
            }
            i = i + 1;
        }
        
        // 处理可变参数
        if is_varargs != 0 {
            if param_count > 0 {
                fputs(", " as *byte, codegen.output);
            }
            fputs("..." as *byte, codegen.output);
        }
    }
    
    // 添加函数体开始
    if is_main != 0 {
        fputs(" {\n" as *byte, codegen.output);
        // 在 main 函数开始时调用测试运行器（只有在有测试时才调用）
        if codegen.test_count > 0 {
            fputs("    uya_run_tests();\n" as *byte, codegen.output);
        }
    } else {
        fputs(") {\n" as *byte, codegen.output);
    }
    codegen.indent_level = codegen.indent_level + 1;
    
    // 保存当前函数的返回类型（用于生成返回语句）
    codegen.current_function_return_type = return_type;
    
    // 保存当前函数声明（用于 @params 与 ... 转发）
    const saved_current_function_decl: &ASTNode = codegen.current_function_decl;
    codegen.current_function_decl = fn_decl;
    
    // 保存函数开始时的局部变量表状态（用于函数结束时恢复）
    // 每个函数有自己独立的局部变量表，函数结束后恢复之前的状态
    const saved_local_variable_count: i32 = codegen.local_variable_count;
    const saved_current_depth: i32 = codegen.current_depth;
    
    // 重置当前函数的局部变量表（从 0 开始）
    // 这样每个函数都有自己独立的局部变量表，避免大文件时表被填满
    // 参数和局部变量都从索引 0 开始添加
    codegen.local_variable_count = 0;
    codegen.current_depth = 0;
    
    // 处理数组参数：为数组参数创建局部副本（实现按值传递）
    i = 0;
    while i < param_count {
        const param: &ASTNode = fn_decl.fn_decl_params[i];
        if param != null && param.type == ASTNodeType.AST_VAR_DECL {
            const param_name: &byte = get_safe_c_identifier(codegen, param.var_decl_name);
            const param_type: &ASTNode = param.var_decl_type;
            
            if param_type.type == ASTNodeType.AST_TYPE_ARRAY {
                // 数组参数：创建局部数组副本
                const array_type_c: &byte = c99_type_to_c(codegen, param_type);
                // 解析数组类型格式：int32_t[3] -> int32_t arr[3]
                const bracket: *byte = strchr(array_type_c as *byte, 91);  // '['
                c99_emit_indent(codegen);
                fputs("// 数组参数按值传递：创建局部副本\n" as *byte, codegen.output);
                if bracket != null {
                    const str_len: i32 = ptr_diff(bracket, array_type_c as *byte);
                    // 注意：Uya Mini 不支持 %.*s，需要手动处理
                    var temp_buf: [byte: TEMP_BUF_SIZE] = [];
                    var j: i32 = 0;
                    while j < str_len && j < TEMP_BUF_LIMIT {
                        temp_buf[j] = array_type_c[j];
                        j = j + 1;
                    }
                    if j >= 0 && j < TEMP_BUF_SIZE {
                        temp_buf[j] = 0;
                    }
                    fprintf(codegen.output, "    %s %s%s;\n" as *byte, &temp_buf[0] as *byte, param_name as *byte, bracket);
                } else {
                    c99_emit_indent(codegen);
                    fprintf(codegen.output, "%s %s;\n" as *byte, array_type_c as *byte, param_name as *byte);
                }
                c99_emit_indent(codegen);
                codegen.needs_string_h = 1;
                fprintf(codegen.output, "    __uya_memcpy(%s, %s_param, sizeof(%s));\n" as *byte, param_name as *byte, param_name as *byte, param_name as *byte);
                
                // 将参数名注册为局部数组（而不是参数）
                if param_name != null && codegen.local_variable_count < C99_MAX_LOCAL_VARS {
                    codegen.local_variables[codegen.local_variable_count].name = param.var_decl_name;  // 使用原始名称
                    codegen.local_variables[codegen.local_variable_count].type_c = array_type_c;
                    codegen.local_variable_count = codegen.local_variable_count + 1;
                }
            } else {
                // 非数组参数：正常添加到局部变量表
                var param_type_c: &byte = c99_type_to_c(codegen, param_type);
                // 对于 slice 类型参数，需要添加 * 后缀（因为 slice 参数通过指针传递）
                if param_type.type == ASTNodeType.AST_TYPE_SLICE {
                    // 为 slice 类型添加指针后缀
                    const len: usize = strlen(param_type_c as *byte) + 3;  // 类型 + " *" + null
                    const ptr_type: &byte = arena_alloc(codegen.arena, len) as &byte;
                    if ptr_type != null {
                        var dst: &byte = ptr_type;
                        const src: *byte = param_type_c as *byte;
                        var j: i32 = 0;
                        while src[j] != 0 {
                            dst[j] = src[j];
                            j = j + 1;
                        }
                        dst[j] = 32;  // ' '
                        dst[j + 1] = 42;  // '*'
                        dst[j + 2] = 0;  // '\0'
                        param_type_c = ptr_type;
                    }
                }
                if param_name != null && param_type_c != null && codegen.local_variable_count < C99_MAX_LOCAL_VARS {
                    codegen.local_variables[codegen.local_variable_count].name = param.var_decl_name;
                    codegen.local_variables[codegen.local_variable_count].type_c = param_type_c;
                    codegen.local_variable_count = codegen.local_variable_count + 1;
                }
            }
        }
        i = i + 1;
    }
    i = 0;
    while i < param_count {
        const param: &ASTNode = fn_decl.fn_decl_params[i];
        if param != null && param.type == ASTNodeType.AST_VAR_DECL {
            const pname: &byte = get_safe_c_identifier(codegen, param.var_decl_name);
            if pname != null {
                c99_emit_indent(codegen);
                if param.var_decl_type != null && param.var_decl_type.type == ASTNodeType.AST_TYPE_ARRAY {
                    fprintf(codegen.output as *void, "(void)%s_param;\n" as *byte, pname as *byte);
                } else {
                    fprintf(codegen.output as *void, "(void)%s;\n" as *byte, pname as *byte);
                }
            }
        }
        i = i + 1;
    }
    
    // 生成函数体
    gen_stmt(codegen, body);
    
    // 检查函数体是否以 return 结尾
    var has_return: i32 = 0;
    if body != null && body.type == ASTNodeType.AST_BLOCK {
        const stmts: & & ASTNode = body.block_stmts;
        const stmt_count: i32 = body.block_stmt_count;
        var j: i32 = stmt_count - 1;
        while j >= 0 {
            const s: &ASTNode = stmts[j];
            if s != null && s.type != ASTNodeType.AST_DEFER_STMT && s.type != ASTNodeType.AST_ERRDEFER_STMT {
                if s.type == ASTNodeType.AST_RETURN_STMT {
                    has_return = 1;
                } else {
                    has_return = 0;
                }
                break;
            }
            j = j - 1;
        }
    }
    
    // 如果返回类型是 !void 且函数体没有显式返回，添加默认返回语句
    if has_return == 0 && return_type != null && return_type.type == ASTNodeType.AST_TYPE_ERROR_UNION {
        const payload_node: &ASTNode = return_type.type_error_union_payload_type;
        var is_void_payload: i32 = 0;
        if payload_node == null {
            is_void_payload = 1;
        } else if payload_node.type == ASTNodeType.AST_TYPE_NAMED && payload_node.type_named_name != null &&
            strcmp(payload_node.type_named_name as *byte, "void" as *byte) == 0 {
            is_void_payload = 1;
        }
        if is_void_payload != 0 {
            // !void 类型：返回成功的错误联合（缩进与 C 编译器一致）
            codegen.indent_level = codegen.indent_level + 1;
            c99_emit_indent(codegen);
            fprintf(codegen.output as *void, "return (%s){ .error_id = 0 };\n" as *byte, return_c as *byte);
            codegen.indent_level = codegen.indent_level - 1;
        }
    }
    // 若返回类型非 void 且函数体末尾无 return，补兜底 return 避免 -Wreturn-type（缩进与 C 编译器一致）
    if has_return == 0 && return_type != null {
        var is_void: i32 = 0;
        if return_type.type == ASTNodeType.AST_TYPE_NAMED && return_type.type_named_name != null &&
            strcmp(return_type.type_named_name as *byte, "void" as *byte) == 0 {
            is_void = 1;
        } else if return_type.type == ASTNodeType.AST_TYPE_ERROR_UNION {
            const pl: &ASTNode = return_type.type_error_union_payload_type;
            if pl == null {
                is_void = 1;
            } else if pl.type == ASTNodeType.AST_TYPE_NAMED && pl.type_named_name != null &&
                strcmp(pl.type_named_name as *byte, "void" as *byte) == 0 {
                is_void = 1;
            }
        }
        if is_void == 0 {
            codegen.indent_level = codegen.indent_level + 1;
            c99_emit_indent(codegen);
            if return_c != null && strncmp(return_c as *byte, "struct " as *byte, 7) == 0 {
                fprintf(codegen.output as *void, "return (%s){0};\n" as *byte, return_c as *byte);
            } else {
                fputs("return 0;\n" as *byte, codegen.output as *void);
            }
            codegen.indent_level = codegen.indent_level - 1;
        }
    }
    
    // 清除当前函数的返回类型
    codegen.current_function_return_type = null;
    
    // 恢复当前函数声明
    codegen.current_function_decl = saved_current_function_decl;
    
    // 恢复函数开始时的局部变量表状态
    // 这样下一个函数可以从干净的状态开始
    codegen.local_variable_count = saved_local_variable_count;
    codegen.current_depth = saved_current_depth;
    
    codegen.indent_level = codegen.indent_level - 1;
    c99_emit_indent(codegen);
    c99_emit_close_brace_newline(codegen);
}

// ===== async stage-B codegen（单 @await 最小状态机）=====
// full_return_type: 函数声明的返回类型（可为 !Future<T> 或 Future<!T>）
// effective_return_type: 用于状态机的 Future 类型（Future<T> 或 Future<!T>）
fn gen_async_function_stage_b(codegen: &C99CodeGenerator, fn_decl: &ASTNode, func_c_name: &byte, full_return_type: &ASTNode, effective_return_type: &ASTNode) void {
    if codegen == null || fn_decl == null || effective_return_type == null {
        return;
    }
    if effective_return_type.type != ASTNodeType.AST_TYPE_NAMED || effective_return_type.type_named_name == null ||
        strcmp(effective_return_type.type_named_name as *byte, "Future" as *byte) != 0 ||
        effective_return_type.type_named_type_arg_count != 1 || effective_return_type.type_named_type_args == null {
        return;
    }
    var inner: &ASTNode = effective_return_type.type_named_type_args[0];
    if inner == null {
        return;
    }
    var inner_is_err_union: i32 = 0;
    if inner.type == ASTNodeType.AST_TYPE_ERROR_UNION && inner.type_error_union_payload_type != null {
        inner_is_err_union = 1;
    }
    // 当函数返回 !Future<T> 时，子调用返回 !Future<T>，需 try 取 .value；且 poll 需能返回错误，故用 Poll<!T>
    if full_return_type != null && full_return_type.type == ASTNodeType.AST_TYPE_ERROR_UNION &&
        full_return_type.type_error_union_payload_type != null {
        const pl: &ASTNode = full_return_type.type_error_union_payload_type;
        if pl.type == ASTNodeType.AST_TYPE_NAMED && pl.type_named_name != null &&
            strcmp(pl.type_named_name as *byte, "Future" as *byte) == 0 {
            const payload_t: &ASTNode = effective_return_type.type_named_type_args[0];
            const inner_err_node: &ASTNode = ast_new_node(ASTNodeType.AST_TYPE_ERROR_UNION, 0, 0, codegen.arena, null);
            if inner_err_node != null {
                inner_err_node.type_error_union_payload_type = payload_t;
                inner = inner_err_node;
                inner_is_err_union = 1;
            }
        }
    }

    // 生成单态名：Future_T / Future_err_T、Poll_T / Poll_err_T
    const type_args: & & ASTNode = arena_alloc(codegen.arena, @size_of(&ASTNode)) as & & ASTNode;
    if type_args == null {
        return;
    }
    type_args[0] = inner;
    const future_mono: &byte = get_mono_struct_name(codegen, "Future" as &byte, type_args, 1);
    const safe_future: &byte = get_safe_c_identifier(codegen, future_mono);
    var vtable_future_safe: &byte = safe_future;
    const iface_c: &byte = c99_type_to_c(codegen, effective_return_type);
    const inner_err_c: &byte = c99_type_to_c(codegen, inner);
    var concrete_future_safe: &byte = safe_future;
    if effective_return_type.type_named_type_args != null && effective_return_type.type_named_type_arg_count >= 1 {
        const payload_future_mono: &byte = get_mono_struct_name(codegen, "Future" as &byte, effective_return_type.type_named_type_args, effective_return_type.type_named_type_arg_count);
        if payload_future_mono != null {
            concrete_future_safe = get_safe_c_identifier(codegen, payload_future_mono);
        }
    }
    // 内层 Poll<T> 的 C 名（用于 Future<T>.state，如 return 42 时包装为 Future{ state: Poll.Ready(42) }）
    var inner_poll_ret_c: &byte = null;
    var inner_poll_union_c: &byte = null;
    if effective_return_type.type_named_type_args != null && effective_return_type.type_named_type_arg_count >= 1 {
        const inner_poll_mono: &byte = get_mono_union_name(codegen, "Poll" as &byte, effective_return_type.type_named_type_args, effective_return_type.type_named_type_arg_count);
        if inner_poll_mono != null {
            const inner_poll_safe: &byte = get_safe_c_identifier(codegen, inner_poll_mono);
            const ipr: &byte = arena_alloc(codegen.arena, 128) as &byte;
            if ipr != null { snprintf(ipr as *byte, 128, "struct uya_tagged_%s" as *byte, inner_poll_safe as *byte); inner_poll_ret_c = ipr; }
            const ipu: &byte = arena_alloc(codegen.arena, 128) as &byte;
            if ipu != null { snprintf(ipu as *byte, 128, "union %s" as *byte, inner_poll_safe as *byte); inner_poll_union_c = ipu; }
        }
    }
    // 本分支仅用于无 await 的 !Future<T>，effective_return_type 应有 type_args；若无则 fallback 可能错误
    if inner_poll_ret_c == null { inner_poll_ret_c = "struct uya_tagged_Poll_i32" as &byte; }
    if inner_poll_union_c == null { inner_poll_union_c = "union Poll_i32" as &byte; }

    // 提取所有 await 点（仅支持：const x: U = try @await <operand>;）与 return expr
    const body: &ASTNode = fn_decl.fn_decl_body;
    const MAX_AWAITS: i32 = 32;
    var await_operands: [&ASTNode: 32] = [];
    var await_bind_names: [&byte: 32] = [];
    var await_bind_types: [&ASTNode: 32] = [];
    var await_count: i32 = 0;
    var ret_expr: &ASTNode = null;
    if body != null && body.type == ASTNodeType.AST_BLOCK && body.block_stmts != null {
        var i: i32 = 0;
        while i < body.block_stmt_count && await_count < MAX_AWAITS {
            const s: &ASTNode = body.block_stmts[i];
            if s != null && s.type == ASTNodeType.AST_VAR_DECL && s.var_decl_init != null {
                const init: &ASTNode = s.var_decl_init;
                if init.type == ASTNodeType.AST_TRY_EXPR && init.try_expr_operand != null {
                    const op: &ASTNode = init.try_expr_operand;
                    if op.type == ASTNodeType.AST_AWAIT_EXPR && op.await_expr_operand != null {
                        await_operands[await_count] = op.await_expr_operand;
                        await_bind_names[await_count] = s.var_decl_name;
                        await_bind_types[await_count] = s.var_decl_type;
                        await_count = await_count + 1;
                    }
                }
            }
            if s != null && s.type == ASTNodeType.AST_RETURN_STMT {
                ret_expr = s.return_stmt_expr;
            }
            i = i + 1;
        }
    }
    // 兼容无 await 判断：type_args_poll / 无-await 分支用 await_count == 0

    // poll 返回类型：无 await 且返回 !Future<T> 时为 Poll<!Future<T>>，否则为 Poll<inner>
    const type_args_poll: & & ASTNode = arena_alloc(codegen.arena, @size_of(&ASTNode)) as & & ASTNode;
    var safe_poll: &byte = get_safe_c_identifier(codegen, get_mono_union_name(codegen, "Poll" as &byte, type_args, 1));
    var poll_ret_c: &byte = null;
    var poll_union_c: &byte = null;
    var return_future_err_union: i32 = 0;
    if type_args_poll != null {
        // 返回 !Future<T> 时 poll 始终为 Poll<!Future<T>>（有无 await 一致），否则为 Poll<inner>
        if full_return_type != null && full_return_type.type == ASTNodeType.AST_TYPE_ERROR_UNION &&
            full_return_type.type_error_union_payload_type != null {
            const pl: &ASTNode = full_return_type.type_error_union_payload_type;
            if pl.type == ASTNodeType.AST_TYPE_NAMED && pl.type_named_name != null &&
                strcmp(pl.type_named_name as *byte, "Future" as *byte) == 0 {
                if await_count == 0 {
                    return_future_err_union = 1;
                } else if ret_expr != null && ret_expr.type == ASTNodeType.AST_STRUCT_INIT && ret_expr.struct_init_struct_name != null &&
                    strcmp(ret_expr.struct_init_struct_name as *byte, "Future" as *byte) == 0 {
                    return_future_err_union = 1;
                } else if await_bind_types[0] != null && await_bind_types[0].type == ASTNodeType.AST_TYPE_NAMED &&
                    await_bind_types[0].type_named_name != null &&
                    strcmp(await_bind_types[0].type_named_name as *byte, "Future" as *byte) == 0 {
                    return_future_err_union = 1;
                }
            }
        }
        if return_future_err_union != 0 {
            type_args_poll[0] = full_return_type;
            const poll_type_node: &ASTNode = ast_new_node(ASTNodeType.AST_TYPE_NAMED, 0, 0, codegen.arena, null);
            const poll_union_decl: &ASTNode = find_union_decl_c99(codegen, "Poll" as &byte);
            if poll_union_decl != null {
                gen_mono_union_definition(codegen, poll_union_decl, type_args_poll, 1);
            }
            const poll_full_mono: &byte = get_mono_union_name(codegen, "Poll" as &byte, type_args_poll, 1);
            if poll_full_mono != null {
                safe_poll = get_safe_c_identifier(codegen, poll_full_mono);
                const pbuf_full: &byte = arena_alloc(codegen.arena, 256) as &byte;
                if pbuf_full != null {
                    snprintf(pbuf_full as *byte, 256, "struct uya_tagged_%s" as *byte, safe_poll as *byte);
                    poll_ret_c = pbuf_full;
                }
                const ubuf_full: &byte = arena_alloc(codegen.arena, 256) as &byte;
                if ubuf_full != null {
                    snprintf(ubuf_full as *byte, 256, "union %s" as *byte, safe_poll as *byte);
                    poll_union_c = ubuf_full;
                }
            }
            const future_full_mono: &byte = get_mono_struct_name(codegen, "Future" as &byte, type_args_poll, 1);
            if future_full_mono != null {
                vtable_future_safe = get_safe_c_identifier(codegen, future_full_mono);
                const future_type_node: &ASTNode = ast_new_node(ASTNodeType.AST_TYPE_NAMED, 0, 0, codegen.arena, null);
                if future_type_node != null {
                    future_type_node.type_named_name = "Future" as &byte;
                    future_type_node.type_named_type_args = type_args_poll;
                    future_type_node.type_named_type_arg_count = 1;
                    c99_type_to_c(codegen, future_type_node);
                }
            }
        }
    }
    if poll_ret_c == null {
        const pbuf: &byte = arena_alloc(codegen.arena, 256) as &byte;
        if pbuf != null {
            snprintf(pbuf as *byte, 256, "struct uya_tagged_%s" as *byte, safe_poll as *byte);
            poll_ret_c = pbuf;
        }
        const ubuf2: &byte = arena_alloc(codegen.arena, 256) as &byte;
        if ubuf2 != null {
            snprintf(ubuf2 as *byte, 256, "union %s" as *byte, safe_poll as *byte);
            poll_union_c = ubuf2;
        }
    }
    // 状态机内 Ready 载荷类型：返回 !Future<T> 时为 full_return_type，否则为 inner_err_c
    var ready_payload_c: &byte = inner_err_c;
    if return_future_err_union != 0 && full_return_type != null {
        const fc: &byte = c99_type_to_c(codegen, full_return_type);
        if fc != null { ready_payload_c = fc; }
    }
    // 子 future 的 vtable 名：返回 !Future<T> 时为 Future<!Future<T>>，否则为 safe_future
    var child_vtable_safe: &byte = safe_future;
    if return_future_err_union != 0 { child_vtable_safe = vtable_future_safe; }
    // 当 return_future_err_union=0 时，状态机实现 Future<inner>，需用 type_args 的 vtable 名
    if return_future_err_union == 0 && type_args != null {
        const mono_future: &byte = get_mono_struct_name(codegen, "Future" as &byte, type_args, 1);
        if mono_future != null { vtable_future_safe = get_safe_c_identifier(codegen, mono_future); }
    }
    // 首段 await 是否对 !Future<T> 做 try：绑定类型为 Future 时做 try，存的是 .value（Future<T> 接口）
    var await_operand_is_err_future: i32 = 0;
    if await_count > 0 && await_bind_types[0] != null && await_bind_types[0].type == ASTNodeType.AST_TYPE_NAMED &&
        await_bind_types[0].type_named_name != null &&
        strcmp(await_bind_types[0].type_named_name as *byte, "Future" as *byte) == 0 {
        await_operand_is_err_future = 1;
    }
    // 状态机 await 槽位类型：return_future_err_union 时为 effective 的接口；否则若首段做 try 则用 iface_c（存 !Future<T>.value），否则用 Future<inner>
    var state_slot_iface_c: &byte = iface_c;
    if return_future_err_union == 0 && type_args != null && type_args[0] != null {
        if await_operand_is_err_future != 0 {
            state_slot_iface_c = iface_c;
        } else {
            const future_inner_type_node: &ASTNode = ast_new_node(ASTNodeType.AST_TYPE_NAMED, 0, 0, codegen.arena, null);
            if future_inner_type_node != null {
                future_inner_type_node.type_named_name = "Future" as &byte;
                future_inner_type_node.type_named_type_args = type_args;
                future_inner_type_node.type_named_type_arg_count = 1;
                const slot_c: &byte = c99_type_to_c(codegen, future_inner_type_node);
                if slot_c != null { state_slot_iface_c = slot_c; }
            }
        }
    }

    // async 状态机 struct 名
    const async_struct: &byte = arena_alloc(codegen.arena, 128) as &byte;
    const poll_name: &byte = arena_alloc(codegen.arena, 256) as &byte;
    const vtable_name: &byte = arena_alloc(codegen.arena, 256) as &byte;
    if async_struct == null || poll_name == null || vtable_name == null {
        return;
    }
    snprintf(async_struct as *byte, 128, "uya_async_%s" as *byte, func_c_name as *byte);
    snprintf(poll_name as *byte, 256, "uya_%s_poll" as *byte, async_struct as *byte);
    snprintf(vtable_name as *byte, 256, "uya_vtable_%s_%s" as *byte, vtable_future_safe as *byte, async_struct as *byte);

    // 确保 stdlib（malloc）可用
    codegen.needs_stdlib_h = 1;

    // 若 poll 内会用到子 future 的 vtable，在 poll 前输出该 vtable 结构体定义（否则 ->poll 会报未定义类型），并标记已定义避免后续重复
    if await_count > 0 && poll_ret_c != null {
        const vtable_struct_buf: &byte = arena_alloc(codegen.arena, 128) as &byte;
        if vtable_struct_buf != null {
            snprintf(vtable_struct_buf as *byte, 128, "uya_vtable_%s" as *byte, child_vtable_safe as *byte);
            if is_struct_defined(codegen, vtable_struct_buf) == 0 {
                fprintf(codegen.output as *void, "struct uya_vtable_%s { %s (*poll)(void *self, struct Waker *); };\n" as *byte,
                    child_vtable_safe as *byte, poll_ret_c as *byte);
                mark_struct_defined(codegen, vtable_struct_buf);
            }
        }
    }

    // 输出状态机 struct
    emit_line_directive(codegen, fn_decl.line, fn_decl.filename);
    fprintf(codegen.output as *void, "struct %s { int32_t state; %s await_fut; };\n" as *byte, async_struct as *byte, state_slot_iface_c as *byte);

    // 输出 poll 函数
    if poll_ret_c == null {
        poll_ret_c = "struct uya_tagged_Poll_i32" as &byte;
    }
    if poll_union_c == null {
        poll_union_c = "union Poll_i32" as &byte;
    }
    fprintf(codegen.output as *void, "static %s %s(void *self, struct Waker *waker) {\n" as *byte, poll_ret_c as *byte, poll_name as *byte);
    fprintf(codegen.output as *void, "    struct %s *s = (struct %s *)self;\n" as *byte, async_struct as *byte, async_struct as *byte);
    fprintf(codegen.output as *void, "    if (s == (void*)0) { return (%s){ ._tag = 0 }; }\n" as *byte, poll_ret_c as *byte);
    // 多 await 时在函数开头声明所有绑定变量，供最后一态 ret_expr 使用
    var decl_i: i32 = 0;
    while decl_i < await_count {
        const bind_c_decl: &byte = c99_type_to_c(codegen, await_bind_types[decl_i]);
        const bind_safe_decl: &byte = get_safe_c_identifier(codegen, await_bind_names[decl_i]);
        if bind_c_decl != null && bind_safe_decl != null {
            fprintf(codegen.output as *void, "    %s %s;\n" as *byte, bind_c_decl as *byte, bind_safe_decl as *byte);
        }
        decl_i = decl_i + 1;
    }
    // state machine：state 0 = 起点；state 1..await_count = 各 await 就绪后
    fputs("    if (s->state == 0) {\n" as *byte, codegen.output as *void);
    if await_count > 0 {
        fputs("        s->state = 1;\n" as *byte, codegen.output as *void);
        fputs("        s->await_fut = " as *byte, codegen.output as *void);
        if await_operand_is_err_future != 0 && full_return_type != null && full_return_type.type == ASTNodeType.AST_TYPE_ERROR_UNION {
            const operand_union_c: &byte = c99_type_to_c(codegen, full_return_type);
            if operand_union_c != null {
                fprintf(codegen.output as *void, "({ %s _uya_await_tmp = " as *byte, operand_union_c as *byte);
                gen_expr(codegen, await_operands[0]);
                fprintf(codegen.output as *void, "; if (_uya_await_tmp.error_id != 0) return (%s){ ._tag = 1, .u = (%s){ .Ready = (%s){ .error_id = _uya_await_tmp.error_id } } }; _uya_await_tmp.value; })" as *byte, poll_ret_c as *byte, poll_union_c as *byte, ready_payload_c as *byte);
            } else {
                gen_expr(codegen, await_operands[0]);
            }
        } else {
            gen_expr(codegen, await_operands[0]);
        }
        fputs(";\n" as *byte, codegen.output as *void);
    } else {
        fputs("        s->state = 2;\n" as *byte, codegen.output as *void);
    }
    fputs("    }\n" as *byte, codegen.output as *void);

    var state_k: i32 = 1;
    while state_k <= await_count {
        fprintf(codegen.output as *void, "    if (s->state == %d) {\n" as *byte, state_k);
        fprintf(codegen.output as *void, "        %s p = ((struct uya_vtable_%s *)s->await_fut.vtable)->poll(s->await_fut.data, waker);\n" as *byte,
            poll_ret_c as *byte, child_vtable_safe as *byte);
        fprintf(codegen.output as *void, "        if (p._tag == 0) { return (%s){ ._tag = 0 }; }\n" as *byte, poll_ret_c as *byte);
        if inner_is_err_union != 0 {
            fprintf(codegen.output as *void, "        %s r = p.u.Ready;\n" as *byte, ready_payload_c as *byte);
            fprintf(codegen.output as *void, "        if (r.error_id != 0) { return (%s){ ._tag = 1, .u = (%s){ .Ready = r } }; }\n" as *byte, poll_ret_c as *byte, poll_union_c as *byte);
            const cur_bind_name: &byte = await_bind_names[state_k - 1];
            const cur_bind_type: &ASTNode = await_bind_types[state_k - 1];
            if cur_bind_name != null && cur_bind_type != null {
                const bind_safe: &byte = get_safe_c_identifier(codegen, cur_bind_name);
                fprintf(codegen.output as *void, "        %s = r.value;\n" as *byte, bind_safe as *byte);
            }
            if state_k < await_count {
                fputs("        s->state = " as *byte, codegen.output as *void);
                var next_state: i32 = state_k + 1;
                fprintf(codegen.output as *void, "%d;\n" as *byte, next_state);
                fputs("        s->await_fut = " as *byte, codegen.output as *void);
                var next_await_is_err_future: i32 = 0;
                if await_bind_types[state_k] != null && await_bind_types[state_k].type == ASTNodeType.AST_TYPE_NAMED &&
                    await_bind_types[state_k].type_named_name != null &&
                    strcmp(await_bind_types[state_k].type_named_name as *byte, "Future" as *byte) == 0 {
                    next_await_is_err_future = 1;
                }
                if next_await_is_err_future != 0 && full_return_type != null && full_return_type.type == ASTNodeType.AST_TYPE_ERROR_UNION {
                    const operand_union_c2: &byte = c99_type_to_c(codegen, full_return_type);
                    if operand_union_c2 != null {
                        fprintf(codegen.output as *void, "({ %s _uya_await_tmp = " as *byte, operand_union_c2 as *byte);
                        gen_expr(codegen, await_operands[state_k]);
                        fprintf(codegen.output as *void, "; if (_uya_await_tmp.error_id != 0) return (%s){ ._tag = 1, .u = (%s){ .Ready = (%s){ .error_id = _uya_await_tmp.error_id } } }; _uya_await_tmp.value; })" as *byte, poll_ret_c as *byte, poll_union_c as *byte, ready_payload_c as *byte);
                    } else {
                        gen_expr(codegen, await_operands[state_k]);
                    }
                } else {
                    gen_expr(codegen, await_operands[state_k]);
                }
                fputs(";\n" as *byte, codegen.output as *void);
            } else {
                // 最后一态：用 ret_expr 计算返回值。若函数返回 !Future<T> 则 ok 为 full_return_type，value 需 Future 装箱
                fputs("        s->state = " as *byte, codegen.output as *void);
                fprintf(codegen.output as *void, "%d;\n" as *byte, await_count + 1);
                var is_return_future_err: i32 = 0;
                if return_future_err_union != 0 && full_return_type != null && full_return_type.type == ASTNodeType.AST_TYPE_ERROR_UNION &&
                    full_return_type.type_error_union_payload_type != null {
                    const pl: &ASTNode = full_return_type.type_error_union_payload_type;
                    if pl.type == ASTNodeType.AST_TYPE_NAMED && pl.type_named_name != null &&
                        strcmp(pl.type_named_name as *byte, "Future" as *byte) == 0 {
                        is_return_future_err = 1;
                    }
                }
                if is_return_future_err != 0 {
                    const no_await_ret_c: &byte = c99_type_to_c(codegen, full_return_type);
                    if no_await_ret_c != null {
                        fprintf(codegen.output as *void, "        %s ok = (%s){ .error_id = 0, .value = " as *byte, no_await_ret_c as *byte, no_await_ret_c as *byte);
                        codegen.current_function_return_type = effective_return_type;
                        if ret_expr != null {
                            var is_future_literal: i32 = 0;
                            if ret_expr.type == ASTNodeType.AST_STRUCT_INIT && ret_expr.struct_init_struct_name != null &&
                                strcmp(ret_expr.struct_init_struct_name as *byte, "Future" as *byte) == 0 {
                                is_future_literal = 1;
                            }
                            if is_future_literal != 0 {
                                fprintf(codegen.output as *void, "({ struct %s _uya_f = " as *byte, concrete_future_safe as *byte);
                                gen_expr(codegen, ret_expr);
                                fprintf(codegen.output as *void, "; (%s){ .vtable = (void*)&uya_vtable_%s_%s, .data = (void*)&_uya_f }; })" as *byte, iface_c as *byte, concrete_future_safe as *byte, concrete_future_safe as *byte);
                            } else {
                                fprintf(codegen.output as *void, "({ struct %s _uya_f = (struct %s){ .state = (%s){ ._tag = 1, .u = (%s){ .Ready = " as *byte,
                                    concrete_future_safe as *byte, concrete_future_safe as *byte, inner_poll_ret_c as *byte, inner_poll_union_c as *byte);
                                gen_expr(codegen, ret_expr);
                                fprintf(codegen.output as *void, " } } }; (%s){ .vtable = (void*)&uya_vtable_%s_%s, .data = (void*)&_uya_f }; })" as *byte, iface_c as *byte, concrete_future_safe as *byte, concrete_future_safe as *byte);
                            }
                        } else {
                            fprintf(codegen.output as *void, "(%s){ .vtable = (void*)0, .data = (void*)0 }" as *byte, iface_c as *byte);
                        }
                        codegen.current_function_return_type = null;
                        fputs(" };\n" as *byte, codegen.output as *void);
                    }
                } else if inner.type_error_union_payload_type != null &&
                    inner.type_error_union_payload_type.type == ASTNodeType.AST_TYPE_NAMED &&
                    inner.type_error_union_payload_type.type_named_name != null &&
                    strcmp(inner.type_error_union_payload_type.type_named_name as *byte, "void" as *byte) == 0 {
                    fprintf(codegen.output as *void, "        %s ok = (%s){ .error_id = 0 };\n" as *byte, inner_err_c as *byte, inner_err_c as *byte);
                } else {
                    fprintf(codegen.output as *void, "        %s ok = (%s){ .error_id = 0, .value = " as *byte, inner_err_c as *byte, inner_err_c as *byte);
                    if ret_expr != null {
                        codegen.current_function_return_type = effective_return_type;
                        gen_expr(codegen, ret_expr);
                        codegen.current_function_return_type = null;
                    } else {
                        fputs("0" as *byte, codegen.output as *void);
                    }
                    fputs(" };\n" as *byte, codegen.output as *void);
                }
                fprintf(codegen.output as *void, "        return (%s){ ._tag = 1, .u = (%s){ .Ready = ok } };\n" as *byte, poll_ret_c as *byte, poll_union_c as *byte);
            }
        } else {
            const cur_bind_name2: &byte = await_bind_names[state_k - 1];
            if cur_bind_name2 != null {
                const bind_safe2: &byte = get_safe_c_identifier(codegen, cur_bind_name2);
                fprintf(codegen.output as *void, "        %s = p.u.Ready;\n" as *byte, bind_safe2 as *byte);
            }
            if state_k < await_count {
                fprintf(codegen.output as *void, "        s->state = %d;\n" as *byte, state_k + 1);
                fputs("        s->await_fut = " as *byte, codegen.output as *void);
                gen_expr(codegen, await_operands[state_k]);
                fputs(";\n" as *byte, codegen.output as *void);
            } else {
                fputs("        s->state = " as *byte, codegen.output as *void);
                fprintf(codegen.output as *void, "%d;\n" as *byte, await_count + 1);
                codegen.current_function_return_type = effective_return_type;
                fprintf(codegen.output as *void, "        return (%s){ ._tag = 1, .u = (%s){ .Ready = " as *byte, poll_ret_c as *byte, poll_union_c as *byte);
                if ret_expr != null {
                    gen_expr(codegen, ret_expr);
                } else {
                    fputs("0" as *byte, codegen.output as *void);
                }
                codegen.current_function_return_type = null;
                fputs(" } };\n" as *byte, codegen.output as *void);
            }
        }
        fputs("    }\n" as *byte, codegen.output as *void);
        state_k = state_k + 1;
    }

    // 无 await：计算返回值并返回 Ready(ok)
    if await_count == 0 {
        fputs("    {\n" as *byte, codegen.output as *void);
        if full_return_type != null && full_return_type.type == ASTNodeType.AST_TYPE_ERROR_UNION {
            // 返回 !Future<T> 且无 await：ok 为 full_return_type，poll 返回 Poll<!Future<T>>（safe_poll 已在上方按此设置）
            const no_await_ret_c: &byte = c99_type_to_c(codegen, full_return_type);
            if no_await_ret_c != null {
                fprintf(codegen.output as *void, "        %s ok = (%s){ .error_id = 0, .value = " as *byte, no_await_ret_c as *byte, no_await_ret_c as *byte);
                codegen.current_function_return_type = effective_return_type;
                if ret_expr != null {
                    var is_future_literal: i32 = 0;
                    if ret_expr.type == ASTNodeType.AST_STRUCT_INIT && ret_expr.struct_init_struct_name != null &&
                        strcmp(ret_expr.struct_init_struct_name as *byte, "Future" as *byte) == 0 {
                        is_future_literal = 1;
                    }
                    if is_future_literal != 0 {
                        fprintf(codegen.output as *void, "({ struct %s _uya_f = " as *byte, concrete_future_safe as *byte);
                        gen_expr(codegen, ret_expr);
                        fprintf(codegen.output as *void, "; (%s){ .vtable = (void*)&uya_vtable_%s_%s, .data = (void*)&_uya_f }; })" as *byte, iface_c as *byte, concrete_future_safe as *byte, concrete_future_safe as *byte);
                    } else {
                        fprintf(codegen.output as *void, "({ struct %s _uya_f = (struct %s){ .state = (%s){ ._tag = 1, .u = (%s){ .Ready = " as *byte,
                            concrete_future_safe as *byte, concrete_future_safe as *byte, inner_poll_ret_c as *byte, inner_poll_union_c as *byte);
                        gen_expr(codegen, ret_expr);
                        fprintf(codegen.output as *void, " } } }; (%s){ .vtable = (void*)&uya_vtable_%s_%s, .data = (void*)&_uya_f }; })" as *byte, iface_c as *byte, concrete_future_safe as *byte, concrete_future_safe as *byte);
                    }
                } else {
                    // 无 return 表达式：.value 为接口类型，显式零初始化（类型检查应保证 @async_fn 有 return 或本路径不可达）
                    fprintf(codegen.output as *void, "(%s){ .vtable = (void*)0, .data = (void*)0 }" as *byte, iface_c as *byte);
                }
                codegen.current_function_return_type = null;
                fputs(" };\n" as *byte, codegen.output as *void);
                fprintf(codegen.output as *void, "        return (%s){ ._tag = 1, .u = (%s){ .Ready = ok } };\n" as *byte, poll_ret_c as *byte, poll_union_c as *byte);
            } else {
                fprintf(codegen.output as *void, "        return (%s){ ._tag = 0 };\n" as *byte, poll_ret_c as *byte);
            }
        } else if inner_is_err_union != 0 {
            if inner.type_error_union_payload_type != null &&
                inner.type_error_union_payload_type.type == ASTNodeType.AST_TYPE_NAMED &&
                inner.type_error_union_payload_type.type_named_name != null &&
                strcmp(inner.type_error_union_payload_type.type_named_name as *byte, "void" as *byte) == 0 {
                fprintf(codegen.output as *void, "        %s ok = (%s){ .error_id = 0 };\n" as *byte, inner_err_c as *byte, inner_err_c as *byte);
            } else {
                fprintf(codegen.output as *void, "        %s ok = (%s){ .error_id = 0, .value = " as *byte, inner_err_c as *byte, inner_err_c as *byte);
                if ret_expr != null {
                    gen_expr(codegen, ret_expr);
                } else {
                    fputs("0" as *byte, codegen.output as *void);
                }
                fputs(" };\n" as *byte, codegen.output as *void);
            }
            fprintf(codegen.output as *void, "        return (%s){ ._tag = 1, .u = (%s){ .Ready = ok } };\n" as *byte, poll_ret_c as *byte, poll_union_c as *byte);
        } else {
            codegen.current_function_return_type = effective_return_type;
            fprintf(codegen.output as *void, "        return (%s){ ._tag = 1, .u = (%s){ .Ready = " as *byte, poll_ret_c as *byte, poll_union_c as *byte);
            if ret_expr != null {
                gen_expr(codegen, ret_expr);
            } else {
                fputs("0" as *byte, codegen.output as *void);
            }
            codegen.current_function_return_type = null;
            fputs(" } };\n" as *byte, codegen.output as *void);
        }
        fputs("    }\n" as *byte, codegen.output as *void);
    }
    fputs("}\n" as *byte, codegen.output as *void);

    // 无 await 且返回 !Future<T> 时 vtable 类型为 Future<!Future<T>>，需先给出完整定义再定义常量（否则 C 报 incomplete type）
    if strcmp(vtable_future_safe as *byte, safe_future as *byte) != 0 {
        var vtable_struct_name_buf: [byte: 128] = [];
        snprintf(&vtable_struct_name_buf[0] as *byte, 128, "uya_vtable_%s" as *byte, vtable_future_safe as *byte);
        const vtable_struct_name: &byte = &vtable_struct_name_buf[0] as &byte;
        if is_struct_defined(codegen, vtable_struct_name) == 0 {
            var iface_struct_name_buf: [byte: 128] = [];
            snprintf(&iface_struct_name_buf[0] as *byte, 128, "uya_interface_%s" as *byte, vtable_future_safe as *byte);
            fprintf(codegen.output as *void, "struct uya_interface_%s { void *vtable; void *data; };\n" as *byte, vtable_future_safe as *byte);
            fprintf(codegen.output as *void, "struct uya_vtable_%s {\n  %s (*poll)(void *self, struct Waker *);\n};\n" as *byte, vtable_future_safe as *byte, poll_ret_c as *byte);
            mark_struct_defined(codegen, &iface_struct_name_buf[0] as &byte);
            mark_struct_defined(codegen, vtable_struct_name);
        }
    }
    // vtable 常量
    fprintf(codegen.output as *void, "static const struct uya_vtable_%s %s = { (%s (*)(void *self, struct Waker *))&%s };\n" as *byte,
        vtable_future_safe as *byte, vtable_name as *byte, poll_ret_c as *byte, poll_name as *byte);

    // 输出原函数：分配状态机并返回；若声明为 !Future<T> 则包装为 err_union
    var wrapper_ret_c: &byte = iface_c;
    var need_wrap: i32 = 0;
    if full_return_type != null && full_return_type.type == ASTNodeType.AST_TYPE_ERROR_UNION {
        wrapper_ret_c = c99_type_to_c(codegen, full_return_type);
        if wrapper_ret_c != null && strstr(wrapper_ret_c as *byte, "err_union_" as *byte) != null {
            need_wrap = 1;
        }
    }
    fprintf(codegen.output as *void, "static __attribute__((unused)) %s %s(void" as *byte, wrapper_ret_c as *byte, func_c_name as *byte);
    fputs(") {\n" as *byte, codegen.output as *void);
    fprintf(codegen.output as *void, "    struct %s *s = (struct %s *)malloc(sizeof(struct %s));\n" as *byte, async_struct as *byte, async_struct as *byte, async_struct as *byte);
    fputs("    if (s != (void*)0) { s->state = 0; __builtin_memset((void *)&s->await_fut, 0, sizeof(s->await_fut)); }\n" as *byte, codegen.output as *void);
    if need_wrap != 0 {
        fprintf(codegen.output as *void, "    return (%s){ .error_id = 0, .value = (%s){ .vtable = (void*)&%s, .data = (void*)s } };\n" as *byte, wrapper_ret_c as *byte, iface_c as *byte, vtable_name as *byte);
    } else {
        fprintf(codegen.output as *void, "    return (%s){ .vtable = (void*)&%s, .data = (void*)s };\n" as *byte, iface_c as *byte, vtable_name as *byte);
    }
    fputs("}\n" as *byte, codegen.output as *void);
}

// 是否该结构体类型有 drop 方法（规范 §12）
fn type_has_drop_c99(codegen: &C99CodeGenerator, struct_name: &byte) i32 {
    if find_method_in_struct_c99(codegen, struct_name, "drop" as *byte) != null {
        return 1;
    }
    return 0;
}

// 生成方法函数的前向声明（uya_StructName_methodname）
fn gen_method_prototype(codegen: &C99CodeGenerator, fn_decl: &ASTNode, struct_name: &byte) void {
    if fn_decl == null || fn_decl.type != ASTNodeType.AST_FN_DECL || struct_name == null {
        return;
    }
    const method_name: &byte = fn_decl.fn_decl_name;
    const c_name: &byte = get_method_c_name(codegen, struct_name, method_name);
    if c_name == null {
        return;
    }
    var return_c: &byte = convert_array_return_type(codegen, fn_decl.fn_decl_return_type);
    return_c = normalize_poll_return_type(codegen, return_c);
    const params: & & ASTNode = fn_decl.fn_decl_params;
    const param_count: i32 = fn_decl.fn_decl_param_count;
    fprintf(codegen.output as *void, "%s %s(" as *byte, return_c as *byte, c_name as *byte);
    var i: i32 = 0;
    while i < param_count {
        const param: &ASTNode = params[i];
        if param == null || param.type != ASTNodeType.AST_VAR_DECL {
            i = i + 1;
            continue;
        }
        const param_name: &byte = get_safe_c_identifier(codegen, param.var_decl_name);
        var const_self: i32 = 0;
        if i == 0 { const_self = 1; }
        const param_type_c: &byte = c99_type_to_c_with_self_opt(codegen, param.var_decl_type, struct_name, const_self);
        format_param_type(codegen, param_type_c, param_name, codegen.output as *void);
        if i < param_count - 1 {
            c99_emit_comma_space(codegen);
        }
        i = i + 1;
    }
    fputs(");\n" as *byte, codegen.output as *void);
}

// 生成方法函数定义（uya_StructName_methodname）
fn gen_method_function(codegen: &C99CodeGenerator, fn_decl: &ASTNode, struct_name: &byte) void {
    if fn_decl == null || fn_decl.type != ASTNodeType.AST_FN_DECL || struct_name == null || fn_decl.fn_decl_body == null {
        return;
    }
    const method_name: &byte = fn_decl.fn_decl_name;
    const c_name: &byte = get_method_c_name(codegen, struct_name, method_name);
    if c_name == null {
        return;
    }
    var return_c: &byte = convert_array_return_type(codegen, fn_decl.fn_decl_return_type);
    return_c = normalize_poll_return_type(codegen, return_c);
    const params: & & ASTNode = fn_decl.fn_decl_params;
    const param_count: i32 = fn_decl.fn_decl_param_count;
    emit_line_directive(codegen, fn_decl.line, fn_decl.filename);
    fprintf(codegen.output as *void, "%s %s(" as *byte, return_c as *byte, c_name as *byte);
    var i: i32 = 0;
    while i < param_count {
        const param: &ASTNode = params[i];
        if param == null || param.type != ASTNodeType.AST_VAR_DECL {
            i = i + 1;
            continue;
        }
        const param_name: &byte = get_safe_c_identifier(codegen, param.var_decl_name);
        var const_self: i32 = 0;
        if i == 0 { const_self = 1; }
        const param_type_c: &byte = c99_type_to_c_with_self_opt(codegen, param.var_decl_type, struct_name, const_self);
        format_param_type(codegen, param_type_c, param_name, codegen.output as *void);
        if i < param_count - 1 {
            c99_emit_comma_space(codegen);
        }
        i = i + 1;
    }
    fputs(") {\n" as *byte, codegen.output as *void);
    codegen.indent_level = codegen.indent_level + 1;
    codegen.current_function_return_type = fn_decl.fn_decl_return_type;
    const saved_current_function_decl: &ASTNode = codegen.current_function_decl;
    codegen.current_function_decl = fn_decl;
    const saved_method_struct: &byte = codegen.current_method_struct_name;
    codegen.current_method_struct_name = struct_name;
    const saved_local_count: i32 = codegen.local_variable_count;
    const saved_depth: i32 = codegen.current_depth;
    codegen.local_variable_count = 0;
    codegen.current_depth = 0;
    i = 0;
    while i < param_count {
        const param: &ASTNode = params[i];
        if param != null && param.type == ASTNodeType.AST_VAR_DECL {
            const param_name: &byte = get_safe_c_identifier(codegen, param.var_decl_name);
            var const_self: i32 = 0;
        if i == 0 { const_self = 1; }
        const param_type_c: &byte = c99_type_to_c_with_self_opt(codegen, param.var_decl_type, struct_name, const_self);
            if param_name != null && param_type_c != null && codegen.local_variable_count < C99_MAX_LOCAL_VARS {
                codegen.local_variables[codegen.local_variable_count].name = param.var_decl_name;
                codegen.local_variables[codegen.local_variable_count].type_c = param_type_c;
                codegen.local_variable_count = codegen.local_variable_count + 1;
            }
        }
        i = i + 1;
    }
    if method_name != null && strcmp(method_name as *byte, "drop" as *byte) == 0 {
        const struct_decl: &ASTNode = find_struct_decl_c99(codegen, struct_name);
        const self_safe: &byte = get_safe_c_identifier(codegen, "self" as *byte);
        if struct_decl != null && struct_decl.struct_decl_fields != null && self_safe != null {
            const fc: i32 = struct_decl.struct_decl_field_count;
            var fi: i32 = fc - 1;
            while fi >= 0 {
                const field: &ASTNode = struct_decl.struct_decl_fields[fi];
                if field == null || field.type != ASTNodeType.AST_VAR_DECL || field.var_decl_name == null {
                    fi = fi - 1;
                    continue;
                }
                const ft: &ASTNode = field.var_decl_type;
                if ft == null || ft.type != ASTNodeType.AST_TYPE_NAMED || ft.type_named_name == null {
                    fi = fi - 1;
                    continue;
                }
                const field_type_name: &byte = ft.type_named_name;
                if type_has_drop_c99(codegen, field_type_name) == 0 {
                    fi = fi - 1;
                    continue;
                }
                const drop_c: &byte = get_method_c_name(codegen, field_type_name, "drop" as *byte);
                const field_safe: &byte = get_safe_c_identifier(codegen, field.var_decl_name);
                if drop_c != null && field_safe != null {
                    c99_emit_indent(codegen);
                    fprintf(codegen.output as *void, "/* drop field */ %s(%s.%s);\n" as *byte, drop_c as *byte, self_safe as *byte, field_safe as *byte);
                }
                fi = fi - 1;
            }
        }
    }
    gen_stmt(codegen, fn_decl.fn_decl_body);
    
    // 检查函数体是否以 return 结尾
    var has_return: i32 = 0;
    if fn_decl.fn_decl_body != null && fn_decl.fn_decl_body.type == ASTNodeType.AST_BLOCK {
        const stmts: & & ASTNode = fn_decl.fn_decl_body.block_stmts;
        const stmt_count: i32 = fn_decl.fn_decl_body.block_stmt_count;
        var j: i32 = stmt_count - 1;
        while j >= 0 {
            const s: &ASTNode = stmts[j];
            if s != null && s.type != ASTNodeType.AST_DEFER_STMT && s.type != ASTNodeType.AST_ERRDEFER_STMT {
                if s.type == ASTNodeType.AST_RETURN_STMT {
                    has_return = 1;
                } else {
                    has_return = 0;
                }
                break;
            }
            j = j - 1;
        }
    }
    
    // 如果返回类型是 !void 且函数体没有显式返回，添加默认返回语句
    if has_return == 0 && fn_decl.fn_decl_return_type != null && fn_decl.fn_decl_return_type.type == ASTNodeType.AST_TYPE_ERROR_UNION {
        const payload_node: &ASTNode = fn_decl.fn_decl_return_type.type_error_union_payload_type;
        var is_void_payload: i32 = 0;
        if payload_node == null {
            is_void_payload = 1;
        } else if payload_node.type == ASTNodeType.AST_TYPE_NAMED && payload_node.type_named_name != null &&
            strcmp(payload_node.type_named_name as *byte, "void" as *byte) == 0 {
            is_void_payload = 1;
        }
        if is_void_payload != 0 {
            // !void 类型：返回成功的错误联合（缩进与 C 编译器一致）
            codegen.indent_level = codegen.indent_level + 1;
            c99_emit_indent(codegen);
            fprintf(codegen.output as *void, "return (%s){ .error_id = 0 };\n" as *byte, return_c as *byte);
            codegen.indent_level = codegen.indent_level - 1;
        }
    }
    
    codegen.current_function_return_type = null;
    codegen.current_function_decl = saved_current_function_decl;
    codegen.current_method_struct_name = saved_method_struct;
    codegen.local_variable_count = saved_local_count;
    codegen.current_depth = saved_depth;
    codegen.indent_level = codegen.indent_level - 1;
    c99_emit_indent(codegen);
    c99_emit_close_brace_newline(codegen);
}

// 检查函数是否是泛型函数（有类型参数）
fn is_generic_function_c99(fn_decl: &ASTNode) i32 {
    if fn_decl == null || fn_decl.type != ASTNodeType.AST_FN_DECL {
        return 0;
    }
    if fn_decl.fn_decl_type_param_count > 0 {
        return 1;
    }
    return 0;
}

// 获取单态化函数名称
// 例如：identity<i32> -> identity_i32
fn get_mono_function_name(codegen: &C99CodeGenerator, generic_name: &byte, type_args: & & ASTNode, type_arg_count: i32) &byte {
    if codegen == null || generic_name == null || type_args == null || type_arg_count <= 0 {
        return generic_name;
    }
    
    // 构建后缀
    var suffix: [byte: TEMP_BUF_SIZE] = [0: TEMP_BUF_SIZE];
    var suffix_len: i32 = 0;
    
    var i: i32 = 0;
    while i < type_arg_count {
        if i > 0 {
            if suffix_len >= 0 && suffix_len < TEMP_BUF_LIMIT {
                suffix[suffix_len] = 95 as byte;  // '_' = 95
            }
            suffix_len = suffix_len + 1;
        }

        const type_arg: &ASTNode = type_args[i];
        suffix_len = append_type_arg_suffix(codegen, type_arg, &suffix[0], suffix_len, TEMP_BUF_SIZE);
        i = i + 1;
    }
    if suffix_len >= 0 && suffix_len < TEMP_BUF_SIZE {
        suffix[suffix_len] = 0;
    }
    
    // 分配并构建完整名称
    // 注意：函数名要走模块前缀逻辑（例如 std.async.ok<i32> -> std_async_ok_i32）
    const base_name: &byte = get_c_name_for_global_function(codegen, generic_name, 0);
    const safe_name: &byte = get_safe_c_identifier(codegen, base_name);
    const name_len: usize = (strlen(safe_name as *byte) as usize) + 1 + (suffix_len as usize) + 1;
    const mono_name: &byte = arena_alloc(codegen.arena, name_len) as &byte;
    if mono_name == null {
        return generic_name;
    }
    snprintf(mono_name as *byte, name_len, "%s_%s" as *byte, safe_name as *byte, (&suffix[0]) as *byte);
    
    return mono_name;
}

// 在单态化上下文中将类型参数替换为具体类型
fn substitute_type_arg(codegen: &C99CodeGenerator, type_node: &ASTNode) &ASTNode {
    if codegen == null || type_node == null {
        return type_node;
    }
    
    // 如果不在单态化上下文中，直接返回
    if codegen.current_type_params == null || codegen.current_type_param_count == 0 {
        return type_node;
    }
    
    // 对于命名类型，检查是否是类型参数
    if type_node.type == ASTNodeType.AST_TYPE_NAMED && type_node.type_named_name != null {
        const name: &byte = type_node.type_named_name;
        var i: i32 = 0;
        while i < codegen.current_type_param_count {
            if codegen.current_type_params[i].name != null &&
                strcmp(codegen.current_type_params[i].name as *byte, name as *byte) == 0 {
                // 找到匹配的类型参数，返回对应的类型实参
                if codegen.current_type_args != null && i < codegen.current_type_arg_count {
                    return codegen.current_type_args[i];
                }
            }
            i = i + 1;
        }
    }
    
    // 递归处理指针类型 (&T 或 *T)
    if type_node.type == ASTNodeType.AST_TYPE_POINTER && type_node.type_pointer_pointed_type != null {
        const inner_substituted: &ASTNode = substitute_type_arg(codegen, type_node.type_pointer_pointed_type);
        // 如果内部类型被替换了，创建新的指针类型节点
        if inner_substituted != type_node.type_pointer_pointed_type {
            const new_node: &ASTNode = arena_alloc(codegen.arena, @size_of(ASTNode)) as &ASTNode;
            if new_node != null {
                new_node.type = ASTNodeType.AST_TYPE_POINTER;
                new_node.line = type_node.line;
                new_node.column = type_node.column;
                new_node.type_pointer_pointed_type = inner_substituted;
                new_node.type_pointer_is_ffi_pointer = type_node.type_pointer_is_ffi_pointer;
                return new_node;
            }
        }
    }
    
    // 递归处理数组类型 [T: N]
    if type_node.type == ASTNodeType.AST_TYPE_ARRAY && type_node.type_array_element_type != null {
        const elem_substituted: &ASTNode = substitute_type_arg(codegen, type_node.type_array_element_type);
        if elem_substituted != type_node.type_array_element_type {
            const new_node: &ASTNode = arena_alloc(codegen.arena, @size_of(ASTNode)) as &ASTNode;
            if new_node != null {
                new_node.type = ASTNodeType.AST_TYPE_ARRAY;
                new_node.line = type_node.line;
                new_node.column = type_node.column;
                new_node.type_array_element_type = elem_substituted;
                new_node.type_array_size_expr = type_node.type_array_size_expr;
                return new_node;
            }
        }
    }
    
    // 递归处理错误联合类型 !T（payload 可能包含类型参数）
    if type_node.type == ASTNodeType.AST_TYPE_ERROR_UNION && type_node.type_error_union_payload_type != null {
        const payload_substituted: &ASTNode = substitute_type_arg(codegen, type_node.type_error_union_payload_type);
        if payload_substituted != type_node.type_error_union_payload_type {
            const new_node: &ASTNode = arena_alloc(codegen.arena, @size_of(ASTNode)) as &ASTNode;
            if new_node != null {
                new_node.type = ASTNodeType.AST_TYPE_ERROR_UNION;
                new_node.line = type_node.line;
                new_node.column = type_node.column;
                new_node.type_error_union_payload_type = payload_substituted;
                return new_node;
            }
        }
    }
    
    return type_node;
}

// 获取类型的 C 表示（支持类型参数替换）
fn c99_mono_type_to_c(codegen: &C99CodeGenerator, type_node: &ASTNode) &byte {
    const substituted: &ASTNode = substitute_type_arg(codegen, type_node);
    return c99_type_to_c(codegen, substituted);
}

// 生成单态化函数原型
fn gen_mono_function_prototype(codegen: &C99CodeGenerator, fn_decl: &ASTNode, type_args: & & ASTNode, type_arg_count: i32) void {
    if fn_decl == null || fn_decl.type != ASTNodeType.AST_FN_DECL || type_args == null {
        return;
    }
    
    const orig_name: &byte = fn_decl.fn_decl_name;
    const mono_name: &byte = get_mono_function_name(codegen, orig_name, type_args, type_arg_count);
    const return_type: &ASTNode = fn_decl.fn_decl_return_type;
    const params: & & ASTNode = fn_decl.fn_decl_params;
    const param_count: i32 = fn_decl.fn_decl_param_count;
    const is_varargs: i32 = fn_decl.fn_decl_is_varargs;
    
    // 保存并设置单态化上下文
    const saved_type_params: &TypeParam = codegen.current_type_params;
    const saved_type_param_count: i32 = codegen.current_type_param_count;
    const saved_type_args: & & ASTNode = codegen.current_type_args;
    const saved_type_arg_count: i32 = codegen.current_type_arg_count;
    
    codegen.current_type_params = fn_decl.fn_decl_type_params;
    codegen.current_type_param_count = fn_decl.fn_decl_type_param_count;
    codegen.current_type_args = type_args;
    codegen.current_type_arg_count = type_arg_count;
    
    // 返回类型（替换类型参数）
    const return_c: &byte = c99_mono_type_to_c(codegen, return_type);
    
    fprintf(codegen.output as *void, "%s %s(" as *byte, return_c as *byte, mono_name as *byte);
    
    // 参数列表
    var i: i32 = 0;
    while i < param_count {
        const param: &ASTNode = params[i];
        if param == null || param.type != ASTNodeType.AST_VAR_DECL {
            i = i + 1;
            continue;
        }
        
        const param_name: &byte = get_safe_c_identifier(codegen, param.var_decl_name);
        const param_type: &ASTNode = param.var_decl_type;
        const param_type_c: &byte = c99_mono_type_to_c(codegen, param_type);
        
        format_param_type(codegen, param_type_c, param_name, codegen.output);
        if i < param_count - 1 {
            c99_emit_comma_space(codegen);
        }
        i = i + 1;
    }
    
    // 处理可变参数
    if is_varargs != 0 {
        if param_count > 0 {
            c99_emit_comma_space(codegen);
        }
        fputs("..." as *byte, codegen.output as *void);
    }
    
    fputs(");\n" as *byte, codegen.output as *void);
    
    // 恢复上下文
    codegen.current_type_params = saved_type_params;
    codegen.current_type_param_count = saved_type_param_count;
    codegen.current_type_args = saved_type_args;
    codegen.current_type_arg_count = saved_type_arg_count;
}

// 生成单态化函数定义
fn gen_mono_function(codegen: &C99CodeGenerator, fn_decl: &ASTNode, type_args: & & ASTNode, type_arg_count: i32) void {
    if fn_decl == null || fn_decl.type != ASTNodeType.AST_FN_DECL || type_args == null {
        return;
    }
    
    const orig_name: &byte = fn_decl.fn_decl_name;
    const mono_name: &byte = get_mono_function_name(codegen, orig_name, type_args, type_arg_count);
    const return_type: &ASTNode = fn_decl.fn_decl_return_type;
    const params: & & ASTNode = fn_decl.fn_decl_params;
    const param_count: i32 = fn_decl.fn_decl_param_count;
    const is_varargs: i32 = fn_decl.fn_decl_is_varargs;
    const body: &ASTNode = fn_decl.fn_decl_body;
    
    // 如果没有函数体，跳过
    if body == null {
        return;
    }
    
    // 保存并设置单态化上下文
    const saved_type_params: &TypeParam = codegen.current_type_params;
    const saved_type_param_count: i32 = codegen.current_type_param_count;
    const saved_type_args: & & ASTNode = codegen.current_type_args;
    const saved_type_arg_count: i32 = codegen.current_type_arg_count;
    
    codegen.current_type_params = fn_decl.fn_decl_type_params;
    codegen.current_type_param_count = fn_decl.fn_decl_type_param_count;
    codegen.current_type_args = type_args;
    codegen.current_type_arg_count = type_arg_count;
    
    // 生成 #line 指令
    emit_line_directive(codegen, fn_decl.line, fn_decl.filename);
    
    // 返回类型（替换类型参数）
    const return_c: &byte = c99_mono_type_to_c(codegen, return_type);
    
    fprintf(codegen.output as *void, "%s %s(" as *byte, return_c as *byte, mono_name as *byte);
    
    // 参数列表
    var i: i32 = 0;
    while i < param_count {
        const param: &ASTNode = params[i];
        if param == null || param.type != ASTNodeType.AST_VAR_DECL {
            i = i + 1;
            continue;
        }
        
        const param_name: &byte = get_safe_c_identifier(codegen, param.var_decl_name);
        const param_type: &ASTNode = param.var_decl_type;
        const param_type_c: &byte = c99_mono_type_to_c(codegen, param_type);
        
        format_param_type(codegen, param_type_c, param_name, codegen.output);
        if i < param_count - 1 {
            c99_emit_comma_space(codegen);
        }
        i = i + 1;
    }
    
    // 处理可变参数
    if is_varargs != 0 {
        if param_count > 0 {
            c99_emit_comma_space(codegen);
        }
        fputs("..." as *byte, codegen.output as *void);
    }
    
    fputs(") {\n" as *byte, codegen.output as *void);
    
    // 保存当前状态
    const saved_return_type: &ASTNode = codegen.current_function_return_type;
    const saved_current_function_decl: &ASTNode = codegen.current_function_decl;
    const saved_local_count: i32 = codegen.local_variable_count;
    const saved_depth: i32 = codegen.current_depth;
    
    codegen.current_function_return_type = return_type;
    codegen.current_function_decl = fn_decl;
    codegen.indent_level = codegen.indent_level + 1;
    codegen.current_depth = codegen.current_depth + 1;
    
    // 将参数添加到局部变量表
    i = 0;
    while i < param_count {
        const param: &ASTNode = params[i];
        if param != null && param.type == ASTNodeType.AST_VAR_DECL {
            if codegen.local_variable_count < C99_MAX_LOCAL_VARS {
                codegen.local_variables[codegen.local_variable_count].name = param.var_decl_name;
                codegen.local_variables[codegen.local_variable_count].type_c = c99_mono_type_to_c(codegen, param.var_decl_type);
                codegen.local_variables[codegen.local_variable_count].depth = codegen.current_depth;
                codegen.local_variable_count = codegen.local_variable_count + 1;
            }
        }
        i = i + 1;
    }
    i = 0;
    while i < param_count {
        const param: &ASTNode = params[i];
        if param != null && param.type == ASTNodeType.AST_VAR_DECL {
            const pname: &byte = get_safe_c_identifier(codegen, param.var_decl_name);
            if pname != null {
                c99_emit_indent(codegen);
                fputs("(void)" as *byte, codegen.output as *void);
                fputs(pname as *byte, codegen.output as *void);
                c99_emit_semi_newline(codegen);
            }
        }
        i = i + 1;
    }
    
    // 生成函数体
    gen_stmt(codegen, body);
    
    // 若返回类型非 void 且函数体末尾无 return，补兜底 return 避免 -Wreturn-type
    var has_return_mono: i32 = 0;
    if body.type == ASTNodeType.AST_BLOCK && body.block_stmts != null {
        const stmts_mono: & & ASTNode = body.block_stmts;
        const stmt_count_mono: i32 = body.block_stmt_count;
        var j: i32 = stmt_count_mono - 1;
        while j >= 0 {
            const s: &ASTNode = stmts_mono[j];
            if s != null && s.type != ASTNodeType.AST_DEFER_STMT && s.type != ASTNodeType.AST_ERRDEFER_STMT {
                if s.type == ASTNodeType.AST_RETURN_STMT {
                    has_return_mono = 1;
                }
                j = -1;
                break;
            }
            j = j - 1;
        }
    }
    const rt: &ASTNode = codegen.current_function_return_type;
    if has_return_mono == 0 && rt != null {
        var is_void_mono: i32 = 0;
        if rt.type == ASTNodeType.AST_TYPE_NAMED && rt.type_named_name != null &&
            strcmp(rt.type_named_name as *byte, "void" as *byte) == 0 {
            is_void_mono = 1;
        } else if rt.type == ASTNodeType.AST_TYPE_ERROR_UNION {
            const pl: &ASTNode = rt.type_error_union_payload_type;
            if pl == null {
                is_void_mono = 1;
            } else if pl.type == ASTNodeType.AST_TYPE_NAMED && pl.type_named_name != null &&
                strcmp(pl.type_named_name as *byte, "void" as *byte) == 0 {
                is_void_mono = 1;
            }
        }
        if is_void_mono == 0 {
            codegen.indent_level = codegen.indent_level + 1;
            c99_emit_indent(codegen);
            if return_c != null && strncmp(return_c as *byte, "struct " as *byte, 7) == 0 {
                fprintf(codegen.output as *void, "return (%s){0};\n" as *byte, return_c as *byte);
            } else {
                fputs("return 0;\n" as *byte, codegen.output as *void);
            }
            codegen.indent_level = codegen.indent_level - 1;
        }
    }
    
    // 恢复状态
    codegen.current_function_return_type = saved_return_type;
    codegen.current_function_decl = saved_current_function_decl;
    codegen.local_variable_count = saved_local_count;
    codegen.current_depth = saved_depth;
    codegen.indent_level = codegen.indent_level - 1;
    
    c99_emit_close_brace_newline(codegen);
    
    // 恢复单态化上下文
    codegen.current_type_params = saved_type_params;
    codegen.current_type_param_count = saved_type_param_count;
    codegen.current_type_args = saved_type_args;
    codegen.current_type_arg_count = saved_type_arg_count;
}

// 生成单态化方法原型
fn gen_mono_method_prototype(codegen: &C99CodeGenerator, fn_decl: &ASTNode, struct_name: &byte, type_args: & & ASTNode, type_arg_count: i32) void {
    if fn_decl == null || fn_decl.type != ASTNodeType.AST_FN_DECL || type_args == null || struct_name == null {
        return;
    }
    
    const method_name: &byte = fn_decl.fn_decl_name;
    
    // 构建单态化方法名
    var mono_name_buf: [byte: C99_TYPE_ARG_BUF_SIZE] = [];
    var pos: i32 = snprintf(&mono_name_buf[0] as *byte, C99_TYPE_ARG_BUF_SIZE, "%s_%s" as *byte, struct_name as *byte, method_name as *byte);
    var ti: i32 = 0;
    while ti < type_arg_count && pos < C99_TYPE_ARG_BUF_LIMIT {
        pos = pos + snprintf(&mono_name_buf[pos] as *byte, C99_TYPE_ARG_BUF_SIZE - pos, "_" as *byte);
        const type_arg: &ASTNode = type_args[ti];
        if type_arg != null && type_arg.type == ASTNodeType.AST_TYPE_NAMED && type_arg.type_named_name != null {
            pos = pos + snprintf(&mono_name_buf[pos] as *byte, C99_TYPE_ARG_BUF_SIZE - pos, "%s" as *byte, type_arg.type_named_name as *byte);
        }
        ti = ti + 1;
    }
    const mono_method_name: &byte = get_safe_c_identifier(codegen, &mono_name_buf[0]);
    
    // 保存方法的类型参数上下文
    const saved_type_params: &TypeParam = codegen.current_type_params;
    const saved_type_param_count: i32 = codegen.current_type_param_count;
    const saved_type_args: & & ASTNode = codegen.current_type_args;
    const saved_type_arg_count: i32 = codegen.current_type_arg_count;
    
    // 设置方法的类型参数上下文（结构体的类型参数上下文已经在外层设置）
    codegen.current_type_params = fn_decl.fn_decl_type_params;
    codegen.current_type_param_count = fn_decl.fn_decl_type_param_count;
    codegen.current_type_args = type_args;
    codegen.current_type_arg_count = type_arg_count;
    
    // 使用 c99_type_to_c_with_self 来正确处理 Self 类型
    const return_c: &byte = c99_type_to_c_with_self(codegen, fn_decl.fn_decl_return_type, struct_name);
    const params: & & ASTNode = fn_decl.fn_decl_params;
    const param_count: i32 = fn_decl.fn_decl_param_count;
    
    fprintf(codegen.output as *void, "%s %s(" as *byte, return_c as *byte, mono_method_name as *byte);
    
    var i: i32 = 0;
    while i < param_count {
        const param: &ASTNode = params[i];
        if param == null || param.type != ASTNodeType.AST_VAR_DECL {
            i = i + 1;
            continue;
        }
        
        const param_name: &byte = get_safe_c_identifier(codegen, param.var_decl_name);
        const param_type_c: &byte = c99_type_to_c_with_self(codegen, param.var_decl_type, struct_name);
        
        format_param_type(codegen, param_type_c, param_name, codegen.output);
        if i < param_count - 1 {
            c99_emit_comma_space(codegen);
        }
        i = i + 1;
    }
    
    fputs(");\n" as *byte, codegen.output as *void);
    
    // 恢复方法的类型参数上下文
    codegen.current_type_params = saved_type_params;
    codegen.current_type_param_count = saved_type_param_count;
    codegen.current_type_args = saved_type_args;
    codegen.current_type_arg_count = saved_type_arg_count;
}

// 生成单态化方法函数定义
fn gen_mono_method_function(codegen: &C99CodeGenerator, fn_decl: &ASTNode, struct_name: &byte, type_args: & & ASTNode, type_arg_count: i32) void {
    if fn_decl == null || fn_decl.type != ASTNodeType.AST_FN_DECL || type_args == null || struct_name == null || fn_decl.fn_decl_body == null {
        return;
    }
    
    const method_name: &byte = fn_decl.fn_decl_name;
    
    // 构建单态化方法名
    var mono_name_buf: [byte: C99_TYPE_ARG_BUF_SIZE] = [];
    var pos: i32 = snprintf(&mono_name_buf[0] as *byte, C99_TYPE_ARG_BUF_SIZE, "%s_%s" as *byte, struct_name as *byte, method_name as *byte);
    var ti: i32 = 0;
    while ti < type_arg_count && pos < C99_TYPE_ARG_BUF_LIMIT {
        pos = pos + snprintf(&mono_name_buf[pos] as *byte, C99_TYPE_ARG_BUF_SIZE - pos, "_" as *byte);
        const type_arg: &ASTNode = type_args[ti];
        if type_arg != null && type_arg.type == ASTNodeType.AST_TYPE_NAMED && type_arg.type_named_name != null {
            pos = pos + snprintf(&mono_name_buf[pos] as *byte, C99_TYPE_ARG_BUF_SIZE - pos, "%s" as *byte, type_arg.type_named_name as *byte);
        }
        ti = ti + 1;
    }
    const mono_method_name: &byte = get_safe_c_identifier(codegen, &mono_name_buf[0]);
    
    const return_type: &ASTNode = fn_decl.fn_decl_return_type;
    const params: & & ASTNode = fn_decl.fn_decl_params;
    const param_count: i32 = fn_decl.fn_decl_param_count;
    const body: &ASTNode = fn_decl.fn_decl_body;
    
    // 保存方法的类型参数上下文
    const saved_type_params: &TypeParam = codegen.current_type_params;
    const saved_type_param_count: i32 = codegen.current_type_param_count;
    const saved_type_args: & & ASTNode = codegen.current_type_args;
    const saved_type_arg_count: i32 = codegen.current_type_arg_count;
    
    // 设置方法的类型参数上下文（结构体的类型参数上下文已经在外层设置）
    codegen.current_type_params = fn_decl.fn_decl_type_params;
    codegen.current_type_param_count = fn_decl.fn_decl_type_param_count;
    codegen.current_type_args = type_args;
    codegen.current_type_arg_count = type_arg_count;
    
    emit_line_directive(codegen, fn_decl.line, fn_decl.filename);
    
    // 使用 c99_type_to_c_with_self 来正确处理 Self 类型
    const return_c: &byte = c99_type_to_c_with_self(codegen, return_type, struct_name);
    
    fprintf(codegen.output as *void, "%s %s(" as *byte, return_c as *byte, mono_method_name as *byte);
    
    var i: i32 = 0;
    while i < param_count {
        const param: &ASTNode = params[i];
        if param == null || param.type != ASTNodeType.AST_VAR_DECL {
            i = i + 1;
            continue;
        }
        
        const param_name: &byte = get_safe_c_identifier(codegen, param.var_decl_name);
        const param_type_c: &byte = c99_type_to_c_with_self(codegen, param.var_decl_type, struct_name);
        
        format_param_type(codegen, param_type_c, param_name, codegen.output);
        if i < param_count - 1 {
            c99_emit_comma_space(codegen);
        }
        i = i + 1;
    }
    
    fputs(") {\n" as *byte, codegen.output as *void);
    
    // 保存当前状态
    const saved_return_type: &ASTNode = codegen.current_function_return_type;
    const saved_current_function_decl: &ASTNode = codegen.current_function_decl;
    const saved_local_count: i32 = codegen.local_variable_count;
    const saved_depth: i32 = codegen.current_depth;
    
    codegen.current_function_return_type = return_type;
    codegen.current_function_decl = fn_decl;
    codegen.indent_level = codegen.indent_level + 1;
    codegen.current_depth = codegen.current_depth + 1;
    
    // 将参数添加到局部变量表
    i = 0;
    while i < param_count {
        const param: &ASTNode = params[i];
        if param != null && param.type == ASTNodeType.AST_VAR_DECL {
            if codegen.local_variable_count < C99_MAX_LOCAL_VARS {
                codegen.local_variables[codegen.local_variable_count].name = param.var_decl_name;
                codegen.local_variables[codegen.local_variable_count].type_c = c99_type_to_c_with_self(codegen, param.var_decl_type, struct_name);
                codegen.local_variables[codegen.local_variable_count].depth = codegen.current_depth;
                codegen.local_variable_count = codegen.local_variable_count + 1;
            }
        }
        i = i + 1;
    }
    
    i = 0;
    while i < param_count {
        const param: &ASTNode = params[i];
        if param != null && param.type == ASTNodeType.AST_VAR_DECL {
            const pname: &byte = get_safe_c_identifier(codegen, param.var_decl_name);
            if pname != null {
                c99_emit_indent(codegen);
                fputs("(void)" as *byte, codegen.output as *void);
                fputs(pname as *byte, codegen.output as *void);
                c99_emit_semi_newline(codegen);
            }
        }
        i = i + 1;
    }
    
    // 生成函数体
    gen_stmt(codegen, body);
    
    // 若返回类型非 void 且函数体末尾无 return，补兜底 return
    var has_return_mono: i32 = 0;
    if body.type == ASTNodeType.AST_BLOCK && body.block_stmts != null {
        const stmts_mono: & & ASTNode = body.block_stmts;
        const stmt_count_mono: i32 = body.block_stmt_count;
        var j: i32 = stmt_count_mono - 1;
        while j >= 0 {
            const s: &ASTNode = stmts_mono[j];
            if s != null && s.type != ASTNodeType.AST_DEFER_STMT && s.type != ASTNodeType.AST_ERRDEFER_STMT {
                if s.type == ASTNodeType.AST_RETURN_STMT {
                    has_return_mono = 1;
                }
                j = -1;
                break;
            }
            j = j - 1;
        }
    }
    const rt: &ASTNode = codegen.current_function_return_type;
    if has_return_mono == 0 && rt != null {
        var is_void_mono: i32 = 0;
        if rt.type == ASTNodeType.AST_TYPE_NAMED && rt.type_named_name != null &&
            strcmp(rt.type_named_name as *byte, "void" as *byte) == 0 {
            is_void_mono = 1;
        } else if rt.type == ASTNodeType.AST_TYPE_ERROR_UNION {
            const pl: &ASTNode = rt.type_error_union_payload_type;
            if pl == null {
                is_void_mono = 1;
            } else if pl.type == ASTNodeType.AST_TYPE_NAMED && pl.type_named_name != null &&
                strcmp(pl.type_named_name as *byte, "void" as *byte) == 0 {
                is_void_mono = 1;
            }
        }
        if is_void_mono == 0 {
            codegen.indent_level = codegen.indent_level + 1;
            c99_emit_indent(codegen);
            if return_c != null && strncmp(return_c as *byte, "struct " as *byte, 7) == 0 {
                fprintf(codegen.output as *void, "return (%s){0};\n" as *byte, return_c as *byte);
            } else {
                fputs("return 0;\n" as *byte, codegen.output as *void);
            }
            codegen.indent_level = codegen.indent_level - 1;
        }
    }
    
    // 恢复状态
    codegen.current_function_return_type = saved_return_type;
    codegen.current_function_decl = saved_current_function_decl;
    codegen.local_variable_count = saved_local_count;
    codegen.current_depth = saved_depth;
    codegen.indent_level = codegen.indent_level - 1;
    
    c99_emit_close_brace_newline(codegen);
    
    // 恢复方法的类型参数上下文
    codegen.current_type_params = saved_type_params;
    codegen.current_type_param_count = saved_type_param_count;
    codegen.current_type_args = saved_type_args;
    codegen.current_type_arg_count = saved_type_arg_count;
}

