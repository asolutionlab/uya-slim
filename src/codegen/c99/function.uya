// function.uya - C99 代码生成器函数模块
// 提供函数声明和定义生成功能
//
// 注意：需要先包含 internal.uya（包含类型定义和函数声明）
// 由于 Uya Mini 不支持模块系统，这里假设相关类型已经定义

// ===== 外部函数声明 =====
// C 标准库函数（在 extern_decls.uya 中声明）
// 哈希函数（来自 checker/symbols.uya）
extern fn hash_string(str: &byte) i32;
extern fn type_from_ast(checker: &TypeChecker, type_node: &ASTNode) Type;

// 查找函数声明
// 若存在多个同名顶层 fn（如前向 extern 与后续带函数体的实现），优先返回带 body 的定义，
// 否则可达性分析与代码生成会锚到无体的声明，导致实现既不生成原型也不生成定义（如 libc time 的 _strftime_write）。
// 策略：缓存命中时 O(1)，未命中或冲突时回退线性查找。
fn find_function_decl_c99(codegen: &C99CodeGenerator, func_name: &byte) &ASTNode {
    if codegen == null || func_name == null || codegen.program_node == null {
        return null;
    }

    // 优先使用缓存（O(1)）
    if codegen.decl_cache_initialized != 0 {
        const h: i32 = (hash_string(func_name) & C99_DECL_CACHE_MASK) as i32;
        const cached: &ASTNode = codegen.fn_decl_cache[h];
        if cached != null && cached.type == ASTNodeType.AST_FN_DECL {
            const cached_name: &byte = cached.fn_decl_name;
            if cached_name != null && strcmp(cached_name as *byte, func_name as *byte) == 0 {
                // 缓存命中且唯一，直接返回（优先有 body 的）
                if cached.fn_decl_body != null {
                    return cached;
                }
                // 有缓存但无 body，线性查找是否有同名的有 body 版本
                const decl_count: i32 = codegen.program_node.program_decl_count;
                var i: i32 = 0;
                while i < decl_count {
                    const decl: &ASTNode = codegen.program_node.program_decls[i];
                    if decl != null && decl.type == ASTNodeType.AST_FN_DECL && decl.fn_decl_body != null {
                        const dn: &byte = decl.fn_decl_name;
                        if dn != null && strcmp(dn as *byte, func_name as *byte) == 0 {
                            return decl;
                        }
                    }
                    i = i + 1;
                }
                // 缓存本身就是唯一匹配
                return cached;
            }
        }
    }

    // 缓存未命中或冲突，线性查找
    const decl_count: i32 = codegen.program_node.program_decl_count;

    var i: i32 = 0;
    var stub: &ASTNode = null;
    while i < decl_count {
        const decl: &ASTNode = codegen.program_node.program_decls[i];
        if decl != null && decl.type == ASTNodeType.AST_FN_DECL {
            const decl_name: &byte = decl.fn_decl_name;
            if decl_name != null && strcmp(decl_name as *byte, func_name as *byte) == 0 {
                if decl.fn_decl_body != null {
                    return decl;
                }
                if stub == null {
                    stub = decl;
                }
            }
        }
        i = i + 1;
    }

    return stub;
}

// 检查函数是否是 extern "libc" fn（用于决定字符串参数类型）
fn is_extern_libc_function(codegen: &C99CodeGenerator, func_name: &byte) i32 {
    if codegen == null || func_name == null {
        return 0;
    }
    const fn_decl: &ASTNode = find_function_decl_c99(codegen, func_name);
    if fn_decl != null && fn_decl.type == ASTNodeType.AST_FN_DECL {
        if fn_decl.fn_decl_extern_lib_name != null {
            return 1;
        }
    }
    return 0;
}

// extern "libc" 规范：byte 在 FFI 中映射为 C 的 char。
// 返回值：0 = 非 byte 指针；1 = char *；2 = const char *
fn get_extern_libc_byte_mode_for_type(type_node: &ASTNode) i32 {
    if type_node == null || type_node.type != ASTNodeType.AST_TYPE_POINTER {
        return 0;
    }
    const pointed_type: &ASTNode = type_node.type_pointer_pointed_type;
    if pointed_type == null || pointed_type.type != ASTNodeType.AST_TYPE_NAMED || pointed_type.type_named_name == null {
        return 0;
    }
    if strcmp(pointed_type.type_named_name as *byte, "byte" as *byte) != 0 {
        return 0;
    }
    if type_node.type_pointer_is_const != 0 {
        return 2;
    }
    return 1;
}

fn get_extern_libc_c_type_override(type_node: &ASTNode) &byte {
    const byte_mode: i32 = get_extern_libc_byte_mode_for_type(type_node);
    if byte_mode == 2 {
        return ("const char *" as *byte) as &byte;
    }
    if byte_mode == 1 {
        return ("char *" as *byte) as &byte;
    }
    return null;
}

fn get_extern_libc_param_c_type(fn_decl: &ASTNode, param_index: i32) &byte {
    if fn_decl == null || fn_decl.type != ASTNodeType.AST_FN_DECL || fn_decl.fn_decl_extern_lib_name == null ||
        param_index < 0 || param_index >= fn_decl.fn_decl_param_count || fn_decl.fn_decl_params == null {
        return null;
    }
    const param: &ASTNode = fn_decl.fn_decl_params[param_index];
    if param == null || param.type != ASTNodeType.AST_VAR_DECL {
        return null;
    }
    return get_extern_libc_c_type_override(param.var_decl_type);
}

fn get_extern_libc_return_c_type(fn_decl: &ASTNode) &byte {
    if fn_decl == null || fn_decl.type != ASTNodeType.AST_FN_DECL || fn_decl.fn_decl_extern_lib_name == null {
        return null;
    }
    return get_extern_libc_c_type_override(fn_decl.fn_decl_return_type);
}

fn should_skip_libc_syscall_stub(codegen: &C99CodeGenerator, fn_decl: &ASTNode) i32 {
    if codegen == null || fn_decl == null || fn_decl.type != ASTNodeType.AST_FN_DECL ||
        fn_decl.fn_decl_extern_lib_name == null || fn_decl.fn_decl_name == null || fn_decl.filename == null ||
        codegen.program_node == null || codegen.program_node.type != ASTNodeType.AST_PROGRAM {
        return 0;
    }
    if strstr(fn_decl.filename as *byte, "libc/syscall" as *byte) == null {
        return 0;
    }
    var di: i32 = 0;
    const dc: i32 = codegen.program_node.program_decl_count;
    while di < dc {
        const d: &ASTNode = codegen.program_node.program_decls[di];
        if d != null && d != fn_decl && d.type == ASTNodeType.AST_FN_DECL &&
            d.fn_decl_name != null && strcmp(d.fn_decl_name as *byte, fn_decl.fn_decl_name as *byte) == 0 &&
            d.fn_decl_body != null && d.fn_decl_extern_lib_name == null && d.filename != null &&
            strstr(d.filename as *byte, "syscall/linux" as *byte) != null {
            return 1;
        }
        di = di + 1;
    }
    return 0;
}

// 从文件名提取模块前缀（lib/libc/ -> libc_, lib/std/io/ -> std_io_）
fn get_module_prefix_from_filename(codegen: &C99CodeGenerator, filename: &byte) &byte {
    if codegen == null || filename == null || codegen.arena == null {
        return ("" as *byte) as &byte;
    }
    if strstr(filename as *byte, "/lib/libc/" as *byte) != null || strstr(filename as *byte, "lib/libc/" as *byte) != null {
        return ("libc_" as *byte) as &byte;
    }
    var lib_std: *byte = strstr(filename as *byte, "/lib/std/" as *byte);
    if lib_std == null {
        lib_std = strstr(filename as *byte, "lib/std/" as *byte);
    }
    if lib_std != null {
        var rel: &byte = lib_std as &byte;
        if rel[0] == 47 { rel = &rel[1]; }
        if strncmp(rel as *byte, "lib/std/" as *byte, 8) == 0 {
            rel = &rel[8];
        }
        const rel_len: usize = strlen(rel as *byte);
        var base_len: usize = rel_len;
        if rel_len > 4 && strcmp((rel as *byte + (rel_len - 4)) as *byte, ".uya" as *byte) == 0 {
            base_len = rel_len - 4;
        }
        var si: usize = base_len;
        var last_slash: &byte = null;
        while si > 0 {
            si = si - 1;
            if rel[si] == 47 || rel[si] == 92 {
                last_slash = &rel[si];
                break;
            }
        }
        if last_slash != null {
            const slash_pos: usize = ptr_diff(last_slash as *byte, rel as *byte) as usize;
            const total_len: usize = 4 + slash_pos + 2;
            const prefix: &byte = compiler_arena_alloc(codegen.arena, total_len) as &byte;
            if prefix != null {
                strcpy(prefix as *byte, "std_" as *byte);
                memcpy((prefix as *byte + 4) as *void, rel as *void, slash_pos);
                prefix[4 + slash_pos] = 95 as byte;
                prefix[4 + slash_pos + 1] = 0 as byte;
                var idx: usize = 4;
                while idx < 4 + slash_pos {
                    if prefix[idx] == 47 || prefix[idx] == 92 {
                        prefix[idx] = 95 as byte;
                    }
                    idx = idx + 1;
                }
                return prefix;
            }
        }
        return ("std_" as *byte) as &byte;
    }
    // 检查是否是 src/ 文件（应用程序主文件）
    var src_path: *byte = strstr(filename as *byte, "/src/" as *byte);
    if src_path == null {
        src_path = strstr(filename as *byte, "src/" as *byte);
    }
    if src_path == null {
        src_path = strstr(filename as *byte, "\\src\\" as *byte);
    }
    if src_path != null {
        var rel: &byte = src_path as &byte;
        if rel[0] == 47 { rel = &rel[1]; }
        if strncmp(rel as *byte, "src/" as *byte, 4) == 0 {
            rel = &rel[4];
        } else if strncmp(rel as *byte, "src\\" as *byte, 4) == 0 {
            rel = &rel[4];
        }
        const rel_len: usize = strlen(rel as *byte);
        var base_len: usize = rel_len;
        if rel_len > 4 && strcmp((rel as *byte + (rel_len - 4)) as *byte, ".uya" as *byte) == 0 {
            base_len = rel_len - 4;
        }
        const prefix: &byte = compiler_arena_alloc(codegen.arena, base_len + 2) as &byte;
        if prefix != null {
            memcpy(prefix as *void, rel as *void, base_len);
            prefix[base_len] = 95 as byte;
            prefix[base_len + 1] = 0 as byte;
            // 将路径分隔符 / 和 \ 替换为 _
            var idx: i32 = 0;
            while idx < base_len as i32 {
                if prefix[idx] == 47 || prefix[idx] == 92 {  // '/' or '\'
                    prefix[idx] = 95 as byte;  // '_'
                }
                idx = idx + 1;
            }
            return prefix;
        }
    }
    return ("" as *byte) as &byte;
}

fn get_export_function_c_name(codegen: &C99CodeGenerator, name: &byte, filename: &byte) &byte {
    if name == null {
        return get_safe_c_identifier(codegen, (" " as *byte) as &byte);
    }
    const prefix: &byte = get_module_prefix_from_filename(codegen, filename);
    if prefix == null || prefix[0] == 0 {
        return get_safe_c_identifier(codegen, name);
    }
    const safe_name: &byte = get_safe_c_identifier(codegen, name);
    const prefix_len: usize = strlen(prefix as *byte);
    const name_len: usize = strlen(safe_name as *byte);
    const result: &byte = compiler_arena_alloc(codegen.arena, prefix_len + name_len + 1) as &byte;
    if result == null {
        return safe_name;
    }
    strcpy(result as *byte, prefix as *byte);
    strcpy((result as *byte + prefix_len) as *byte, safe_name as *byte);
    return result;
}

// 全局函数在 C 中的名称（export 函数带模块前缀，但 extern "libc" fn 除外）
fn get_c_name_for_global_function(codegen: &C99CodeGenerator, name: &byte, for_definition: i32) &byte {
    if name == null {
        return get_safe_c_identifier(codegen, (" " as *byte) as &byte);
    }
    if for_definition == 0 && codegen != null && codegen.program_node != null && codegen.program_node.type == ASTNodeType.AST_PROGRAM {
        var di: i32 = 0;
        while di < codegen.program_node.program_decl_count {
            const d: &ASTNode = codegen.program_node.program_decls[di];
            if d != null && d.type == ASTNodeType.AST_FN_DECL && d.fn_decl_name != null &&
               strcmp(d.fn_decl_name as *byte, name as *byte) == 0 &&
               d.fn_decl_is_export != 0 && d.filename != null {
                // extern "libc" fn 不添加模块前缀
                if d.fn_decl_extern_lib_name != null {
                    return get_safe_c_identifier(codegen, name);
                }
                return get_export_function_c_name(codegen, name, d.filename);
            }
            di = di + 1;
        }
    }
    return get_safe_c_identifier(codegen, name);
}

// 全局常量在 C 中的名称（lib/libc/ 和 lib/syscall/ 下的 export 变量加模块前缀）
fn get_c_name_for_global_constant(codegen: &C99CodeGenerator, name: &byte, filename: &byte, is_export: i32) &byte {
    if name == null {
        return get_safe_c_identifier(codegen, (" " as *byte) as &byte);
    }
    // 仅对 lib/libc/ 和 lib/syscall/ 下的 export 变量添加模块前缀
    // 但排除 stderr/stdin/stdout，因为它们需要链接到系统 libc
    if filename != null && is_export != 0 {
        const is_std_stream: i32 = (strcmp(name as *byte, "stderr" as *byte) == 0) ||
                                   (strcmp(name as *byte, "stdin" as *byte) == 0) ||
                                   (strcmp(name as *byte, "stdout" as *byte) == 0);
        if is_std_stream == 0 {
            const prefix: &byte = get_module_prefix_from_filename(codegen, filename);
            if prefix != null && prefix[0] != 0 {
                const safe_name: &byte = get_safe_c_identifier(codegen, name);
                const prefix_len: usize = strlen(prefix as *byte);
                const name_len: usize = strlen(safe_name as *byte);
                const result: &byte = compiler_arena_alloc(codegen.arena, prefix_len + name_len + 1) as &byte;
                if result != null {
                    strcpy(result as *byte, prefix as *byte);
                    strcpy((result as *byte + prefix_len) as *byte, safe_name as *byte);
                    return result;
                }
            }
        }
    }
    return get_safe_c_identifier(codegen, name);
}

fn format_param_type(codegen: &C99CodeGenerator, type_c: &byte, param_name: &byte, output: &void) void {
    // codegen 参数未使用，但保留以保持接口一致性
    if type_c == null || param_name == null {
        return;
    }
    
    // 特殊处理：如果是 copy_type 函数的第一个参数且类型是 "struct Type *" 或 "const struct Type *"，则改为 "const struct Type *"
    // 检查当前函数名是否为 copy_type（通过 codegen.current_function_decl）
    var is_copy_type_param: i32 = 0;
    if codegen != null && codegen.current_function_decl != null {
        const fn_name: &byte = codegen.current_function_decl.fn_decl_name;
        if fn_name != null && strcmp(fn_name as *byte, "copy_type" as *byte) == 0 {
            // 检查参数类型是否为 "struct Type *" 或已经是 "const struct Type *"
            if strcmp(type_c as *byte, "struct Type *" as *byte) == 0 {
                is_copy_type_param = 1;
            } else if strcmp(type_c as *byte, "const struct Type *" as *byte) == 0 {
                is_copy_type_param = 1;
            }
        }
    }
    
    // 检查是否是指向数组的指针（包含 "(*)" 和 "[数字]"）
    // 例如：uint8_t (*)[4096] -> uint8_t (*param_name)[4096]
    const paren_star: *byte = strstr(type_c as *byte, "(*)" as *byte);
    if paren_star != null {
        // 是指向数组的指针，需要将 param_name 插入到 (*) 中
        const before_paren: i32 = ptr_diff(paren_star, type_c as *byte);
        const after_paren: *byte = paren_star + 3;  // 跳过 "(*)"
        // 输出：base_type (*param_name)[dims]
        var temp_buf: [byte: TEMP_BUF_SIZE] = [];
        var i: i32 = 0;
        while i < before_paren && i < TEMP_BUF_LIMIT {
            temp_buf[i] = type_c[i];
            i = i + 1;
        }
        if i >= 0 && i < TEMP_BUF_SIZE {
            temp_buf[i] = 0;
        }
        fprintf(output, "%s (*%s)%s" as *byte, &temp_buf[0] as *byte, param_name as *byte, after_paren);
    } else {
        // 检查是否是数组类型（包含 [数字]）
        const bracket: *byte = strchr(type_c as *byte, 91);  // '['
        if bracket != null {
            // 提取元素类型（bracket之前的部分）
            const str_len: i32 = ptr_diff(bracket, type_c as *byte);
            // 注意：Uya Mini 不支持 %.*s，需要手动处理
            // 简化处理：使用临时缓冲区
            var temp_buf: [byte: TEMP_BUF_SIZE] = [];
            var i: i32 = 0;
            while i < str_len && i < TEMP_BUF_LIMIT {
                temp_buf[i] = type_c[i];
                i = i + 1;
            }
            if i >= 0 && i < TEMP_BUF_SIZE {
                temp_buf[i] = 0;
            }
            fprintf(output, "%s %s%s" as *byte, &temp_buf[0] as *byte, param_name as *byte, bracket);
        } else {
            // 非数组类型
            // 检查是否是指针类型（包含 '*'）
            // 如果是指针类型，格式应该是 "type * name"（* 紧跟在类型后面）
            // c99_type_to_c 已经返回了正确的格式（如 "struct Type *"），所以直接输出即可
            // 特殊处理 copy_type 函数：将 "struct Type *" 改为 "const struct Type *"
            if is_copy_type_param != 0 {
                fprintf(output, "const struct Type * %s" as *byte, param_name as *byte);
            } else {
                fprintf(output, "%s %s" as *byte, type_c as *byte, param_name as *byte);
            }
        }
    }
}

// 生成函数原型（前向声明）
// 注意：此函数在 main.uya 中被调用，但由于 function.uya 在 main.uya 之前编译，函数已经可见
fn gen_function_prototype(codegen: &C99CodeGenerator, fn_decl: &ASTNode) void {
    if fn_decl == null || fn_decl.type != ASTNodeType.AST_FN_DECL {
        return;
    }
    if should_skip_libc_syscall_stub(codegen, fn_decl) != 0 {
        return;
    }
    
    // 设置当前函数声明（用于 format_param_type 中的 copy_type 检查）
    const saved_current_function_decl: &ASTNode = codegen.current_function_decl;
    codegen.current_function_decl = fn_decl;
    
    const extern_lib_name: &byte = fn_decl.fn_decl_extern_lib_name;  // extern "libc" fn 的库名
    
    // extern "libc" fn 不添加模块前缀，直接使用原始函数名
    var func_name: &byte = get_c_name_for_global_function(codegen, fn_decl.fn_decl_name, 1);
    if fn_decl.fn_decl_is_export != 0 && fn_decl.filename != null && extern_lib_name == null {
        func_name = get_export_function_c_name(codegen, fn_decl.fn_decl_name, fn_decl.filename);
    }
    const return_type: &ASTNode = fn_decl.fn_decl_return_type;
    const param_count: i32 = fn_decl.fn_decl_param_count;
    const is_varargs: i32 = fn_decl.fn_decl_is_varargs;
    const body: &ASTNode = fn_decl.fn_decl_body;
    
    // 检查是否为extern函数（body为NULL表示extern函数）
    var is_extern: i32 = 0;
    if body == null && extern_lib_name == null {
        // 只有当没有 extern_lib_name 时才标记为 is_extern
        // extern "libc" fn 带函数体时，is_extern 应该为 0
        is_extern = 1;
    }
    
    // extern "libc" fn 无函数体：不生成声明，链接到系统 libc
    if extern_lib_name != null && body == null {
        return;
    }
    
    // 返回类型（如果是数组类型，转换为指针类型）
    var return_c: &byte = convert_array_return_type(codegen, return_type);
    return_c = normalize_poll_return_type(codegen, return_c);
    const libc_return_c: &byte = get_extern_libc_return_c_type(fn_decl);
    if libc_return_c != null {
        return_c = libc_return_c;
    }

    // 特殊处理：main 函数需要重命名为 uya_main（符合 Uya 规范：main 函数无参数）
    // 注意：Uya Mini 不支持三元运算符，使用 if-else 代替
    var is_main: i32 = 0;
    if fn_decl.fn_decl_name != null && strcmp(fn_decl.fn_decl_name as *byte, "main" as *byte) == 0 {
        is_main = 1;
    }

    // 检查是否为标准 C main 函数（export extern fn main）
    var is_c_main: i32 = 0;
    if is_main != 0 && fn_decl.fn_decl_is_export != 0 && fn_decl.fn_decl_is_extern != 0 {
        is_c_main = 1;
    }

    // export extern fn main：生成裸名 main 的前向声明，不带模块前缀
    if is_c_main != 0 {
        var j: i32 = 0;
        c99_preregister_slices_top_level_fn(codegen, fn_decl);
        fprintf(codegen.emit_stream, "extern %s main(" as *byte, return_c as *byte);
        while j < param_count {
            const param: &ASTNode = fn_decl.fn_decl_params[j];
            if param != null && param.type == ASTNodeType.AST_VAR_DECL {
                const param_name: &byte = get_safe_c_identifier(codegen, param.var_decl_name);
                if j == 1 {
                    if codegen.is_nostdlib != 0 {
                        fprintf(codegen.emit_stream, "uint8_t **%s" as *byte, param_name as *byte);
                    } else {
                        fprintf(codegen.emit_stream, "char **%s" as *byte, param_name as *byte);
                    }
                } else {
                    const param_type: &ASTNode = param.var_decl_type;
                    const param_type_c: &byte = c99_type_to_c(codegen, param_type);
                    format_param_type(codegen, param_type_c, param_name, codegen.emit_stream as *void);
                }
                if j < param_count - 1 {
                    fputs(", " as *byte, codegen.emit_stream);
                }
            }
            j = j + 1;
        }
        fputs(");\n" as *byte, codegen.emit_stream);
        codegen.current_function_decl = saved_current_function_decl;
        return;
    }

    // 仅 fn main（非 export）提前返回生成 uya_main(void)；export fn main 走通用路径生成 main_main()
    if is_main != 0 && is_c_main == 0 && fn_decl.fn_decl_is_export == 0 {
        fprintf(codegen.emit_stream, "%s uya_main(void);\n" as *byte, return_c as *byte);
        return;
    }
    
    // 读取 is_export 标志；若有同名 extern 声明则不能加 static
    const is_export: i32 = fn_decl.fn_decl_is_export;
    var has_extern_same: i32 = 0;
    if is_extern == 0 && fn_decl.fn_decl_name != null && codegen.program_node != null && codegen.program_node.type == ASTNodeType.AST_PROGRAM {
        var di: i32 = 0;
        while di < codegen.program_node.program_decl_count {
            const d: &ASTNode = codegen.program_node.program_decls[di];
            if d != null && d.type == ASTNodeType.AST_FN_DECL && d.fn_decl_name != null &&
               strcmp(d.fn_decl_name as *byte, fn_decl.fn_decl_name as *byte) == 0 && d.fn_decl_body == null {
                has_extern_same = 1;
                break;
            }
            di = di + 1;
        }
    }
    // 若程序中已有同名函数定义（如 libc 实现），跳过 extern 声明，避免与 GCC built-in 冲突
    if is_extern != 0 && fn_decl.fn_decl_name != null && codegen.program_node != null && codegen.program_node.type == ASTNodeType.AST_PROGRAM {
        var di: i32 = 0;
        while di < codegen.program_node.program_decl_count {
            const d: &ASTNode = codegen.program_node.program_decls[di];
            if d != null && d != fn_decl && d.type == ASTNodeType.AST_FN_DECL && d.fn_decl_name != null &&
               strcmp(d.fn_decl_name as *byte, fn_decl.fn_decl_name as *byte) == 0 && d.fn_decl_body != null {
                codegen.current_function_decl = saved_current_function_decl;
                return;
            }
            di = di + 1;
        }
    }
    // uya_thread_call_* 由 C99 前导中的 static inline 提供；跳过 extern 原型以免与定义链接属性冲突
    if is_extern != 0 && fn_decl.fn_decl_name != null {
        if strcmp(fn_decl.fn_decl_name as *byte, "uya_thread_call_i32" as *byte) == 0 ||
           strcmp(fn_decl.fn_decl_name as *byte, "uya_thread_call_u32" as *byte) == 0 ||
           strcmp(fn_decl.fn_decl_name as *byte, "uya_thread_call_usize" as *byte) == 0 {
            codegen.current_function_decl = saved_current_function_decl;
            return;
        }
    }
    c99_preregister_slices_top_level_fn(codegen, fn_decl);
    if is_extern != 0 {
        fprintf(codegen.emit_stream, "extern %s %s(" as *byte, return_c as *byte, func_name as *byte);
    } else {
        if is_export == 0 && has_extern_same == 0 && codegen.split_enabled == 0 {
            fprintf(codegen.emit_stream, "static " as *byte);
        }
        fprintf(codegen.emit_stream, "%s %s(" as *byte, return_c as *byte, func_name as *byte);
    }
    
    // 检查是否为 copy_type 函数（需要 const 限定符）
    var is_copy_type: i32 = 0;
    if fn_decl.fn_decl_name != null && strcmp(fn_decl.fn_decl_name as *byte, "copy_type" as *byte) == 0 {
        is_copy_type = 1;
    }

    // 检查是否为标准库函数（extern "libc" fn）
    var is_stdlib: i32 = 0;
    if extern_lib_name != null {
        is_stdlib = 1;
    }

    // 参数列表
    var i: i32 = 0;
    while i < param_count {
        const param: &ASTNode = fn_decl.fn_decl_params[i];
        if param != null && param.type == ASTNodeType.AST_VAR_DECL {
            const param_name: &byte = get_safe_c_identifier(codegen, param.var_decl_name);
            const param_type: &ASTNode = param.var_decl_type;
            var param_type_c: &byte = c99_type_to_c(codegen, param_type);
            
            // 特殊处理 copy_type 函数：将第一个参数类型改为 const struct Type *
            if is_copy_type != 0 && i == 0 {
                // 对于 copy_type 函数，第一个参数类型必须是 const struct Type *
                // 直接替换，不检查原始类型（因为 copy_type 的参数类型总是 &Type，即 struct Type *）
                param_type_c = ("const struct Type *" as *byte) as &byte;
            }
            
            // 对于 extern 函数，检查大结构体参数（>16字节），转换为指针类型
            // 根据 x86-64 System V ABI，大于 16 字节的结构体通过指针传递
            if is_extern != 0 && param_type.type == ASTNodeType.AST_TYPE_NAMED {
                const struct_size: i32 = calculate_struct_size(codegen, param_type);
                if struct_size > 16 {
                    // 大结构体：转换为指针类型
                    // 注意：如果是 copy_type 函数，保持 const struct Type *
                    if is_copy_type != 0 && i == 0 {
                        param_type_c = ("const struct Type *" as *byte) as &byte;
                    } else {
                        param_type_c = c99_type_to_c(codegen, param_type);
                    }
                    fprintf(codegen.emit_stream, "%s *%s" as *byte, param_type_c as *byte, param_name as *byte);
                    if i < param_count - 1 {
                        fputs(", " as *byte, codegen.emit_stream);
                    }
                    i = i + 1;
                    continue;
                }
            }
            
            const libc_param_c: &byte = get_extern_libc_param_c_type(fn_decl, i);
            if libc_param_c != null {
                param_type_c = libc_param_c;
            }
            
            // 数组参数：在参数名后添加 _param 后缀，函数内部会创建副本
            if param_type.type == ASTNodeType.AST_TYPE_ARRAY {
                // 数组参数格式：T name_param[N]
                const bracket: *byte = strchr(param_type_c as *byte, 91);  // '['
                if bracket != null {
                    const str_len: i32 = ptr_diff(bracket, param_type_c as *byte);
                    // 注意：Uya Mini 不支持 %.*s，需要手动处理
                    var temp_buf: [byte: TEMP_BUF_SIZE] = [];
                    var j: i32 = 0;
                    while j < str_len && j < TEMP_BUF_LIMIT {
                        temp_buf[j] = param_type_c[j];
                        j = j + 1;
                    }
                    if j >= 0 && j < TEMP_BUF_SIZE {
                        temp_buf[j] = 0;
                    }
                    fprintf(codegen.emit_stream, "%s %s_param%s" as *byte, &temp_buf[0] as *byte, param_name as *byte, bracket);
                } else {
                    fprintf(codegen.emit_stream, "%s %s_param" as *byte, param_type_c as *byte, param_name as *byte);
                }
            } else if param_type.type == ASTNodeType.AST_TYPE_SLICE {
                // Slice 形参 &[T]：C 侧统一为按值 struct uya_slice_*（extern 声明与 Uya 定义一致）
                format_param_type(codegen, param_type_c, param_name, codegen.emit_stream);
            } else {
                // 对于 copy_type 函数，直接输出 const struct Type *，不调用 format_param_type
                if is_copy_type != 0 && i == 0 {
                    fprintf(codegen.emit_stream, "const struct Type * %s" as *byte, param_name as *byte);
                } else {
                    format_param_type(codegen, param_type_c, param_name, codegen.emit_stream);
                }
            }
            if i < param_count - 1 {
                fputs(", " as *byte, codegen.emit_stream);
            }
        }
        i = i + 1;
    }
    
    // 处理可变参数
    if is_varargs != 0 {
        if param_count > 0 {
            fputs(", " as *byte, codegen.emit_stream);
        }
        fputs("..." as *byte, codegen.emit_stream);
    }
    
    fputs(");\n" as *byte, codegen.emit_stream);
    
    // 恢复当前函数声明
    codegen.current_function_decl = saved_current_function_decl;
}

// 生成函数定义
// 注意：此函数在 main.uya 中被调用，但由于 function.uya 在 main.uya 之前编译，函数已经可见
fn gen_function(codegen: &C99CodeGenerator, fn_decl: &ASTNode) void {
    if fn_decl == null || fn_decl.type != ASTNodeType.AST_FN_DECL {
        return;
    }
    
    const orig_name: &byte = fn_decl.fn_decl_name;
    const extern_lib_name: &byte = fn_decl.fn_decl_extern_lib_name;  // extern "libc" fn 的库名
    
    // extern "libc" fn 不添加模块前缀，直接使用原始函数名
    var func_name: &byte = get_c_name_for_global_function(codegen, orig_name, 1);
    if fn_decl.fn_decl_is_export != 0 && fn_decl.filename != null && extern_lib_name == null {
        func_name = get_export_function_c_name(codegen, orig_name, fn_decl.filename);
    }
    const return_type: &ASTNode = fn_decl.fn_decl_return_type;
    const param_count: i32 = fn_decl.fn_decl_param_count;
    const is_varargs: i32 = fn_decl.fn_decl_is_varargs;
    const body: &ASTNode = fn_decl.fn_decl_body;
    
    // 如果没有函数体（外部函数），则不生成定义
    if body == null {
        return;
    }

    // lib/libc/syscall.uya 的 export extern "libc" sys_* 与 lib/syscall/linux.uya 的 export sys_* C 符号均为 sys_*，
    // 合并编译时只应保留 linux 实现，否则 C 报重复定义。
    if should_skip_libc_syscall_stub(codegen, fn_decl) != 0 {
        return;
    }

    // @async_fn：
    // - 形式一（阶段 B）：返回 Future<!T> 或 !Future<T>，使用状态机生成 async
    // - 形式二（阶段 A 兼容）：其他返回类型走普通函数代码生成
    if fn_decl.fn_decl_is_async != 0 {
        var use_stage_b: i32 = 0;
        var effective_return_type: &ASTNode = return_type;
        if return_type != null && return_type.type == ASTNodeType.AST_TYPE_NAMED &&
            return_type.type_named_name != null &&
            strcmp(return_type.type_named_name as *byte, "Future" as *byte) == 0 &&
            return_type.type_named_type_arg_count == 1 &&
            return_type.type_named_type_args != null {
            const a0: &ASTNode = return_type.type_named_type_args[0];
            if a0 != null && a0.type == ASTNodeType.AST_TYPE_ERROR_UNION &&
                a0.type_error_union_payload_type != null {
                use_stage_b = 1;
            }
        }
        if use_stage_b == 0 && return_type != null && return_type.type == ASTNodeType.AST_TYPE_ERROR_UNION &&
            return_type.type_error_union_payload_type != null {
            const pl: &ASTNode = return_type.type_error_union_payload_type;
            if pl.type == ASTNodeType.AST_TYPE_NAMED && pl.type_named_name != null &&
                strcmp(pl.type_named_name as *byte, "Future" as *byte) == 0 &&
                pl.type_named_type_arg_count == 1 && pl.type_named_type_args != null {
                use_stage_b = 1;
                effective_return_type = pl;
            }
        }
        if use_stage_b != 0 {
            gen_async_function_stage_b(codegen, fn_decl, func_name, return_type, effective_return_type);
            return;
        }
        // 否则继续走普通函数定义路径
    }
    
    // 生成 #line 指令，指向函数定义的位置
    emit_line_directive(codegen, fn_decl.line, fn_decl.filename);
    
    // 特殊处理：main 函数需要重命名为 uya_main（符合 Uya 规范：main 函数无参数）
    // 注意：Uya Mini 不支持三元运算符，使用 if-else 代替
    var is_main: i32 = 0;
    if fn_decl.fn_decl_name != null && strcmp(fn_decl.fn_decl_name as *byte, "main" as *byte) == 0 {
        is_main = 1;
    }
    
    // 返回类型（如果是数组类型，转换为指针类型）
    var return_c: &byte = convert_array_return_type(codegen, return_type);
    return_c = normalize_poll_return_type(codegen, return_c);
    const libc_return_c: &byte = get_extern_libc_return_c_type(fn_decl);
    if libc_return_c != null {
        return_c = libc_return_c;
    }
    c99_preregister_slices_top_level_fn(codegen, fn_decl);
    
    // 声明循环变量 i（在 if-else 之前声明，确保在所有分支都可见）
    var i: i32 = 0;
    
    // 检查是否为extern函数（body为NULL表示extern函数）
    var is_extern: i32 = 0;
    if body == null && extern_lib_name == null {
        // 只有当没有 extern_lib_name 时才标记为 is_extern
        // extern "libc" fn 带函数体时，is_extern 应该为 0
        is_extern = 1;
    }
    
    // 读取 is_export 标志
    const is_export: i32 = fn_decl.fn_decl_is_export;
    // 若程序中存在同名 extern 声明（如 parser 的 extern fn lexer_next_token），定义处不能加 static
    var has_extern_decl_same_name: i32 = 0;
    if is_extern == 0 && fn_decl.fn_decl_name != null && codegen.program_node != null && codegen.program_node.type == ASTNodeType.AST_PROGRAM {
        var di: i32 = 0;
        while di < codegen.program_node.program_decl_count {
            const d: &ASTNode = codegen.program_node.program_decls[di];
            if d != null && d.type == ASTNodeType.AST_FN_DECL && d.fn_decl_name != null &&
               strcmp(d.fn_decl_name as *byte, fn_decl.fn_decl_name as *byte) == 0 && d.fn_decl_body == null {
                has_extern_decl_same_name = 1;
                break;
            }
            di = di + 1;
        }
    }
    // extern "libc" fn 带函数体时，不使用 static，不使用模块前缀
    var is_static: i32 = 0;
    if is_main == 0 && is_extern == 0 && is_export == 0 && has_extern_decl_same_name == 0 && extern_lib_name == null {
        is_static = 1;
    }
    // 多文件 C（split）：定义与前置原型均不加 static，避免与非 static 原型冲突（与 gen_function_prototype 一致）
    if codegen.split_enabled != 0 {
        is_static = 0;
    }

    // 检查是否为标准 C main 函数（export extern fn main）
    var is_c_main: i32 = 0;
    if is_main != 0 && fn_decl.fn_decl_is_export != 0 && fn_decl.fn_decl_is_extern != 0 {
        is_c_main = 1;
    }

    if is_main != 0 && is_c_main == 0 {
        // export fn main → main_main，fn main → uya_main
        var main_def_name: &byte = "uya_main" as *byte;
        if fn_decl.fn_decl_is_export != 0 {
            main_def_name = "main_main" as *byte;
        }
        fprintf(codegen.emit_stream, "%s %s(void)" as *byte, return_c as *byte, main_def_name as *byte);
    } else {
        // 非 extern 函数：根据 is_export 决定是否添加 static
        // fn foo() void → static void foo(void)（内部函数，不导出）
        // export fn foo() void → void foo(void)（导出函数，供其他模块使用）
        // @naked_fn 函数添加 __attribute__((naked))
        if fn_decl.fn_decl_is_naked != 0 {
            fprintf(codegen.emit_stream, "__attribute__((naked)) " as *byte);
        }
        if is_static != 0 {
            fprintf(codegen.emit_stream, "static __attribute__((unused)) " as *byte);
        }
        fprintf(codegen.emit_stream, "%s %s(" as *byte, return_c as *byte, func_name as *byte);
        
        // 检查是否为 copy_type 函数（需要 const 限定符）
        var is_copy_type: i32 = 0;
        if fn_decl.fn_decl_name != null && strcmp(fn_decl.fn_decl_name as *byte, "copy_type" as *byte) == 0 {
            is_copy_type = 1;
        }

        // 参数列表
        i = 0;
        while i < param_count {
            const param: &ASTNode = fn_decl.fn_decl_params[i];
            if param != null && param.type == ASTNodeType.AST_VAR_DECL {
                const param_name: &byte = get_safe_c_identifier(codegen, param.var_decl_name);
                const param_type: &ASTNode = param.var_decl_type;
                var param_type_c: &byte = c99_type_to_c(codegen, param_type);
                
                // 特殊处理 copy_type 函数：将第一个参数类型改为 const struct Type *
                if is_copy_type != 0 && i == 0 {
                    // 对于 copy_type 函数，第一个参数类型必须是 const struct Type *
                    // 直接替换，不检查原始类型（因为 copy_type 的参数类型总是 &Type，即 struct Type *）
                    param_type_c = ("const struct Type *" as *byte) as &byte;
                }
                
                const libc_param_c: &byte = get_extern_libc_param_c_type(fn_decl, i);
                if libc_param_c != null {
                    param_type_c = libc_param_c;
                }
                
                // 数组参数：在参数名后添加 _param 后缀，函数内部会创建副本
                if param_type.type == ASTNodeType.AST_TYPE_ARRAY {
                    // 数组参数格式：T name_param[N]
                    const bracket: *byte = strchr(param_type_c as *byte, 91);  // '['
                    if bracket != null {
                        const str_len: i32 = ptr_diff(bracket, param_type_c as *byte);
                        // 注意：Uya Mini 不支持 %.*s，需要手动处理
                        var temp_buf: [byte: TEMP_BUF_SIZE] = [];
                        var j: i32 = 0;
                        while j < str_len && j < TEMP_BUF_LIMIT {
                            temp_buf[j] = param_type_c[j];
                            j = j + 1;
                        }
                        if j >= 0 && j < TEMP_BUF_SIZE {
                            temp_buf[j] = 0;
                        }
                        fprintf(codegen.emit_stream, "%s %s_param%s" as *byte, &temp_buf[0] as *byte, param_name as *byte, bracket);
                    } else {
                        fprintf(codegen.emit_stream, "%s %s_param" as *byte, param_type_c as *byte, param_name as *byte);
                    }
                } else if param_type.type == ASTNodeType.AST_TYPE_SLICE {
                    // slice 形参按值 struct uya_slice_*（gen_function 仅在 body!=null 时到达此处）
                    format_param_type(codegen, param_type_c, param_name, codegen.emit_stream);
                } else if is_c_main != 0 && i == 1 {
                    if codegen.is_nostdlib != 0 {
                        fprintf(codegen.emit_stream, "uint8_t **%s" as *byte, param_name as *byte);
                    } else {
                        fprintf(codegen.emit_stream, "char **%s" as *byte, param_name as *byte);
                    }
                } else {
                    // 对于 copy_type 函数，直接输出 const struct Type *，不调用 format_param_type
                    if is_copy_type != 0 && i == 0 {
                        fprintf(codegen.emit_stream, "const struct Type * %s" as *byte, param_name as *byte);
                    } else {
                        format_param_type(codegen, param_type_c, param_name, codegen.emit_stream);
                    }
                }
                if i < param_count - 1 {
                    fputs(", " as *byte, codegen.emit_stream);
                }
            }
            i = i + 1;
        }
        
        // 处理可变参数
        if is_varargs != 0 {
            if param_count > 0 {
                fputs(", " as *byte, codegen.emit_stream);
            }
            fputs("..." as *byte, codegen.emit_stream);
        }
    }
    
    // 添加函数体开始
    if is_main != 0 {
        fputs(" {\n" as *byte, codegen.emit_stream);
        // 在 main 函数开始时调用测试运行器（只有在有测试时才调用）
        if codegen.test_count > 0 {
            fputs("    uya_run_tests();\n" as *byte, codegen.emit_stream);
        }
    } else {
        fputs(") {\n" as *byte, codegen.emit_stream);
    }
    codegen.indent_level = codegen.indent_level + 1;
    
    // 保存当前函数的返回类型（用于生成返回语句）
    codegen.current_function_return_type = return_type;
    
    // 保存当前函数声明（用于 @params 与 ... 转发）
    const saved_current_function_decl: &ASTNode = codegen.current_function_decl;
    codegen.current_function_decl = fn_decl;
    
    // 保存函数开始时的局部变量表状态（用于函数结束时恢复）
    // 每个函数有自己独立的局部变量表，函数结束后恢复之前的状态
    const saved_local_variable_count: i32 = codegen.local_variable_count;
    const saved_current_depth: i32 = codegen.current_depth;
    
    // 重置当前函数的局部变量表（从 0 开始）
    // 这样每个函数都有自己独立的局部变量表，避免大文件时表被填满
    // 参数和局部变量都从索引 0 开始添加
    codegen.local_variable_count = 0;
    codegen.current_depth = 0;
    
    // 处理数组参数：为数组参数创建局部副本（实现按值传递）
    i = 0;
    while i < param_count {
        const param: &ASTNode = fn_decl.fn_decl_params[i];
        if param != null && param.type == ASTNodeType.AST_VAR_DECL {
            const param_name: &byte = get_safe_c_identifier(codegen, param.var_decl_name);
            const param_type: &ASTNode = param.var_decl_type;
            
            if param_type.type == ASTNodeType.AST_TYPE_ARRAY {
                // 数组参数：创建局部数组副本
                const array_type_c: &byte = c99_type_to_c(codegen, param_type);
                // 解析数组类型格式：int32_t[3] -> int32_t arr[3]
                const bracket: *byte = strchr(array_type_c as *byte, 91);  // '['
                c99_emit_indent(codegen);
                fputs("// 数组参数按值传递：创建局部副本\n" as *byte, codegen.emit_stream);
                if bracket != null {
                    const str_len: i32 = ptr_diff(bracket, array_type_c as *byte);
                    // 注意：Uya Mini 不支持 %.*s，需要手动处理
                    var temp_buf: [byte: TEMP_BUF_SIZE] = [];
                    var j: i32 = 0;
                    while j < str_len && j < TEMP_BUF_LIMIT {
                        temp_buf[j] = array_type_c[j];
                        j = j + 1;
                    }
                    if j >= 0 && j < TEMP_BUF_SIZE {
                        temp_buf[j] = 0;
                    }
                    fprintf(codegen.emit_stream, "    %s %s%s;\n" as *byte, &temp_buf[0] as *byte, param_name as *byte, bracket);
                } else {
                    c99_emit_indent(codegen);
                    fprintf(codegen.emit_stream, "%s %s;\n" as *byte, array_type_c as *byte, param_name as *byte);
                }
                c99_emit_indent(codegen);
                codegen.needs_string_h = 1;
                fprintf(codegen.emit_stream, "    __uya_memcpy(%s, %s_param, sizeof(%s));\n" as *byte, param_name as *byte, param_name as *byte, param_name as *byte);
                
                // 将参数名注册为局部数组（而不是参数）
                if param_name != null && codegen.local_variable_count < C99_MAX_LOCAL_VARS {
                    codegen.local_variables[codegen.local_variable_count].name = param.var_decl_name;  // 使用原始名称
                    codegen.local_variables[codegen.local_variable_count].type_c = array_type_c;
                    codegen.local_variables[codegen.local_variable_count].type_node = param.var_decl_type;
                    codegen.local_variable_count = codegen.local_variable_count + 1;
                }
            } else {
                // 非数组参数：正常添加到局部变量表（slice 形参 C 侧为按值 struct，类型串无 *）
                const param_type_c: &byte = c99_type_to_c(codegen, param_type);
                if param_name != null && param_type_c != null && codegen.local_variable_count < C99_MAX_LOCAL_VARS {
                    codegen.local_variables[codegen.local_variable_count].name = param.var_decl_name;
                    codegen.local_variables[codegen.local_variable_count].type_c = param_type_c;
                    codegen.local_variables[codegen.local_variable_count].type_node = param.var_decl_type;
                    codegen.local_variable_count = codegen.local_variable_count + 1;
                }
            }
        }
        i = i + 1;
    }
    if fn_decl.fn_decl_is_naked == 0 {
        i = 0;
        while i < param_count {
            const param: &ASTNode = fn_decl.fn_decl_params[i];
            if param != null && param.type == ASTNodeType.AST_VAR_DECL {
                const pname: &byte = get_safe_c_identifier(codegen, param.var_decl_name);
                if pname != null {
                    c99_emit_indent(codegen);
                    if param.var_decl_type != null && param.var_decl_type.type == ASTNodeType.AST_TYPE_ARRAY {
                        fprintf(codegen.emit_stream as *void, "(void)%s_param;\n" as *byte, pname as *byte);
                    } else {
                        fprintf(codegen.emit_stream as *void, "(void)%s;\n" as *byte, pname as *byte);
                    }
                }
            }
            i = i + 1;
        }
    }
    
    // 生成函数体
    gen_stmt(codegen, body);
    
    // 检查函数体是否以 return 结尾
    var has_return: i32 = 0;
    if body != null && body.type == ASTNodeType.AST_BLOCK {
        const stmts: & & ASTNode = body.block_stmts;
        const stmt_count: i32 = body.block_stmt_count;
        var j: i32 = stmt_count - 1;
        while j >= 0 {
            const s: &ASTNode = stmts[j];
            if s != null && s.type != ASTNodeType.AST_DEFER_STMT && s.type != ASTNodeType.AST_ERRDEFER_STMT {
                if s.type == ASTNodeType.AST_RETURN_STMT {
                    has_return = 1;
                } else {
                    has_return = 0;
                }
                break;
            }
            j = j - 1;
        }
    }
    
    // 如果返回类型是 !void 且函数体没有显式返回，添加默认返回语句
    if fn_decl.fn_decl_is_naked == 0 && has_return == 0 && return_type != null && return_type.type == ASTNodeType.AST_TYPE_ERROR_UNION {
        const payload_node: &ASTNode = return_type.type_error_union_payload_type;
        var is_void_payload: i32 = 0;
        if payload_node == null {
            is_void_payload = 1;
        } else if payload_node.type == ASTNodeType.AST_TYPE_NAMED && payload_node.type_named_name != null &&
            strcmp(payload_node.type_named_name as *byte, "void" as *byte) == 0 {
            is_void_payload = 1;
        }
        if is_void_payload != 0 {
            // !void 类型：返回成功的错误联合（缩进与 C 编译器一致）
            codegen.indent_level = codegen.indent_level + 1;
            c99_emit_indent(codegen);
            fprintf(codegen.emit_stream as *void, "return (%s){ .error_id = 0 };\n" as *byte, return_c as *byte);
            codegen.indent_level = codegen.indent_level - 1;
        }
    }
    // 若返回类型非 void 且函数体末尾无 return，补兜底 return 避免 -Wreturn-type（缩进与 C 编译器一致）
    if fn_decl.fn_decl_is_naked == 0 && has_return == 0 && return_type != null {
        var is_void: i32 = 0;
        if return_type.type == ASTNodeType.AST_TYPE_NAMED && return_type.type_named_name != null &&
            strcmp(return_type.type_named_name as *byte, "void" as *byte) == 0 {
            is_void = 1;
        } else if return_type.type == ASTNodeType.AST_TYPE_ERROR_UNION {
            const pl: &ASTNode = return_type.type_error_union_payload_type;
            if pl == null {
                is_void = 1;
            } else if pl.type == ASTNodeType.AST_TYPE_NAMED && pl.type_named_name != null &&
                strcmp(pl.type_named_name as *byte, "void" as *byte) == 0 {
                is_void = 1;
            }
        }
        if is_void == 0 {
            codegen.indent_level = codegen.indent_level + 1;
            c99_emit_indent(codegen);
            if return_c != null && strncmp(return_c as *byte, "struct " as *byte, 7) == 0 {
                fprintf(codegen.emit_stream as *void, "return (%s){0};\n" as *byte, return_c as *byte);
            } else {
                fputs("return 0;\n" as *byte, codegen.emit_stream as *void);
            }
            codegen.indent_level = codegen.indent_level - 1;
        }
    }
    
    // 清除当前函数的返回类型
    codegen.current_function_return_type = null;
    
    // 恢复当前函数声明
    codegen.current_function_decl = saved_current_function_decl;
    
    // 恢复函数开始时的局部变量表状态
    // 这样下一个函数可以从干净的状态开始
    codegen.local_variable_count = saved_local_variable_count;
    codegen.current_depth = saved_current_depth;
    
    codegen.indent_level = codegen.indent_level - 1;
    c99_emit_indent(codegen);
    c99_emit_close_brace_newline(codegen);
}

// 从已解析的 Type 计算字节大小（用于 async 状态机估算）；递归字段使用 checker 从 AST 解析
fn get_type_size_bytes_resolved(codegen: &C99CodeGenerator, t: &Type) i32 {
    if t == null || codegen == null || codegen.checker == null {
        return -1;
    }
    const k: TypeKind = t.kind;
    if k == TypeKind.TYPE_I8 || k == TypeKind.TYPE_BOOL || k == TypeKind.TYPE_BYTE { return 1; }
    if k == TypeKind.TYPE_I16 || k == TypeKind.TYPE_U16 { return 2; }
    if k == TypeKind.TYPE_I32 || k == TypeKind.TYPE_U32 || k == TypeKind.TYPE_F32 { return 4; }
    if k == TypeKind.TYPE_I64 || k == TypeKind.TYPE_U64 || k == TypeKind.TYPE_F64 || k == TypeKind.TYPE_USIZE { return 8; }
    if k == TypeKind.TYPE_POINTER { return 8; }
    if k == TypeKind.TYPE_ATOMIC && t.atomic_inner_type != null {
        return get_type_size_bytes_resolved(codegen, t.atomic_inner_type);
    }
    if k == TypeKind.TYPE_ARRAY {
        if t.element_type != null && t.array_size > 0 {
            const esz: i32 = get_type_size_bytes_resolved(codegen, t.element_type);
            if esz > 0 && t.array_size <= 0x7FFFFFFF / esz {
                return esz * t.array_size;
            }
        }
        return -1;
    }
    if k == TypeKind.TYPE_SLICE { return 16; }
    if k == TypeKind.TYPE_TUPLE && t.tuple_count > 0 && t.tuple_element_types != null {
        var total: i32 = 0;
        var ti: i32 = 0;
        while ti < t.tuple_count {
            const et: &Type = &t.tuple_element_types[ti];
            if et != null {
                const es: i32 = get_type_size_bytes_resolved(codegen, et);
                if es <= 0 { return -1; }
                total = total + es;
            }
            ti = ti + 1;
        }
        return total;
    }
    if k == TypeKind.TYPE_ERROR_UNION {
        if t.error_union_payload_type != null {
            const ps: i32 = get_type_size_bytes_resolved(codegen, t.error_union_payload_type);
            if ps > 0 {
                if ps >= 4 { return ps; } else { return 4; }
            }
        }
        return 4;
    }
    if k == TypeKind.TYPE_STRUCT || k == TypeKind.TYPE_UNION ||
        k == TypeKind.TYPE_ERROR_UNION || k == TypeKind.TYPE_INTERFACE {
        if t.struct_name == null {
            return -1;
        }
        const decl: &ASTNode = find_struct_decl_c99(codegen, t.struct_name);
        if decl != null && decl.type == ASTNodeType.AST_STRUCT_DECL {
            var sz: i32 = 0;
            if decl.struct_decl_fields != null {
                var fi: i32 = 0;
                while fi < decl.struct_decl_field_count {
                    const field: &ASTNode = decl.struct_decl_fields[fi];
                    if field != null && field.type == ASTNodeType.AST_VAR_DECL {
                        const ft: Type = type_from_ast(codegen.checker, field.var_decl_type);
                        const fsz: i32 = get_type_size_bytes_resolved(codegen, &ft);
                        if fsz <= 0 { return -1; }
                        sz = sz + fsz;
                    }
                    fi = fi + 1;
                }
            }
            return sz;
        }
        return -1;
    }
    return -1;
}

// 从 AST 类型节点计算字节大小（用于状态机估算）：先经 type_from_ast 再按 Type 递归
fn get_type_node_size_bytes(codegen: &C99CodeGenerator, type_ast: &ASTNode) i32 {
    if type_ast == null || codegen == null || codegen.checker == null {
        return -1;
    }
    const resolved: Type = type_from_ast(codegen.checker, type_ast);
    return get_type_size_bytes_resolved(codegen, &resolved);
}

// 递归收集 await 点（进入 while/if/for/block 内部），使用 codegen.async_collect_* 存储结果
fn collect_awaits_recursive(node: &ASTNode, codegen: &C99CodeGenerator, max_count: i32) void {
    if node == null || codegen.async_collect_count >= max_count {
        return;
    }
    if node.type == ASTNodeType.AST_BLOCK && node.block_stmts != null {
        var i: i32 = 0;
        while i < node.block_stmt_count && codegen.async_collect_count < max_count {
            collect_awaits_recursive(node.block_stmts[i], codegen, max_count);
            i = i + 1;
        }
    } else if node.type == ASTNodeType.AST_WHILE_STMT && node.while_stmt_body != null {
        codegen.async_collect_has_loop = 1;
        collect_awaits_recursive(node.while_stmt_body, codegen, max_count);
    } else if node.type == ASTNodeType.AST_IF_STMT {
        if node.if_stmt_then_branch != null {
            collect_awaits_recursive(node.if_stmt_then_branch, codegen, max_count);
        }
        if node.if_stmt_else_branch != null {
            collect_awaits_recursive(node.if_stmt_else_branch, codegen, max_count);
        }
    } else if node.type == ASTNodeType.AST_FOR_STMT && node.for_stmt_body != null {
        codegen.async_collect_has_loop = 1;
        collect_awaits_recursive(node.for_stmt_body, codegen, max_count);
    } else if node.type == ASTNodeType.AST_VAR_DECL && node.var_decl_init != null {
        const init: &ASTNode = node.var_decl_init;
        if init.type == ASTNodeType.AST_TRY_EXPR && init.try_expr_operand != null {
            const op: &ASTNode = init.try_expr_operand;
            if op.type == ASTNodeType.AST_AWAIT_EXPR && op.await_expr_operand != null && codegen.async_collect_count < max_count {
                codegen.async_collect_operands[codegen.async_collect_count] = op.await_expr_operand;
                codegen.async_collect_names[codegen.async_collect_count] = node.var_decl_name;
                codegen.async_collect_types[codegen.async_collect_count] = node.var_decl_type;
                codegen.async_collect_count = codegen.async_collect_count + 1;
            }
        }
    } else if node.type == ASTNodeType.AST_RETURN_STMT {
        codegen.async_collect_ret_expr = node.return_stmt_expr;
    }
}

// try @await 形式的 var 声明由 async_collect_* 单独捕获，此处跳过
fn c99_var_decl_init_is_try_await_bind(init: &ASTNode) i32 {
    if init == null {
        return 0;
    }
    if init.type != ASTNodeType.AST_TRY_EXPR {
        return 0;
    }
    if init.try_expr_operand == null {
        return 0;
    }
    if init.try_expr_operand.type != ASTNodeType.AST_AWAIT_EXPR {
        return 0;
    }
    return 1;
}

// 收集函数体顶层、第一个 return 之前的 const/var（用于 poll 内 ret_expr 引用）
fn collect_async_pre_return_locals(codegen: &C99CodeGenerator, body: &ASTNode) void {
    codegen.async_local_count = 0;
    if codegen == null || body == null || body.type != ASTNodeType.AST_BLOCK {
        return;
    }
    var si: i32 = 0;
    while si < body.block_stmt_count && codegen.async_local_count < 16 {
        const st: &ASTNode = body.block_stmts[si];
        if st == null {
            si = si + 1;
            continue;
        }
        if st.type == ASTNodeType.AST_RETURN_STMT {
            break;
        }
        if st.type == ASTNodeType.AST_VAR_DECL && st.var_decl_name != null &&
            st.var_decl_type != null && st.var_decl_init != null &&
            c99_var_decl_init_is_try_await_bind(st.var_decl_init) == 0 {
            codegen.async_local_names[codegen.async_local_count] = st.var_decl_name;
            codegen.async_local_types[codegen.async_local_count] = st.var_decl_type;
            codegen.async_local_inits[codegen.async_local_count] = st.var_decl_init;
            codegen.async_local_count = codegen.async_local_count + 1;
        }
        si = si + 1;
    }
}

fn emit_async_pre_return_local_inits(codegen: &C99CodeGenerator) void {
    if codegen == null || codegen.async_state_var == null || codegen.async_local_count <= 0 {
        return;
    }
    var li: i32 = 0;
    while li < codegen.async_local_count && li < 16 {
        const orig: &byte = codegen.async_local_names[li];
        const ie: &ASTNode = codegen.async_local_inits[li];
        if orig != null && ie != null {
            const ls: &byte = get_safe_c_identifier(codegen, orig);
            if ls != null {
                fprintf(codegen.emit_stream as *void, "        %s->_uya_loc_%s = " as *byte,
                    codegen.async_state_var as *byte, ls as *byte);
                gen_expr(codegen, ie);
                fputs(";\n" as *byte, codegen.emit_stream as *void);
            }
        }
        li = li + 1;
    }
}

// ===== async stage-B codegen（单 @await 最小状态机）=====
// full_return_type: 函数声明的返回类型（可为 !Future<T> 或 Future<!T>）
// effective_return_type: 用于状态机的 Future 类型（Future<T> 或 Future<!T>）
fn gen_async_function_stage_b(codegen: &C99CodeGenerator, fn_decl: &ASTNode, func_c_name: &byte, full_return_type: &ASTNode, effective_return_type: &ASTNode) void {
    if codegen == null || fn_decl == null || effective_return_type == null {
        return;
    }
    if effective_return_type.type != ASTNodeType.AST_TYPE_NAMED || effective_return_type.type_named_name == null ||
        strcmp(effective_return_type.type_named_name as *byte, "Future" as *byte) != 0 ||
        effective_return_type.type_named_type_arg_count != 1 || effective_return_type.type_named_type_args == null {
        return;
    }
    var inner: &ASTNode = effective_return_type.type_named_type_args[0];
    if inner == null {
        return;
    }
    var inner_is_err_union: i32 = 0;
    if inner.type == ASTNodeType.AST_TYPE_ERROR_UNION && inner.type_error_union_payload_type != null {
        inner_is_err_union = 1;
    }
    // 当函数返回 !Future<T> 时，子调用返回 !Future<T>，需 try 取 .value；且 poll 需能返回错误，故用 Poll<!T>
    if full_return_type != null && full_return_type.type == ASTNodeType.AST_TYPE_ERROR_UNION &&
        full_return_type.type_error_union_payload_type != null {
        const pl: &ASTNode = full_return_type.type_error_union_payload_type;
        if pl.type == ASTNodeType.AST_TYPE_NAMED && pl.type_named_name != null &&
            strcmp(pl.type_named_name as *byte, "Future" as *byte) == 0 {
            const payload_t: &ASTNode = effective_return_type.type_named_type_args[0];
            const inner_err_node: &ASTNode = ast_new_node(ASTNodeType.AST_TYPE_ERROR_UNION, 0, 0, codegen.arena, null);
            if inner_err_node != null {
                inner_err_node.type_error_union_payload_type = payload_t;
                inner = inner_err_node;
                inner_is_err_union = 1;
            }
        }
    }

    // 生成单态名：Future_T / Future_err_T、Poll_T / Poll_err_T
    const type_args: & & ASTNode = compiler_arena_alloc(codegen.arena, @size_of(&ASTNode)) as & & ASTNode;
    if type_args == null {
        return;
    }
    type_args[0] = inner;
    const future_mono: &byte = get_mono_struct_name(codegen, "Future" as &byte, type_args, 1);
    const safe_future: &byte = get_safe_c_identifier(codegen, future_mono);
    var vtable_future_safe: &byte = safe_future;
    const iface_c: &byte = c99_type_to_c(codegen, effective_return_type);
    const inner_err_c: &byte = c99_type_to_c(codegen, inner);
    var concrete_future_safe: &byte = safe_future;
    if effective_return_type.type_named_type_args != null && effective_return_type.type_named_type_arg_count >= 1 {
        var slot_ta: & & ASTNode = effective_return_type.type_named_type_args;
        var slot_tc: i32 = effective_return_type.type_named_type_arg_count;
        const arg0: &ASTNode = effective_return_type.type_named_type_args[0];
        if arg0 != null && arg0.type == ASTNodeType.AST_TYPE_ERROR_UNION && arg0.type_error_union_payload_type != null {
            const one_arg: & & ASTNode = compiler_arena_alloc(codegen.arena, @size_of(&ASTNode) * 2) as & & ASTNode;
            if one_arg != null {
                one_arg[0] = arg0.type_error_union_payload_type;
                slot_ta = one_arg;
                slot_tc = 1;
            }
        }
        const payload_future_mono: &byte = get_mono_struct_name(codegen, "Future" as &byte, slot_ta, slot_tc);
        if payload_future_mono != null {
            concrete_future_safe = get_safe_c_identifier(codegen, payload_future_mono);
        }
    }
    // 内层 Poll<T> 的 C 名（用于 Future<T>.state，如 return 42 时包装为 Future{ state: Poll.Ready(42) }）
    var inner_poll_ret_c: &byte = null;
    var inner_poll_union_c: &byte = null;
    if effective_return_type.type_named_type_args != null && effective_return_type.type_named_type_arg_count >= 1 {
        const inner_poll_mono: &byte = get_mono_union_name(codegen, "Poll" as &byte, effective_return_type.type_named_type_args, effective_return_type.type_named_type_arg_count);
        if inner_poll_mono != null {
            const inner_poll_safe: &byte = get_safe_c_identifier(codegen, inner_poll_mono);
            const ipr: &byte = compiler_arena_alloc(codegen.arena, 128) as &byte;
            if ipr != null { snprintf(ipr as *byte, 128, "struct uya_tagged_%s" as *byte, inner_poll_safe as *byte); inner_poll_ret_c = ipr; }
            const ipu: &byte = compiler_arena_alloc(codegen.arena, 128) as &byte;
            if ipu != null { snprintf(ipu as *byte, 128, "union %s" as *byte, inner_poll_safe as *byte); inner_poll_union_c = ipu; }
        }
    }
    // 本分支仅用于无 await 的 !Future<T>，effective_return_type 应有 type_args；若无则 fallback 可能错误
    if inner_poll_ret_c == null { inner_poll_ret_c = "struct uya_tagged_Poll_i32" as &byte; }
    if inner_poll_union_c == null { inner_poll_union_c = "union Poll_i32" as &byte; }

    // 提取所有 await 点（支持递归进入 while/if/for/block）
    const body: &ASTNode = fn_decl.fn_decl_body;
    const MAX_AWAITS: i32 = 256;
    var await_operands: [&ASTNode: 256] = [];
    var await_bind_names: [&byte: 256] = [];
    var await_bind_types: [&ASTNode: 256] = [];
    var await_count: i32 = 0;
    var ret_expr: &ASTNode = null;
    var has_await_loop: i32 = 0;
    var async_loop_var_is_total: i32 = 0;
    if body != null {
        codegen.async_collect_count = 0;
        codegen.async_collect_ret_expr = null;
        codegen.async_collect_has_loop = 0;
        collect_awaits_recursive(body, codegen, MAX_AWAITS);
        await_count = codegen.async_collect_count;
        ret_expr = codegen.async_collect_ret_expr;
        has_await_loop = codegen.async_collect_has_loop;
        var ci: i32 = 0;
        while ci < await_count && ci < 256 {
            await_operands[ci] = codegen.async_collect_operands[ci];
            await_bind_names[ci] = codegen.async_collect_names[ci];
            await_bind_types[ci] = codegen.async_collect_types[ci];
            ci = ci + 1;
        }
        collect_async_pre_return_locals(codegen, body);
    }
    // 编译期计算状态机字节大小（使用真实类型大小）
    // - state = 4 字节
    // - await_fut（vtable+data 接口）= 16 字节
    // - 循环变量 = 16 字节
    // - await 绑定：按实际绑定类型大小
    // - 参数：按实际参数类型大小
    // 结果存 codegen.async_state_size：> 0 && <= 256 则栈分配（暂未启用），否则堆分配
    {
        var est: i32 = 4 + 16;
        if has_await_loop != 0 {
            est = est + 16;
        }
        // await 绑定：按实际类型大小
        var ai: i32 = 0;
        while ai < await_count && ai < 256 {
            const bind_type_node: &ASTNode = await_bind_types[ai];
            if bind_type_node != null {
                const sz: i32 = get_type_node_size_bytes(codegen, bind_type_node);
                if sz > 0 {
                    est = est + sz;
                } else {
                    est = est + 16;
                }
            } else {
                est = est + 16;
            }
            ai = ai + 1;
        }
        // 参数：按实际类型大小
        {
            var pc: i32 = fn_decl.fn_decl_param_count;
            if pc > 16 { pc = 16; }
            var pi2: i32 = 0;
            while pi2 < pc {
                const param: &ASTNode = fn_decl.fn_decl_params[pi2];
                if param != null && param.type == ASTNodeType.AST_VAR_DECL {
                    const sz: i32 = get_type_node_size_bytes(codegen, param.var_decl_type);
                    if sz > 0 {
                        est = est + sz;
                    } else {
                        est = est + 16;
                    }
                }
                pi2 = pi2 + 1;
            }
        }
        codegen.async_state_size = est;
    }
    // 兼容无 await 判断：type_args_poll / 无-await 分支用 await_count == 0

    // poll 返回类型：无 await 且返回 !Future<T> 时为 Poll<!Future<T>>，否则为 Poll<inner>
    const type_args_poll: & & ASTNode = compiler_arena_alloc(codegen.arena, @size_of(&ASTNode)) as & & ASTNode;
    var safe_poll: &byte = get_safe_c_identifier(codegen, get_mono_union_name(codegen, "Poll" as &byte, type_args, 1));
    var poll_ret_c: &byte = null;
    var poll_union_c: &byte = null;
    var return_future_err_union: i32 = 0;
    if type_args_poll != null {
        // 返回 !Future<T> 时 poll 始终为 Poll<!Future<T>>（有无 await 一致），否则为 Poll<inner>
        if full_return_type != null && full_return_type.type == ASTNodeType.AST_TYPE_ERROR_UNION &&
            full_return_type.type_error_union_payload_type != null {
            const pl: &ASTNode = full_return_type.type_error_union_payload_type;
            if pl.type == ASTNodeType.AST_TYPE_NAMED && pl.type_named_name != null &&
                strcmp(pl.type_named_name as *byte, "Future" as *byte) == 0 {
                return_future_err_union = 1;
            }
        }
        if return_future_err_union != 0 {
            var poll_inner: &ASTNode = null;
            if effective_return_type.type_named_type_args != null && effective_return_type.type_named_type_arg_count >= 1 {
                const arg0: &ASTNode = effective_return_type.type_named_type_args[0];
                if arg0 != null { poll_inner = arg0; }
            }
            if ret_expr != null && ret_expr.type == ASTNodeType.AST_STRUCT_INIT && ret_expr.struct_init_struct_name != null &&
                strcmp(ret_expr.struct_init_struct_name as *byte, "Future" as *byte) == 0 &&
                full_return_type != null && full_return_type.type_error_union_payload_type != null {
                poll_inner = full_return_type.type_error_union_payload_type;
            }
            if poll_inner == null && full_return_type != null && full_return_type.type_error_union_payload_type != null {
                poll_inner = full_return_type.type_error_union_payload_type;
            }
            type_args_poll[0] = poll_inner;
            const poll_type_node: &ASTNode = ast_new_node(ASTNodeType.AST_TYPE_NAMED, 0, 0, codegen.arena, null);
            const poll_union_decl: &ASTNode = find_union_decl_c99(codegen, "Poll" as &byte);
            if poll_union_decl != null {
                gen_mono_union_definition(codegen, poll_union_decl, type_args_poll, 1);
            }
            const poll_full_mono: &byte = get_mono_union_name(codegen, "Poll" as &byte, type_args_poll, 1);
            if poll_full_mono != null {
                safe_poll = get_safe_c_identifier(codegen, poll_full_mono);
                const pbuf_full: &byte = compiler_arena_alloc(codegen.arena, 256) as &byte;
                if pbuf_full != null {
                    snprintf(pbuf_full as *byte, 256, "struct uya_tagged_%s" as *byte, safe_poll as *byte);
                    poll_ret_c = pbuf_full;
                }
                const ubuf_full: &byte = compiler_arena_alloc(codegen.arena, 256) as &byte;
                if ubuf_full != null {
                    snprintf(ubuf_full as *byte, 256, "union %s" as *byte, safe_poll as *byte);
                    poll_union_c = ubuf_full;
                }
            }
            const future_full_mono: &byte = get_mono_struct_name(codegen, "Future" as &byte, type_args_poll, 1);
            if future_full_mono != null {
                vtable_future_safe = get_safe_c_identifier(codegen, future_full_mono);
                const future_type_node: &ASTNode = ast_new_node(ASTNodeType.AST_TYPE_NAMED, 0, 0, codegen.arena, null);
                if future_type_node != null {
                    future_type_node.type_named_name = "Future" as &byte;
                    future_type_node.type_named_type_args = type_args_poll;
                    future_type_node.type_named_type_arg_count = 1;
                    c99_type_to_c(codegen, future_type_node);
                }
            }
        }
    }
    if poll_ret_c == null {
        const pbuf: &byte = compiler_arena_alloc(codegen.arena, 256) as &byte;
        if pbuf != null {
            snprintf(pbuf as *byte, 256, "struct uya_tagged_%s" as *byte, safe_poll as *byte);
            poll_ret_c = pbuf;
        }
        const ubuf2: &byte = compiler_arena_alloc(codegen.arena, 256) as &byte;
        if ubuf2 != null {
            snprintf(ubuf2 as *byte, 256, "union %s" as *byte, safe_poll as *byte);
            poll_union_c = ubuf2;
        }
    }
    // 状态机内 Ready 载荷类型：poll 返回 Poll<T>，Ready 的载荷为 T（inner），故用 inner_err_c
    var ready_payload_c: &byte = inner_err_c;
    // 子 future 的 vtable 名：返回 !Future<T> 时为 Future<!Future<T>>，否则为 safe_future
    var child_vtable_safe: &byte = safe_future;
    if return_future_err_union != 0 { child_vtable_safe = vtable_future_safe; }
    var state_slot_iface_c: &byte = iface_c;
    // 首段 await 是否对 !Future<T> 做 try：返回 !Future<T> 或绑定类型为 Future 时做 try，存的是 .value（Future<T> 接口）
    var await_operand_is_err_future: i32 = return_future_err_union;
    if await_operand_is_err_future == 0 && await_count > 0 && await_bind_types[0] != null && await_bind_types[0].type == ASTNodeType.AST_TYPE_NAMED &&
        await_bind_types[0].type_named_name != null &&
        strcmp(await_bind_types[0].type_named_name as *byte, "Future" as *byte) == 0 {
        await_operand_is_err_future = 1;
    }
    // 当 return_future_err_union && await_operand_is_err_future 时，子 future 实际是 Future<T>，其 poll 返回 Poll<T>
    var child_poll_ret_c: &byte = poll_ret_c;
    var child_poll_union_c: &byte = poll_union_c;
    var child_inner_is_err_union: i32 = inner_is_err_union;
    if return_future_err_union != 0 && await_count > 0 && full_return_type != null && full_return_type.type_error_union_payload_type != null &&
        effective_return_type.type_named_type_args != null {
        var child_ta: & & ASTNode = effective_return_type.type_named_type_args;
        var child_ta_count: i32 = 1;
        var caller_returns_future_literal: i32 = 0;
        if ret_expr != null && ret_expr.type == ASTNodeType.AST_STRUCT_INIT && ret_expr.struct_init_struct_name != null &&
            strcmp(ret_expr.struct_init_struct_name as *byte, "Future" as *byte) == 0 {
            caller_returns_future_literal = 1;
        }
        if caller_returns_future_literal != 0 && await_bind_types[0] != null && await_bind_types[0].type == ASTNodeType.AST_TYPE_NAMED &&
            await_bind_types[0].type_named_name != null && strcmp(await_bind_types[0].type_named_name as *byte, "Future" as *byte) == 0 {
            const pay_ta: & & ASTNode = compiler_arena_alloc(codegen.arena, @size_of(&ASTNode)) as & & ASTNode;
            if pay_ta != null { pay_ta[0] = full_return_type.type_error_union_payload_type; child_ta = pay_ta; child_ta_count = 1; }
        }
        if child_ta != null && child_ta_count > 0 {
            const child_poll_mono: &byte = get_mono_union_name(codegen, "Poll" as &byte, child_ta, child_ta_count);
            const child_future_mono: &byte = get_mono_struct_name(codegen, "Future" as &byte, child_ta, child_ta_count);
            if child_poll_mono != null && child_future_mono != null {
                const cps: &byte = get_safe_c_identifier(codegen, child_poll_mono);
                const cfs: &byte = get_safe_c_identifier(codegen, child_future_mono);
                if cps != null && cfs != null {
                    const cpr: &byte = compiler_arena_alloc(codegen.arena, 128) as &byte;
                    const cpu: &byte = compiler_arena_alloc(codegen.arena, 128) as &byte;
                    if cpr != null { snprintf(cpr as *byte, 128, "struct uya_tagged_%s" as *byte, cps as *byte); child_poll_ret_c = cpr; }
                    if cpu != null { snprintf(cpu as *byte, 128, "union %s" as *byte, cps as *byte); child_poll_union_c = cpu; }
                    child_vtable_safe = cfs;
                    child_inner_is_err_union = 0;
                    const slot_buf: &byte = compiler_arena_alloc(codegen.arena, 64) as &byte;
                    if slot_buf != null && concrete_future_safe != null {
                        snprintf(slot_buf as *byte, 64, "struct uya_interface_%s" as *byte, concrete_future_safe as *byte);
                        state_slot_iface_c = slot_buf;
                    }
                }
            }
        }
    }
    // 当 return_future_err_union=0 时，状态机实现 Future<inner>，需用 type_args 的 vtable 名
    if return_future_err_union == 0 && type_args != null {
        const mono_future: &byte = get_mono_struct_name(codegen, "Future" as &byte, type_args, 1);
        if mono_future != null { vtable_future_safe = get_safe_c_identifier(codegen, mono_future); }
    }
    // 状态机 await 槽位类型：return_future_err_union 时为 effective 的接口；否则若首段做 try 则用 iface_c（存 !Future<T>.value），否则用 Future<inner>
    if return_future_err_union != 0 && await_count > 0 && effective_return_type.type_named_type_args != null && effective_return_type.type_named_type_arg_count >= 1 {
        var slot_type_args: & & ASTNode = effective_return_type.type_named_type_args;
        var slot_type_count: i32 = effective_return_type.type_named_type_arg_count;
        const pay0: &ASTNode = effective_return_type.type_named_type_args[0];
        if pay0 != null && pay0.type == ASTNodeType.AST_TYPE_ERROR_UNION && pay0.type_error_union_payload_type != null {
            const one_arg: & & ASTNode = compiler_arena_alloc(codegen.arena, @size_of(&ASTNode) * 2) as & & ASTNode;
            if one_arg != null {
                one_arg[0] = pay0.type_error_union_payload_type;
                slot_type_args = one_arg;
                slot_type_count = 1;
            }
        }
        const slot_mono: &byte = get_mono_struct_name(codegen, "Future" as &byte, slot_type_args, slot_type_count);
        if slot_mono != null {
            const slot_safe: &byte = get_safe_c_identifier(codegen, slot_mono);
            if slot_safe != null {
                const slot_buf2: &byte = compiler_arena_alloc(codegen.arena, 64) as &byte;
                if slot_buf2 != null {
                    snprintf(slot_buf2 as *byte, 64, "struct uya_interface_%s" as *byte, slot_safe as *byte);
                    state_slot_iface_c = slot_buf2;
                }
            }
        }
    }
    if return_future_err_union == 0 && type_args != null && type_args[0] != null {
        if await_operand_is_err_future != 0 {
            state_slot_iface_c = iface_c;
        } else {
            const future_inner_type_node: &ASTNode = ast_new_node(ASTNodeType.AST_TYPE_NAMED, 0, 0, codegen.arena, null);
            if future_inner_type_node != null {
                future_inner_type_node.type_named_name = "Future" as &byte;
                future_inner_type_node.type_named_type_args = type_args;
                future_inner_type_node.type_named_type_arg_count = 1;
                const slot_c: &byte = c99_type_to_c(codegen, future_inner_type_node);
                if slot_c != null { state_slot_iface_c = slot_c; }
            }
        }
    }

    // async 状态机 struct 名
    const async_struct: &byte = compiler_arena_alloc(codegen.arena, 128) as &byte;
    const poll_name: &byte = compiler_arena_alloc(codegen.arena, 256) as &byte;
    const vtable_name: &byte = compiler_arena_alloc(codegen.arena, 256) as &byte;
    if async_struct == null || poll_name == null || vtable_name == null {
        return;
    }
    snprintf(async_struct as *byte, 128, "uya_async_%s" as *byte, func_c_name as *byte);
    snprintf(poll_name as *byte, 256, "uya_%s_poll" as *byte, async_struct as *byte);
    snprintf(vtable_name as *byte, 256, "uya_vtable_%s_%s" as *byte, vtable_future_safe as *byte, async_struct as *byte);

    // 确保 stdlib（malloc）可用
    codegen.needs_stdlib_h = 1;

    // 若存在循环内 await，检查 ret_expr 是否引用非 await 绑定的循环内变量
    // 如果是，需要将该变量持久化到状态机结构体中
    var loop_var_name: &byte = null;
    if has_await_loop != 0 && ret_expr != null && await_count >= 2 {
        // 简单遍历 ret_expr 收集标识符（只检查顶层标识符）
        var ret_names: [&byte: 16] = [];
        var ret_name_count: i32 = 0;
        // 检查 ret_expr 本身是否是标识符
        if ret_expr.type == ASTNodeType.AST_IDENTIFIER && ret_expr.identifier_name != null {
            ret_names[0] = ret_expr.identifier_name;
            ret_name_count = 1;
        } else if ret_expr.type == ASTNodeType.AST_BINARY_EXPR {
            // 检查二元表达式的左右操作数
            if ret_expr.binary_expr_left != null && ret_expr.binary_expr_left.type == ASTNodeType.AST_IDENTIFIER &&
                ret_expr.binary_expr_left.identifier_name != null && ret_name_count < 16 {
                ret_names[ret_name_count] = ret_expr.binary_expr_left.identifier_name;
                ret_name_count = ret_name_count + 1;
            }
            if ret_expr.binary_expr_right != null && ret_expr.binary_expr_right.type == ASTNodeType.AST_IDENTIFIER &&
                ret_expr.binary_expr_right.identifier_name != null && ret_name_count < 16 {
                ret_names[ret_name_count] = ret_expr.binary_expr_right.identifier_name;
                ret_name_count = ret_name_count + 1;
            }
        }
        
        // 检查每个 ret_expr 中的标识符是否都是 await 绑定
        var k: i32 = 0;
        while k < ret_name_count && k < 16 {
            const rn: &byte = ret_names[k];
            if rn != null {
                var is_bind: i32 = 0;
                var bi: i32 = 0;
                while bi < await_count && bi < 256 {
                    if await_bind_names[bi] != null && strcmp(await_bind_names[bi] as *byte, rn as *byte) == 0 {
                        is_bind = 1;
                        break;
                    }
                    bi = bi + 1;
                }
                if is_bind == 0 {
                    // 这是一个非 await 绑定的引用，需要持久化
                    async_loop_var_is_total = 1;
                    loop_var_name = rn;
                    break;
                }
            }
            k = k + 1;
        }
    }

    // 若 poll 内会用到子 future 的 vtable，在 poll 前输出该 vtable 结构体定义（否则 ->poll 会报未定义类型），并标记已定义避免后续重复
    if await_count > 0 && child_poll_ret_c != null {
        const vtable_struct_buf: &byte = compiler_arena_alloc(codegen.arena, 128) as &byte;
        if vtable_struct_buf != null {
            snprintf(vtable_struct_buf as *byte, 128, "uya_vtable_%s" as *byte, child_vtable_safe as *byte);
            if is_struct_defined(codegen, vtable_struct_buf) == 0 {
                fprintf(codegen.emit_stream as *void, "struct uya_vtable_%s { %s (*poll)(void *self, struct Waker *); };\n" as *byte,
                    child_vtable_safe as *byte, child_poll_ret_c as *byte);
                mark_struct_defined(codegen, vtable_struct_buf);
            }
        }
    }

    // 输出状态机 struct（含捕获参数 + 所有 await 绑定变量）
    // await 绑定变量必须存在结构体中，确保跨 poll 调用时值不丢失
    emit_line_directive(codegen, fn_decl.line, fn_decl.filename);
    fputs("struct " as *byte, codegen.emit_stream as *void);
    fprintf(codegen.emit_stream as *void, "%s" as *byte, async_struct as *byte);
    fputs(" { int32_t state; " as *byte, codegen.emit_stream as *void);
    if await_count > 0 && concrete_future_safe != null && await_operand_is_err_future != 0 {
        fprintf(codegen.emit_stream as *void, "struct %s _uya_await_storage; " as *byte, concrete_future_safe as *byte);
    }
    fprintf(codegen.emit_stream as *void, "%s await_fut;" as *byte, state_slot_iface_c as *byte);
    if async_loop_var_is_total != 0 {
        // 上次 read 返回的字节数：state==2 可能在后续 poll 调用中进入，局部 n 未定义，不能与 written 比较
        fputs(" size_t _uya_total; size_t _uya_read_n;" as *byte, codegen.emit_stream as *void);
    }
    // 输出所有 await 绑定变量到结构体（确保跨 poll 调用时值不丢失）
    var bind_i: i32 = 0;
    while bind_i < await_count {
        const bind_c_type: &byte = c99_type_to_c(codegen, await_bind_types[bind_i]);
        const bind_safe_name: &byte = get_safe_c_identifier(codegen, await_bind_names[bind_i]);
        if bind_c_type != null && bind_safe_name != null {
            fprintf(codegen.emit_stream as *void, " %s _uya_bind_%s;" as *byte, bind_c_type as *byte, bind_safe_name as *byte);
        }
        bind_i = bind_i + 1;
    }
    var loc_i: i32 = 0;
    while loc_i < codegen.async_local_count && loc_i < 16 {
        const ltype_c: &byte = c99_type_to_c(codegen, codegen.async_local_types[loc_i]);
        const lname_safe: &byte = get_safe_c_identifier(codegen, codegen.async_local_names[loc_i]);
        if ltype_c != null && lname_safe != null {
            fprintf(codegen.emit_stream as *void, " %s _uya_loc_%s;" as *byte, ltype_c as *byte, lname_safe as *byte);
        }
        loc_i = loc_i + 1;
    }
    const param_count: i32 = fn_decl.fn_decl_param_count;
    const params: & & ASTNode = fn_decl.fn_decl_params;
    var pi: i32 = 0;
    while pi < param_count && pi < 16 {
        const param: &ASTNode = params[pi];
        if param != null && param.type == ASTNodeType.AST_VAR_DECL && param.var_decl_type != null && param.var_decl_name != null {
            const ptype_c: &byte = c99_type_to_c(codegen, param.var_decl_type);
            const pname: &byte = get_safe_c_identifier(codegen, param.var_decl_name);
            if ptype_c != null && pname != null {
                fprintf(codegen.emit_stream as *void, " %s %s;" as *byte, ptype_c as *byte, pname as *byte);
            }
        }
        pi = pi + 1;
    }
    fputs(" };\n" as *byte, codegen.emit_stream as *void);

    // 设置 async 参数捕获（poll 内 gen_expr 将参数引用为 s->param）
    const async_s: &byte = "s" as *byte;
    codegen.async_state_var = async_s;
    if async_loop_var_is_total != 0 && loop_var_name != null {
        codegen.async_loop_var_name = loop_var_name;
        codegen.async_loop_var_c = "s->_uya_total" as &byte;
    }
    // 设置 await 绑定变量（poll 内 gen_expr 将绑定变量引用为 s->_uya_bind_name）
    codegen.async_bind_count = await_count;
    var bind_idx: i32 = 0;
    while bind_idx < await_count && bind_idx < 256 {
        codegen.async_bind_names[bind_idx] = await_bind_names[bind_idx];
        bind_idx = bind_idx + 1;
    }
    codegen.async_param_count = 0;
    pi = 0;
    while pi < param_count && pi < 16 {
        const param: &ASTNode = params[pi];
        if param != null && param.type == ASTNodeType.AST_VAR_DECL && param.var_decl_name != null {
            codegen.async_param_names[pi] = param.var_decl_name;
            codegen.async_param_count = codegen.async_param_count + 1;
            // 将捕获参数注册为 local_variables，使 get_identifier_type_c 能找到类型（用于 reader.read 等接口/方法调用）
            if param.var_decl_type != null && codegen.local_variable_count < C99_MAX_LOCAL_VARS {
                const ptype_c: &byte = c99_type_to_c(codegen, param.var_decl_type);
                if ptype_c != null {
                    codegen.local_variables[codegen.local_variable_count].name = param.var_decl_name;
                    codegen.local_variables[codegen.local_variable_count].type_c = ptype_c;
                    codegen.local_variables[codegen.local_variable_count].type_node = param.var_decl_type;
                    codegen.local_variable_count = codegen.local_variable_count + 1;
                }
            }
        }
        pi = pi + 1;
    }

    // 输出 poll 函数
    if poll_ret_c == null {
        poll_ret_c = "struct uya_tagged_Poll_i32" as &byte;
    }
    if poll_union_c == null {
        poll_union_c = "union Poll_i32" as &byte;
    }
    fprintf(codegen.emit_stream as *void, "static %s %s(void *self, struct Waker *waker) {\n" as *byte, poll_ret_c as *byte, poll_name as *byte);
    fprintf(codegen.emit_stream as *void, "    struct %s *s = (struct %s *)self;\n" as *byte, async_struct as *byte, async_struct as *byte);
    fprintf(codegen.emit_stream as *void, "    if (s == (void*)0) { return (%s){ ._tag = 0 }; }\n" as *byte, poll_ret_c as *byte);
    // await 绑定变量已在结构体中（_uya_bind_*），无需局部变量声明
    // state machine：state 0 = 起点；state 1..await_count = 各 await 就绪后
    fputs("    if (s->state == 0) {\n" as *byte, codegen.emit_stream as *void);
    if await_count > 0 {
        if async_loop_var_is_total != 0 {
            fputs("        s->_uya_total = 0;\n" as *byte, codegen.emit_stream as *void);
        }
        fputs("        s->state = 1;\n" as *byte, codegen.emit_stream as *void);
        fputs("        s->await_fut = " as *byte, codegen.emit_stream as *void);
        if await_operand_is_err_future != 0 && full_return_type != null && full_return_type.type == ASTNodeType.AST_TYPE_ERROR_UNION &&
            concrete_future_safe != null && state_slot_iface_c != null {
            const operand_union_c: &byte = c99_type_to_c(codegen, full_return_type);
            if operand_union_c != null {
                fprintf(codegen.emit_stream as *void, "({ %s _uya_await_tmp = " as *byte, operand_union_c as *byte);
                gen_expr(codegen, await_operands[0]);
                fprintf(codegen.emit_stream as *void, "; if (_uya_await_tmp.error_id != 0) abort(); s->_uya_await_storage = *(struct %s *)_uya_await_tmp.value.data; s->await_fut = (%s){ .vtable = _uya_await_tmp.value.vtable, .data = (void*)&s->_uya_await_storage }; })" as *byte, concrete_future_safe as *byte, state_slot_iface_c as *byte);
            } else {
                gen_expr(codegen, await_operands[0]);
            }
        } else if await_operand_is_err_future != 0 && full_return_type != null && full_return_type.type == ASTNodeType.AST_TYPE_ERROR_UNION {
            const operand_union_c: &byte = c99_type_to_c(codegen, full_return_type);
            if operand_union_c != null {
                fprintf(codegen.emit_stream as *void, "({ %s _uya_await_tmp = " as *byte, operand_union_c as *byte);
                gen_expr(codegen, await_operands[0]);
                fprintf(codegen.emit_stream as *void, "; if (_uya_await_tmp.error_id != 0) abort(); _uya_await_tmp.value; })" as *byte);
            } else {
                gen_expr(codegen, await_operands[0]);
            }
        } else {
            gen_expr(codegen, await_operands[0]);
        }
        fputs(";\n" as *byte, codegen.emit_stream as *void);
    } else {
        emit_async_pre_return_local_inits(codegen);
        fputs("        s->state = 2;\n" as *byte, codegen.emit_stream as *void);
    }
    fputs("    }\n" as *byte, codegen.emit_stream as *void);

    var state_k: i32 = 1;
    while state_k <= await_count {
        fprintf(codegen.emit_stream as *void, "    if (s->state == %d) {\n" as *byte, state_k);
        fprintf(codegen.emit_stream as *void, "        %s p = ((struct uya_vtable_%s *)s->await_fut.vtable)->poll(s->await_fut.data, waker);\n" as *byte,
