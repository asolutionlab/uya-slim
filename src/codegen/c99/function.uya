                        fprintf(codegen.emit_stream as *void, "(%s){ .vtable = (void*)0, .data = (void*)0 }" as *byte, iface_c as *byte);
                    }
                    codegen.current_function_return_type = null;
                    fputs(" };\n" as *byte, codegen.emit_stream as *void);
                    if no_await_is_future_literal != 0 {
                        fprintf(codegen.emit_stream as *void, "        return (%s){ ._tag = 1, .u = (%s){ .Ready = ok.value } };\n" as *byte, poll_ret_c as *byte, poll_union_c as *byte);
                    } else {
                        fprintf(codegen.emit_stream as *void, "        return (%s){ ._tag = 1, .u = (%s){ .Ready = (*(struct %s *)ok.value.data).state.u.Ready } };\n" as *byte, poll_ret_c as *byte, poll_union_c as *byte, concrete_future_safe as *byte);
                    }
                } else {
                    fprintf(codegen.emit_stream as *void, "        return (%s){ ._tag = 0 };\n" as *byte, poll_ret_c as *byte);
                }
            }
        } else if inner_is_err_union != 0 {
            if inner.type_error_union_payload_type != null &&
                inner.type_error_union_payload_type.type == ASTNodeType.AST_TYPE_NAMED &&
                inner.type_error_union_payload_type.type_named_name != null &&
                strcmp(inner.type_error_union_payload_type.type_named_name as *byte, "void" as *byte) == 0 {
                fprintf(codegen.emit_stream as *void, "        %s ok = (%s){ .error_id = 0 };\n" as *byte, inner_err_c as *byte, inner_err_c as *byte);
            } else {
                fprintf(codegen.emit_stream as *void, "        %s ok = (%s){ .error_id = 0, .value = " as *byte, inner_err_c as *byte, inner_err_c as *byte);
                if ret_expr != null {
                    gen_expr(codegen, ret_expr);
                } else {
                    fputs("0" as *byte, codegen.emit_stream as *void);
                }
                fputs(" };\n" as *byte, codegen.emit_stream as *void);
            }
            fprintf(codegen.emit_stream as *void, "        return (%s){ ._tag = 1, .u = (%s){ .Ready = ok } };\n" as *byte, poll_ret_c as *byte, poll_union_c as *byte);
        } else {
            codegen.current_function_return_type = effective_return_type;
            fprintf(codegen.emit_stream as *void, "        return (%s){ ._tag = 1, .u = (%s){ .Ready = " as *byte, poll_ret_c as *byte, poll_union_c as *byte);
            if ret_expr != null {
                gen_expr(codegen, ret_expr);
            } else {
                fputs("0" as *byte, codegen.emit_stream as *void);
            }
            codegen.current_function_return_type = null;
            fputs(" } };\n" as *byte, codegen.emit_stream as *void);
        }
        fputs("    }\n" as *byte, codegen.emit_stream as *void);
    }
    fputs("}\n" as *byte, codegen.emit_stream as *void);

    // 清除 async 参数捕获
    codegen.async_state_var = null;
    codegen.async_param_count = 0;
    codegen.async_local_count = 0;
    codegen.async_loop_var_name = null;
    codegen.async_loop_var_c = null;
    pi = 0;
    while pi < 16 {
        codegen.async_param_names[pi] = null;
        pi = pi + 1;
    }

    // 返回 !Future<T> 时 vtable 类型为 Future<!Future<T>>，需先给出完整定义再定义常量（否则 C 报 incomplete type）。
    // 有 await 时由 1174 块输出；无 await 时此处输出。使用 arena 存储名称以保证 mark_struct_defined 的持久性。
    if return_future_err_union != 0 && vtable_future_safe != null && poll_ret_c != null {
    const vtable_struct_name: &byte = compiler_arena_alloc(codegen.arena, 128) as &byte;
    if vtable_struct_name != null {
        snprintf(vtable_struct_name as *byte, 128, "uya_vtable_%s" as *byte, vtable_future_safe as *byte);
        if is_struct_defined(codegen, vtable_struct_name) == 0 {
            const iface_struct_name: &byte = compiler_arena_alloc(codegen.arena, 128) as &byte;
            if iface_struct_name != null {
                snprintf(iface_struct_name as *byte, 128, "uya_interface_%s" as *byte, vtable_future_safe as *byte);
                fprintf(codegen.emit_stream as *void, "struct uya_interface_%s { void *vtable; void *data; };\n" as *byte, vtable_future_safe as *byte);
                fprintf(codegen.emit_stream as *void, "struct uya_vtable_%s {\n  %s (*poll)(void *self, struct Waker *);\n};\n" as *byte, vtable_future_safe as *byte, poll_ret_c as *byte);
                mark_struct_defined(codegen, iface_struct_name);
                mark_struct_defined(codegen, vtable_struct_name);
            }
        }
    }
    }
    // vtable 常量
    fprintf(codegen.emit_stream as *void, "static const struct uya_vtable_%s %s = { (%s (*)(void *self, struct Waker *))&%s };\n" as *byte,
        vtable_future_safe as *byte, vtable_name as *byte, poll_ret_c as *byte, poll_name as *byte);

    // 输出原函数：分配状态机，复制参数，返回 Future
    var wrapper_ret_c: &byte = iface_c;
    var need_wrap: i32 = 0;
    if full_return_type != null && full_return_type.type == ASTNodeType.AST_TYPE_ERROR_UNION {
        wrapper_ret_c = c99_type_to_c(codegen, full_return_type);
        if wrapper_ret_c != null && strstr(wrapper_ret_c as *byte, "err_union_" as *byte) != null {
            need_wrap = 1;
        }
    }
    if fn_decl.fn_decl_is_export != 0 {
        fprintf(codegen.emit_stream as *void, "%s %s(" as *byte, wrapper_ret_c as *byte, func_c_name as *byte);
    } else {
        // 多文件 C（split）：与 gen_function_prototype / 普通函数定义一致，不加 static，避免 uya_split_protos.h 中非 static 声明与本定义冲突
        if codegen.split_enabled == 0 {
            fprintf(codegen.emit_stream as *void, "static __attribute__((unused)) %s %s(" as *byte, wrapper_ret_c as *byte, func_c_name as *byte);
        } else {
            fprintf(codegen.emit_stream as *void, "%s %s(" as *byte, wrapper_ret_c as *byte, func_c_name as *byte);
        }
    }
    pi = 0;
    var first_param: i32 = 1;
    while pi < param_count && pi < 16 {
        const param: &ASTNode = params[pi];
        if param != null && param.type == ASTNodeType.AST_VAR_DECL && param.var_decl_type != null && param.var_decl_name != null {
            if first_param == 0 {
                fputs(", " as *byte, codegen.emit_stream as *void);
            }
            first_param = 0;
            const ptype_c: &byte = c99_type_to_c(codegen, param.var_decl_type);
            const pname: &byte = get_safe_c_identifier(codegen, param.var_decl_name);
            if ptype_c != null && pname != null {
                fprintf(codegen.emit_stream as *void, "%s %s" as *byte, ptype_c as *byte, pname as *byte);
            }
        }
        pi = pi + 1;
    }
    fputs(") {\n" as *byte, codegen.emit_stream as *void);
    if await_count == 0 && return_future_err_union != 0 && body != null {
        emit_async_err_future_wrapper_prelude(codegen, fn_decl, body, full_return_type);
    }
    // 状态机分配：始终使用 malloc 堆分配，避免大状态机（>256B）栈溢出
    // 栈分配路径（<=64B 估算）暂未启用
    fprintf(codegen.emit_stream as *void, "    struct %s *s = (struct %s *)malloc(sizeof(struct %s));\n" as *byte, async_struct as *byte, async_struct as *byte, async_struct as *byte);
    fputs("    if (s != (void*)0) { s->state = 0; __builtin_memset((void *)&s->await_fut, 0, sizeof(s->await_fut)); " as *byte, codegen.emit_stream as *void);
    pi = 0;
    while pi < param_count && pi < 16 {
        const param: &ASTNode = params[pi];
        if param != null && param.type == ASTNodeType.AST_VAR_DECL && param.var_decl_name != null {
            const pname: &byte = get_safe_c_identifier(codegen, param.var_decl_name);
            if pname != null {
                fprintf(codegen.emit_stream as *void, "s->%s = %s; " as *byte, pname as *byte, pname as *byte);
            }
        }
        pi = pi + 1;
    }
    fputs("}\n" as *byte, codegen.emit_stream as *void);
    if need_wrap != 0 {
        fprintf(codegen.emit_stream as *void, "    return (%s){ .error_id = 0, .value = (%s){ .vtable = (void*)&%s, .data = (void*)s } };\n" as *byte, wrapper_ret_c as *byte, iface_c as *byte, vtable_name as *byte);
    } else {
        fprintf(codegen.emit_stream as *void, "    return (%s){ .vtable = (void*)&%s, .data = (void*)s };\n" as *byte, iface_c as *byte, vtable_name as *byte);
    }
    fputs("\n}\n" as *byte, codegen.emit_stream as *void);
}

// 是否该结构体类型有 drop 方法（规范 §12）
fn type_has_drop_c99(codegen: &C99CodeGenerator, struct_name: &byte) i32 {
    if find_method_in_struct_c99(codegen, struct_name, "drop" as *byte) != null {
        return 1;
    }
    return 0;
}

// 生成方法函数的前向声明（uya_StructName_methodname）
fn gen_method_prototype(codegen: &C99CodeGenerator, fn_decl: &ASTNode, struct_name: &byte) void {
    if fn_decl == null || fn_decl.type != ASTNodeType.AST_FN_DECL || struct_name == null {
        return;
    }
    const method_name: &byte = fn_decl.fn_decl_name;
    const c_name: &byte = get_method_c_name(codegen, struct_name, method_name);
    if c_name == null {
        return;
    }
    var return_c: &byte = convert_array_return_type(codegen, fn_decl.fn_decl_return_type);
    return_c = normalize_poll_return_type(codegen, return_c);
    c99_preregister_slices_method(codegen, fn_decl, struct_name);
    const params: & & ASTNode = fn_decl.fn_decl_params;
    const param_count: i32 = fn_decl.fn_decl_param_count;
    fprintf(codegen.emit_stream as *void, "%s %s(" as *byte, return_c as *byte, c_name as *byte);
    var i: i32 = 0;
    while i < param_count {
        const param: &ASTNode = params[i];
        if param == null || param.type != ASTNodeType.AST_VAR_DECL {
            i = i + 1;
            continue;
        }
        const param_name: &byte = get_safe_c_identifier(codegen, param.var_decl_name);
        const param_type_c: &byte = c99_type_to_c_with_self_opt(codegen, param.var_decl_type, struct_name, 0);
        format_param_type(codegen, param_type_c, param_name, codegen.emit_stream as *void);
        if i < param_count - 1 {
            c99_emit_comma_space(codegen);
        }
        i = i + 1;
    }
    fputs(");\n" as *byte, codegen.emit_stream as *void);
}

// 生成方法函数定义（uya_StructName_methodname）
fn gen_method_function(codegen: &C99CodeGenerator, fn_decl: &ASTNode, struct_name: &byte) void {
    if fn_decl == null || fn_decl.type != ASTNodeType.AST_FN_DECL || struct_name == null || fn_decl.fn_decl_body == null {
        return;
    }
    const method_name: &byte = fn_decl.fn_decl_name;
    const c_name: &byte = get_method_c_name(codegen, struct_name, method_name);
    if c_name == null {
        return;
    }
    var return_c: &byte = convert_array_return_type(codegen, fn_decl.fn_decl_return_type);
    return_c = normalize_poll_return_type(codegen, return_c);
    const params: & & ASTNode = fn_decl.fn_decl_params;
    const param_count: i32 = fn_decl.fn_decl_param_count;
    emit_line_directive(codegen, fn_decl.line, fn_decl.filename);
    c99_preregister_slices_method(codegen, fn_decl, struct_name);
    fprintf(codegen.emit_stream as *void, "%s %s(" as *byte, return_c as *byte, c_name as *byte);
    var i: i32 = 0;
    while i < param_count {
        const param: &ASTNode = params[i];
        if param == null || param.type != ASTNodeType.AST_VAR_DECL {
            i = i + 1;
            continue;
        }
        const param_name: &byte = get_safe_c_identifier(codegen, param.var_decl_name);
        const param_type_c: &byte = c99_type_to_c_with_self_opt(codegen, param.var_decl_type, struct_name, 0);
        format_param_type(codegen, param_type_c, param_name, codegen.emit_stream as *void);
        if i < param_count - 1 {
            c99_emit_comma_space(codegen);
        }
        i = i + 1;
    }
    fputs(") {\n" as *byte, codegen.emit_stream as *void);
    codegen.indent_level = codegen.indent_level + 1;
    codegen.current_function_return_type = fn_decl.fn_decl_return_type;
    const saved_current_function_decl: &ASTNode = codegen.current_function_decl;
    codegen.current_function_decl = fn_decl;
    const saved_method_struct: &byte = codegen.current_method_struct_name;
    codegen.current_method_struct_name = struct_name;
    const saved_local_count: i32 = codegen.local_variable_count;
    const saved_depth: i32 = codegen.current_depth;
    codegen.local_variable_count = 0;
    codegen.current_depth = 0;
    i = 0;
    while i < param_count {
        const param: &ASTNode = params[i];
        if param != null && param.type == ASTNodeType.AST_VAR_DECL {
            const param_name: &byte = get_safe_c_identifier(codegen, param.var_decl_name);
            const param_type_c: &byte = c99_type_to_c_with_self_opt(codegen, param.var_decl_type, struct_name, 0);
            if param_name != null && param_type_c != null && codegen.local_variable_count < C99_MAX_LOCAL_VARS {
                codegen.local_variables[codegen.local_variable_count].name = param.var_decl_name;
                codegen.local_variables[codegen.local_variable_count].type_c = param_type_c;
                codegen.local_variables[codegen.local_variable_count].type_node = param.var_decl_type;
                codegen.local_variable_count = codegen.local_variable_count + 1;
            }
        }
        i = i + 1;
    }
    if method_name != null && strcmp(method_name as *byte, "drop" as *byte) == 0 {
        const struct_decl: &ASTNode = find_struct_decl_c99(codegen, struct_name);
        const self_safe: &byte = get_safe_c_identifier(codegen, "self" as *byte);
        if struct_decl != null && struct_decl.struct_decl_fields != null && self_safe != null {
            const fc: i32 = struct_decl.struct_decl_field_count;
            var fi: i32 = fc - 1;
            while fi >= 0 {
                const field: &ASTNode = struct_decl.struct_decl_fields[fi];
                if field == null || field.type != ASTNodeType.AST_VAR_DECL || field.var_decl_name == null {
                    fi = fi - 1;
                    continue;
                }
                const ft: &ASTNode = field.var_decl_type;
                if ft == null || ft.type != ASTNodeType.AST_TYPE_NAMED || ft.type_named_name == null {
                    fi = fi - 1;
                    continue;
                }
                const field_type_name: &byte = ft.type_named_name;
                if type_has_drop_c99(codegen, field_type_name) == 0 {
                    fi = fi - 1;
                    continue;
                }
                const drop_c: &byte = get_method_c_name(codegen, field_type_name, "drop" as *byte);
                const field_safe: &byte = get_safe_c_identifier(codegen, field.var_decl_name);
                if drop_c != null && field_safe != null {
                    c99_emit_indent(codegen);
                    fprintf(codegen.emit_stream as *void, "/* drop field */ %s(%s.%s);\n" as *byte, drop_c as *byte, self_safe as *byte, field_safe as *byte);
                }
                fi = fi - 1;
            }
        }
    }
    gen_stmt(codegen, fn_decl.fn_decl_body);
    
    // 检查函数体是否以 return 结尾
    var has_return: i32 = 0;
    if fn_decl.fn_decl_body != null && fn_decl.fn_decl_body.type == ASTNodeType.AST_BLOCK {
        const stmts: & & ASTNode = fn_decl.fn_decl_body.block_stmts;
        const stmt_count: i32 = fn_decl.fn_decl_body.block_stmt_count;
        var j: i32 = stmt_count - 1;
        while j >= 0 {
            const s: &ASTNode = stmts[j];
            if s != null && s.type != ASTNodeType.AST_DEFER_STMT && s.type != ASTNodeType.AST_ERRDEFER_STMT {
                if s.type == ASTNodeType.AST_RETURN_STMT {
                    has_return = 1;
                } else {
                    has_return = 0;
                }
                break;
            }
            j = j - 1;
        }
    }
    
    // 如果返回类型是 !void 且函数体没有显式返回，添加默认返回语句
    if has_return == 0 && fn_decl.fn_decl_return_type != null && fn_decl.fn_decl_return_type.type == ASTNodeType.AST_TYPE_ERROR_UNION {
        const payload_node: &ASTNode = fn_decl.fn_decl_return_type.type_error_union_payload_type;
        var is_void_payload: i32 = 0;
        if payload_node == null {
            is_void_payload = 1;
        } else if payload_node.type == ASTNodeType.AST_TYPE_NAMED && payload_node.type_named_name != null &&
            strcmp(payload_node.type_named_name as *byte, "void" as *byte) == 0 {
            is_void_payload = 1;
        }
        if is_void_payload != 0 {
            // !void 类型：返回成功的错误联合（缩进与 C 编译器一致）
            codegen.indent_level = codegen.indent_level + 1;
            c99_emit_indent(codegen);
            fprintf(codegen.emit_stream as *void, "return (%s){ .error_id = 0 };\n" as *byte, return_c as *byte);
            codegen.indent_level = codegen.indent_level - 1;
        }
    }
    
    codegen.current_function_return_type = null;
    codegen.current_function_decl = saved_current_function_decl;
    codegen.current_method_struct_name = saved_method_struct;
    codegen.local_variable_count = saved_local_count;
    codegen.current_depth = saved_depth;
    codegen.indent_level = codegen.indent_level - 1;
    c99_emit_indent(codegen);
    c99_emit_close_brace_newline(codegen);
}

// 检查函数是否是泛型函数（有类型参数）
fn is_generic_function_c99(fn_decl: &ASTNode) i32 {
    if fn_decl == null || fn_decl.type != ASTNodeType.AST_FN_DECL {
        return 0;
    }
    if fn_decl.fn_decl_type_param_count > 0 {
        return 1;
    }
    return 0;
}

// 为泛型调用 ok<i32>(...) 解析应使用哪条顶层泛型 fn 声明（避免与同名 export 冲突，如 std.async 的 ok<T>）。
// 优先：与当前正在生成的函数同文件的声明；其次：全程序唯一匹配；再次：首个匹配的 export。
fn find_generic_fn_decl_for_mono_call(codegen: &C99CodeGenerator, func_name: &byte, type_arg_count: i32) &ASTNode {
    if codegen == null || func_name == null || codegen.program_node == null ||
        codegen.program_node.type != ASTNodeType.AST_PROGRAM {
        return null;
    }
    const dc: i32 = codegen.program_node.program_decl_count;
    if codegen.current_function_decl != null && codegen.current_function_decl.filename != null {
        var i: i32 = 0;
        while i < dc {
            const d: &ASTNode = codegen.program_node.program_decls[i];
            if d != null && d.type == ASTNodeType.AST_FN_DECL && d.fn_decl_name != null &&
                strcmp(d.fn_decl_name as *byte, func_name as *byte) == 0 &&
                d.fn_decl_type_param_count == type_arg_count &&
                d.filename != null &&
                strcmp(d.filename as *byte, codegen.current_function_decl.filename as *byte) == 0 {
                return d;
            }
            i = i + 1;
        }
    }
    var found: &ASTNode = null;
    var nfound: i32 = 0;
    var j: i32 = 0;
    while j < dc {
        const d2: &ASTNode = codegen.program_node.program_decls[j];
        if d2 != null && d2.type == ASTNodeType.AST_FN_DECL && d2.fn_decl_name != null &&
            strcmp(d2.fn_decl_name as *byte, func_name as *byte) == 0 &&
            d2.fn_decl_type_param_count == type_arg_count {
            nfound = nfound + 1;
            found = d2;
        }
        j = j + 1;
    }
    if nfound == 1 {
        return found;
    }
    var k: i32 = 0;
    while k < dc {
        const d3: &ASTNode = codegen.program_node.program_decls[k];
        if d3 != null && d3.type == ASTNodeType.AST_FN_DECL && d3.fn_decl_name != null &&
            strcmp(d3.fn_decl_name as *byte, func_name as *byte) == 0 &&
            d3.fn_decl_type_param_count == type_arg_count &&
            d3.fn_decl_is_export != 0 && d3.fn_decl_extern_lib_name == null {
            return d3;
        }
        k = k + 1;
    }
    return find_function_decl_c99(codegen, func_name);
}

// 获取单态化函数名称
// 例如：identity<i32> -> identity_i32
// fn_decl：该单态对应的泛型模板声明；null 时回退旧逻辑（易与同名 export 冲突）
fn get_mono_function_name(codegen: &C99CodeGenerator, generic_name: &byte, type_args: & & ASTNode, type_arg_count: i32, fn_decl: &ASTNode) &byte {
    if codegen == null || generic_name == null || type_args == null || type_arg_count <= 0 {
        return generic_name;
    }
    
    // 构建后缀
    var suffix: [byte: TEMP_BUF_SIZE] = [0: TEMP_BUF_SIZE];
    var suffix_len: i32 = 0;
    
    var i: i32 = 0;
    while i < type_arg_count {
        if i > 0 {
            if suffix_len >= 0 && suffix_len < TEMP_BUF_LIMIT {
                suffix[suffix_len] = 95 as byte;  // '_' = 95
            }
            suffix_len = suffix_len + 1;
        }

        const type_arg: &ASTNode = type_args[i];
        suffix_len = append_type_arg_suffix(codegen, type_arg, &suffix[0], suffix_len, TEMP_BUF_SIZE);
        i = i + 1;
    }
    if suffix_len >= 0 && suffix_len < TEMP_BUF_SIZE {
        suffix[suffix_len] = 0;
    }
    
    // 基名：必须来自「本条」泛型声明所在文件，不能用 get_c_name_for_global_function(name,0)
    // （否则会命中程序中第一个同名 export，如 std.async 的 ok<T> -> std_ok，与测试里私有 ok<T> 单态冲突）。
    var safe_name: &byte = null;
    if fn_decl != null && fn_decl.type == ASTNodeType.AST_FN_DECL && fn_decl.filename != null {
        if fn_decl.fn_decl_is_export != 0 && fn_decl.fn_decl_extern_lib_name != null {
            safe_name = get_safe_c_identifier(codegen, generic_name);
        } else {
            safe_name = get_safe_c_identifier(codegen, get_export_function_c_name(codegen, generic_name, fn_decl.filename));
        }
    } else {
        const legacy_base: &byte = get_c_name_for_global_function(codegen, generic_name, 0);
        safe_name = get_safe_c_identifier(codegen, legacy_base);
    }
    const name_len: usize = (strlen(safe_name as *byte) as usize) + 1 + (suffix_len as usize) + 1;
    const mono_name: &byte = compiler_arena_alloc(codegen.arena, name_len) as &byte;
    if mono_name == null {
        return generic_name;
    }
    snprintf(mono_name as *byte, name_len, "%s_%s" as *byte, safe_name as *byte, (&suffix[0]) as *byte);

    // 若单态名与已有非泛型/显式特化函数的 C 符号冲突，则追加 _mono 避让。
    if codegen.program_node != null {
        const decl_count: i32 = codegen.program_node.program_decl_count;
        var di: i32 = 0;
        while di < decl_count {
            const decl: &ASTNode = codegen.program_node.program_decls[di];
            if decl != null && decl.type == ASTNodeType.AST_FN_DECL && decl.fn_decl_name != null {
                var decl_c_name: &byte = get_c_name_for_global_function(codegen, decl.fn_decl_name, 1);
                if decl.fn_decl_is_export != 0 && decl.filename != null && decl.fn_decl_extern_lib_name == null {
                    decl_c_name = get_export_function_c_name(codegen, decl.fn_decl_name, decl.filename);
                }
                const decl_safe_name: &byte = get_safe_c_identifier(codegen, decl_c_name);
                if decl_safe_name != null && strcmp(decl_safe_name as *byte, mono_name as *byte) == 0 {
                    const mono_name2_len: usize = name_len + 5;
                    const mono_name2: &byte = compiler_arena_alloc(codegen.arena, mono_name2_len) as &byte;
                    if mono_name2 != null {
                        snprintf(mono_name2 as *byte, mono_name2_len, "%s_mono" as *byte, mono_name as *byte);
                        return mono_name2;
                    }
                    break;
                }
            }
            di = di + 1;
        }
    }
    
    return mono_name;
}

// 在单态化上下文中将类型参数替换为具体类型
fn substitute_type_arg(codegen: &C99CodeGenerator, type_node: &ASTNode) &ASTNode {
    if codegen == null || type_node == null {
        return type_node;
    }

    // 对于命名类型：先函数/方法形参，再结构体/联合体单态形参。
    // （c99_type_to_c_uncached 仍「先 struct 再 current」以固定 Poll<!T> 等字段 C 类型；substitute 用于单态函数体/签名时，
    //  若残留 Future vtable 的 struct_type_*（如 T→!i32），不得抢占本函数的 T→i32，否则 AsyncComputeFuture<T> 会变成 err 双包。）
    if type_node.type == ASTNodeType.AST_TYPE_NAMED && type_node.type_named_name != null {
        const name: &byte = type_node.type_named_name;
        var i: i32 = 0;
        while i < codegen.current_type_param_count {
            if codegen.current_type_params[i].name != null &&
                strcmp(codegen.current_type_params[i].name as *byte, name as *byte) == 0 {
                if codegen.current_type_args != null && i < codegen.current_type_arg_count {
                    return codegen.current_type_args[i];
                }
            }
            i = i + 1;
        }

        i = 0;
        while i < codegen.struct_type_param_count {
            if codegen.struct_type_params[i].name != null &&
                strcmp(codegen.struct_type_params[i].name as *byte, name as *byte) == 0 {
                if codegen.struct_type_args != null && i < codegen.struct_type_arg_count {
                    return codegen.struct_type_args[i];
                }
            }
            i = i + 1;
        }

        if type_node.type_named_type_arg_count > 0 && type_node.type_named_type_args != null {
            const arg_count: i32 = type_node.type_named_type_arg_count;
            const args: & & ASTNode = compiler_arena_alloc(codegen.arena, @size_of(&ASTNode) * arg_count) as & & ASTNode;
            var changed: i32 = 0;
            if args != null {
                i = 0;
                while i < arg_count {
                    const substituted_arg: &ASTNode = substitute_type_arg(codegen, type_node.type_named_type_args[i]);
                    args[i] = substituted_arg;
                    if substituted_arg != type_node.type_named_type_args[i] {
                        changed = 1;
                    }
                    i = i + 1;
                }
                if changed != 0 {
                    const new_named: &ASTNode = ast_new_node(ASTNodeType.AST_TYPE_NAMED, type_node.line, type_node.column, codegen.arena, type_node.filename);
                    if new_named != null {
                        new_named.type_named_name = type_node.type_named_name;
                        new_named.type_named_type_args = args;
                        new_named.type_named_type_arg_count = arg_count;
                        return new_named;
                    }
                }
            }
        }
    }

    // 递归处理指针类型 (&T 或 *T)
    if type_node.type == ASTNodeType.AST_TYPE_POINTER && type_node.type_pointer_pointed_type != null {
        const inner_substituted: &ASTNode = substitute_type_arg(codegen, type_node.type_pointer_pointed_type);
        // 如果内部类型被替换了，创建新的指针类型节点
        if inner_substituted != type_node.type_pointer_pointed_type {
            const new_node: &ASTNode = ast_new_node(ASTNodeType.AST_TYPE_POINTER, type_node.line, type_node.column, codegen.arena, type_node.filename);
            if new_node != null {
                new_node.type_pointer_pointed_type = inner_substituted;
                new_node.type_pointer_is_ffi_pointer = type_node.type_pointer_is_ffi_pointer;
                new_node.type_pointer_is_const = type_node.type_pointer_is_const;
                return new_node;
            }
        }
    }

    // 递归处理数组类型 [T: N]
    if type_node.type == ASTNodeType.AST_TYPE_ARRAY && type_node.type_array_element_type != null {
        const elem_substituted: &ASTNode = substitute_type_arg(codegen, type_node.type_array_element_type);
        if elem_substituted != type_node.type_array_element_type {
            const new_node: &ASTNode = ast_new_node(ASTNodeType.AST_TYPE_ARRAY, type_node.line, type_node.column, codegen.arena, type_node.filename);
            if new_node != null {
                new_node.type_array_element_type = elem_substituted;
                new_node.type_array_size_expr = type_node.type_array_size_expr;
                return new_node;
            }
        }
    }

    // 递归处理切片类型 &[T]
    if type_node.type == ASTNodeType.AST_TYPE_SLICE && type_node.type_slice_element_type != null {
        const slice_substituted: &ASTNode = substitute_type_arg(codegen, type_node.type_slice_element_type);
        if slice_substituted != type_node.type_slice_element_type {
            const new_slice: &ASTNode = ast_new_node(ASTNodeType.AST_TYPE_SLICE, type_node.line, type_node.column, codegen.arena, type_node.filename);
            if new_slice != null {
                new_slice.type_slice_element_type = slice_substituted;
                new_slice.type_slice_size_expr = type_node.type_slice_size_expr;
                new_slice.type_slice_element_const = type_node.type_slice_element_const;
                return new_slice;
            }
        }
    }

    // 递归处理错误联合类型 !T（payload 可能包含类型参数）
    if type_node.type == ASTNodeType.AST_TYPE_ERROR_UNION && type_node.type_error_union_payload_type != null {
        const payload_substituted: &ASTNode = substitute_type_arg(codegen, type_node.type_error_union_payload_type);
        if payload_substituted != type_node.type_error_union_payload_type {
            const new_node: &ASTNode = ast_new_node(ASTNodeType.AST_TYPE_ERROR_UNION, type_node.line, type_node.column, codegen.arena, type_node.filename);
            if new_node != null {
                new_node.type_error_union_payload_type = payload_substituted;
                return new_node;
            }
        }
    }

    return type_node;
}

// 获取类型的 C 表示（支持类型参数替换）
fn c99_mono_type_to_c(codegen: &C99CodeGenerator, type_node: &ASTNode) &byte {
    const substituted: &ASTNode = substitute_type_arg(codegen, type_node);
    codegen.type_conv_depth = codegen.type_conv_depth + 1;
    const r: &byte = c99_type_to_c(codegen, substituted);
    codegen.type_conv_depth = codegen.type_conv_depth - 1;
    return r;
}

// 在输出函数原型/定义的形参列表之前：遍历返回类型与各形参，令 c99_type_to_c 登记所有 uya_slice_*，
// 再一次性 emit_pending_slice_structs。禁止在已向 emit_stream 写出 `foo(` 之后调用 emit_pending，
// 否则完整 struct 定义会插入参数表中间，破坏 C 语法。
fn c99_preregister_slices_top_level_fn(codegen: &C99CodeGenerator, fn_decl: &ASTNode) void {
    if codegen == null || fn_decl == null || fn_decl.type != ASTNodeType.AST_FN_DECL {
        return;
    }
    if fn_decl.fn_decl_return_type != null {
        _ = c99_type_to_c(codegen, fn_decl.fn_decl_return_type);
    }
    var pi: i32 = 0;
    while pi < fn_decl.fn_decl_param_count {
        const p: &ASTNode = fn_decl.fn_decl_params[pi];
        if p != null && p.type == ASTNodeType.AST_VAR_DECL && p.var_decl_type != null {
            _ = c99_type_to_c(codegen, p.var_decl_type);
        }
        pi = pi + 1;
    }
    emit_pending_slice_structs(codegen);
}

fn c99_preregister_slices_method(codegen: &C99CodeGenerator, fn_decl: &ASTNode, struct_name: &byte) void {
    if codegen == null || fn_decl == null || fn_decl.type != ASTNodeType.AST_FN_DECL || struct_name == null {
        return;
    }
    if fn_decl.fn_decl_return_type != null {
        _ = c99_type_to_c_with_self_opt(codegen, fn_decl.fn_decl_return_type, struct_name, 0);
    }
    var pi: i32 = 0;
    while pi < fn_decl.fn_decl_param_count {
        const p: &ASTNode = fn_decl.fn_decl_params[pi];
        if p != null && p.type == ASTNodeType.AST_VAR_DECL && p.var_decl_type != null {
            _ = c99_type_to_c_with_self_opt(codegen, p.var_decl_type, struct_name, 0);
        }
        pi = pi + 1;
    }
    emit_pending_slice_structs(codegen);
}

fn c99_preregister_slices_mono_fn(codegen: &C99CodeGenerator, fn_decl: &ASTNode) void {
    if codegen == null || fn_decl == null || fn_decl.type != ASTNodeType.AST_FN_DECL {
        return;
    }
    if fn_decl.fn_decl_return_type != null {
        _ = c99_mono_type_to_c(codegen, fn_decl.fn_decl_return_type);
    }
    var pi: i32 = 0;
    while pi < fn_decl.fn_decl_param_count {
        const p: &ASTNode = fn_decl.fn_decl_params[pi];
        if p != null && p.type == ASTNodeType.AST_VAR_DECL && p.var_decl_type != null {
            _ = c99_mono_type_to_c(codegen, p.var_decl_type);
        }
        pi = pi + 1;
    }
    emit_pending_slice_structs(codegen);
}

// 生成单态化函数原型
fn gen_mono_function_prototype(codegen: &C99CodeGenerator, fn_decl: &ASTNode, type_args: & & ASTNode, type_arg_count: i32) void {
    if fn_decl == null || fn_decl.type != ASTNodeType.AST_FN_DECL || type_args == null {
        return;
    }
    
    const orig_name: &byte = fn_decl.fn_decl_name;
    const mono_name: &byte = get_mono_function_name(codegen, orig_name, type_args, type_arg_count, fn_decl);
    const return_type: &ASTNode = fn_decl.fn_decl_return_type;
    const params: & & ASTNode = fn_decl.fn_decl_params;
    const param_count: i32 = fn_decl.fn_decl_param_count;
    const is_varargs: i32 = fn_decl.fn_decl_is_varargs;
    
    // 保存并设置单态化上下文
    const saved_type_params: &TypeParam = codegen.current_type_params;
    const saved_type_param_count: i32 = codegen.current_type_param_count;
    const saved_type_args: & & ASTNode = codegen.current_type_args;
    const saved_type_arg_count: i32 = codegen.current_type_arg_count;
    
    codegen.current_type_params = fn_decl.fn_decl_type_params;
    codegen.current_type_param_count = fn_decl.fn_decl_type_param_count;
    codegen.current_type_args = type_args;
    codegen.current_type_arg_count = type_arg_count;
    
    // 返回类型（替换类型参数）
    c99_preregister_slices_mono_fn(codegen, fn_decl);
    const return_c: &byte = c99_mono_type_to_c(codegen, return_type);
    
    if fn_decl.fn_decl_is_async != 0 && fn_decl.fn_decl_is_export == 0 && codegen.split_enabled == 0 {
        fprintf(codegen.emit_stream as *void, "static __attribute__((unused)) %s %s(" as *byte, return_c as *byte, mono_name as *byte);
    } else {
        fprintf(codegen.emit_stream as *void, "%s %s(" as *byte, return_c as *byte, mono_name as *byte);
    }
    
    // 参数列表
    var i: i32 = 0;
    while i < param_count {
        const param: &ASTNode = params[i];
        if param == null || param.type != ASTNodeType.AST_VAR_DECL {
            i = i + 1;
            continue;
        }
        
        const param_name: &byte = get_safe_c_identifier(codegen, param.var_decl_name);
        const param_type: &ASTNode = param.var_decl_type;
        const param_type_c: &byte = c99_mono_type_to_c(codegen, param_type);
        format_param_type(codegen, param_type_c, param_name, codegen.emit_stream);
        if i < param_count - 1 {
            c99_emit_comma_space(codegen);
        }
        i = i + 1;
    }
    
    // 处理可变参数
    if is_varargs != 0 {
        if param_count > 0 {
            c99_emit_comma_space(codegen);
        }
        fputs("..." as *byte, codegen.emit_stream as *void);
    }
    
    fputs(");\n" as *byte, codegen.emit_stream as *void);
    
    // 恢复上下文
    codegen.current_type_params = saved_type_params;
    codegen.current_type_param_count = saved_type_param_count;
    codegen.current_type_args = saved_type_args;
    codegen.current_type_arg_count = saved_type_arg_count;
}

// 生成单态化函数定义
fn gen_mono_function(codegen: &C99CodeGenerator, fn_decl: &ASTNode, type_args: & & ASTNode, type_arg_count: i32) void {
    if fn_decl == null || fn_decl.type != ASTNodeType.AST_FN_DECL || type_args == null {
        return;
    }
    
    const orig_name: &byte = fn_decl.fn_decl_name;
    const mono_name: &byte = get_mono_function_name(codegen, orig_name, type_args, type_arg_count, fn_decl);
    const return_type: &ASTNode = fn_decl.fn_decl_return_type;
    const params: & & ASTNode = fn_decl.fn_decl_params;
    const param_count: i32 = fn_decl.fn_decl_param_count;
    const is_varargs: i32 = fn_decl.fn_decl_is_varargs;
    const body: &ASTNode = fn_decl.fn_decl_body;
    
    // 如果没有函数体，跳过
    if body == null {
        return;
    }
    // async_compute<T> 单态：宏 thread_type_is_*(T) 在 C 体生成阶段无法可靠折叠，展开体会落回错误分支。
    // 直接调用 std_thread_async_compute_future_new_<T>（与 lib 中 thread_async_compute_future_new<T> 对应）再装箱为 Future<!T>。
    if orig_name != null && strcmp(orig_name as *byte, "async_compute" as *byte) == 0 &&
        type_arg_count == 1 && type_args[0] != null &&
        type_args[0].type == ASTNodeType.AST_TYPE_NAMED && type_args[0].type_named_name != null {
        var concrete_new_c: &byte = null;
        var concrete_struct_c: &byte = null;
        var concrete_vtable_c: &byte = null;
        var task_kind_val: i32 = 0;
        var arg_bits_c: &byte = null;
        const type_name: &byte = type_args[0].type_named_name;
        if strcmp(type_name as *byte, "i32" as *byte) == 0 {
            concrete_new_c = "std_thread_async_compute_future_new_i32" as &byte;
            concrete_struct_c = "AsyncComputeFuture_i32" as &byte;
            concrete_vtable_c = "uya_vtable_Future_err_i32_AsyncComputeFuture_i32" as &byte;
            task_kind_val = 1;
            arg_bits_c = "(size_t)arg" as &byte;
        } else if strcmp(type_name as *byte, "usize" as *byte) == 0 {
            concrete_new_c = "std_thread_async_compute_future_new_usize" as &byte;
            concrete_struct_c = "AsyncComputeFuture_usize" as &byte;
            concrete_vtable_c = "uya_vtable_Future_err_usize_AsyncComputeFuture_usize" as &byte;
            task_kind_val = 3;
            arg_bits_c = "arg" as &byte;
        } else if strcmp(type_name as *byte, "u32" as *byte) == 0 {
            concrete_new_c = "std_thread_async_compute_future_new_u32" as &byte;
            concrete_struct_c = "AsyncComputeFuture_u32" as &byte;
            concrete_vtable_c = "uya_vtable_Future_err_u32_AsyncComputeFuture_u32" as &byte;
            task_kind_val = 2;
            arg_bits_c = "(size_t)arg" as &byte;
        } else if strcmp(type_name as *byte, "i64" as *byte) == 0 {
            concrete_new_c = "std_thread_async_compute_future_new_i64" as &byte;
            concrete_struct_c = "AsyncComputeFuture_i64" as &byte;
            concrete_vtable_c = "uya_vtable_Future_err_i64_AsyncComputeFuture_i64" as &byte;
            task_kind_val = 4;
            arg_bits_c = "(size_t)arg" as &byte;
        } else if strcmp(type_name as *byte, "u64" as *byte) == 0 {
            concrete_new_c = "std_thread_async_compute_future_new_u64" as &byte;
            concrete_struct_c = "AsyncComputeFuture_u64" as &byte;
            concrete_vtable_c = "uya_vtable_Future_err_u64_AsyncComputeFuture_u64" as &byte;
            task_kind_val = 5;
            arg_bits_c = "(size_t)arg" as &byte;
        } else if strcmp(type_name as *byte, "i16" as *byte) == 0 {
            concrete_new_c = "std_thread_async_compute_future_new_i16" as &byte;
            concrete_struct_c = "AsyncComputeFuture_i16" as &byte;
            concrete_vtable_c = "uya_vtable_Future_err_i16_AsyncComputeFuture_i16" as &byte;
            task_kind_val = 6;
            arg_bits_c = "(size_t)arg" as &byte;
        } else if strcmp(type_name as *byte, "u16" as *byte) == 0 {
            concrete_new_c = "std_thread_async_compute_future_new_u16" as &byte;
            concrete_struct_c = "AsyncComputeFuture_u16" as &byte;
            concrete_vtable_c = "uya_vtable_Future_err_u16_AsyncComputeFuture_u16" as &byte;
            task_kind_val = 7;
            arg_bits_c = "(size_t)arg" as &byte;
        } else if strcmp(type_name as *byte, "i8" as *byte) == 0 {
            concrete_new_c = "std_thread_async_compute_future_new_i8" as &byte;
            concrete_struct_c = "AsyncComputeFuture_i8" as &byte;
            concrete_vtable_c = "uya_vtable_Future_err_i8_AsyncComputeFuture_i8" as &byte;
            task_kind_val = 8;
            arg_bits_c = "(size_t)arg" as &byte;
        } else if strcmp(type_name as *byte, "u8" as *byte) == 0 {
            concrete_new_c = "std_thread_async_compute_future_new_u8" as &byte;
            concrete_struct_c = "AsyncComputeFuture_u8" as &byte;
            concrete_vtable_c = "uya_vtable_Future_err_u8_AsyncComputeFuture_u8" as &byte;
            task_kind_val = 9;
            arg_bits_c = "(size_t)arg" as &byte;
        } else if strcmp(type_name as *byte, "bool" as *byte) == 0 {
            concrete_new_c = "std_thread_async_compute_future_new_bool" as &byte;
            concrete_struct_c = "AsyncComputeFuture_bool" as &byte;
            concrete_vtable_c = "uya_vtable_Future_err_bool_AsyncComputeFuture_bool" as &byte;
            task_kind_val = 10;
            arg_bits_c = "(size_t)(arg ? 1 : 0)" as &byte;
        } else if strcmp(type_name as *byte, "f32" as *byte) == 0 {
            concrete_new_c = "std_thread_async_compute_future_new_f32" as &byte;
            concrete_struct_c = "AsyncComputeFuture_f32" as &byte;
            concrete_vtable_c = "uya_vtable_Future_err_f32_AsyncComputeFuture_f32" as &byte;
            task_kind_val = 11;
            arg_bits_c = "thread_f32_arg_bits(arg)" as &byte;
        } else if strcmp(type_name as *byte, "f64" as *byte) == 0 {
            concrete_new_c = "std_thread_async_compute_future_new_f64" as &byte;
            concrete_struct_c = "AsyncComputeFuture_f64" as &byte;
            concrete_vtable_c = "uya_vtable_Future_err_f64_AsyncComputeFuture_f64" as &byte;
            task_kind_val = 12;
            arg_bits_c = "thread_f64_arg_bits(arg)" as &byte;
        }
        if concrete_new_c != null && concrete_struct_c != null && concrete_vtable_c != null && arg_bits_c != null {
            const saved_type_params2: &TypeParam = codegen.current_type_params;
            const saved_type_param_count2: i32 = codegen.current_type_param_count;
            const saved_type_args2: & & ASTNode = codegen.current_type_args;
            const saved_type_arg_count2: i32 = codegen.current_type_arg_count;
            codegen.current_type_params = fn_decl.fn_decl_type_params;
            codegen.current_type_param_count = fn_decl.fn_decl_type_param_count;
            codegen.current_type_args = type_args;
            codegen.current_type_arg_count = type_arg_count;

            emit_line_directive(codegen, fn_decl.line, fn_decl.filename);
            const return_c2: &byte = c99_mono_type_to_c(codegen, return_type);
            if fn_decl.fn_decl_is_export != 0 {
                fprintf(codegen.emit_stream as *void, "%s %s(" as *byte, return_c2 as *byte, mono_name as *byte);
            } else {
                if codegen.split_enabled == 0 {
                    fprintf(codegen.emit_stream as *void, "static __attribute__((unused)) %s %s(" as *byte, return_c2 as *byte, mono_name as *byte);
                } else {
                    fprintf(codegen.emit_stream as *void, "%s %s(" as *byte, return_c2 as *byte, mono_name as *byte);
                }
            }
            var ai: i32 = 0;
            while ai < param_count {
                const param2: &ASTNode = params[ai];
                if param2 == null || param2.type != ASTNodeType.AST_VAR_DECL {
                    ai = ai + 1;
                    continue;
                }
                const param_name2: &byte = get_safe_c_identifier(codegen, param2.var_decl_name);
                const param_type2: &byte = c99_mono_type_to_c(codegen, param2.var_decl_type);
                format_param_type(codegen, param_type2, param_name2, codegen.emit_stream);
                if ai < param_count - 1 {
                    c99_emit_comma_space(codegen);
                }
                ai = ai + 1;
            }
            if is_varargs != 0 {
                if param_count > 0 {
                    c99_emit_comma_space(codegen);
                }
                fputs("..." as *byte, codegen.emit_stream as *void);
            }
            fputs(") {\n" as *byte, codegen.emit_stream as *void);
            fprintf(codegen.emit_stream as *void, "    struct %s _uya_tmp = %s(pool, compute_fn, %d, %s);\n" as *byte,
                concrete_struct_c as *byte, concrete_new_c as *byte, task_kind_val, arg_bits_c as *byte);
            fprintf(codegen.emit_stream as *void, "    struct %s *_uya_box = (struct %s *)malloc(sizeof(struct %s));\n" as *byte,
                concrete_struct_c as *byte, concrete_struct_c as *byte, concrete_struct_c as *byte);
            fprintf(codegen.emit_stream as *void, "    if (_uya_box != (void*)0) { *_uya_box = _uya_tmp; }\n" as *byte);
            fprintf(codegen.emit_stream as *void, "    return (%s){ .vtable = (void*)&%s, .data = (void*)_uya_box };\n" as *byte,
                return_c2 as *byte, concrete_vtable_c as *byte);
            fputs("}\n" as *byte, codegen.emit_stream as *void);

            codegen.current_type_params = saved_type_params2;
            codegen.current_type_param_count = saved_type_param_count2;
            codegen.current_type_args = saved_type_args2;
            codegen.current_type_arg_count = saved_type_arg_count2;
            return;
        }
    }
    var body_to_gen: &ASTNode = body;
    if codegen.checker != null && orig_name != null &&
       (strcmp(orig_name as *byte, "to_json" as *byte) == 0 ||
        strcmp(orig_name as *byte, "async_compute" as *byte) == 0) &&
       fn_decl.fn_decl_type_params != null && fn_decl.fn_decl_type_param_count > 0 &&
       type_args != null && type_arg_count > 0 {
        const expanded: &ASTNode = prepare_mono_body_expand_macros(codegen.checker, body,
            fn_decl.fn_decl_type_params, fn_decl.fn_decl_type_param_count, type_args, type_arg_count);
        if expanded != null { body_to_gen = expanded; }
    }
    // from_json<T>：首类型实参为结构体时，按结构体字段生成解码 body（与 to_json 一致，无需方法块声明）
    if codegen.checker != null && orig_name != null && strcmp(orig_name as *byte, "from_json" as *byte) == 0 &&
       type_args != null && type_arg_count >= 1 && type_args[0] != null &&
       type_args[0].type == ASTNodeType.AST_TYPE_NAMED && type_args[0].type_named_name != null {
        var filename: &byte = null;
        if fn_decl.filename != null {
            filename = fn_decl.filename;
        }
        const reflect_body: &ASTNode = build_from_json_reflect_body(codegen.checker, type_args[0],
            fn_decl.line, fn_decl.column, filename);
        if reflect_body != null { body_to_gen = reflect_body; }
    }
    // 保存并设置单态化上下文
    const saved_type_params: &TypeParam = codegen.current_type_params;
    const saved_type_param_count: i32 = codegen.current_type_param_count;
    const saved_type_args: & & ASTNode = codegen.current_type_args;
    const saved_type_arg_count: i32 = codegen.current_type_arg_count;
    
    codegen.current_type_params = fn_decl.fn_decl_type_params;
    codegen.current_type_param_count = fn_decl.fn_decl_type_param_count;
    codegen.current_type_args = type_args;
    codegen.current_type_arg_count = type_arg_count;

    // 泛型 @async_fn 也需要走 stage-B 状态机生成；否则会按普通函数落下 @await。
    if fn_decl.fn_decl_is_async != 0 {
        var use_stage_b: i32 = 0;
        var effective_return_type: &ASTNode = return_type;
        if return_type != null && return_type.type == ASTNodeType.AST_TYPE_NAMED &&
            return_type.type_named_name != null &&
            strcmp(return_type.type_named_name as *byte, "Future" as *byte) == 0 &&
            return_type.type_named_type_arg_count == 1 &&
            return_type.type_named_type_args != null {
            const a0: &ASTNode = return_type.type_named_type_args[0];
            if a0 != null && a0.type == ASTNodeType.AST_TYPE_ERROR_UNION &&
                a0.type_error_union_payload_type != null {
                use_stage_b = 1;
            }
        }
        if use_stage_b == 0 && return_type != null && return_type.type == ASTNodeType.AST_TYPE_ERROR_UNION &&
            return_type.type_error_union_payload_type != null {
            const pl: &ASTNode = return_type.type_error_union_payload_type;
            if pl.type == ASTNodeType.AST_TYPE_NAMED && pl.type_named_name != null &&
                strcmp(pl.type_named_name as *byte, "Future" as *byte) == 0 &&
                pl.type_named_type_arg_count == 1 && pl.type_named_type_args != null {
                use_stage_b = 1;
                effective_return_type = pl;
            }
        }
        if use_stage_b != 0 {
            gen_async_function_stage_b(codegen, fn_decl, mono_name, return_type, effective_return_type);
            codegen.current_type_params = saved_type_params;
            codegen.current_type_param_count = saved_type_param_count;
            codegen.current_type_args = saved_type_args;
            codegen.current_type_arg_count = saved_type_arg_count;
            return;
        }
    }
    
    // 生成 #line 指令
    emit_line_directive(codegen, fn_decl.line, fn_decl.filename);
    
    // 返回类型（替换类型参数）
    c99_preregister_slices_mono_fn(codegen, fn_decl);
    const return_c: &byte = c99_mono_type_to_c(codegen, return_type);
    fprintf(codegen.emit_stream as *void, "%s %s(" as *byte, return_c as *byte, mono_name as *byte);
    
    // 参数列表
    var i: i32 = 0;
    while i < param_count {
        const param: &ASTNode = params[i];
        if param == null || param.type != ASTNodeType.AST_VAR_DECL {
            i = i + 1;
            continue;
        }
        
        const param_name: &byte = get_safe_c_identifier(codegen, param.var_decl_name);
        const param_type: &ASTNode = param.var_decl_type;
        const param_type_c: &byte = c99_mono_type_to_c(codegen, param_type);
        format_param_type(codegen, param_type_c, param_name, codegen.emit_stream);
        if i < param_count - 1 {
            c99_emit_comma_space(codegen);
        }
        i = i + 1;
    }
    
    // 处理可变参数
    if is_varargs != 0 {
        if param_count > 0 {
            c99_emit_comma_space(codegen);
        }
        fputs("..." as *byte, codegen.emit_stream as *void);
    }
    
    fputs(") {\n" as *byte, codegen.emit_stream as *void);
    
    // 保存当前状态
    const saved_return_type: &ASTNode = codegen.current_function_return_type;
    const saved_current_function_decl: &ASTNode = codegen.current_function_decl;
    const saved_local_count: i32 = codegen.local_variable_count;
    const saved_depth: i32 = codegen.current_depth;
    
    codegen.current_function_return_type = return_type;
    codegen.current_function_decl = fn_decl;
    codegen.indent_level = codegen.indent_level + 1;
    codegen.current_depth = codegen.current_depth + 1;
    
    // 将参数添加到局部变量表
    i = 0;
    while i < param_count {
        const param: &ASTNode = params[i];
        if param != null && param.type == ASTNodeType.AST_VAR_DECL {
            if codegen.local_variable_count < C99_MAX_LOCAL_VARS {
                codegen.local_variables[codegen.local_variable_count].name = param.var_decl_name;
                codegen.local_variables[codegen.local_variable_count].type_c = c99_mono_type_to_c(codegen, param.var_decl_type);
                codegen.local_variables[codegen.local_variable_count].type_node = param.var_decl_type;
                codegen.local_variables[codegen.local_variable_count].depth = codegen.current_depth;
                codegen.local_variable_count = codegen.local_variable_count + 1;
            }
        }
        i = i + 1;
    }
    i = 0;
    while i < param_count {
        const param: &ASTNode = params[i];
        if param != null && param.type == ASTNodeType.AST_VAR_DECL {
            const pname: &byte = get_safe_c_identifier(codegen, param.var_decl_name);
            if pname != null {
                c99_emit_indent(codegen);
                fputs("(void)" as *byte, codegen.emit_stream as *void);
                fputs(pname as *byte, codegen.emit_stream as *void);
                c99_emit_semi_newline(codegen);
            }
        }
        i = i + 1;
    }
    
    // 生成函数体
    gen_stmt(codegen, body_to_gen);
    
    // 若返回类型非 void 且函数体末尾无 return，补兜底 return 避免 -Wreturn-type
    var has_return_mono: i32 = 0;
    if body_to_gen.type == ASTNodeType.AST_BLOCK && body_to_gen.block_stmts != null {
        const stmts_mono: & & ASTNode = body_to_gen.block_stmts;
        const stmt_count_mono: i32 = body_to_gen.block_stmt_count;
        var j: i32 = stmt_count_mono - 1;
        while j >= 0 {
            const s: &ASTNode = stmts_mono[j];
            if s != null && s.type != ASTNodeType.AST_DEFER_STMT && s.type != ASTNodeType.AST_ERRDEFER_STMT {
                if s.type == ASTNodeType.AST_RETURN_STMT {
                    has_return_mono = 1;
                }
                j = -1;
                break;
            }
            j = j - 1;
        }
    }
    const rt: &ASTNode = codegen.current_function_return_type;
    if has_return_mono == 0 && rt != null {
        var is_void_mono: i32 = 0;
        if rt.type == ASTNodeType.AST_TYPE_NAMED && rt.type_named_name != null &&
            strcmp(rt.type_named_name as *byte, "void" as *byte) == 0 {
            is_void_mono = 1;
        } else if rt.type == ASTNodeType.AST_TYPE_ERROR_UNION {
            const pl: &ASTNode = rt.type_error_union_payload_type;
            if pl == null {
                is_void_mono = 1;
            } else if pl.type == ASTNodeType.AST_TYPE_NAMED && pl.type_named_name != null &&
                strcmp(pl.type_named_name as *byte, "void" as *byte) == 0 {
                is_void_mono = 1;
            }
        }
        if is_void_mono == 0 {
            codegen.indent_level = codegen.indent_level + 1;
            c99_emit_indent(codegen);
            if return_c != null && strncmp(return_c as *byte, "struct " as *byte, 7) == 0 {
                fprintf(codegen.emit_stream as *void, "return (%s){0};\n" as *byte, return_c as *byte);
            } else {
                fputs("return 0;\n" as *byte, codegen.emit_stream as *void);
            }
            codegen.indent_level = codegen.indent_level - 1;
        }
    }
    
    // 恢复状态
    codegen.current_function_return_type = saved_return_type;
    codegen.current_function_decl = saved_current_function_decl;
    codegen.local_variable_count = saved_local_count;
    codegen.current_depth = saved_depth;
    codegen.indent_level = codegen.indent_level - 1;
    
    c99_emit_close_brace_newline(codegen);
    
    // 恢复单态化上下文
    codegen.current_type_params = saved_type_params;
    codegen.current_type_param_count = saved_type_param_count;
    codegen.current_type_args = saved_type_args;
    codegen.current_type_arg_count = saved_type_arg_count;
}

// 生成单态化方法原型
fn gen_mono_method_prototype(codegen: &C99CodeGenerator, fn_decl: &ASTNode, struct_name: &byte, type_args: & & ASTNode, type_arg_count: i32) void {
    if fn_decl == null || fn_decl.type != ASTNodeType.AST_FN_DECL || type_args == null || struct_name == null {
        return;
    }
    
    const method_name: &byte = fn_decl.fn_decl_name;
    
    // 构建单态化方法名
    var mono_name_buf: [byte: C99_TYPE_ARG_BUF_SIZE] = [];
    var pos: i32 = snprintf(&mono_name_buf[0] as *byte, C99_TYPE_ARG_BUF_SIZE, "%s_%s" as *byte, struct_name as *byte, method_name as *byte);
    var ti: i32 = 0;
    while ti < type_arg_count && pos < C99_TYPE_ARG_BUF_LIMIT {
        pos = pos + snprintf(&mono_name_buf[pos] as *byte, C99_TYPE_ARG_BUF_SIZE - pos, "_" as *byte);
        const type_arg: &ASTNode = type_args[ti];
        if type_arg != null && type_arg.type == ASTNodeType.AST_TYPE_NAMED && type_arg.type_named_name != null {
            pos = pos + snprintf(&mono_name_buf[pos] as *byte, C99_TYPE_ARG_BUF_SIZE - pos, "%s" as *byte, type_arg.type_named_name as *byte);
        }
        ti = ti + 1;
    }
    const mono_method_name: &byte = get_safe_c_identifier(codegen, &mono_name_buf[0]);
    
    // 保存方法的类型参数上下文
    const saved_type_params: &TypeParam = codegen.current_type_params;
    const saved_type_param_count: i32 = codegen.current_type_param_count;
    const saved_type_args: & & ASTNode = codegen.current_type_args;
    const saved_type_arg_count: i32 = codegen.current_type_arg_count;
    
    // 设置方法的类型参数上下文（结构体的类型参数上下文已经在外层设置）
    codegen.current_type_params = fn_decl.fn_decl_type_params;
    codegen.current_type_param_count = fn_decl.fn_decl_type_param_count;
    codegen.current_type_args = type_args;
    codegen.current_type_arg_count = type_arg_count;
    
    // 使用 c99_type_to_c_with_self 来正确处理 Self 类型
    c99_preregister_slices_method(codegen, fn_decl, struct_name);
    const return_c: &byte = c99_type_to_c_with_self(codegen, fn_decl.fn_decl_return_type, struct_name);
    const params: & & ASTNode = fn_decl.fn_decl_params;
    const param_count: i32 = fn_decl.fn_decl_param_count;
    
    fprintf(codegen.emit_stream as *void, "%s %s(" as *byte, return_c as *byte, mono_method_name as *byte);
    
    var i: i32 = 0;
    while i < param_count {
        const param: &ASTNode = params[i];
        if param == null || param.type != ASTNodeType.AST_VAR_DECL {
            i = i + 1;
            continue;
        }
        
        const param_name: &byte = get_safe_c_identifier(codegen, param.var_decl_name);
        const param_type_c: &byte = c99_type_to_c_with_self(codegen, param.var_decl_type, struct_name);
        format_param_type(codegen, param_type_c, param_name, codegen.emit_stream);
        if i < param_count - 1 {
            c99_emit_comma_space(codegen);
        }
        i = i + 1;
    }
    
    fputs(");\n" as *byte, codegen.emit_stream as *void);
    
    // 恢复方法的类型参数上下文
    codegen.current_type_params = saved_type_params;
    codegen.current_type_param_count = saved_type_param_count;
    codegen.current_type_args = saved_type_args;
    codegen.current_type_arg_count = saved_type_arg_count;
}

// 生成单态化方法函数定义
fn gen_mono_method_function(codegen: &C99CodeGenerator, fn_decl: &ASTNode, struct_name: &byte, type_args: & & ASTNode, type_arg_count: i32) void {
    if fn_decl == null || fn_decl.type != ASTNodeType.AST_FN_DECL || type_args == null || struct_name == null || fn_decl.fn_decl_body == null {
        return;
    }
    
    const method_name: &byte = fn_decl.fn_decl_name;
    
    // 构建单态化方法名
    var mono_name_buf: [byte: C99_TYPE_ARG_BUF_SIZE] = [];
    var pos: i32 = snprintf(&mono_name_buf[0] as *byte, C99_TYPE_ARG_BUF_SIZE, "%s_%s" as *byte, struct_name as *byte, method_name as *byte);
    var ti: i32 = 0;
    while ti < type_arg_count && pos < C99_TYPE_ARG_BUF_LIMIT {
        pos = pos + snprintf(&mono_name_buf[pos] as *byte, C99_TYPE_ARG_BUF_SIZE - pos, "_" as *byte);
        const type_arg: &ASTNode = type_args[ti];
        if type_arg != null && type_arg.type == ASTNodeType.AST_TYPE_NAMED && type_arg.type_named_name != null {
            pos = pos + snprintf(&mono_name_buf[pos] as *byte, C99_TYPE_ARG_BUF_SIZE - pos, "%s" as *byte, type_arg.type_named_name as *byte);
        }
        ti = ti + 1;
    }
    const mono_method_name: &byte = get_safe_c_identifier(codegen, &mono_name_buf[0]);
    
    const return_type: &ASTNode = fn_decl.fn_decl_return_type;
    const params: & & ASTNode = fn_decl.fn_decl_params;
    const param_count: i32 = fn_decl.fn_decl_param_count;
    const body: &ASTNode = fn_decl.fn_decl_body;
    
    // 保存方法的类型参数上下文
    const saved_type_params: &TypeParam = codegen.current_type_params;
    const saved_type_param_count: i32 = codegen.current_type_param_count;
    const saved_type_args: & & ASTNode = codegen.current_type_args;
    const saved_type_arg_count: i32 = codegen.current_type_arg_count;
    
    // 设置方法的类型参数上下文（结构体的类型参数上下文已经在外层设置）
    codegen.current_type_params = fn_decl.fn_decl_type_params;
    codegen.current_type_param_count = fn_decl.fn_decl_type_param_count;
    codegen.current_type_args = type_args;
    codegen.current_type_arg_count = type_arg_count;
    
    emit_line_directive(codegen, fn_decl.line, fn_decl.filename);
    
    // 使用 c99_type_to_c_with_self 来正确处理 Self 类型
    c99_preregister_slices_method(codegen, fn_decl, struct_name);
    const return_c: &byte = c99_type_to_c_with_self(codegen, return_type, struct_name);
    fprintf(codegen.emit_stream as *void, "%s %s(" as *byte, return_c as *byte, mono_method_name as *byte);
    
    var i: i32 = 0;
    while i < param_count {
        const param: &ASTNode = params[i];
        if param == null || param.type != ASTNodeType.AST_VAR_DECL {
            i = i + 1;
            continue;
        }
        
        const param_name: &byte = get_safe_c_identifier(codegen, param.var_decl_name);
        const param_type_c: &byte = c99_type_to_c_with_self(codegen, param.var_decl_type, struct_name);
        format_param_type(codegen, param_type_c, param_name, codegen.emit_stream);
        if i < param_count - 1 {
            c99_emit_comma_space(codegen);
        }
        i = i + 1;
    }
    
    fputs(") {\n" as *byte, codegen.emit_stream as *void);
    
    // 保存当前状态
    const saved_return_type: &ASTNode = codegen.current_function_return_type;
    const saved_current_function_decl: &ASTNode = codegen.current_function_decl;
    const saved_local_count: i32 = codegen.local_variable_count;
    const saved_depth: i32 = codegen.current_depth;
    
    codegen.current_function_return_type = return_type;
    codegen.current_function_decl = fn_decl;
    codegen.indent_level = codegen.indent_level + 1;
    codegen.current_depth = codegen.current_depth + 1;
    
    // 将参数添加到局部变量表
    i = 0;
    while i < param_count {
        const param: &ASTNode = params[i];
        if param != null && param.type == ASTNodeType.AST_VAR_DECL {
            if codegen.local_variable_count < C99_MAX_LOCAL_VARS {
                codegen.local_variables[codegen.local_variable_count].name = param.var_decl_name;
                codegen.local_variables[codegen.local_variable_count].type_c = c99_type_to_c_with_self(codegen, param.var_decl_type, struct_name);
                codegen.local_variables[codegen.local_variable_count].type_node = param.var_decl_type;
                codegen.local_variables[codegen.local_variable_count].depth = codegen.current_depth;
                codegen.local_variable_count = codegen.local_variable_count + 1;
            }
        }
        i = i + 1;
    }
    
    i = 0;
    while i < param_count {
        const param: &ASTNode = params[i];
        if param != null && param.type == ASTNodeType.AST_VAR_DECL {
            const pname: &byte = get_safe_c_identifier(codegen, param.var_decl_name);
            if pname != null {
                c99_emit_indent(codegen);
                fputs("(void)" as *byte, codegen.emit_stream as *void);
                fputs(pname as *byte, codegen.emit_stream as *void);
                c99_emit_semi_newline(codegen);
            }
        }
        i = i + 1;
    }
    
    // 生成函数体
    gen_stmt(codegen, body);
    
    // 若返回类型非 void 且函数体末尾无 return，补兜底 return
    var has_return_mono: i32 = 0;
    if body.type == ASTNodeType.AST_BLOCK && body.block_stmts != null {
        const stmts_mono: & & ASTNode = body.block_stmts;
        const stmt_count_mono: i32 = body.block_stmt_count;
        var j: i32 = stmt_count_mono - 1;
        while j >= 0 {
            const s: &ASTNode = stmts_mono[j];
            if s != null && s.type != ASTNodeType.AST_DEFER_STMT && s.type != ASTNodeType.AST_ERRDEFER_STMT {
                if s.type == ASTNodeType.AST_RETURN_STMT {
                    has_return_mono = 1;
                }
                j = -1;
                break;
            }
            j = j - 1;
        }
    }
    const rt: &ASTNode = codegen.current_function_return_type;
    if has_return_mono == 0 && rt != null {
        var is_void_mono: i32 = 0;
        if rt.type == ASTNodeType.AST_TYPE_NAMED && rt.type_named_name != null &&
            strcmp(rt.type_named_name as *byte, "void" as *byte) == 0 {
            is_void_mono = 1;
        } else if rt.type == ASTNodeType.AST_TYPE_ERROR_UNION {
            const pl: &ASTNode = rt.type_error_union_payload_type;
            if pl == null {
                is_void_mono = 1;
            } else if pl.type == ASTNodeType.AST_TYPE_NAMED && pl.type_named_name != null &&
                strcmp(pl.type_named_name as *byte, "void" as *byte) == 0 {
                is_void_mono = 1;
            }
        }
        if is_void_mono == 0 {
            codegen.indent_level = codegen.indent_level + 1;
            c99_emit_indent(codegen);
            if return_c != null && strncmp(return_c as *byte, "struct " as *byte, 7) == 0 {
                fprintf(codegen.emit_stream as *void, "return (%s){0};\n" as *byte, return_c as *byte);
            } else {
                fputs("return 0;\n" as *byte, codegen.emit_stream as *void);
            }
            codegen.indent_level = codegen.indent_level - 1;
        }
    }
    
    // 恢复状态
    codegen.current_function_return_type = saved_return_type;
    codegen.current_function_decl = saved_current_function_decl;
    codegen.local_variable_count = saved_local_count;
    codegen.current_depth = saved_depth;
    codegen.indent_level = codegen.indent_level - 1;
    
    c99_emit_close_brace_newline(codegen);
    
    // 恢复方法的类型参数上下文
    codegen.current_type_params = saved_type_params;
    codegen.current_type_param_count = saved_type_param_count;
    codegen.current_type_args = saved_type_args;
    codegen.current_type_arg_count = saved_type_arg_count;
}

