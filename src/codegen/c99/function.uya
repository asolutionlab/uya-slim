// function.uya - C99 代码生成器函数模块
// 提供函数声明和定义生成功能
//
// 注意：需要先包含 internal.uya（包含类型定义和函数声明）
// 由于 Uya Mini 不支持模块系统，这里假设相关类型已经定义

use lower.async;

// ===== 外部函数声明 =====
// C 标准库函数（在 extern_decls.uya 中声明）
// 哈希函数（来自 checker/symbols.uya）
extern fn hash_string(str: &byte) i32;
extern fn type_from_ast(checker: &TypeChecker, type_node: &ASTNode) Type;
extern fn checker_infer_type(checker: &TypeChecker, expr: &ASTNode) Type;
extern fn type_to_ast(checker: &TypeChecker, t: &Type, line: i32, column: i32, filename: &byte) &ASTNode;
// expr.uya 在 compile.sh 中晚于 function.uya，需前向声明
extern fn gen_array_literal_contents(codegen: &C99CodeGenerator, expr: &ASTNode) void;
// async frame meta 注册（来自 checker/async_frame_meta.uya）
extern fn checker_register_async_frame_meta(checker: &TypeChecker, meta: &AsyncFrameMeta) i32;
extern fn checker_find_async_frame_meta_by_key_text(checker: &TypeChecker, key_text: &byte) &AsyncFrameMeta;
// lowering 分析函数（来自 lower/async.uya）
extern fn async_lower_analyze_escape_class(checker: &TypeChecker, fn_body: &ASTNode) AsyncFrameEscapeClass;

// 查找函数声明
// 若存在多个同名顶层 fn（如前向 extern 与后续带函数体的实现），优先返回带 body 的定义，
// 否则可达性分析与代码生成会锚到无体的声明，导致实现既不生成原型也不生成定义（如 libc time 的 _strftime_write）。
// 策略：缓存命中时 O(1)，未命中或冲突时回退线性查找。
fn c99_filename_is_in_lib_family(filename: &byte, family: &byte) i32 {
    if filename == null || family == null {
        return 0;
    }
    if strcmp(family as *byte, "libc" as *byte) == 0 {
        if strstr(filename as *byte, "/lib/libc/" as *byte) != null ||
            strstr(filename as *byte, "lib/libc/" as *byte) != null {
            return 1;
        }
        return 0;
    }
    if strcmp(family as *byte, "std" as *byte) == 0 {
        if strstr(filename as *byte, "/lib/std/" as *byte) != null ||
            strstr(filename as *byte, "lib/std/" as *byte) != null {
            return 1;
        }
        return 0;
    }
    return 0;
}

fn c99_decl_matches_current_lib_family(codegen: &C99CodeGenerator, decl: &ASTNode) i32 {
    if codegen == null || decl == null || decl.filename == null ||
        codegen.current_function_decl == null || codegen.current_function_decl.filename == null {
        return 0;
    }
    const current_filename: &byte = codegen.current_function_decl.filename;
    if c99_filename_is_in_lib_family(current_filename, "libc" as &byte) != 0 {
        return c99_filename_is_in_lib_family(decl.filename, "libc" as &byte);
    }
    if c99_filename_is_in_lib_family(current_filename, "std" as &byte) != 0 {
        return c99_filename_is_in_lib_family(decl.filename, "std" as &byte);
    }
    return 0;
}

fn find_function_decl_c99(codegen: &C99CodeGenerator, func_name: &byte) &ASTNode {
    if codegen == null || func_name == null || codegen.program_node == null {
        return null;
    }

    // 优先使用缓存（O(1)）
    if codegen.decl_cache_initialized != 0 {
        const h: i32 = (hash_string(func_name) & C99_DECL_CACHE_MASK) as i32;
        const cached: &ASTNode = codegen.fn_decl_cache[h];
        if cached != null && cached.type == ASTNodeType.AST_FN_DECL {
            const cached_name: &byte = cached.fn_decl_name;
            if cached_name != null && strcmp(cached_name as *byte, func_name as *byte) == 0 {
                // 缓存命中后仍线性查找，优先非 extern 定义，再退回 extern/声明。
                const decl_count: i32 = codegen.program_node.program_decl_count;
                var i: i32 = 0;
                var family_body_match: &ASTNode = null;
                var family_stub_match: &ASTNode = null;
                var body_match: &ASTNode = null;
                var stub_match: &ASTNode = null;
                while i < decl_count {
                    const decl_cached_scan: &ASTNode = codegen.program_node.program_decls[i];
                    if decl_cached_scan != null && decl_cached_scan.type == ASTNodeType.AST_FN_DECL {
                        const dn_cached_scan: &byte = decl_cached_scan.fn_decl_name;
                        if dn_cached_scan != null && strcmp(dn_cached_scan as *byte, func_name as *byte) == 0 {
                            const same_family: i32 = c99_decl_matches_current_lib_family(codegen, decl_cached_scan);
                            if same_family != 0 {
                                if decl_cached_scan.fn_decl_body != null {
                                    if decl_cached_scan.fn_decl_extern_lib_name == null {
                                        return decl_cached_scan;
                                    }
                                    if family_body_match == null {
                                        family_body_match = decl_cached_scan;
                                    }
                                } else if family_stub_match == null {
                                    family_stub_match = decl_cached_scan;
                                }
                            } else {
                                if decl_cached_scan.fn_decl_body != null {
                                    if decl_cached_scan.fn_decl_extern_lib_name == null {
                                        return decl_cached_scan;
                                    }
                                    if body_match == null {
                                        body_match = decl_cached_scan;
                                    }
                                } else if stub_match == null {
                                    stub_match = decl_cached_scan;
                                }
                            }
                        }
                    }
                    i = i + 1;
                }
                if family_body_match != null {
                    return family_body_match;
                }
                if family_stub_match != null {
                    return family_stub_match;
                }
                if body_match != null {
                    return body_match;
                }
                if stub_match != null {
                    return stub_match;
                }
                return cached;
            }
        }
    }

    // 缓存未命中或冲突，线性查找
    const decl_count: i32 = codegen.program_node.program_decl_count;

    var i: i32 = 0;
    var family_body_match: &ASTNode = null;
    var family_stub: &ASTNode = null;
    var body_match: &ASTNode = null;
    var stub: &ASTNode = null;
    while i < decl_count {
        const decl: &ASTNode = codegen.program_node.program_decls[i];
        if decl != null && decl.type == ASTNodeType.AST_FN_DECL {
            const decl_name: &byte = decl.fn_decl_name;
            if decl_name != null && strcmp(decl_name as *byte, func_name as *byte) == 0 {
                const same_family: i32 = c99_decl_matches_current_lib_family(codegen, decl);
                if same_family != 0 {
                    if decl.fn_decl_body != null {
                        if decl.fn_decl_extern_lib_name == null {
                            return decl;
                        }
                        if family_body_match == null {
                            family_body_match = decl;
                        }
                    }
                    if family_stub == null {
                        family_stub = decl;
                    }
                } else {
                    if decl.fn_decl_body != null {
                        if decl.fn_decl_extern_lib_name == null {
                            return decl;
                        }
                        if body_match == null {
                            body_match = decl;
                        }
                    }
                    if stub == null {
                        stub = decl;
                    }
                }
            }
        }
        i = i + 1;
    }

    if family_body_match != null {
        return family_body_match;
    }
    if family_stub != null {
        return family_stub;
    }
    if body_match != null {
        return body_match;
    }
    return stub;
}

// 检查函数是否是 extern "libc" fn（用于决定字符串参数类型）
fn should_use_raw_libc_symbol_name(codegen: &C99CodeGenerator, fn_decl: &ASTNode) i32 {
    if fn_decl == null || fn_decl.type != ASTNodeType.AST_FN_DECL || fn_decl.fn_decl_extern_lib_name == null {
        return 0;
    }
    // extern "libc" 无函数体：链接系统 libc，必须保持原始符号名。
    if fn_decl.fn_decl_body == null {
        return 1;
    }
    // --nostdlib 下保留原始 libc 名。
    if codegen != null && codegen.is_nostdlib != 0 {
        return 1;
    }

    // hosted 模式：仅对与系统 stdlib 原型冲突的符号改为模块前缀名。
    const name: &byte = fn_decl.fn_decl_name;
    if name != null {
        if strcmp(name as *byte, "atol" as *byte) == 0 ||
            strcmp(name as *byte, "strtod" as *byte) == 0 ||
            strcmp(name as *byte, "strtol" as *byte) == 0 ||
            strcmp(name as *byte, "labs" as *byte) == 0 ||
            strcmp(name as *byte, "div" as *byte) == 0 ||
            strcmp(name as *byte, "ldiv" as *byte) == 0 ||
            strcmp(name as *byte, "lldiv" as *byte) == 0 ||
            strcmp(name as *byte, "strtoll" as *byte) == 0 ||
            strcmp(name as *byte, "strtoull" as *byte) == 0 ||
            strcmp(name as *byte, "strtoul" as *byte) == 0 ||
            strcmp(name as *byte, "qsort" as *byte) == 0 ||
            strcmp(name as *byte, "bsearch" as *byte) == 0 {
            return 0;
        }
    }
    return 1;
}

// 检查函数是否按 extern "libc" 原始名调用（用于模块限定调用名生成）
fn is_extern_libc_function(codegen: &C99CodeGenerator, func_name: &byte) i32 {
    if codegen == null || func_name == null {
        return 0;
    }
    const fn_decl: &ASTNode = find_function_decl_c99(codegen, func_name);
    if should_use_raw_libc_symbol_name(codegen, fn_decl) != 0 {
        return 1;
    }
    return 0;
}

// extern "libc" 规范：byte 指针族在 FFI 中映射为 C 的 char 指针族。
// 例如：
//   &byte         -> char *
//   &const byte   -> const char *
//   &&const byte  -> const char * *
fn get_extern_libc_pointer_chain_c_type(codegen: &C99CodeGenerator, type_node: &ASTNode) &byte {
    if codegen == null || type_node == null {
        return null;
    }
    if type_node.type == ASTNodeType.AST_TYPE_NAMED &&
        type_node.type_named_name != null &&
        strcmp(type_node.type_named_name as *byte, "byte" as *byte) == 0 {
        return ("char" as *byte) as &byte;
    }
    if type_node.type != ASTNodeType.AST_TYPE_POINTER || type_node.type_pointer_pointed_type == null {
        return null;
    }
    const pointee_c: &byte = get_extern_libc_pointer_chain_c_type(codegen, type_node.type_pointer_pointed_type);
    if pointee_c == null {
        return null;
    }
    const len: i32 = strlen(pointee_c as *byte) + 16;
    const result: &byte = compiler_arena_alloc(codegen.arena, len as usize) as &byte;
    if result == null {
        return null;
    }
    if type_node.type_pointer_is_const != 0 {
        snprintf(result as *byte, len, "const %s *" as *byte, pointee_c as *byte);
    } else {
        snprintf(result as *byte, len, "%s *" as *byte, pointee_c as *byte);
    }
    return result;
}

fn get_extern_libc_c_type_override(codegen: &C99CodeGenerator, type_node: &ASTNode) &byte {
    if type_node == null || type_node.type != ASTNodeType.AST_TYPE_POINTER {
        return null;
    }
    return get_extern_libc_pointer_chain_c_type(codegen, type_node);
}

fn get_extern_libc_param_c_type(codegen: &C99CodeGenerator, fn_decl: &ASTNode, param_index: i32) &byte {
    if codegen == null || fn_decl == null || fn_decl.type != ASTNodeType.AST_FN_DECL || fn_decl.fn_decl_extern_lib_name == null ||
        param_index < 0 || param_index >= fn_decl.fn_decl_param_count || fn_decl.fn_decl_params == null {
        return null;
    }
    const param: &ASTNode = fn_decl.fn_decl_params[param_index];
    if param == null || param.type != ASTNodeType.AST_VAR_DECL {
        return null;
    }
    return get_extern_libc_c_type_override(codegen, param.var_decl_type);
}

fn get_extern_libc_return_c_type(codegen: &C99CodeGenerator, fn_decl: &ASTNode) &byte {
    if codegen == null || fn_decl == null || fn_decl.type != ASTNodeType.AST_FN_DECL || fn_decl.fn_decl_extern_lib_name == null {
        return null;
    }
    return get_extern_libc_c_type_override(codegen, fn_decl.fn_decl_return_type);
}

fn should_skip_libc_syscall_stub(codegen: &C99CodeGenerator, fn_decl: &ASTNode) i32 {
    if codegen == null || fn_decl == null || fn_decl.type != ASTNodeType.AST_FN_DECL ||
        fn_decl.fn_decl_extern_lib_name == null || fn_decl.fn_decl_name == null || fn_decl.filename == null ||
        codegen.program_node == null || codegen.program_node.type != ASTNodeType.AST_PROGRAM {
        return 0;
    }
    if strstr(fn_decl.filename as *byte, "libc/syscall" as *byte) == null {
        return 0;
    }
    var di: i32 = 0;
    const dc: i32 = codegen.program_node.program_decl_count;
    while di < dc {
        const d: &ASTNode = codegen.program_node.program_decls[di];
        if d != null && d != fn_decl && d.type == ASTNodeType.AST_FN_DECL &&
            d.fn_decl_name != null && strcmp(d.fn_decl_name as *byte, fn_decl.fn_decl_name as *byte) == 0 &&
            d.fn_decl_body != null && d.fn_decl_extern_lib_name == null && d.filename != null &&
            strstr(d.filename as *byte, "syscall/linux" as *byte) != null {
            return 1;
        }
        di = di + 1;
    }
    return 0;
}

// 从文件名提取模块前缀（lib/libc/ -> libc_, lib/std/io/ -> std_io_）
fn get_module_prefix_from_filename(codegen: &C99CodeGenerator, filename: &byte) &byte {
    if codegen == null || filename == null || codegen.arena == null {
        return ("" as *byte) as &byte;
    }
    if strstr(filename as *byte, "/lib/libc/" as *byte) != null || strstr(filename as *byte, "lib/libc/" as *byte) != null {
        return ("libc_" as *byte) as &byte;
    }
    var lib_std: *byte = strstr(filename as *byte, "/lib/std/" as *byte);
    if lib_std == null {
        lib_std = strstr(filename as *byte, "lib/std/" as *byte);
    }
    if lib_std != null {
        var rel: &byte = lib_std as &byte;
        if rel[0] == 47 { rel = &rel[1]; }
        if strncmp(rel as *byte, "lib/std/" as *byte, 8) == 0 {
            rel = &rel[8];
        }
        const rel_len: usize = strlen(rel as *byte);
        var base_len: usize = rel_len;
        if rel_len > 4 && strcmp((rel as *byte + (rel_len - 4)) as *byte, ".uya" as *byte) == 0 {
            base_len = rel_len - 4;
        }
        var si: usize = base_len;
        var last_slash: &byte = null;
        while si > 0 {
            si = si - 1;
            if rel[si] == 47 || rel[si] == 92 {
                last_slash = &rel[si];
                break;
            }
        }
        if last_slash != null {
            const slash_pos_tmp: !usize = ptr_diff(last_slash as *byte, rel as *byte) as! usize;
            const slash_pos: usize = slash_pos_tmp.value;
            const total_len: usize = 4 + slash_pos + 2;
            const prefix: &byte = compiler_arena_alloc(codegen.arena, total_len) as &byte;
            if prefix != null {
                strcpy(prefix as *byte, "std_" as *byte);
                memcpy((prefix as *byte + 4) as *void, rel as *void, slash_pos);
                prefix[4 + slash_pos] = 95 as byte;
                prefix[4 + slash_pos + 1] = 0 as byte;
                var idx: usize = 4;
                while idx < 4 + slash_pos {
                    if prefix[idx] == 47 || prefix[idx] == 92 {
                        prefix[idx] = 95 as byte;
                    }
                    idx = idx + 1;
                }
                return prefix;
            }
        }
        return ("std_" as *byte) as &byte;
    }
    var lib_tls: *byte = strstr(filename as *byte, "/lib/tls/" as *byte);
    if lib_tls == null {
        lib_tls = strstr(filename as *byte, "lib/tls/" as *byte);
    }
    if lib_tls != null {
        var rel_tls: &byte = lib_tls as &byte;
        if rel_tls[0] == 47 { rel_tls = &rel_tls[1]; }
        if strncmp(rel_tls as *byte, "lib/tls/" as *byte, 8) == 0 {
            rel_tls = &rel_tls[8];
        }
        const rel_tls_len: usize = strlen(rel_tls as *byte);
        var base_tls_len: usize = rel_tls_len;
        if rel_tls_len > 4 && strcmp((rel_tls as *byte + (rel_tls_len - 4)) as *byte, ".uya" as *byte) == 0 {
            base_tls_len = rel_tls_len - 4;
        }
        const total_tls_len: usize = 4 + base_tls_len + 2;
        const prefix_tls: &byte = compiler_arena_alloc(codegen.arena, total_tls_len) as &byte;
        if prefix_tls != null {
            strcpy(prefix_tls as *byte, "tls_" as *byte);
            memcpy((prefix_tls as *byte + 4) as *void, rel_tls as *void, base_tls_len);
            const tls_idx1: i32 = 4 + base_tls_len as i32;
            const tls_idx2: i32 = tls_idx1 + 1;
            if tls_idx1 >= 0 && tls_idx1 < 1000000 {
                prefix_tls[tls_idx1] = 95 as byte;
            }
            if tls_idx2 >= 0 && tls_idx2 < 1000000 {
                prefix_tls[tls_idx2] = 0 as byte;
            }
            var ti: usize = 4;
            while ti < 4 + base_tls_len {
                if prefix_tls[ti] == 47 || prefix_tls[ti] == 92 {
                    prefix_tls[ti] = 95 as byte;
                }
                ti = ti + 1;
            }
            return prefix_tls;
        }
    }
    // 检查是否是 src/ 文件（应用程序主文件）
    var src_path: *byte = strstr(filename as *byte, "/src/" as *byte);
    if src_path == null {
        src_path = strstr(filename as *byte, "src/" as *byte);
    }
    if src_path == null {
        src_path = strstr(filename as *byte, "\\src\\" as *byte);
    }
    if src_path != null {
        var rel: &byte = src_path as &byte;
        if rel[0] == 47 { rel = &rel[1]; }
        if strncmp(rel as *byte, "src/" as *byte, 4) == 0 {
            rel = &rel[4];
        } else if strncmp(rel as *byte, "src\\" as *byte, 4) == 0 {
            rel = &rel[4];
        }
        const rel_len: usize = strlen(rel as *byte);
        var base_len: usize = rel_len;
        if rel_len > 4 && strcmp((rel as *byte + (rel_len - 4)) as *byte, ".uya" as *byte) == 0 {
            base_len = rel_len - 4;
        }
        const prefix: &byte = compiler_arena_alloc(codegen.arena, base_len + 2) as &byte;
        if prefix != null {
            memcpy(prefix as *void, rel as *void, base_len);
            const p_idx1: i32 = base_len as i32;
            const p_idx2: i32 = p_idx1 + 1;
            if p_idx1 >= 0 && p_idx1 < 1000000 {
                prefix[p_idx1] = 95 as byte;
            }
            if p_idx2 >= 0 && p_idx2 < 1000000 {
                prefix[p_idx2] = 0 as byte;
            }
            // 将路径分隔符 / 和 \ 替换为 _
            var idx: i32 = 0;
            while idx < base_len as i32 {
                if prefix[idx] == 47 || prefix[idx] == 92 {  // '/' or '\'
                    prefix[idx] = 95 as byte;  // '_'
                }
                idx = idx + 1;
            }
            return prefix;
        }
    }
    return ("" as *byte) as &byte;
}

fn get_export_function_c_name(codegen: &C99CodeGenerator, name: &byte, filename: &byte) &byte {
    if name == null {
        return get_safe_c_identifier(codegen, (" " as *byte) as &byte);
    }
    const prefix: &byte = get_module_prefix_from_filename(codegen, filename);
    if prefix == null || prefix[0] == 0 {
        return get_safe_c_identifier(codegen, name);
    }
    const safe_name: &byte = get_safe_c_identifier(codegen, name);
    const prefix_len: usize = strlen(prefix as *byte);
    const name_len: usize = strlen(safe_name as *byte);
    const result: &byte = compiler_arena_alloc(codegen.arena, prefix_len + name_len + 1) as &byte;
    if result == null {
        return safe_name;
    }
    strcpy(result as *byte, prefix as *byte);
    strcpy((result as *byte + prefix_len) as *byte, safe_name as *byte);
    return result;
}

// 全局函数在 C 中的名称（export 函数带模块前缀；仅原始 libc 符号名保持裸名）
fn get_c_name_for_global_function(codegen: &C99CodeGenerator, name: &byte, for_definition: i32) &byte {
    if name == null {
        return get_safe_c_identifier(codegen, (" " as *byte) as &byte);
    }
    if for_definition == 0 && codegen != null && codegen.program_node != null && codegen.program_node.type == ASTNodeType.AST_PROGRAM {
        const d: &ASTNode = find_function_decl_c99(codegen, name);
        if d != null && d.type == ASTNodeType.AST_FN_DECL &&
           d.fn_decl_is_export != 0 && d.filename != null {
            // 仅原始 libc 符号使用裸名（例如 extern "libc" 无函数体，或 --nostdlib 下带函数体）
            if should_use_raw_libc_symbol_name(codegen, d) != 0 {
                return get_safe_c_identifier(codegen, name);
            }
            return get_export_function_c_name(codegen, name, d.filename);
        }
    }
    return get_safe_c_identifier(codegen, name);
}

// 全局常量在 C 中的名称（lib/libc/ 和 lib/syscall/ 下的 export 变量加模块前缀）
fn get_c_name_for_global_constant(codegen: &C99CodeGenerator, name: &byte, filename: &byte, is_export: i32) &byte {
    if name == null {
        return get_safe_c_identifier(codegen, (" " as *byte) as &byte);
    }
    // 仅对 lib/libc/ 和 lib/syscall/ 下的 export 变量添加模块前缀
    // 但排除 stderr/stdin/stdout，因为它们需要链接到系统 libc
    if filename != null && is_export != 0 {
        const is_std_stream: i32 = (strcmp(name as *byte, "stderr" as *byte) == 0) ||
                                   (strcmp(name as *byte, "stdin" as *byte) == 0) ||
                                   (strcmp(name as *byte, "stdout" as *byte) == 0);
        const is_clocks_per_sec: i32 = (strcmp(name as *byte, "CLOCKS_PER_SEC" as *byte) == 0);
        if is_std_stream == 0 && is_clocks_per_sec == 0 {
            const prefix: &byte = get_module_prefix_from_filename(codegen, filename);
            if prefix != null && prefix[0] != 0 {
                const safe_name: &byte = get_safe_c_identifier(codegen, name);
                const prefix_len: usize = strlen(prefix as *byte);
                const name_len: usize = strlen(safe_name as *byte);
                const result: &byte = compiler_arena_alloc(codegen.arena, prefix_len + name_len + 1) as &byte;
                if result != null {
                    strcpy(result as *byte, prefix as *byte);
                    strcpy((result as *byte + prefix_len) as *byte, safe_name as *byte);
                    return result;
                }
            }
        }
    }
    return get_safe_c_identifier(codegen, name);
}

fn format_param_type(codegen: &C99CodeGenerator, type_c: &byte, param_name: &byte, output: &void) void {
    // codegen 参数未使用，但保留以保持接口一致性
    if type_c == null || param_name == null {
        return;
    }

    // 特殊处理：如果是 copy_type 函数的第一个参数且类型是 "struct Type *" 或 "const struct Type *"，则改为 "const struct Type *"
    // 检查当前函数名是否为 copy_type（通过 codegen.current_function_decl）
    var is_copy_type_param: i32 = 0;
    if codegen != null && codegen.current_function_decl != null {
        const fn_name: &byte = codegen.current_function_decl.fn_decl_name;
        if fn_name != null && strcmp(fn_name as *byte, "copy_type" as *byte) == 0 {
            // 检查参数类型是否为 "struct Type *" 或已经是 "const struct Type *"
            if strcmp(type_c as *byte, "struct Type *" as *byte) == 0 {
                is_copy_type_param = 1;
            } else if strcmp(type_c as *byte, "const struct Type *" as *byte) == 0 {
                is_copy_type_param = 1;
            }
        }
    }

    // 检查是否是指向数组的指针（包含 "(*)" 和 "[数字]"）
    // 例如：uint8_t (*)[4096] -> uint8_t (*param_name)[4096]
    const paren_star: *byte = strstr(type_c as *byte, "(*)" as *byte);
    if paren_star != null {
        // 是指向数组的指针，需要将 param_name 插入到 (*) 中
        const before_paren: i32 = ptr_diff(paren_star, type_c as *byte);
        const after_paren: *byte = paren_star + 3;  // 跳过 "(*)"
        // 输出：base_type (*param_name)[dims]
        var temp_buf: [byte: TEMP_BUF_SIZE] = [];
        var i: i32 = 0;
        while i < before_paren && i < TEMP_BUF_LIMIT {
            temp_buf[i] = type_c[i];
            i = i + 1;
        }
        if i >= 0 && i < TEMP_BUF_SIZE {
            temp_buf[i] = 0;
        }
        fprintf(output, "%s (*%s)%s" as *byte, &temp_buf[0] as *byte, param_name as *byte, after_paren);
    } else {
        // 检查是否是数组类型（包含 [数字]）
        const bracket: *byte = strchr(type_c as *byte, 91);  // '['
        if bracket != null {
            // 提取元素类型（bracket之前的部分）
            const str_len: i32 = ptr_diff(bracket, type_c as *byte);
            // 注意：Uya Mini 不支持 %.*s，需要手动处理
            // 简化处理：使用临时缓冲区
            var temp_buf: [byte: TEMP_BUF_SIZE] = [];
            var i: i32 = 0;
            while i < str_len && i < TEMP_BUF_LIMIT {
                temp_buf[i] = type_c[i];
                i = i + 1;
            }
            if i >= 0 && i < TEMP_BUF_SIZE {
                temp_buf[i] = 0;
            }
            fprintf(output, "%s %s%s" as *byte, &temp_buf[0] as *byte, param_name as *byte, bracket);
        } else {
            // 非数组类型
            // 检查是否是指针类型（包含 '*'）
            // 如果是指针类型，格式应该是 "type * name"（* 紧跟在类型后面）
            // c99_type_to_c 已经返回了正确的格式（如 "struct Type *"），所以直接输出即可
            // 特殊处理 copy_type 函数：将 "struct Type *" 改为 "const struct Type *"
            if is_copy_type_param != 0 {
                fprintf(output, "const struct Type * %s" as *byte, param_name as *byte);
            } else {
                fprintf(output, "%s %s" as *byte, type_c as *byte, param_name as *byte);
            }
        }
    }
}

// 生成函数原型（前向声明）
// 注意：此函数在 main.uya 中被调用，但由于 function.uya 在 main.uya 之前编译，函数已经可见
fn c99_should_emit_static_top_level_function(codegen: &C99CodeGenerator, fn_decl: &ASTNode) i32 {
    if codegen == null || fn_decl == null || fn_decl.type != ASTNodeType.AST_FN_DECL {
        return 0;
    }
    if codegen.split_enabled != 0 {
        return 0;
    }
    if fn_decl.fn_decl_body == null {
        return 0;
    }
    if fn_decl.fn_decl_is_export != 0 || fn_decl.fn_decl_extern_lib_name != null {
        return 0;
    }
    if fn_decl.fn_decl_name != null && strcmp(fn_decl.fn_decl_name as *byte, "main" as *byte) == 0 {
        return 0;
    }
    if fn_decl.fn_decl_name != null && codegen.program_node != null && codegen.program_node.type == ASTNodeType.AST_PROGRAM {
        var di: i32 = 0;
        while di < codegen.program_node.program_decl_count {
            const d: &ASTNode = codegen.program_node.program_decls[di];
            if d != null && d.type == ASTNodeType.AST_FN_DECL && d.fn_decl_name != null &&
               strcmp(d.fn_decl_name as *byte, fn_decl.fn_decl_name as *byte) == 0 && d.fn_decl_body == null {
                return 0;
            }
            di = di + 1;
        }
    }
    return 1;
}

fn gen_function_prototype(codegen: &C99CodeGenerator, fn_decl: &ASTNode) void {
    if fn_decl == null || fn_decl.type != ASTNodeType.AST_FN_DECL {
        return;
    }
    if should_skip_libc_syscall_stub(codegen, fn_decl) != 0 {
        return;
    }
    
    // 设置当前函数声明（用于 format_param_type 中的 copy_type 检查）
    const saved_current_function_decl: &ASTNode = codegen.current_function_decl;
    codegen.current_function_decl = fn_decl;
    
    const extern_lib_name: &byte = fn_decl.fn_decl_extern_lib_name;  // extern "libc" fn 的库名
    
    const use_raw_libc_name: i32 = should_use_raw_libc_symbol_name(codegen, fn_decl);
    // hosted 下 extern "libc" 带函数体改为模块前缀名，避免与系统 libc 原型冲突
    var func_name: &byte = get_c_name_for_global_function(codegen, fn_decl.fn_decl_name, 1);
    if fn_decl.fn_decl_is_export != 0 && fn_decl.filename != null &&
        (extern_lib_name == null || use_raw_libc_name == 0) {
        func_name = get_export_function_c_name(codegen, fn_decl.fn_decl_name, fn_decl.filename);
    }
    const return_type: &ASTNode = fn_decl.fn_decl_return_type;
    const param_count: i32 = fn_decl.fn_decl_param_count;
    const is_varargs: i32 = fn_decl.fn_decl_is_varargs;
    const body: &ASTNode = fn_decl.fn_decl_body;
    
    // 检查是否为extern函数（body为NULL表示extern函数）
    var is_extern: i32 = 0;
    if body == null && extern_lib_name == null {
        // 只有当没有 extern_lib_name 时才标记为 is_extern
        // extern "libc" fn 带函数体时，is_extern 应该为 0
        is_extern = 1;
    }
    
    // extern "libc" fn 无函数体：不生成声明，链接到系统 libc
    if extern_lib_name != null && body == null {
        return;
    }
    
    // 返回类型（如果是数组类型，转换为指针类型）
    var return_c: &byte = convert_array_return_type(codegen, return_type);
    return_c = normalize_poll_return_type(codegen, return_c);
    const libc_return_c: &byte = get_extern_libc_return_c_type(codegen, fn_decl);
    if libc_return_c != null {
        return_c = libc_return_c;
    }

    // 特殊处理：main 函数需要重命名为 uya_main（符合 Uya 规范：main 函数无参数）
    // 注意：Uya Mini 不支持三元运算符，使用 if-else 代替
    var is_main: i32 = 0;
    if fn_decl.fn_decl_name != null && strcmp(fn_decl.fn_decl_name as *byte, "main" as *byte) == 0 {
        is_main = 1;
    }

    // 检查是否为标准 C main 函数（export extern fn main）
    var is_c_main: i32 = 0;
    if is_main != 0 && fn_decl.fn_decl_is_export != 0 && fn_decl.fn_decl_is_extern != 0 {
        is_c_main = 1;
    }

    // export extern fn main：生成裸名 main 的前向声明，不带模块前缀
    // C 入口统一使用 char **argv，以兼容 Zig/Clang 对 main 签名的要求；
    // saved_argv 仍由 gen_assign_non_array 负责显式转换成 uint8_t **。
    if is_c_main != 0 {
        var j: i32 = 0;
        c99_preregister_slices_top_level_fn(codegen, fn_decl);
        fprintf(codegen.emit_stream, "extern %s main(" as *byte, return_c as *byte);
        while j < param_count {
            const param: &ASTNode = fn_decl.fn_decl_params[j];
            if param != null && param.type == ASTNodeType.AST_VAR_DECL {
                const param_name: &byte = get_safe_c_identifier(codegen, param.var_decl_name);
                if j == 1 {
                    fprintf(codegen.emit_stream, "char **%s" as *byte, param_name as *byte);
                } else {
                    const param_type: &ASTNode = param.var_decl_type;
                    const param_type_c: &byte = c99_type_to_c(codegen, param_type);
                    format_param_type(codegen, param_type_c, param_name, codegen.emit_stream as *void);
                }
                if j < param_count - 1 {
                    fputs(", " as *byte, codegen.emit_stream);
                }
            }
            j = j + 1;
        }
        fputs(");\n" as *byte, codegen.emit_stream);
        codegen.current_function_decl = saved_current_function_decl;
        return;
    }

    // 仅 fn main（非 export）提前返回生成 uya_main(void)；export fn main 走通用路径生成 main_main()
    if is_main != 0 && is_c_main == 0 && fn_decl.fn_decl_is_export == 0 {
        fprintf(codegen.emit_stream, "%s uya_main(void);\n" as *byte, return_c as *byte);
        return;
    }
    
    // 若程序中已有同名函数定义（如 libc 实现），跳过 extern 声明，避免与 GCC built-in 冲突
    if is_extern != 0 && fn_decl.fn_decl_name != null && codegen.program_node != null && codegen.program_node.type == ASTNodeType.AST_PROGRAM {
        var di: i32 = 0;
        while di < codegen.program_node.program_decl_count {
            const d: &ASTNode = codegen.program_node.program_decls[di];
            if d != null && d != fn_decl && d.type == ASTNodeType.AST_FN_DECL && d.fn_decl_name != null &&
               strcmp(d.fn_decl_name as *byte, fn_decl.fn_decl_name as *byte) == 0 && d.fn_decl_body != null {
                codegen.current_function_decl = saved_current_function_decl;
                return;
            }
            di = di + 1;
        }
    }
    // uya_thread_call_* 由 C99 前导中的 static inline 提供；跳过 extern 原型以免与定义链接属性冲突
    if is_extern != 0 && fn_decl.fn_decl_name != null {
        if strcmp(fn_decl.fn_decl_name as *byte, "uya_thread_call_i32" as *byte) == 0 ||
           strcmp(fn_decl.fn_decl_name as *byte, "uya_thread_call_u32" as *byte) == 0 ||
           strcmp(fn_decl.fn_decl_name as *byte, "uya_thread_call_usize" as *byte) == 0 {
            codegen.current_function_decl = saved_current_function_decl;
            return;
        }
    }
    c99_preregister_slices_top_level_fn(codegen, fn_decl);
    c99_emit_async_frame_forward_for_type(codegen, return_type);
    var pi_fwd: i32 = 0;
    while pi_fwd < param_count {
        const param_fwd: &ASTNode = fn_decl.fn_decl_params[pi_fwd];
        if param_fwd != null && param_fwd.type == ASTNodeType.AST_VAR_DECL && param_fwd.var_decl_type != null {
            c99_emit_async_frame_forward_for_type(codegen, param_fwd.var_decl_type);
        }
        pi_fwd = pi_fwd + 1;
    }
    const should_emit_static: i32 = c99_should_emit_static_top_level_function(codegen, fn_decl);
    // 顶层 helper 可能在定义前被调用；若定义是内部链接，则原型也必须保持 static，避免 single-file C 里出现
    // “non-static declaration” 与后续 static 定义冲突。
    if is_extern == 0 {
        if should_emit_static != 0 {
            fprintf(codegen.emit_stream, "static __attribute__((used)) %s %s(" as *byte, return_c as *byte, func_name as *byte);
        } else {
            fprintf(codegen.emit_stream, "%s %s(" as *byte, return_c as *byte, func_name as *byte);
        }
    } else {
        fprintf(codegen.emit_stream, "extern %s %s(" as *byte, return_c as *byte, func_name as *byte);
    }
    
    // 检查是否为 copy_type 函数（需要 const 限定符）
    var is_copy_type: i32 = 0;
    if fn_decl.fn_decl_name != null && strcmp(fn_decl.fn_decl_name as *byte, "copy_type" as *byte) == 0 {
        is_copy_type = 1;
    }

    // 检查是否为标准库函数（extern "libc" fn）
    var is_stdlib: i32 = 0;
    if extern_lib_name != null {
        is_stdlib = 1;
    }

    // 参数列表
    var i: i32 = 0;
    while i < param_count {
        const param: &ASTNode = fn_decl.fn_decl_params[i];
        if param != null && param.type == ASTNodeType.AST_VAR_DECL {
            const param_name: &byte = get_safe_c_identifier(codegen, param.var_decl_name);
            const param_type: &ASTNode = param.var_decl_type;
            var param_type_c: &byte = c99_type_to_c(codegen, param_type);
            
            // 特殊处理 copy_type 函数：将第一个参数类型改为 const struct Type *
            if is_copy_type != 0 && i == 0 {
                // 对于 copy_type 函数，第一个参数类型必须是 const struct Type *
                // 直接替换，不检查原始类型（因为 copy_type 的参数类型总是 &Type，即 struct Type *）
                param_type_c = ("const struct Type *" as *byte) as &byte;
            }
            
            // 对于 extern 函数，检查大结构体参数（>16字节），转换为指针类型
            // 根据 x86-64 System V ABI，大于 16 字节的结构体通过指针传递
            if is_extern != 0 && param_type.type == ASTNodeType.AST_TYPE_NAMED {
                const struct_size: i32 = calculate_struct_size(codegen, param_type);
                if struct_size > 16 {
                    // 大结构体：转换为指针类型
                    // 注意：如果是 copy_type 函数，保持 const struct Type *
                    if is_copy_type != 0 && i == 0 {
                        param_type_c = ("const struct Type *" as *byte) as &byte;
                    } else {
                        param_type_c = c99_type_to_c(codegen, param_type);
                    }
                    fprintf(codegen.emit_stream, "%s *%s" as *byte, param_type_c as *byte, param_name as *byte);
                    if i < param_count - 1 {
                        fputs(", " as *byte, codegen.emit_stream);
                    }
                    i = i + 1;
                    continue;
                }
            }
            
            const libc_param_c: &byte = get_extern_libc_param_c_type(codegen, fn_decl, i);
            if libc_param_c != null {
                param_type_c = libc_param_c;
            }
            
            // 数组参数：在参数名后添加 _param 后缀，函数内部会创建副本
            if param_type.type == ASTNodeType.AST_TYPE_ARRAY {
                // 数组参数格式：T name_param[N]
                const bracket: *byte = strchr(param_type_c as *byte, 91);  // '['
                if bracket != null {
                    const str_len: i32 = ptr_diff(bracket, param_type_c as *byte);
                    // 注意：Uya Mini 不支持 %.*s，需要手动处理
                    var temp_buf: [byte: TEMP_BUF_SIZE] = [];
                    var j: i32 = 0;
                    while j < str_len && j < TEMP_BUF_LIMIT {
                        temp_buf[j] = param_type_c[j];
                        j = j + 1;
                    }
                    if j >= 0 && j < TEMP_BUF_SIZE {
                        temp_buf[j] = 0;
                    }
                    fprintf(codegen.emit_stream, "%s %s_param%s" as *byte, &temp_buf[0] as *byte, param_name as *byte, bracket);
                } else {
                    fprintf(codegen.emit_stream, "%s %s_param" as *byte, param_type_c as *byte, param_name as *byte);
                }
            } else if param_type.type == ASTNodeType.AST_TYPE_SLICE {
                // Slice 形参 &[T]：C 侧统一为按值 struct uya_slice_*（extern 声明与 Uya 定义一致）
                format_param_type(codegen, param_type_c, param_name, codegen.emit_stream);
            } else {
                // 对于 copy_type 函数，直接输出 const struct Type *，不调用 format_param_type
                if is_copy_type != 0 && i == 0 {
                    fprintf(codegen.emit_stream, "const struct Type * %s" as *byte, param_name as *byte);
                } else {
                    format_param_type(codegen, param_type_c, param_name, codegen.emit_stream);
                }
            }
            if i < param_count - 1 {
                fputs(", " as *byte, codegen.emit_stream);
            }
        }
        i = i + 1;
    }
    
    // 处理可变参数
    if is_varargs != 0 {
        if param_count > 0 {
            fputs(", " as *byte, codegen.emit_stream);
        }
        fputs("..." as *byte, codegen.emit_stream);
    }
    
    fputs(");\n" as *byte, codegen.emit_stream);
    
    // 恢复当前函数声明
    codegen.current_function_decl = saved_current_function_decl;
}

// 生成函数定义
// 注意：此函数在 main.uya 中被调用，但由于 function.uya 在 main.uya 之前编译，函数已经可见
fn gen_function(codegen: &C99CodeGenerator, fn_decl: &ASTNode) void {
    if fn_decl == null || fn_decl.type != ASTNodeType.AST_FN_DECL {
        return;
    }
    
    const orig_name: &byte = fn_decl.fn_decl_name;
    const extern_lib_name: &byte = fn_decl.fn_decl_extern_lib_name;  // extern "libc" fn 的库名
    
    const use_raw_libc_name: i32 = should_use_raw_libc_symbol_name(codegen, fn_decl);
    // hosted 下 extern "libc" 带函数体改为模块前缀名，避免与系统 libc 原型冲突
    var func_name: &byte = get_c_name_for_global_function(codegen, orig_name, 1);
    if fn_decl.fn_decl_is_export != 0 && fn_decl.filename != null &&
        (extern_lib_name == null || use_raw_libc_name == 0) {
        func_name = get_export_function_c_name(codegen, orig_name, fn_decl.filename);
    }
    const return_type: &ASTNode = fn_decl.fn_decl_return_type;
    const param_count: i32 = fn_decl.fn_decl_param_count;
    const is_varargs: i32 = fn_decl.fn_decl_is_varargs;
    const body: &ASTNode = fn_decl.fn_decl_body;
    
    // 如果没有函数体（外部函数），则不生成定义
    if body == null {
        return;
    }

    // lib/libc/syscall.uya 的 export extern "libc" sys_* 与 lib/syscall/linux.uya 的 export sys_* C 符号均为 sys_*，
    // 合并编译时只应保留 linux 实现，否则 C 报重复定义。
    if should_skip_libc_syscall_stub(codegen, fn_decl) != 0 {
        return;
    }

    // @async_fn：
    // - 形式一（阶段 B）：返回 Future<!T> 或 !Future<T>，使用状态机生成 async
    // - 形式二（阶段 A 兼容）：其他返回类型走普通函数代码生成
    if fn_decl.fn_decl_is_async != 0 {
        var use_stage_b: i32 = 0;
        var effective_return_type: &ASTNode = return_type;
        if return_type != null && return_type.type == ASTNodeType.AST_TYPE_NAMED &&
            return_type.type_named_name != null &&
            strcmp(return_type.type_named_name as *byte, "Future" as *byte) == 0 &&
            return_type.type_named_type_arg_count == 1 &&
            return_type.type_named_type_args != null {
            const a0: &ASTNode = return_type.type_named_type_args[0];
            if a0 != null && a0.type == ASTNodeType.AST_TYPE_ERROR_UNION &&
                a0.type_error_union_payload_type != null {
                use_stage_b = 1;
            }
        }
        if use_stage_b == 0 && return_type != null && return_type.type == ASTNodeType.AST_TYPE_ERROR_UNION &&
            return_type.type_error_union_payload_type != null {
            const pl: &ASTNode = return_type.type_error_union_payload_type;
            if pl.type == ASTNodeType.AST_TYPE_NAMED && pl.type_named_name != null &&
                strcmp(pl.type_named_name as *byte, "Future" as *byte) == 0 &&
                pl.type_named_type_arg_count == 1 && pl.type_named_type_args != null {
                use_stage_b = 1;
                effective_return_type = pl;
            }
        }
        if use_stage_b != 0 {
            gen_async_function_stage_b(codegen, fn_decl, func_name, return_type, effective_return_type, 0);
            return;
        }
        // 否则继续走普通函数定义路径
    }
    
    // 生成 #line 指令，指向函数定义的位置
    emit_line_directive(codegen, fn_decl.line, fn_decl.filename);
    
    // 特殊处理：main 函数需要重命名为 uya_main（符合 Uya 规范：main 函数无参数）
    // 注意：Uya Mini 不支持三元运算符，使用 if-else 代替
    var is_main: i32 = 0;
    if fn_decl.fn_decl_name != null && strcmp(fn_decl.fn_decl_name as *byte, "main" as *byte) == 0 {
        is_main = 1;
    }
    
    // 返回类型（如果是数组类型，转换为指针类型）
    var return_c: &byte = convert_array_return_type(codegen, return_type);
    return_c = normalize_poll_return_type(codegen, return_c);
    const libc_return_c: &byte = get_extern_libc_return_c_type(codegen, fn_decl);
    if libc_return_c != null {
        return_c = libc_return_c;
    }
    c99_preregister_slices_top_level_fn(codegen, fn_decl);
    
    // 声明循环变量 i（在 if-else 之前声明，确保在所有分支都可见）
    var i: i32 = 0;
    
    const is_static: i32 = c99_should_emit_static_top_level_function(codegen, fn_decl);

    // 检查是否为标准 C main 函数（export extern fn main）
    var is_c_main: i32 = 0;
    if is_main != 0 && fn_decl.fn_decl_is_export != 0 && fn_decl.fn_decl_is_extern != 0 {
        is_c_main = 1;
    }

    if is_main != 0 && is_c_main == 0 {
        // export fn main → main_main，fn main → uya_main
        var main_def_name: &byte = "uya_main" as *byte;
        if fn_decl.fn_decl_is_export != 0 {
            main_def_name = "main_main" as *byte;
        }
        fprintf(codegen.emit_stream, "%s %s(void)" as *byte, return_c as *byte, main_def_name as *byte);
    } else {
        // 非 extern 函数：根据 is_export 决定是否添加 static
        // fn foo() void → static void foo(void)（内部函数，不导出）
        // export fn foo() void → void foo(void)（导出函数，供其他模块使用）
        // @naked_fn 函数添加 __attribute__((naked))
        if fn_decl.fn_decl_is_naked != 0 {
            fprintf(codegen.emit_stream, "__attribute__((naked)) " as *byte);
        }
        if is_static != 0 {
            fprintf(codegen.emit_stream, "static __attribute__((used)) " as *byte);
        } else if fn_decl.fn_decl_extern_lib_name != null {
            // extern "libc" 等函数可能在 @asm 中被引用，LTO + --gc-sections 下需要 used 防止被回收
            fprintf(codegen.emit_stream, "__attribute__((used)) " as *byte);
        }
        fprintf(codegen.emit_stream, "%s %s(" as *byte, return_c as *byte, func_name as *byte);
        
        // 检查是否为 copy_type 函数（需要 const 限定符）
        var is_copy_type: i32 = 0;
        if fn_decl.fn_decl_name != null && strcmp(fn_decl.fn_decl_name as *byte, "copy_type" as *byte) == 0 {
            is_copy_type = 1;
        }

        // 参数列表
        i = 0;
        while i < param_count {
            const param: &ASTNode = fn_decl.fn_decl_params[i];
            if param != null && param.type == ASTNodeType.AST_VAR_DECL {
                const param_name: &byte = get_safe_c_identifier(codegen, param.var_decl_name);
                const param_type: &ASTNode = param.var_decl_type;
                var param_type_c: &byte = c99_type_to_c(codegen, param_type);
                
                // 特殊处理 copy_type 函数：将第一个参数类型改为 const struct Type *
                if is_copy_type != 0 && i == 0 {
                    // 对于 copy_type 函数，第一个参数类型必须是 const struct Type *
                    // 直接替换，不检查原始类型（因为 copy_type 的参数类型总是 &Type，即 struct Type *）
                    param_type_c = ("const struct Type *" as *byte) as &byte;
                }
                
                const libc_param_c: &byte = get_extern_libc_param_c_type(codegen, fn_decl, i);
                if libc_param_c != null {
                    param_type_c = libc_param_c;
                }
                
                // 数组参数：在参数名后添加 _param 后缀，函数内部会创建副本
                if param_type.type == ASTNodeType.AST_TYPE_ARRAY {
                    // 数组参数格式：T name_param[N]
                    const bracket: *byte = strchr(param_type_c as *byte, 91);  // '['
                    if bracket != null {
                        const str_len: i32 = ptr_diff(bracket, param_type_c as *byte);
                        // 注意：Uya Mini 不支持 %.*s，需要手动处理
                        var temp_buf: [byte: TEMP_BUF_SIZE] = [];
                        var j: i32 = 0;
                        while j < str_len && j < TEMP_BUF_LIMIT {
                            temp_buf[j] = param_type_c[j];
                            j = j + 1;
                        }
                        if j >= 0 && j < TEMP_BUF_SIZE {
                            temp_buf[j] = 0;
                        }
                        fprintf(codegen.emit_stream, "%s %s_param%s" as *byte, &temp_buf[0] as *byte, param_name as *byte, bracket);
                    } else {
                        fprintf(codegen.emit_stream, "%s %s_param" as *byte, param_type_c as *byte, param_name as *byte);
                    }
                } else if param_type.type == ASTNodeType.AST_TYPE_SLICE {
                    // slice 形参按值 struct uya_slice_*（gen_function 仅在 body!=null 时到达此处）
                    format_param_type(codegen, param_type_c, param_name, codegen.emit_stream);
                } else if is_c_main != 0 && i == 1 {
                    if codegen.is_nostdlib != 0 {
                        fprintf(codegen.emit_stream, "uint8_t **%s" as *byte, param_name as *byte);
                    } else {
                        fprintf(codegen.emit_stream, "char **%s" as *byte, param_name as *byte);
                    }
                } else {
                    // 对于 copy_type 函数，直接输出 const struct Type *，不调用 format_param_type
                    if is_copy_type != 0 && i == 0 {
                        fprintf(codegen.emit_stream, "const struct Type * %s" as *byte, param_name as *byte);
                    } else {
                        format_param_type(codegen, param_type_c, param_name, codegen.emit_stream);
                    }
                }
                if i < param_count - 1 {
                    fputs(", " as *byte, codegen.emit_stream);
                }
            }
            i = i + 1;
        }
        
        // 处理可变参数
        if is_varargs != 0 {
            if param_count > 0 {
                fputs(", " as *byte, codegen.emit_stream);
            }
            fputs("..." as *byte, codegen.emit_stream);
        }
    }
    
    // 添加函数体开始
    if is_main != 0 {
        fputs(" {\n" as *byte, codegen.emit_stream);
        // 在 main 函数开始时调用测试运行器（只有在有测试时才调用）
        if codegen.test_count > 0 {
            fputs("    uya_run_tests();\n" as *byte, codegen.emit_stream);
        }
    } else {
        fputs(") {\n" as *byte, codegen.emit_stream);
    }
    codegen.indent_level = codegen.indent_level + 1;
    
    // 保存当前函数的返回类型（用于生成返回语句）
    codegen.current_function_return_type = return_type;
    
    // 保存当前函数声明（用于 @params 与 ... 转发）
    const saved_current_function_decl: &ASTNode = codegen.current_function_decl;
    codegen.current_function_decl = fn_decl;
    
    // 保存函数开始时的局部变量表状态（用于函数结束时恢复）
    // 每个函数有自己独立的局部变量表，函数结束后恢复之前的状态
    const saved_local_variable_count: i32 = codegen.local_variable_count;
    const saved_current_depth: i32 = codegen.current_depth;
    
    // 重置当前函数的局部变量表（从 0 开始）
    // 这样每个函数都有自己独立的局部变量表，避免大文件时表被填满
    // 参数和局部变量都从索引 0 开始添加
    codegen.local_variable_count = 0;
    codegen.current_depth = 0;
    
    // 处理数组参数：为数组参数创建局部副本（实现按值传递）
    i = 0;
    while i < param_count {
        const param: &ASTNode = fn_decl.fn_decl_params[i];
        if param != null && param.type == ASTNodeType.AST_VAR_DECL {
            const param_name: &byte = get_safe_c_identifier(codegen, param.var_decl_name);
            const param_type: &ASTNode = param.var_decl_type;
            
            if param_type.type == ASTNodeType.AST_TYPE_ARRAY {
                // 数组参数：创建局部数组副本
                const array_type_c: &byte = c99_type_to_c(codegen, param_type);
                // 解析数组类型格式：int32_t[3] -> int32_t arr[3]
                const bracket: *byte = strchr(array_type_c as *byte, 91);  // '['
                c99_emit_indent(codegen);
                fputs("// 数组参数按值传递：创建局部副本\n" as *byte, codegen.emit_stream);
                if bracket != null {
                    const str_len: i32 = ptr_diff(bracket, array_type_c as *byte);
                    // 注意：Uya Mini 不支持 %.*s，需要手动处理
                    var temp_buf: [byte: TEMP_BUF_SIZE] = [];
                    var j: i32 = 0;
                    while j < str_len && j < TEMP_BUF_LIMIT {
                        temp_buf[j] = array_type_c[j];
                        j = j + 1;
                    }
                    if j >= 0 && j < TEMP_BUF_SIZE {
                        temp_buf[j] = 0;
                    }
                    fprintf(codegen.emit_stream, "    %s %s%s;\n" as *byte, &temp_buf[0] as *byte, param_name as *byte, bracket);
                } else {
                    c99_emit_indent(codegen);
                    fprintf(codegen.emit_stream, "%s %s;\n" as *byte, array_type_c as *byte, param_name as *byte);
                }
                c99_emit_indent(codegen);
                codegen.needs_string_h = 1;
                fprintf(codegen.emit_stream, "    __uya_memcpy(%s, %s_param, sizeof(%s));\n" as *byte, param_name as *byte, param_name as *byte, param_name as *byte);
                
                // 将参数名注册为局部数组（而不是参数）
                if param_name != null && codegen.local_variable_count < C99_MAX_LOCAL_VARS {
                    c99_push_local_variable(codegen, param.var_decl_name, array_type_c, param.var_decl_type, codegen.current_depth);
                }
            } else {
                // 非数组参数：正常添加到局部变量表（slice 形参 C 侧为按值 struct，类型串无 *）
                const param_type_c: &byte = c99_type_to_c(codegen, param_type);
                if param_name != null && param_type_c != null && codegen.local_variable_count < C99_MAX_LOCAL_VARS {
                    c99_push_local_variable(codegen, param.var_decl_name, param_type_c, param.var_decl_type, codegen.current_depth);
                }
            }
        }
        i = i + 1;
    }
    if fn_decl.fn_decl_is_naked == 0 {
        i = 0;
        while i < param_count {
            const param: &ASTNode = fn_decl.fn_decl_params[i];
            if param != null && param.type == ASTNodeType.AST_VAR_DECL {
                const pname: &byte = get_safe_c_identifier(codegen, param.var_decl_name);
                if pname != null {
                    c99_emit_indent(codegen);
                    if param.var_decl_type != null && param.var_decl_type.type == ASTNodeType.AST_TYPE_ARRAY {
                        fprintf(codegen.emit_stream as *void, "(void)%s_param;\n" as *byte, pname as *byte);
                    } else {
                        fprintf(codegen.emit_stream as *void, "(void)%s;\n" as *byte, pname as *byte);
                    }
                }
            }
            i = i + 1;
        }
    }
    
    // 生成函数体
    gen_stmt(codegen, body);
    
    // 检查函数体是否以 return 结尾
    var has_return: i32 = 0;
    if body != null && body.type == ASTNodeType.AST_BLOCK {
        const stmts: & & ASTNode = body.block_stmts;
        const stmt_count: i32 = body.block_stmt_count;
        var j: i32 = stmt_count - 1;
        while j >= 0 {
            const s: &ASTNode = stmts[j];
            if s != null && s.type != ASTNodeType.AST_DEFER_STMT && s.type != ASTNodeType.AST_ERRDEFER_STMT {
                if s.type == ASTNodeType.AST_RETURN_STMT {
                    has_return = 1;
                } else {
                    has_return = 0;
                }
                break;
            }
            j = j - 1;
        }
    }
    
    // 如果返回类型是 !void 且函数体没有显式返回，添加默认返回语句
    if fn_decl.fn_decl_is_naked == 0 && has_return == 0 && return_type != null && return_type.type == ASTNodeType.AST_TYPE_ERROR_UNION {
        const payload_node: &ASTNode = return_type.type_error_union_payload_type;
        var is_void_payload: i32 = 0;
        if payload_node == null {
            is_void_payload = 1;
        } else if payload_node.type == ASTNodeType.AST_TYPE_NAMED && payload_node.type_named_name != null &&
            strcmp(payload_node.type_named_name as *byte, "void" as *byte) == 0 {
            is_void_payload = 1;
        }
        if is_void_payload != 0 {
            // !void 类型：返回成功的错误联合（缩进与 C 编译器一致）
            codegen.indent_level = codegen.indent_level + 1;
            c99_emit_indent(codegen);
            fprintf(codegen.emit_stream as *void, "return (%s){ .error_id = 0 };\n" as *byte, return_c as *byte);
            codegen.indent_level = codegen.indent_level - 1;
        }
    }
    // 若返回类型非 void 且函数体末尾无 return，补兜底 return 避免 -Wreturn-type（缩进与 C 编译器一致）
    if fn_decl.fn_decl_is_naked == 0 && has_return == 0 && return_type != null {
        var is_void: i32 = 0;
        if return_type.type == ASTNodeType.AST_TYPE_NAMED && return_type.type_named_name != null &&
            strcmp(return_type.type_named_name as *byte, "void" as *byte) == 0 {
            is_void = 1;
        } else if return_type.type == ASTNodeType.AST_TYPE_ERROR_UNION {
            const pl: &ASTNode = return_type.type_error_union_payload_type;
            if pl == null {
                is_void = 1;
            } else if pl.type == ASTNodeType.AST_TYPE_NAMED && pl.type_named_name != null &&
                strcmp(pl.type_named_name as *byte, "void" as *byte) == 0 {
                is_void = 1;
            }
        }
        if is_void == 0 {
            codegen.indent_level = codegen.indent_level + 1;
            c99_emit_indent(codegen);
            if return_c != null && strncmp(return_c as *byte, "struct " as *byte, 7) == 0 {
                fprintf(codegen.emit_stream as *void, "return (%s){0};\n" as *byte, return_c as *byte);
            } else {
                fputs("return 0;\n" as *byte, codegen.emit_stream as *void);
            }
            codegen.indent_level = codegen.indent_level - 1;
        }
    }
    
    // 清除当前函数的返回类型
    codegen.current_function_return_type = null;
    
    // 恢复当前函数声明
    codegen.current_function_decl = saved_current_function_decl;
    
    // 恢复函数开始时的局部变量表状态
    // 这样下一个函数可以从干净的状态开始
    codegen.local_variable_count = saved_local_variable_count;
    codegen.current_depth = saved_current_depth;
    
    codegen.indent_level = codegen.indent_level - 1;
    c99_emit_indent(codegen);
    c99_emit_close_brace_newline(codegen);
}

// 从已解析的 Type 计算字节大小（用于 async 状态机估算）；递归字段使用 checker 从 AST 解析
fn get_type_size_bytes_resolved(codegen: &C99CodeGenerator, t: &Type) i32 {
    if t == null || codegen == null || codegen.checker == null {
        return -1;
    }
    const k: TypeKind = t.kind;
    if k == TypeKind.TYPE_I8 || k == TypeKind.TYPE_BOOL || k == TypeKind.TYPE_BYTE { return 1; }
    if k == TypeKind.TYPE_I16 || k == TypeKind.TYPE_U16 { return 2; }
    if k == TypeKind.TYPE_I32 || k == TypeKind.TYPE_U32 || k == TypeKind.TYPE_F32 { return 4; }
    if k == TypeKind.TYPE_I64 || k == TypeKind.TYPE_U64 || k == TypeKind.TYPE_F64 || k == TypeKind.TYPE_USIZE { return 8; }
    if k == TypeKind.TYPE_POINTER { return 8; }
    if k == TypeKind.TYPE_ATOMIC && t.atomic_inner_type != null {
        return get_type_size_bytes_resolved(codegen, t.atomic_inner_type);
    }
    if k == TypeKind.TYPE_ARRAY {
        if t.element_type != null && t.array_size > 0 {
            const esz: i32 = get_type_size_bytes_resolved(codegen, t.element_type);
            if esz > 0 && t.array_size <= 0x7FFFFFFF / esz {
                return esz * t.array_size;
            }
        }
        return -1;
    }
    if k == TypeKind.TYPE_SLICE { return 16; }
    if k == TypeKind.TYPE_TUPLE && t.tuple_count > 0 && t.tuple_element_types != null {
        var total: i32 = 0;
        var ti: i32 = 0;
        while ti < t.tuple_count {
            const et: &Type = &t.tuple_element_types[ti];
            if et != null {
                const es: i32 = get_type_size_bytes_resolved(codegen, et);
                if es <= 0 { return -1; }
                total = total + es;
            }
            ti = ti + 1;
        }
        return total;
    }
    if k == TypeKind.TYPE_ERROR_UNION {
        if t.error_union_payload_type != null {
            const ps: i32 = get_type_size_bytes_resolved(codegen, t.error_union_payload_type);
            if ps > 0 {
                if ps >= 4 { return ps; } else { return 4; }
            }
        }
        return 4;
    }
    if k == TypeKind.TYPE_STRUCT || k == TypeKind.TYPE_UNION ||
        k == TypeKind.TYPE_ERROR_UNION || k == TypeKind.TYPE_INTERFACE {
        if t.struct_name == null {
            return -1;
        }
        const decl: &ASTNode = find_struct_decl_c99(codegen, t.struct_name);
        if decl != null && decl.type == ASTNodeType.AST_STRUCT_DECL {
            var sz: i32 = 0;
            if decl.struct_decl_fields != null {
                var fi: i32 = 0;
                while fi < decl.struct_decl_field_count {
                    const field: &ASTNode = decl.struct_decl_fields[fi];
                    if field != null && field.type == ASTNodeType.AST_VAR_DECL {
                        const ft: Type = type_from_ast(codegen.checker, field.var_decl_type);
                        const fsz: i32 = get_type_size_bytes_resolved(codegen, &ft);
                        if fsz <= 0 { return -1; }
                        sz = sz + fsz;
                    }
                    fi = fi + 1;
                }
            }
            return sz;
        }
        return -1;
    }
    return -1;
}

// 从 AST 类型节点计算字节大小（用于状态机估算）：先经 type_from_ast 再按 Type 递归
fn get_type_node_size_bytes(codegen: &C99CodeGenerator, type_ast: &ASTNode) i32 {
    if type_ast == null || codegen == null || codegen.checker == null {
        return -1;
    }
    const resolved: Type = type_from_ast(codegen.checker, type_ast);
    return get_type_size_bytes_resolved(codegen, &resolved);
}

// 从已解析的 Type 计算字节对齐（用于 async frame 估算）
fn get_type_align_bytes_resolved(codegen: &C99CodeGenerator, t: &Type) i32 {
    if t == null || codegen == null || codegen.checker == null {
        return -1;
    }
    const k: TypeKind = t.kind;
    if k == TypeKind.TYPE_I8 || k == TypeKind.TYPE_BOOL || k == TypeKind.TYPE_BYTE { return 1; }
    if k == TypeKind.TYPE_I16 || k == TypeKind.TYPE_U16 { return 2; }
    if k == TypeKind.TYPE_I32 || k == TypeKind.TYPE_U32 || k == TypeKind.TYPE_F32 { return 4; }
    if k == TypeKind.TYPE_I64 || k == TypeKind.TYPE_U64 || k == TypeKind.TYPE_F64 || k == TypeKind.TYPE_USIZE { return 8; }
    if k == TypeKind.TYPE_POINTER { return 8; }
    if k == TypeKind.TYPE_ATOMIC && t.atomic_inner_type != null {
        return get_type_align_bytes_resolved(codegen, t.atomic_inner_type);
    }
    if k == TypeKind.TYPE_ARRAY && t.element_type != null {
        return get_type_align_bytes_resolved(codegen, t.element_type);
    }
    if k == TypeKind.TYPE_SLICE { return 8; }
    if k == TypeKind.TYPE_TUPLE && t.tuple_count > 0 && t.tuple_element_types != null {
        var max_align: i32 = 1;
        var ti: i32 = 0;
        while ti < t.tuple_count {
            const et: &Type = &t.tuple_element_types[ti];
            if et != null {
                const ea: i32 = get_type_align_bytes_resolved(codegen, et);
                if ea > max_align { max_align = ea; }
            }
            ti = ti + 1;
        }
        return max_align;
    }
    if k == TypeKind.TYPE_ERROR_UNION {
        if t.error_union_payload_type != null {
            const pa: i32 = get_type_align_bytes_resolved(codegen, t.error_union_payload_type);
            if pa > 4 { return pa; } else { return 4; }
        }
        return 4;
    }
    if k == TypeKind.TYPE_STRUCT || k == TypeKind.TYPE_UNION || k == TypeKind.TYPE_INTERFACE {
        return 8;
    }
    return -1;
}

// 从 AST 类型节点计算字节对齐（用于状态机估算）
fn get_type_node_align_bytes(codegen: &C99CodeGenerator, type_ast: &ASTNode) i32 {
    if type_ast == null || codegen == null || codegen.checker == null {
        return -1;
    }
    const resolved: Type = type_from_ast(codegen.checker, type_ast);
    return get_type_align_bytes_resolved(codegen, &resolved);
}

// 递归收集 await 点（进入 while/if/for/block 内部），使用 codegen.async_collect_* 存储结果
// enclosing_while：当前语句所在最内层 while 结点（用于 while+单 await 状态机）
// enclosing_for：当前语句所在最内层 for 结点（for 内 await 回跳；内层 while 优先用 enclosing_while）
fn collect_awaits_recursive(node: &ASTNode, codegen: &C99CodeGenerator, max_count: i32, parent_block: &ASTNode, parent_stmt_index: i32, enclosing_while: &ASTNode, enclosing_for: &ASTNode) void {
    if node == null || codegen.async_collect_count >= max_count {
        return;
    }
    if node.type == ASTNodeType.AST_BLOCK && node.block_stmts != null {
        var i: i32 = 0;
        while i < node.block_stmt_count && codegen.async_collect_count < max_count {
            collect_awaits_recursive(node.block_stmts[i], codegen, max_count, node, i, enclosing_while, enclosing_for);
            i = i + 1;
        }
    } else if node.type == ASTNodeType.AST_WHILE_STMT && node.while_stmt_body != null {
        codegen.async_collect_has_loop = 1;
        collect_awaits_recursive(node.while_stmt_body, codegen, max_count, null, -1, node, enclosing_for);
    } else if node.type == ASTNodeType.AST_IF_STMT {
        if node.if_stmt_then_branch != null {
            collect_awaits_recursive(node.if_stmt_then_branch, codegen, max_count, null, -1, enclosing_while, enclosing_for);
        }
        if node.if_stmt_else_branch != null {
            collect_awaits_recursive(node.if_stmt_else_branch, codegen, max_count, null, -1, enclosing_while, enclosing_for);
        }
    } else if node.type == ASTNodeType.AST_FOR_STMT && node.for_stmt_body != null {
        codegen.async_collect_has_loop = 1;
        collect_awaits_recursive(node.for_stmt_body, codegen, max_count, null, -1, enclosing_while, node);
    } else if node.type == ASTNodeType.AST_VAR_DECL && node.var_decl_init != null {
        const init: &ASTNode = node.var_decl_init;
        if init.type == ASTNodeType.AST_TRY_EXPR && init.try_expr_operand != null {
            const op: &ASTNode = init.try_expr_operand;
            if op.type == ASTNodeType.AST_AWAIT_EXPR && op.await_expr_operand != null &&
                codegen.async_collect_count < max_count && codegen.async_collect_count < C99_ASYNC_MAX_AWAITS {
                const collect_idx: i32 = codegen.async_collect_count;
                if collect_idx >= 0 && collect_idx < @len(codegen.async_collect_operands) {
                    codegen.async_collect_operands[collect_idx] = op.await_expr_operand;
                    codegen.async_collect_names[collect_idx] = node.var_decl_name;
                    codegen.async_collect_types[collect_idx] = node.var_decl_type;
                    codegen.async_collect_blocks[collect_idx] = parent_block;
                    codegen.async_collect_stmt_indices[collect_idx] = parent_stmt_index;
                    codegen.async_collect_enclosing_while[collect_idx] = enclosing_while;
                    codegen.async_collect_enclosing_for[collect_idx] = enclosing_for;
                    codegen.async_collect_count = collect_idx + 1;
                    return;
                }
            }
        }
    } else if node.type == ASTNodeType.AST_RETURN_STMT {
        // Bug C fix: 检查 return try @await inner(...) 模式
        const ret_expr: &ASTNode = node.return_stmt_expr;
        if ret_expr != null && ret_expr.type == ASTNodeType.AST_TRY_EXPR && ret_expr.try_expr_operand != null {
            const ret_op: &ASTNode = ret_expr.try_expr_operand;
            if ret_op.type == ASTNodeType.AST_AWAIT_EXPR && ret_op.await_expr_operand != null &&
                codegen.async_collect_count < max_count && codegen.async_collect_count < C99_ASYNC_MAX_AWAITS {
                // 收集为 await 点，bind_name = null 表示 "return await"
                const collect_idx2: i32 = codegen.async_collect_count;
                if collect_idx2 >= 0 && collect_idx2 < @len(codegen.async_collect_operands) {
                    codegen.async_collect_operands[collect_idx2] = ret_op.await_expr_operand;
                    codegen.async_collect_names[collect_idx2] = null;
                    codegen.async_collect_types[collect_idx2] = null;
                    codegen.async_collect_blocks[collect_idx2] = parent_block;
                    codegen.async_collect_stmt_indices[collect_idx2] = parent_stmt_index;
                    codegen.async_collect_enclosing_while[collect_idx2] = enclosing_while;
                    codegen.async_collect_enclosing_for[collect_idx2] = enclosing_for;
                    codegen.async_collect_count = collect_idx2 + 1;
                    // ret_expr 设为 null，表示返回值由最后一个 await 的 Ready 值提供
                    codegen.async_collect_ret_expr = null;
                    return;
                }
            }
        }
        codegen.async_collect_ret_expr = ret_expr;
    }

    // 复合表达式里的 try @await：把整个语句/表达式当成 await 点收集，并在 resume 时重放该语句。
    if node.type != ASTNodeType.AST_BLOCK && node.type != ASTNodeType.AST_IF_STMT &&
        node.type != ASTNodeType.AST_WHILE_STMT && node.type != ASTNodeType.AST_FOR_STMT &&
        codegen.async_collect_count < max_count && codegen.async_collect_count < C99_ASYNC_MAX_AWAITS {
        var nested_try: [&ASTNode: 1] = [null];
        if c99_find_first_try_await_expr(node, &nested_try[0]) != 0 && nested_try[0] != null &&
            nested_try[0].try_expr_operand != null && nested_try[0].try_expr_operand.type == ASTNodeType.AST_AWAIT_EXPR &&
            nested_try[0].try_expr_operand.await_expr_operand != null {
            const idx2: i32 = codegen.async_collect_count;
            if idx2 < 0 {
                return;
            }
            if idx2 >= C99_ASYNC_MAX_AWAITS {
                return;
            }
            var name_buf: [byte: 64] = [];
            snprintf(&name_buf[0] as *byte, 64, "__uya_expr_tmp_%d" as *byte, idx2);
            const bind_name2: &byte = c99_arena_strdup(codegen.arena, &name_buf[0] as &byte);
            if bind_name2 == null {
                return;
            }
            var bind_type2: &ASTNode = null;
            if nested_try[0].try_expr_operand != null &&
                nested_try[0].try_expr_operand.await_expr_operand != null && codegen.current_function_decl != null {
                const future_inner2: &ASTNode = c99_async_operand_future_inner_ast(codegen, nested_try[0].try_expr_operand.await_expr_operand, codegen.current_function_decl);
                if future_inner2 != null {
                    if future_inner2.type == ASTNodeType.AST_TYPE_ERROR_UNION && future_inner2.type_error_union_payload_type != null {
                        bind_type2 = future_inner2.type_error_union_payload_type;
                    } else {
                        bind_type2 = future_inner2;
                    }
                }
            }
            if bind_type2 == null && node.type == ASTNodeType.AST_ASSIGN && node.assign_dest != null && codegen.checker != null {
                const dest_ty: Type = checker_infer_type(codegen.checker, node.assign_dest);
                if dest_ty.kind != TypeKind.TYPE_VOID {
                    bind_type2 = type_to_ast(codegen.checker, &dest_ty, node.line, node.column, node.filename);
                }
            }
            if bind_type2 == null && node.type == ASTNodeType.AST_VAR_DECL {
                bind_type2 = node.var_decl_type;
            }
            codegen.async_collect_operands[idx2] = nested_try[0].try_expr_operand.await_expr_operand;
            codegen.async_collect_names[idx2] = bind_name2;
            codegen.async_collect_types[idx2] = bind_type2;
            codegen.async_collect_blocks[idx2] = parent_block;
            codegen.async_collect_stmt_indices[idx2] = parent_stmt_index;
            codegen.async_collect_enclosing_while[idx2] = enclosing_while;
            codegen.async_collect_enclosing_for[idx2] = enclosing_for;
            codegen.async_collect_count = idx2 + 1;
            return;
        }
    }
}

// try @await 形式的 var 声明由 async_collect_* 单独捕获，此处跳过
fn c99_var_decl_init_is_try_await_bind(init: &ASTNode) i32 {
    if init == null {
        return 0;
    }
    if init.type != ASTNodeType.AST_TRY_EXPR {
        return 0;
    }
    if init.try_expr_operand == null {
        return 0;
    }
    if init.try_expr_operand.type != ASTNodeType.AST_AWAIT_EXPR {
        return 0;
    }
    return 1;
}

fn c99_return_stmt_is_try_await_bind(stmt: &ASTNode) i32 {
    if stmt == null || stmt.type != ASTNodeType.AST_RETURN_STMT || stmt.return_stmt_expr == null {
        return 0;
    }
    if stmt.return_stmt_expr.type != ASTNodeType.AST_TRY_EXPR || stmt.return_stmt_expr.try_expr_operand == null {
        return 0;
    }
    if stmt.return_stmt_expr.try_expr_operand.type != ASTNodeType.AST_AWAIT_EXPR ||
        stmt.return_stmt_expr.try_expr_operand.await_expr_operand == null {
        return 0;
    }
    return 1;
}

// 在任意语句/表达式子树中查找第一个 `try @await ...` 节点。
// 用于把复合表达式里的 await 提前提取成状态机 await 点，并在 continuation 重放时做替换。
fn c99_find_first_try_await_expr(node: &ASTNode, out_try_expr: &&ASTNode) i32 {
    if node == null || out_try_expr == null {
        return 0;
    }
    if node.type == ASTNodeType.AST_TRY_EXPR && node.try_expr_operand != null {
        if node.try_expr_operand.type == ASTNodeType.AST_AWAIT_EXPR && node.try_expr_operand.await_expr_operand != null {
            out_try_expr[0] = node;
            return 1;
        }
        if c99_find_first_try_await_expr(node.try_expr_operand, out_try_expr) != 0 {
            return 1;
        }
        return 0;
    }
    if node.type == ASTNodeType.AST_BLOCK && node.block_stmts != null {
        var bi: i32 = 0;
        while bi < node.block_stmt_count {
            if c99_find_first_try_await_expr(node.block_stmts[bi], out_try_expr) != 0 {
                return 1;
            }
            bi = bi + 1;
        }
        return 0;
    }
    if node.type == ASTNodeType.AST_VAR_DECL {
        return c99_find_first_try_await_expr(node.var_decl_init, out_try_expr);
    }
    if node.type == ASTNodeType.AST_RETURN_STMT {
        return c99_find_first_try_await_expr(node.return_stmt_expr, out_try_expr);
    }
    if node.type == ASTNodeType.AST_ASSIGN {
        if c99_find_first_try_await_expr(node.assign_dest, out_try_expr) != 0 {
            return 1;
        }
        return c99_find_first_try_await_expr(node.assign_src, out_try_expr);
    }
    if node.type == ASTNodeType.AST_IF_STMT {
        if c99_find_first_try_await_expr(node.if_stmt_condition, out_try_expr) != 0 {
            return 1;
        }
        if c99_find_first_try_await_expr(node.if_stmt_then_branch, out_try_expr) != 0 {
            return 1;
        }
        return c99_find_first_try_await_expr(node.if_stmt_else_branch, out_try_expr);
    }
    if node.type == ASTNodeType.AST_WHILE_STMT {
        if c99_find_first_try_await_expr(node.while_stmt_condition, out_try_expr) != 0 {
            return 1;
        }
        return c99_find_first_try_await_expr(node.while_stmt_body, out_try_expr);
    }
    if node.type == ASTNodeType.AST_FOR_STMT {
        if c99_find_first_try_await_expr(node.for_stmt_range_start, out_try_expr) != 0 {
            return 1;
        }
        if c99_find_first_try_await_expr(node.for_stmt_range_end, out_try_expr) != 0 {
            return 1;
        }
        if c99_find_first_try_await_expr(node.for_stmt_array, out_try_expr) != 0 {
            return 1;
        }
        return c99_find_first_try_await_expr(node.for_stmt_body, out_try_expr);
    }
    if node.type == ASTNodeType.AST_CALL_EXPR {
        if c99_find_first_try_await_expr(node.call_expr_callee, out_try_expr) != 0 {
            return 1;
        }
        if node.call_expr_args != null {
            var ai: i32 = 0;
            while ai < node.call_expr_arg_count {
                if c99_find_first_try_await_expr(node.call_expr_args[ai], out_try_expr) != 0 {
                    return 1;
                }
                ai = ai + 1;
            }
        }
        return 0;
    }
    if node.type == ASTNodeType.AST_MEMBER_ACCESS {
        return c99_find_first_try_await_expr(node.member_access_object, out_try_expr);
    }
    if node.type == ASTNodeType.AST_ARRAY_ACCESS {
        if c99_find_first_try_await_expr(node.array_access_array, out_try_expr) != 0 {
            return 1;
        }
        return c99_find_first_try_await_expr(node.array_access_index, out_try_expr);
    }
    if node.type == ASTNodeType.AST_SLICE_EXPR {
        if c99_find_first_try_await_expr(node.slice_expr_base, out_try_expr) != 0 {
            return 1;
        }
        if c99_find_first_try_await_expr(node.slice_expr_start_expr, out_try_expr) != 0 {
            return 1;
        }
        return c99_find_first_try_await_expr(node.slice_expr_len_expr, out_try_expr);
    }
    if node.type == ASTNodeType.AST_BINARY_EXPR {
        if c99_find_first_try_await_expr(node.binary_expr_left, out_try_expr) != 0 {
            return 1;
        }
        return c99_find_first_try_await_expr(node.binary_expr_right, out_try_expr);
    }
    if node.type == ASTNodeType.AST_UNARY_EXPR {
        return c99_find_first_try_await_expr(node.unary_expr_operand, out_try_expr);
    }
    if node.type == ASTNodeType.AST_CAST_EXPR {
        return c99_find_first_try_await_expr(node.cast_expr_expr, out_try_expr);
    }
    if node.type == ASTNodeType.AST_CATCH_EXPR {
        if c99_find_first_try_await_expr(node.catch_expr_operand, out_try_expr) != 0 {
            return 1;
        }
        return c99_find_first_try_await_expr(node.catch_expr_catch_block, out_try_expr);
    }
    if node.type == ASTNodeType.AST_MATCH_EXPR && node.match_expr_arms != null {
        if c99_find_first_try_await_expr(node.match_expr_expr, out_try_expr) != 0 {
            return 1;
        }
        var mi: i32 = 0;
        while mi < node.match_expr_arm_count {
            if c99_find_first_try_await_expr(node.match_expr_arms[mi].result_expr, out_try_expr) != 0 {
                return 1;
            }
            mi = mi + 1;
        }
        return 0;
    }
    if node.type == ASTNodeType.AST_STRUCT_INIT && node.struct_init_field_values != null {
        var fi: i32 = 0;
        while fi < node.struct_init_field_count {
            if c99_find_first_try_await_expr(node.struct_init_field_values[fi], out_try_expr) != 0 {
                return 1;
            }
            fi = fi + 1;
        }
        return 0;
    }
    if node.type == ASTNodeType.AST_ARRAY_LITERAL && node.array_literal_elements != null {
        var ei: i32 = 0;
        while ei < node.array_literal_element_count {
            if c99_find_first_try_await_expr(node.array_literal_elements[ei], out_try_expr) != 0 {
                return 1;
            }
            ei = ei + 1;
        }
        return 0;
    }
    if node.type == ASTNodeType.AST_TUPLE_LITERAL && node.tuple_literal_elements != null {
        var ti: i32 = 0;
        while ti < node.tuple_literal_element_count {
            if c99_find_first_try_await_expr(node.tuple_literal_elements[ti], out_try_expr) != 0 {
                return 1;
            }
            ti = ti + 1;
        }
        return 0;
    }
    if node.type == ASTNodeType.AST_PRINT || node.type == ASTNodeType.AST_PRINTLN {
        return c99_find_first_try_await_expr(node.print_expr, out_try_expr);
    }
    if node.type == ASTNodeType.AST_SYSCALL {
        if c99_find_first_try_await_expr(node.syscall_number, out_try_expr) != 0 {
            return 1;
        }
        if node.syscall_args != null {
            var si2: i32 = 0;
            while si2 < node.syscall_arg_count {
                if c99_find_first_try_await_expr(node.syscall_args[si2], out_try_expr) != 0 {
                    return 1;
                }
                si2 = si2 + 1;
            }
        }
        return 0;
    }
    if node.type == ASTNodeType.AST_STRING_INTERP && node.string_interp_segments != null {
        var si3: i32 = 0;
        while si3 < node.string_interp_segment_count {
            const seg: &ASTStringInterpSegment = &node.string_interp_segments[si3];
            if seg != null && seg.is_text == 0 && seg.expr != null &&
                c99_find_first_try_await_expr(seg.expr, out_try_expr) != 0 {
                return 1;
            }
            si3 = si3 + 1;
        }
        return 0;
    }
    if node.type == ASTNodeType.AST_SIZEOF {
        return c99_find_first_try_await_expr(node.sizeof_expr_target, out_try_expr);
    }
    if node.type == ASTNodeType.AST_LEN {
        return c99_find_first_try_await_expr(node.len_expr_array, out_try_expr);
    }
    if node.type == ASTNodeType.AST_ALIGNOF {
        return c99_find_first_try_await_expr(node.alignof_expr_target, out_try_expr);
    }
    if node.type == ASTNodeType.AST_PTR_FROM_USIZE {
        return c99_find_first_try_await_expr(node.ptr_from_usize_value, out_try_expr);
    }
    if node.type == ASTNodeType.AST_USIZE_FROM_PTR {
        return c99_find_first_try_await_expr(node.usize_from_ptr_ptr, out_try_expr);
    }
    if node.type == ASTNodeType.AST_ERROR_ID {
        return c99_find_first_try_await_expr(node.error_id_operand, out_try_expr);
    }
    if node.type == ASTNodeType.AST_VA_START {
        if c99_find_first_try_await_expr(node.va_start_ap, out_try_expr) != 0 {
            return 1;
        }
        return c99_find_first_try_await_expr(node.va_start_last_param, out_try_expr);
    }
    if node.type == ASTNodeType.AST_VA_END {
        return c99_find_first_try_await_expr(node.va_end_ap, out_try_expr);
    }
    if node.type == ASTNodeType.AST_VA_ARG {
        if c99_find_first_try_await_expr(node.va_arg_ap, out_try_expr) != 0 {
            return 1;
        }
        return c99_find_first_try_await_expr(node.va_arg_arg_type, out_try_expr);
    }
    if node.type == ASTNodeType.AST_VA_COPY {
        if c99_find_first_try_await_expr(node.va_copy_dest, out_try_expr) != 0 {
            return 1;
        }
        return c99_find_first_try_await_expr(node.va_copy_src, out_try_expr);
    }
    return 0;
}

// return 语句里是否包含嵌套的 try @await（例如 return 1 + (try @await foo())）
fn c99_return_stmt_has_nested_try_await(stmt: &ASTNode) i32 {
    if stmt == null || stmt.type != ASTNodeType.AST_RETURN_STMT || stmt.return_stmt_expr == null {
        return 0;
    }
    var nested_try: [&ASTNode: 1] = [null];
    if c99_find_first_try_await_expr(stmt.return_stmt_expr, &nested_try[0]) != 0 &&
        nested_try[0] != null && nested_try[0].try_expr_operand != null &&
        nested_try[0].try_expr_operand.type == ASTNodeType.AST_AWAIT_EXPR &&
        nested_try[0].try_expr_operand.await_expr_operand != null {
        return 1;
    }
    return 0;
}


fn c99_emit_async_arm_await_index(
    codegen: &C99CodeGenerator,
    j: i32,
    await_operands: [&ASTNode: C99_ASYNC_MAX_AWAITS],
    await_bind_types: [&ASTNode: C99_ASYNC_MAX_AWAITS],
    fn_decl: &ASTNode,
    await_operand_is_err_future: i32,
    full_return_type: &ASTNode,
    concrete_future_safe: &byte,
    state_slot_iface_c: &byte
) void {
    if j < 0 {
        return;
    }
    if j >= C99_ASYNC_MAX_AWAITS {
        return;
    }
    // caller-owned stack 内联：直接初始化 child frame 字段，不调用 wrapper
    var inline_struct_name: &byte = null;
    if c99_async_await_operand_is_inlineable(codegen, await_operands[j], &inline_struct_name) != 0 && inline_struct_name != null {
        fprintf(codegen.emit_stream as *void, "        s->_uya_inline_await_%d._uya_frame_active = 1; s->_uya_inline_await_%d.state = 0; __builtin_memset((void *)&s->_uya_inline_await_%d.await_fut, 0, sizeof(s->_uya_inline_await_%d.await_fut)); " as *byte, j, j, j, j);
        const operand: &ASTNode = await_operands[j];
        if operand != null && operand.type == ASTNodeType.AST_CALL_EXPR && operand.call_expr_args != null {
            const callee: &ASTNode = operand.call_expr_callee;
            const fd: &ASTNode = find_function_decl_c99(codegen, callee.identifier_name);
            if fd != null && fd.fn_decl_params != null {
                var arg_i: i32 = 0;
                const arg_count: i32 = operand.call_expr_arg_count;
                const param_count2: i32 = fd.fn_decl_param_count;
                while arg_i < arg_count && arg_i < param_count2 && arg_i < 16 {
                    const param: &ASTNode = fd.fn_decl_params[arg_i];
                    const arg: &ASTNode = operand.call_expr_args[arg_i];
                    if param != null && param.type == ASTNodeType.AST_VAR_DECL && param.var_decl_name != null && arg != null {
                        const psafe: &byte = get_safe_c_identifier(codegen, param.var_decl_name);
                        if psafe != null {
                            fprintf(codegen.emit_stream as *void, "s->_uya_inline_await_%d.%s = " as *byte, j, psafe);
                            gen_expr(codegen, arg);
                            fputs("; " as *byte, codegen.emit_stream as *void);
                        }
                    }
                    arg_i = arg_i + 1;
                }
            }
        }
        fputs("\n" as *byte, codegen.emit_stream as *void);
        return;
    }
    var next_await_is_err_future: i32 = await_operand_is_err_future;
    if next_await_is_err_future == 0 && await_bind_types[j] != null && await_bind_types[j].type == ASTNodeType.AST_TYPE_NAMED &&
        await_bind_types[j].type_named_name != null &&
        strcmp(await_bind_types[j].type_named_name as *byte, "Future" as *byte) == 0 {
        next_await_is_err_future = 1;
    }
    if next_await_is_err_future != 0 && full_return_type != null && full_return_type.type == ASTNodeType.AST_TYPE_ERROR_UNION {
        const operand_union_c2: &byte = c99_type_to_c(codegen, full_return_type);
        if operand_union_c2 != null {
            fprintf(codegen.emit_stream as *void, "        ({ %s _uya_await_tmp = " as *byte, operand_union_c2 as *byte);
            gen_expr(codegen, await_operands[j]);
            if concrete_future_safe != null && state_slot_iface_c != null {
                fprintf(codegen.emit_stream as *void, "; if (_uya_await_tmp.error_id != 0) abort(); s->_uya_await_storage = *(struct %s *)_uya_await_tmp.value.data; s->await_fut.vtable = (void*)_uya_await_tmp.value.vtable; s->await_fut.data = (void*)&s->_uya_await_storage; });\n" as *byte, concrete_future_safe as *byte);
            } else {
                fprintf(codegen.emit_stream as *void, "; if (_uya_await_tmp.error_id != 0) abort(); s->await_fut.vtable = (void*)_uya_await_tmp.value.vtable; s->await_fut.data = _uya_await_tmp.value.data; });\n" as *byte);
            }
        } else {
            c99_emit_await_fut_assign_from_expr(codegen, await_operands[j], fn_decl);
        }
    } else {
        c99_emit_await_fut_assign_from_expr(codegen, await_operands[j], fn_decl);
    }
}


/// 从 @await 操作数表达式推断「子 Future」的单类型实参 T（即 `Future<T>` / `!Future<T>` 中的 T），并转为 AST，供 Poll<T>/vtable 单态化。
/// 说明：多段 await 时每段子 Future 的 T 可能不同（如 `!usize` vs `!Http1AsyncResponse`），不能统一用函数返回的 inner。
fn c99_async_operand_future_inner_ast(codegen: &C99CodeGenerator, operand: &ASTNode, fn_decl: &ASTNode) &ASTNode {
    if operand == null || codegen == null || codegen.checker == null || fn_decl == null {
        return null;
    }
    if operand.type == ASTNodeType.AST_IDENTIFIER && operand.identifier_name != null {
        const id_type_node: &ASTNode = c99_find_identifier_type_node(codegen, operand.identifier_name);
        if id_type_node != null {
            const inner_id: &ASTNode = c99_async_future_inner_ast_from_return_type(codegen, id_type_node, fn_decl);
            if inner_id != null {
                return inner_id;
            }
        }
    }
    if operand.type == ASTNodeType.AST_CALL_EXPR && operand.call_expr_callee != null {
        const cal: &ASTNode = operand.call_expr_callee;
        if cal.type == ASTNodeType.AST_IDENTIFIER && cal.identifier_name != null {
            const fd_ret: &ASTNode = find_function_decl_c99(codegen, cal.identifier_name);
            if fd_ret != null && fd_ret.fn_decl_return_type != null {
                const inner_decl: &ASTNode = c99_async_future_inner_ast_from_return_type(codegen, fd_ret.fn_decl_return_type, fn_decl);
                if inner_decl != null {
                    return inner_decl;
                }
            }
        }
    }
    var ot: Type = checker_infer_type(codegen.checker, operand);
    if ot.kind == TypeKind.TYPE_ERROR_UNION && ot.error_union_payload_type != null {
        const pl: Type = ot.error_union_payload_type[0];
        if pl.kind == TypeKind.TYPE_INTERFACE && pl.interface_name != null &&
            (str_equals(pl.interface_name, "Future" as *byte) != 0 ||
             (strlen(pl.interface_name as *byte) >= 6 && strncmp(pl.interface_name as *byte, "Future" as *byte, 6) == 0)) {
            if pl.interface_type_arg_count >= 1 && pl.interface_type_args != null {
                var inner_u: Type = pl.interface_type_args[0];
                return type_to_ast(codegen.checker, &inner_u, fn_decl.line, fn_decl.column, fn_decl.filename);
            }
        }
        if pl.kind == TypeKind.TYPE_STRUCT && pl.struct_name != null &&
            (str_equals(pl.struct_name, "Future" as *byte) != 0 ||
             (strlen(pl.struct_name as *byte) >= 6 && strncmp(pl.struct_name as *byte, "Future" as *byte, 6) == 0)) {
            if pl.struct_type_arg_count >= 1 && pl.struct_type_args != null {
                var inner_s: Type = pl.struct_type_args[0];
                return type_to_ast(codegen.checker, &inner_s, fn_decl.line, fn_decl.column, fn_decl.filename);
            }
        }
    }
    if ot.kind == TypeKind.TYPE_INTERFACE && ot.interface_name != null &&
        (str_equals(ot.interface_name, "Future" as *byte) != 0 ||
         (strlen(ot.interface_name as *byte) >= 6 && strncmp(ot.interface_name as *byte, "Future" as *byte, 6) == 0)) {
        if ot.interface_type_arg_count >= 1 && ot.interface_type_args != null {
            var inner_f: Type = ot.interface_type_args[0];
            return type_to_ast(codegen.checker, &inner_f, fn_decl.line, fn_decl.column, fn_decl.filename);
        }
    }
    if ot.kind == TypeKind.TYPE_STRUCT && ot.struct_name != null &&
        (str_equals(ot.struct_name, "Future" as *byte) != 0 ||
         (strlen(ot.struct_name as *byte) >= 6 && strncmp(ot.struct_name as *byte, "Future" as *byte, 6) == 0)) {
        if ot.struct_type_arg_count >= 1 && ot.struct_type_args != null {
            var inner_g: Type = ot.struct_type_args[0];
            return type_to_ast(codegen.checker, &inner_g, fn_decl.line, fn_decl.column, fn_decl.filename);
        }
    }
    if operand.type == ASTNodeType.AST_CALL_EXPR && operand.call_expr_callee != null {
        const cal: &ASTNode = operand.call_expr_callee;
        if cal.type == ASTNodeType.AST_IDENTIFIER && cal.identifier_name != null {
            const fd_ret: &ASTNode = find_function_decl_c99(codegen, cal.identifier_name);
            if fd_ret != null && fd_ret.fn_decl_return_type != null {
                const inner_decl: &ASTNode = c99_async_future_inner_ast_from_return_type(codegen, fd_ret.fn_decl_return_type, fn_decl);
                if inner_decl != null {
                    return inner_decl;
                }
            }
        }
        if cal.type == ASTNodeType.AST_MEMBER_ACCESS && cal.member_access_object != null && cal.member_access_field_name != null {
            const ot_obj: Type = checker_infer_type(codegen.checker, cal.member_access_object);
            var mfn: &ASTNode = null;
            if ot_obj.kind == TypeKind.TYPE_STRUCT && ot_obj.struct_name != null {
                mfn = find_method_in_struct_c99(codegen, ot_obj.struct_name, cal.member_access_field_name);
            } else if ot_obj.kind == TypeKind.TYPE_POINTER && ot_obj.pointer_to != null {
                const pt: Type = ot_obj.pointer_to[0];
                if pt.kind == TypeKind.TYPE_STRUCT && pt.struct_name != null {
                    mfn = find_method_in_struct_c99(codegen, pt.struct_name, cal.member_access_field_name);
                } else if pt.kind == TypeKind.TYPE_INTERFACE && pt.interface_name != null {
                    mfn = c99_find_interface_method_sig(codegen, pt.interface_name, cal.member_access_field_name);
                }
            } else if ot_obj.kind == TypeKind.TYPE_INTERFACE && ot_obj.interface_name != null {
                mfn = c99_find_interface_method_sig(codegen, ot_obj.interface_name, cal.member_access_field_name);
            }
            if mfn != null && mfn.fn_decl_return_type != null {
                const inner_decl2: &ASTNode = c99_async_future_inner_ast_from_return_type(codegen, mfn.fn_decl_return_type, fn_decl);
                if inner_decl2 != null {
                    return inner_decl2;
                }
            }
            if (mfn == null || mfn.fn_decl_return_type == null) && cal.member_access_object != null {
                const obj_c_fb: &byte = get_c_type_of_expr(codegen, cal.member_access_object);
                if obj_c_fb != null {
                    const sdecl_fb: &ASTNode = find_struct_decl_from_type_c(codegen, obj_c_fb);
                    if sdecl_fb != null && sdecl_fb.struct_decl_name != null {
                        const mfn3: &ASTNode = find_method_in_struct_c99(codegen, sdecl_fb.struct_decl_name, cal.member_access_field_name);
                        if mfn3 != null && mfn3.fn_decl_return_type != null {
                            const inner_decl3: &ASTNode = c99_async_future_inner_ast_from_return_type(codegen, mfn3.fn_decl_return_type, fn_decl);
                            if inner_decl3 != null {
                                return inner_decl3;
                            }
                        }
                    }
                }
            }
        }
    }
    return null;
}

// 从 `try @await expr` 推导 `@await expr` 的结果类型 AST（用于 try 的临时错误联合类型）。
// 这样 codegen 不必把整个 try 表达式重新交回 checker，避免重复打印语义错误。
fn c99_async_await_result_ast(codegen: &C99CodeGenerator, await_expr: &ASTNode, fn_decl: &ASTNode) &ASTNode {
    if codegen == null || codegen.checker == null || await_expr == null || fn_decl == null {
        return null;
    }
    if await_expr.type != ASTNodeType.AST_AWAIT_EXPR || await_expr.await_expr_operand == null {
        return null;
    }
    const op: &ASTNode = await_expr.await_expr_operand;
    if op.type == ASTNodeType.AST_CALL_EXPR && op.call_expr_callee != null {
        const cal: &ASTNode = op.call_expr_callee;
        if cal.type == ASTNodeType.AST_IDENTIFIER && cal.identifier_name != null {
            const fd_ret: &ASTNode = find_function_decl_c99(codegen, cal.identifier_name);
            if fd_ret != null && fd_ret.fn_decl_return_type != null {
                const inner_call: &ASTNode = c99_async_future_inner_ast_from_return_type(codegen, fd_ret.fn_decl_return_type, fn_decl);
                if inner_call != null {
                    if fd_ret.fn_decl_return_type.type == ASTNodeType.AST_TYPE_ERROR_UNION {
                        const eu_call: &ASTNode = ast_new_node(ASTNodeType.AST_TYPE_ERROR_UNION, await_expr.line, await_expr.column, codegen.arena, await_expr.filename);
                        if eu_call != null {
                            eu_call.type_error_union_payload_type = inner_call;
                            return eu_call;
                        }
                    }
                    return inner_call;
                }
            }
        }
    }
    if op.type == ASTNodeType.AST_IDENTIFIER && op.identifier_name != null {
        const id_type_node: &ASTNode = c99_find_identifier_type_node(codegen, op.identifier_name);
        if id_type_node != null {
            const inner_id: &ASTNode = c99_async_future_inner_ast_from_return_type(codegen, id_type_node, fn_decl);
            if inner_id != null {
                if id_type_node.type == ASTNodeType.AST_TYPE_ERROR_UNION {
                    const eu_id: &ASTNode = ast_new_node(ASTNodeType.AST_TYPE_ERROR_UNION, await_expr.line, await_expr.column, codegen.arena, await_expr.filename);
                    if eu_id != null {
                        eu_id.type_error_union_payload_type = inner_id;
                        return eu_id;
                    }
                }
                return inner_id;
            }
        }
    }
    const inner: &ASTNode = c99_async_operand_future_inner_ast(codegen, await_expr.await_expr_operand, fn_decl);
    if inner == null {
        return null;
    }
    if inner.type == ASTNodeType.AST_TYPE_ERROR_UNION {
        return inner;
    }
    const awaited_type: Type = checker_infer_type(codegen.checker, await_expr.await_expr_operand);
    if awaited_type.kind == TypeKind.TYPE_ERROR_UNION {
        const eu_node: &ASTNode = ast_new_node(ASTNodeType.AST_TYPE_ERROR_UNION, await_expr.line, await_expr.column, codegen.arena, await_expr.filename);
        if eu_node != null {
            eu_node.type_error_union_payload_type = inner;
            return eu_node;
        }
    }
    return inner;
}

// 判断 @await 操作数是否可直接内联为 caller-owned frame
// 条件：直接调用一个 @async_fn 标识符（非成员方法、非变量间接调用）
// 返回 1 并在 out_async_struct_cname 中填充 "uya_async_<cname>"
fn c99_async_await_operand_is_inlineable(codegen: &C99CodeGenerator, operand: &ASTNode, out_async_struct_cname: &&byte) i32 {
    if codegen == null || operand == null || out_async_struct_cname == null {
        return 0;
    }
    if operand.type != ASTNodeType.AST_CALL_EXPR || operand.call_expr_callee == null {
        return 0;
    }
    const callee: &ASTNode = operand.call_expr_callee;
    if callee.type != ASTNodeType.AST_IDENTIFIER || callee.identifier_name == null {
        return 0;
    }
    const fd: &ASTNode = find_function_decl_c99(codegen, callee.identifier_name);
    if fd == null || fd.fn_decl_is_async == 0 {
        return 0;
    }
    var func_c_name: &byte = null;
    if fd.fn_decl_is_export != 0 && fd.filename != null {
        func_c_name = get_export_function_c_name(codegen, callee.identifier_name, fd.filename);
    } else {
        func_c_name = get_safe_c_identifier(codegen, callee.identifier_name);
    }
    if func_c_name == null {
        return 0;
    }
    const prefix: &byte = "uya_async_";
    const total_len: usize = strlen(prefix as *byte) + strlen(func_c_name as *byte) + 1;
    const result: &byte = compiler_arena_alloc(codegen.arena, total_len) as &byte;
    if result == null {
        return 0;
    }
    strcpy(result as *byte, prefix as *byte);
    strcat(result as *byte, func_c_name as *byte);
    out_async_struct_cname[0] = result;
    return 1;
}

fn c99_async_stage_b_effective_return_type(return_type: &ASTNode, out_effective_return_type: &&ASTNode) i32 {
    if out_effective_return_type == null {
        return 0;
    }
    out_effective_return_type[0] = return_type;
    if return_type == null {
        return 0;
    }
    if return_type.type == ASTNodeType.AST_TYPE_NAMED &&
        return_type.type_named_name != null &&
        strcmp(return_type.type_named_name as *byte, "Future" as *byte) == 0 &&
        return_type.type_named_type_arg_count == 1 &&
        return_type.type_named_type_args != null {
        const a0: &ASTNode = return_type.type_named_type_args[0];
        if a0 != null && a0.type == ASTNodeType.AST_TYPE_ERROR_UNION &&
            a0.type_error_union_payload_type != null {
            return 1;
        }
    }
    if return_type.type == ASTNodeType.AST_TYPE_ERROR_UNION &&
        return_type.type_error_union_payload_type != null {
        const pl: &ASTNode = return_type.type_error_union_payload_type;
        if pl.type == ASTNodeType.AST_TYPE_NAMED && pl.type_named_name != null &&
            strcmp(pl.type_named_name as *byte, "Future" as *byte) == 0 &&
            pl.type_named_type_arg_count == 1 && pl.type_named_type_args != null {
            out_effective_return_type[0] = pl;
            return 1;
        }
    }
    return 0;
}

fn c99_async_emit_inline_child_predefs(codegen: &C99CodeGenerator, current_fn_decl: &ASTNode, operand: &ASTNode) void {
    if codegen == null || operand == null {
        return;
    }
    var child_struct_name: &byte = null;
    if c99_async_await_operand_is_inlineable(codegen, operand, &child_struct_name) == 0 || child_struct_name == null {
        return;
    }
    if operand.call_expr_callee == null || operand.call_expr_callee.type != ASTNodeType.AST_IDENTIFIER ||
        operand.call_expr_callee.identifier_name == null {
        return;
    }
    const child_decl: &ASTNode = find_function_decl_c99(codegen, operand.call_expr_callee.identifier_name);
    if child_decl == null || child_decl.fn_decl_is_async == 0 || child_decl.fn_decl_return_type == null {
        return;
    }
    if current_fn_decl != null && @usize_from_ptr(child_decl as &void) == @usize_from_ptr(current_fn_decl as &void) {
        return;
    }
    if is_struct_defined(codegen, child_struct_name) != 0 {
        return;
    }
    var child_func_c_name: &byte = null;
    if child_decl.fn_decl_is_export != 0 && child_decl.filename != null {
        child_func_c_name = get_export_function_c_name(codegen, child_decl.fn_decl_name, child_decl.filename);
    } else {
        child_func_c_name = get_safe_c_identifier(codegen, child_decl.fn_decl_name);
    }
    if child_func_c_name == null {
        return;
    }
    var child_effective_return_type: &ASTNode = child_decl.fn_decl_return_type;
    if c99_async_stage_b_effective_return_type(child_decl.fn_decl_return_type, &child_effective_return_type) == 0 {
        return;
    }

    const saved_collect_count: i32 = codegen.async_collect_count;
    const saved_collect_ret_expr: &ASTNode = codegen.async_collect_ret_expr;
    const saved_collect_has_loop: i32 = codegen.async_collect_has_loop;
    const saved_async_state_size: i32 = codegen.async_state_size;
    const saved_async_local_count: i32 = codegen.async_local_count;
    const saved_async_inline_temp_var_count: i32 = codegen.async_inline_temp_var_count;

    var saved_collect_operands: [&ASTNode: C99_ASYNC_MAX_AWAITS] = [];
    var saved_collect_names: [&byte: C99_ASYNC_MAX_AWAITS] = [];
    var saved_collect_types: [&ASTNode: C99_ASYNC_MAX_AWAITS] = [];
    var saved_collect_blocks: [&ASTNode: C99_ASYNC_MAX_AWAITS] = [];
    var saved_collect_stmt_indices: [i32: C99_ASYNC_MAX_AWAITS] = [];
    var saved_collect_enclosing_while: [&ASTNode: C99_ASYNC_MAX_AWAITS] = [];
    var saved_collect_enclosing_for: [&ASTNode: C99_ASYNC_MAX_AWAITS] = [];
    var saved_async_local_names: [&byte: 32] = [];
    var saved_async_local_types: [&ASTNode: 32] = [];
    var saved_async_local_inits: [&ASTNode: 32] = [];
    var saved_async_inline_temp_var_names: [&byte: 32] = [];

    var save_i: i32 = 0;
    while save_i < C99_ASYNC_MAX_AWAITS {
        saved_collect_operands[save_i] = codegen.async_collect_operands[save_i];
        saved_collect_names[save_i] = codegen.async_collect_names[save_i];
        saved_collect_types[save_i] = codegen.async_collect_types[save_i];
        saved_collect_blocks[save_i] = codegen.async_collect_blocks[save_i];
        saved_collect_stmt_indices[save_i] = codegen.async_collect_stmt_indices[save_i];
        saved_collect_enclosing_while[save_i] = codegen.async_collect_enclosing_while[save_i];
        saved_collect_enclosing_for[save_i] = codegen.async_collect_enclosing_for[save_i];
        save_i = save_i + 1;
    }
    save_i = 0;
    while save_i < 32 {
        saved_async_local_names[save_i] = codegen.async_local_names[save_i];
        saved_async_local_types[save_i] = codegen.async_local_types[save_i];
        saved_async_local_inits[save_i] = codegen.async_local_inits[save_i];
        saved_async_inline_temp_var_names[save_i] = codegen.async_inline_temp_var_names[save_i];
        save_i = save_i + 1;
    }

    gen_async_function_stage_b(codegen, child_decl, child_func_c_name, child_decl.fn_decl_return_type, child_effective_return_type, 1);

    codegen.async_collect_count = saved_collect_count;
    codegen.async_collect_ret_expr = saved_collect_ret_expr;
    codegen.async_collect_has_loop = saved_collect_has_loop;
    codegen.async_state_size = saved_async_state_size;
    codegen.async_local_count = saved_async_local_count;
    codegen.async_inline_temp_var_count = saved_async_inline_temp_var_count;

    save_i = 0;
    while save_i < C99_ASYNC_MAX_AWAITS {
        codegen.async_collect_operands[save_i] = saved_collect_operands[save_i];
        codegen.async_collect_names[save_i] = saved_collect_names[save_i];
        codegen.async_collect_types[save_i] = saved_collect_types[save_i];
        codegen.async_collect_blocks[save_i] = saved_collect_blocks[save_i];
        codegen.async_collect_stmt_indices[save_i] = saved_collect_stmt_indices[save_i];
        codegen.async_collect_enclosing_while[save_i] = saved_collect_enclosing_while[save_i];
        codegen.async_collect_enclosing_for[save_i] = saved_collect_enclosing_for[save_i];
        save_i = save_i + 1;
    }
    save_i = 0;
    while save_i < 32 {
        codegen.async_local_names[save_i] = saved_async_local_names[save_i];
        codegen.async_local_types[save_i] = saved_async_local_types[save_i];
        codegen.async_local_inits[save_i] = saved_async_local_inits[save_i];
        codegen.async_inline_temp_var_names[save_i] = saved_async_inline_temp_var_names[save_i];
        save_i = save_i + 1;
    }
}

// 判断变量名是否在 async inline temp var 列表中
fn c99_var_is_inline_temp(codegen: &C99CodeGenerator, name: &byte) i32 {
    if codegen == null || name == null || codegen.async_inline_temp_var_count <= 0 {
        return 0;
    }
    var i: i32 = 0;
    while i < codegen.async_inline_temp_var_count && i < 32 {
        if codegen.async_inline_temp_var_names[i] != null &&
            strcmp(codegen.async_inline_temp_var_names[i] as *byte, name as *byte) == 0 {
            return 1;
        }
        i = i + 1;
    }
    return 0;
}

// 在函数体中递归查找变量的初始化表达式
fn c99_async_find_var_decl_init(node: &ASTNode, name: &byte) &ASTNode {
    if node == null || name == null {
        return null;
    }
    if node.type == ASTNodeType.AST_VAR_DECL && node.var_decl_name != null &&
        strcmp(node.var_decl_name as *byte, name as *byte) == 0 {
        return node.var_decl_init;
    }
    if node.type == ASTNodeType.AST_BLOCK && node.block_stmts != null {
        var i: i32 = 0;
        while i < node.block_stmt_count {
            const r: &ASTNode = c99_async_find_var_decl_init(node.block_stmts[i], name);
            if r != null {
                return r;
            }
            i = i + 1;
        }
    } else if node.type == ASTNodeType.AST_IF_STMT {
        if node.if_stmt_then_branch != null {
            const r: &ASTNode = c99_async_find_var_decl_init(node.if_stmt_then_branch, name);
            if r != null {
                return r;
            }
        }
        if node.if_stmt_else_branch != null {
            const r: &ASTNode = c99_async_find_var_decl_init(node.if_stmt_else_branch, name);
            if r != null {
                return r;
            }
        }
    } else if node.type == ASTNodeType.AST_WHILE_STMT && node.while_stmt_body != null {
        const r: &ASTNode = c99_async_find_var_decl_init(node.while_stmt_body, name);
        if r != null {
            return r;
        }
    } else if node.type == ASTNodeType.AST_FOR_STMT && node.for_stmt_body != null {
        const r: &ASTNode = c99_async_find_var_decl_init(node.for_stmt_body, name);
        if r != null {
            return r;
        }
    }
    return null;
}

// 递归统计函数体中指定标识符的出现次数（保守逃逸分析）
fn c99_async_count_identifier_uses(node: &ASTNode, name: &byte) i32 {
    if node == null || name == null {
        return 0;
    }
    var count: i32 = 0;
    if node.type == ASTNodeType.AST_IDENTIFIER && node.identifier_name != null &&
        strcmp(node.identifier_name as *byte, name as *byte) == 0 {
        count = count + 1;
    }
    if node.type == ASTNodeType.AST_BLOCK && node.block_stmts != null {
        var i: i32 = 0;
        while i < node.block_stmt_count {
            count = count + c99_async_count_identifier_uses(node.block_stmts[i], name);
            i = i + 1;
        }
    } else if node.type == ASTNodeType.AST_IF_STMT {
        count = count + c99_async_count_identifier_uses(node.if_stmt_condition, name);
        count = count + c99_async_count_identifier_uses(node.if_stmt_then_branch, name);
        count = count + c99_async_count_identifier_uses(node.if_stmt_else_branch, name);
    } else if node.type == ASTNodeType.AST_WHILE_STMT {
        count = count + c99_async_count_identifier_uses(node.while_stmt_condition, name);
        count = count + c99_async_count_identifier_uses(node.while_stmt_body, name);
    } else if node.type == ASTNodeType.AST_FOR_STMT {
        count = count + c99_async_count_identifier_uses(node.for_stmt_array, name);
        count = count + c99_async_count_identifier_uses(node.for_stmt_range_start, name);
        count = count + c99_async_count_identifier_uses(node.for_stmt_range_end, name);
        count = count + c99_async_count_identifier_uses(node.for_stmt_body, name);
    } else if node.type == ASTNodeType.AST_RETURN_STMT {
        count = count + c99_async_count_identifier_uses(node.return_stmt_expr, name);
    } else if node.type == ASTNodeType.AST_VAR_DECL {
        count = count + c99_async_count_identifier_uses(node.var_decl_init, name);
    } else if node.type == ASTNodeType.AST_ASSIGN {
        count = count + c99_async_count_identifier_uses(node.assign_dest, name);
        count = count + c99_async_count_identifier_uses(node.assign_src, name);
    } else if node.type == ASTNodeType.AST_BINARY_EXPR {
        count = count + c99_async_count_identifier_uses(node.binary_expr_left, name);
        count = count + c99_async_count_identifier_uses(node.binary_expr_right, name);
    } else if node.type == ASTNodeType.AST_UNARY_EXPR {
        count = count + c99_async_count_identifier_uses(node.unary_expr_operand, name);
    } else if node.type == ASTNodeType.AST_CALL_EXPR {
        count = count + c99_async_count_identifier_uses(node.call_expr_callee, name);
        if node.call_expr_args != null {
            var i: i32 = 0;
            while i < node.call_expr_arg_count {
                count = count + c99_async_count_identifier_uses(node.call_expr_args[i], name);
                i = i + 1;
            }
        }
    } else if node.type == ASTNodeType.AST_MEMBER_ACCESS {
        count = count + c99_async_count_identifier_uses(node.member_access_object, name);
    } else if node.type == ASTNodeType.AST_ARRAY_ACCESS {
        count = count + c99_async_count_identifier_uses(node.array_access_array, name);
        count = count + c99_async_count_identifier_uses(node.array_access_index, name);
    } else if node.type == ASTNodeType.AST_SLICE_EXPR {
        count = count + c99_async_count_identifier_uses(node.slice_expr_base, name);
        count = count + c99_async_count_identifier_uses(node.slice_expr_start_expr, name);
        count = count + c99_async_count_identifier_uses(node.slice_expr_len_expr, name);
    } else if node.type == ASTNodeType.AST_TRY_EXPR {
        count = count + c99_async_count_identifier_uses(node.try_expr_operand, name);
    } else if node.type == ASTNodeType.AST_CATCH_EXPR {
        count = count + c99_async_count_identifier_uses(node.catch_expr_operand, name);
        count = count + c99_async_count_identifier_uses(node.catch_expr_catch_block, name);
    } else if node.type == ASTNodeType.AST_CAST_EXPR {
        count = count + c99_async_count_identifier_uses(node.cast_expr_expr, name);
    } else if node.type == ASTNodeType.AST_AWAIT_EXPR {
        count = count + c99_async_count_identifier_uses(node.await_expr_operand, name);
    } else if node.type == ASTNodeType.AST_MATCH_EXPR {
        count = count + c99_async_count_identifier_uses(node.match_expr_expr, name);
        if node.match_expr_arms != null {
            var i: i32 = 0;
            while i < node.match_expr_arm_count {
                count = count + c99_async_count_identifier_uses(node.match_expr_arms[i].result_expr, name);
                i = i + 1;
            }
        }
    } else if node.type == ASTNodeType.AST_STRUCT_INIT {
        if node.struct_init_field_values != null {
            var i: i32 = 0;
            while i < node.struct_init_field_count {
                count = count + c99_async_count_identifier_uses(node.struct_init_field_values[i], name);
                i = i + 1;
            }
        }
    } else if node.type == ASTNodeType.AST_ARRAY_LITERAL {
        if node.array_literal_elements != null {
            var i: i32 = 0;
            while i < node.array_literal_element_count {
                count = count + c99_async_count_identifier_uses(node.array_literal_elements[i], name);
                i = i + 1;
            }
        }
        count = count + c99_async_count_identifier_uses(node.array_literal_repeat_count_expr, name);
    } else if node.type == ASTNodeType.AST_TUPLE_LITERAL {
        if node.tuple_literal_elements != null {
            var i: i32 = 0;
            while i < node.tuple_literal_element_count {
                count = count + c99_async_count_identifier_uses(node.tuple_literal_elements[i], name);
                i = i + 1;
            }
        }
    } else if node.type == ASTNodeType.AST_SIZEOF {
        count = count + c99_async_count_identifier_uses(node.sizeof_expr_target, name);
    } else if node.type == ASTNodeType.AST_LEN {
        count = count + c99_async_count_identifier_uses(node.len_expr_array, name);
    } else if node.type == ASTNodeType.AST_ALIGNOF {
        count = count + c99_async_count_identifier_uses(node.alignof_expr_target, name);
    } else if node.type == ASTNodeType.AST_DEFER_STMT {
        count = count + c99_async_count_identifier_uses(node.defer_stmt_body, name);
    } else if node.type == ASTNodeType.AST_ERRDEFER_STMT {
        count = count + c99_async_count_identifier_uses(node.errdefer_stmt_body, name);
    }
    return count;
}

// 扫描并替换可内联的 temp var await 操作数
fn c99_async_scan_inline_temp_vars(codegen: &C99CodeGenerator, body: &ASTNode) void {
    if codegen == null || body == null || codegen.async_collect_count <= 0 {
        return;
    }
    var j: i32 = 0;
    while j < codegen.async_collect_count && j < C99_ASYNC_MAX_AWAITS {
        const op: &ASTNode = codegen.async_collect_operands[j];
        if op != null && op.type == ASTNodeType.AST_IDENTIFIER && op.identifier_name != null {
            const name: &byte = op.identifier_name;
            const init: &ASTNode = c99_async_find_var_decl_init(body, name);
            if init != null && init.type == ASTNodeType.AST_CALL_EXPR && init.call_expr_callee != null {
                const callee: &ASTNode = init.call_expr_callee;
                if callee.type == ASTNodeType.AST_IDENTIFIER && callee.identifier_name != null {
                    const fd: &ASTNode = find_function_decl_c99(codegen, callee.identifier_name);
                    if fd != null && fd.fn_decl_is_async != 0 {
                        const use_count: i32 = c99_async_count_identifier_uses(body, name);
                        if use_count == 1 {
                            const inline_temp_idx: i32 = codegen.async_inline_temp_var_count;
                            if inline_temp_idx >= 0 && inline_temp_idx < 32 {
                                codegen.async_inline_temp_var_names[inline_temp_idx] = name;
                                codegen.async_inline_temp_var_count = codegen.async_inline_temp_var_count + 1;
                                codegen.async_collect_operands[j] = init;
                            }
                        }
                    }
                }
            }
        }
        j = j + 1;
    }
}

/// 将 Future 表达式赋给状态机的 await_fut（vtable+data），避免不同 Future 单态结构体之间不兼容。
fn c99_emit_await_fut_assign_from_expr(codegen: &C99CodeGenerator, operand: &ASTNode, fn_decl: &ASTNode) void {
    if operand == null || codegen == null || codegen.checker == null || fn_decl == null {
        return;
    }
    const ot: Type = checker_infer_type(codegen.checker, operand);
    var tc: &byte = c99_type_to_c_from_inferred_type(codegen, ot, fn_decl.line, fn_decl.column, fn_decl.filename);
    if operand.type == ASTNodeType.AST_CALL_EXPR && operand.call_expr_callee != null {
        const cal: &ASTNode = operand.call_expr_callee;
        if cal.type == ASTNodeType.AST_IDENTIFIER && cal.identifier_name != null {
            const fd_ret: &ASTNode = find_function_decl_c99(codegen, cal.identifier_name);
            if fd_ret != null && fd_ret.fn_decl_return_type != null {
                const t_fn: &byte = c99_type_to_c(codegen, fd_ret.fn_decl_return_type);
                if t_fn != null {
                    tc = t_fn;
                }
            }
        }
        // 成员调用：始终用语义上的方法返回类型求 C 名，避免 `||`/`&&` 优先级导致未进入补全分支而 abort
        if cal.type == ASTNodeType.AST_MEMBER_ACCESS && cal.member_access_object != null && cal.member_access_field_name != null {
            const ot_obj: Type = checker_infer_type(codegen.checker, cal.member_access_object);
            var mfn: &ASTNode = null;
            if ot_obj.kind == TypeKind.TYPE_STRUCT && ot_obj.struct_name != null {
                mfn = find_method_in_struct_c99(codegen, ot_obj.struct_name, cal.member_access_field_name);
            } else if ot_obj.kind == TypeKind.TYPE_POINTER && ot_obj.pointer_to != null {
                const pt: Type = ot_obj.pointer_to[0];
                if pt.kind == TypeKind.TYPE_STRUCT && pt.struct_name != null {
                    mfn = find_method_in_struct_c99(codegen, pt.struct_name, cal.member_access_field_name);
                } else if pt.kind == TypeKind.TYPE_INTERFACE && pt.interface_name != null {
                    mfn = c99_find_interface_method_sig(codegen, pt.interface_name, cal.member_access_field_name);
                }
            } else if ot_obj.kind == TypeKind.TYPE_INTERFACE && ot_obj.interface_name != null {
                mfn = c99_find_interface_method_sig(codegen, ot_obj.interface_name, cal.member_access_field_name);
            }
            if mfn != null && mfn.fn_decl_return_type != null {
                const tm: &byte = c99_type_to_c(codegen, mfn.fn_decl_return_type);
                if tm != null {
                    tc = tm;
                }
            }
            // checker_infer_type(接收者) 在部分上下文中得不到 struct 名；用 C 类型串回查声明（与 get_c_type_of_expr 路径一致）
            if (tc == null || strcmp(tc as *byte, "void" as *byte) == 0) && cal.member_access_object != null {
                const obj_c_fb: &byte = get_c_type_of_expr(codegen, cal.member_access_object);
                if obj_c_fb != null {
                    const sdecl_fb: &ASTNode = find_struct_decl_from_type_c(codegen, obj_c_fb);
                    if sdecl_fb != null && sdecl_fb.struct_decl_name != null {
                        const mfn2: &ASTNode = find_method_in_struct_c99(codegen, sdecl_fb.struct_decl_name, cal.member_access_field_name);
                        if mfn2 != null && mfn2.fn_decl_return_type != null {
                            const tm2: &byte = c99_type_to_c(codegen, mfn2.fn_decl_return_type);
                            if tm2 != null {
                                tc = tm2;
                            }
                        }
                        if (tc == null || strcmp(tc as *byte, "void" as *byte) == 0) && sdecl_fb.struct_decl_interface_names != null {
                            var ii: i32 = 0;
                            while ii < sdecl_fb.struct_decl_interface_count {
                                const inm: &byte = sdecl_fb.struct_decl_interface_names[ii];
                                if inm != null {
                                    const mif: &ASTNode = c99_find_interface_method_sig(codegen, inm, cal.member_access_field_name);
                                    if mif != null && mif.fn_decl_return_type != null {
                                        const tm3: &byte = c99_type_to_c(codegen, mif.fn_decl_return_type);
                                        if tm3 != null {
                                            tc = tm3;
                                            ii = sdecl_fb.struct_decl_interface_count;
                                        }
                                    }
                                }
                                ii = ii + 1;
                            }
                        }
                    }
                }
            }
        }
    }
    if tc == null || strcmp(tc as *byte, "void" as *byte) == 0 {
        const fallback_tc: &byte = get_c_type_of_expr(codegen, operand);
        if fallback_tc != null && strcmp(fallback_tc as *byte, "void" as *byte) != 0 {
            tc = fallback_tc;
        } else {
            fputs("        abort(); /* await_fut: missing C type for Future operand */\n" as *byte, codegen.emit_stream as *void);
            return;
        }
    }
    fputs("        { " as *byte, codegen.emit_stream as *void);
    fprintf(codegen.emit_stream as *void, "%s _uya_await_slot_tmp = " as *byte, tc as *byte);
    gen_expr(codegen, operand);
    fputs("; s->await_fut.vtable = (void*)_uya_await_slot_tmp.vtable; s->await_fut.data = _uya_await_slot_tmp.data; }\n" as *byte, codegen.emit_stream as *void);
}

fn c99_async_future_inner_ast_from_return_type(codegen: &C99CodeGenerator, ret_type: &ASTNode, fn_decl: &ASTNode) &ASTNode {
    if codegen == null || codegen.checker == null || ret_type == null || fn_decl == null {
        return null;
    }
    const rt: Type = type_from_ast(codegen.checker, ret_type);
    if rt.kind == TypeKind.TYPE_INTERFACE && rt.interface_name != null &&
        (str_equals(rt.interface_name, "Future" as *byte) != 0 ||
         (strlen(rt.interface_name as *byte) >= 6 && strncmp(rt.interface_name as *byte, "Future" as *byte, 6) == 0)) {
        if rt.interface_type_arg_count >= 1 && rt.interface_type_args != null {
            return type_to_ast(codegen.checker, &rt.interface_type_args[0], fn_decl.line, fn_decl.column, fn_decl.filename);
        }
    }
    if rt.kind == TypeKind.TYPE_STRUCT && rt.struct_name != null &&
        (str_equals(rt.struct_name, "Future" as *byte) != 0 ||
         (strlen(rt.struct_name as *byte) >= 6 && strncmp(rt.struct_name as *byte, "Future" as *byte, 6) == 0)) {
        if rt.struct_type_arg_count >= 1 && rt.struct_type_args != null {
            return type_to_ast(codegen.checker, &rt.struct_type_args[0], fn_decl.line, fn_decl.column, fn_decl.filename);
        }
    }
    if rt.kind == TypeKind.TYPE_ERROR_UNION && rt.error_union_payload_type != null {
        const pl: Type = rt.error_union_payload_type[0];
        if pl.kind == TypeKind.TYPE_INTERFACE && pl.interface_name != null &&
            (str_equals(pl.interface_name, "Future" as *byte) != 0 ||
             (strlen(pl.interface_name as *byte) >= 6 && strncmp(pl.interface_name as *byte, "Future" as *byte, 6) == 0)) {
            if pl.interface_type_arg_count >= 1 && pl.interface_type_args != null {
                return type_to_ast(codegen.checker, &pl.interface_type_args[0], fn_decl.line, fn_decl.column, fn_decl.filename);
            }
        }
        if pl.kind == TypeKind.TYPE_STRUCT && pl.struct_name != null &&
            (str_equals(pl.struct_name, "Future" as *byte) != 0 ||
             (strlen(pl.struct_name as *byte) >= 6 && strncmp(pl.struct_name as *byte, "Future" as *byte, 6) == 0)) {
            if pl.struct_type_arg_count >= 1 && pl.struct_type_args != null {
                return type_to_ast(codegen.checker, &pl.struct_type_args[0], fn_decl.line, fn_decl.column, fn_decl.filename);
            }
        }
    }
    return null;
}

fn c99_async_subtree_contains_block_node(node: &ASTNode, target: &ASTNode) i32 {
    if node == null || target == null {
        return 0;
    }
    if @usize_from_ptr(node as &void) == @usize_from_ptr(target as &void) {
        return 1;
    }
    if node.type == ASTNodeType.AST_WHILE_STMT && node.while_stmt_body != null {
        if c99_async_subtree_contains_block_node(node.while_stmt_body, target) != 0 {
            return 1;
        }
    }
    if node.type == ASTNodeType.AST_IF_STMT {
        if node.if_stmt_then_branch != null && c99_async_subtree_contains_block_node(node.if_stmt_then_branch, target) != 0 {
            return 1;
        }
        if node.if_stmt_else_branch != null && c99_async_subtree_contains_block_node(node.if_stmt_else_branch, target) != 0 {
            return 1;
        }
    }
    if node.type == ASTNodeType.AST_FOR_STMT && node.for_stmt_body != null {
        if c99_async_subtree_contains_block_node(node.for_stmt_body, target) != 0 {
            return 1;
        }
    }
    if node.type == ASTNodeType.AST_BLOCK && node.block_stmts != null {
        var bi: i32 = 0;
        while bi < node.block_stmt_count {
            const ch: &ASTNode = node.block_stmts[bi];
            if ch != null && c99_async_subtree_contains_block_node(ch, target) != 0 {
                return 1;
            }
            bi = bi + 1;
        }
    }
    return 0;
}

/// 第一个 await 所在「函数体顶层语句」下标：memcpy 仅应对 root_stmt < 此下标的定长数组在 state 0 执行（避免误初始化 try/结构体等）。
fn c99_async_root_stmt_index_of_first_await(body: &ASTNode, await_blocks: [&ASTNode: C99_ASYNC_MAX_AWAITS], await_stmt_indices: [i32: C99_ASYNC_MAX_AWAITS], await_count: i32) i32 {
    if body == null || body.type != ASTNodeType.AST_BLOCK || await_count <= 0 {
        return -1;
    }
    const inner: &ASTNode = await_blocks[0];
    if inner == null {
        return -1;
    }
    if @usize_from_ptr(inner as &void) == @usize_from_ptr(body as &void) {
        const ix: i32 = await_stmt_indices[0];
        if ix >= 0 {
            return ix;
        }
        return -1;
    }
    var ri: i32 = 0;
    while ri < body.block_stmt_count {
        const st: &ASTNode = body.block_stmts[ri];
        if st != null && c99_async_subtree_contains_block_node(st, inner) != 0 {
            return ri;
        }
        ri = ri + 1;
    }
    return -1;
}

/// 若最后一个 await 与 return 同在函数体顶层，去掉「该 await 声明行之后」提升的 _uya_loc_*（由最后一态 gen_stmt 处理，避免与 s->_uya_loc_x 重名）。
fn c99_async_operand_at(await_operands: [&ASTNode: C99_ASYNC_MAX_AWAITS], idx: i32) &ASTNode {
    if idx < 0 {
        return null;
    }
    if idx >= C99_ASYNC_MAX_AWAITS {
        return null;
    }
    return await_operands[idx];
}

fn c99_async_bind_name_at(await_bind_names: [&byte: C99_ASYNC_MAX_AWAITS], idx: i32) &byte {
    if idx < 0 {
        return null;
    }
    if idx >= C99_ASYNC_MAX_AWAITS {
        return null;
    }
    return await_bind_names[idx];
}

fn c99_async_bind_type_at(await_bind_types: [&ASTNode: C99_ASYNC_MAX_AWAITS], idx: i32) &ASTNode {
    if idx < 0 {
        return null;
    }
    if idx >= C99_ASYNC_MAX_AWAITS {
        return null;
    }
    return await_bind_types[idx];
}

fn c99_async_await_block_at(await_blocks: [&ASTNode: C99_ASYNC_MAX_AWAITS], idx: i32) &ASTNode {
    if idx < 0 {
        return null;
    }
    if idx >= C99_ASYNC_MAX_AWAITS {
        return null;
    }
    return await_blocks[idx];
}

fn c99_async_await_stmt_index_at(await_stmt_indices: [i32: C99_ASYNC_MAX_AWAITS], idx: i32) i32 {
    if idx < 0 {
        return -1;
    }
    if idx >= C99_ASYNC_MAX_AWAITS {
        return -1;
    }
    return await_stmt_indices[idx];
}

fn c99_async_local_init_set(codegen: &C99CodeGenerator, idx: i32, init_expr: &ASTNode) void {
    if codegen == null {
        return;
    }
    if idx < 0 {
        return;
    }
    if idx >= 32 {
        return;
    }
    codegen.async_local_inits[idx] = init_expr;
}

fn c99_async_local_name_set(codegen: &C99CodeGenerator, idx: i32, name: &byte) void {
    if codegen == null {
        return;
    }
    if idx < 0 {
        return;
    }
    if idx >= 32 {
        return;
    }
    codegen.async_local_names[idx] = name;
}

fn c99_async_local_type_set(codegen: &C99CodeGenerator, idx: i32, typ: &ASTNode) void {
    if codegen == null {
        return;
    }
    if idx < 0 {
        return;
    }
    if idx >= 32 {
        return;
    }
    codegen.async_local_types[idx] = typ;
}

fn c99_async_local_root_stmt_set(codegen: &C99CodeGenerator, idx: i32, root_si: i32) void {
    if codegen == null {
        return;
    }
    if idx < 0 {
        return;
    }
    if idx >= 32 {
        return;
    }
    codegen.async_local_root_stmt[idx] = root_si;
}

fn c99_async_trim_locals_after_last_await_root(codegen: &C99CodeGenerator, body: &ASTNode, await_blocks: [&ASTNode: C99_ASYNC_MAX_AWAITS], await_stmt_indices: [i32: C99_ASYNC_MAX_AWAITS], await_count: i32) void {
    if codegen == null || body == null || await_count <= 0 {
        return;
    }
    const last_await_idx: i32 = await_count - 1;
    if last_await_idx < 0 {
        return;
    }
    if last_await_idx >= C99_ASYNC_MAX_AWAITS {
        return;
    }
    const lb: &ASTNode = await_blocks[last_await_idx];
    if lb == null || @usize_from_ptr(lb as &void) != @usize_from_ptr(body as &void) {
        return;
    }
    const last_ix: i32 = await_stmt_indices[last_await_idx];
    if last_ix < 0 {
        return;
    }
    var w: i32 = 0;
    var r: i32 = 0;
    while r < codegen.async_local_count && r < @len(codegen.async_local_names) {
        if codegen.async_local_root_stmt[r] <= last_ix {
            if w != r {
                if w >= 0 && w < @len(codegen.async_local_names) {
                    codegen.async_local_names[w] = codegen.async_local_names[r];
                    codegen.async_local_types[w] = codegen.async_local_types[r];
                    codegen.async_local_inits[w] = codegen.async_local_inits[r];
                    codegen.async_local_root_stmt[w] = codegen.async_local_root_stmt[r];
                }
            }
            w = w + 1;
        }
        r = r + 1;
    }
    codegen.async_local_count = w;
}

// 收集函数体顶层、第一个顶层 return 之前的 const/var（非 try @await 绑定），记入 async_local_* 并记录根语句下标。
fn c99_async_collect_locals_recursive(codegen: &C99CodeGenerator, fn_body: &ASTNode, node: &ASTNode, parent_block: &ASTNode, parent_stmt_index: i32) void {
    if codegen == null || node == null || codegen.async_local_count >= @len(codegen.async_local_names) {
        return;
    }
    var nested_block_root_si: i32 = 2147483647;
    if fn_body != null && parent_block != null && @usize_from_ptr(parent_block as &void) == @usize_from_ptr(fn_body as &void) {
        nested_block_root_si = parent_stmt_index;
    }
    if node.type == ASTNodeType.AST_BLOCK && node.block_stmts != null {
        var bi: i32 = 0;
        while bi < node.block_stmt_count && codegen.async_local_count < @len(codegen.async_local_names) {
            c99_async_collect_locals_recursive(codegen, fn_body, node.block_stmts[bi], node, bi);
            bi = bi + 1;
        }
        return;
    }
    if node.type == ASTNodeType.AST_IF_STMT {
        if node.if_stmt_then_branch != null {
            c99_async_collect_locals_recursive(codegen, fn_body, node.if_stmt_then_branch, null, -1);
        }
        if node.if_stmt_else_branch != null {
            c99_async_collect_locals_recursive(codegen, fn_body, node.if_stmt_else_branch, null, -1);
        }
        return;
    }
    if node.type == ASTNodeType.AST_WHILE_STMT && node.while_stmt_body != null {
        c99_async_collect_locals_recursive(codegen, fn_body, node.while_stmt_body, null, -1);
        return;
    }
    if node.type == ASTNodeType.AST_FOR_STMT && node.for_stmt_body != null {
        c99_async_collect_locals_recursive(codegen, fn_body, node.for_stmt_body, null, -1);
        return;
    }
    if node.type != ASTNodeType.AST_VAR_DECL || node.var_decl_name == null || node.var_decl_type == null ||
        c99_var_decl_init_is_try_await_bind(node.var_decl_init) != 0 {
        return;
    }
    // @frame(...) 类型允许无初始化，但仍需提升到状态机结构体中
    var allow_no_init: i32 = 0;
    if node.var_decl_init == null && node.var_decl_type.type == ASTNodeType.AST_TYPE_FRAME {
        allow_no_init = 1;
    }
    if node.var_decl_init == null && allow_no_init == 0 {
        return;
    }
    var root_si: i32 = nested_block_root_si;
    const before_count: i32 = codegen.async_local_count;
    c99_async_try_append_hoist_local(codegen, node.var_decl_name, node.var_decl_type, root_si);
    if codegen.async_local_count > before_count {
        const alc1: i32 = codegen.async_local_count - 1;
        if alc1 >= 0 {
            if alc1 < @len(codegen.async_local_inits) {
                c99_async_local_init_set(codegen, alc1, node.var_decl_init);
                if node.var_decl_init != null && c99_stmt_tree_has_await(node.var_decl_init) != 0 {
                    // 该初始化本身含 await：state 0 不做前置初始化，等语句在 resume 后重放。
                    c99_async_local_init_set(codegen, alc1, null);
                }
            }
        }
    }
}

fn collect_async_pre_return_locals(codegen: &C99CodeGenerator, body: &ASTNode) void {
    codegen.async_local_count = 0;
    if codegen == null || body == null || body.type != ASTNodeType.AST_BLOCK {
        return;
    }
    var si: i32 = 0;
    while si < body.block_stmt_count && codegen.async_local_count < @len(codegen.async_local_names) {
        const st: &ASTNode = body.block_stmts[si];
        if st == null {
            si = si + 1;
            continue;
        }
        if st.type == ASTNodeType.AST_RETURN_STMT {
            break;
        }
        c99_async_collect_locals_recursive(codegen, body, st, body, si);
        si = si + 1;
    }
}

/// state==0 且存在 await 时：对「第一个 await 所在顶层语句之前」的提升局部做完整初始化（含 try connect / build_headers 等；定长数组仍用 memcpy）。
/// 仅包含 root_stmt < cut_root 的项，避免把 meta=0、malloc(body_total) 等后置语句误写入 state 0。
fn emit_async_state0_pre_first_await_local_inits(codegen: &C99CodeGenerator, cut_root: i32) void {
    if codegen == null || codegen.async_state_var == null || codegen.async_local_count <= 0 || cut_root < 0 {
        return;
    }
    var li: i32 = 0;
    while li < codegen.async_local_count && li < @len(codegen.async_local_names) {
        if codegen.async_local_root_stmt[li] >= cut_root {
            li = li + 1;
            continue;
        }
        const orig: &byte = codegen.async_local_names[li];
        const ie: &ASTNode = codegen.async_local_inits[li];
        const ltype: &ASTNode = codegen.async_local_types[li];
        if orig != null && ie == null && ltype != null && ltype.type == ASTNodeType.AST_TYPE_FRAME {
            const ls0: &byte = get_safe_c_identifier(codegen, orig);
            if ls0 != null {
                fprintf(codegen.emit_stream as *void,
                    "        __builtin_memset((void *)&%s->_uya_loc_%s, 0, sizeof(%s->_uya_loc_%s));\n" as *byte,
                    codegen.async_state_var as *byte, ls0 as *byte, codegen.async_state_var as *byte, ls0 as *byte);
            }
            li = li + 1;
            continue;
        }
        if orig != null && ie != null {
            const ls: &byte = get_safe_c_identifier(codegen, orig);
            if ls != null {
                if ltype != null && ltype.type == ASTNodeType.AST_TYPE_ARRAY &&
                    ltype.type_array_element_type != null && ie.type == ASTNodeType.AST_ARRAY_LITERAL {
                    const elem_c: &byte = c99_type_to_c(codegen, ltype.type_array_element_type);
                    if elem_c != null {
                        var lit_len: i32 = ie.array_literal_element_count;
                        if ie.array_literal_repeat_count_expr != null && ie.array_literal_element_count >= 1 {
                            const rep_n: i32 = eval_const_expr(codegen, ie.array_literal_repeat_count_expr);
                            if rep_n >= 0 {
                                lit_len = rep_n;
                            }
                        }
                        const arr_n: i32 = eval_const_expr(codegen, ltype.type_array_size_expr);
                        if arr_n > 0 && lit_len >= 0 && lit_len < arr_n {
                            fprintf(codegen.emit_stream as *void,
                                "        __builtin_memset((void *)&%s->_uya_loc_%s, 0, sizeof(%s->_uya_loc_%s));\n" as *byte,
                                codegen.async_state_var as *byte, ls as *byte, codegen.async_state_var as *byte, ls as *byte);
                            if lit_len > 0 {
                                fprintf(codegen.emit_stream as *void, "        __uya_memcpy((void *)%s->_uya_loc_%s, (const void *)(const " as *byte,
                                    codegen.async_state_var as *byte, ls as *byte);
                                fputs(elem_c as *byte, codegen.emit_stream as *void);
                                fputs("[]){" as *byte, codegen.emit_stream as *void);
                                gen_array_literal_contents(codegen, ie);
                                fprintf(codegen.emit_stream as *void,
                                    "}, ((size_t)(%d)) * sizeof(%s->_uya_loc_%s[0]));\n" as *byte,
                                    lit_len, codegen.async_state_var as *byte, ls as *byte);
                            }
                        } else {
                            fprintf(codegen.emit_stream as *void, "        __uya_memcpy((void *)%s->_uya_loc_%s, (const void *)(const " as *byte,
                                codegen.async_state_var as *byte, ls as *byte);
                            fputs(elem_c as *byte, codegen.emit_stream as *void);
                            fputs("[]){" as *byte, codegen.emit_stream as *void);
                            gen_array_literal_contents(codegen, ie);
                            fprintf(codegen.emit_stream as *void, "}, sizeof(%s->_uya_loc_%s));\n" as *byte,
                                codegen.async_state_var as *byte, ls as *byte);
                        }
                    }
                } else {
                    fprintf(codegen.emit_stream as *void, "        %s->_uya_loc_%s = " as *byte,
                        codegen.async_state_var as *byte, ls as *byte);
                    gen_expr(codegen, ie);
                    fputs(";\n" as *byte, codegen.emit_stream as *void);
                }
            }
        }
        li = li + 1;
    }
}

fn emit_async_pre_return_local_inits(codegen: &C99CodeGenerator) void {
    if codegen == null || codegen.async_state_var == null || codegen.async_local_count <= 0 {
        return;
    }
    var li: i32 = 0;
    while li < codegen.async_local_count && li < @len(codegen.async_local_names) {
        const orig: &byte = codegen.async_local_names[li];
        const ie: &ASTNode = codegen.async_local_inits[li];
        const ltype: &ASTNode = codegen.async_local_types[li];
        if orig != null && ie == null && ltype != null && ltype.type == ASTNodeType.AST_TYPE_FRAME {
            const ls0: &byte = get_safe_c_identifier(codegen, orig);
            if ls0 != null {
                fprintf(codegen.emit_stream as *void,
                    "        __builtin_memset((void *)&%s->_uya_loc_%s, 0, sizeof(%s->_uya_loc_%s));\n" as *byte,
                    codegen.async_state_var as *byte, ls0 as *byte, codegen.async_state_var as *byte, ls0 as *byte);
            }
            li = li + 1;
            continue;
        }
        if orig != null && ie != null {
            const ls: &byte = get_safe_c_identifier(codegen, orig);
            if ls != null {
                // 定长数组提升为状态机字段后不能 s->_uya_loc_x = { ... }，用 memcpy + 复合字面量
                if ltype != null && ltype.type == ASTNodeType.AST_TYPE_ARRAY &&
                    ltype.type_array_element_type != null && ie.type == ASTNodeType.AST_ARRAY_LITERAL {
                    const elem_c: &byte = c99_type_to_c(codegen, ltype.type_array_element_type);
                    if elem_c != null {
                        var lit_len2: i32 = ie.array_literal_element_count;
                        if ie.array_literal_repeat_count_expr != null && ie.array_literal_element_count >= 1 {
                            const rep_n2: i32 = eval_const_expr(codegen, ie.array_literal_repeat_count_expr);
                            if rep_n2 >= 0 {
                                lit_len2 = rep_n2;
                            }
                        }
                        const arr_n2: i32 = eval_const_expr(codegen, ltype.type_array_size_expr);
                        if arr_n2 > 0 && lit_len2 >= 0 && lit_len2 < arr_n2 {
                            fprintf(codegen.emit_stream as *void,
                                "        __builtin_memset((void *)&%s->_uya_loc_%s, 0, sizeof(%s->_uya_loc_%s));\n" as *byte,
                                codegen.async_state_var as *byte, ls as *byte, codegen.async_state_var as *byte, ls as *byte);
                            if lit_len2 > 0 {
                                fprintf(codegen.emit_stream as *void, "        __uya_memcpy((void *)%s->_uya_loc_%s, (const void *)(const " as *byte,
                                    codegen.async_state_var as *byte, ls as *byte);
                                fputs(elem_c as *byte, codegen.emit_stream as *void);
                                fputs("[]){" as *byte, codegen.emit_stream as *void);
                                gen_array_literal_contents(codegen, ie);
                                fprintf(codegen.emit_stream as *void,
                                    "}, ((size_t)(%d)) * sizeof(%s->_uya_loc_%s[0]));\n" as *byte,
                                    lit_len2, codegen.async_state_var as *byte, ls as *byte);
                            }
                        } else {
                            fprintf(codegen.emit_stream as *void, "        __uya_memcpy((void *)%s->_uya_loc_%s, (const void *)(const " as *byte,
                                codegen.async_state_var as *byte, ls as *byte);
                            fputs(elem_c as *byte, codegen.emit_stream as *void);
                            fputs("[]){" as *byte, codegen.emit_stream as *void);
                            gen_array_literal_contents(codegen, ie);
                            fprintf(codegen.emit_stream as *void, "}, sizeof(%s->_uya_loc_%s));\n" as *byte,
                                codegen.async_state_var as *byte, ls as *byte);
                        }
                        li = li + 1;
                        continue;
                    }
                }
                fprintf(codegen.emit_stream as *void, "        %s->_uya_loc_%s = " as *byte,
                    codegen.async_state_var as *byte, ls as *byte);
                gen_expr(codegen, ie);
                fputs(";\n" as *byte, codegen.emit_stream as *void);
            }
        }
        li = li + 1;
    }
}

// ===== 通用协程变换：递归段发射 =====

// 判断语句树是否包含任意 @await（用于 while/if 分支判断）
fn c99_stmt_tree_has_await(node: &ASTNode) i32 {
    if node == null { return 0; }
    if node.type == ASTNodeType.AST_AWAIT_EXPR { return 1; }
    if node.type == ASTNodeType.AST_TRY_EXPR && node.try_expr_operand != null {
        return c99_stmt_tree_has_await(node.try_expr_operand);
    }
    if node.type == ASTNodeType.AST_VAR_DECL && node.var_decl_init != null {
        return c99_stmt_tree_has_await(node.var_decl_init);
    }
    if node.type == ASTNodeType.AST_RETURN_STMT && node.return_stmt_expr != null {
        return c99_stmt_tree_has_await(node.return_stmt_expr);
    }
    if node.type == ASTNodeType.AST_BLOCK && node.block_stmts != null {
        var i: i32 = 0;
        while i < node.block_stmt_count {
            if c99_stmt_tree_has_await(node.block_stmts[i]) != 0 { return 1; }
            i = i + 1;
        }
    }
    if node.type == ASTNodeType.AST_WHILE_STMT && node.while_stmt_body != null {
        return c99_stmt_tree_has_await(node.while_stmt_body);
    }
    if node.type == ASTNodeType.AST_FOR_STMT && node.for_stmt_body != null {
        return c99_stmt_tree_has_await(node.for_stmt_body);
    }
    if node.type == ASTNodeType.AST_IF_STMT {
        if node.if_stmt_then_branch != null && c99_stmt_tree_has_await(node.if_stmt_then_branch) != 0 { return 1; }
        if node.if_stmt_else_branch != null && c99_stmt_tree_has_await(node.if_stmt_else_branch) != 0 { return 1; }
    }
    if node.type == ASTNodeType.AST_ASSIGN {
        if c99_stmt_tree_has_await(node.assign_dest) != 0 { return 1; }
        return c99_stmt_tree_has_await(node.assign_src);
    }
    if node.type == ASTNodeType.AST_CALL_EXPR {
        if c99_stmt_tree_has_await(node.call_expr_callee) != 0 { return 1; }
        if node.call_expr_args != null {
            var ai: i32 = 0;
            while ai < node.call_expr_arg_count {
                if c99_stmt_tree_has_await(node.call_expr_args[ai]) != 0 { return 1; }
                ai = ai + 1;
            }
        }
        return 0;
    }
    if node.type == ASTNodeType.AST_MEMBER_ACCESS {
        return c99_stmt_tree_has_await(node.member_access_object);
    }
    if node.type == ASTNodeType.AST_ARRAY_ACCESS {
        if c99_stmt_tree_has_await(node.array_access_array) != 0 { return 1; }
        return c99_stmt_tree_has_await(node.array_access_index);
    }
    if node.type == ASTNodeType.AST_SLICE_EXPR {
        if c99_stmt_tree_has_await(node.slice_expr_base) != 0 { return 1; }
        if c99_stmt_tree_has_await(node.slice_expr_start_expr) != 0 { return 1; }
        return c99_stmt_tree_has_await(node.slice_expr_len_expr);
    }
    if node.type == ASTNodeType.AST_BINARY_EXPR {
        if c99_stmt_tree_has_await(node.binary_expr_left) != 0 { return 1; }
        return c99_stmt_tree_has_await(node.binary_expr_right);
    }
    if node.type == ASTNodeType.AST_UNARY_EXPR {
        return c99_stmt_tree_has_await(node.unary_expr_operand);
    }
    if node.type == ASTNodeType.AST_CAST_EXPR {
        return c99_stmt_tree_has_await(node.cast_expr_expr);
    }
    if node.type == ASTNodeType.AST_CATCH_EXPR {
        if c99_stmt_tree_has_await(node.catch_expr_operand) != 0 { return 1; }
        return c99_stmt_tree_has_await(node.catch_expr_catch_block);
    }
    if node.type == ASTNodeType.AST_MATCH_EXPR && node.match_expr_arms != null {
        if c99_stmt_tree_has_await(node.match_expr_expr) != 0 { return 1; }
        var mi: i32 = 0;
        while mi < node.match_expr_arm_count {
            if c99_stmt_tree_has_await(node.match_expr_arms[mi].result_expr) != 0 { return 1; }
            mi = mi + 1;
        }
        return 0;
    }
    if node.type == ASTNodeType.AST_STRUCT_INIT && node.struct_init_field_values != null {
        var fi: i32 = 0;
        while fi < node.struct_init_field_count {
            if c99_stmt_tree_has_await(node.struct_init_field_values[fi]) != 0 { return 1; }
            fi = fi + 1;
        }
        return 0;
    }
    if node.type == ASTNodeType.AST_ARRAY_LITERAL && node.array_literal_elements != null {
        var ei: i32 = 0;
        while ei < node.array_literal_element_count {
            if c99_stmt_tree_has_await(node.array_literal_elements[ei]) != 0 { return 1; }
            ei = ei + 1;
        }
        return 0;
    }
    if node.type == ASTNodeType.AST_TUPLE_LITERAL && node.tuple_literal_elements != null {
        var ti: i32 = 0;
        while ti < node.tuple_literal_element_count {
            if c99_stmt_tree_has_await(node.tuple_literal_elements[ti]) != 0 { return 1; }
            ti = ti + 1;
        }
        return 0;
    }
    if node.type == ASTNodeType.AST_PRINT || node.type == ASTNodeType.AST_PRINTLN {
        return c99_stmt_tree_has_await(node.print_expr);
    }
    if node.type == ASTNodeType.AST_SYSCALL {
        if c99_stmt_tree_has_await(node.syscall_number) != 0 { return 1; }
        if node.syscall_args != null {
            var si2: i32 = 0;
            while si2 < node.syscall_arg_count {
                if c99_stmt_tree_has_await(node.syscall_args[si2]) != 0 { return 1; }
                si2 = si2 + 1;
            }
        }
        return 0;
    }
    if node.type == ASTNodeType.AST_STRING_INTERP && node.string_interp_segments != null {
        var si3: i32 = 0;
        while si3 < node.string_interp_segment_count {
            const seg: &ASTStringInterpSegment = &node.string_interp_segments[si3];
            if seg != null && seg.is_text == 0 && seg.expr != null && c99_stmt_tree_has_await(seg.expr) != 0 {
                return 1;
            }
            si3 = si3 + 1;
        }
        return 0;
    }
    if node.type == ASTNodeType.AST_SIZEOF {
        return c99_stmt_tree_has_await(node.sizeof_expr_target);
    }
    if node.type == ASTNodeType.AST_LEN {
        return c99_stmt_tree_has_await(node.len_expr_array);
    }
    if node.type == ASTNodeType.AST_ALIGNOF {
        return c99_stmt_tree_has_await(node.alignof_expr_target);
    }
    if node.type == ASTNodeType.AST_PTR_FROM_USIZE {
        return c99_stmt_tree_has_await(node.ptr_from_usize_value);
    }
    if node.type == ASTNodeType.AST_USIZE_FROM_PTR {
        return c99_stmt_tree_has_await(node.usize_from_ptr_ptr);
    }
    if node.type == ASTNodeType.AST_ERROR_ID {
        return c99_stmt_tree_has_await(node.error_id_operand);
    }
    if node.type == ASTNodeType.AST_VA_START {
        if c99_stmt_tree_has_await(node.va_start_ap) != 0 { return 1; }
        return c99_stmt_tree_has_await(node.va_start_last_param);
    }
    if node.type == ASTNodeType.AST_VA_END {
        return c99_stmt_tree_has_await(node.va_end_ap);
    }
    if node.type == ASTNodeType.AST_VA_ARG {
        if c99_stmt_tree_has_await(node.va_arg_ap) != 0 { return 1; }
        return c99_stmt_tree_has_await(node.va_arg_arg_type);
    }
    if node.type == ASTNodeType.AST_VA_COPY {
        if c99_stmt_tree_has_await(node.va_copy_dest) != 0 { return 1; }
        return c99_stmt_tree_has_await(node.va_copy_src);
    }
    return 0;
}

extern fn c99_arena_strdup(arena: &CompilerArena, src: &byte) &byte;

// 为含 await 的 for 生成稳定合成名（与 emit 侧一致）
fn c99_async_for_fe_hoist_name(codegen: &C99CodeGenerator, for_n: &ASTNode) &byte {
    if codegen == null || codegen.arena == null || for_n == null {
        return null;
    }
    var buf: [byte: 64] = [];
    snprintf(&buf[0] as *byte, 64, "__uya_fe_%d_%d" as *byte, for_n.line, for_n.column);
    return c99_arena_strdup(codegen.arena, &buf[0] as &byte);
}

fn c99_async_for_ar_hoist_names(codegen: &C99CodeGenerator, for_n: &ASTNode, out_len: &&byte, out_i: &&byte) void {
    out_len[0] = null;
    out_i[0] = null;
    if codegen == null || codegen.arena == null || for_n == null {
        return;
    }
    var buf1: [byte: 64] = [];
    var buf2: [byte: 64] = [];
    snprintf(&buf1[0] as *byte, 64, "__uya_ar_%d_%d_len" as *byte, for_n.line, for_n.column);
    snprintf(&buf2[0] as *byte, 64, "__uya_ar_%d_%d_i" as *byte, for_n.line, for_n.column);
    out_len[0] = c99_arena_strdup(codegen.arena, &buf1[0] as &byte);
    out_i[0] = c99_arena_strdup(codegen.arena, &buf2[0] as &byte);
}

fn c99_async_type_named_usize(codegen: &C99CodeGenerator) &ASTNode {
    if codegen == null || codegen.arena == null {
        return null;
    }
    const n: &ASTNode = ast_new_node(ASTNodeType.AST_TYPE_NAMED, 0, 0, codegen.arena, null);
    if n != null {
        n.type_named_name = "usize" as &byte;
    }
    return n;
}

fn c99_async_find_var_decl_type_in_block(blk: &ASTNode, name: &byte) &ASTNode {
    if blk == null || blk.type != ASTNodeType.AST_BLOCK || blk.block_stmts == null || name == null {
        return null;
    }
    var vi: i32 = 0;
    while vi < blk.block_stmt_count {
        const st: &ASTNode = blk.block_stmts[vi];
        if st != null && st.type == ASTNodeType.AST_VAR_DECL && st.var_decl_name != null &&
            strcmp(st.var_decl_name as *byte, name as *byte) == 0 {
            return st.var_decl_type;
        }
        vi = vi + 1;
    }
    return null;
}

fn c99_async_find_var_or_param_type_ast(fn_decl: &ASTNode, name: &byte) &ASTNode {
    if fn_decl == null || name == null {
        return null;
    }
    if fn_decl.fn_decl_body != null {
        const t1: &ASTNode = c99_async_find_var_decl_type_in_block(fn_decl.fn_decl_body, name);
        if t1 != null {
            return t1;
        }
    }
    var pi: i32 = 0;
    while pi < fn_decl.fn_decl_param_count && fn_decl.fn_decl_params != null {
        const p: &ASTNode = fn_decl.fn_decl_params[pi];
        if p != null && p.type == ASTNodeType.AST_VAR_DECL && p.var_decl_name != null &&
            strcmp(p.var_decl_name as *byte, name as *byte) == 0 {
            return p.var_decl_type;
        }
        pi = pi + 1;
    }
    return null;
}

// 定长数组 for：元素 C 类型（优先 local_variables，否则从形参/函数体 var 的 AST 类型推断）
fn c99_async_for_array_elem_type_c(codegen: &C99CodeGenerator, for_stmt: &ASTNode) &byte {
    if codegen == null || for_stmt == null || for_stmt.for_stmt_array == null {
        return null;
    }
    var elem_cb: &byte = get_array_element_type(codegen, for_stmt.for_stmt_array);
    if elem_cb == null && codegen.async_fn_decl != null &&
        for_stmt.for_stmt_array.type == ASTNodeType.AST_IDENTIFIER &&
        for_stmt.for_stmt_array.identifier_name != null {
        const avt: &ASTNode = c99_async_find_var_or_param_type_ast(codegen.async_fn_decl, for_stmt.for_stmt_array.identifier_name);
        if avt != null && avt.type == ASTNodeType.AST_TYPE_ARRAY && avt.type_array_element_type != null {
            elem_cb = c99_type_to_c(codegen, avt.type_array_element_type);
        } else if avt != null && avt.type == ASTNodeType.AST_TYPE_SLICE && avt.type_slice_element_type != null {
            elem_cb = c99_type_to_c(codegen, avt.type_slice_element_type);
        }
    }
    return elem_cb;
}

fn c99_async_try_append_hoist_local(codegen: &C99CodeGenerator, name: &byte, typ: &ASTNode, root_si: i32) void {
    if codegen == null || name == null || typ == null || codegen.async_local_count >= @len(codegen.async_local_names) {
        return;
    }
    var li: i32 = 0;
    while li < codegen.async_local_count {
        if li >= 0 && li < @len(codegen.async_local_names) {
            if codegen.async_local_names[li] != null &&
                strcmp(codegen.async_local_names[li] as *byte, name as *byte) == 0 {
                return;
            }
        }
        li = li + 1;
    }
    const alc: i32 = codegen.async_local_count;
    if alc >= 0 {
        if alc < @len(codegen.async_local_names) {
            c99_async_local_name_set(codegen, alc, name);
        }
    }
    if alc >= 0 {
        if alc < @len(codegen.async_local_types) {
            c99_async_local_type_set(codegen, alc, typ);
        }
    }
    if alc >= 0 {
        if alc < @len(codegen.async_local_inits) {
            c99_async_local_init_set(codegen, alc, null);
        }
    }
    if alc >= 0 {
        if alc < @len(codegen.async_local_root_stmt) {
            c99_async_local_root_stmt_set(codegen, alc, root_si);
        }
    }
    codegen.async_local_count = codegen.async_local_count + 1;
}

fn c99_async_hoist_one_for_with_await(codegen: &C99CodeGenerator, fn_decl: &ASTNode, for_n: &ASTNode) void {
    if codegen == null || for_n == null || codegen.checker == null || fn_decl == null {
        return;
    }
    if for_n.for_stmt_is_range != 0 {
        if for_n.for_stmt_range_start == null {
            return;
        }
        const st_t: Type = checker_infer_type(codegen.checker, for_n.for_stmt_range_start);
        const ta: &ASTNode = type_to_ast(codegen.checker, &st_t, for_n.line, for_n.column, fn_decl.filename);
        if ta == null {
            return;
        }
        if for_n.for_stmt_range_end != null {
            if for_n.for_stmt_var_name != null {
                c99_async_try_append_hoist_local(codegen, for_n.for_stmt_var_name, ta, 0);
                const fe: &byte = c99_async_for_fe_hoist_name(codegen, for_n);
                c99_async_try_append_hoist_local(codegen, fe, ta, 0);
            } else {
                c99_async_try_append_hoist_local(codegen, "_uya_s" as &byte, ta, 0);
                c99_async_try_append_hoist_local(codegen, "_uya_e" as &byte, ta, 0);
                c99_async_try_append_hoist_local(codegen, "_uya_i" as &byte, ta, 0);
            }
        } else {
            if for_n.for_stmt_var_name != null {
                c99_async_try_append_hoist_local(codegen, for_n.for_stmt_var_name, ta, 0);
            }
        }
        return;
    }
    // 不能依赖 get_array_element_type（需 local_variables）；优先从形参/函数体 var 的 AST 类型取元素类型
    var elt_from_ast: &ASTNode = null;
    if for_n.for_stmt_array != null && for_n.for_stmt_array.type == ASTNodeType.AST_IDENTIFIER &&
        for_n.for_stmt_array.identifier_name != null {
        const vty: &ASTNode = c99_async_find_var_or_param_type_ast(fn_decl, for_n.for_stmt_array.identifier_name);
        if vty != null && vty.type == ASTNodeType.AST_TYPE_ARRAY && vty.type_array_element_type != null {
            elt_from_ast = vty.type_array_element_type;
        } else if vty != null && vty.type == ASTNodeType.AST_TYPE_SLICE && vty.type_slice_element_type != null {
            elt_from_ast = vty.type_slice_element_type;
        }
    }
    if elt_from_ast == null {
        var arr_ty: Type = checker_infer_type(codegen.checker, for_n.for_stmt_array);
        if arr_ty.kind == TypeKind.TYPE_POINTER && arr_ty.pointer_to != null {
            arr_ty = arr_ty.pointer_to[0];
        }
        if arr_ty.kind == TypeKind.TYPE_ARRAY && arr_ty.element_type != null {
            elt_from_ast = type_to_ast(codegen.checker, arr_ty.element_type, for_n.line, for_n.column, fn_decl.filename);
        } else if arr_ty.kind == TypeKind.TYPE_SLICE && arr_ty.slice_element_type != null {
            elt_from_ast = type_to_ast(codegen.checker, arr_ty.slice_element_type, for_n.line, for_n.column, fn_decl.filename);
        }
    }
    if elt_from_ast == null {
        return;
    }
    const usz: &ASTNode = c99_async_type_named_usize(codegen);
    if usz == null {
        return;
    }
    var len_nm: [&byte: 1] = [null];
    var i_nm: [&byte: 1] = [null];
    c99_async_for_ar_hoist_names(codegen, for_n, &len_nm[0], &i_nm[0]);
    if len_nm[0] != null {
        c99_async_try_append_hoist_local(codegen, len_nm[0], usz, 0);
    }
    if i_nm[0] != null {
        c99_async_try_append_hoist_local(codegen, i_nm[0], usz, 0);
    }
    if for_n.for_stmt_var_name != null {
        c99_async_try_append_hoist_local(codegen, for_n.for_stmt_var_name, elt_from_ast, 0);
    }
}

fn c99_async_hoist_for_with_await_vars_rec(codegen: &C99CodeGenerator, fn_decl: &ASTNode, node: &ASTNode) void {
    if node == null {
        return;
    }
    if node.type == ASTNodeType.AST_BLOCK && node.block_stmts != null {
        var bi: i32 = 0;
        while bi < node.block_stmt_count {
            c99_async_hoist_for_with_await_vars_rec(codegen, fn_decl, node.block_stmts[bi]);
            bi = bi + 1;
        }
        return;
    }
    if node.type == ASTNodeType.AST_FOR_STMT && node.for_stmt_body != null {
        if c99_stmt_tree_has_await(node.for_stmt_body) != 0 {
            c99_async_hoist_one_for_with_await(codegen, fn_decl, node);
        }
        c99_async_hoist_for_with_await_vars_rec(codegen, fn_decl, node.for_stmt_body);
        return;
    }
    if node.type == ASTNodeType.AST_WHILE_STMT && node.while_stmt_body != null {
        c99_async_hoist_for_with_await_vars_rec(codegen, fn_decl, node.while_stmt_body);
        return;
    }
    if node.type == ASTNodeType.AST_IF_STMT {
        if node.if_stmt_then_branch != null {
            c99_async_hoist_for_with_await_vars_rec(codegen, fn_decl, node.if_stmt_then_branch);
        }
        if node.if_stmt_else_branch != null {
            c99_async_hoist_for_with_await_vars_rec(codegen, fn_decl, node.if_stmt_else_branch);
        }
    }
}

// 查找 (block, stmt_index) 对应的 await 索引（0-based），-1 = 不是 await 点
fn c99_async_find_await_at(codegen: &C99CodeGenerator, block: &ASTNode, si: i32) i32 {
    if codegen == null || block == null { return -1; }
    var j: i32 = 0;
    while j < codegen.async_collect_count && j < C99_ASYNC_MAX_AWAITS {
        if codegen.async_collect_stmt_indices[j] == si && codegen.async_collect_blocks[j] != null &&
            @usize_from_ptr(codegen.async_collect_blocks[j] as &void) == @usize_from_ptr(block as &void) {
            return j;
        }
        j = j + 1;
    }
    return -1;
}

// 生成 await 状态转移（前向）：设 state、arm future，不 return — 依赖 fall-through 到下一个 if(state==K+1)
fn c99_emit_async_arm_and_fallthrough(codegen: &C99CodeGenerator, await_index: i32) void {
    if codegen == null || await_index < 0 || await_index >= codegen.async_collect_count { return; }
    fprintf(codegen.emit_stream as *void, "        s->state = %d;\n" as *byte, await_index + 1);
    c99_emit_async_arm_await_index(codegen, await_index,
        codegen.async_collect_operands, codegen.async_collect_types,
        codegen.async_fn_decl,
        codegen.async_await_operand_is_err_future,
        codegen.async_full_return_type,
        codegen.async_concrete_future_safe,
        codegen.async_state_slot_iface_c);
}

// 生成 await 状态转移（回跳）：设 state、arm future、return Pending（while 回跳必须 yield）
fn c99_emit_async_arm_and_goto(codegen: &C99CodeGenerator, await_index: i32) void {
    c99_emit_async_arm_and_fallthrough(codegen, await_index);
    if codegen != null {
        fprintf(codegen.emit_stream as *void, "        return (%s){ ._tag = 0 };\n" as *byte, codegen.async_poll_ret_c as *byte);
    }
}

// 递归查找 needle 在 block 树中的位置，返回所在的父 block 和索引
// out_block[0] = 父 block, out_si[0] = 索引; 返回 1=找到, 0=未找到
fn c99_find_stmt_in_node_tree(needle: &ASTNode, node: &ASTNode, parent_block: &ASTNode, parent_si: i32, out_block: &&ASTNode, out_si: &i32) i32 {
    if needle == null || node == null {
        return 0;
    }
    if node.type == ASTNodeType.AST_BLOCK && node.block_stmts != null {
        var i: i32 = 0;
        while i < node.block_stmt_count {
            const ch: &ASTNode = node.block_stmts[i];
            if ch != null && @usize_from_ptr(ch as &void) == @usize_from_ptr(needle as &void) {
                out_block[0] = node;
                out_si[0] = i;
                return 1;
            }
            if ch != null && c99_find_stmt_in_node_tree(needle, ch, node, i, out_block, out_si) != 0 {
                return 1;
            }
            i = i + 1;
        }
        return 0;
    }
    if node.type == ASTNodeType.AST_IF_STMT {
        if node.if_stmt_then_branch != null &&
            c99_find_stmt_in_node_tree(needle, node.if_stmt_then_branch, parent_block, parent_si, out_block, out_si) != 0 {
            return 1;
        }
        if node.if_stmt_else_branch != null {
            if @usize_from_ptr(node.if_stmt_else_branch as &void) == @usize_from_ptr(needle as &void) {
                out_block[0] = parent_block;
                out_si[0] = parent_si;
                return 1;
            }
            if c99_find_stmt_in_node_tree(needle, node.if_stmt_else_branch, parent_block, parent_si, out_block, out_si) != 0 {
                return 1;
            }
        }
    } else if node.type == ASTNodeType.AST_WHILE_STMT && node.while_stmt_body != null {
        if c99_find_stmt_in_node_tree(needle, node.while_stmt_body, parent_block, parent_si, out_block, out_si) != 0 {
            return 1;
        }
    } else if node.type == ASTNodeType.AST_FOR_STMT && node.for_stmt_body != null {
        if c99_find_stmt_in_node_tree(needle, node.for_stmt_body, parent_block, parent_si, out_block, out_si) != 0 {
            return 1;
        }
    }
    return 0;
}

fn c99_find_stmt_in_block_tree(needle: &ASTNode, block: &ASTNode, out_block: &&ASTNode, out_si: &i32) i32 {
    return c99_find_stmt_in_node_tree(needle, block, null, -1, out_block, out_si);
}

// 在 fn_body 树中找 stmt 的位置，发射其后的剩余语句（通用：while/if/for 退出共用）
// 返回: 0 = 发射了状态转移, 1 = 到达末尾
fn emit_async_after_stmt(codegen: &C99CodeGenerator, stmt: &ASTNode) i32 {
    if codegen == null || stmt == null || codegen.async_fn_body == null { return 1; }
    var parent_block: [&ASTNode: 1] = [null];
    var stmt_si: [i32: 1] = [-1];
    if c99_find_stmt_in_block_tree(stmt, codegen.async_fn_body, &parent_block[0], &stmt_si[0]) == 0 {
        return 1;
    }
    const r: i32 = emit_async_segment(codegen, parent_block[0], stmt_si[0] + 1, parent_block[0].block_stmt_count);
    if r != 0 &&
        parent_block[0] != null &&
        @usize_from_ptr(parent_block[0] as &void) != @usize_from_ptr(codegen.async_fn_body as &void) {
        return emit_async_continue_in_parent(codegen, parent_block[0]);
    }
    return r;
}

// 递归查找 child_block 的父控制流语句（if/while/for），返回父 block + 父语句索引
fn c99_find_parent_of_block_node(child: &ASTNode, node: &ASTNode, parent_block: &ASTNode, parent_si: i32, out_block: &&ASTNode, out_si: &i32) i32 {
    if child == null || node == null {
        return 0;
    }
    if @usize_from_ptr(node as &void) == @usize_from_ptr(child as &void) {
        if parent_block != null {
            out_block[0] = parent_block;
            out_si[0] = parent_si;
            return 1;
        }
        return 0;
    }
    if node.type == ASTNodeType.AST_BLOCK && node.block_stmts != null {
        var i: i32 = 0;
        while i < node.block_stmt_count {
            const st: &ASTNode = node.block_stmts[i];
            if st != null {
                if c99_find_parent_of_block_node(child, st, node, i, out_block, out_si) != 0 {
                    return 1;
                }
            }
            i = i + 1;
        }
        return 0;
    }
    if node.type == ASTNodeType.AST_IF_STMT {
        if node.if_stmt_then_branch != null &&
            c99_find_parent_of_block_node(child, node.if_stmt_then_branch, parent_block, parent_si, out_block, out_si) != 0 {
            return 1;
        }
        if node.if_stmt_else_branch != null &&
            c99_find_parent_of_block_node(child, node.if_stmt_else_branch, parent_block, parent_si, out_block, out_si) != 0 {
            return 1;
        }
    } else if node.type == ASTNodeType.AST_WHILE_STMT && node.while_stmt_body != null {
        if c99_find_parent_of_block_node(child, node.while_stmt_body, parent_block, parent_si, out_block, out_si) != 0 {
            return 1;
        }
    } else if node.type == ASTNodeType.AST_FOR_STMT && node.for_stmt_body != null {
        if c99_find_parent_of_block_node(child, node.for_stmt_body, parent_block, parent_si, out_block, out_si) != 0 {
            return 1;
        }
    }
    return 0;
}

fn c99_find_parent_of_block(child: &ASTNode, search_in: &ASTNode, out_block: &&ASTNode, out_si: &i32) i32 {
    return c99_find_parent_of_block_node(child, search_in, null, -1, out_block, out_si);
}

// await 所在 block 结束后，沿父级上升继续发射。用于 if 分支 / 嵌套 block 结束时的 continuation 延续。
// 返回: 0 = 发射了转移, 1 = 到达函数体末尾
fn emit_async_continue_in_parent(codegen: &C99CodeGenerator, child_block: &ASTNode) i32 {
    if codegen == null || child_block == null || codegen.async_fn_body == null { return 1; }
    // child_block 就是函数体 → 顶层结束
    if @usize_from_ptr(child_block as &void) == @usize_from_ptr(codegen.async_fn_body as &void) { return 1; }
    var parent_blk: [&ASTNode: 1] = [null];
    var stmt_idx: [i32: 1] = [-1];
    if c99_find_parent_of_block(child_block, codegen.async_fn_body, &parent_blk[0], &stmt_idx[0]) == 0 {
        return 1;
    }
    const r: i32 = emit_async_segment(codegen, parent_blk[0], stmt_idx[0] + 1, parent_blk[0].block_stmt_count);
    if r != 0 &&
        parent_blk[0] != null &&
        @usize_from_ptr(parent_blk[0] as &void) != @usize_from_ptr(codegen.async_fn_body as &void) {
        return emit_async_continue_in_parent(codegen, parent_blk[0]);
    }
    return r;
}

fn emit_async_segment_with_control(codegen: &C99CodeGenerator, block: &ASTNode, from_si: i32, to_si: i32, control_while: &ASTNode, control_for: &ASTNode) i32 {
    if codegen == null {
        return 1;
    }
    const saved_while: &ASTNode = codegen.async_control_while;
    const saved_for: &ASTNode = codegen.async_control_for;
    codegen.async_control_while = control_while;
    codegen.async_control_for = control_for;
    const r: i32 = emit_async_segment(codegen, block, from_si, to_si);
    codegen.async_control_while = saved_while;
    codegen.async_control_for = saved_for;
    return r;
}

// while 循环退出后回跳或继续
fn emit_async_while_loopback_or_exit(codegen: &C99CodeGenerator, ew: &ASTNode) void {
    if codegen == null || ew == null || ew.type != ASTNodeType.AST_WHILE_STMT { return; }
    const wcond: &ASTNode = ew.while_stmt_condition;
    const wbody: &ASTNode = ew.while_stmt_body;
    if wbody == null { return; }
    var is_while_true: i32 = 0;
    if wcond != null && wcond.type == ASTNodeType.AST_BOOL && wcond.bool_literal_value != 0 {
        is_while_true = 1;
    }
    if is_while_true != 0 {
        // while true：无条件回跳进循环体（必须 return Pending 让出控制）
        emit_async_segment_with_control(codegen, wbody, 0, wbody.block_stmt_count, ew, null);
        fprintf(codegen.emit_stream as *void, "        return (%s){ ._tag = 0 };\n" as *byte, codegen.async_poll_ret_c as *byte);
    } else {
        fputs("        if (" as *byte, codegen.emit_stream as *void);
        gen_expr(codegen, wcond);
        fputs(") {\n" as *byte, codegen.emit_stream as *void);
        // 回跳：arm + return Pending
        emit_async_segment_with_control(codegen, wbody, 0, wbody.block_stmt_count, ew, null);
        fprintf(codegen.emit_stream as *void, "        return (%s){ ._tag = 0 };\n" as *byte, codegen.async_poll_ret_c as *byte);
        fputs("        } else {\n" as *byte, codegen.emit_stream as *void);
        const r: i32 = emit_async_after_stmt(codegen, ew);
        if r != 0 {
            fprintf(codegen.emit_stream as *void, "        s->state = %d;\n" as *byte, codegen.async_collect_count + 1);
        }
        fputs("        }\n" as *byte, codegen.emit_stream as *void);
    }
}

// while(含 await) 变换：条件检查 + 进入循环体 + 不成立时 fallthrough
fn emit_async_while_with_await(codegen: &C99CodeGenerator, while_stmt: &ASTNode, while_si: i32, parent_block: &ASTNode, parent_to_si: i32) void {
    if codegen == null || while_stmt == null { return; }
    const wcond: &ASTNode = while_stmt.while_stmt_condition;
    const wbody: &ASTNode = while_stmt.while_stmt_body;
    if wbody == null { return; }
    var is_while_true: i32 = 0;
    if wcond != null && wcond.type == ASTNodeType.AST_BOOL && wcond.bool_literal_value != 0 {
        is_while_true = 1;
    }
    if is_while_true != 0 {
        // while true：直接进入循环体
        emit_async_segment_with_control(codegen, wbody, 0, wbody.block_stmt_count, while_stmt, null);
        fprintf(codegen.emit_stream as *void, "        return (%s){ ._tag = 0 };\n" as *byte, codegen.async_poll_ret_c as *byte);
    } else {
        fputs("        if (" as *byte, codegen.emit_stream as *void);
        gen_expr(codegen, wcond);
        fputs(") {\n" as *byte, codegen.emit_stream as *void);
        emit_async_segment_with_control(codegen, wbody, 0, wbody.block_stmt_count, while_stmt, null);
        fprintf(codegen.emit_stream as *void, "        return (%s){ ._tag = 0 };\n" as *byte, codegen.async_poll_ret_c as *byte);
        fputs("        } else {\n" as *byte, codegen.emit_stream as *void);
        const r: i32 = emit_async_segment(codegen, parent_block, while_si + 1, parent_to_si);
        if r != 0 {
            // while 后无更多代码 — 跳到终态
            fprintf(codegen.emit_stream as *void, "        s->state = %d;\n" as *byte, codegen.async_collect_count + 1);
        }
        fputs("        }\n" as *byte, codegen.emit_stream as *void);
    }
}

// 带下标变量名的数组元素绑定（下标为状态机字段表达式，如 s->_uya_loc_xxx）
// async poll 内：写入 s->_uya_loc_<var>，使跨 await 后 gen_expr 仍解析到持久字段
fn c99_emit_async_for_array_iter_bind_indexed(codegen: &C99CodeGenerator, for_stmt: &ASTNode, elem_type_c: &byte, idx_c_safe: &byte) void {
    if codegen == null || for_stmt == null || elem_type_c == null || for_stmt.for_stmt_array == null || idx_c_safe == null {
        return;
    }
    const var_name2: &byte = get_safe_c_identifier(codegen, for_stmt.for_stmt_var_name);
    const array: &ASTNode = for_stmt.for_stmt_array;
    if var_name2 == null || codegen.async_state_var == null {
        return;
    }
    // 按引用 for |&x| 跨 await 需指针字段语义，另日完善
    if for_stmt.for_stmt_is_ref != 0 {
        return;
    }
    const bracket2: *byte = strchr(elem_type_c as *byte, 91);  // '['
    if bracket2 != null {
        const base_len2: i32 = ptr_diff(bracket2, elem_type_c as *byte);
        var tb2: [byte: TEMP_BUF_SIZE] = [];
        var j2: i32 = 0;
        while j2 < base_len2 && j2 < TEMP_BUF_LIMIT {
            tb2[j2] = elem_type_c[j2];
            j2 = j2 + 1;
        }
        if j2 >= 0 && j2 < TEMP_BUF_SIZE {
            tb2[j2] = 0;
        }
        fputs("        " as *byte, codegen.emit_stream as *void);
        fprintf(codegen.emit_stream as *void, "__uya_memcpy((void *)&%s->_uya_loc_%s, " as *byte,
            codegen.async_state_var as *byte, var_name2 as *byte);
        gen_expr(codegen, array);
        fputs("[" as *byte, codegen.emit_stream as *void);
        fputs(idx_c_safe as *byte, codegen.emit_stream as *void);
        fputs("], sizeof(" as *byte, codegen.emit_stream as *void);
        fprintf(codegen.emit_stream as *void, "%s->_uya_loc_%s));\n" as *byte, codegen.async_state_var as *byte, var_name2 as *byte);
    } else {
        fputs("        " as *byte, codegen.emit_stream as *void);
        fprintf(codegen.emit_stream as *void, "%s->_uya_loc_%s = " as *byte, codegen.async_state_var as *byte, var_name2 as *byte);
        gen_expr(codegen, array);
        fputs("[" as *byte, codegen.emit_stream as *void);
        fputs(idx_c_safe as *byte, codegen.emit_stream as *void);
        fputs("];\n" as *byte, codegen.emit_stream as *void);
    }
}

// for(含 await) 循环结束一轮后：递增/回跳或退出（与 emit_async_while_loopback_or_exit 对称）
fn emit_async_for_loopback_or_exit(codegen: &C99CodeGenerator, fs: &ASTNode) void {
    if codegen == null || fs == null || fs.type != ASTNodeType.AST_FOR_STMT {
        return;
    }
    const fbody: &ASTNode = fs.for_stmt_body;
    if fbody == null || fbody.type != ASTNodeType.AST_BLOCK {
        return;
    }
    if fs.for_stmt_is_range != 0 {
        const end_e: &ASTNode = fs.for_stmt_range_end;
        if end_e != null {
            if fs.for_stmt_var_name != null {
                const vn: &byte = get_safe_c_identifier(codegen, fs.for_stmt_var_name);
                const fe_raw: &byte = c99_async_for_fe_hoist_name(codegen, fs);
                const fe_s: &byte = get_safe_c_identifier(codegen, fe_raw);
                if vn != null && fe_s != null && codegen.async_state_var != null {
                    fprintf(codegen.emit_stream as *void, "        %s->_uya_loc_%s++;\n" as *byte,
                        codegen.async_state_var as *byte, vn as *byte);
                    fputs("        if (" as *byte, codegen.emit_stream as *void);
                    fprintf(codegen.emit_stream as *void, "%s->_uya_loc_%s < %s->_uya_loc_%s" as *byte,
                        codegen.async_state_var as *byte, vn as *byte, codegen.async_state_var as *byte, fe_s as *byte);
                    fputs(") {\n" as *byte, codegen.emit_stream as *void);
                    emit_async_segment_with_control(codegen, fbody, 0, fbody.block_stmt_count, null, fs);
                    fprintf(codegen.emit_stream as *void, "        return (%s){ ._tag = 0 };\n" as *byte, codegen.async_poll_ret_c as *byte);
                    fputs("        } else {\n" as *byte, codegen.emit_stream as *void);
                    const r2: i32 = emit_async_after_stmt(codegen, fs);
                    if r2 != 0 {
                        fprintf(codegen.emit_stream as *void, "        s->state = %d;\n" as *byte, codegen.async_collect_count + 1);
                    }
                    fputs("        }\n" as *byte, codegen.emit_stream as *void);
                }
            } else {
                const is3: &byte = get_safe_c_identifier(codegen, "_uya_i" as &byte);
                const es3: &byte = get_safe_c_identifier(codegen, "_uya_e" as &byte);
                if is3 != null && es3 != null && codegen.async_state_var != null {
                    fprintf(codegen.emit_stream as *void, "        %s->_uya_loc_%s++;\n" as *byte,
                        codegen.async_state_var as *byte, is3 as *byte);
                    fputs("        if (" as *byte, codegen.emit_stream as *void);
                    fprintf(codegen.emit_stream as *void, "%s->_uya_loc_%s < %s->_uya_loc_%s" as *byte,
                        codegen.async_state_var as *byte, is3 as *byte, codegen.async_state_var as *byte, es3 as *byte);
                    fputs(") {\n" as *byte, codegen.emit_stream as *void);
                    emit_async_segment_with_control(codegen, fbody, 0, fbody.block_stmt_count, null, fs);
                    fprintf(codegen.emit_stream as *void, "        return (%s){ ._tag = 0 };\n" as *byte, codegen.async_poll_ret_c as *byte);
                    fputs("        } else {\n" as *byte, codegen.emit_stream as *void);
                    const r3: i32 = emit_async_after_stmt(codegen, fs);
                    if r3 != 0 {
                        fprintf(codegen.emit_stream as *void, "        s->state = %d;\n" as *byte, codegen.async_collect_count + 1);
                    }
                    fputs("        }\n" as *byte, codegen.emit_stream as *void);
                }
            }
        } else {
            emit_async_segment_with_control(codegen, fbody, 0, fbody.block_stmt_count, null, fs);
            fprintf(codegen.emit_stream as *void, "        return (%s){ ._tag = 0 };\n" as *byte, codegen.async_poll_ret_c as *byte);
        }
        return;
    }
    var len_nm: [&byte: 1] = [null];
    var i_nm: [&byte: 1] = [null];
    c99_async_for_ar_hoist_names(codegen, fs, &len_nm[0], &i_nm[0]);
    const ln_s: &byte = get_safe_c_identifier(codegen, len_nm[0]);
    const ii_s: &byte = get_safe_c_identifier(codegen, i_nm[0]);
    const elem_ca: &byte = c99_async_for_array_elem_type_c(codegen, fs);
    if ln_s != null && ii_s != null && elem_ca != null && codegen.async_state_var != null {
        fprintf(codegen.emit_stream as *void, "        %s->_uya_loc_%s++;\n" as *byte,
            codegen.async_state_var as *byte, ii_s as *byte);
        fputs("        if (" as *byte, codegen.emit_stream as *void);
        fprintf(codegen.emit_stream as *void, "%s->_uya_loc_%s < %s->_uya_loc_%s" as *byte,
            codegen.async_state_var as *byte, ii_s as *byte, codegen.async_state_var as *byte, ln_s as *byte);
        fputs(") {\n" as *byte, codegen.emit_stream as *void);
        var idx_expr: [byte: 128] = [];
        snprintf(&idx_expr[0] as *byte, 128, "%s->_uya_loc_%s" as *byte, codegen.async_state_var as *byte, ii_s as *byte);
        c99_emit_async_for_array_iter_bind_indexed(codegen, fs, elem_ca, &idx_expr[0] as &byte);
        emit_async_segment_with_control(codegen, fbody, 0, fbody.block_stmt_count, null, fs);
        fprintf(codegen.emit_stream as *void, "        return (%s){ ._tag = 0 };\n" as *byte, codegen.async_poll_ret_c as *byte);
        fputs("        } else {\n" as *byte, codegen.emit_stream as *void);
        const r4: i32 = emit_async_after_stmt(codegen, fs);
        if r4 != 0 {
            fprintf(codegen.emit_stream as *void, "        s->state = %d;\n" as *byte, codegen.async_collect_count + 1);
        }
        fputs("        }\n" as *byte, codegen.emit_stream as *void);
    }
}

// for(含 await) 变换：范围/数组与 gen_for_* 对齐，循环变量在 async_local 中提升
fn emit_async_for_with_await(codegen: &C99CodeGenerator, for_stmt: &ASTNode, for_si: i32, parent_block: &ASTNode, parent_to_si: i32) void {
    if codegen == null || for_stmt == null {
        return;
    }
    const fbody: &ASTNode = for_stmt.for_stmt_body;
    if fbody == null || fbody.type != ASTNodeType.AST_BLOCK {
        return;
    }
    if for_stmt.for_stmt_is_range != 0 {
        const start_e: &ASTNode = for_stmt.for_stmt_range_start;
        const end_e: &ASTNode = for_stmt.for_stmt_range_end;
        if start_e == null {
            return;
        }
        if end_e != null {
            if for_stmt.for_stmt_var_name != null {
                const vn2: &byte = get_safe_c_identifier(codegen, for_stmt.for_stmt_var_name);
                const fe_r: &byte = c99_async_for_fe_hoist_name(codegen, for_stmt);
                const fe_s2: &byte = get_safe_c_identifier(codegen, fe_r);
                if vn2 != null && fe_s2 != null && codegen.async_state_var != null {
                    fputs("        {\n" as *byte, codegen.emit_stream as *void);
                    fprintf(codegen.emit_stream as *void, "        %s->_uya_loc_%s = " as *byte,
                        codegen.async_state_var as *byte, vn2 as *byte);
                    gen_expr(codegen, start_e);
                    fputs(";\n" as *byte, codegen.emit_stream as *void);
                    fprintf(codegen.emit_stream as *void, "        %s->_uya_loc_%s = " as *byte,
                        codegen.async_state_var as *byte, fe_s2 as *byte);
                    gen_expr(codegen, end_e);
                    fputs(";\n" as *byte, codegen.emit_stream as *void);
                    fputs("        if (" as *byte, codegen.emit_stream as *void);
                    fprintf(codegen.emit_stream as *void, "%s->_uya_loc_%s < %s->_uya_loc_%s" as *byte,
                        codegen.async_state_var as *byte, vn2 as *byte, codegen.async_state_var as *byte, fe_s2 as *byte);
                    fputs(") {\n" as *byte, codegen.emit_stream as *void);
                    emit_async_segment_with_control(codegen, fbody, 0, fbody.block_stmt_count, null, for_stmt);
                    fputs("        } else {\n" as *byte, codegen.emit_stream as *void);
                    const r5: i32 = emit_async_segment(codegen, parent_block, for_si + 1, parent_to_si);
                    if r5 != 0 {
                        fprintf(codegen.emit_stream as *void, "        s->state = %d;\n" as *byte, codegen.async_collect_count + 1);
                    }
                    fputs("        }\n" as *byte, codegen.emit_stream as *void);
                    fputs("        }\n" as *byte, codegen.emit_stream as *void);
                }
            } else {
                const ss2: &byte = get_safe_c_identifier(codegen, "_uya_s" as &byte);
                const ee2: &byte = get_safe_c_identifier(codegen, "_uya_e" as &byte);
                const ii2: &byte = get_safe_c_identifier(codegen, "_uya_i" as &byte);
                if ss2 != null && ee2 != null && ii2 != null && codegen.async_state_var != null {
                    fputs("        {\n" as *byte, codegen.emit_stream as *void);
                    fprintf(codegen.emit_stream as *void, "        %s->_uya_loc_%s = " as *byte,
                        codegen.async_state_var as *byte, ss2 as *byte);
                    gen_expr(codegen, start_e);
                    fputs(";\n" as *byte, codegen.emit_stream as *void);
                    fprintf(codegen.emit_stream as *void, "        %s->_uya_loc_%s = " as *byte,
                        codegen.async_state_var as *byte, ee2 as *byte);
                    gen_expr(codegen, end_e);
                    fputs(";\n" as *byte, codegen.emit_stream as *void);
                    fprintf(codegen.emit_stream as *void, "        %s->_uya_loc_%s = %s->_uya_loc_%s;\n" as *byte,
                        codegen.async_state_var as *byte, ii2 as *byte, codegen.async_state_var as *byte, ss2 as *byte);
                    fputs("        if (" as *byte, codegen.emit_stream as *void);
                    fprintf(codegen.emit_stream as *void, "%s->_uya_loc_%s < %s->_uya_loc_%s" as *byte,
                        codegen.async_state_var as *byte, ii2 as *byte, codegen.async_state_var as *byte, ee2 as *byte);
                    fputs(") {\n" as *byte, codegen.emit_stream as *void);
                    emit_async_segment_with_control(codegen, fbody, 0, fbody.block_stmt_count, null, for_stmt);
                    fputs("        } else {\n" as *byte, codegen.emit_stream as *void);
                    const r6: i32 = emit_async_segment(codegen, parent_block, for_si + 1, parent_to_si);
                    if r6 != 0 {
                        fprintf(codegen.emit_stream as *void, "        s->state = %d;\n" as *byte, codegen.async_collect_count + 1);
                    }
                    fputs("        }\n" as *byte, codegen.emit_stream as *void);
                    fputs("        }\n" as *byte, codegen.emit_stream as *void);
                }
            }
        } else {
            if for_stmt.for_stmt_var_name != null {
                const vn3: &byte = get_safe_c_identifier(codegen, for_stmt.for_stmt_var_name);
                if vn3 != null && codegen.async_state_var != null {
                    fprintf(codegen.emit_stream as *void, "        %s->_uya_loc_%s = " as *byte,
                        codegen.async_state_var as *byte, vn3 as *byte);
                    gen_expr(codegen, start_e);
                    fputs(";\n" as *byte, codegen.emit_stream as *void);
                    emit_async_segment_with_control(codegen, fbody, 0, fbody.block_stmt_count, null, for_stmt);
                }
            }
        }
        return;
    }
    if for_stmt.for_stmt_is_ref != 0 {
        fprintf(stderr as *void, "错误: @async_fn 中 for |&x| 数组迭代与 @await 尚未支持\n" as *byte);
        const r_ref: i32 = emit_async_segment(codegen, parent_block, for_si + 1, parent_to_si);
        if r_ref != 0 {
            fprintf(codegen.emit_stream as *void, "        s->state = %d;\n" as *byte, codegen.async_collect_count + 1);
        }
        return;
    }
    const elem_cb: &byte = c99_async_for_array_elem_type_c(codegen, for_stmt);
    if elem_cb == null {
        fprintf(stderr as *void, "错误: @async_fn 中 for 数组迭代若为迭代器接口形式，@await 尚未支持\n" as *byte);
        const r7: i32 = emit_async_segment(codegen, parent_block, for_si + 1, parent_to_si);
        if r7 != 0 {
            fprintf(codegen.emit_stream as *void, "        s->state = %d;\n" as *byte, codegen.async_collect_count + 1);
        }
        return;
    }
    var len_nm2: [&byte: 1] = [null];
    var i_nm2: [&byte: 1] = [null];
    c99_async_for_ar_hoist_names(codegen, for_stmt, &len_nm2[0], &i_nm2[0]);
    const ln_s2: &byte = get_safe_c_identifier(codegen, len_nm2[0]);
    const ii_s2: &byte = get_safe_c_identifier(codegen, i_nm2[0]);
    if ln_s2 != null && ii_s2 != null && codegen.async_state_var != null {
        fputs("        {\n" as *byte, codegen.emit_stream as *void);
        fputs("        " as *byte, codegen.emit_stream as *void);
        fprintf(codegen.emit_stream as *void, "%s->_uya_loc_%s = sizeof(" as *byte,
            codegen.async_state_var as *byte, ln_s2 as *byte);
        gen_expr(codegen, for_stmt.for_stmt_array);
        fputs(") / sizeof(" as *byte, codegen.emit_stream as *void);
        gen_expr(codegen, for_stmt.for_stmt_array);
        fputs("[0]);\n" as *byte, codegen.emit_stream as *void);
        fprintf(codegen.emit_stream as *void, "        %s->_uya_loc_%s = 0;\n" as *byte,
            codegen.async_state_var as *byte, ii_s2 as *byte);
        fputs("        if (" as *byte, codegen.emit_stream as *void);
        fprintf(codegen.emit_stream as *void, "%s->_uya_loc_%s < %s->_uya_loc_%s" as *byte,
            codegen.async_state_var as *byte, ii_s2 as *byte, codegen.async_state_var as *byte, ln_s2 as *byte);
        fputs(") {\n" as *byte, codegen.emit_stream as *void);
        var idx_expr2: [byte: 128] = [];
        snprintf(&idx_expr2[0] as *byte, 128, "%s->_uya_loc_%s" as *byte, codegen.async_state_var as *byte, ii_s2 as *byte);
        c99_emit_async_for_array_iter_bind_indexed(codegen, for_stmt, elem_cb, &idx_expr2[0] as &byte);
        emit_async_segment_with_control(codegen, fbody, 0, fbody.block_stmt_count, null, for_stmt);
        fputs("        } else {\n" as *byte, codegen.emit_stream as *void);
        const r8: i32 = emit_async_segment(codegen, parent_block, for_si + 1, parent_to_si);
        if r8 != 0 {
            fprintf(codegen.emit_stream as *void, "        s->state = %d;\n" as *byte, codegen.async_collect_count + 1);
        }
        fputs("        }\n" as *byte, codegen.emit_stream as *void);
        fputs("        }\n" as *byte, codegen.emit_stream as *void);
    }
}

// if/else(含 await) 变换：每个分支递归段发射，无 await 的分支同步执行后 fallthrough 到 if 后代码
fn emit_async_if_with_await(codegen: &C99CodeGenerator, if_stmt: &ASTNode, if_si: i32, parent_block: &ASTNode, parent_to_si: i32) void {
    if codegen == null || if_stmt == null { return; }
    const cond: &ASTNode = if_stmt.if_stmt_condition;
    const then_br: &ASTNode = if_stmt.if_stmt_then_branch;
    const else_br: &ASTNode = if_stmt.if_stmt_else_branch;
    var then_has_await: i32 = 0;
    var else_has_await: i32 = 0;
    if then_br != null { then_has_await = c99_stmt_tree_has_await(then_br); }
    if else_br != null { else_has_await = c99_stmt_tree_has_await(else_br); }
    fputs("        if (" as *byte, codegen.emit_stream as *void);
    gen_expr(codegen, cond);
    fputs(") {\n" as *byte, codegen.emit_stream as *void);
    if then_has_await != 0 {
        // then 分支含 await：递归段发射（arm await 后 fall through 到对应 state handler）
        if then_br != null && then_br.type == ASTNodeType.AST_BLOCK {
            emit_async_segment(codegen, then_br, 0, then_br.block_stmt_count);
        }
    } else {
        // then 分支无 await：同步执行全部语句，然后 fallthrough 到 if 后代码
        if then_br != null && then_br.type == ASTNodeType.AST_BLOCK && then_br.block_stmts != null {
            var ti: i32 = 0;
            while ti < then_br.block_stmt_count {
                if then_br.block_stmts[ti] != null { gen_stmt(codegen, then_br.block_stmts[ti]); }
                ti = ti + 1;
            }
        }
        const then_r: i32 = emit_async_segment(codegen, parent_block, if_si + 1, parent_to_si);
        if then_r != 0 {
            fprintf(codegen.emit_stream as *void, "        s->state = %d;\n" as *byte, codegen.async_collect_count + 1);
        }
    }
    fputs("        } else {\n" as *byte, codegen.emit_stream as *void);
    if else_has_await != 0 {
        if else_br != null && else_br.type == ASTNodeType.AST_BLOCK {
            emit_async_segment(codegen, else_br, 0, else_br.block_stmt_count);
        } else if else_br != null && else_br.type == ASTNodeType.AST_IF_STMT {
            emit_async_if_with_await(codegen, else_br, if_si, parent_block, parent_to_si);
        }
    } else {
        // else 分支无 await（或无 else）：同步执行，然后 fallthrough 到 if 后代码
        if else_br != null && else_br.type == ASTNodeType.AST_BLOCK && else_br.block_stmts != null {
            var ei: i32 = 0;
            while ei < else_br.block_stmt_count {
                if else_br.block_stmts[ei] != null { gen_stmt(codegen, else_br.block_stmts[ei]); }
                ei = ei + 1;
            }
        } else if else_br != null && else_br.type == ASTNodeType.AST_IF_STMT {
            gen_stmt(codegen, else_br);
        }
        const else_r: i32 = emit_async_segment(codegen, parent_block, if_si + 1, parent_to_si);
        if else_r != 0 {
            fprintf(codegen.emit_stream as *void, "        s->state = %d;\n" as *byte, codegen.async_collect_count + 1);
        }
    }
    fputs("        }\n" as *byte, codegen.emit_stream as *void);
}

/// 发射单个提升到状态机的局部变量初始化（s->_uya_loc_name = expr）
fn c99_emit_async_local_init_single(codegen: &C99CodeGenerator, stmt: &ASTNode) i32 {
    if codegen == null || stmt == null || codegen.async_state_var == null { return 0; }
    if stmt.type != ASTNodeType.AST_VAR_DECL || stmt.var_decl_name == null { return 0; }
    if stmt.var_decl_init != null && c99_stmt_tree_has_await(stmt.var_decl_init) != 0 {
        return 0;
    }
    // 检查是否在 async_local_names 中
    var li: i32 = 0;
    while li < codegen.async_local_count && li < @len(codegen.async_local_names) {
        if codegen.async_local_names[li] != null &&
            strcmp(codegen.async_local_names[li] as *byte, stmt.var_decl_name as *byte) == 0 {
            const ls: &byte = get_safe_c_identifier(codegen, stmt.var_decl_name);
            const ie: &ASTNode = stmt.var_decl_init;
            const ltype: &ASTNode = stmt.var_decl_type;
            if ls == null || ie == null { return 1; }
            // 定长数组：memcpy
            if ltype != null && ltype.type == ASTNodeType.AST_TYPE_ARRAY &&
                ltype.type_array_element_type != null && ie.type == ASTNodeType.AST_ARRAY_LITERAL {
                const elem_c: &byte = c99_type_to_c(codegen, ltype.type_array_element_type);
                if elem_c != null {
                    var lit_len: i32 = ie.array_literal_element_count;
                    if ie.array_literal_repeat_count_expr != null && ie.array_literal_element_count >= 1 {
                        const rep_n: i32 = eval_const_expr(codegen, ie.array_literal_repeat_count_expr);
                        if rep_n >= 0 { lit_len = rep_n; }
                    }
                    const arr_n: i32 = eval_const_expr(codegen, ltype.type_array_size_expr);
                    if arr_n > 0 && lit_len >= 0 && lit_len < arr_n {
                        fprintf(codegen.emit_stream as *void,
                            "        __builtin_memset((void *)&%s->_uya_loc_%s, 0, sizeof(%s->_uya_loc_%s));\n" as *byte,
                            codegen.async_state_var as *byte, ls as *byte, codegen.async_state_var as *byte, ls as *byte);
                        if lit_len > 0 {
                            fprintf(codegen.emit_stream as *void, "        __uya_memcpy((void *)%s->_uya_loc_%s, (const void *)(const " as *byte,
                                codegen.async_state_var as *byte, ls as *byte);
                            fputs(elem_c as *byte, codegen.emit_stream as *void);
                            fputs("[]){" as *byte, codegen.emit_stream as *void);
                            gen_array_literal_contents(codegen, ie);
                            fprintf(codegen.emit_stream as *void,
                                "}, ((size_t)(%d)) * sizeof(%s->_uya_loc_%s[0]));\n" as *byte,
                                lit_len, codegen.async_state_var as *byte, ls as *byte);
                        }
                    } else {
                        fprintf(codegen.emit_stream as *void, "        __uya_memcpy((void *)%s->_uya_loc_%s, (const void *)(const " as *byte,
                            codegen.async_state_var as *byte, ls as *byte);
                        fputs(elem_c as *byte, codegen.emit_stream as *void);
                        fputs("[]){" as *byte, codegen.emit_stream as *void);
                        gen_array_literal_contents(codegen, ie);
                        fprintf(codegen.emit_stream as *void, "}, sizeof(%s->_uya_loc_%s));\n" as *byte,
                            codegen.async_state_var as *byte, ls as *byte);
                    }
                    return 1;
                }
            }
            // 普通类型：简单赋值
            fprintf(codegen.emit_stream as *void, "        %s->_uya_loc_%s = " as *byte,
                codegen.async_state_var as *byte, ls as *byte);
            gen_expr(codegen, ie);
            fputs(";\n" as *byte, codegen.emit_stream as *void);
            return 1;
        }
        li = li + 1;
    }
    return 0;
}

/// 递归段发射：遍历 block.stmts[from_si..to_si)，对普通语句调 gen_stmt，遇 await 分裂则状态转移。
/// 返回: 0 = 已发射状态转移(await armed), 1 = 到达范围末尾无转移
fn emit_async_segment(codegen: &C99CodeGenerator, block: &ASTNode, from_si: i32, to_si: i32) i32 {
    if codegen == null || block == null || block.type != ASTNodeType.AST_BLOCK || block.block_stmts == null {
        return 1;
    }
    var si: i32 = from_si;
    while si < to_si && si < block.block_stmt_count {
        const stmt: &ASTNode = block.block_stmts[si];
        if stmt == null {
            si = si + 1;
            continue;
        }
        // try @await 绑定：这是分裂点
        if stmt.type == ASTNodeType.AST_VAR_DECL && stmt.var_decl_init != null &&
            c99_var_decl_init_is_try_await_bind(stmt.var_decl_init) != 0 {
            const ai: i32 = c99_async_find_await_at(codegen, block, si);
            if ai >= 0 {
                c99_emit_async_arm_and_fallthrough(codegen, ai);
                return 0;
            }
        }
        // return try @await：分裂点
        if stmt.type == ASTNodeType.AST_RETURN_STMT && stmt.return_stmt_expr != null &&
            c99_stmt_tree_has_await(stmt) != 0 {
            const ai: i32 = c99_async_find_await_at(codegen, block, si);
            if ai >= 0 {
                c99_emit_async_arm_and_fallthrough(codegen, ai);
                return 0;
            }
        }
        // while 含 await：变换
        if stmt.type == ASTNodeType.AST_WHILE_STMT && stmt.while_stmt_body != null &&
            c99_stmt_tree_has_await(stmt.while_stmt_body) != 0 {
            emit_async_while_with_await(codegen, stmt, si, block, to_si);
            return 0;
        }
        // for 含 await：范围/定长数组 for 变换（迭代器接口形式见 emit_async_for_with_await 内提示）
        if stmt.type == ASTNodeType.AST_FOR_STMT && stmt.for_stmt_body != null &&
            c99_stmt_tree_has_await(stmt.for_stmt_body) != 0 {
            emit_async_for_with_await(codegen, stmt, si, block, to_si);
            return 0;
        }
        // 嵌套 block 含 await：递归 lower，保留块内同步语句与局部变量
        if stmt.type == ASTNodeType.AST_BLOCK && stmt.block_stmts != null &&
            c99_stmt_tree_has_await(stmt) != 0 {
            const nested_r: i32 = emit_async_segment(codegen, stmt, 0, stmt.block_stmt_count);
            if nested_r == 0 {
                return 0;
            }
            si = si + 1;
            continue;
        }
        // if 含 await：分支递归段发射
        if stmt.type == ASTNodeType.AST_IF_STMT {
            var then_has: i32 = 0;
            var else_has: i32 = 0;
            if stmt.if_stmt_then_branch != null { then_has = c99_stmt_tree_has_await(stmt.if_stmt_then_branch); }
            if stmt.if_stmt_else_branch != null { else_has = c99_stmt_tree_has_await(stmt.if_stmt_else_branch); }
            if then_has != 0 || else_has != 0 {
                emit_async_if_with_await(codegen, stmt, si, block, to_si);
                return 0;
            }
        }
        // 提升到状态机的局部变量：发射 s->_uya_loc_name = expr
        if stmt.type == ASTNodeType.AST_VAR_DECL && stmt.var_decl_init != null &&
            c99_emit_async_local_init_single(codegen, stmt) != 0 {
            si = si + 1;
            continue;
        }
        // 复合表达式里的 try @await：把当前语句当成分裂点，resume 后再重放整条语句。
        if stmt.type != ASTNodeType.AST_BLOCK && stmt.type != ASTNodeType.AST_IF_STMT &&
            stmt.type != ASTNodeType.AST_WHILE_STMT && stmt.type != ASTNodeType.AST_FOR_STMT {
            var nested_try: [&ASTNode: 1] = [null];
            if c99_find_first_try_await_expr(stmt, &nested_try[0]) != 0 && nested_try[0] != null &&
                nested_try[0].try_expr_operand != null && nested_try[0].try_expr_operand.type == ASTNodeType.AST_AWAIT_EXPR &&
                nested_try[0].try_expr_operand.await_expr_operand != null {
                const ai2: i32 = c99_async_find_await_at(codegen, block, si);
                if ai2 >= 0 {
                    c99_emit_async_arm_and_fallthrough(codegen, ai2);
                    return 0;
                }
            }
        }
        // return 语句：仅对块末尾的尾部 return 停止（由 state loop 的 return Ready 逻辑处理，
        // 因 return_future_err_union 等需要 Future boxing）；中间 return（提前返回）走 gen_stmt。
        if stmt.type == ASTNodeType.AST_RETURN_STMT {
            if si + 1 >= to_si || si + 1 >= block.block_stmt_count {
                // 块末尾的 return：停止段发射，由调用方显式生成 return Ready
                return 1;
            }
            // 中间 return（if 分支内提前返回等）：由 gen_stmt + async_emit_poll_return 处理
            gen_stmt(codegen, stmt);
            si = si + 1;
            continue;
        }
        // 普通语句
        gen_stmt(codegen, stmt);
        si = si + 1;
    }
    return 1;
}

/// state K 的 continuation：await K-1 就绪后发射后续代码
/// 返回: 1 = 到达 return 语句（需调用方发射 return Ready），0 = 已完成状态转移
fn emit_async_continuation(codegen: &C99CodeGenerator, cur_ai: i32) i32 {
    if codegen == null {
        return 0;
    }
    if cur_ai < 0 {
        return 0;
    }
    if cur_ai >= codegen.async_collect_count {
        return 0;
    }
    if cur_ai >= C99_ASYNC_MAX_AWAITS {
        return 0;
    }
    const ew: &ASTNode = codegen.async_collect_enclosing_while[cur_ai];
    const ab: &ASTNode = codegen.async_collect_blocks[cur_ai];
    const asi: i32 = codegen.async_collect_stmt_indices[cur_ai];
    if ab == null { return 0; }
    var cur_stmt: &ASTNode = null;
    if ab.block_stmts != null && asi >= 0 && asi < ab.block_stmt_count {
        cur_stmt = ab.block_stmts[asi];
    }
    const saved_epr: i32 = codegen.async_emit_poll_return;
    codegen.async_emit_poll_return = 1;
    var result: i32 = 0;
    if cur_stmt != null && cur_stmt.type != ASTNodeType.AST_BLOCK && cur_stmt.type != ASTNodeType.AST_IF_STMT &&
        cur_stmt.type != ASTNodeType.AST_WHILE_STMT && cur_stmt.type != ASTNodeType.AST_FOR_STMT {
        var nested_try: [&ASTNode: 1] = [null];
        if c99_find_first_try_await_expr(cur_stmt, &nested_try[0]) != 0 && nested_try[0] != null &&
            nested_try[0].try_expr_operand != null && nested_try[0].try_expr_operand.type == ASTNodeType.AST_AWAIT_EXPR &&
            nested_try[0].try_expr_operand.await_expr_operand != null &&
            (cur_stmt.type != ASTNodeType.AST_VAR_DECL || c99_var_decl_init_is_try_await_bind(cur_stmt.var_decl_init) == 0) &&
            c99_return_stmt_is_try_await_bind(cur_stmt) == 0 {
            const saved_subst_try_expr: &ASTNode = codegen.async_expr_subst_try_expr;
            const saved_subst_name: &byte = codegen.async_expr_subst_name;
            codegen.async_expr_subst_try_expr = nested_try[0];
            codegen.async_expr_subst_name = codegen.async_bind_names[cur_ai];
            gen_stmt(codegen, cur_stmt);
            codegen.async_expr_subst_try_expr = saved_subst_try_expr;
            codegen.async_expr_subst_name = saved_subst_name;
            if cur_stmt.type == ASTNodeType.AST_RETURN_STMT {
                codegen.async_emit_poll_return = saved_epr;
                return 1;
            }
        }
    }
    if ew != null && ew.type == ASTNodeType.AST_WHILE_STMT {
        // await 在 while 内：发射 while 体剩余语句
        const reached_end: i32 = emit_async_segment_with_control(codegen, ab, asi + 1, ab.block_stmt_count, ew, null);
        if reached_end != 0 {
            // 最后一个 await 在 while 内 → 回跳或退出
            emit_async_while_loopback_or_exit(codegen, ew);
        }
    } else {
        const ef: &ASTNode = codegen.async_collect_enclosing_for[cur_ai];
        if ef != null && ef.type == ASTNodeType.AST_FOR_STMT {
            const reached_for: i32 = emit_async_segment_with_control(codegen, ab, asi + 1, ab.block_stmt_count, null, ef);
            if reached_for != 0 {
                emit_async_for_loopback_or_exit(codegen, ef);
            }
        } else {
            // 非循环 await：发射 block 剩余语句（遇 return 语句停止）
            const r: i32 = emit_async_segment(codegen, ab, asi + 1, ab.block_stmt_count);
            if r != 0 {
                // 块结束：如果不是函数体顶层，沿父级上升继续（if 分支结束后继续 if 后代码）
                if codegen.async_fn_body != null && @usize_from_ptr(ab as &void) != @usize_from_ptr(codegen.async_fn_body as &void) {
                    const pr: i32 = emit_async_continue_in_parent(codegen, ab);
                    if pr != 0 { result = 1; }
                } else {
                    result = 1;  // 函数体顶层到达 return → 需调用方发射 return Ready
                }
            }
        }
    }
    codegen.async_emit_poll_return = saved_epr;
    return result;
}

fn emit_async_no_await_ready_return(
    codegen: &C99CodeGenerator,
    fn_decl: &ASTNode,
    full_return_type: &ASTNode,
    effective_return_type: &ASTNode,
    ret_expr: &ASTNode,
    inner: &ASTNode,
    inner_is_err_union: i32,
    inner_err_c: &byte,
    iface_c: &byte,
    concrete_future_safe: &byte,
    inner_poll_ret_c: &byte,
    inner_poll_union_c: &byte,
    poll_ret_c: &byte,
    poll_union_c: &byte
) void {
    if codegen == null || poll_ret_c == null || poll_union_c == null {
        return;
    }
    if full_return_type != null && full_return_type.type == ASTNodeType.AST_TYPE_ERROR_UNION {
        const pl: &ASTNode = full_return_type.type_error_union_payload_type;
        var is_future_payload: i32 = 0;
        if pl != null && pl.type == ASTNodeType.AST_TYPE_NAMED && pl.type_named_name != null && strcmp(pl.type_named_name as *byte, "Future" as *byte) == 0 {
            is_future_payload = 1;
        }
        if is_future_payload != 0 {
            var no_await_is_future_literal: i32 = 0;
            if ret_expr != null && ret_expr.type == ASTNodeType.AST_STRUCT_INIT && ret_expr.struct_init_struct_name != null &&
                strcmp(ret_expr.struct_init_struct_name as *byte, "Future" as *byte) == 0 {
                no_await_is_future_literal = 1;
            }
            const no_await_ret_c: &byte = c99_type_to_c(codegen, full_return_type);
            if no_await_ret_c != null && concrete_future_safe != null {
                fprintf(codegen.emit_stream as *void, "        %s ok = (%s){ .error_id = 0, .value = " as *byte, no_await_ret_c as *byte, no_await_ret_c as *byte);
                codegen.current_function_return_type = effective_return_type;
                if ret_expr != null {
                    if no_await_is_future_literal != 0 {
                        fprintf(codegen.emit_stream as *void, "({ struct %s *_uya_box = (struct %s *)std_async_box_alloc_current(sizeof(struct %s)); if (_uya_box != (void*)0) { *_uya_box = " as *byte, concrete_future_safe as *byte, concrete_future_safe as *byte, concrete_future_safe as *byte);
                        gen_expr(codegen, ret_expr);
                        fprintf(codegen.emit_stream as *void, "; } (%s){ .vtable = (void*)&uya_vtable_%s_%s, .data = (void*)_uya_box }; })" as *byte, iface_c as *byte, concrete_future_safe as *byte, concrete_future_safe as *byte);
                    } else {
                        fprintf(codegen.emit_stream as *void, "({ struct %s *_uya_box = (struct %s *)std_async_box_alloc_current(sizeof(struct %s)); if (_uya_box != (void*)0) { *_uya_box = (struct %s){ .state = (%s){ ._tag = 1, .u = (%s){ .Ready = " as *byte,
                            concrete_future_safe as *byte, concrete_future_safe as *byte, concrete_future_safe as *byte, concrete_future_safe as *byte, inner_poll_ret_c as *byte, inner_poll_union_c as *byte);
                        gen_expr(codegen, ret_expr);
                        fprintf(codegen.emit_stream as *void, " } } }; } (%s){ .vtable = (void*)&uya_vtable_%s_%s, .data = (void*)_uya_box }; })" as *byte, iface_c as *byte, concrete_future_safe as *byte, concrete_future_safe as *byte);
                    }
                } else {
                    fprintf(codegen.emit_stream as *void, "(%s){ .vtable = (void*)0, .data = (void*)0 }" as *byte, iface_c as *byte);
                }
                codegen.current_function_return_type = null;
                fputs(" };\n" as *byte, codegen.emit_stream as *void);
                if no_await_is_future_literal != 0 {
                    fprintf(codegen.emit_stream as *void, "        return (%s){ ._tag = 1, .u = (%s){ .Ready = ok.value } };\n" as *byte, poll_ret_c as *byte, poll_union_c as *byte);
                } else {
                    fprintf(codegen.emit_stream as *void, "        return (%s){ ._tag = 1, .u = (%s){ .Ready = (*(struct %s *)ok.value.data).state.u.Ready } };\n" as *byte, poll_ret_c as *byte, poll_union_c as *byte, concrete_future_safe as *byte);
                }
            } else {
                fprintf(codegen.emit_stream as *void, "        return (%s){ ._tag = 0 };\n" as *byte, poll_ret_c as *byte);
            }
            return;
        }
    }
    if inner_is_err_union != 0 {
        if inner != null && inner.type_error_union_payload_type != null &&
            inner.type_error_union_payload_type.type == ASTNodeType.AST_TYPE_NAMED &&
            inner.type_error_union_payload_type.type_named_name != null &&
            strcmp(inner.type_error_union_payload_type.type_named_name as *byte, "void" as *byte) == 0 {
            fprintf(codegen.emit_stream as *void, "        %s ok = (%s){ .error_id = 0 };\n" as *byte, inner_err_c as *byte, inner_err_c as *byte);
        } else {
            fprintf(codegen.emit_stream as *void, "        %s ok = (%s){ .error_id = 0, .value = " as *byte, inner_err_c as *byte, inner_err_c as *byte);
            if ret_expr != null {
                gen_expr(codegen, ret_expr);
            } else {
                fputs("0" as *byte, codegen.emit_stream as *void);
            }
            fputs(" };\n" as *byte, codegen.emit_stream as *void);
        }
        fprintf(codegen.emit_stream as *void, "        return (%s){ ._tag = 1, .u = (%s){ .Ready = ok } };\n" as *byte, poll_ret_c as *byte, poll_union_c as *byte);
        return;
    }
    codegen.current_function_return_type = effective_return_type;
    fprintf(codegen.emit_stream as *void, "        return (%s){ ._tag = 1, .u = (%s){ .Ready = " as *byte, poll_ret_c as *byte, poll_union_c as *byte);
    if ret_expr != null {
        gen_expr(codegen, ret_expr);
    } else {
        fputs("0" as *byte, codegen.emit_stream as *void);
    }
    codegen.current_function_return_type = null;
    fputs(" } };\n" as *byte, codegen.emit_stream as *void);
}

// ===== async stage-B codegen（单 @await 最小状态机）=====
// full_return_type: 函数声明的返回类型（可为 !Future<T> 或 Future<!T>）
// effective_return_type: 用于状态机的 Future 类型（Future<T> 或 Future<!T>）
fn c99_type_to_c_async_method_opt(codegen: &C99CodeGenerator, type_node: &ASTNode) &byte {
    if codegen == null {
        return null;
    }
    if codegen.current_method_struct_name != null {
        return c99_type_to_c_with_self(codegen, type_node, codegen.current_method_struct_name);
    }
    return c99_type_to_c(codegen, type_node);
}

fn gen_async_function_stage_b(codegen: &C99CodeGenerator, fn_decl: &ASTNode, func_c_name: &byte, full_return_type: &ASTNode, effective_return_type: &ASTNode, only_struct: i32) void {
    if codegen == null || fn_decl == null || effective_return_type == null {
        return;
    }
    if effective_return_type.type != ASTNodeType.AST_TYPE_NAMED || effective_return_type.type_named_name == null ||
        strcmp(effective_return_type.type_named_name as *byte, "Future" as *byte) != 0 ||
        effective_return_type.type_named_type_arg_count != 1 || effective_return_type.type_named_type_args == null {
        return;
    }
    var inner: &ASTNode = effective_return_type.type_named_type_args[0];
    if inner == null {
        return;
    }
    var inner_is_err_union: i32 = 0;
    if inner.type == ASTNodeType.AST_TYPE_ERROR_UNION && inner.type_error_union_payload_type != null {
        inner_is_err_union = 1;
    }
    // 当函数返回 !Future<T> 时，子调用返回 !Future<T>，需 try 取 .value；且 poll 需能返回错误，故用 Poll<!T>
    if full_return_type != null && full_return_type.type == ASTNodeType.AST_TYPE_ERROR_UNION &&
        full_return_type.type_error_union_payload_type != null {
        const pl: &ASTNode = full_return_type.type_error_union_payload_type;
        if pl.type == ASTNodeType.AST_TYPE_NAMED && pl.type_named_name != null &&
            strcmp(pl.type_named_name as *byte, "Future" as *byte) == 0 {
            const payload_t: &ASTNode = effective_return_type.type_named_type_args[0];
            const inner_err_node: &ASTNode = ast_new_node(ASTNodeType.AST_TYPE_ERROR_UNION, 0, 0, codegen.arena, null);
            if inner_err_node != null {
                inner_err_node.type_error_union_payload_type = payload_t;
                inner = inner_err_node;
                inner_is_err_union = 1;
            }
        }
    }

    // 生成单态名：Future_T / Future_err_T、Poll_T / Poll_err_T
    const type_args: & & ASTNode = compiler_arena_alloc(codegen.arena, @size_of(&ASTNode)) as & & ASTNode;
    if type_args == null {
        return;
    }
    type_args[0] = inner;
    const future_mono: &byte = get_mono_struct_name(codegen, "Future" as &byte, type_args, 1);
    const safe_future: &byte = get_safe_c_identifier(codegen, future_mono);
    var vtable_future_safe: &byte = safe_future;
    const iface_c: &byte = c99_type_to_c_async_method_opt(codegen, effective_return_type);
    const inner_err_c: &byte = c99_type_to_c_async_method_opt(codegen, inner);
    var outer_err_payload_value_c: &byte = null;
    if inner.type == ASTNodeType.AST_TYPE_ERROR_UNION && inner.type_error_union_payload_type != null {
        outer_err_payload_value_c = c99_type_to_c_async_method_opt(codegen, inner.type_error_union_payload_type);
    }
    var concrete_future_safe: &byte = safe_future;
    if effective_return_type.type_named_type_args != null && effective_return_type.type_named_type_arg_count >= 1 {
        var slot_ta: & & ASTNode = effective_return_type.type_named_type_args;
        var slot_tc: i32 = effective_return_type.type_named_type_arg_count;
        const arg0: &ASTNode = effective_return_type.type_named_type_args[0];
        if arg0 != null && arg0.type == ASTNodeType.AST_TYPE_ERROR_UNION && arg0.type_error_union_payload_type != null {
            const one_arg: & & ASTNode = compiler_arena_alloc(codegen.arena, @size_of(&ASTNode) * 2) as & & ASTNode;
            if one_arg != null {
                one_arg[0] = arg0.type_error_union_payload_type;
                slot_ta = one_arg;
                slot_tc = 1;
            }
        }
        const payload_future_mono: &byte = get_mono_struct_name(codegen, "Future" as &byte, slot_ta, slot_tc);
        if payload_future_mono != null {
            concrete_future_safe = get_safe_c_identifier(codegen, payload_future_mono);
        }
    }
    // 内层 Poll<T> 的 C 名（用于 Future<T>.state，如 return 42 时包装为 Future{ state: Poll.Ready(42) }）
    var inner_poll_ret_c: &byte = null;
    var inner_poll_union_c: &byte = null;
    if effective_return_type.type_named_type_args != null && effective_return_type.type_named_type_arg_count >= 1 {
        const inner_poll_mono: &byte = get_mono_union_name(codegen, "Poll" as &byte, effective_return_type.type_named_type_args, effective_return_type.type_named_type_arg_count);
        if inner_poll_mono != null {
            const inner_poll_safe: &byte = get_safe_c_identifier(codegen, inner_poll_mono);
            const ipr: &byte = compiler_arena_alloc(codegen.arena, 128) as &byte;
            if ipr != null { snprintf(ipr as *byte, 128, "struct uya_tagged_%s" as *byte, inner_poll_safe as *byte); inner_poll_ret_c = ipr; }
            const ipu: &byte = compiler_arena_alloc(codegen.arena, 128) as &byte;
            if ipu != null { snprintf(ipu as *byte, 128, "union %s" as *byte, inner_poll_safe as *byte); inner_poll_union_c = ipu; }
        }
    }
    // 本分支仅用于无 await 的 !Future<T>，effective_return_type 应有 type_args；若无则 fallback 可能错误
    if inner_poll_ret_c == null { inner_poll_ret_c = "struct uya_tagged_Poll_i32" as &byte; }
    if inner_poll_union_c == null { inner_poll_union_c = "union Poll_i32" as &byte; }

    // 提取所有 await 点（支持递归进入 while/if/for/block）
    const body: &ASTNode = fn_decl.fn_decl_body;
    const MAX_AWAITS: i32 = C99_ASYNC_MAX_AWAITS;
    var await_operands: [&ASTNode: C99_ASYNC_MAX_AWAITS] = [];
    var await_bind_names: [&byte: C99_ASYNC_MAX_AWAITS] = [];
    var await_bind_types: [&ASTNode: C99_ASYNC_MAX_AWAITS] = [];
    var await_blocks: [&ASTNode: C99_ASYNC_MAX_AWAITS] = [];
    var await_stmt_indices: [i32: C99_ASYNC_MAX_AWAITS] = [];
    var await_count: i32 = 0;
    var ret_expr: &ASTNode = null;
    var has_await_loop: i32 = 0;
    var async_loop_var_is_total: i32 = 0;
    var async_cut_root: i32 = -1;
    if body != null {
        codegen.async_collect_count = 0;
        codegen.async_collect_ret_expr = null;
        codegen.async_collect_has_loop = 0;
        codegen.async_inline_temp_var_count = 0;
        var ewz: i32 = 0;
        while ewz < C99_ASYNC_MAX_AWAITS {
            codegen.async_collect_enclosing_while[ewz] = null;
            codegen.async_collect_enclosing_for[ewz] = null;
            ewz = ewz + 1;
        }
        collect_awaits_recursive(body, codegen, MAX_AWAITS, null, -1, null, null);
        c99_async_scan_inline_temp_vars(codegen, body);
        await_count = codegen.async_collect_count;
        ret_expr = codegen.async_collect_ret_expr;
        has_await_loop = codegen.async_collect_has_loop;
        var ci: i32 = 0;
        while ci < await_count && ci < C99_ASYNC_MAX_AWAITS {
            await_operands[ci] = codegen.async_collect_operands[ci];
            await_bind_names[ci] = codegen.async_collect_names[ci];
            await_bind_types[ci] = codegen.async_collect_types[ci];
            await_blocks[ci] = codegen.async_collect_blocks[ci];
            await_stmt_indices[ci] = codegen.async_collect_stmt_indices[ci];
            ci = ci + 1;
        }
        collect_async_pre_return_locals(codegen, body);
        c99_async_hoist_for_with_await_vars_rec(codegen, fn_decl, body);
        async_cut_root = c99_async_root_stmt_index_of_first_await(body, await_blocks, await_stmt_indices, await_count);
    }
    // 编译期计算状态机字节大小（使用真实类型大小）
    // - state = 4 字节
    // - await_fut（vtable+data 接口）= 16 字节
    // - 循环变量 = 16 字节
    // - await 绑定：按实际绑定类型大小
    // - 参数：按实际参数类型大小
    // 结果存 codegen.async_state_size：> 0 && <= 256 则栈分配（暂未启用），否则堆分配
    {
        var est: i32 = 4 + 16;
        if has_await_loop != 0 {
            est = est + 16;
        }
        // await 绑定：按实际类型大小
        var ai: i32 = 0;
        while ai < await_count && ai < C99_ASYNC_MAX_AWAITS {
            const bind_type_node: &ASTNode = await_bind_types[ai];
            if bind_type_node != null {
                const sz: i32 = get_type_node_size_bytes(codegen, bind_type_node);
                if sz > 0 {
                    est = est + sz;
                } else {
                    est = est + 16;
                }
            } else {
                est = est + 16;
            }
            ai = ai + 1;
        }
        // 参数：按实际类型大小
        {
            var pc: i32 = fn_decl.fn_decl_param_count;
            if pc > 16 { pc = 16; }
            var pi2: i32 = 0;
            while pi2 < pc {
                const param: &ASTNode = fn_decl.fn_decl_params[pi2];
                if param != null && param.type == ASTNodeType.AST_VAR_DECL {
                    const sz: i32 = get_type_node_size_bytes(codegen, param.var_decl_type);
                    if sz > 0 {
                        est = est + sz;
                    } else {
                        est = est + 16;
                    }
                }
                pi2 = pi2 + 1;
            }
        }
        codegen.async_state_size = est;
    }
    // 兼容无 await 判断：type_args_poll / 无-await 分支用 await_count == 0

    // poll 返回类型：无 await 且返回 !Future<T> 时为 Poll<!Future<T>>，否则为 Poll<inner>
    const type_args_poll: & & ASTNode = compiler_arena_alloc(codegen.arena, @size_of(&ASTNode)) as & & ASTNode;
    var safe_poll: &byte = get_safe_c_identifier(codegen, get_mono_union_name(codegen, "Poll" as &byte, type_args, 1));
    var poll_ret_c: &byte = null;
    var poll_union_c: &byte = null;
    var return_future_err_union: i32 = 0;
    if type_args_poll != null {
        // 返回 !Future<T> 时 poll 始终为 Poll<!Future<T>>（有无 await 一致），否则为 Poll<inner>
        if full_return_type != null && full_return_type.type == ASTNodeType.AST_TYPE_ERROR_UNION &&
            full_return_type.type_error_union_payload_type != null {
            const pl: &ASTNode = full_return_type.type_error_union_payload_type;
            if pl.type == ASTNodeType.AST_TYPE_NAMED && pl.type_named_name != null &&
                strcmp(pl.type_named_name as *byte, "Future" as *byte) == 0 {
                return_future_err_union = 1;
            }
        }
        if return_future_err_union != 0 {
            var poll_inner: &ASTNode = null;
            if effective_return_type.type_named_type_args != null && effective_return_type.type_named_type_arg_count >= 1 {
                const arg0: &ASTNode = effective_return_type.type_named_type_args[0];
                if arg0 != null { poll_inner = arg0; }
            }
            if ret_expr != null && ret_expr.type == ASTNodeType.AST_STRUCT_INIT && ret_expr.struct_init_struct_name != null &&
                strcmp(ret_expr.struct_init_struct_name as *byte, "Future" as *byte) == 0 &&
                full_return_type != null && full_return_type.type_error_union_payload_type != null {
                poll_inner = full_return_type.type_error_union_payload_type;
            }
            if poll_inner == null && full_return_type != null && full_return_type.type_error_union_payload_type != null {
                poll_inner = full_return_type.type_error_union_payload_type;
            }
            if poll_inner != null {
                type_args_poll[0] = substitute_type_arg(codegen, poll_inner);
            } else {
                type_args_poll[0] = poll_inner;
            }
            const poll_type_node: &ASTNode = ast_new_node(ASTNodeType.AST_TYPE_NAMED, 0, 0, codegen.arena, null);
            const poll_union_decl: &ASTNode = find_union_decl_c99(codegen, "Poll" as &byte);
            if poll_union_decl != null {
                gen_mono_union_definition(codegen, poll_union_decl, type_args_poll, 1);
            }
            const poll_full_mono: &byte = get_mono_union_name(codegen, "Poll" as &byte, type_args_poll, 1);
            if poll_full_mono != null {
                safe_poll = get_safe_c_identifier(codegen, poll_full_mono);
                const pbuf_full: &byte = compiler_arena_alloc(codegen.arena, 256) as &byte;
                if pbuf_full != null {
                    snprintf(pbuf_full as *byte, 256, "struct uya_tagged_%s" as *byte, safe_poll as *byte);
                    poll_ret_c = pbuf_full;
                }
                const ubuf_full: &byte = compiler_arena_alloc(codegen.arena, 256) as &byte;
                if ubuf_full != null {
                    snprintf(ubuf_full as *byte, 256, "union %s" as *byte, safe_poll as *byte);
                    poll_union_c = ubuf_full;
                }
            }
            const future_full_mono: &byte = get_mono_struct_name(codegen, "Future" as &byte, type_args_poll, 1);
            if future_full_mono != null {
                vtable_future_safe = get_safe_c_identifier(codegen, future_full_mono);
                const future_type_node: &ASTNode = ast_new_node(ASTNodeType.AST_TYPE_NAMED, 0, 0, codegen.arena, null);
                if future_type_node != null {
                    future_type_node.type_named_name = "Future" as &byte;
                    future_type_node.type_named_type_args = type_args_poll;
                    future_type_node.type_named_type_arg_count = 1;
                    c99_type_to_c_async_method_opt(codegen, future_type_node);
                }
            }
        }
    }
    if poll_ret_c == null {
        const pbuf: &byte = compiler_arena_alloc(codegen.arena, 256) as &byte;
        if pbuf != null {
            snprintf(pbuf as *byte, 256, "struct uya_tagged_%s" as *byte, safe_poll as *byte);
            poll_ret_c = pbuf;
        }
        const ubuf2: &byte = compiler_arena_alloc(codegen.arena, 256) as &byte;
        if ubuf2 != null {
            snprintf(ubuf2 as *byte, 256, "union %s" as *byte, safe_poll as *byte);
            poll_union_c = ubuf2;
        }
    }
    // 状态机内 Ready 载荷类型：poll 返回 Poll<T>，Ready 的载荷为 T（inner），故用 inner_err_c
    var ready_payload_c: &byte = inner_err_c;
    // 子 future 的 vtable 名：返回 !Future<T> 时为 Future<!Future<T>>，否则为 safe_future
    var child_vtable_safe: &byte = safe_future;
    if return_future_err_union != 0 { child_vtable_safe = vtable_future_safe; }
    var state_slot_iface_c: &byte = iface_c;
    // 首段 await 是否对 !Future<T> 做 try：返回 !Future<T> 或绑定类型为 Future 时做 try，存的是 .value（Future<T> 接口）
    var await_operand_is_err_future: i32 = return_future_err_union;
    if await_operand_is_err_future == 0 && await_count > 0 && await_bind_types[0] != null && await_bind_types[0].type == ASTNodeType.AST_TYPE_NAMED &&
        await_bind_types[0].type_named_name != null &&
        strcmp(await_bind_types[0].type_named_name as *byte, "Future" as *byte) == 0 {
        await_operand_is_err_future = 1;
    }
    // 当 return_future_err_union && await_operand_is_err_future 时，子 future 实际是 Future<T>，其 poll 返回 Poll<T>
    var child_poll_ret_c: &byte = poll_ret_c;
    var child_poll_union_c: &byte = poll_union_c;
    var child_inner_is_err_union: i32 = inner_is_err_union;
    if return_future_err_union != 0 && await_count > 0 && full_return_type != null && full_return_type.type_error_union_payload_type != null &&
        effective_return_type.type_named_type_args != null {
        var child_ta: & & ASTNode = effective_return_type.type_named_type_args;
        var child_ta_count: i32 = 1;
        var caller_returns_future_literal: i32 = 0;
        if ret_expr != null && ret_expr.type == ASTNodeType.AST_STRUCT_INIT && ret_expr.struct_init_struct_name != null &&
            strcmp(ret_expr.struct_init_struct_name as *byte, "Future" as *byte) == 0 {
            caller_returns_future_literal = 1;
        }
        if caller_returns_future_literal != 0 && await_bind_types[0] != null && await_bind_types[0].type == ASTNodeType.AST_TYPE_NAMED &&
            await_bind_types[0].type_named_name != null && strcmp(await_bind_types[0].type_named_name as *byte, "Future" as *byte) == 0 {
            const pay_ta: & & ASTNode = compiler_arena_alloc(codegen.arena, @size_of(&ASTNode)) as & & ASTNode;
            if pay_ta != null { pay_ta[0] = full_return_type.type_error_union_payload_type; child_ta = pay_ta; child_ta_count = 1; }
        }
        if child_ta != null && child_ta_count > 0 {
            const child_poll_mono: &byte = get_mono_union_name(codegen, "Poll" as &byte, child_ta, child_ta_count);
            const child_future_mono: &byte = get_mono_struct_name(codegen, "Future" as &byte, child_ta, child_ta_count);
            if child_poll_mono != null && child_future_mono != null {
                const cps: &byte = get_safe_c_identifier(codegen, child_poll_mono);
                const cfs: &byte = get_safe_c_identifier(codegen, child_future_mono);
                if cps != null && cfs != null {
                    const cpr: &byte = compiler_arena_alloc(codegen.arena, 128) as &byte;
                    const cpu: &byte = compiler_arena_alloc(codegen.arena, 128) as &byte;
                    if cpr != null { snprintf(cpr as *byte, 128, "struct uya_tagged_%s" as *byte, cps as *byte); child_poll_ret_c = cpr; }
                    if cpu != null { snprintf(cpu as *byte, 128, "union %s" as *byte, cps as *byte); child_poll_union_c = cpu; }
                    child_vtable_safe = cfs;
                    child_inner_is_err_union = 0;
                    const slot_buf: &byte = compiler_arena_alloc(codegen.arena, 64) as &byte;
                    if slot_buf != null && concrete_future_safe != null {
                        snprintf(slot_buf as *byte, 64, "struct uya_interface_%s" as *byte, concrete_future_safe as *byte);
                        state_slot_iface_c = slot_buf;
                    }
                }
            }
        }
    }
    // 当 return_future_err_union=0 时，状态机实现 Future<inner>，需用 type_args 的 vtable 名
    if return_future_err_union == 0 && type_args != null {
        const mono_future: &byte = get_mono_struct_name(codegen, "Future" as &byte, type_args, 1);
        if mono_future != null { vtable_future_safe = get_safe_c_identifier(codegen, mono_future); }
    }
    // 状态机 await 槽位类型：return_future_err_union 时为 effective 的接口；否则若首段做 try 则用 iface_c（存 !Future<T>.value），否则用 Future<inner>
    if return_future_err_union != 0 && await_count > 0 && effective_return_type.type_named_type_args != null && effective_return_type.type_named_type_arg_count >= 1 {
        var slot_type_args: & & ASTNode = effective_return_type.type_named_type_args;
        var slot_type_count: i32 = effective_return_type.type_named_type_arg_count;
        const pay0: &ASTNode = effective_return_type.type_named_type_args[0];
        if pay0 != null && pay0.type == ASTNodeType.AST_TYPE_ERROR_UNION && pay0.type_error_union_payload_type != null {
            const one_arg: & & ASTNode = compiler_arena_alloc(codegen.arena, @size_of(&ASTNode) * 2) as & & ASTNode;
            if one_arg != null {
                one_arg[0] = pay0.type_error_union_payload_type;
                slot_type_args = one_arg;
                slot_type_count = 1;
            }
        }
        const slot_mono: &byte = get_mono_struct_name(codegen, "Future" as &byte, slot_type_args, slot_type_count);
        if slot_mono != null {
            const slot_safe: &byte = get_safe_c_identifier(codegen, slot_mono);
            if slot_safe != null {
                const slot_buf2: &byte = compiler_arena_alloc(codegen.arena, 64) as &byte;
                if slot_buf2 != null {
                    snprintf(slot_buf2 as *byte, 64, "struct uya_interface_%s" as *byte, slot_safe as *byte);
                    state_slot_iface_c = slot_buf2;
                }
            }
        }
    }
    if return_future_err_union == 0 && type_args != null && type_args[0] != null {
        if await_operand_is_err_future != 0 {
            state_slot_iface_c = iface_c;
        } else {
            const future_inner_type_node: &ASTNode = ast_new_node(ASTNodeType.AST_TYPE_NAMED, 0, 0, codegen.arena, null);
            if future_inner_type_node != null {
                future_inner_type_node.type_named_name = "Future" as &byte;
                future_inner_type_node.type_named_type_args = type_args;
                future_inner_type_node.type_named_type_arg_count = 1;
                const slot_c: &byte = c99_type_to_c_async_method_opt(codegen, future_inner_type_node);
                if slot_c != null { state_slot_iface_c = slot_c; }
            }
        }
    }

    // async 状态机 struct 名
    const async_struct: &byte = compiler_arena_alloc(codegen.arena, 128) as &byte;
    const poll_name: &byte = compiler_arena_alloc(codegen.arena, 256) as &byte;
    const vtable_name: &byte = compiler_arena_alloc(codegen.arena, 256) as &byte;
    const release_name: &byte = compiler_arena_alloc(codegen.arena, 256) as &byte;
    const alloc_name: &byte = compiler_arena_alloc(codegen.arena, 256) as &byte;
    const free_name: &byte = compiler_arena_alloc(codegen.arena, 256) as &byte;
    if async_struct == null || poll_name == null || vtable_name == null || release_name == null || alloc_name == null || free_name == null {
        return;
    }
    snprintf(async_struct as *byte, 128, "uya_async_%s" as *byte, func_c_name as *byte);
    snprintf(poll_name as *byte, 256, "%s_poll" as *byte, func_c_name as *byte);
    snprintf(vtable_name as *byte, 256, "uya_vtable_%s_%s" as *byte, vtable_future_safe as *byte, async_struct as *byte);
    snprintf(release_name as *byte, 256, "uya_%s_release" as *byte, async_struct as *byte);
    snprintf(alloc_name as *byte, 256, "_uya_alloc_%s" as *byte, async_struct as *byte);
    snprintf(free_name as *byte, 256, "_uya_free_%s" as *byte, async_struct as *byte);

    // 确保 stdlib（malloc）可用
    codegen.needs_stdlib_h = 1;
    if is_struct_in_table(codegen, async_struct) == 0 {
        add_struct_definition(codegen, async_struct);
    }

    // 若存在循环内 await，检查 ret_expr 是否引用非 await 绑定的循环内变量
    // 如果是，需要将该变量持久化到状态机结构体中
    var loop_var_name: &byte = null;
    if has_await_loop != 0 && ret_expr != null && await_count >= 2 {
        // 简单遍历 ret_expr 收集标识符（只检查顶层标识符）
        var ret_names: [&byte: 16] = [];
        var ret_name_count: i32 = 0;
        // 检查 ret_expr 本身是否是标识符
        if ret_expr.type == ASTNodeType.AST_IDENTIFIER && ret_expr.identifier_name != null {
            ret_names[0] = ret_expr.identifier_name;
            ret_name_count = 1;
        } else if ret_expr.type == ASTNodeType.AST_BINARY_EXPR {
            // 检查二元表达式的左右操作数
            if ret_expr.binary_expr_left != null && ret_expr.binary_expr_left.type == ASTNodeType.AST_IDENTIFIER &&
                ret_expr.binary_expr_left.identifier_name != null && ret_name_count < 16 {
                ret_names[ret_name_count] = ret_expr.binary_expr_left.identifier_name;
                ret_name_count = ret_name_count + 1;
            }
            if ret_expr.binary_expr_right != null && ret_expr.binary_expr_right.type == ASTNodeType.AST_IDENTIFIER &&
                ret_expr.binary_expr_right.identifier_name != null && ret_name_count < 16 {
                ret_names[ret_name_count] = ret_expr.binary_expr_right.identifier_name;
                ret_name_count = ret_name_count + 1;
            }
        }
        
        // 检查每个 ret_expr 中的标识符是否都是 await 绑定
        var k: i32 = 0;
        while k < ret_name_count && k < 16 {
            const rn: &byte = ret_names[k];
            if rn != null {
                var is_bind: i32 = 0;
                var bi: i32 = 0;
                while bi < await_count && bi < C99_ASYNC_MAX_AWAITS {
                    if await_bind_names[bi] != null && strcmp(await_bind_names[bi] as *byte, rn as *byte) == 0 {
                        is_bind = 1;
                        break;
                    }
                    bi = bi + 1;
                }
                if is_bind == 0 {
                    // 这是一个非 await 绑定的引用，需要持久化
                    async_loop_var_is_total = 1;
                    loop_var_name = rn;
                    break;
                }
            }
            k = k + 1;
        }
    }

    // 若 poll 内会用到子 future 的 vtable：多段 await 时每段 Future<T> 的 T 可能不同，须为每个操作数对应的 Poll<T> 输出一次 vtable 声明
    if await_count > 0 {
        var predef_i: i32 = 0;
        while predef_i < await_count {
            c99_async_emit_inline_child_predefs(codegen, fn_decl, await_operands[predef_i]);
            predef_i = predef_i + 1;
        }
        var vti: i32 = 0;
        while vti < await_count {
            const vop: &ASTNode = await_operands[vti];
            const vinner_ast: &ASTNode = c99_async_operand_future_inner_ast(codegen, vop, fn_decl);
            if vinner_ast != null {
                const poll_ud_v: &ASTNode = find_union_decl_c99(codegen, "Poll" as &byte);
                const ta_v: & & ASTNode = compiler_arena_alloc(codegen.arena, @size_of(&ASTNode)) as & & ASTNode;
                if ta_v != null && poll_ud_v != null {
                    ta_v[0] = vinner_ast;
                    gen_mono_union_definition(codegen, poll_ud_v, ta_v, 1);
                    const pm_v: &byte = get_mono_union_name(codegen, "Poll" as &byte, ta_v, 1);
                    const pms_v: &byte = get_safe_c_identifier(codegen, pm_v);
                    const pr_v: &byte = compiler_arena_alloc(codegen.arena, 256) as &byte;
                    if pr_v != null && pms_v != null {
                        snprintf(pr_v as *byte, 256, "struct uya_tagged_%s" as *byte, pms_v as *byte);
                        const fm_v: &byte = get_mono_struct_name(codegen, "Future" as &byte, ta_v, 1);
                        const fms_v: &byte = get_safe_c_identifier(codegen, fm_v);
                        if fms_v != null {
                            const vtable_vbuf: &byte = compiler_arena_alloc(codegen.arena, 128) as &byte;
                            if vtable_vbuf != null {
                                snprintf(vtable_vbuf as *byte, 128, "uya_vtable_%s" as *byte, fms_v as *byte);
                                if is_struct_defined(codegen, vtable_vbuf) == 0 {
                                    fprintf(codegen.emit_stream as *void, "struct uya_vtable_%s { %s (*poll)(void *self, struct Waker *); };\n" as *byte,
                                        fms_v as *byte, pr_v as *byte);
                                    mark_struct_defined(codegen, vtable_vbuf);
                                }
                            }
                        }
                    }
                }
            }
            vti = vti + 1;
        }
        if child_poll_ret_c != null && child_vtable_safe != null {
            const vtable_fallback: &byte = compiler_arena_alloc(codegen.arena, 128) as &byte;
            if vtable_fallback != null {
                snprintf(vtable_fallback as *byte, 128, "uya_vtable_%s" as *byte, child_vtable_safe as *byte);
                if is_struct_defined(codegen, vtable_fallback) == 0 {
                    fprintf(codegen.emit_stream as *void, "struct uya_vtable_%s { %s (*poll)(void *self, struct Waker *); };\n" as *byte,
                        child_vtable_safe as *byte, child_poll_ret_c as *byte);
                    mark_struct_defined(codegen, vtable_fallback);
                }
            }
        }
    }

    // 输出状态机 struct（含捕获参数 + 所有 await 绑定变量）
    // await 绑定变量必须存在结构体中，确保跨 poll 调用时值不丢失
    var bind_i: i32 = 0;
    var loc_i: i32 = 0;
    if is_struct_defined(codegen, async_struct) == 0 {
        emit_line_directive(codegen, fn_decl.line, fn_decl.filename);
        fputs("struct " as *byte, codegen.emit_stream as *void);
        fprintf(codegen.emit_stream as *void, "%s" as *byte, async_struct as *byte);
        fputs(" { int32_t state; int32_t _uya_frame_active; " as *byte, codegen.emit_stream as *void);
        if await_count > 0 && concrete_future_safe != null && await_operand_is_err_future != 0 {
            fprintf(codegen.emit_stream as *void, "struct %s _uya_await_storage; " as *byte, concrete_future_safe as *byte);
        }
        if await_count > 0 {
            fputs("struct { void *vtable; void *data; } await_fut;" as *byte, codegen.emit_stream as *void);
        } else {
            fprintf(codegen.emit_stream as *void, "%s await_fut;" as *byte, state_slot_iface_c as *byte);
        }
        // 为可内联的 await 操作数添加 caller-owned child frame 字段
        var inline_i: i32 = 0;
        while inline_i < await_count {
            var inline_struct_name: &byte = null;
            if c99_async_await_operand_is_inlineable(codegen, await_operands[inline_i], &inline_struct_name) != 0 && inline_struct_name != null {
                fprintf(codegen.emit_stream as *void, "struct %s _uya_inline_await_%d; " as *byte, inline_struct_name as *byte, inline_i);
            }
            inline_i = inline_i + 1;
        }
        // 输出所有 await 绑定变量到结构体（确保跨 poll 调用时值不丢失）
        while bind_i < await_count {
            const bind_safe_name: &byte = get_safe_c_identifier(codegen, await_bind_names[bind_i]);
            if await_bind_types[bind_i] != null && bind_safe_name != null {
                c99_emit_struct_field_decl_fragment(codegen, await_bind_types[bind_i], "_uya_bind_" as &byte, bind_safe_name);
            }
            bind_i = bind_i + 1;
        }
        while loc_i < codegen.async_local_count && loc_i < @len(codegen.async_local_names) {
            const lname_safe: &byte = get_safe_c_identifier(codegen, codegen.async_local_names[loc_i]);
            if codegen.async_local_types[loc_i] != null && lname_safe != null {
                c99_emit_struct_field_decl_fragment(codegen, codegen.async_local_types[loc_i], "_uya_loc_" as &byte, lname_safe);
            }
            loc_i = loc_i + 1;
        }
    }
    const param_count: i32 = fn_decl.fn_decl_param_count;
    const params: & & ASTNode = fn_decl.fn_decl_params;
    var pi: i32 = 0;
    if is_struct_defined(codegen, async_struct) == 0 {
        while pi < param_count && pi < 16 {
            const param: &ASTNode = params[pi];
            if param != null && param.type == ASTNodeType.AST_VAR_DECL && param.var_decl_type != null && param.var_decl_name != null {
                const pname: &byte = get_safe_c_identifier(codegen, param.var_decl_name);
                if pname != null {
                    c99_emit_struct_field_decl_fragment(codegen, param.var_decl_type, null, pname);
                }
            }
            pi = pi + 1;
        }
        if fn_decl.fn_decl_align > 0 {
            fprintf(codegen.emit_stream as *void, " } __attribute__((aligned(%d)));\n" as *byte, fn_decl.fn_decl_align);
        } else {
            fputs(" };\n" as *byte, codegen.emit_stream as *void);
        }
        mark_struct_defined(codegen, async_struct);
    }

    if only_struct != 0 {
        const frame_stop_forward_name: &byte = compiler_arena_alloc(codegen.arena, 256) as &byte;
        if frame_stop_forward_name != null {
            snprintf(frame_stop_forward_name as *byte, 256, "%s_frame_stop" as *byte, func_c_name as *byte);
            fprintf(codegen.emit_stream as *void, "static %s %s(void *self, struct Waker *waker);\n" as *byte, poll_ret_c as *byte, poll_name as *byte);
            fprintf(codegen.emit_stream as *void, "static void %s(struct %s *s);\n" as *byte, frame_stop_forward_name as *byte, async_struct as *byte);
        }
        return;
    }

    // 计算 async frame size / align（保守估算，用于 checker 元信息注册）
    {
        var est_offset: i32 = 0;
        var est_align: i32 = 4;
        est_offset = 8;
        if await_count > 0 && concrete_future_safe != null && await_operand_is_err_future != 0 {
            var st_sz: i32 = get_type_node_size_bytes(codegen, effective_return_type);
            if st_sz <= 0 { st_sz = 24; }
            est_offset = ((est_offset + 7) / 8) * 8;
            est_offset = est_offset + st_sz;
            if 8 > est_align { est_align = 8; }
        }
        est_offset = ((est_offset + 7) / 8) * 8;
        est_offset = est_offset + 16;
        if 8 > est_align { est_align = 8; }
        // 加上内联 child frame 的大小
        var inline_sz_i: i32 = 0;
        while inline_sz_i < await_count {
            var inline_struct_name_sz: &byte = null;
            if c99_async_await_operand_is_inlineable(codegen, await_operands[inline_sz_i], &inline_struct_name_sz) != 0 && inline_struct_name_sz != null {
                const prefix_len: usize = strlen("uya_async_" as *byte);
                const child_key: &byte = &inline_struct_name_sz[prefix_len];
                const child_meta: &AsyncFrameMeta = checker_find_async_frame_meta_by_key_text(codegen.checker, child_key);
                var child_sz: i32 = 64;
                var child_al: i32 = 8;
                if child_meta != null {
                    child_sz = child_meta.frame_size as i32;
                    child_al = child_meta.frame_align as i32;
                }
                if child_sz <= 0 { child_sz = 64; }
                if child_al <= 0 { child_al = 8; }
                est_offset = ((est_offset + child_al - 1) / child_al) * child_al;
                est_offset = est_offset + child_sz;
                if child_al > est_align { est_align = child_al; }
            }
            inline_sz_i = inline_sz_i + 1;
        }
        bind_i = 0;
        while bind_i < await_count {
            if await_bind_types[bind_i] != null {
                const bsz: i32 = get_type_node_size_bytes(codegen, await_bind_types[bind_i]);
                const bal: i32 = get_type_node_align_bytes(codegen, await_bind_types[bind_i]);
                var use_sz: i32 = bsz;
                if use_sz <= 0 { use_sz = 8; }
                var use_al: i32 = bal;
                if use_al <= 0 { use_al = 8; }
                est_offset = ((est_offset + use_al - 1) / use_al) * use_al;
                est_offset = est_offset + use_sz;
                if use_al > est_align { est_align = use_al; }
            }
            bind_i = bind_i + 1;
        }
        loc_i = 0;
        while loc_i < codegen.async_local_count && loc_i < @len(codegen.async_local_names) {
            if codegen.async_local_types[loc_i] != null {
                const lsz: i32 = get_type_node_size_bytes(codegen, codegen.async_local_types[loc_i]);
                const lal: i32 = get_type_node_align_bytes(codegen, codegen.async_local_types[loc_i]);
                var use_sz: i32 = lsz;
                if use_sz <= 0 { use_sz = 8; }
                var use_al: i32 = lal;
                if use_al <= 0 { use_al = 8; }
                est_offset = ((est_offset + use_al - 1) / use_al) * use_al;
                est_offset = est_offset + use_sz;
                if use_al > est_align { est_align = use_al; }
            }
            loc_i = loc_i + 1;
        }
        pi = 0;
        while pi < param_count && pi < 16 {
            const param2: &ASTNode = params[pi];
            if param2 != null && param2.type == ASTNodeType.AST_VAR_DECL && param2.var_decl_type != null {
                const psz: i32 = get_type_node_size_bytes(codegen, param2.var_decl_type);
                const pal: i32 = get_type_node_align_bytes(codegen, param2.var_decl_type);
                var use_sz: i32 = psz;
                if use_sz <= 0 { use_sz = 8; }
                var use_al: i32 = pal;
                if use_al <= 0 { use_al = 8; }
                est_offset = ((est_offset + use_al - 1) / use_al) * use_al;
                est_offset = est_offset + use_sz;
                if use_al > est_align { est_align = use_al; }
            }
            pi = pi + 1;
        }
        if fn_decl.fn_decl_align > 0 {
            est_align = fn_decl.fn_decl_align;
        }
        if est_align > 0 {
            est_offset = ((est_offset + est_align - 1) / est_align) * est_align;
        }
        if est_offset < 0 { est_offset = 0; }
        codegen.async_frame_size = est_offset as usize;
        codegen.async_frame_align = est_align as usize;
    }

    // 注册 async frame 元信息到 checker
    if codegen.checker != null {
        var type_arg_count_for_meta: i32 = 0;
        var generic_name_for_meta: &byte = fn_decl.fn_decl_name;
        if fn_decl.fn_decl_type_param_count > 0 {
            var mi: i32 = 0;
            while mi < codegen.mono_instance_count {
                if codegen.mono_instances[mi].generic_name != null &&
                    strcmp(codegen.mono_instances[mi].generic_name as *byte, fn_decl.fn_decl_name as *byte) == 0 &&
                    codegen.mono_instances[mi].is_function != 0 {
                    const test_name: &byte = get_mono_function_name(codegen, fn_decl.fn_decl_name,
                        codegen.mono_instances[mi].type_args, codegen.mono_instances[mi].type_arg_count, fn_decl);
                    if test_name != null && strcmp(test_name as *byte, func_c_name as *byte) == 0 {
                        type_arg_count_for_meta = codegen.mono_instances[mi].type_arg_count;
                        break;
                    }
                }
                mi = mi + 1;
            }
        }
        const escape_class: AsyncFrameEscapeClass = async_lower_analyze_escape_class(codegen.checker, fn_decl.fn_decl_body);
        const existing: &AsyncFrameMeta = checker_find_async_frame_meta_by_key_text(codegen.checker, func_c_name);
        if existing == null {
            var meta: AsyncFrameMeta = AsyncFrameMeta{};
            meta.frame_key_text = func_c_name;
            meta.frame_id = codegen.checker.async_frame_meta_count as u32;
            meta.descriptor_index = meta.frame_id;
            meta.fn_name = func_c_name;
            meta.generic_name = generic_name_for_meta;
            meta.type_arg_count = type_arg_count_for_meta;
            meta.decl_node = fn_decl;
            meta.instance_node = fn_decl;
            meta.frame_size = codegen.async_frame_size;
            meta.frame_align = codegen.async_frame_align;
            meta.escape_class = escape_class;
            meta.is_pinned = 1;
            meta.contains_pinned_field = 0;
            meta.needs_drop = 0;
            meta.field_count = 0;
            checker_register_async_frame_meta(codegen.checker, &meta);
        } else {
            existing.frame_size = codegen.async_frame_size;
            existing.frame_align = codegen.async_frame_align;
            existing.escape_class = escape_class;
        }
    }

    // 设置 async 参数捕获（poll 内 gen_expr 将参数引用为 s->param）
    const async_s: &byte = "s" as *byte;
    codegen.async_state_var = async_s;
    codegen.async_poll_try_propagate_type = inner;
    codegen.async_poll_ret_c = poll_ret_c;
    codegen.async_poll_union_c = poll_union_c;
    codegen.async_poll_ready_payload_c = ready_payload_c;
    codegen.async_poll_inner_is_err_union = inner_is_err_union;
    codegen.async_emit_poll_return = 0;
    // 设置 await 绑定变量（poll 内 gen_expr 将绑定变量引用为 s->_uya_bind_name）
    codegen.async_bind_count = await_count;
    var bind_idx: i32 = 0;
    while bind_idx < await_count && bind_idx < C99_ASYNC_MAX_AWAITS {
        codegen.async_bind_names[bind_idx] = await_bind_names[bind_idx];
        bind_idx = bind_idx + 1;
    }
    codegen.async_param_count = 0;
    pi = 0;
    while pi < param_count && pi < 16 {
        const param: &ASTNode = params[pi];
        if param != null && param.type == ASTNodeType.AST_VAR_DECL && param.var_decl_name != null {
            codegen.async_param_names[pi] = param.var_decl_name;
            codegen.async_param_count = codegen.async_param_count + 1;
            // 将捕获参数注册为 local_variables，使 get_identifier_type_c 能找到类型（用于 reader.read 等接口/方法调用）
            if param.var_decl_type != null && codegen.local_variable_count < C99_MAX_LOCAL_VARS {
                const ptype_c: &byte = c99_type_to_c_async_method_opt(codegen, param.var_decl_type);
                if ptype_c != null {
                    c99_push_local_variable(codegen, param.var_decl_name, ptype_c, param.var_decl_type, codegen.current_depth);
                }
            }
        }
        pi = pi + 1;
    }

    // 输出 poll 函数
    if poll_ret_c == null {
        poll_ret_c = "struct uya_tagged_Poll_i32" as &byte;
    }
    if poll_union_c == null {
        poll_union_c = "union Poll_i32" as &byte;
    }
    fprintf(codegen.emit_stream as *void, "static %s %s(void *self, struct Waker *waker) {\n" as *byte, poll_ret_c as *byte, poll_name as *byte);
    fprintf(codegen.emit_stream as *void, "    struct %s *s = (struct %s *)self;\n" as *byte, async_struct as *byte, async_struct as *byte);
    fprintf(codegen.emit_stream as *void, "    if (s == (void*)0) { return (%s){ ._tag = 0 }; }\n" as *byte, poll_ret_c as *byte);
    fputs("    if (s->_uya_frame_active == 0) { abort(); }\n" as *byte, codegen.emit_stream as *void);
    // await 绑定变量已在结构体中（_uya_bind_*），无需局部变量声明
    // 设置通用协程变换上下文
    codegen.async_fn_decl = fn_decl;
    codegen.async_fn_body = body;
    codegen.async_await_operand_is_err_future = await_operand_is_err_future;
    codegen.async_full_return_type = full_return_type;
    codegen.async_concrete_future_safe = concrete_future_safe;
    codegen.async_state_slot_iface_c = state_slot_iface_c;
    // state machine：state 0 = 起点；state 1..await_count = 各 await 就绪后
    fputs("    if (s->state == 0) {\n" as *byte, codegen.emit_stream as *void);
    if await_count > 0 {
        emit_async_state0_pre_first_await_local_inits(codegen, async_cut_root);
        codegen.async_emit_poll_return = 1;
        emit_async_segment(codegen, body, async_cut_root, body.block_stmt_count);
        codegen.async_emit_poll_return = 0;
    } else {
        codegen.async_emit_poll_return = 1;
        const no_await_reached_end: i32 = emit_async_segment(codegen, body, 0, body.block_stmt_count);
        if no_await_reached_end != 0 {
            fputs("        s->state = 2;\n" as *byte, codegen.emit_stream as *void);
            emit_async_no_await_ready_return(codegen, fn_decl, full_return_type, effective_return_type, ret_expr,
                inner, inner_is_err_union, inner_err_c, iface_c, concrete_future_safe,
                inner_poll_ret_c, inner_poll_union_c, poll_ret_c, poll_union_c);
        }
        codegen.async_emit_poll_return = 0;
    }
    fputs("    }\n" as *byte, codegen.emit_stream as *void);

    var emit_await_count: i32 = await_count;
    if emit_await_count > C99_ASYNC_MAX_AWAITS {
        emit_await_count = C99_ASYNC_MAX_AWAITS;
    }
    var state_k: i32 = 1;
    while state_k <= emit_await_count {
        const state_idx: i32 = state_k - 1;
        if state_idx < 0 {
            state_k = state_k + 1;
            continue;
        }
        if state_idx >= C99_ASYNC_MAX_AWAITS {
            break;
        }
        // 每段 await 的 Poll/vtable 类型可能不同：按操作数推断并单态化
        var seg_poll_ret_c: &byte = child_poll_ret_c;
        var seg_poll_union_c: &byte = child_poll_union_c;
        var seg_vtable_safe: &byte = child_vtable_safe;
        var seg_inner_is_err: i32 = child_inner_is_err_union;
        var seg_ready_payload_c: &byte = ready_payload_c;
        const seg_op: &ASTNode = c99_async_operand_at(await_operands, state_idx);
        const seg_inner_ast: &ASTNode = c99_async_operand_future_inner_ast(codegen, seg_op, fn_decl);
        if seg_inner_ast != null {
            const poll_ud_seg: &ASTNode = find_union_decl_c99(codegen, "Poll" as &byte);
            const ta_seg: & & ASTNode = compiler_arena_alloc(codegen.arena, @size_of(&ASTNode)) as & & ASTNode;
            if ta_seg != null && poll_ud_seg != null {
                ta_seg[0] = seg_inner_ast;
                gen_mono_union_definition(codegen, poll_ud_seg, ta_seg, 1);
                const pm_seg: &byte = get_mono_union_name(codegen, "Poll" as &byte, ta_seg, 1);
                const pms_seg: &byte = get_safe_c_identifier(codegen, pm_seg);
                if pms_seg != null {
                    const pr_seg: &byte = compiler_arena_alloc(codegen.arena, 256) as &byte;
                    const pu_seg: &byte = compiler_arena_alloc(codegen.arena, 256) as &byte;
                    if pr_seg != null { snprintf(pr_seg as *byte, 256, "struct uya_tagged_%s" as *byte, pms_seg as *byte); seg_poll_ret_c = pr_seg; }
                    if pu_seg != null { snprintf(pu_seg as *byte, 256, "union %s" as *byte, pms_seg as *byte); seg_poll_union_c = pu_seg; }
                }
                const fm_seg: &byte = get_mono_struct_name(codegen, "Future" as &byte, ta_seg, 1);
                const fms_seg: &byte = get_safe_c_identifier(codegen, fm_seg);
                if fms_seg != null { seg_vtable_safe = fms_seg; }
            }
            if seg_inner_ast.type == ASTNodeType.AST_TYPE_ERROR_UNION {
                seg_inner_is_err = 1;
            } else {
                seg_inner_is_err = 0;
            }
            const seg_rpc: &byte = c99_type_to_c_async_method_opt(codegen, seg_inner_ast);
            if seg_rpc != null { seg_ready_payload_c = seg_rpc; }
        }
        fprintf(codegen.emit_stream as *void, "    if (s->state == %d) {\n" as *byte, state_k);
        var poll_line_ret: &byte = child_poll_ret_c;
        var poll_line_vt: &byte = child_vtable_safe;
        if seg_inner_is_err != 0 && seg_inner_ast != null {
            poll_line_ret = seg_poll_ret_c;
            poll_line_vt = seg_vtable_safe;
        }
        var inline_struct_name_poll: &byte = null;
        if c99_async_await_operand_is_inlineable(codegen, seg_op, &inline_struct_name_poll) != 0 && inline_struct_name_poll != null {
            const poll_fn_name: &byte = compiler_arena_alloc(codegen.arena, 256) as &byte;
            if poll_fn_name != null {
                const prefix_len_poll: usize = strlen("uya_async_" as *byte);
                const child_poll_key: &byte = &inline_struct_name_poll[prefix_len_poll];
                snprintf(poll_fn_name as *byte, 256, "%s_poll" as *byte, child_poll_key as *byte);
                fprintf(codegen.emit_stream as *void, "        %s p = %s(&s->_uya_inline_await_%d, waker);\n" as *byte,
                    poll_line_ret as *byte, poll_fn_name as *byte, state_idx);
            } else {
                fprintf(codegen.emit_stream as *void, "        %s p = ((struct uya_vtable_%s *)s->await_fut.vtable)->poll(s->await_fut.data, waker);\n" as *byte,
                    poll_line_ret as *byte, poll_line_vt as *byte);
            }
        } else {
            fprintf(codegen.emit_stream as *void, "        %s p = ((struct uya_vtable_%s *)s->await_fut.vtable)->poll(s->await_fut.data, waker);\n" as *byte,
                poll_line_ret as *byte, poll_line_vt as *byte);
        }
        fprintf(codegen.emit_stream as *void, "        if (p._tag == 0) { return (%s){ ._tag = 0 }; }\n" as *byte, poll_ret_c as *byte);
        if seg_inner_is_err != 0 {
            fprintf(codegen.emit_stream as *void, "        %s r = p.u.Ready;\n" as *byte, seg_ready_payload_c as *byte);
            var seg_err_use_bridge: i32 = 0;
            if seg_inner_ast != null && seg_ready_payload_c != null && ready_payload_c != null &&
                outer_err_payload_value_c != null &&
                strcmp(seg_ready_payload_c as *byte, ready_payload_c as *byte) != 0 {
                seg_err_use_bridge = 1;
            }
            if seg_err_use_bridge != 0 {
                fprintf(codegen.emit_stream as *void, "        if (r.error_id != 0) { return (%s){ ._tag = 1, .u = (%s){ .Ready = (%s){ .error_id = r.error_id, .value = (%s){0} } } }; }\n" as *byte,
                    poll_ret_c as *byte, poll_union_c as *byte, ready_payload_c as *byte, outer_err_payload_value_c as *byte);
            } else {
                fprintf(codegen.emit_stream as *void, "        if (r.error_id != 0) { return (%s){ ._tag = 1, .u = (%s){ .Ready = r } }; }\n" as *byte, poll_ret_c as *byte, poll_union_c as *byte);
            }
            const cur_bind_name: &byte = c99_async_bind_name_at(await_bind_names, state_idx);
            const cur_bind_type: &ASTNode = c99_async_bind_type_at(await_bind_types, state_idx);
            if cur_bind_name != null && cur_bind_type != null {
                const bind_safe: &byte = get_safe_c_identifier(codegen, cur_bind_name);
                fprintf(codegen.emit_stream as *void, "        s->_uya_bind_%s = r.value;\n" as *byte, bind_safe as *byte);
            }
            if concrete_future_safe != null && await_operand_is_err_future != 0 {
                fputs("        if (s->await_fut.data != (void*)0 && s->await_fut.data != (void*)&s->_uya_await_storage) { if (s->await_fut.vtable != (void*)0) { void (*_uya_rel)(void*) = (void (*)(void*))((void**)s->await_fut.vtable)[1]; if (_uya_rel != (void*)0) _uya_rel(s->await_fut.data); } }\n" as *byte, codegen.emit_stream as *void);
            } else {
                fputs("        if (s->await_fut.data != (void*)0) { if (s->await_fut.vtable != (void*)0) { void (*_uya_rel)(void*) = (void (*)(void*))((void**)s->await_fut.vtable)[1]; if (_uya_rel != (void*)0) _uya_rel(s->await_fut.data); } }\n" as *byte, codegen.emit_stream as *void);
            }
            fputs("        s->await_fut.data = (void*)0; s->await_fut.vtable = (void*)0;\n" as *byte, codegen.emit_stream as *void);
            // Bug C: "return try @await" — 无 bind name：直接 return Ready(r.value)
            if cur_bind_name == null && ret_expr == null {
                fprintf(codegen.emit_stream as *void, "        return (%s){ ._tag = 1, .u = (%s){ .Ready = (%s){ .error_id = 0, .value = r.value } } };\n" as *byte,
                    poll_ret_c as *byte, poll_union_c as *byte, ready_payload_c as *byte);
                fputs("    }\n" as *byte, codegen.emit_stream as *void);
                state_k = state_k + 1;
                continue;
            }
            // 通用 continuation：递归段发射（emit_async_segment 遇 return 语句停止）
            {
                const cont_r: i32 = emit_async_continuation(codegen, state_idx);
                var skip_ret_expr_emit: i32 = 0;
                const await_block2: &ASTNode = c99_async_await_block_at(await_blocks, state_idx);
                const await_stmt_index2: i32 = c99_async_await_stmt_index_at(await_stmt_indices, state_idx);
                if await_block2 != null && await_stmt_index2 >= 0 &&
                    await_stmt_index2 < await_block2.block_stmt_count {
                    const cur_stmt2: &ASTNode = await_block2.block_stmts[await_stmt_index2];
                    if c99_return_stmt_has_nested_try_await(cur_stmt2) != 0 {
                        skip_ret_expr_emit = 1;
                    }
                }
                if cont_r != 0 && ret_expr != null && skip_ret_expr_emit == 0 {
                    codegen.current_function_return_type = effective_return_type;
                    fprintf(codegen.emit_stream as *void, "        return (%s){ ._tag = 1, .u = (%s){ .Ready = (%s){ .error_id = 0, .value = " as *byte,
                        poll_ret_c as *byte, poll_union_c as *byte, ready_payload_c as *byte);
                    gen_expr(codegen, ret_expr);
                    fputs(" } } };\n" as *byte, codegen.emit_stream as *void);
                    codegen.current_function_return_type = null;
                }
            }
        } else {
            const cur_bind_name2: &byte = c99_async_bind_name_at(await_bind_names, state_idx);
            if cur_bind_name2 != null {
                const bind_safe2: &byte = get_safe_c_identifier(codegen, cur_bind_name2);
                fprintf(codegen.emit_stream as *void, "        s->_uya_bind_%s = p.u.Ready;\n" as *byte, bind_safe2 as *byte);
            }
            if concrete_future_safe != null && await_operand_is_err_future != 0 {
                fputs("        if (s->await_fut.data != (void*)0 && s->await_fut.data != (void*)&s->_uya_await_storage) { if (s->await_fut.vtable != (void*)0) { void (*_uya_rel)(void*) = (void (*)(void*))((void**)s->await_fut.vtable)[1]; if (_uya_rel != (void*)0) _uya_rel(s->await_fut.data); } }\n" as *byte, codegen.emit_stream as *void);
            } else {
                fputs("        if (s->await_fut.data != (void*)0) { if (s->await_fut.vtable != (void*)0) { void (*_uya_rel)(void*) = (void (*)(void*))((void**)s->await_fut.vtable)[1]; if (_uya_rel != (void*)0) _uya_rel(s->await_fut.data); } }\n" as *byte, codegen.emit_stream as *void);
            }
            fputs("        s->await_fut.data = (void*)0; s->await_fut.vtable = (void*)0;\n" as *byte, codegen.emit_stream as *void);
            // 通用 continuation：递归段发射（emit_async_segment 遇 return 语句停止）
            {
                const cont_r2: i32 = emit_async_continuation(codegen, state_idx);
                var skip_ret_expr_emit2: i32 = 0;
                const await_block3: &ASTNode = c99_async_await_block_at(await_blocks, state_idx);
                const await_stmt_index3: i32 = c99_async_await_stmt_index_at(await_stmt_indices, state_idx);
                if await_block3 != null && await_stmt_index3 >= 0 &&
                    await_stmt_index3 < await_block3.block_stmt_count {
                    const cur_stmt3: &ASTNode = await_block3.block_stmts[await_stmt_index3];
                    if c99_return_stmt_has_nested_try_await(cur_stmt3) != 0 {
                        skip_ret_expr_emit2 = 1;
                    }
                }
                if cont_r2 != 0 && ret_expr != null && skip_ret_expr_emit2 == 0 {
                    codegen.current_function_return_type = effective_return_type;
                    // return_future_err_union + Future 字面量：需要 boxing 为接口
                    var is_future_literal_ret: i32 = 0;
                    if return_future_err_union != 0 && ret_expr.type == ASTNodeType.AST_STRUCT_INIT && ret_expr.struct_init_struct_name != null &&
                        strcmp(ret_expr.struct_init_struct_name as *byte, "Future" as *byte) == 0 && concrete_future_safe != null {
                        is_future_literal_ret = 1;
                    }
                    if is_future_literal_ret != 0 {
                        const last_ret_c: &byte = c99_type_to_c_async_method_opt(codegen, full_return_type);
                        if last_ret_c != null {
                            fprintf(codegen.emit_stream as *void, "        %s ok = (%s){ .error_id = 0, .value = " as *byte, last_ret_c as *byte, last_ret_c as *byte);
                            fprintf(codegen.emit_stream as *void, "({ struct %s _uya_f = " as *byte, concrete_future_safe as *byte);
                            gen_expr(codegen, ret_expr);
                            fprintf(codegen.emit_stream as *void, "; (%s){ .vtable = (void*)&uya_vtable_%s_%s, .data = (void*)&_uya_f }; }) };\n" as *byte, iface_c as *byte, concrete_future_safe as *byte, concrete_future_safe as *byte);
                            fprintf(codegen.emit_stream as *void, "        return (%s){ ._tag = 1, .u = (%s){ .Ready = ok.value } };\n" as *byte, poll_ret_c as *byte, poll_union_c as *byte);
                        }
                    } else {
                        fprintf(codegen.emit_stream as *void, "        return (%s){ ._tag = 1, .u = (%s){ .Ready = " as *byte,
                            poll_ret_c as *byte, poll_union_c as *byte);
                        gen_expr(codegen, ret_expr);
                        fputs(" } };\n" as *byte, codegen.emit_stream as *void);
                    }
                    codegen.current_function_return_type = null;
                }
            }
        }
        fputs("    }\n" as *byte, codegen.emit_stream as *void);
        state_k = state_k + 1;
    }

    // 终态 — while/if 的无 await 分支可能到达 s->state = await_count+1。
    // 若最终 return 本身含 @await，它已在前面的 await state 中拆分处理，不能再次普通生成。
    var terminal_return_stmt: &ASTNode = null;
    if body != null && body.type == ASTNodeType.AST_BLOCK && body.block_stmts != null {
        var terminal_si: i32 = body.block_stmt_count - 1;
        while terminal_si >= 0 {
            const terminal_st: &ASTNode = body.block_stmts[terminal_si];
            if terminal_st != null && terminal_st.type == ASTNodeType.AST_RETURN_STMT {
                terminal_return_stmt = terminal_st;
                break;
            }
            terminal_si = terminal_si - 1;
        }
    }
    if await_count > 0 && (terminal_return_stmt == null || c99_stmt_tree_has_await(terminal_return_stmt) == 0) {
        fprintf(codegen.emit_stream as *void, "    if (s->state == %d) {\n" as *byte, await_count + 1);
        codegen.async_emit_poll_return = 1;
        if terminal_return_stmt != null {
            const terminal_expr: &ASTNode = terminal_return_stmt.return_stmt_expr;
            if terminal_expr != null && terminal_expr.type == ASTNodeType.AST_ERROR_VALUE {
                gen_stmt(codegen, terminal_return_stmt);
            } else {
                emit_async_no_await_ready_return(codegen, fn_decl, full_return_type, effective_return_type, terminal_expr,
                    inner, inner_is_err_union, inner_err_c, iface_c, concrete_future_safe,
                    inner_poll_ret_c, inner_poll_union_c, poll_ret_c, poll_union_c);
            }
        } else {
            // terminal_return_stmt == null: body does not end with a return.
            // This happens for async functions whose last statement is an infinite loop (e.g. while true).
            // The await_count+1 state may be reached incorrectly from inner loop fallthrough paths.
            // Loop back to state 0 to avoid an empty block that falls through and causes UB.
            var last_stmt_is_loop: i32 = 0;
            if body != null && body.type == ASTNodeType.AST_BLOCK && body.block_stmts != null && body.block_stmt_count > 0 {
                var last_si: i32 = body.block_stmt_count - 1;
                while last_si >= 0 {
                    const last_st: &ASTNode = body.block_stmts[last_si];
                    if last_st != null {
                        if last_st.type == ASTNodeType.AST_WHILE_STMT || last_st.type == ASTNodeType.AST_FOR_STMT {
                            last_stmt_is_loop = 1;
                        }
                        break;
                    }
                    last_si = last_si - 1;
                }
            }
            if last_stmt_is_loop != 0 {
                fprintf(codegen.emit_stream as *void, "        s->state = 0;\n" as *byte);
            }
            fprintf(codegen.emit_stream as *void, "        return (%s){ ._tag = 0 };\n" as *byte, poll_ret_c as *byte);
        }
        codegen.async_emit_poll_return = 0;
        fputs("    }\n" as *byte, codegen.emit_stream as *void);
    }


    // 无 await：计算返回值并返回 Ready(ok)
    if await_count == 0 {
        fputs("    {\n" as *byte, codegen.emit_stream as *void);
        emit_async_no_await_ready_return(codegen, fn_decl, full_return_type, effective_return_type, ret_expr,
            inner, inner_is_err_union, inner_err_c, iface_c, concrete_future_safe,
            inner_poll_ret_c, inner_poll_union_c, poll_ret_c, poll_union_c);
        fputs("    }\n" as *byte, codegen.emit_stream as *void);
    }
    fprintf(codegen.emit_stream as *void, "    abort();\n" as *byte);
    fprintf(codegen.emit_stream as *void, "    return (%s){ ._tag = 0 };\n" as *byte, poll_ret_c as *byte);
    fputs("}\n" as *byte, codegen.emit_stream as *void);

    // 清除 async 参数捕获
    codegen.async_state_var = null;
    codegen.async_poll_try_propagate_type = null;
    codegen.async_poll_ret_c = null;
    codegen.async_poll_union_c = null;
    codegen.async_poll_ready_payload_c = null;
    codegen.async_poll_inner_is_err_union = 0;
    codegen.async_emit_poll_return = 0;
    codegen.async_param_count = 0;
    codegen.async_bind_count = 0;
    codegen.async_local_count = 0;
    codegen.async_loop_var_name = null;
    codegen.async_loop_var_c = null;
    codegen.async_fn_decl = null;
    codegen.async_fn_body = null;
    codegen.async_await_operand_is_err_future = 0;
    codegen.async_full_return_type = null;
    codegen.async_concrete_future_safe = null;
    codegen.async_state_slot_iface_c = null;
    pi = 0;
    while pi < 16 {
        codegen.async_param_names[pi] = null;
        pi = pi + 1;
    }

    // 查询当前函数的 frame_id（用于统一 AsyncFramePool）
    var async_frame_id: u32 = 0;
    if codegen.checker != null {
        const af_meta: &AsyncFrameMeta = checker_find_async_frame_meta_by_key_text(codegen.checker, func_c_name);
        if af_meta != null {
            async_frame_id = af_meta.frame_id;
        }
    }

    const frame_init_name: &byte = compiler_arena_alloc(codegen.arena, 256) as &byte;
    if frame_init_name != null {
        snprintf(frame_init_name as *byte, 256, "%s_frame_start" as *byte, func_c_name as *byte);
    }
    const frame_drop_fields_name: &byte = compiler_arena_alloc(codegen.arena, 256) as &byte;
    if frame_drop_fields_name != null {
        snprintf(frame_drop_fields_name as *byte, 256, "%s_frame_stop" as *byte, func_c_name as *byte);
    }
    const old_frame_init_name: &byte = compiler_arena_alloc(codegen.arena, 256) as &byte;
    if old_frame_init_name != null {
        snprintf(old_frame_init_name as *byte, 256, "%s_frame_init" as *byte, func_c_name as *byte);
    }
    const old_frame_drop_fields_name: &byte = compiler_arena_alloc(codegen.arena, 256) as &byte;
    if old_frame_drop_fields_name != null {
        snprintf(old_frame_drop_fields_name as *byte, 256, "%s_frame_drop_fields" as *byte, func_c_name as *byte);
    }

    // 生成 frame_stop 函数：停止当前 frame 运行，递归释放 child future，但不释放自身 storage
    // 供 caller-owned stack 内联或显式 frame 持有时，由 parent / caller 调用
    if frame_drop_fields_name != null {
        fprintf(codegen.emit_stream as *void, "static void %s(struct %s *s) {\n" as *byte, frame_drop_fields_name as *byte, async_struct as *byte);
        fputs("    if (s == (void*)0) return;\n" as *byte, codegen.emit_stream as *void);
        fputs("    if (s->_uya_frame_active == 0) return;\n" as *byte, codegen.emit_stream as *void);
        fputs("    if (s->await_fut.data != (void*)0 && s->await_fut.vtable != (void*)0) {\n" as *byte, codegen.emit_stream as *void);
        fputs("        void (*_uya_rel)(void*) = (void (*)(void*))((void**)s->await_fut.vtable)[1];\n" as *byte, codegen.emit_stream as *void);
        fputs("        if (_uya_rel != (void*)0) _uya_rel(s->await_fut.data);\n" as *byte, codegen.emit_stream as *void);
        fputs("        s->await_fut.data = (void*)0;\n        s->await_fut.vtable = (void*)0;\n    }\n" as *byte, codegen.emit_stream as *void);
        var rel_i: i32 = 0;
        while rel_i < await_count {
            var rel_inline_struct: &byte = null;
            if c99_async_await_operand_is_inlineable(codegen, await_operands[rel_i], &rel_inline_struct) != 0 && rel_inline_struct != null {
                const child_rel_fields: &byte = compiler_arena_alloc(codegen.arena, 256) as &byte;
                if child_rel_fields != null {
                    const child_prefix_len: usize = strlen("uya_async_" as *byte);
                    const child_key: &byte = &rel_inline_struct[child_prefix_len];
                    snprintf(child_rel_fields as *byte, 256, "%s_frame_stop" as *byte, child_key as *byte);
                    fprintf(codegen.emit_stream as *void, "    %s(&s->_uya_inline_await_%d);\n" as *byte, child_rel_fields as *byte, rel_i);
                }
            }
            rel_i = rel_i + 1;
        }
        fputs("    s->state = 0;\n" as *byte, codegen.emit_stream as *void);
        fputs("    s->_uya_frame_active = 0;\n" as *byte, codegen.emit_stream as *void);
        fputs("}\n" as *byte, codegen.emit_stream as *void);
    }

    // 生成 frame_start 函数：caller-owned storage 启动入口；若当前仍为 active，先 stop 再 restart
    if frame_init_name != null {
        fprintf(codegen.emit_stream as *void, "static void %s(struct %s *s" as *byte, frame_init_name as *byte, async_struct as *byte);
        pi = 0;
        while pi < param_count && pi < 16 {
            const param: &ASTNode = params[pi];
            if param != null && param.type == ASTNodeType.AST_VAR_DECL && param.var_decl_type != null && param.var_decl_name != null {
                const ptype_c: &byte = c99_type_to_c_async_method_opt(codegen, param.var_decl_type);
                const pname: &byte = get_safe_c_identifier(codegen, param.var_decl_name);
                if ptype_c != null && pname != null {
                    fputs(", " as *byte, codegen.emit_stream as *void);
                    fprintf(codegen.emit_stream as *void, "%s %s" as *byte, ptype_c as *byte, pname as *byte);
                }
            }
            pi = pi + 1;
        }
        fputs(") {\n" as *byte, codegen.emit_stream as *void);
        fputs("    if (s == (void*)0) return;\n" as *byte, codegen.emit_stream as *void);
        if frame_drop_fields_name != null {
            fprintf(codegen.emit_stream as *void, "    if (s->_uya_frame_active != 0) %s(s);\n" as *byte, frame_drop_fields_name as *byte);
        }
        fputs("    s->state = 0; s->_uya_frame_active = 1; __builtin_memset((void *)&s->await_fut, 0, sizeof(s->await_fut)); " as *byte, codegen.emit_stream as *void);
        pi = 0;
        while pi < param_count && pi < 16 {
            const param: &ASTNode = params[pi];
            if param != null && param.type == ASTNodeType.AST_VAR_DECL && param.var_decl_name != null {
                const pname: &byte = get_safe_c_identifier(codegen, param.var_decl_name);
                if pname != null {
                    fprintf(codegen.emit_stream as *void, "s->%s = %s; " as *byte, pname as *byte, pname as *byte);
                }
            }
            pi = pi + 1;
        }
        fputs("\n}\n" as *byte, codegen.emit_stream as *void);
    }
    if old_frame_init_name != null && frame_init_name != null {
        fprintf(codegen.emit_stream as *void, "static void %s(struct %s *s" as *byte, old_frame_init_name as *byte, async_struct as *byte);
        pi = 0;
        while pi < param_count && pi < 16 {
            const param_old: &ASTNode = params[pi];
            if param_old != null && param_old.type == ASTNodeType.AST_VAR_DECL && param_old.var_decl_type != null && param_old.var_decl_name != null {
                const ptype_old: &byte = c99_type_to_c_async_method_opt(codegen, param_old.var_decl_type);
                const pname_old: &byte = get_safe_c_identifier(codegen, param_old.var_decl_name);
                if ptype_old != null && pname_old != null {
                    fputs(", " as *byte, codegen.emit_stream as *void);
                    fprintf(codegen.emit_stream as *void, "%s %s" as *byte, ptype_old as *byte, pname_old as *byte);
                }
            }
            pi = pi + 1;
        }
        fputs(") {\n" as *byte, codegen.emit_stream as *void);
        fprintf(codegen.emit_stream as *void, "    %s(s" as *byte, frame_init_name as *byte);
        pi = 0;
        while pi < param_count && pi < 16 {
            const param_old2: &ASTNode = params[pi];
            if param_old2 != null && param_old2.type == ASTNodeType.AST_VAR_DECL && param_old2.var_decl_name != null {
                const pname_old2: &byte = get_safe_c_identifier(codegen, param_old2.var_decl_name);
                if pname_old2 != null {
                    fprintf(codegen.emit_stream as *void, ", %s" as *byte, pname_old2 as *byte);
                }
            }
            pi = pi + 1;
        }
        fputs(");\n}\n" as *byte, codegen.emit_stream as *void);
    }
    if old_frame_drop_fields_name != null && frame_drop_fields_name != null {
        fprintf(codegen.emit_stream as *void, "static void %s(struct %s *s) {\n" as *byte, old_frame_drop_fields_name as *byte, async_struct as *byte);
        fprintf(codegen.emit_stream as *void, "    %s(s);\n}\n" as *byte, frame_drop_fields_name as *byte);
    }

    // 生成 per-function 帧池分配器与 release 函数（无锁 CAS free list）
    // Zig cc 对 _Atomic(T) 的 builtin 参数更严格，因此显式把地址转成普通指针。
    fprintf(codegen.emit_stream as *void, "static _Atomic(void*) %s_pool_head = (void*)0;\n" as *byte, alloc_name as *byte);
    fprintf(codegen.emit_stream as *void, "static _Atomic(int32_t) %s_pool_count = 0;\n" as *byte, alloc_name as *byte);
    fprintf(codegen.emit_stream as *void, "static const int32_t %s_pool_cap = 4096;\n" as *byte, alloc_name as *byte);
    fprintf(codegen.emit_stream as *void, "static struct %s *%s(void) {\n" as *byte, async_struct as *byte, alloc_name as *byte);
    fputs("    struct uya_interface_IAllocator *a = std_get_async_frame_allocator();\n" as *byte, codegen.emit_stream as *void);
    fprintf(codegen.emit_stream as *void, "    if (a != (void*)0) { struct err_union_uint8_tptr r = ((struct uya_vtable_IAllocator *)a->vtable)->alloc(a->data, sizeof(struct %s)); if (r.error_id == 0) return (struct %s *)r.value; return (struct %s *)0; }\n" as *byte, async_struct as *byte, async_struct as *byte, async_struct as *byte);
    fprintf(codegen.emit_stream as *void, "    void *head = __atomic_load_n((void **)&%s_pool_head, __ATOMIC_ACQUIRE);\n" as *byte, alloc_name as *byte);
    fprintf(codegen.emit_stream as *void, "    while (head != (void*)0) {\n" as *byte);
    fprintf(codegen.emit_stream as *void, "        void *next = *(void**)head;\n" as *byte);
    fprintf(codegen.emit_stream as *void, "        if (__atomic_compare_exchange_n((void **)&%s_pool_head, &head, next, 1, __ATOMIC_ACQUIRE, __ATOMIC_RELAXED)) {\n" as *byte, alloc_name as *byte);
    fprintf(codegen.emit_stream as *void, "            __atomic_sub_fetch((int32_t *)&%s_pool_count, 1, __ATOMIC_RELAXED);\n" as *byte, alloc_name as *byte);
    fprintf(codegen.emit_stream as *void, "            return (struct %s *)head;\n" as *byte, async_struct as *byte);
    fputs("        }\n    }\n" as *byte, codegen.emit_stream as *void);
    fprintf(codegen.emit_stream as *void, "    return (struct %s *)malloc(sizeof(struct %s));\n}\n" as *byte, async_struct as *byte, async_struct as *byte);
    fprintf(codegen.emit_stream as *void, "static void %s(struct %s *p) {\n" as *byte, free_name as *byte, async_struct as *byte);
    fputs("    if (p == (void*)0) return;\n" as *byte, codegen.emit_stream as *void);
    fputs("    struct uya_interface_IAllocator *a = std_get_async_frame_allocator();\n" as *byte, codegen.emit_stream as *void);
    fprintf(codegen.emit_stream as *void, "    if (a != (void*)0) { ((struct uya_vtable_IAllocator *)a->vtable)->dealloc(a->data, (uint8_t *)p); return; }\n" as *byte);
    fprintf(codegen.emit_stream as *void, "    int32_t cnt = __atomic_load_n((int32_t *)&%s_pool_count, __ATOMIC_RELAXED);\n" as *byte, alloc_name as *byte);
    fprintf(codegen.emit_stream as *void, "    if (cnt >= %s_pool_cap) { free(p); return; }\n" as *byte, alloc_name as *byte);
    fprintf(codegen.emit_stream as *void, "    void *head = __atomic_load_n((void **)&%s_pool_head, __ATOMIC_RELAXED);\n" as *byte, alloc_name as *byte);
    fprintf(codegen.emit_stream as *void, "    do {\n" as *byte);
    fprintf(codegen.emit_stream as *void, "        *(void**)p = head;\n" as *byte);
    fprintf(codegen.emit_stream as *void, "        if (__atomic_compare_exchange_n((void **)&%s_pool_head, &head, p, 1, __ATOMIC_RELEASE, __ATOMIC_RELAXED)) {\n" as *byte, alloc_name as *byte);
    fprintf(codegen.emit_stream as *void, "            __atomic_add_fetch((int32_t *)&%s_pool_count, 1, __ATOMIC_RELAXED);\n" as *byte, alloc_name as *byte);
    fprintf(codegen.emit_stream as *void, "            return;\n        }\n    } while (1);\n}\n" as *byte, alloc_name as *byte);

    // 生成 release 函数：先 stop，再归还 per-function free list
    fprintf(codegen.emit_stream as *void, "static void %s(void *self) {\n" as *byte, release_name as *byte);
    if frame_drop_fields_name != null {
        fprintf(codegen.emit_stream as *void, "    %s((struct %s *)self);\n" as *byte, frame_drop_fields_name as *byte, async_struct as *byte);
    } else {
        fprintf(codegen.emit_stream as *void, "    struct %s *s = (struct %s *)self;\n" as *byte, async_struct as *byte, async_struct as *byte);
        fputs("    if (s == (void*)0) return;\n" as *byte, codegen.emit_stream as *void);
        fputs("    if (s->await_fut.data != (void*)0 && s->await_fut.vtable != (void*)0) {\n" as *byte, codegen.emit_stream as *void);
        fputs("        void (*_uya_rel)(void*) = (void (*)(void*))((void**)s->await_fut.vtable)[1];\n" as *byte, codegen.emit_stream as *void);
        fputs("        if (_uya_rel != (void*)0) _uya_rel(s->await_fut.data);\n" as *byte, codegen.emit_stream as *void);
        fputs("        s->await_fut.data = (void*)0;\n    }\n" as *byte, codegen.emit_stream as *void);
    }
    fprintf(codegen.emit_stream as *void, "    %s((struct %s*)self);\n}\n" as *byte, free_name as *byte, async_struct as *byte);

    // 返回 !Future<T> 时 vtable 类型为 Future<!Future<T>>，需先给出完整定义再定义常量（否则 C 报 incomplete type）。
    // 有 await 时由 1174 块输出；无 await 时此处输出。使用 arena 存储名称以保证 mark_struct_defined 的持久性。
    if return_future_err_union != 0 && vtable_future_safe != null && poll_ret_c != null {
    const vtable_struct_name: &byte = compiler_arena_alloc(codegen.arena, 128) as &byte;
    if vtable_struct_name != null {
        snprintf(vtable_struct_name as *byte, 128, "uya_vtable_%s" as *byte, vtable_future_safe as *byte);
        if is_struct_defined(codegen, vtable_struct_name) == 0 {
            const iface_struct_name: &byte = compiler_arena_alloc(codegen.arena, 128) as &byte;
            if iface_struct_name != null {
                snprintf(iface_struct_name as *byte, 128, "uya_interface_%s" as *byte, vtable_future_safe as *byte);
                fprintf(codegen.emit_stream as *void, "struct uya_interface_%s { void *vtable; void *data; };\n" as *byte, vtable_future_safe as *byte);
                fprintf(codegen.emit_stream as *void, "struct uya_vtable_%s {\n  %s (*poll)(void *self, struct Waker *);\n  void (*release)(void *self);\n};\n" as *byte, vtable_future_safe as *byte, poll_ret_c as *byte);
                mark_struct_defined(codegen, iface_struct_name);
                mark_struct_defined(codegen, vtable_struct_name);
            }
        }
    }
    }
    // vtable 常量
    fprintf(codegen.emit_stream as *void, "static const struct uya_vtable_%s %s = { (%s (*)(void *self, struct Waker *))&%s, (void (*)(void *self))&%s };\n" as *byte,
        vtable_future_safe as *byte, vtable_name as *byte, poll_ret_c as *byte, poll_name as *byte, release_name as *byte);

    // 输出原函数：分配状态机，复制参数，返回 Future
    var wrapper_ret_c: &byte = iface_c;
    var need_wrap: i32 = 0;
    if full_return_type != null && full_return_type.type == ASTNodeType.AST_TYPE_ERROR_UNION {
        wrapper_ret_c = c99_type_to_c_async_method_opt(codegen, full_return_type);
        if wrapper_ret_c != null && strstr(wrapper_ret_c as *byte, "err_union_" as *byte) != null {
            need_wrap = 1;
        }
    }
    if fn_decl.fn_decl_is_export != 0 || codegen.split_enabled != 0 {
        fprintf(codegen.emit_stream as *void, "%s %s(" as *byte, wrapper_ret_c as *byte, func_c_name as *byte);
    } else {
        // 多文件 C（split）：与 gen_function_prototype / 普通函数定义一致，不加 static，避免 uya_split_protos.h 中非 static 声明与本定义冲突
        if codegen.split_enabled == 0 {
            fprintf(codegen.emit_stream as *void, "static __attribute__((used)) %s %s(" as *byte, wrapper_ret_c as *byte, func_c_name as *byte);
        } else {
            fprintf(codegen.emit_stream as *void, "%s %s(" as *byte, wrapper_ret_c as *byte, func_c_name as *byte);
        }
    }
    pi = 0;
    var first_param: i32 = 1;
    while pi < param_count && pi < 16 {
        const param: &ASTNode = params[pi];
        if param != null && param.type == ASTNodeType.AST_VAR_DECL && param.var_decl_type != null && param.var_decl_name != null {
            if first_param == 0 {
                fputs(", " as *byte, codegen.emit_stream as *void);
            }
            first_param = 0;
            const ptype_c: &byte = c99_type_to_c_async_method_opt(codegen, param.var_decl_type);
            const pname: &byte = get_safe_c_identifier(codegen, param.var_decl_name);
            if ptype_c != null && pname != null {
                fprintf(codegen.emit_stream as *void, "%s %s" as *byte, ptype_c as *byte, pname as *byte);
            }
        }
        pi = pi + 1;
    }
    fputs(") {\n" as *byte, codegen.emit_stream as *void);
    if await_count == 0 && return_future_err_union != 0 && body != null {
        emit_async_err_future_wrapper_prelude(codegen, fn_decl, body, full_return_type);
    }
    // 状态机分配：使用 per-function 帧池分配器，热路径避免 malloc
    fprintf(codegen.emit_stream as *void, "    struct %s *s = %s();\n" as *byte, async_struct as *byte, alloc_name as *byte);
    var pool_full_id: i32 = c99_get_or_add_error_id(codegen, "AsyncFramePoolFull" as *byte);
    if pool_full_id == 0 { pool_full_id = 1; }
    if need_wrap != 0 {
        fprintf(codegen.emit_stream as *void, "    if (s == (void*)0) { return (%s){ .error_id = %dU, .value = (%s){0} }; }\n" as *byte, wrapper_ret_c as *byte, pool_full_id, iface_c as *byte);
    } else {
        fputs("    if (s == (void*)0) { abort(); }\n" as *byte, codegen.emit_stream as *void);
    }
    if frame_init_name != null {
        fprintf(codegen.emit_stream as *void, "    %s(s" as *byte, frame_init_name as *byte);
        pi = 0;
        while pi < param_count && pi < 16 {
            const param: &ASTNode = params[pi];
            if param != null && param.type == ASTNodeType.AST_VAR_DECL && param.var_decl_name != null {
                const pname: &byte = get_safe_c_identifier(codegen, param.var_decl_name);
                if pname != null {
                    fprintf(codegen.emit_stream as *void, ", %s" as *byte, pname as *byte);
                }
            }
            pi = pi + 1;
        }
        fputs(");\n" as *byte, codegen.emit_stream as *void);
    } else {
        fputs("    s->state = 0; __builtin_memset((void *)&s->await_fut, 0, sizeof(s->await_fut));\n" as *byte, codegen.emit_stream as *void);
        pi = 0;
        while pi < param_count && pi < 16 {
            const param: &ASTNode = params[pi];
            if param != null && param.type == ASTNodeType.AST_VAR_DECL && param.var_decl_name != null {
                const pname: &byte = get_safe_c_identifier(codegen, param.var_decl_name);
                if pname != null {
                    fprintf(codegen.emit_stream as *void, "    s->%s = %s;\n" as *byte, pname as *byte, pname as *byte);
                }
            }
            pi = pi + 1;
        }
    }
    if need_wrap != 0 {
        fprintf(codegen.emit_stream as *void, "    return (%s){ .error_id = 0, .value = (%s){ .vtable = (void*)&%s, .data = (void*)s } };\n" as *byte, wrapper_ret_c as *byte, iface_c as *byte, vtable_name as *byte);
    } else {
        fprintf(codegen.emit_stream as *void, "    return (%s){ .vtable = (void*)&%s, .data = (void*)s };\n" as *byte, iface_c as *byte, vtable_name as *byte);
    }
    fputs("\n}\n" as *byte, codegen.emit_stream as *void);
}

// 是否该结构体类型有 drop 方法（规范 §12）
fn type_has_drop_c99(codegen: &C99CodeGenerator, struct_name: &byte) i32 {
    if find_method_in_struct_c99(codegen, struct_name, "drop" as *byte) != null {
        return 1;
    }
    return 0;
}

// 生成方法函数的前向声明（uya_StructName_methodname）
fn gen_method_prototype(codegen: &C99CodeGenerator, fn_decl: &ASTNode, struct_name: &byte) void {
    if fn_decl == null || fn_decl.type != ASTNodeType.AST_FN_DECL || struct_name == null {
        return;
    }
    const method_name: &byte = fn_decl.fn_decl_name;
    const c_name: &byte = get_method_c_name(codegen, struct_name, method_name);
    if c_name == null {
        return;
    }
    var return_c: &byte = convert_array_return_type(codegen, fn_decl.fn_decl_return_type);
    return_c = normalize_poll_return_type(codegen, return_c);
    c99_preregister_slices_method(codegen, fn_decl, struct_name);
    c99_emit_async_frame_forward_for_type(codegen, fn_decl.fn_decl_return_type);
    const params: & & ASTNode = fn_decl.fn_decl_params;
    const param_count: i32 = fn_decl.fn_decl_param_count;
    var pi_fwd_m: i32 = 0;
    while pi_fwd_m < param_count {
        const param_fwd: &ASTNode = params[pi_fwd_m];
        if param_fwd != null && param_fwd.type == ASTNodeType.AST_VAR_DECL && param_fwd.var_decl_type != null {
            c99_emit_async_frame_forward_for_type(codegen, param_fwd.var_decl_type);
        }
        pi_fwd_m = pi_fwd_m + 1;
    }
    if fn_decl.fn_decl_is_async != 0 && codegen.split_enabled == 0 {
        fprintf(codegen.emit_stream as *void, "static __attribute__((used)) %s %s(" as *byte, return_c as *byte, c_name as *byte);
    } else {
        fprintf(codegen.emit_stream as *void, "%s %s(" as *byte, return_c as *byte, c_name as *byte);
    }
    var i: i32 = 0;
    while i < param_count {
        const param: &ASTNode = params[i];
        if param == null || param.type != ASTNodeType.AST_VAR_DECL {
            i = i + 1;
            continue;
        }
        const param_name: &byte = get_safe_c_identifier(codegen, param.var_decl_name);
        const param_type_c: &byte = c99_type_to_c_with_self_opt(codegen, param.var_decl_type, struct_name, 0);
        format_param_type(codegen, param_type_c, param_name, codegen.emit_stream as *void);
        if i < param_count - 1 {
            c99_emit_comma_space(codegen);
        }
        i = i + 1;
    }
    fputs(");\n" as *byte, codegen.emit_stream as *void);
}

// 生成方法函数定义（uya_StructName_methodname）
fn gen_method_function(codegen: &C99CodeGenerator, fn_decl: &ASTNode, struct_name: &byte) void {
    if fn_decl == null || fn_decl.type != ASTNodeType.AST_FN_DECL || struct_name == null || fn_decl.fn_decl_body == null {
        return;
    }
    const method_name: &byte = fn_decl.fn_decl_name;
    const c_name: &byte = get_method_c_name(codegen, struct_name, method_name);
    if c_name == null {
        return;
    }
    const saved_method_struct_early: &byte = codegen.current_method_struct_name;
    codegen.current_method_struct_name = struct_name;
    if fn_decl.fn_decl_is_async != 0 {
        const return_type_async: &ASTNode = fn_decl.fn_decl_return_type;
        var effective_return_type_async: &ASTNode = return_type_async;
        var use_stage_b_async: i32 = 0;
        if return_type_async != null && return_type_async.type == ASTNodeType.AST_TYPE_NAMED &&
            return_type_async.type_named_name != null &&
            strcmp(return_type_async.type_named_name as *byte, "Future" as *byte) == 0 &&
            return_type_async.type_named_type_arg_count == 1 &&
            return_type_async.type_named_type_args != null {
            const a0_async: &ASTNode = return_type_async.type_named_type_args[0];
            if a0_async != null && a0_async.type == ASTNodeType.AST_TYPE_ERROR_UNION &&
                a0_async.type_error_union_payload_type != null {
                use_stage_b_async = 1;
            }
        }
        if use_stage_b_async == 0 && return_type_async != null && return_type_async.type == ASTNodeType.AST_TYPE_ERROR_UNION &&
            return_type_async.type_error_union_payload_type != null {
            const pl_async: &ASTNode = return_type_async.type_error_union_payload_type;
            if pl_async.type == ASTNodeType.AST_TYPE_NAMED && pl_async.type_named_name != null &&
                strcmp(pl_async.type_named_name as *byte, "Future" as *byte) == 0 &&
                pl_async.type_named_type_arg_count == 1 && pl_async.type_named_type_args != null {
                use_stage_b_async = 1;
                effective_return_type_async = pl_async;
            }
        }
        if use_stage_b_async != 0 {
            gen_async_function_stage_b(codegen, fn_decl, c_name, return_type_async, effective_return_type_async, 0);
            codegen.current_method_struct_name = saved_method_struct_early;
            return;
        }
    }
    var return_c: &byte = convert_array_return_type(codegen, fn_decl.fn_decl_return_type);
    return_c = normalize_poll_return_type(codegen, return_c);
    const params: & & ASTNode = fn_decl.fn_decl_params;
    const param_count: i32 = fn_decl.fn_decl_param_count;
    emit_line_directive(codegen, fn_decl.line, fn_decl.filename);
    c99_preregister_slices_method(codegen, fn_decl, struct_name);
    fprintf(codegen.emit_stream as *void, "%s %s(" as *byte, return_c as *byte, c_name as *byte);
    var i: i32 = 0;
    while i < param_count {
        const param: &ASTNode = params[i];
        if param == null || param.type != ASTNodeType.AST_VAR_DECL {
            i = i + 1;
            continue;
        }
        const param_name: &byte = get_safe_c_identifier(codegen, param.var_decl_name);
        const param_type_c: &byte = c99_type_to_c_with_self_opt(codegen, param.var_decl_type, struct_name, 0);
        format_param_type(codegen, param_type_c, param_name, codegen.emit_stream as *void);
        if i < param_count - 1 {
            c99_emit_comma_space(codegen);
        }
        i = i + 1;
    }
    fputs(") {\n" as *byte, codegen.emit_stream as *void);
    codegen.indent_level = codegen.indent_level + 1;
    codegen.current_function_return_type = fn_decl.fn_decl_return_type;
    const saved_current_function_decl: &ASTNode = codegen.current_function_decl;
    codegen.current_function_decl = fn_decl;
    const saved_method_struct: &byte = saved_method_struct_early;
    const saved_local_count: i32 = codegen.local_variable_count;
    const saved_depth: i32 = codegen.current_depth;
    codegen.local_variable_count = 0;
    codegen.current_depth = 0;
    i = 0;
    while i < param_count {
        const param: &ASTNode = params[i];
        if param != null && param.type == ASTNodeType.AST_VAR_DECL {
            const param_name: &byte = get_safe_c_identifier(codegen, param.var_decl_name);
            const param_type_c: &byte = c99_type_to_c_with_self_opt(codegen, param.var_decl_type, struct_name, 0);
            if param_name != null && param_type_c != null && codegen.local_variable_count < C99_MAX_LOCAL_VARS {
                c99_push_local_variable(codegen, param.var_decl_name, param_type_c, param.var_decl_type, codegen.current_depth);
            }
        }
        i = i + 1;
    }
    if method_name != null && strcmp(method_name as *byte, "drop" as *byte) == 0 {
        const struct_decl: &ASTNode = find_struct_decl_c99(codegen, struct_name);
        const self_safe: &byte = get_safe_c_identifier(codegen, "self" as *byte);
        if struct_decl != null && struct_decl.struct_decl_fields != null && self_safe != null {
            const fc: i32 = struct_decl.struct_decl_field_count;
            var fi: i32 = fc - 1;
            while fi >= 0 {
                const field: &ASTNode = struct_decl.struct_decl_fields[fi];
                if field == null || field.type != ASTNodeType.AST_VAR_DECL || field.var_decl_name == null {
                    fi = fi - 1;
                    continue;
                }
                const ft: &ASTNode = field.var_decl_type;
                if ft == null || ft.type != ASTNodeType.AST_TYPE_NAMED || ft.type_named_name == null {
                    fi = fi - 1;
                    continue;
                }
                var drop_type_name: &byte = ft.type_named_name;
                if ft.type_named_type_args != null && ft.type_named_type_arg_count > 0 {
                    const mono_field_name: &byte = get_mono_struct_name(
                        codegen,
                        ft.type_named_name,
                        ft.type_named_type_args,
                        ft.type_named_type_arg_count
                    );
                    if mono_field_name != null {
                        drop_type_name = mono_field_name;
                    }
                }
                if drop_type_name == null || type_has_drop_c99(codegen, drop_type_name) == 0 {
                    fi = fi - 1;
                    continue;
                }
                const drop_c: &byte = get_method_c_name(codegen, drop_type_name, "drop" as *byte);
                const field_safe: &byte = get_safe_c_identifier(codegen, field.var_decl_name);
                if drop_c != null && field_safe != null {
                    c99_emit_indent(codegen);
                    fprintf(codegen.emit_stream as *void, "/* drop field */ %s(%s.%s);\n" as *byte, drop_c as *byte, self_safe as *byte, field_safe as *byte);
                }
                fi = fi - 1;
            }
        }
    }
    gen_stmt(codegen, fn_decl.fn_decl_body);
    
    // 检查函数体是否以 return 结尾
    var has_return: i32 = 0;
    if fn_decl.fn_decl_body != null && fn_decl.fn_decl_body.type == ASTNodeType.AST_BLOCK {
        const stmts: & & ASTNode = fn_decl.fn_decl_body.block_stmts;
        const stmt_count: i32 = fn_decl.fn_decl_body.block_stmt_count;
        var j: i32 = stmt_count - 1;
        while j >= 0 {
            const s: &ASTNode = stmts[j];
            if s != null && s.type != ASTNodeType.AST_DEFER_STMT && s.type != ASTNodeType.AST_ERRDEFER_STMT {
                if s.type == ASTNodeType.AST_RETURN_STMT {
                    has_return = 1;
                } else {
                    has_return = 0;
                }
                break;
            }
            j = j - 1;
        }
    }
    
    // 如果返回类型是 !void 且函数体没有显式返回，添加默认返回语句
    if has_return == 0 && fn_decl.fn_decl_return_type != null && fn_decl.fn_decl_return_type.type == ASTNodeType.AST_TYPE_ERROR_UNION {
        const payload_node: &ASTNode = fn_decl.fn_decl_return_type.type_error_union_payload_type;
        var is_void_payload: i32 = 0;
        if payload_node == null {
            is_void_payload = 1;
        } else if payload_node.type == ASTNodeType.AST_TYPE_NAMED && payload_node.type_named_name != null &&
            strcmp(payload_node.type_named_name as *byte, "void" as *byte) == 0 {
            is_void_payload = 1;
        }
        if is_void_payload != 0 {
            // !void 类型：返回成功的错误联合（缩进与 C 编译器一致）
            codegen.indent_level = codegen.indent_level + 1;
            c99_emit_indent(codegen);
            fprintf(codegen.emit_stream as *void, "return (%s){ .error_id = 0 };\n" as *byte, return_c as *byte);
            codegen.indent_level = codegen.indent_level - 1;
        }
    }
    
    codegen.current_function_return_type = null;
    codegen.current_function_decl = saved_current_function_decl;
    codegen.current_method_struct_name = saved_method_struct;
    codegen.local_variable_count = saved_local_count;
    codegen.current_depth = saved_depth;
    codegen.indent_level = codegen.indent_level - 1;
    c99_emit_indent(codegen);
    c99_emit_close_brace_newline(codegen);
}

// 检查函数是否是泛型函数（有类型参数）
fn is_generic_function_c99(fn_decl: &ASTNode) i32 {
    if fn_decl == null || fn_decl.type != ASTNodeType.AST_FN_DECL {
        return 0;
    }
    if fn_decl.fn_decl_type_param_count > 0 {
        return 1;
    }
    return 0;
}

// 为泛型调用 ok<i32>(...) 解析应使用哪条顶层泛型 fn 声明（避免与同名 export 冲突，如 std.async 的 ok<T>）。
// 优先：与当前正在生成的函数同文件的声明；其次：全程序唯一匹配；再次：首个匹配的 export。
fn find_generic_fn_decl_for_mono_call(codegen: &C99CodeGenerator, func_name: &byte, type_arg_count: i32) &ASTNode {
    if codegen == null || func_name == null || codegen.program_node == null ||
        codegen.program_node.type != ASTNodeType.AST_PROGRAM {
        return null;
    }
    const dc: i32 = codegen.program_node.program_decl_count;
    if codegen.current_function_decl != null && codegen.current_function_decl.filename != null {
        var i: i32 = 0;
        while i < dc {
            const d: &ASTNode = codegen.program_node.program_decls[i];
            if d != null && d.type == ASTNodeType.AST_FN_DECL && d.fn_decl_name != null &&
                strcmp(d.fn_decl_name as *byte, func_name as *byte) == 0 &&
                d.fn_decl_type_param_count == type_arg_count &&
                d.filename != null &&
                strcmp(d.filename as *byte, codegen.current_function_decl.filename as *byte) == 0 {
                return d;
            }
            i = i + 1;
        }
    }
    var found: &ASTNode = null;
    var nfound: i32 = 0;
    var j: i32 = 0;
    while j < dc {
        const d2: &ASTNode = codegen.program_node.program_decls[j];
        if d2 != null && d2.type == ASTNodeType.AST_FN_DECL && d2.fn_decl_name != null &&
            strcmp(d2.fn_decl_name as *byte, func_name as *byte) == 0 &&
            d2.fn_decl_type_param_count == type_arg_count {
            nfound = nfound + 1;
            found = d2;
        }
        j = j + 1;
    }
    if nfound == 1 {
        return found;
    }
    var k: i32 = 0;
    while k < dc {
        const d3: &ASTNode = codegen.program_node.program_decls[k];
        if d3 != null && d3.type == ASTNodeType.AST_FN_DECL && d3.fn_decl_name != null &&
            strcmp(d3.fn_decl_name as *byte, func_name as *byte) == 0 &&
            d3.fn_decl_type_param_count == type_arg_count &&
            d3.fn_decl_is_export != 0 && d3.fn_decl_extern_lib_name == null {
            return d3;
        }
        k = k + 1;
    }
    return find_function_decl_c99(codegen, func_name);
}

// 获取单态化函数名称
// 例如：identity<i32> -> identity_i32
// fn_decl：该单态对应的泛型模板声明；null 时回退旧逻辑（易与同名 export 冲突）
fn get_mono_function_name(codegen: &C99CodeGenerator, generic_name: &byte, type_args: & & ASTNode, type_arg_count: i32, fn_decl: &ASTNode) &byte {
    if codegen == null || generic_name == null || type_args == null || type_arg_count <= 0 {
        return generic_name;
    }
    
    // 构建后缀
    var suffix: [byte: TEMP_BUF_SIZE] = [0: TEMP_BUF_SIZE];
    var suffix_len: i32 = 0;
    
    var i: i32 = 0;
    while i < type_arg_count {
        if i > 0 {
            if suffix_len >= 0 && suffix_len < TEMP_BUF_LIMIT {
                suffix[suffix_len] = 95 as byte;  // '_' = 95
            }
            suffix_len = suffix_len + 1;
        }

        const type_arg: &ASTNode = type_args[i];
        suffix_len = append_type_arg_suffix(codegen, type_arg, &suffix[0], suffix_len, TEMP_BUF_SIZE);
        i = i + 1;
    }
    if suffix_len >= 0 && suffix_len < TEMP_BUF_SIZE {
        suffix[suffix_len] = 0;
    }
    
    // 基名：必须来自「本条」泛型声明所在文件，不能用 get_c_name_for_global_function(name,0)
    // （否则会命中程序中第一个同名 export，如 std.async 的 ok<T> -> std_ok，与测试里私有 ok<T> 单态冲突）。
    var safe_name: &byte = null;
    if fn_decl != null && fn_decl.type == ASTNodeType.AST_FN_DECL && fn_decl.filename != null {
        if fn_decl.fn_decl_is_export != 0 && fn_decl.fn_decl_extern_lib_name != null {
            safe_name = get_safe_c_identifier(codegen, generic_name);
        } else {
            safe_name = get_safe_c_identifier(codegen, get_export_function_c_name(codegen, generic_name, fn_decl.filename));
        }
    } else {
        const legacy_base: &byte = get_c_name_for_global_function(codegen, generic_name, 0);
        safe_name = get_safe_c_identifier(codegen, legacy_base);
    }
    const name_len: usize = (strlen(safe_name as *byte) as usize) + 1 + (suffix_len as usize) + 1;
    const mono_name: &byte = compiler_arena_alloc(codegen.arena, name_len) as &byte;
    if mono_name == null {
        return generic_name;
    }
    snprintf(mono_name as *byte, name_len, "%s_%s" as *byte, safe_name as *byte, (&suffix[0]) as *byte);

    // 若单态名与已有非泛型/显式特化函数的 C 符号冲突，则追加 _mono 避让。
    if codegen.program_node != null {
        const decl_count: i32 = codegen.program_node.program_decl_count;
        var di: i32 = 0;
        while di < decl_count {
            const decl: &ASTNode = codegen.program_node.program_decls[di];
            if decl != null && decl.type == ASTNodeType.AST_FN_DECL && decl.fn_decl_name != null {
                var decl_c_name: &byte = get_c_name_for_global_function(codegen, decl.fn_decl_name, 1);
                if decl.fn_decl_is_export != 0 && decl.filename != null && decl.fn_decl_extern_lib_name == null {
                    decl_c_name = get_export_function_c_name(codegen, decl.fn_decl_name, decl.filename);
                }
                const decl_safe_name: &byte = get_safe_c_identifier(codegen, decl_c_name);
                if decl_safe_name != null && strcmp(decl_safe_name as *byte, mono_name as *byte) == 0 {
                    const mono_name2_len: usize = name_len + 5;
                    const mono_name2: &byte = compiler_arena_alloc(codegen.arena, mono_name2_len) as &byte;
                    if mono_name2 != null {
                        snprintf(mono_name2 as *byte, mono_name2_len, "%s_mono" as *byte, mono_name as *byte);
                        return mono_name2;
                    }
                    break;
                }
            }
            di = di + 1;
        }
    }
    
    return mono_name;
}

// 在单态化上下文中将类型参数替换为具体类型
fn substitute_type_arg(codegen: &C99CodeGenerator, type_node: &ASTNode) &ASTNode {
    if codegen == null || type_node == null {
        return type_node;
    }

    // 对于命名类型：先函数/方法形参，再结构体/联合体单态形参。
    // （c99_type_to_c_uncached 仍「先 struct 再 current」以固定 Poll<!T> 等字段 C 类型；substitute 用于单态函数体/签名时，
    //  若残留 Future vtable 的 struct_type_*（如 T→!i32），不得抢占本函数的 T→i32，否则 AsyncComputeFuture<T> 会变成 err 双包。）
    if type_node.type == ASTNodeType.AST_TYPE_NAMED && type_node.type_named_name != null {
        const name: &byte = type_node.type_named_name;
        var i: i32 = 0;
        while i < codegen.current_type_param_count {
            if codegen.current_type_params[i].name != null &&
                strcmp(codegen.current_type_params[i].name as *byte, name as *byte) == 0 {
                if codegen.current_type_args != null && i < codegen.current_type_arg_count {
                    return codegen.current_type_args[i];
                }
            }
            i = i + 1;
        }

        i = 0;
        while i < codegen.struct_type_param_count {
            if codegen.struct_type_params[i].name != null &&
                strcmp(codegen.struct_type_params[i].name as *byte, name as *byte) == 0 {
                if codegen.struct_type_args != null && i < codegen.struct_type_arg_count {
                    return codegen.struct_type_args[i];
                }
            }
            i = i + 1;
        }

        if type_node.type_named_type_arg_count > 0 && type_node.type_named_type_args != null {
            const arg_count: i32 = type_node.type_named_type_arg_count;
            const args: & & ASTNode = compiler_arena_alloc(codegen.arena, @size_of(&ASTNode) * arg_count) as & & ASTNode;
            var changed: i32 = 0;
            if args != null {
                i = 0;
                while i < arg_count {
                    const substituted_arg: &ASTNode = substitute_type_arg(codegen, type_node.type_named_type_args[i]);
                    args[i] = substituted_arg;
                    if substituted_arg != type_node.type_named_type_args[i] {
                        changed = 1;
                    }
                    i = i + 1;
                }
                if changed != 0 {
                    const new_named: &ASTNode = ast_new_node(ASTNodeType.AST_TYPE_NAMED, type_node.line, type_node.column, codegen.arena, type_node.filename);
                    if new_named != null {
                        new_named.type_named_name = type_node.type_named_name;
                        new_named.type_named_type_args = args;
                        new_named.type_named_type_arg_count = arg_count;
                        return new_named;
                    }
                }
            }
        }
    }

    // 递归处理指针类型 (&T 或 *T)
    if type_node.type == ASTNodeType.AST_TYPE_POINTER && type_node.type_pointer_pointed_type != null {
        const inner_substituted: &ASTNode = substitute_type_arg(codegen, type_node.type_pointer_pointed_type);
        // 如果内部类型被替换了，创建新的指针类型节点
        if inner_substituted != type_node.type_pointer_pointed_type {
            const new_node: &ASTNode = ast_new_node(ASTNodeType.AST_TYPE_POINTER, type_node.line, type_node.column, codegen.arena, type_node.filename);
            if new_node != null {
                new_node.type_pointer_pointed_type = inner_substituted;
                new_node.type_pointer_is_ffi_pointer = type_node.type_pointer_is_ffi_pointer;
                new_node.type_pointer_is_const = type_node.type_pointer_is_const;
                return new_node;
            }
        }
    }

    // 递归处理数组类型 [T: N]
    if type_node.type == ASTNodeType.AST_TYPE_ARRAY && type_node.type_array_element_type != null {
        const elem_substituted: &ASTNode = substitute_type_arg(codegen, type_node.type_array_element_type);
        if elem_substituted != type_node.type_array_element_type {
            const new_node: &ASTNode = ast_new_node(ASTNodeType.AST_TYPE_ARRAY, type_node.line, type_node.column, codegen.arena, type_node.filename);
            if new_node != null {
                new_node.type_array_element_type = elem_substituted;
                new_node.type_array_size_expr = type_node.type_array_size_expr;
                return new_node;
            }
        }
    }

    // 递归处理切片类型 &[T]
    if type_node.type == ASTNodeType.AST_TYPE_SLICE && type_node.type_slice_element_type != null {
        const slice_substituted: &ASTNode = substitute_type_arg(codegen, type_node.type_slice_element_type);
        if slice_substituted != type_node.type_slice_element_type {
            const new_slice: &ASTNode = ast_new_node(ASTNodeType.AST_TYPE_SLICE, type_node.line, type_node.column, codegen.arena, type_node.filename);
            if new_slice != null {
                new_slice.type_slice_element_type = slice_substituted;
                new_slice.type_slice_size_expr = type_node.type_slice_size_expr;
                new_slice.type_slice_element_const = type_node.type_slice_element_const;
                return new_slice;
            }
        }
    }

    // 递归处理错误联合类型 !T（payload 可能包含类型参数）
    if type_node.type == ASTNodeType.AST_TYPE_ERROR_UNION && type_node.type_error_union_payload_type != null {
        const payload_substituted: &ASTNode = substitute_type_arg(codegen, type_node.type_error_union_payload_type);
        if payload_substituted != type_node.type_error_union_payload_type {
            const new_node: &ASTNode = ast_new_node(ASTNodeType.AST_TYPE_ERROR_UNION, type_node.line, type_node.column, codegen.arena, type_node.filename);
            if new_node != null {
                new_node.type_error_union_payload_type = payload_substituted;
                return new_node;
            }
        }
    }

    return type_node;
}

// 获取类型的 C 表示（支持类型参数替换）
fn c99_mono_type_to_c(codegen: &C99CodeGenerator, type_node: &ASTNode) &byte {
    const substituted: &ASTNode = substitute_type_arg(codegen, type_node);
    codegen.type_conv_depth = codegen.type_conv_depth + 1;
    const r: &byte = c99_type_to_c(codegen, substituted);
    codegen.type_conv_depth = codegen.type_conv_depth - 1;
    return r;
}

// 在输出函数原型/定义的形参列表之前：遍历返回类型与各形参，令 c99_type_to_c 登记所有 uya_slice_*，
// 再一次性 emit_pending_slice_structs。禁止在已向 emit_stream 写出 `foo(` 之后调用 emit_pending，
// 否则完整 struct 定义会插入参数表中间，破坏 C 语法。
fn c99_preregister_slices_top_level_fn(codegen: &C99CodeGenerator, fn_decl: &ASTNode) void {
    if codegen == null || fn_decl == null || fn_decl.type != ASTNodeType.AST_FN_DECL {
        return;
    }
    if fn_decl.fn_decl_return_type != null {
        _ = c99_type_to_c(codegen, fn_decl.fn_decl_return_type);
    }
    var pi: i32 = 0;
    while pi < fn_decl.fn_decl_param_count {
        const p: &ASTNode = fn_decl.fn_decl_params[pi];
        if p != null && p.type == ASTNodeType.AST_VAR_DECL && p.var_decl_type != null {
            _ = c99_type_to_c(codegen, p.var_decl_type);
        }
        pi = pi + 1;
    }
    emit_pending_slice_structs(codegen);
}

fn c99_preregister_slices_method(codegen: &C99CodeGenerator, fn_decl: &ASTNode, struct_name: &byte) void {
    if codegen == null || fn_decl == null || fn_decl.type != ASTNodeType.AST_FN_DECL || struct_name == null {
        return;
    }
    if fn_decl.fn_decl_return_type != null {
        _ = c99_type_to_c_with_self_opt(codegen, fn_decl.fn_decl_return_type, struct_name, 0);
    }
    var pi: i32 = 0;
    while pi < fn_decl.fn_decl_param_count {
        const p: &ASTNode = fn_decl.fn_decl_params[pi];
        if p != null && p.type == ASTNodeType.AST_VAR_DECL && p.var_decl_type != null {
            _ = c99_type_to_c_with_self_opt(codegen, p.var_decl_type, struct_name, 0);
        }
        pi = pi + 1;
    }
    emit_pending_slice_structs(codegen);
}

fn c99_preregister_slices_mono_fn(codegen: &C99CodeGenerator, fn_decl: &ASTNode) void {
    if codegen == null || fn_decl == null || fn_decl.type != ASTNodeType.AST_FN_DECL {
        return;
    }
    if fn_decl.fn_decl_return_type != null {
        _ = c99_mono_type_to_c(codegen, fn_decl.fn_decl_return_type);
    }
    var pi: i32 = 0;
    while pi < fn_decl.fn_decl_param_count {
        const p: &ASTNode = fn_decl.fn_decl_params[pi];
        if p != null && p.type == ASTNodeType.AST_VAR_DECL && p.var_decl_type != null {
            _ = c99_mono_type_to_c(codegen, p.var_decl_type);
        }
        pi = pi + 1;
    }
    emit_pending_slice_structs(codegen);
}

// 生成单态化函数原型
fn gen_mono_function_prototype(codegen: &C99CodeGenerator, fn_decl: &ASTNode, type_args: & & ASTNode, type_arg_count: i32) void {
    if fn_decl == null || fn_decl.type != ASTNodeType.AST_FN_DECL || type_args == null {
        return;
    }
    
    const orig_name: &byte = fn_decl.fn_decl_name;
    const mono_name: &byte = get_mono_function_name(codegen, orig_name, type_args, type_arg_count, fn_decl);
    const return_type: &ASTNode = fn_decl.fn_decl_return_type;
    const params: & & ASTNode = fn_decl.fn_decl_params;
    const param_count: i32 = fn_decl.fn_decl_param_count;
    const is_varargs: i32 = fn_decl.fn_decl_is_varargs;
    
    // 保存并设置单态化上下文
    const saved_type_params: &TypeParam = codegen.current_type_params;
    const saved_type_param_count: i32 = codegen.current_type_param_count;
    const saved_type_args: & & ASTNode = codegen.current_type_args;
    const saved_type_arg_count: i32 = codegen.current_type_arg_count;
    
    codegen.current_type_params = fn_decl.fn_decl_type_params;
    codegen.current_type_param_count = fn_decl.fn_decl_type_param_count;
    codegen.current_type_args = type_args;
    codegen.current_type_arg_count = type_arg_count;
    
    // 返回类型（替换类型参数）
    c99_preregister_slices_mono_fn(codegen, fn_decl);
    c99_emit_async_frame_forward_for_type(codegen, return_type);
    var pi_fwd: i32 = 0;
    while pi_fwd < param_count {
        const param_fwd: &ASTNode = params[pi_fwd];
        if param_fwd != null && param_fwd.type == ASTNodeType.AST_VAR_DECL && param_fwd.var_decl_type != null {
            c99_emit_async_frame_forward_for_type(codegen, param_fwd.var_decl_type);
        }
        pi_fwd = pi_fwd + 1;
    }
    const return_c: &byte = c99_mono_type_to_c(codegen, return_type);
    
    if fn_decl.fn_decl_is_async != 0 && fn_decl.fn_decl_is_export == 0 && codegen.split_enabled == 0 {
        fprintf(codegen.emit_stream as *void, "static __attribute__((used)) %s %s(" as *byte, return_c as *byte, mono_name as *byte);
    } else {
        fprintf(codegen.emit_stream as *void, "%s %s(" as *byte, return_c as *byte, mono_name as *byte);
    }
    
    // 参数列表
    var i: i32 = 0;
    while i < param_count {
        const param: &ASTNode = params[i];
        if param == null || param.type != ASTNodeType.AST_VAR_DECL {
            i = i + 1;
            continue;
        }
        
        const param_name: &byte = get_safe_c_identifier(codegen, param.var_decl_name);
        const param_type: &ASTNode = param.var_decl_type;
        const param_type_c: &byte = c99_mono_type_to_c(codegen, param_type);
        format_param_type(codegen, param_type_c, param_name, codegen.emit_stream);
        if i < param_count - 1 {
            c99_emit_comma_space(codegen);
        }
        i = i + 1;
    }
    
    // 处理可变参数
    if is_varargs != 0 {
        if param_count > 0 {
            c99_emit_comma_space(codegen);
        }
        fputs("..." as *byte, codegen.emit_stream as *void);
    }
    
    fputs(");\n" as *byte, codegen.emit_stream as *void);
    
    // 恢复上下文
    codegen.current_type_params = saved_type_params;
    codegen.current_type_param_count = saved_type_param_count;
    codegen.current_type_args = saved_type_args;
    codegen.current_type_arg_count = saved_type_arg_count;
}

// 生成单态化函数定义
fn gen_mono_function(codegen: &C99CodeGenerator, fn_decl: &ASTNode, type_args: & & ASTNode, type_arg_count: i32) void {
    if fn_decl == null || fn_decl.type != ASTNodeType.AST_FN_DECL || type_args == null {
        return;
    }
    
    const orig_name: &byte = fn_decl.fn_decl_name;
    const mono_name: &byte = get_mono_function_name(codegen, orig_name, type_args, type_arg_count, fn_decl);
    const return_type: &ASTNode = fn_decl.fn_decl_return_type;
    const params: & & ASTNode = fn_decl.fn_decl_params;
    const param_count: i32 = fn_decl.fn_decl_param_count;
    const is_varargs: i32 = fn_decl.fn_decl_is_varargs;
    const body: &ASTNode = fn_decl.fn_decl_body;
    
    // 如果没有函数体，跳过
    if body == null {
        return;
    }
    // async_compute<T> 单态：宏 thread_type_is_*(T) 在 C 体生成阶段无法可靠折叠，展开体会落回错误分支。
    // 直接调用 std_thread_async_compute_future_new_<T>（与 lib 中 thread_async_compute_future_new<T> 对应）再装箱为 Future<!T>。
    if orig_name != null && strcmp(orig_name as *byte, "async_compute" as *byte) == 0 &&
        type_arg_count == 1 && type_args[0] != null &&
        type_args[0].type == ASTNodeType.AST_TYPE_NAMED && type_args[0].type_named_name != null {
        var concrete_new_c: &byte = null;
        var concrete_struct_c: &byte = null;
        var concrete_vtable_c: &byte = null;
        var task_kind_val: i32 = 0;
        var arg_bits_c: &byte = null;
        const type_name: &byte = type_args[0].type_named_name;
        if strcmp(type_name as *byte, "i32" as *byte) == 0 {
            concrete_new_c = "std_thread_async_compute_future_new_i32" as &byte;
            concrete_struct_c = "AsyncComputeFuture_i32" as &byte;
            concrete_vtable_c = "uya_vtable_Future_err_i32_AsyncComputeFuture_i32" as &byte;
            task_kind_val = 1;
            arg_bits_c = "(size_t)arg" as &byte;
        } else if strcmp(type_name as *byte, "usize" as *byte) == 0 {
            concrete_new_c = "std_thread_async_compute_future_new_usize" as &byte;
            concrete_struct_c = "AsyncComputeFuture_usize" as &byte;
            concrete_vtable_c = "uya_vtable_Future_err_usize_AsyncComputeFuture_usize" as &byte;
            task_kind_val = 3;
            arg_bits_c = "arg" as &byte;
        } else if strcmp(type_name as *byte, "u32" as *byte) == 0 {
            concrete_new_c = "std_thread_async_compute_future_new_u32" as &byte;
            concrete_struct_c = "AsyncComputeFuture_u32" as &byte;
            concrete_vtable_c = "uya_vtable_Future_err_u32_AsyncComputeFuture_u32" as &byte;
            task_kind_val = 2;
            arg_bits_c = "(size_t)arg" as &byte;
        } else if strcmp(type_name as *byte, "i64" as *byte) == 0 {
            concrete_new_c = "std_thread_async_compute_future_new_i64" as &byte;
            concrete_struct_c = "AsyncComputeFuture_i64" as &byte;
            concrete_vtable_c = "uya_vtable_Future_err_i64_AsyncComputeFuture_i64" as &byte;
            task_kind_val = 4;
            arg_bits_c = "(size_t)arg" as &byte;
        } else if strcmp(type_name as *byte, "u64" as *byte) == 0 {
            concrete_new_c = "std_thread_async_compute_future_new_u64" as &byte;
            concrete_struct_c = "AsyncComputeFuture_u64" as &byte;
            concrete_vtable_c = "uya_vtable_Future_err_u64_AsyncComputeFuture_u64" as &byte;
            task_kind_val = 5;
            arg_bits_c = "(size_t)arg" as &byte;
        } else if strcmp(type_name as *byte, "i16" as *byte) == 0 {
            concrete_new_c = "std_thread_async_compute_future_new_i16" as &byte;
            concrete_struct_c = "AsyncComputeFuture_i16" as &byte;
            concrete_vtable_c = "uya_vtable_Future_err_i16_AsyncComputeFuture_i16" as &byte;
            task_kind_val = 6;
            arg_bits_c = "(size_t)arg" as &byte;
        } else if strcmp(type_name as *byte, "u16" as *byte) == 0 {
            concrete_new_c = "std_thread_async_compute_future_new_u16" as &byte;
            concrete_struct_c = "AsyncComputeFuture_u16" as &byte;
            concrete_vtable_c = "uya_vtable_Future_err_u16_AsyncComputeFuture_u16" as &byte;
            task_kind_val = 7;
            arg_bits_c = "(size_t)arg" as &byte;
        } else if strcmp(type_name as *byte, "i8" as *byte) == 0 {
            concrete_new_c = "std_thread_async_compute_future_new_i8" as &byte;
            concrete_struct_c = "AsyncComputeFuture_i8" as &byte;
            concrete_vtable_c = "uya_vtable_Future_err_i8_AsyncComputeFuture_i8" as &byte;
            task_kind_val = 8;
            arg_bits_c = "(size_t)arg" as &byte;
        } else if strcmp(type_name as *byte, "u8" as *byte) == 0 {
            concrete_new_c = "std_thread_async_compute_future_new_u8" as &byte;
            concrete_struct_c = "AsyncComputeFuture_u8" as &byte;
            concrete_vtable_c = "uya_vtable_Future_err_u8_AsyncComputeFuture_u8" as &byte;
            task_kind_val = 9;
            arg_bits_c = "(size_t)arg" as &byte;
        } else if strcmp(type_name as *byte, "bool" as *byte) == 0 {
            concrete_new_c = "std_thread_async_compute_future_new_bool" as &byte;
            concrete_struct_c = "AsyncComputeFuture_bool" as &byte;
            concrete_vtable_c = "uya_vtable_Future_err_bool_AsyncComputeFuture_bool" as &byte;
            task_kind_val = 10;
            arg_bits_c = "(size_t)(arg ? 1 : 0)" as &byte;
        } else if strcmp(type_name as *byte, "f32" as *byte) == 0 {
            concrete_new_c = "std_thread_async_compute_future_new_f32" as &byte;
            concrete_struct_c = "AsyncComputeFuture_f32" as &byte;
            concrete_vtable_c = "uya_vtable_Future_err_f32_AsyncComputeFuture_f32" as &byte;
            task_kind_val = 11;
            arg_bits_c = "thread_f32_arg_bits(arg)" as &byte;
        } else if strcmp(type_name as *byte, "f64" as *byte) == 0 {
            concrete_new_c = "std_thread_async_compute_future_new_f64" as &byte;
            concrete_struct_c = "AsyncComputeFuture_f64" as &byte;
            concrete_vtable_c = "uya_vtable_Future_err_f64_AsyncComputeFuture_f64" as &byte;
            task_kind_val = 12;
            arg_bits_c = "thread_f64_arg_bits(arg)" as &byte;
        }
        if concrete_new_c != null && concrete_struct_c != null && concrete_vtable_c != null && arg_bits_c != null {
            const saved_type_params2: &TypeParam = codegen.current_type_params;
            const saved_type_param_count2: i32 = codegen.current_type_param_count;
            const saved_type_args2: & & ASTNode = codegen.current_type_args;
            const saved_type_arg_count2: i32 = codegen.current_type_arg_count;
            codegen.current_type_params = fn_decl.fn_decl_type_params;
            codegen.current_type_param_count = fn_decl.fn_decl_type_param_count;
            codegen.current_type_args = type_args;
            codegen.current_type_arg_count = type_arg_count;

            emit_line_directive(codegen, fn_decl.line, fn_decl.filename);
            const return_c2: &byte = c99_mono_type_to_c(codegen, return_type);
            if fn_decl.fn_decl_is_export != 0 {
                fprintf(codegen.emit_stream as *void, "%s %s(" as *byte, return_c2 as *byte, mono_name as *byte);
            } else {
                if codegen.split_enabled == 0 {
                    fprintf(codegen.emit_stream as *void, "static __attribute__((used)) %s %s(" as *byte, return_c2 as *byte, mono_name as *byte);
                } else {
                    fprintf(codegen.emit_stream as *void, "%s %s(" as *byte, return_c2 as *byte, mono_name as *byte);
                }
            }
            var ai: i32 = 0;
            while ai < param_count {
                const param2: &ASTNode = params[ai];
                if param2 == null || param2.type != ASTNodeType.AST_VAR_DECL {
                    ai = ai + 1;
                    continue;
                }
                const param_name2: &byte = get_safe_c_identifier(codegen, param2.var_decl_name);
                const param_type2: &byte = c99_mono_type_to_c(codegen, param2.var_decl_type);
                format_param_type(codegen, param_type2, param_name2, codegen.emit_stream);
                if ai < param_count - 1 {
                    c99_emit_comma_space(codegen);
                }
                ai = ai + 1;
            }
            if is_varargs != 0 {
                if param_count > 0 {
                    c99_emit_comma_space(codegen);
                }
                fputs("..." as *byte, codegen.emit_stream as *void);
            }
            fputs(") {\n" as *byte, codegen.emit_stream as *void);
            fprintf(codegen.emit_stream as *void, "    struct %s _uya_tmp = %s(pool, compute_fn, %d, %s);\n" as *byte,
                concrete_struct_c as *byte, concrete_new_c as *byte, task_kind_val, arg_bits_c as *byte);
            fprintf(codegen.emit_stream as *void, "    struct %s *_uya_box = (struct %s *)std_async_box_alloc_current(sizeof(struct %s));\n" as *byte,
                concrete_struct_c as *byte, concrete_struct_c as *byte, concrete_struct_c as *byte);
            fprintf(codegen.emit_stream as *void, "    if (_uya_box != (void*)0) { *_uya_box = _uya_tmp; }\n" as *byte);
            fprintf(codegen.emit_stream as *void, "    return (%s){ .vtable = (void*)&%s, .data = (void*)_uya_box };\n" as *byte,
                return_c2 as *byte, concrete_vtable_c as *byte);
            fputs("}\n" as *byte, codegen.emit_stream as *void);

            codegen.current_type_params = saved_type_params2;
            codegen.current_type_param_count = saved_type_param_count2;
            codegen.current_type_args = saved_type_args2;
            codegen.current_type_arg_count = saved_type_arg_count2;
            return;
        }
    }
    var body_to_gen: &ASTNode = body;
    if codegen.checker != null && orig_name != null &&
       (strcmp(orig_name as *byte, "to_json" as *byte) == 0 ||
        strcmp(orig_name as *byte, "async_compute" as *byte) == 0) &&
       fn_decl.fn_decl_type_params != null && fn_decl.fn_decl_type_param_count > 0 &&
       type_args != null && type_arg_count > 0 {
        const expanded: &ASTNode = prepare_mono_body_expand_macros(codegen.checker, body,
            fn_decl.fn_decl_type_params, fn_decl.fn_decl_type_param_count, type_args, type_arg_count);
        if expanded != null { body_to_gen = expanded; }
    }
    // from_json<T>：首类型实参为结构体时，按结构体字段生成解码 body（与 to_json 一致，无需方法块声明）
    if codegen.checker != null && orig_name != null && strcmp(orig_name as *byte, "from_json" as *byte) == 0 &&
       type_args != null && type_arg_count >= 1 && type_args[0] != null &&
       type_args[0].type == ASTNodeType.AST_TYPE_NAMED && type_args[0].type_named_name != null {
        var filename: &byte = null;
        if fn_decl.filename != null {
            filename = fn_decl.filename;
        }
        const reflect_body: &ASTNode = build_from_json_reflect_body(codegen.checker, type_args[0],
            fn_decl.line, fn_decl.column, filename);
        if reflect_body != null { body_to_gen = reflect_body; }
    }
    // 保存并设置单态化上下文
    const saved_type_params: &TypeParam = codegen.current_type_params;
    const saved_type_param_count: i32 = codegen.current_type_param_count;
    const saved_type_args: & & ASTNode = codegen.current_type_args;
    const saved_type_arg_count: i32 = codegen.current_type_arg_count;
    
    codegen.current_type_params = fn_decl.fn_decl_type_params;
    codegen.current_type_param_count = fn_decl.fn_decl_type_param_count;
    codegen.current_type_args = type_args;
    codegen.current_type_arg_count = type_arg_count;

    // 泛型 @async_fn 也需要走 stage-B 状态机生成；否则会按普通函数落下 @await。
    if fn_decl.fn_decl_is_async != 0 {
        var use_stage_b: i32 = 0;
        var effective_return_type: &ASTNode = return_type;
        if return_type != null && return_type.type == ASTNodeType.AST_TYPE_NAMED &&
            return_type.type_named_name != null &&
            strcmp(return_type.type_named_name as *byte, "Future" as *byte) == 0 &&
            return_type.type_named_type_arg_count == 1 &&
            return_type.type_named_type_args != null {
            const a0: &ASTNode = return_type.type_named_type_args[0];
            if a0 != null && a0.type == ASTNodeType.AST_TYPE_ERROR_UNION &&
                a0.type_error_union_payload_type != null {
                use_stage_b = 1;
            }
        }
        if use_stage_b == 0 && return_type != null && return_type.type == ASTNodeType.AST_TYPE_ERROR_UNION &&
            return_type.type_error_union_payload_type != null {
            const pl: &ASTNode = return_type.type_error_union_payload_type;
            if pl.type == ASTNodeType.AST_TYPE_NAMED && pl.type_named_name != null &&
                strcmp(pl.type_named_name as *byte, "Future" as *byte) == 0 &&
                pl.type_named_type_arg_count == 1 && pl.type_named_type_args != null {
                use_stage_b = 1;
                effective_return_type = pl;
            }
        }
        if use_stage_b != 0 {
            gen_async_function_stage_b(codegen, fn_decl, mono_name, return_type, effective_return_type, 0);
            codegen.current_type_params = saved_type_params;
            codegen.current_type_param_count = saved_type_param_count;
            codegen.current_type_args = saved_type_args;
            codegen.current_type_arg_count = saved_type_arg_count;
            return;
        }
    }
    
    // 生成 #line 指令
    emit_line_directive(codegen, fn_decl.line, fn_decl.filename);
    
    // 返回类型（替换类型参数）
    c99_preregister_slices_mono_fn(codegen, fn_decl);
    const return_c: &byte = c99_mono_type_to_c(codegen, return_type);
    fprintf(codegen.emit_stream as *void, "%s %s(" as *byte, return_c as *byte, mono_name as *byte);
    
    // 参数列表
    var i: i32 = 0;
    while i < param_count {
        const param: &ASTNode = params[i];
        if param == null || param.type != ASTNodeType.AST_VAR_DECL {
            i = i + 1;
            continue;
        }
        
        const param_name: &byte = get_safe_c_identifier(codegen, param.var_decl_name);
        const param_type: &ASTNode = param.var_decl_type;
        const param_type_c: &byte = c99_mono_type_to_c(codegen, param_type);
        format_param_type(codegen, param_type_c, param_name, codegen.emit_stream);
        if i < param_count - 1 {
            c99_emit_comma_space(codegen);
        }
        i = i + 1;
    }
    
    // 处理可变参数
    if is_varargs != 0 {
        if param_count > 0 {
            c99_emit_comma_space(codegen);
        }
        fputs("..." as *byte, codegen.emit_stream as *void);
    }
    
    fputs(") {\n" as *byte, codegen.emit_stream as *void);
    
    // 保存当前状态
    const saved_return_type: &ASTNode = codegen.current_function_return_type;
    const saved_current_function_decl: &ASTNode = codegen.current_function_decl;
    const saved_local_count: i32 = codegen.local_variable_count;
    const saved_depth: i32 = codegen.current_depth;
    
    codegen.current_function_return_type = return_type;
    codegen.current_function_decl = fn_decl;
    codegen.indent_level = codegen.indent_level + 1;
    codegen.current_depth = codegen.current_depth + 1;
    
    // 将参数添加到局部变量表
    i = 0;
    while i < param_count {
        const param: &ASTNode = params[i];
        if param != null && param.type == ASTNodeType.AST_VAR_DECL {
            if codegen.local_variable_count < C99_MAX_LOCAL_VARS {
                const mono_param_type_c: &byte = c99_mono_type_to_c(codegen, param.var_decl_type);
                c99_push_local_variable(codegen, param.var_decl_name, mono_param_type_c, param.var_decl_type, codegen.current_depth);
            }
        }
        i = i + 1;
    }
    i = 0;
    while i < param_count {
        const param: &ASTNode = params[i];
        if param != null && param.type == ASTNodeType.AST_VAR_DECL {
            const pname: &byte = get_safe_c_identifier(codegen, param.var_decl_name);
            if pname != null {
                c99_emit_indent(codegen);
                fputs("(void)" as *byte, codegen.emit_stream as *void);
                fputs(pname as *byte, codegen.emit_stream as *void);
                c99_emit_semi_newline(codegen);
            }
        }
        i = i + 1;
    }
    
    // 生成函数体
    gen_stmt(codegen, body_to_gen);
    
    // 若返回类型非 void 且函数体末尾无 return，补兜底 return 避免 -Wreturn-type
    var has_return_mono: i32 = 0;
    if body_to_gen.type == ASTNodeType.AST_BLOCK && body_to_gen.block_stmts != null {
        const stmts_mono: & & ASTNode = body_to_gen.block_stmts;
        const stmt_count_mono: i32 = body_to_gen.block_stmt_count;
        var j: i32 = stmt_count_mono - 1;
        while j >= 0 {
            const s: &ASTNode = stmts_mono[j];
            if s != null && s.type != ASTNodeType.AST_DEFER_STMT && s.type != ASTNodeType.AST_ERRDEFER_STMT {
                if s.type == ASTNodeType.AST_RETURN_STMT {
                    has_return_mono = 1;
                }
                j = -1;
                break;
            }
            j = j - 1;
        }
    }
    const rt: &ASTNode = codegen.current_function_return_type;
    if has_return_mono == 0 && rt != null {
        var is_void_mono: i32 = 0;
        if rt.type == ASTNodeType.AST_TYPE_NAMED && rt.type_named_name != null &&
            strcmp(rt.type_named_name as *byte, "void" as *byte) == 0 {
            is_void_mono = 1;
        } else if rt.type == ASTNodeType.AST_TYPE_ERROR_UNION {
            const pl: &ASTNode = rt.type_error_union_payload_type;
            if pl == null {
                is_void_mono = 1;
            } else if pl.type == ASTNodeType.AST_TYPE_NAMED && pl.type_named_name != null &&
                strcmp(pl.type_named_name as *byte, "void" as *byte) == 0 {
                is_void_mono = 1;
            }
        }
        if is_void_mono == 0 {
            codegen.indent_level = codegen.indent_level + 1;
            c99_emit_indent(codegen);
            if return_c != null && strncmp(return_c as *byte, "struct " as *byte, 7) == 0 {
                fprintf(codegen.emit_stream as *void, "return (%s){0};\n" as *byte, return_c as *byte);
            } else {
                fputs("return 0;\n" as *byte, codegen.emit_stream as *void);
            }
            codegen.indent_level = codegen.indent_level - 1;
        }
    }
    
    // 恢复状态
    codegen.current_function_return_type = saved_return_type;
    codegen.current_function_decl = saved_current_function_decl;
    codegen.local_variable_count = saved_local_count;
    codegen.current_depth = saved_depth;
    codegen.indent_level = codegen.indent_level - 1;
    
    c99_emit_close_brace_newline(codegen);
    
    // 恢复单态化上下文
    codegen.current_type_params = saved_type_params;
    codegen.current_type_param_count = saved_type_param_count;
    codegen.current_type_args = saved_type_args;
    codegen.current_type_arg_count = saved_type_arg_count;
}

// 生成单态化方法原型
fn gen_mono_method_prototype(codegen: &C99CodeGenerator, fn_decl: &ASTNode, struct_name: &byte, type_args: & & ASTNode, type_arg_count: i32) void {
    if fn_decl == null || fn_decl.type != ASTNodeType.AST_FN_DECL || type_args == null || struct_name == null {
        return;
    }
    
    const method_name: &byte = fn_decl.fn_decl_name;
    
    // 构建单态化方法名
    var mono_name_buf: [byte: C99_TYPE_ARG_BUF_SIZE] = [];
    var pos: i32 = snprintf(&mono_name_buf[0] as *byte, C99_TYPE_ARG_BUF_SIZE, "%s_%s" as *byte, struct_name as *byte, method_name as *byte);
    var ti: i32 = 0;
    while ti < type_arg_count && pos < C99_TYPE_ARG_BUF_LIMIT {
        pos = pos + snprintf(&mono_name_buf[pos] as *byte, C99_TYPE_ARG_BUF_SIZE - pos, "_" as *byte);
        const type_arg: &ASTNode = type_args[ti];
        if type_arg != null && type_arg.type == ASTNodeType.AST_TYPE_NAMED && type_arg.type_named_name != null {
            pos = pos + snprintf(&mono_name_buf[pos] as *byte, C99_TYPE_ARG_BUF_SIZE - pos, "%s" as *byte, type_arg.type_named_name as *byte);
        }
        ti = ti + 1;
    }
    const mono_method_name: &byte = get_safe_c_identifier(codegen, &mono_name_buf[0]);
    
    // 保存方法的类型参数上下文
    const saved_type_params: &TypeParam = codegen.current_type_params;
    const saved_type_param_count: i32 = codegen.current_type_param_count;
    const saved_type_args: & & ASTNode = codegen.current_type_args;
    const saved_type_arg_count: i32 = codegen.current_type_arg_count;
    
    // 设置方法的类型参数上下文（结构体的类型参数上下文已经在外层设置）
    codegen.current_type_params = fn_decl.fn_decl_type_params;
    codegen.current_type_param_count = fn_decl.fn_decl_type_param_count;
    codegen.current_type_args = type_args;
    codegen.current_type_arg_count = type_arg_count;
    
    // 使用 c99_type_to_c_with_self 来正确处理 Self 类型
    c99_preregister_slices_method(codegen, fn_decl, struct_name);
    c99_emit_async_frame_forward_for_type(codegen, fn_decl.fn_decl_return_type);
    const return_c: &byte = c99_type_to_c_with_self(codegen, fn_decl.fn_decl_return_type, struct_name);
    const params: & & ASTNode = fn_decl.fn_decl_params;
    const param_count: i32 = fn_decl.fn_decl_param_count;
    var pi_fwd_mm: i32 = 0;
    while pi_fwd_mm < param_count {
        const param_fwd: &ASTNode = params[pi_fwd_mm];
        if param_fwd != null && param_fwd.type == ASTNodeType.AST_VAR_DECL && param_fwd.var_decl_type != null {
            c99_emit_async_frame_forward_for_type(codegen, param_fwd.var_decl_type);
        }
        pi_fwd_mm = pi_fwd_mm + 1;
    }
    
    if fn_decl.fn_decl_is_async != 0 && codegen.split_enabled == 0 {
        fprintf(codegen.emit_stream as *void, "static __attribute__((used)) %s %s(" as *byte, return_c as *byte, mono_method_name as *byte);
    } else {
        fprintf(codegen.emit_stream as *void, "%s %s(" as *byte, return_c as *byte, mono_method_name as *byte);
    }
    
    var i: i32 = 0;
    while i < param_count {
        const param: &ASTNode = params[i];
        if param == null || param.type != ASTNodeType.AST_VAR_DECL {
            i = i + 1;
            continue;
        }
        
        const param_name: &byte = get_safe_c_identifier(codegen, param.var_decl_name);
        const param_type_c: &byte = c99_type_to_c_with_self(codegen, param.var_decl_type, struct_name);
        format_param_type(codegen, param_type_c, param_name, codegen.emit_stream);
        if i < param_count - 1 {
            c99_emit_comma_space(codegen);
        }
        i = i + 1;
    }
    
    fputs(");\n" as *byte, codegen.emit_stream as *void);
    
    // 恢复方法的类型参数上下文
    codegen.current_type_params = saved_type_params;
    codegen.current_type_param_count = saved_type_param_count;
    codegen.current_type_args = saved_type_args;
    codegen.current_type_arg_count = saved_type_arg_count;
}

// 生成单态化方法函数定义
fn gen_mono_method_function(codegen: &C99CodeGenerator, fn_decl: &ASTNode, struct_name: &byte, type_args: & & ASTNode, type_arg_count: i32) void {
    if fn_decl == null || fn_decl.type != ASTNodeType.AST_FN_DECL || type_args == null || struct_name == null || fn_decl.fn_decl_body == null {
        return;
    }
    
    const method_name: &byte = fn_decl.fn_decl_name;
    
    // 构建单态化方法名
    var mono_name_buf: [byte: C99_TYPE_ARG_BUF_SIZE] = [];
    var pos: i32 = snprintf(&mono_name_buf[0] as *byte, C99_TYPE_ARG_BUF_SIZE, "%s_%s" as *byte, struct_name as *byte, method_name as *byte);
    var ti: i32 = 0;
    while ti < type_arg_count && pos < C99_TYPE_ARG_BUF_LIMIT {
        pos = pos + snprintf(&mono_name_buf[pos] as *byte, C99_TYPE_ARG_BUF_SIZE - pos, "_" as *byte);
        const type_arg: &ASTNode = type_args[ti];
        if type_arg != null && type_arg.type == ASTNodeType.AST_TYPE_NAMED && type_arg.type_named_name != null {
            pos = pos + snprintf(&mono_name_buf[pos] as *byte, C99_TYPE_ARG_BUF_SIZE - pos, "%s" as *byte, type_arg.type_named_name as *byte);
        }
        ti = ti + 1;
    }
    const mono_method_name: &byte = get_safe_c_identifier(codegen, &mono_name_buf[0]);
    
    const return_type: &ASTNode = fn_decl.fn_decl_return_type;
    const params: & & ASTNode = fn_decl.fn_decl_params;
    const param_count: i32 = fn_decl.fn_decl_param_count;
    const body: &ASTNode = fn_decl.fn_decl_body;
    
    // 保存方法的类型参数上下文
    const saved_type_params: &TypeParam = codegen.current_type_params;
    const saved_type_param_count: i32 = codegen.current_type_param_count;
    const saved_type_args: & & ASTNode = codegen.current_type_args;
    const saved_type_arg_count: i32 = codegen.current_type_arg_count;
    
    // 设置方法的类型参数上下文（结构体的类型参数上下文已经在外层设置）
    codegen.current_type_params = fn_decl.fn_decl_type_params;
    codegen.current_type_param_count = fn_decl.fn_decl_type_param_count;
    codegen.current_type_args = type_args;
    codegen.current_type_arg_count = type_arg_count;
    const saved_method_struct_early: &byte = codegen.current_method_struct_name;
    codegen.current_method_struct_name = struct_name;

    if fn_decl.fn_decl_is_async != 0 {
        var effective_return_type_async: &ASTNode = return_type;
        var use_stage_b_async: i32 = 0;
        if return_type != null && return_type.type == ASTNodeType.AST_TYPE_NAMED &&
            return_type.type_named_name != null &&
            strcmp(return_type.type_named_name as *byte, "Future" as *byte) == 0 &&
            return_type.type_named_type_arg_count == 1 &&
            return_type.type_named_type_args != null {
            const a0_async: &ASTNode = return_type.type_named_type_args[0];
            if a0_async != null && a0_async.type == ASTNodeType.AST_TYPE_ERROR_UNION &&
                a0_async.type_error_union_payload_type != null {
                use_stage_b_async = 1;
            }
        }
        if use_stage_b_async == 0 && return_type != null && return_type.type == ASTNodeType.AST_TYPE_ERROR_UNION &&
            return_type.type_error_union_payload_type != null {
            const pl_async: &ASTNode = return_type.type_error_union_payload_type;
            if pl_async.type == ASTNodeType.AST_TYPE_NAMED && pl_async.type_named_name != null &&
                strcmp(pl_async.type_named_name as *byte, "Future" as *byte) == 0 &&
                pl_async.type_named_type_arg_count == 1 && pl_async.type_named_type_args != null {
                use_stage_b_async = 1;
                effective_return_type_async = pl_async;
            }
        }
        if use_stage_b_async != 0 {
            gen_async_function_stage_b(codegen, fn_decl, mono_method_name, return_type, effective_return_type_async, 0);
            codegen.current_method_struct_name = saved_method_struct_early;
            codegen.current_type_params = saved_type_params;
            codegen.current_type_param_count = saved_type_param_count;
            codegen.current_type_args = saved_type_args;
            codegen.current_type_arg_count = saved_type_arg_count;
            return;
        }
    }
    
    emit_line_directive(codegen, fn_decl.line, fn_decl.filename);
    
    // 使用 c99_type_to_c_with_self 来正确处理 Self 类型
    c99_preregister_slices_method(codegen, fn_decl, struct_name);
    const return_c: &byte = c99_type_to_c_with_self(codegen, return_type, struct_name);
    fprintf(codegen.emit_stream as *void, "%s %s(" as *byte, return_c as *byte, mono_method_name as *byte);
    
    var i: i32 = 0;
    while i < param_count {
        const param: &ASTNode = params[i];
        if param == null || param.type != ASTNodeType.AST_VAR_DECL {
            i = i + 1;
            continue;
        }
        
        const param_name: &byte = get_safe_c_identifier(codegen, param.var_decl_name);
        const param_type_c: &byte = c99_type_to_c_with_self(codegen, param.var_decl_type, struct_name);
        format_param_type(codegen, param_type_c, param_name, codegen.emit_stream);
        if i < param_count - 1 {
            c99_emit_comma_space(codegen);
        }
        i = i + 1;
    }
    
    fputs(") {\n" as *byte, codegen.emit_stream as *void);
    
    // 保存当前状态
    const saved_return_type: &ASTNode = codegen.current_function_return_type;
    const saved_current_function_decl: &ASTNode = codegen.current_function_decl;
    const saved_local_count: i32 = codegen.local_variable_count;
    const saved_depth: i32 = codegen.current_depth;
    const saved_method_struct: &byte = saved_method_struct_early;
    
    codegen.current_function_return_type = return_type;
    codegen.current_function_decl = fn_decl;
    codegen.indent_level = codegen.indent_level + 1;
    codegen.current_depth = codegen.current_depth + 1;
    
    // 将参数添加到局部变量表
    i = 0;
    while i < param_count {
        const param: &ASTNode = params[i];
        if param != null && param.type == ASTNodeType.AST_VAR_DECL {
            if codegen.local_variable_count < C99_MAX_LOCAL_VARS {
                const method_param_type_c: &byte = c99_type_to_c_with_self(codegen, param.var_decl_type, struct_name);
                c99_push_local_variable(codegen, param.var_decl_name, method_param_type_c, param.var_decl_type, codegen.current_depth);
            }
        }
        i = i + 1;
    }
    
    i = 0;
    while i < param_count {
        const param: &ASTNode = params[i];
        if param != null && param.type == ASTNodeType.AST_VAR_DECL {
            const pname: &byte = get_safe_c_identifier(codegen, param.var_decl_name);
            if pname != null {
                c99_emit_indent(codegen);
                fputs("(void)" as *byte, codegen.emit_stream as *void);
                fputs(pname as *byte, codegen.emit_stream as *void);
                c99_emit_semi_newline(codegen);
            }
        }
        i = i + 1;
    }
    
    // 生成函数体
    gen_stmt(codegen, body);
    
    // 若返回类型非 void 且函数体末尾无 return，补兜底 return
    var has_return_mono: i32 = 0;
    if body.type == ASTNodeType.AST_BLOCK && body.block_stmts != null {
        const stmts_mono: & & ASTNode = body.block_stmts;
        const stmt_count_mono: i32 = body.block_stmt_count;
        var j: i32 = stmt_count_mono - 1;
        while j >= 0 {
            const s: &ASTNode = stmts_mono[j];
            if s != null && s.type != ASTNodeType.AST_DEFER_STMT && s.type != ASTNodeType.AST_ERRDEFER_STMT {
                if s.type == ASTNodeType.AST_RETURN_STMT {
                    has_return_mono = 1;
                }
                j = -1;
                break;
            }
            j = j - 1;
        }
    }
    const rt: &ASTNode = codegen.current_function_return_type;
    if has_return_mono == 0 && rt != null {
        var is_void_mono: i32 = 0;
        if rt.type == ASTNodeType.AST_TYPE_NAMED && rt.type_named_name != null &&
            strcmp(rt.type_named_name as *byte, "void" as *byte) == 0 {
            is_void_mono = 1;
        } else if rt.type == ASTNodeType.AST_TYPE_ERROR_UNION {
            const pl: &ASTNode = rt.type_error_union_payload_type;
            if pl == null {
                is_void_mono = 1;
            } else if pl.type == ASTNodeType.AST_TYPE_NAMED && pl.type_named_name != null &&
                strcmp(pl.type_named_name as *byte, "void" as *byte) == 0 {
                is_void_mono = 1;
            }
        }
        if is_void_mono == 0 {
            codegen.indent_level = codegen.indent_level + 1;
            c99_emit_indent(codegen);
            if return_c != null && strncmp(return_c as *byte, "struct " as *byte, 7) == 0 {
                fprintf(codegen.emit_stream as *void, "return (%s){0};\n" as *byte, return_c as *byte);
            } else {
                fputs("return 0;\n" as *byte, codegen.emit_stream as *void);
            }
            codegen.indent_level = codegen.indent_level - 1;
        }
    }
    
    // 恢复状态
    codegen.current_function_return_type = saved_return_type;
    codegen.current_function_decl = saved_current_function_decl;
    codegen.local_variable_count = saved_local_count;
    codegen.current_depth = saved_depth;
    codegen.current_method_struct_name = saved_method_struct;
    codegen.indent_level = codegen.indent_level - 1;
    
    c99_emit_close_brace_newline(codegen);
    
    // 恢复方法的类型参数上下文
    codegen.current_type_params = saved_type_params;
    codegen.current_type_param_count = saved_type_param_count;
    codegen.current_type_args = saved_type_args;
    codegen.current_type_arg_count = saved_type_arg_count;
}
