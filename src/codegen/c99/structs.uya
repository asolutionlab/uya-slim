// structs.uya - C99 代码生成器结构体模块
// 提供结构体定义生成功能
//
// 注意：需要先包含 internal.uya（包含类型定义和函数声明）
// 由于 Uya Mini 不支持模块系统，这里假设相关类型已经定义

// 检查结构体是否已添加到表中
fn is_struct_in_table(codegen: &C99CodeGenerator, struct_name: &byte) i32 {
    if struct_name == null {
        return 0;
    }
    var i: i32 = 0;
    while i < codegen.struct_definition_count {
        if codegen.struct_definitions[i].name != null && 
            strcmp(codegen.struct_definitions[i].name as *byte, struct_name as *byte) == 0 {
            return 1;
        }
        i = i + 1;
    }
    return 0;
}

// 检查结构体是否已定义
fn is_struct_defined(codegen: &C99CodeGenerator, struct_name: &byte) i32 {
    var i: i32 = 0;
    while i < codegen.struct_definition_count {
        if strcmp(codegen.struct_definitions[i].name as *byte, struct_name as *byte) == 0 {
            const result: i32 = codegen.struct_definitions[i].defined;
            return result;
        }
        i = i + 1;
    }
    return 0;
}

// 标记结构体已定义
fn mark_struct_defined(codegen: &C99CodeGenerator, struct_name: &byte) void {
    var i: i32 = 0;
    while i < codegen.struct_definition_count {
        if strcmp(codegen.struct_definitions[i].name as *byte, struct_name as *byte) == 0 {
            codegen.struct_definitions[i].defined = 1;
            return;
        }
        i = i + 1;
    }
    
    // 如果不在表中，添加
    const struct_idx: i32 = codegen.struct_definition_count;
    if struct_idx >= 0 && struct_idx < C99_MAX_STRUCT_DEFINITIONS {
        codegen.struct_definitions[struct_idx].name = struct_name;
        codegen.struct_definitions[struct_idx].defined = 1;
        codegen.struct_definition_count = struct_idx + 1;
    }
}

// 添加结构体定义
fn add_struct_definition(codegen: &C99CodeGenerator, struct_name: &byte) void {
    if is_struct_in_table(codegen, struct_name) != 0 {
        return;
    }
    if is_struct_defined(codegen, struct_name) != 0 {
        return;
    }
    
    const struct_idx2: i32 = codegen.struct_definition_count;
    if struct_idx2 >= 0 && struct_idx2 < C99_MAX_STRUCT_DEFINITIONS {
        codegen.struct_definitions[struct_idx2].name = struct_name;
        codegen.struct_definitions[struct_idx2].defined = 0;
        codegen.struct_definition_count = struct_idx2 + 1;
    }
}

// 查找结构体声明
fn find_struct_decl_c99(codegen: &C99CodeGenerator, struct_name: &byte) &ASTNode {
    if codegen == null || struct_name == null || codegen.program_node == null {
        return null;
    }
    if codegen.decl_cache_initialized == 0 {
        build_decl_caches(codegen);
    }
    if codegen.decl_cache_initialized != 0 {
        const h: i32 = (hash_string(struct_name) & C99_DECL_CACHE_MASK) as i32;
        const cached: &ASTNode = codegen.struct_decl_cache[h];
        if cached != null && cached.type == ASTNodeType.AST_STRUCT_DECL &&
            cached.struct_decl_name != null &&
            strcmp(cached.struct_decl_name as *byte, struct_name as *byte) == 0 {
            return cached;
        }
    }
    
    const decl_count: i32 = codegen.program_node.program_decl_count;
    
    var i: i32 = 0;
    while i < decl_count {
        const decl: &ASTNode = codegen.program_node.program_decls[i];
        if decl != null && decl.type == ASTNodeType.AST_STRUCT_DECL {
            const decl_name: &byte = decl.struct_decl_name;
            if decl_name != null && strcmp(decl_name as *byte, struct_name as *byte) == 0 {
                return decl;
            }
        }
        i = i + 1;
    }

    // 泛型结构体单态名（如 Task_err_i32）回查到其模板声明。
    i = 0;
    while i < decl_count {
        const decl: &ASTNode = codegen.program_node.program_decls[i];
        if decl != null && decl.type == ASTNodeType.AST_STRUCT_DECL &&
            decl.struct_decl_name != null && is_generic_struct_c99(decl) != 0 {
            var mi: i32 = 0;
            while mi < codegen.mono_instance_count {
                if codegen.mono_instances[mi].generic_name != null &&
                    strcmp(codegen.mono_instances[mi].generic_name as *byte, decl.struct_decl_name as *byte) == 0 &&
                    codegen.mono_instances[mi].is_function == 0 {
                    const mono_name: &byte = get_mono_struct_name(codegen, decl.struct_decl_name,
                        codegen.mono_instances[mi].type_args, codegen.mono_instances[mi].type_arg_count);
                    if mono_name != null && strcmp(mono_name as *byte, struct_name as *byte) == 0 {
                        return decl;
                    }
                }
                mi = mi + 1;
            }
        }
        i = i + 1;
    }
    
    return null;
}

// 查找联合体声明
fn find_union_decl_c99(codegen: &C99CodeGenerator, union_name: &byte) &ASTNode {
    if codegen == null || union_name == null || codegen.program_node == null {
        return null;
    }
    if codegen.decl_cache_initialized == 0 {
        build_decl_caches(codegen);
    }
    if codegen.decl_cache_initialized != 0 {
        const h: i32 = (hash_string(union_name) & C99_DECL_CACHE_MASK) as i32;
        const cached: &ASTNode = codegen.union_decl_cache[h];
        if cached != null && cached.type == ASTNodeType.AST_UNION_DECL &&
            cached.union_decl_name != null &&
            strcmp(cached.union_decl_name as *byte, union_name as *byte) == 0 {
            return cached;
        }
    }
    const decl_count: i32 = codegen.program_node.program_decl_count;
    var i: i32 = 0;
    while i < decl_count {
        const decl: &ASTNode = codegen.program_node.program_decls[i];
        if decl != null && decl.type == ASTNodeType.AST_UNION_DECL {
            const decl_name: &byte = decl.union_decl_name;
            if decl_name != null && strcmp(decl_name as *byte, union_name as *byte) == 0 {
                return decl;
            }
        }
        i = i + 1;
    }
    i = 0;
    while i < decl_count {
        const decl: &ASTNode = codegen.program_node.program_decls[i];
        if decl != null && decl.type == ASTNodeType.AST_UNION_DECL &&
            decl.union_decl_name != null && is_generic_union_c99(decl) != 0 {
            var mi: i32 = 0;
            while mi < codegen.mono_instance_count {
                if codegen.mono_instances[mi].generic_name != null &&
                    strcmp(codegen.mono_instances[mi].generic_name as *byte, decl.union_decl_name as *byte) == 0 &&
                    codegen.mono_instances[mi].is_function == 0 {
                    const mono_name: &byte = get_mono_union_name(codegen, decl.union_decl_name,
                        codegen.mono_instances[mi].type_args, codegen.mono_instances[mi].type_arg_count);
                    if mono_name != null && strcmp(mono_name as *byte, union_name as *byte) == 0 {
                        return decl;
                    }
                }
                mi = mi + 1;
            }
        }
        i = i + 1;
    }
    return null;
}

// 查找联合体对应的方法块
fn find_method_block_for_union_c99(codegen: &C99CodeGenerator, union_name: &byte) &ASTNode {
    if codegen == null || union_name == null || codegen.program_node == null {
        return null;
    }
    const decl_count: i32 = codegen.program_node.program_decl_count;
    var i: i32 = 0;
    while i < decl_count {
        const decl: &ASTNode = codegen.program_node.program_decls[i];
        if decl != null && decl.type == ASTNodeType.AST_METHOD_BLOCK {
            if decl.method_block_union_name != null &&
                strcmp(decl.method_block_union_name as *byte, union_name as *byte) == 0 {
                return decl;
            }
        }
        i = i + 1;
    }
    return null;
}

// 查找联合体方法（同时检查外部方法块和内部定义的方法）
fn find_method_in_union_c99(codegen: &C99CodeGenerator, union_name: &byte, method_name: &byte) &ASTNode {
    if codegen == null || union_name == null || method_name == null {
        return null;
    }
    const method_block: &ASTNode = find_method_block_for_union_c99(codegen, union_name);
    if method_block != null {
        const m: &ASTNode = find_method_in_block(method_block, method_name);
        if m != null {
            return m;
        }
    }
    const union_decl: &ASTNode = find_union_decl_c99(codegen, union_name);
    if union_decl != null && union_decl.union_decl_methods != null {
        var i: i32 = 0;
        while i < union_decl.union_decl_method_count {
            const m: &ASTNode = union_decl.union_decl_methods[i];
            if m != null && m.type == ASTNodeType.AST_FN_DECL && m.fn_decl_name != null &&
                strcmp(m.fn_decl_name as *byte, method_name as *byte) == 0 {
                return m;
            }
            i = i + 1;
        }
    }
    return null;
}

fn find_instance_method_in_union_c99(codegen: &C99CodeGenerator, union_name: &byte, method_name: &byte) &ASTNode {
    if codegen == null || union_name == null || method_name == null {
        return null;
    }
    const method_block: &ASTNode = find_method_block_for_union_c99(codegen, union_name);
    if method_block != null {
        const m: &ASTNode = c99_find_method_in_block_with_receiver_kind(method_block, union_name, method_name, 1);
        if m != null {
            return m;
        }
    }
    const union_decl: &ASTNode = find_union_decl_c99(codegen, union_name);
    if union_decl != null && union_decl.union_decl_methods != null {
        var i: i32 = 0;
        while i < union_decl.union_decl_method_count {
            const m: &ASTNode = union_decl.union_decl_methods[i];
            if m != null && m.type == ASTNodeType.AST_FN_DECL && m.fn_decl_name != null &&
                strcmp(m.fn_decl_name as *byte, method_name as *byte) == 0 &&
                c99_fn_decl_has_receiver_for_owner(m, union_name) != 0 {
                return m;
            }
            i = i + 1;
        }
    }
    return null;
}

fn find_static_method_in_union_c99(codegen: &C99CodeGenerator, union_name: &byte, method_name: &byte) &ASTNode {
    if codegen == null || union_name == null || method_name == null {
        return null;
    }
    const method_block: &ASTNode = find_method_block_for_union_c99(codegen, union_name);
    if method_block != null {
        const m: &ASTNode = c99_find_method_in_block_with_receiver_kind(method_block, union_name, method_name, 0);
        if m != null {
            return m;
        }
    }
    const union_decl: &ASTNode = find_union_decl_c99(codegen, union_name);
    if union_decl != null && union_decl.union_decl_methods != null {
        var i: i32 = 0;
        while i < union_decl.union_decl_method_count {
            const m: &ASTNode = union_decl.union_decl_methods[i];
            if m != null && m.type == ASTNodeType.AST_FN_DECL && m.fn_decl_name != null &&
                strcmp(m.fn_decl_name as *byte, method_name as *byte) == 0 &&
                c99_fn_decl_has_receiver_for_owner(m, union_name) == 0 {
                return m;
            }
            i = i + 1;
        }
    }
    return null;
}

// 根据 C 类型后缀（如 "uya_tagged_IntOrFloat" 或 "uya_tagged_Foo_i32"）查找联合体声明
fn find_union_decl_by_tagged_c99(codegen: &C99CodeGenerator, tagged_suffix: &byte) &ASTNode {
    if codegen == null || codegen.program_node == null || tagged_suffix == null {
        return null;
    }
    if strncmp(tagged_suffix as *byte, "uya_tagged_" as *byte, 11) != 0 {
        return null;
    }
    const suffix: *byte = tagged_suffix as *byte + 11;
    const decl_count: i32 = codegen.program_node.program_decl_count;
    var i: i32 = 0;
    while i < decl_count {
        const decl: &ASTNode = codegen.program_node.program_decls[i];
        if decl != null && decl.type == ASTNodeType.AST_UNION_DECL && decl.union_decl_name != null {
            const safe: &byte = get_safe_c_identifier(codegen, decl.union_decl_name);
            if safe != null && strcmp(safe as *byte, suffix) == 0 {
                return decl;
            }
        }
        i = i + 1;
    }
    i = 0;
    while i < decl_count {
        const decl: &ASTNode = codegen.program_node.program_decls[i];
        if decl != null && decl.type == ASTNodeType.AST_UNION_DECL && is_generic_union_c99(decl) != 0 {
            var j: i32 = 0;
            while j < codegen.mono_instance_count {
                if codegen.mono_instances[j].generic_name != null &&
                    strcmp(codegen.mono_instances[j].generic_name as *byte, decl.union_decl_name as *byte) == 0 &&
                    codegen.mono_instances[j].is_function == 0 {
                    const mono_name: &byte = get_mono_union_name(codegen, decl.union_decl_name,
                        codegen.mono_instances[j].type_args,
                        codegen.mono_instances[j].type_arg_count);
                    if mono_name != null && strcmp(mono_name as *byte, suffix) == 0 {
                        return decl;
                    }
                }
                j = j + 1;
            }
        }
        i = i + 1;
    }
    return null;
}

// 根据变体名查找包含该变体的联合体声明（用于 match 代码生成）
fn find_union_decl_by_variant_c99(codegen: &C99CodeGenerator, variant_name: &byte) &ASTNode {
    if codegen == null || codegen.program_node == null || variant_name == null {
        return null;
    }
    const decl_count: i32 = codegen.program_node.program_decl_count;
    var i: i32 = 0;
    while i < decl_count {
        const decl: &ASTNode = codegen.program_node.program_decls[i];
        if decl != null && decl.type == ASTNodeType.AST_UNION_DECL {
            if find_union_variant_index(decl, variant_name) >= 0 {
                return decl;
            }
        }
        i = i + 1;
    }
    return null;
}

// 根据 C 类型字符串（如 "struct uya_tagged_Foo_i32"）设置联合体单态上下文，用于 match 内变体类型的解析
// 返回 1 表示已设置，0 表示未设置（非泛型或未找到）
fn set_union_mono_context_from_tagged_type(codegen: &C99CodeGenerator, union_decl: &ASTNode, tagged_type_c: &byte) i32 {
    if codegen == null || union_decl == null || tagged_type_c == null || is_generic_union_c99(union_decl) == 0 {
        return 0;
    }
    const p: *byte = strstr(tagged_type_c as *byte, "uya_tagged_" as *byte);
    if p == null {
        return 0;
    }
    const suffix: &byte = &p[11] as &byte;
    var j: i32 = 0;
    while j < codegen.mono_instance_count {
        if codegen.mono_instances[j].generic_name != null &&
            strcmp(codegen.mono_instances[j].generic_name as *byte, union_decl.union_decl_name as *byte) == 0 &&
            codegen.mono_instances[j].is_function == 0 {
            const mono_name: &byte = get_mono_union_name(codegen, union_decl.union_decl_name,
                codegen.mono_instances[j].type_args,
                codegen.mono_instances[j].type_arg_count);
            if mono_name != null && strcmp(mono_name as *byte, suffix) == 0 {
                codegen.struct_type_params = union_decl.union_decl_type_params;
                codegen.struct_type_args = codegen.mono_instances[j].type_args;
                codegen.struct_type_param_count = union_decl.union_decl_type_param_count;
                codegen.struct_type_arg_count = codegen.mono_instances[j].type_arg_count;
                return 1;
            }
        }
        j = j + 1;
    }
    return 0;
}

// 从 C 类型字符串（如 "struct Future_err_i32"）设置结构体单态上下文，用于方法返回类型中的类型参数解析
// 返回 1 表示已设置，0 表示未设置（非泛型或未找到）
fn set_struct_mono_context_from_type_c(codegen: &C99CodeGenerator, type_c: &byte) i32 {
    if codegen == null || type_c == null {
        return 0;
    }
    const struct_pos: *byte = strstr(type_c as *byte, "struct " as *byte);
    if struct_pos == null {
        return 0;
    }
    const p: &byte = &struct_pos[7] as &byte;
    var name_len: i32 = 0;
    while p[name_len] != 0 && p[name_len] != 32 && p[name_len] != 42 {
        name_len = name_len + 1;
    }
    if name_len <= 0 {
        return 0;
    }
    if name_len >= C99_GENERIC_NAME_BUF_SIZE {
        return 0;
    }
    var mono_buf: [byte: C99_GENERIC_NAME_BUF_SIZE] = [];
    var i: i32 = 0;
    while i < name_len && i < C99_GENERIC_NAME_BUF_SIZE - 1 {
        mono_buf[i] = p[i];
        i = i + 1;
    }
    mono_buf[name_len] = 0 as byte;
    if extract_generic_name_inline(&mono_buf[0]) == 0 {
        return 0;
    }
    const struct_decl: &ASTNode = find_struct_decl_c99(codegen, &g_generic_name_buf[0]);
    if struct_decl == null || struct_decl.struct_decl_type_params == null || struct_decl.struct_decl_type_param_count <= 0 {
        return 0;
    }
    var j: i32 = 0;
    while j < codegen.mono_instance_count {
        if codegen.mono_instances[j].generic_name != null &&
            strcmp(codegen.mono_instances[j].generic_name as *byte, &g_generic_name_buf[0]) == 0 &&
            codegen.mono_instances[j].is_function == 0 {
            const mono_name: &byte = get_mono_struct_name(codegen, &g_generic_name_buf[0],
                codegen.mono_instances[j].type_args,
                codegen.mono_instances[j].type_arg_count);
            if mono_name != null && strcmp(mono_name as *byte, &mono_buf[0]) == 0 {
                codegen.struct_type_params = struct_decl.struct_decl_type_params;
                codegen.struct_type_args = codegen.mono_instances[j].type_args;
                codegen.struct_type_param_count = struct_decl.struct_decl_type_param_count;
                codegen.struct_type_arg_count = codegen.mono_instances[j].type_arg_count;
                return 1;
            }
        }
        j = j + 1;
    }
    return 0;
}

// 从 tagged 类型后缀（如 "Poll_err_i32"）提取单参数联合体的类型实参 C 类型
// 用于 match 中 set_union_mono_context 失败时的后备：variant 类型为 T 时，从后缀解析 !i32 -> struct err_union_int32_t
// 返回 null 表示无法解析
fn variant_c_type_from_tagged_suffix(codegen: &C99CodeGenerator, union_decl: &ASTNode, suffix: &byte) &byte {
    if codegen == null || union_decl == null || suffix == null ||
       union_decl.union_decl_name == null || union_decl.union_decl_type_param_count != 1 {
        return null;
    }
    const prefix: &byte = get_safe_c_identifier(codegen, union_decl.union_decl_name);
    if prefix == null {
        return null;
    }
    const pre_len: i32 = strlen(prefix as *byte);
    if pre_len <= 0 || suffix[pre_len] != 95 {
        return null;
    }
    if strncmp(suffix as *byte, prefix as *byte, pre_len) != 0 {
        return null;
    }
    const type_suffix: &byte = &suffix[pre_len + 1] as &byte;
    if strncmp(type_suffix as *byte, "err_" as *byte, 4) == 0 {
        const inner: &byte = &type_suffix[4] as &byte;
        if strcmp(inner as *byte, "i32" as *byte) == 0 {
            return ("struct err_union_int32_t" as *byte) as &byte;
        }
        if strcmp(inner as *byte, "u32" as *byte) == 0 {
            return ("struct err_union_uint32_t" as *byte) as &byte;
        }
        if strcmp(inner as *byte, "i64" as *byte) == 0 {
            return ("struct err_union_int64_t" as *byte) as &byte;
        }
        if strcmp(inner as *byte, "u64" as *byte) == 0 {
            return ("struct err_union_uint64_t" as *byte) as &byte;
        }
        if strcmp(inner as *byte, "i16" as *byte) == 0 {
            return ("struct err_union_int16_t" as *byte) as &byte;
        }
        if strcmp(inner as *byte, "u16" as *byte) == 0 {
            return ("struct err_union_uint16_t" as *byte) as &byte;
        }
        if strcmp(inner as *byte, "i8" as *byte) == 0 {
            return ("struct err_union_int8_t" as *byte) as &byte;
        }
        if strcmp(inner as *byte, "u8" as *byte) == 0 {
            return ("struct err_union_uint8_t" as *byte) as &byte;
        }
        if strcmp(inner as *byte, "bool" as *byte) == 0 {
            return ("struct err_union_bool" as *byte) as &byte;
        }
        if strcmp(inner as *byte, "f32" as *byte) == 0 {
            return ("struct err_union_float" as *byte) as &byte;
        }
        if strcmp(inner as *byte, "f64" as *byte) == 0 {
            return ("struct err_union_double" as *byte) as &byte;
        }
        if strcmp(inner as *byte, "usize" as *byte) == 0 || strcmp(inner as *byte, "size_t" as *byte) == 0 {
            return ("struct err_union_size_t" as *byte) as &byte;
        }
        if strcmp(inner as *byte, "void" as *byte) == 0 {
            return ("struct err_union_void" as *byte) as &byte;
        }
        // err_MyStruct：具名载荷 !MyStruct -> struct err_union_MyStruct（与 c99_type_to_c 命名一致）
        if inner[0] != 0 {
            const safe_in: &byte = get_safe_c_identifier(codegen, inner);
            if safe_in != null {
                var ebuf: [byte: 192] = [];
                snprintf(&ebuf[0] as *byte, 192, "struct err_union_%s" as *byte, safe_in as *byte);
                const dup_nm: &byte = c99_arena_strdup(codegen.arena, &ebuf[0] as &byte);
                if dup_nm != null {
                    return dup_nm;
                }
            }
        }
    }
    return null;
}

// Poll<T> 单态名 Poll_i32 等（无 err_）：Ready 载荷为 T 本身，与 Poll<!T> 的 err_union_* 不同。
fn poll_ready_plain_c_from_poll_mono_union_name(union_name: &byte) &byte {
    if union_name == null || strncmp(union_name as *byte, "Poll_" as *byte, 5) != 0 {
        return null;
    }
    const suf: &byte = &union_name[5] as &byte;
    if strncmp(suf as *byte, "err_" as *byte, 4) == 0 {
        return null;
    }
    if strcmp(suf as *byte, "i8" as *byte) == 0 {
        return ("int8_t" as *byte) as &byte;
    }
    if strcmp(suf as *byte, "i16" as *byte) == 0 {
        return ("int16_t" as *byte) as &byte;
    }
    if strcmp(suf as *byte, "i32" as *byte) == 0 {
        return ("int32_t" as *byte) as &byte;
    }
    if strcmp(suf as *byte, "i64" as *byte) == 0 {
        return ("int64_t" as *byte) as &byte;
    }
    if strcmp(suf as *byte, "u8" as *byte) == 0 {
        return ("uint8_t" as *byte) as &byte;
    }
    if strcmp(suf as *byte, "u16" as *byte) == 0 {
        return ("uint16_t" as *byte) as &byte;
    }
    if strcmp(suf as *byte, "u32" as *byte) == 0 {
        return ("uint32_t" as *byte) as &byte;
    }
    if strcmp(suf as *byte, "u64" as *byte) == 0 {
        return ("uint64_t" as *byte) as &byte;
    }
    if strcmp(suf as *byte, "usize" as *byte) == 0 || strcmp(suf as *byte, "size_t" as *byte) == 0 {
        return ("size_t" as *byte) as &byte;
    }
    if strcmp(suf as *byte, "isize" as *byte) == 0 {
        return ("intptr_t" as *byte) as &byte;
    }
    if strcmp(suf as *byte, "bool" as *byte) == 0 {
        return ("bool" as *byte) as &byte;
    }
    if strcmp(suf as *byte, "f32" as *byte) == 0 {
        return ("float" as *byte) as &byte;
    }
    if strcmp(suf as *byte, "f64" as *byte) == 0 {
        return ("double" as *byte) as &byte;
    }
    if strcmp(suf as *byte, "void" as *byte) == 0 {
        return ("char" as *byte) as &byte;
    }
    return null;
}

// 返回联合体变体索引（0-based），不存在返回 -1
fn find_union_variant_index(union_decl: &ASTNode, variant_name: &byte) i32 {
    if union_decl == null || union_decl.type != ASTNodeType.AST_UNION_DECL || variant_name == null {
        return -1;
    }
    var i: i32 = 0;
    while i < union_decl.union_decl_variant_count {
        const v: &ASTNode = union_decl.union_decl_variants[i];
        if v != null && v.type == ASTNodeType.AST_VAR_DECL && v.var_decl_name != null &&
            strcmp(v.var_decl_name as *byte, variant_name as *byte) == 0 {
            return i;
        }
        i = i + 1;
    }
    return -1;
}

// 生成联合体定义：union U { ... }; struct uya_tagged_U { int _tag; union U u; };
// 若已通过 ensure_union_emitted_for_type_node 提前发射（如 err_union 的 payload），则跳过避免重复
fn gen_union_definition(codegen: &C99CodeGenerator, union_decl: &ASTNode) i32 {
    if codegen == null || union_decl == null || union_decl.type != ASTNodeType.AST_UNION_DECL {
        return -1;
    }
    const union_name: &byte = get_safe_c_identifier(codegen, union_decl.union_decl_name);
    if union_name == null {
        return -1;
    }
    var key_buf: [byte: 144] = [];
    snprintf(&key_buf[0] as *byte, 144, "uya_union_%s" as *byte, union_name as *byte);
    const key: &byte = c99_arena_strdup(codegen.arena, &key_buf[0] as &byte);
    if key != null && is_struct_defined(codegen, key) != 0 {
        return 0;
    }
    const n: i32 = union_decl.union_decl_variant_count;
    const variants: & & ASTNode = union_decl.union_decl_variants;
    if n <= 0 || variants == null {
        return -1;
    }
    var di: i32 = 0;
    while di < n {
        const dv: &ASTNode = variants[di];
        if dv != null && dv.type == ASTNodeType.AST_VAR_DECL && dv.var_decl_type != null {
            ensure_value_type_deps_emitted(codegen, dv.var_decl_type);
            c99_emit_async_frame_forward_for_type(codegen, dv.var_decl_type);
            if dv.var_decl_type.type == ASTNodeType.AST_TYPE_ERROR_UNION {
                emit_err_union_struct_for_type_node(codegen, dv.var_decl_type);
            }
        }
        di = di + 1;
    }
    c99_emit_indent(codegen);
    fprintf(codegen.emit_stream as *void, "union %s {\n" as *byte, union_name as *byte);
    codegen.indent_level = codegen.indent_level + 1;
    var i: i32 = 0;
    while i < n {
        const v: &ASTNode = variants[i];
        if v != null && v.type == ASTNodeType.AST_VAR_DECL && v.var_decl_name != null && v.var_decl_type != null {
            const vname: &byte = get_safe_c_identifier(codegen, v.var_decl_name);
            var vtype: &byte = c99_type_to_c(codegen, v.var_decl_type);
            if vtype != null && v.var_decl_type.type == ASTNodeType.AST_TYPE_NAMED && v.var_decl_type.type_named_name != null &&
                strcmp(v.var_decl_type.type_named_name as *byte, "void" as *byte) == 0 {
                vtype = "char" as &byte;
            }
            if vname != null && vtype != null {
                c99_emit_indent(codegen);
                fprintf(codegen.emit_stream as *void, "%s %s;\n" as *byte, vtype as *byte, vname as *byte);
            }
        }
        i = i + 1;
    }
    codegen.indent_level = codegen.indent_level - 1;
    c99_emit(codegen, "};\n" as *byte);
    if union_decl.union_decl_is_extern == 0 {
        c99_emit_indent(codegen);
        fprintf(codegen.emit_stream as *void, "struct uya_tagged_%s { int _tag; union %s u; };\n" as *byte, union_name as *byte, union_name as *byte);
    }
    if key != null {
        mark_struct_defined(codegen, key);
    }
    return 0;
}

// 生成单态化联合体定义（泛型 union Foo<T> 的 Foo_i32 等）
fn gen_mono_union_definition(codegen: &C99CodeGenerator, union_decl: &ASTNode, type_args: & &ASTNode, type_arg_count: i32) i32 {
    if codegen == null || union_decl == null || union_decl.type != ASTNodeType.AST_UNION_DECL {
        return -1;
    }
    const orig_name: &byte = union_decl.union_decl_name;
    if orig_name == null || type_args == null || type_arg_count <= 0 {
        return -1;
    }
    // 在清空外层 current_type_* 之前，将实参中的形参（如泛型 @async_fn 内 Poll 的 T）替换为具体类型，
    // 否则 get_mono_union_name 得到 Poll_T，且变体 Ready 字段会被写成 C 非法的 `T Ready`（宿主 cc 报 unknown type name 'T'）。
    const subst_buf: & & ASTNode = compiler_arena_alloc(codegen.arena, (@size_of(&ASTNode) * type_arg_count) as usize) as & & ASTNode;
    if subst_buf == null {
        return -1;
    }
    var si_sub: i32 = 0;
    while si_sub < type_arg_count {
        if type_args[si_sub] != null {
            subst_buf[si_sub] = substitute_type_arg(codegen, type_args[si_sub]);
        } else {
            subst_buf[si_sub] = null;
        }
        si_sub = si_sub + 1;
    }
    if has_unresolved_mono_type_args(union_decl, subst_buf, type_arg_count) != 0 {
        return 0;
    }
    const mono_name: &byte = get_mono_union_name(codegen, orig_name, subst_buf, type_arg_count);
    const union_name: &byte = get_safe_c_identifier(codegen, mono_name);
    if union_name == null {
        return -1;
    }
    if union_decl.union_decl_is_extern == 0 {
        var tagged_buf: [byte: 128] = [0: 128];
        var blen: i32 = snprintf(&tagged_buf[0] as *byte, 128, "uya_tagged_%s" as *byte, union_name as *byte);
        if blen > 0 && blen < 128 && is_struct_defined(codegen, &tagged_buf[0] as &byte) != 0 {
            return 0;
        }
    }
    const n: i32 = union_decl.union_decl_variant_count;
    const variants: & & ASTNode = union_decl.union_decl_variants;
    if n <= 0 || variants == null {
        return -1;
    }
    // 整段屏蔽外层泛型函数的 current_type_*（见下 append_type_arg_suffix 与 c99_type_to_c 均先 struct 再 current）。
    const saved_outer_ctp: &TypeParam = codegen.current_type_params;
    const saved_outer_ctpc: i32 = codegen.current_type_param_count;
    const saved_outer_cta: & & ASTNode = codegen.current_type_args;
    const saved_outer_ctac: i32 = codegen.current_type_arg_count;
    codegen.current_type_params = null;
    codegen.current_type_param_count = 0;
    codegen.current_type_args = null;
    codegen.current_type_arg_count = 0;
    var saved_struct_type_params: &TypeParam = codegen.struct_type_params;
    var saved_struct_type_args: & & ASTNode = codegen.struct_type_args;
    var saved_struct_type_param_count: i32 = codegen.struct_type_param_count;
    var saved_struct_type_arg_count: i32 = codegen.struct_type_arg_count;
    codegen.struct_type_params = union_decl.union_decl_type_params;
    codegen.struct_type_args = subst_buf;
    codegen.struct_type_param_count = union_decl.union_decl_type_param_count;
    codegen.struct_type_arg_count = type_arg_count;
    c99_type_to_c_reset_cache();

    // 单态化后的变体字段可能依赖值类型结构体/联合体（如 Option<Event>.Some）。
    // 这里必须在发出 union 体之前先把依赖类型补齐，否则宿主 C 会把字段视为不完整类型。
    var di: i32 = 0;
    while di < n {
        const dv: &ASTNode = variants[di];
        if dv != null && dv.type == ASTNodeType.AST_VAR_DECL && dv.var_decl_type != null {
            var dep_type: &ASTNode = substitute_type_arg_explicit(codegen, dv.var_decl_type,
                union_decl.union_decl_type_params, subst_buf, type_arg_count);
            if dep_type == null {
                dep_type = dv.var_decl_type;
            }
            ensure_value_type_deps_emitted(codegen, dep_type);
            c99_emit_async_frame_forward_for_type(codegen, dep_type);
            if dep_type.type == ASTNodeType.AST_TYPE_ERROR_UNION {
                emit_err_union_struct_for_type_node(codegen, dep_type);
            }
        }
        di = di + 1;
    }

    c99_emit_indent(codegen);
    fprintf(codegen.emit_stream as *void, "union %s {\n" as *byte, union_name as *byte);
    codegen.indent_level = codegen.indent_level + 1;
    var i: i32 = 0;
    while i < n {
        const v: &ASTNode = variants[i];
        if v != null && v.type == ASTNodeType.AST_VAR_DECL && v.var_decl_name != null && v.var_decl_type != null {
            const vname: &byte = get_safe_c_identifier(codegen, v.var_decl_name);
            // 每个变体求值前再清空：上一变体（如 Pending）的 c99_type_to_c 递归可能临时恢复外层函数形参。
            codegen.current_type_params = null;
            codegen.current_type_param_count = 0;
            codegen.current_type_args = null;
            codegen.current_type_arg_count = 0;
            var vtype: &byte = null;
            // Poll<!T>.Ready：C 名单态后缀（union_name）与 c99_type_to_c(T) 在部分调用上下文中会不一致，按后缀解析 err_union_* 与 finish 侧一致。
            if orig_name != null && strcmp(orig_name as *byte, "Poll" as *byte) == 0 &&
                vname != null && strcmp(vname as *byte, "Ready" as *byte) == 0 && union_name != null {
                vtype = variant_c_type_from_tagged_suffix(codegen, union_decl, union_name);
                if vtype == null {
                    vtype = poll_ready_plain_c_from_poll_mono_union_name(union_name);
                }
            }
            if vtype == null {
                vtype = c99_type_to_c(codegen, v.var_decl_type);
            }
            if vtype != null && v.var_decl_type.type == ASTNodeType.AST_TYPE_NAMED && v.var_decl_type.type_named_name != null &&
                strcmp(v.var_decl_type.type_named_name as *byte, "void" as *byte) == 0 {
                vtype = "char" as &byte;
            }
            if vname != null && vtype != null {
                c99_emit_indent(codegen);
                fprintf(codegen.emit_stream as *void, "%s %s;\n" as *byte, vtype as *byte, vname as *byte);
            }
        }
        i = i + 1;
    }
    codegen.indent_level = codegen.indent_level - 1;
    c99_emit(codegen, "};\n" as *byte);
    if union_decl.union_decl_is_extern == 0 {
        c99_emit_indent(codegen);
        fprintf(codegen.emit_stream as *void, "struct uya_tagged_%s { int _tag; union %s u; };\n" as *byte, union_name as *byte, union_name as *byte);
        var tagged_buf2: [byte: 128] = [0: 128];
        var blen2: i32 = snprintf(&tagged_buf2[0] as *byte, 128, "uya_tagged_%s" as *byte, union_name as *byte);
        if blen2 > 0 && blen2 < 128 {
            const tag_copy: &byte = c99_arena_strdup(codegen.arena, &tagged_buf2[0] as &byte);
            if tag_copy != null {
                add_struct_definition(codegen, tag_copy);
                mark_struct_defined(codegen, tag_copy);
            }
        }
    }
    codegen.struct_type_params = saved_struct_type_params;
    codegen.struct_type_args = saved_struct_type_args;
    codegen.struct_type_param_count = saved_struct_type_param_count;
    codegen.struct_type_arg_count = saved_struct_type_arg_count;
    codegen.current_type_params = saved_outer_ctp;
    codegen.current_type_param_count = saved_outer_ctpc;
    codegen.current_type_args = saved_outer_cta;
    codegen.current_type_arg_count = saved_outer_ctac;
    return 0;
}

// 检查类型名是否是基本类型
fn is_primitive_type_name(type_name: &byte) i32 {
    if type_name == null {
        return 0;
    }
    if strcmp(type_name as *byte, "i8" as *byte) == 0 ||
       strcmp(type_name as *byte, "i16" as *byte) == 0 ||
       strcmp(type_name as *byte, "i32" as *byte) == 0 ||
       strcmp(type_name as *byte, "i64" as *byte) == 0 ||
       strcmp(type_name as *byte, "u8" as *byte) == 0 ||
       strcmp(type_name as *byte, "u16" as *byte) == 0 ||
       strcmp(type_name as *byte, "u32" as *byte) == 0 ||
       strcmp(type_name as *byte, "u64" as *byte) == 0 ||
       strcmp(type_name as *byte, "f32" as *byte) == 0 ||
       strcmp(type_name as *byte, "f64" as *byte) == 0 ||
       strcmp(type_name as *byte, "bool" as *byte) == 0 ||
       strcmp(type_name as *byte, "byte" as *byte) == 0 ||
       strcmp(type_name as *byte, "void" as *byte) == 0 ||
       strcmp(type_name as *byte, "usize" as *byte) == 0 {
        return 1;
    }
    return 0;
}

// 递归收集结构体的值类型字段依赖（用于确定定义顺序）
// 输出顺序：被依赖的结构体在前（拓扑排序）
// 参数：codegen, struct_decl - 结构体声明, out_names - 输出数组, max_count/out_count - 容量/计数
// 注意：只收集非指针的值类型结构体字段，指针类型可以使用前向声明
fn collect_struct_field_deps_recursive(codegen: &C99CodeGenerator, struct_decl: &ASTNode, out_names: & & byte, max_count: i32, out_count: &i32) void {
    if codegen == null || struct_decl == null || struct_decl.type != ASTNodeType.AST_STRUCT_DECL {
        return;
    }
    if out_count == null || out_names == null {
        return;
    }
    
    const field_count: i32 = struct_decl.struct_decl_field_count;
    if field_count <= 0 || struct_decl.struct_decl_fields == null {
        return;
    }
    
    var i: i32 = 0;
    while i < field_count {
        const field: &ASTNode = struct_decl.struct_decl_fields[i];
        if field != null && field.type == ASTNodeType.AST_VAR_DECL && field.var_decl_type != null {
            const field_type: &ASTNode = field.var_decl_type;
            
            // 递归处理类型，收集值类型结构体依赖
            collect_value_struct_deps_from_type(codegen, field_type, out_names, max_count, out_count);
        }
        i = i + 1;
    }
}

// 从类型节点收集值类型结构体依赖（递归处理指针、数组等包装类型）
fn collect_value_struct_deps_from_type(codegen: &C99CodeGenerator, type_node: &ASTNode, out_names: & & byte, max_count: i32, out_count: &i32) void {
    if codegen == null || type_node == null || out_count == null {
        return;
    }
    
    if type_node.type == ASTNodeType.AST_TYPE_POINTER {
        // 指针类型：不需要收集依赖，前向声明即可
        return;
    }
    
    if type_node.type == ASTNodeType.AST_TYPE_NAMED {
        const type_name: &byte = type_node.type_named_name;
        if type_name == null || is_primitive_type_name(type_name) != 0 {
            return;
        }

        // 接口值在 C 侧是 vtable + data 的胖指针，不需要当作值类型结构体依赖展开。
        // 这里必须优先按接口判定，否则像 Future<!i32> 这类“接口/结构体同名”场景
        // 会被误收集成结构体模板依赖，最终错误生成 struct Future { state: Poll<T> }。
        if find_interface_decl_c99(codegen, type_name) != null {
            return;
        }
        
        var dep_struct_name: &byte = type_name;
        const struct_decl: &ASTNode = find_struct_decl_c99(codegen, type_name);
        var is_generic_inst: i32 = 0;
        if struct_decl != null && is_generic_struct_c99(struct_decl) != 0 &&
            type_node.type_named_type_arg_count > 0 && type_node.type_named_type_args != null {
            dep_struct_name = get_mono_struct_name(codegen, type_name,
                type_node.type_named_type_args, type_node.type_named_type_arg_count);
            is_generic_inst = 1;
        }

        // 检查是否已添加
        var already_added: i32 = 0;
        var j: i32 = 0;
        while j < out_count[0] {
            if out_names[j] != null && strcmp(out_names[j] as *byte, dep_struct_name as *byte) == 0 {
                already_added = 1;
                break;
            }
            j = j + 1;
        }
        
        if already_added != 0 {
            return;
        }
        
        if struct_decl != null && is_generic_inst == 0 {
            // 先递归收集该结构体的字段依赖（拓扑排序：被依赖的在前）
            collect_struct_field_deps_recursive(codegen, struct_decl, out_names, max_count, out_count);
        }
        
        // 再添加该结构体本身（在依赖之后）
        if out_count[0] < max_count {
            out_names[out_count[0]] = dep_struct_name;
            out_count[0] = out_count[0] + 1;
        }
    } else if type_node.type == ASTNodeType.AST_TYPE_ARRAY {
        // 数组类型：递归处理元素类型
        if type_node.type_array_element_type != null {
            collect_value_struct_deps_from_type(codegen, type_node.type_array_element_type, out_names, max_count, out_count);
        }
    } else if type_node.type == ASTNodeType.AST_TYPE_SLICE {
        // 切片类型：不需要收集（切片是运行时结构）
        return;
    } else if type_node.type == ASTNodeType.AST_TYPE_TUPLE {
        // 元组类型：递归处理每个元素类型
        if type_node.type_tuple_element_types != null {
            var k: i32 = 0;
            while k < type_node.type_tuple_element_count {
                collect_value_struct_deps_from_type(codegen, type_node.type_tuple_element_types[k], out_names, max_count, out_count);
                k = k + 1;
            }
        }
    }
}

// 收集联合体变体中引用的结构体类型（用于确定定义顺序）
// 参数：codegen, union_decl - 联合体声明, out_names - 输出结构体名称数组, out_count - 输出计数
// 返回：收集到的结构体数量
// 注意：只收集非指针的结构体类型（指针类型可以使用前向声明），并递归处理嵌套依赖
fn collect_struct_types_in_union(codegen: &C99CodeGenerator, union_decl: &ASTNode, out_names: & & byte, max_count: i32, out_count: &i32) i32 {
    if codegen == null || union_decl == null || union_decl.type != ASTNodeType.AST_UNION_DECL {
        return 0;
    }
    if out_count == null {
        return 0;
    }
    out_count[0] = 0;
    
    const n: i32 = union_decl.union_decl_variant_count;
    const variants: & & ASTNode = union_decl.union_decl_variants;
    if n <= 0 || variants == null {
        return 0;
    }
    
    var i: i32 = 0;
    while i < n {
        const v: &ASTNode = variants[i];
        if v != null && v.type == ASTNodeType.AST_VAR_DECL && v.var_decl_type != null {
            const type_node: &ASTNode = v.var_decl_type;
            // 使用递归函数收集值类型结构体依赖（包括嵌套依赖）
            collect_value_struct_deps_from_type(codegen, type_node, out_names, max_count, out_count);
        }
        i = i + 1;
    }
    
    return out_count[0];
}

// 生成联合体所依赖的结构体定义
// 参数：codegen, union_decl - 联合体声明
// 返回：生成的结构体数量
fn emit_struct_deps_for_union(codegen: &C99CodeGenerator, union_decl: &ASTNode) i32 {
    if codegen == null || union_decl == null {
        return 0;
    }
    
    // 收集依赖的结构体名称
    // 注意：数组大小需要足够大以容纳所有变体（可能有 100+ 个）
    var struct_names: [&byte: 128] = [];
    var struct_count: i32 = 0;
    
    // struct_names 是 &byte 数组，直接传递数组首元素地址
    collect_struct_types_in_union(codegen, union_decl, &struct_names[0], 128, &struct_count);
    
    if struct_count <= 0 {
        return 0;
    }

    var generated: i32 = 0;
    var i: i32 = 0;
    // struct_names 数组大小为 128
    while i < @len(struct_names) {
        // 只有当 i < struct_count 时才处理
        if i < struct_count {
            const struct_name: &byte = struct_names[i];
            if struct_name != null {
                // 检查是否已定义
                if is_struct_defined(codegen, struct_name) == 0 {
                    const struct_decl: &ASTNode = find_struct_decl_c99(codegen, struct_name);
                    if struct_decl != null && struct_decl.type == ASTNodeType.AST_STRUCT_DECL {
                        if is_generic_struct_c99(struct_decl) != 0 {
                            var j: i32 = 0;
                            while j < codegen.mono_instance_count {
                                if codegen.mono_instances[j].generic_name != null &&
                                    strcmp(codegen.mono_instances[j].generic_name as *byte, struct_decl.struct_decl_name as *byte) == 0 &&
                                    codegen.mono_instances[j].is_function == 0 {
                                    const mono_name: &byte = get_mono_struct_name(codegen, struct_decl.struct_decl_name,
                                        codegen.mono_instances[j].type_args, codegen.mono_instances[j].type_arg_count);
                                    if mono_name != null &&
                                        strcmp(mono_name as *byte, struct_name as *byte) == 0 &&
                                        has_unresolved_mono_type_args(struct_decl,
                                            codegen.mono_instances[j].type_args,
                                            codegen.mono_instances[j].type_arg_count) == 0 {
                                        gen_mono_struct_definition(codegen, struct_decl,
                                            codegen.mono_instances[j].type_args,
                                            codegen.mono_instances[j].type_arg_count);
                                        c99_emit_newline(codegen);
                                        generated = generated + 1;
                                        break;
                                    }
                                }
                                j = j + 1;
                            }
                        } else {
                            gen_struct_definition(codegen, struct_decl);
                            c99_emit_newline(codegen);
                            generated = generated + 1;
                        }
                    }
                }
            }
        }
        i = i + 1;
    }
    
    return generated;
}

// 收集结构体字段中引用的值类型结构体（用于定义顺序：被依赖的在前）
fn collect_struct_types_in_struct(codegen: &C99CodeGenerator, struct_decl: &ASTNode, out_names: & & byte, max_count: i32, out_count: &i32) i32 {
    if codegen == null || struct_decl == null || struct_decl.type != ASTNodeType.AST_STRUCT_DECL {
        return 0;
    }
    if out_count == null {
        return 0;
    }
    out_count[0] = 0;
    const field_count: i32 = struct_decl.struct_decl_field_count;
    const fields: & & ASTNode = struct_decl.struct_decl_fields;
    if field_count <= 0 || fields == null {
        return 0;
    }
    var i: i32 = 0;
    while i < field_count {
        const field: &ASTNode = fields[i];
        if field != null && field.type == ASTNodeType.AST_VAR_DECL && field.var_decl_type != null {
            collect_value_struct_deps_from_type(codegen, field.var_decl_type, out_names, max_count, out_count);
        }
        i = i + 1;
    }
    return out_count[0];
}

// 生成结构体所依赖的值类型结构体定义（在生成当前结构体之前）
fn emit_struct_deps_for_struct(codegen: &C99CodeGenerator, struct_decl: &ASTNode) i32 {
    if codegen == null || struct_decl == null {
        return 0;
    }
    var struct_names: [&byte: 128] = [];
    var struct_count: i32 = 0;
    collect_struct_types_in_struct(codegen, struct_decl, &struct_names[0], 128, &struct_count);
    if struct_count <= 0 {
        return 0;
    }
    var generated: i32 = 0;
    var i: i32 = 0;
    while i < @len(struct_names) {
        if i < struct_count {
            const struct_name: &byte = struct_names[i];
            if struct_name != null && is_struct_defined(codegen, struct_name) == 0 {
                const dep_decl: &ASTNode = find_struct_decl_c99(codegen, struct_name);
                if dep_decl != null && dep_decl.type == ASTNodeType.AST_STRUCT_DECL {
                    if is_generic_struct_c99(dep_decl) != 0 {
                        var j: i32 = 0;
                        while j < codegen.mono_instance_count {
                            if codegen.mono_instances[j].generic_name != null &&
                                strcmp(codegen.mono_instances[j].generic_name as *byte, dep_decl.struct_decl_name as *byte) == 0 &&
                                codegen.mono_instances[j].is_function == 0 {
                                const mono_name: &byte = get_mono_struct_name(codegen, dep_decl.struct_decl_name,
                                    codegen.mono_instances[j].type_args, codegen.mono_instances[j].type_arg_count);
                                if mono_name != null &&
                                    strcmp(mono_name as *byte, struct_name as *byte) == 0 &&
                                    has_unresolved_mono_type_args(dep_decl,
                                        codegen.mono_instances[j].type_args,
                                        codegen.mono_instances[j].type_arg_count) == 0 {
                                    gen_mono_struct_definition(codegen, dep_decl,
                                        codegen.mono_instances[j].type_args,
                                        codegen.mono_instances[j].type_arg_count);
                                    c99_emit_newline(codegen);
                                    generated = generated + 1;
                                    break;
                                }
                            }
                            j = j + 1;
                        }
                    } else {
                        gen_struct_definition(codegen, dep_decl);
                        c99_emit_newline(codegen);
                        generated = generated + 1;
                    }
                }
            }
        }
        i = i + 1;
    }
    return generated;
}

// 为单态化结构体收集“替换类型参数后的”值类型结构体依赖。
fn emit_struct_deps_for_mono_struct(codegen: &C99CodeGenerator, struct_decl: &ASTNode,
    type_args: & &ASTNode, type_arg_count: i32) i32 {
    if codegen == null || struct_decl == null {
        return 0;
    }
    const field_count: i32 = struct_decl.struct_decl_field_count;
    if field_count <= 0 || struct_decl.struct_decl_fields == null {
        return 0;
    }

    var i: i32 = 0;
    while i < field_count {
        const field: &ASTNode = struct_decl.struct_decl_fields[i];
        if field != null && field.type == ASTNodeType.AST_VAR_DECL && field.var_decl_type != null {
            const resolved_field_type: &ASTNode = substitute_type_arg_explicit(codegen, field.var_decl_type,
                struct_decl.struct_decl_type_params, type_args, type_arg_count);
            ensure_value_type_deps_emitted(codegen, resolved_field_type);
        }
        i = i + 1;
    }
    return 0;
}

// 从 C 类型字符串（如 "struct Data"、"const struct Data *"、"struct Data *"）中提取结构体名并查找声明
fn find_struct_decl_from_type_c(codegen: &C99CodeGenerator, type_c: &byte) &ASTNode {
    if codegen == null || type_c == null || codegen.program_node == null {
        return null;
    }
    // 查找 "struct " 子串
    const struct_pos: *byte = strstr(type_c as *byte, "struct " as *byte);
    if struct_pos == null {
        return null;
    }
    // 跳过 "struct " 前缀
    const p: &byte = &struct_pos[7] as &byte;
    var name_len: i32 = 0;
    while p[name_len] != 0 && p[name_len] != 32 && p[name_len] != 42 {
        name_len = name_len + 1;
    }
    if name_len <= 0 {
        return null;
    }
    if name_len >= C99_GENERIC_NAME_BUF_SIZE {
        name_len = C99_GENERIC_NAME_BUF_SIZE - 1;
    }
    var name_buf: [byte: C99_GENERIC_NAME_BUF_SIZE] = [];
    memcpy(&name_buf[0] as *void, p as *void, name_len as usize);
    if name_len >= 0 && name_len < C99_GENERIC_NAME_BUF_SIZE {
        name_buf[name_len] = 0;
    }
    return find_struct_decl_c99(codegen, &name_buf[0] as &byte);
}

// 检查结构体是否实现某接口
fn struct_implements_interface_c99(codegen: &C99CodeGenerator, struct_name: &byte, interface_name: &byte) i32 {
    const s: &ASTNode = find_struct_decl_c99(codegen, struct_name);
    if s == null || s.type != ASTNodeType.AST_STRUCT_DECL || s.struct_decl_interface_names == null {
        return 0;
    }
    var i: i32 = 0;
    while i < s.struct_decl_interface_count {
        if s.struct_decl_interface_names[i] != null {
            const iname: &byte = s.struct_decl_interface_names[i];
            if strcmp(iname as *byte, interface_name as *byte) == 0 {
                return 1;
            }
            // 兼容：接口名可能带类型参数文本（如 "Future<T>"），这里按前缀匹配
            const nlen: i32 = strlen(interface_name as *byte);
            if nlen > 0 && strncmp(iname as *byte, interface_name as *byte, nlen) == 0 && iname[nlen] == 60 {  // '<'
                return 1;
            }
        }
        i = i + 1;
    }
    return 0;
}

// 查找接口声明（带缓存优化）
fn find_interface_decl_c99(codegen: &C99CodeGenerator, interface_name: &byte) &ASTNode {
    if codegen == null || interface_name == null || codegen.program_node == null {
        return null;
    }
    // 使用缓存（O(1) 查找）
    if codegen.decl_cache_initialized == 0 {
        build_decl_caches(codegen);
    }
    if codegen.decl_cache_initialized != 0 {
        const h: i32 = (hash_string(interface_name) & C99_DECL_CACHE_MASK) as i32;
        const cached: &ASTNode = codegen.interface_decl_cache[h];
        if cached != null && cached.type == ASTNodeType.AST_INTERFACE_DECL &&
            cached.interface_decl_name != null &&
            strcmp(cached.interface_decl_name as *byte, interface_name as *byte) == 0 {
            return cached;
        }
    }
    // 缓存未命中，线性查找
    const decl_count: i32 = codegen.program_node.program_decl_count;
    var i: i32 = 0;
    while i < decl_count {
        const decl: &ASTNode = codegen.program_node.program_decls[i];
        if decl != null && decl.type == ASTNodeType.AST_INTERFACE_DECL {
            const decl_name: &byte = decl.interface_decl_name;
            if decl_name != null && strcmp(decl_name as *byte, interface_name as *byte) == 0 {
                return decl;
            }
        }
        i = i + 1;
    }
    return null;
}

/// 在接口及组合接口中查找方法签名（与 checker lookup 语义一致，供 codegen 解析 Future 操作数 C 类型）
fn c99_find_interface_method_sig(codegen: &C99CodeGenerator, interface_name: &byte, method_name: &byte) &ASTNode {
    if codegen == null || interface_name == null || method_name == null {
        return null;
    }
    const iface: &ASTNode = find_interface_decl_c99(codegen, interface_name);
    if iface == null || iface.type != ASTNodeType.AST_INTERFACE_DECL {
        return null;
    }
    if iface.interface_decl_method_sigs != null {
        var i: i32 = 0;
        while i < iface.interface_decl_method_sig_count {
            const msig: &ASTNode = iface.interface_decl_method_sigs[i];
            if msig != null && msig.type == ASTNodeType.AST_FN_DECL && msig.fn_decl_name != null &&
                strcmp(msig.fn_decl_name as *byte, method_name as *byte) == 0 {
                return msig;
            }
            i = i + 1;
        }
    }
    if iface.interface_decl_composed_interfaces != null {
        var j: i32 = 0;
        while j < iface.interface_decl_composed_count {
            const composed_name: &byte = iface.interface_decl_composed_interfaces[j];
            if composed_name != null {
                const found: &ASTNode = c99_find_interface_method_sig(codegen, composed_name, method_name);
                if found != null {
                    return found;
                }
            }
            j = j + 1;
        }
    }
    return null;
}

// 查找结构体对应的方法块
fn find_method_block_for_struct_c99(codegen: &C99CodeGenerator, struct_name: &byte) &ASTNode {
    if codegen == null || struct_name == null || codegen.program_node == null {
        return null;
    }
    const decl_count: i32 = codegen.program_node.program_decl_count;
    var i: i32 = 0;
    while i < decl_count {
        const decl: &ASTNode = codegen.program_node.program_decls[i];
        if decl != null && decl.type == ASTNodeType.AST_METHOD_BLOCK {
            if decl.method_block_struct_name != null &&
                strcmp(decl.method_block_struct_name as *byte, struct_name as *byte) == 0 {
                return decl;
            }
        }
        i = i + 1;
    }
    return null;
}

// 在方法块中按名称查找方法
fn find_method_in_block(method_block: &ASTNode, method_name: &byte) &ASTNode {
    if method_block == null || method_block.type != ASTNodeType.AST_METHOD_BLOCK || method_name == null {
        return null;
    }
    var i: i32 = 0;
    while i < method_block.method_block_method_count {
        const m: &ASTNode = method_block.method_block_methods[i];
        if m != null && m.type == ASTNodeType.AST_FN_DECL && m.fn_decl_name != null &&
            strcmp(m.fn_decl_name as *byte, method_name as *byte) == 0 {
            return m;
        }
        i = i + 1;
    }
    return null;
}

fn c99_fn_decl_has_interface_receiver(fn_decl: &ASTNode) i32 {
    if fn_decl == null || fn_decl.type != ASTNodeType.AST_FN_DECL ||
        fn_decl.fn_decl_param_count < 1 || fn_decl.fn_decl_params == null {
        return 0;
    }
    const param: &ASTNode = fn_decl.fn_decl_params[0];
    if param == null || param.type != ASTNodeType.AST_VAR_DECL || param.var_decl_type == null {
        return 0;
    }
    const param_type: &ASTNode = param.var_decl_type;
    if param_type.type != ASTNodeType.AST_TYPE_POINTER || param_type.type_pointer_is_ffi_pointer != 0 ||
        param_type.type_pointer_pointed_type == null {
        return 0;
    }
    const pointed: &ASTNode = param_type.type_pointer_pointed_type;
    if pointed.type == ASTNodeType.AST_TYPE_NAMED && pointed.type_named_name != null &&
        strcmp(pointed.type_named_name as *byte, "Self" as *byte) == 0 {
        return 1;
    }
    return 0;
}

fn c99_fn_decl_has_receiver_for_owner(fn_decl: &ASTNode, owner_name: &byte) i32 {
    if fn_decl == null || fn_decl.type != ASTNodeType.AST_FN_DECL || owner_name == null ||
        fn_decl.fn_decl_param_count < 1 || fn_decl.fn_decl_params == null {
        return 0;
    }
    const param: &ASTNode = fn_decl.fn_decl_params[0];
    if param == null || param.type != ASTNodeType.AST_VAR_DECL || param.var_decl_type == null {
        return 0;
    }
    const param_type: &ASTNode = param.var_decl_type;
    if param_type.type != ASTNodeType.AST_TYPE_POINTER || param_type.type_pointer_is_ffi_pointer != 0 ||
        param_type.type_pointer_pointed_type == null {
        return 0;
    }
    const pointed: &ASTNode = param_type.type_pointer_pointed_type;
    if pointed.type != ASTNodeType.AST_TYPE_NAMED || pointed.type_named_name == null {
        return 0;
    }
    if strcmp(pointed.type_named_name as *byte, "Self" as *byte) == 0 ||
        strcmp(pointed.type_named_name as *byte, owner_name as *byte) == 0 {
        return 1;
    }
    return 0;
}

fn c99_find_method_in_block_with_receiver_kind(method_block: &ASTNode, owner_name: &byte, method_name: &byte, want_self_receiver: i32) &ASTNode {
    if method_block == null || method_block.type != ASTNodeType.AST_METHOD_BLOCK || method_name == null {
        return null;
    }
    var i: i32 = 0;
    while i < method_block.method_block_method_count {
        const m: &ASTNode = method_block.method_block_methods[i];
        if m != null && m.type == ASTNodeType.AST_FN_DECL && m.fn_decl_name != null &&
            strcmp(m.fn_decl_name as *byte, method_name as *byte) == 0 {
            if want_self_receiver < 0 || c99_fn_decl_has_receiver_for_owner(m, owner_name) == want_self_receiver {
                return m;
            }
        }
        i = i + 1;
    }
    return null;
}

// 检查结构体是否包含 from_json_reflect（方法块中有 _from_json_placeholder 方法）
export fn struct_has_from_json_reflect_c99(codegen: &C99CodeGenerator, struct_name: &byte) i32 {
    if codegen == null || struct_name == null {
        return 0;
    }
    const block: &ASTNode = find_method_block_for_struct_c99(codegen, struct_name);
    if block == null {
        return 0;
    }
    const m: &ASTNode = find_method_in_block(block, ("_from_json_placeholder" as *byte) as &byte);
    if m != null {
        return 1;
    }
    return 0;
}

// 查找结构体方法（同时检查外部方法块和内部定义的方法）
// 全局静态缓冲区用于从单态化名称提取泛型名称（避免 arena 分配）
var g_generic_name_buf: [byte: C99_GENERIC_NAME_BUF_SIZE] = [];

// 内部辅助函数：从单态化名称提取泛型名称并存储到全局缓冲区
// 返回 1 表示成功提取（结果在 g_generic_name_buf 中），0 表示非单态化名称
fn extract_generic_name_inline(mono_name: &byte) i32 {
    if mono_name == null {
        return 0;
    }
    const underscore: *byte = strchr(mono_name as *byte, 95);  // '_'
    if underscore == null {
        return 0;
    }
    const after: &byte = (underscore + 1) as &byte;
    // 检查是否是基础类型名或首字母大写的用户类型
    var is_type: i32 = 0;
    if strcmp(after as *byte, "i8" as *byte) == 0 || strcmp(after as *byte, "i16" as *byte) == 0 ||
       strcmp(after as *byte, "i32" as *byte) == 0 || strcmp(after as *byte, "i64" as *byte) == 0 ||
       strcmp(after as *byte, "u8" as *byte) == 0 || strcmp(after as *byte, "u16" as *byte) == 0 ||
       strcmp(after as *byte, "u32" as *byte) == 0 || strcmp(after as *byte, "u64" as *byte) == 0 ||
       strcmp(after as *byte, "f32" as *byte) == 0 || strcmp(after as *byte, "f64" as *byte) == 0 ||
       strcmp(after as *byte, "bool" as *byte) == 0 || strcmp(after as *byte, "byte" as *byte) == 0 ||
       strcmp(after as *byte, "usize" as *byte) == 0 {
        is_type = 1;
    } else if after[0] >= 65 && after[0] <= 90 {  // 'A' to 'Z'
        is_type = 1;
    } else {
        const next_underscore: *byte = strchr(after as *byte, 95);
        if next_underscore != null {
            is_type = 1;
        }
    }
    if is_type == 0 {
        return 0;
    }
    const len: i32 = ptr_diff(underscore, mono_name as *byte);
    if len >= C99_GENERIC_NAME_BUF_SIZE || len <= 0 {
        return 0;
    }
    var i: i32 = 0;
    while i < len && i < C99_GENERIC_NAME_BUF_SIZE {
        g_generic_name_buf[i] = mono_name[i];
        i = i + 1;
    }
    if len >= 0 && len < C99_GENERIC_NAME_BUF_SIZE {
        g_generic_name_buf[len] = 0;
    }
    return 1;
}

// 查找结构体方法（同时检查外部方法块和内部定义的方法）
// 支持单态化名称：如果 struct_name 是 Container_i32，会尝试查找 Container 的方法
fn find_method_in_struct_c99(codegen: &C99CodeGenerator, struct_name: &byte, method_name: &byte) &ASTNode {
    if codegen == null || struct_name == null || method_name == null {
        return null;
    }
    // 1. 先检查外部方法块
    var method_block: &ASTNode = find_method_block_for_struct_c99(codegen, struct_name);
    if method_block != null {
        const m: &ASTNode = find_method_in_block(method_block, method_name);
        if m != null {
            return m;
        }
    }
    // 2. 再检查结构体内部定义的方法
    var struct_decl: &ASTNode = find_struct_decl_c99(codegen, struct_name);
    if struct_decl != null && struct_decl.struct_decl_methods != null {
        var i: i32 = 0;
        while i < struct_decl.struct_decl_method_count {
            const m: &ASTNode = struct_decl.struct_decl_methods[i];
            if m != null && m.type == ASTNodeType.AST_FN_DECL && m.fn_decl_name != null &&
                strcmp(m.fn_decl_name as *byte, method_name as *byte) == 0 {
                return m;
            }
            i = i + 1;
        }
    }
    // 3. 如果是单态化名称（如 Container_i32），尝试提取原始名称并查找
    if extract_generic_name_inline(struct_name) != 0 {
        // 检查外部方法块
        method_block = find_method_block_for_struct_c99(codegen, &g_generic_name_buf[0]);
        if method_block != null {
            const m: &ASTNode = find_method_in_block(method_block, method_name);
            if m != null {
                return m;
            }
        }
        // 检查结构体内部定义的方法
        struct_decl = find_struct_decl_c99(codegen, &g_generic_name_buf[0]);
        if struct_decl != null && struct_decl.struct_decl_methods != null {
            var i: i32 = 0;
            while i < struct_decl.struct_decl_method_count {
                const m: &ASTNode = struct_decl.struct_decl_methods[i];
                if m != null && m.type == ASTNodeType.AST_FN_DECL && m.fn_decl_name != null &&
                    strcmp(m.fn_decl_name as *byte, method_name as *byte) == 0 {
                    return m;
                }
                i = i + 1;
            }
        }
    }
    return null;
}

fn find_instance_method_in_struct_c99(codegen: &C99CodeGenerator, struct_name: &byte, method_name: &byte) &ASTNode {
    if codegen == null || struct_name == null || method_name == null {
        return null;
    }
    var method_block: &ASTNode = find_method_block_for_struct_c99(codegen, struct_name);
    if method_block != null {
        const m: &ASTNode = c99_find_method_in_block_with_receiver_kind(method_block, struct_name, method_name, 1);
        if m != null {
            return m;
        }
    }
    var struct_decl: &ASTNode = find_struct_decl_c99(codegen, struct_name);
    if struct_decl != null && struct_decl.struct_decl_methods != null {
        var i: i32 = 0;
        while i < struct_decl.struct_decl_method_count {
            const m: &ASTNode = struct_decl.struct_decl_methods[i];
            if m != null && m.type == ASTNodeType.AST_FN_DECL && m.fn_decl_name != null &&
                strcmp(m.fn_decl_name as *byte, method_name as *byte) == 0 &&
                c99_fn_decl_has_receiver_for_owner(m, struct_name) != 0 {
                return m;
            }
            i = i + 1;
        }
    }
    if extract_generic_name_inline(struct_name) != 0 {
        method_block = find_method_block_for_struct_c99(codegen, &g_generic_name_buf[0]);
        if method_block != null {
            const m: &ASTNode = c99_find_method_in_block_with_receiver_kind(method_block, &g_generic_name_buf[0], method_name, 1);
            if m != null {
                return m;
            }
        }
        struct_decl = find_struct_decl_c99(codegen, &g_generic_name_buf[0]);
        if struct_decl != null && struct_decl.struct_decl_methods != null {
            var i: i32 = 0;
            while i < struct_decl.struct_decl_method_count {
                const m: &ASTNode = struct_decl.struct_decl_methods[i];
                if m != null && m.type == ASTNodeType.AST_FN_DECL && m.fn_decl_name != null &&
                    strcmp(m.fn_decl_name as *byte, method_name as *byte) == 0 &&
                    c99_fn_decl_has_receiver_for_owner(m, &g_generic_name_buf[0]) != 0 {
                    return m;
                }
                i = i + 1;
            }
        }
    }
    return null;
}

fn find_static_method_in_struct_c99(codegen: &C99CodeGenerator, struct_name: &byte, method_name: &byte) &ASTNode {
    if codegen == null || struct_name == null || method_name == null {
        return null;
    }
    var method_block: &ASTNode = find_method_block_for_struct_c99(codegen, struct_name);
    if method_block != null {
        const m: &ASTNode = c99_find_method_in_block_with_receiver_kind(method_block, struct_name, method_name, 0);
        if m != null {
            return m;
        }
    }
    var struct_decl: &ASTNode = find_struct_decl_c99(codegen, struct_name);
    if struct_decl != null && struct_decl.struct_decl_methods != null {
        var i: i32 = 0;
        while i < struct_decl.struct_decl_method_count {
            const m: &ASTNode = struct_decl.struct_decl_methods[i];
            if m != null && m.type == ASTNodeType.AST_FN_DECL && m.fn_decl_name != null &&
                strcmp(m.fn_decl_name as *byte, method_name as *byte) == 0 &&
                c99_fn_decl_has_receiver_for_owner(m, struct_name) == 0 {
                return m;
            }
            i = i + 1;
        }
    }
    if extract_generic_name_inline(struct_name) != 0 {
        method_block = find_method_block_for_struct_c99(codegen, &g_generic_name_buf[0]);
        if method_block != null {
            const m: &ASTNode = c99_find_method_in_block_with_receiver_kind(method_block, &g_generic_name_buf[0], method_name, 0);
            if m != null {
                return m;
            }
        }
        struct_decl = find_struct_decl_c99(codegen, &g_generic_name_buf[0]);
        if struct_decl != null && struct_decl.struct_decl_methods != null {
            var i: i32 = 0;
            while i < struct_decl.struct_decl_method_count {
                const m: &ASTNode = struct_decl.struct_decl_methods[i];
                if m != null && m.type == ASTNodeType.AST_FN_DECL && m.fn_decl_name != null &&
                    strcmp(m.fn_decl_name as *byte, method_name as *byte) == 0 &&
                    c99_fn_decl_has_receiver_for_owner(m, &g_generic_name_buf[0]) == 0 {
                    return m;
                }
                i = i + 1;
            }
        }
    }
    return null;
}

// 获取方法的 C 函数名（uya_StructName_methodname）
fn get_method_c_name(codegen: &C99CodeGenerator, struct_name: &byte, method_name: &byte) &byte {
    if struct_name == null || method_name == null {
        return null;
    }
    const safe_s: &byte = get_safe_c_identifier(codegen, struct_name);
    const safe_m: &byte = get_safe_c_identifier(codegen, method_name);
    if safe_s == null || safe_m == null {
        return null;
    }
    const len: i32 = 5 + strlen(safe_s as *byte) + 1 + strlen(safe_m as *byte) + 1;
    const buf: &byte = compiler_arena_alloc(codegen.arena, len) as &byte;
    if buf == null {
        return null;
    }
    snprintf(buf as *byte, len, "uya_%s_%s" as *byte, safe_s as *byte, safe_m as *byte);
    return buf;
}

fn get_mono_method_c_name(codegen: &C99CodeGenerator, struct_name: &byte, method_name: &byte,
    type_args: & & ASTNode, type_arg_count: i32) &byte {
    if codegen == null || struct_name == null || method_name == null {
        return null;
    }
    if type_args == null || type_arg_count <= 0 {
        return get_method_c_name(codegen, struct_name, method_name);
    }

    var suffix: [byte: C99_SUFFIX_BUF_SIZE] = [0: C99_SUFFIX_BUF_SIZE];
    var suffix_len: i32 = 0;
    var i: i32 = 0;
    while i < type_arg_count {
        if i > 0 {
            if suffix_len >= 0 && suffix_len < C99_SUFFIX_BUF_SIZE {
                suffix[suffix_len] = 95 as byte;
            }
            suffix_len = suffix_len + 1;
        }
        suffix_len = append_type_arg_suffix(codegen, type_args[i], &suffix[0], suffix_len, C99_SUFFIX_BUF_SIZE);
        i = i + 1;
    }
    if suffix_len >= 0 && suffix_len < C99_SUFFIX_BUF_SIZE {
        suffix[suffix_len] = 0;
    }
    normalize_redundant_err_suffix(&suffix[0] as &byte);

    const safe_s: &byte = get_safe_c_identifier(codegen, struct_name);
    const safe_m: &byte = get_safe_c_identifier(codegen, method_name);
    if safe_s == null || safe_m == null {
        return null;
    }

    const len: i32 = 5 + strlen(safe_s as *byte) + 1 + strlen(safe_m as *byte) + 1 + strlen(&suffix[0]) + 1;
    const buf: &byte = compiler_arena_alloc(codegen.arena, len as usize) as &byte;
    if buf == null {
        return null;
    }
    snprintf(buf as *byte, len, "uya_%s_%s_%s" as *byte, safe_s as *byte, safe_m as *byte, &suffix[0] as *byte);
    return buf;
}

// 检查接口是否是泛型接口（有类型参数）
fn is_generic_interface_c99(iface_decl: &ASTNode) i32 {
    if iface_decl == null || iface_decl.type != ASTNodeType.AST_INTERFACE_DECL {
        return 0;
    }
    if iface_decl.interface_decl_type_param_count > 0 {
        return 1;
    }
    return 0;
}

// 生成接口值结构体与 vtable 结构体（不含 vtable 常量）
// 预先生成接口方法签名中使用的错误联合类型结构体定义
fn pregenerate_error_union_structs_for_interface(codegen: &C99CodeGenerator, iface_decl: &ASTNode) void {
    if codegen == null || iface_decl == null || iface_decl.type != ASTNodeType.AST_INTERFACE_DECL {
        return;
    }
    
    // 遍历所有方法签名，收集错误联合类型
    var j: i32 = 0;
    while j < iface_decl.interface_decl_method_sig_count {
        const msig: &ASTNode = iface_decl.interface_decl_method_sigs[j];
        if msig != null && msig.type == ASTNodeType.AST_FN_DECL {
            // 检查返回类型
            const ret_type: &ASTNode = msig.fn_decl_return_type;
            if ret_type != null && ret_type.type == ASTNodeType.AST_TYPE_ERROR_UNION {
                // 预先生成错误联合类型结构体定义（通过调用 c99_type_to_c）
                c99_type_to_c(codegen, ret_type);
            }
            
            // 检查参数类型
            if msig.fn_decl_params != null {
                var k: i32 = 1;
                while k < msig.fn_decl_param_count {
                    const p: &ASTNode = msig.fn_decl_params[k];
                    if p != null && p.type == ASTNodeType.AST_VAR_DECL {
                        const pt: &ASTNode = p.var_decl_type;
                        if pt != null && pt.type == ASTNodeType.AST_TYPE_ERROR_UNION {
                            // 预先生成错误联合类型结构体定义
                            c99_type_to_c(codegen, pt);
                        }
                    }
                    k = k + 1;
                }
            }
        }
        j = j + 1;
    }
}

// 递归收集接口（包括组合接口）的所有方法签名
// 将方法签名写入 sigs 数组，从 start_idx 开始，返回最终的 count
fn collect_interface_method_sigs_internal(codegen: &C99CodeGenerator, interface_name: &byte,
                                           sigs: & & ASTNode, max_sigs: i32, start_idx: i32) i32 {
    if codegen == null || interface_name == null || sigs == null {
        return start_idx;
    }
    
    const iface: &ASTNode = find_interface_decl_c99(codegen, interface_name);
    if iface == null {
        return start_idx;
    }
    
    var count: i32 = start_idx;
    
    // 先收集组合接口的方法（保证继承的方法在前面）
    if iface.interface_decl_composed_interfaces != null {
        var ci: i32 = 0;
        while ci < iface.interface_decl_composed_count {
            const composed_name: &byte = iface.interface_decl_composed_interfaces[ci];
            if composed_name != null {
                count = collect_interface_method_sigs_internal(codegen, composed_name, sigs, max_sigs, count);
            }
            ci = ci + 1;
        }
    }
    
    // 再收集本接口的方法
    if iface.interface_decl_method_sigs != null {
        var mi: i32 = 0;
        while mi < iface.interface_decl_method_sig_count {
            const msig: &ASTNode = iface.interface_decl_method_sigs[mi];
            if msig == null || msig.type != ASTNodeType.AST_FN_DECL {
                mi = mi + 1;
                continue;
            }
            
            // 检查是否已存在（避免重复）
            var exists: i32 = 0;
            var ej: i32 = 0;
            while ej < count {
                if sigs[ej] != null && sigs[ej].fn_decl_name != null && msig.fn_decl_name != null &&
                    str_equals(sigs[ej].fn_decl_name, msig.fn_decl_name) != 0 {
                    exists = 1;
                    break;
                }
                ej = ej + 1;
            }
            
            if exists == 0 && count < max_sigs {
                sigs[count] = msig;
                count = count + 1;
            }
            mi = mi + 1;
        }
    }
    
    return count;
}

// 便捷函数：收集接口的所有方法签名，从 0 开始
fn collect_interface_method_sigs(codegen: &C99CodeGenerator, interface_name: &byte,
                                  sigs: & & ASTNode, max_sigs: i32) i32 {
    return collect_interface_method_sigs_internal(codegen, interface_name, sigs, max_sigs, 0);
}

// 在 vtable 等之前输出所有 union 的 struct uya_tagged_X 前向声明，避免 vtable 参数列表中 "declared inside parameter list" 警告/错误
fn emit_union_tagged_forward_decls(codegen: &C99CodeGenerator) void {
    if codegen == null || codegen.program_node == null {
        return;
    }
    const decl_count: i32 = codegen.program_node.program_decl_count;
    var i: i32 = 0;
    while i < decl_count {
        const decl: &ASTNode = codegen.program_node.program_decls[i];
        if decl != null && decl.type == ASTNodeType.AST_UNION_DECL && decl.union_decl_name != null {
            if is_generic_union_c99(decl) != 0 {
                var j: i32 = 0;
                while j < codegen.mono_instance_count {
                    if codegen.mono_instances[j].generic_name != null &&
                        strcmp(codegen.mono_instances[j].generic_name as *byte, decl.union_decl_name as *byte) == 0 &&
                        codegen.mono_instances[j].is_function == 0 &&
                        has_unresolved_mono_type_args(decl, codegen.mono_instances[j].type_args, codegen.mono_instances[j].type_arg_count) == 0 {
                        const mono_name: &byte = get_mono_union_name(codegen, decl.union_decl_name,
                            codegen.mono_instances[j].type_args, codegen.mono_instances[j].type_arg_count);
                        if mono_name != null {
                            const safe: &byte = get_safe_c_identifier(codegen, mono_name);
                            if safe != null {
                                fprintf(codegen.emit_stream as *void, "struct uya_tagged_%s;\n" as *byte, safe as *byte);
                            }
                        }
                    }
                    j = j + 1;
                }
            } else {
                const safe: &byte = get_safe_c_identifier(codegen, decl.union_decl_name);
                if safe != null {
                    fprintf(codegen.emit_stream as *void, "struct uya_tagged_%s;\n" as *byte, safe as *byte);
                }
            }
        }
        i = i + 1;
    }
}

fn emit_interface_structs_and_vtables(codegen: &C99CodeGenerator) void {
    if codegen == null || codegen.program_node == null {
        return;
    }
    const decl_count: i32 = codegen.program_node.program_decl_count;

    // 第零步：联合体 tagged 结构体前向声明，供 vtable 参数类型使用
    emit_union_tagged_forward_decls(codegen);

    // 第一步：预先生成所有接口方法签名中使用的错误联合类型结构体定义
    // 跳过泛型接口（类型参数会导致错误联合类型如 err_union_T 无法编译）
    var i: i32 = 0;
    while i < decl_count {
        const decl: &ASTNode = codegen.program_node.program_decls[i];
        if decl != null && decl.type == ASTNodeType.AST_INTERFACE_DECL {
            // 跳过泛型接口，它们只是模板，不应生成代码
            if is_generic_interface_c99(decl) == 0 {
                pregenerate_error_union_structs_for_interface(codegen, decl);
            }
        }
        i = i + 1;
    }
    
    // 第二步：生成接口值结构体与 vtable 结构体
    // 跳过泛型接口
    i = 0;
    while i < decl_count {
        const decl: &ASTNode = codegen.program_node.program_decls[i];
        if decl == null || decl.type != ASTNodeType.AST_INTERFACE_DECL {
            i = i + 1;
            continue;
        }
        // 跳过泛型接口，它们只是模板，不应生成代码
        if is_generic_interface_c99(decl) != 0 {
            i = i + 1;
            continue;
        }
        const iface_name: &byte = decl.interface_decl_name;
        if iface_name == null {
            i = i + 1;
            continue;
        }
        const safe_iface: &byte = get_safe_c_identifier(codegen, iface_name);
        fprintf(codegen.emit_stream as *void, "struct uya_interface_%s { void *vtable; void *data; };\n" as *byte, safe_iface as *byte);
        fprintf(codegen.emit_stream as *void, "struct uya_vtable_%s {\n" as *byte, safe_iface as *byte);
        codegen.indent_level = codegen.indent_level + 1;
        
        // 使用 collect_interface_method_sigs 收集所有方法（包括组合接口的方法）
        var all_sigs: [&ASTNode: C99_MAX_INTERFACE_METHODS] = [];
        const sig_count: i32 = collect_interface_method_sigs(codegen, iface_name, &all_sigs[0], C99_MAX_INTERFACE_METHODS);

        var j: i32 = 0;
        while j < sig_count && j < C99_MAX_INTERFACE_METHODS {
            const msig: &ASTNode = all_sigs[j];
            if msig == null || msig.type != ASTNodeType.AST_FN_DECL {
                j = j + 1;
                continue;
            }
            var ret_c: &byte = convert_array_return_type(codegen, msig.fn_decl_return_type);
            ret_c = normalize_poll_return_type(codegen, ret_c);
            const mname: &byte = get_safe_c_identifier(codegen, msig.fn_decl_name);
            const pc: i32 = msig.fn_decl_param_count;
            c99_emit_indent(codegen);
            fprintf(codegen.emit_stream as *void, "%s (*%s)(void *self" as *byte, ret_c as *byte, mname as *byte);
            var k: i32 = 1;
            while k < pc && msig.fn_decl_params != null {
                const p: &ASTNode = msig.fn_decl_params[k];
                if p == null || p.type != ASTNodeType.AST_VAR_DECL {
                    k = k + 1;
                    continue;
                }
                const pt_c: &byte = c99_type_to_c(codegen, p.var_decl_type);
                fprintf(codegen.emit_stream as *void, ", %s" as *byte, pt_c as *byte);
                k = k + 1;
            }
            fputs(");\n" as *byte, codegen.emit_stream as *void);
            j = j + 1;
        }
        codegen.indent_level = codegen.indent_level - 1;
        fputs("};\n" as *byte, codegen.emit_stream as *void);
        i = i + 1;
    }

    // 第三步：为已使用到的泛型接口实例生成接口值结构体与 vtable 结构体
    // 通过 mono_instances 收集（checker/type_from_ast 会为所有 T<Args> 注册 mono instance）
    if codegen.mono_instance_count > 0 {
        var mi: i32 = 0;
        while mi < codegen.mono_instance_count {
            const inst: &MonoInstanceCodegen = &codegen.mono_instances[mi];
            if inst.is_function != 0 || inst.generic_name == null ||
                inst.type_args == null || inst.type_arg_count <= 0 {
                mi = mi + 1;
                continue;
            }
            const iface_decl: &ASTNode = find_interface_decl_c99(codegen, inst.generic_name);
            if iface_decl == null || is_generic_interface_c99(iface_decl) == 0 {
                mi = mi + 1;
                continue;
            }
            // 跳过未解析的类型实参（如 T）
            if has_unresolved_mono_type_args(iface_decl, inst.type_args, inst.type_arg_count) != 0 {
                mi = mi + 1;
                continue;
            }

            // 单态接口名：Iface_T1_T2...
            const mono_iface: &byte = get_mono_struct_name(codegen, inst.generic_name, inst.type_args, inst.type_arg_count);
            const safe_mono_iface: &byte = get_safe_c_identifier(codegen, mono_iface);
            if safe_mono_iface == null {
                mi = mi + 1;
                continue;
            }

            // 临时设置类型参数上下文，让 c99_type_to_c 能把 Poll<T> 等替换成 Poll_i32
            const saved_sp: &TypeParam = codegen.struct_type_params;
            const saved_spc: i32 = codegen.struct_type_param_count;
            const saved_sa: & & ASTNode = codegen.struct_type_args;
            const saved_sac: i32 = codegen.struct_type_arg_count;
            codegen.struct_type_params = iface_decl.interface_decl_type_params;
            codegen.struct_type_param_count = iface_decl.interface_decl_type_param_count;
            codegen.struct_type_args = inst.type_args;
            codegen.struct_type_arg_count = inst.type_arg_count;

            fprintf(codegen.emit_stream as *void, "struct uya_interface_%s { void *vtable; void *data; };\n" as *byte, safe_mono_iface as *byte);
            fprintf(codegen.emit_stream as *void, "struct uya_vtable_%s {\n" as *byte, safe_mono_iface as *byte);
            codegen.indent_level = codegen.indent_level + 1;

            // 收集方法签名（不包含 composed 泛型接口的单态展开；Future<T> 无 composed，足够）
            var all_sigs: [&ASTNode: C99_MAX_INTERFACE_METHODS] = [];
            const sig_count: i32 = collect_interface_method_sigs(codegen, iface_decl.interface_decl_name, &all_sigs[0], C99_MAX_INTERFACE_METHODS);
            var j: i32 = 0;
            while j < sig_count && j < C99_MAX_INTERFACE_METHODS {
                const msig: &ASTNode = all_sigs[j];
                if msig == null || msig.type != ASTNodeType.AST_FN_DECL {
                    j = j + 1;
                    continue;
                }
                var ret_c: &byte = convert_array_return_type(codegen, msig.fn_decl_return_type);
                ret_c = normalize_poll_return_type(codegen, ret_c);
                const mname: &byte = get_safe_c_identifier(codegen, msig.fn_decl_name);
                const pc: i32 = msig.fn_decl_param_count;
                c99_emit_indent(codegen);
                fprintf(codegen.emit_stream as *void, "%s (*%s)(void *self" as *byte, ret_c as *byte, mname as *byte);
                var k: i32 = 1;
                while k < pc && msig.fn_decl_params != null {
                    const p: &ASTNode = msig.fn_decl_params[k];
                    if p == null || p.type != ASTNodeType.AST_VAR_DECL {
                        k = k + 1;
                        continue;
                    }
                    const pt_c: &byte = c99_type_to_c(codegen, p.var_decl_type);
                    fprintf(codegen.emit_stream as *void, ", %s" as *byte, pt_c as *byte);
                    k = k + 1;
                }
                fputs(");\n" as *byte, codegen.emit_stream as *void);
                j = j + 1;
            }
            codegen.indent_level = codegen.indent_level - 1;
            fputs("};\n" as *byte, codegen.emit_stream as *void);

            // 标记已定义，避免后续重复输出
            const iface_struct_len: i32 = strlen(safe_mono_iface as *byte) + 32;
            const iface_struct_name: &byte = compiler_arena_alloc(codegen.arena, iface_struct_len as usize) as &byte;
            const vtable_struct_name: &byte = compiler_arena_alloc(codegen.arena, iface_struct_len as usize) as &byte;
            if iface_struct_name != null && vtable_struct_name != null {
                snprintf(iface_struct_name as *byte, iface_struct_len, "uya_interface_%s" as *byte, safe_mono_iface as *byte);
                snprintf(vtable_struct_name as *byte, iface_struct_len, "uya_vtable_%s" as *byte, safe_mono_iface as *byte);
                mark_struct_defined(codegen, iface_struct_name);
                mark_struct_defined(codegen, vtable_struct_name);
            }

            codegen.struct_type_params = saved_sp;
            codegen.struct_type_param_count = saved_spc;
            codegen.struct_type_args = saved_sa;
            codegen.struct_type_arg_count = saved_sac;

            mi = mi + 1;
        }
    }
}

// 镜像分 TU：vtable 若在 uya_common.c 中用 static，其它镜像 .c 无法链接；需外链 + uya_vtable_externs.h 声明。
fn c99_emit_vtable_var_open(codegen: &C99CodeGenerator, vtable_externs_out: &void, iface_safe: &byte, struct_safe: &byte) void {
    if iface_safe == null || struct_safe == null {
        return;
    }
    if codegen.split_mirror != 0 {
        if vtable_externs_out != null {
            fprintf(vtable_externs_out as *void, "extern const struct uya_vtable_%s uya_vtable_%s_%s;\n" as *byte,
                iface_safe as *byte, iface_safe as *byte, struct_safe as *byte);
        }
        fprintf(codegen.emit_stream as *void, "const struct uya_vtable_%s uya_vtable_%s_%s = { " as *byte,
            iface_safe as *byte, iface_safe as *byte, struct_safe as *byte);
    } else {
        fprintf(codegen.emit_stream as *void, "static const struct uya_vtable_%s uya_vtable_%s_%s = { " as *byte,
            iface_safe as *byte, iface_safe as *byte, struct_safe as *byte);
    }
}

// 在已设置「接口/联合体」struct_type_* 的上下文中解析接口方法返回类型（如 Poll<T> 的 T）。
// 暂时屏蔽外层泛型函数的 current_type_*，避免与接口形参同名（如 block_on<T> 与 Future<T>）时 append_type_arg_suffix 错绑到 i32。
fn convert_array_return_type_iface_vtable(codegen: &C99CodeGenerator, ret_type: &ASTNode) &byte {
    const saved_tp: &TypeParam = codegen.current_type_params;
    const saved_tpc: i32 = codegen.current_type_param_count;
    const saved_ta: & & ASTNode = codegen.current_type_args;
    const saved_tac: i32 = codegen.current_type_arg_count;
    codegen.current_type_params = null;
    codegen.current_type_param_count = 0;
    codegen.current_type_args = null;
    codegen.current_type_arg_count = 0;
    var ret: &byte = convert_array_return_type(codegen, ret_type);
    codegen.current_type_params = saved_tp;
    codegen.current_type_param_count = saved_tpc;
    codegen.current_type_args = saved_ta;
    codegen.current_type_arg_count = saved_tac;
    ret = normalize_poll_return_type(codegen, ret);
    return ret;
}

// 生成各 struct:interface 的 vtable 常量（需在方法前向声明之后调用）
fn emit_vtable_constants(codegen: &C99CodeGenerator) void {
    if codegen == null || codegen.program_node == null {
        return;
    }
    var vtable_externs_out: &void = null;
    if codegen.split_mirror != 0 && codegen.split_dir != null && codegen.split_dir[0] != 0 as byte {
        var vepath: [byte: 1024] = [];
        const vel: i32 = snprintf(&vepath[0] as *byte, 1024, "%s/uya_vtable_externs.h" as *byte, codegen.split_dir as *byte);
        if vel > 0 && vel < 1024 {
            const veh: *void = fopen(&vepath[0] as *byte, "w" as *byte);
            if veh != null {
                fputs("#ifndef UYA_VTABLE_EXTERNS_H\n#define UYA_VTABLE_EXTERNS_H\n\n" as *byte, veh as *void);
                vtable_externs_out = veh as &void;
            }
        }
    }
    const decl_count: i32 = codegen.program_node.program_decl_count;
    var i: i32 = 0;
    while i < decl_count {
        const decl: &ASTNode = codegen.program_node.program_decls[i];
        if decl == null || decl.type != ASTNodeType.AST_STRUCT_DECL {
            i = i + 1;
            continue;
        }
        const struct_name: &byte = decl.struct_decl_name;
        const iface_names: & & byte = decl.struct_decl_interface_names;
        const iface_count: i32 = decl.struct_decl_interface_count;
        if iface_names == null || iface_count <= 0 {
            i = i + 1;
            continue;
        }
        const safe_struct: &byte = get_safe_c_identifier(codegen, struct_name);
        var j: i32 = 0;
        while j < iface_count {
            const iface_name: &byte = iface_names[j];
            if iface_name == null {
                j = j + 1;
                continue;
            }
            // 接口名可能带类型参数文本（如 "Future<T>"），这里取 base name 再查找声明
            var iface_base: &byte = iface_name;
            const lt: *byte = strchr(iface_name as *byte, 60);  // '<'
            if lt != null {
                const base_len: i32 = ptr_diff(lt, iface_name as *byte);
                const buf: &byte = compiler_arena_alloc(codegen.arena, (base_len + 1) as usize) as &byte;
                if buf != null {
                    memcpy(buf as *void, iface_name as *void, base_len as usize);
                    if base_len >= 0 && base_len < 1000000 {
                        buf[base_len] = 0;
                    }
                    iface_base = buf;
                }
            }

            const iface_decl: &ASTNode = find_interface_decl_c99(codegen, iface_base);
            if iface_decl == null {
                j = j + 1;
                continue;
            }

            // ===== 情况 A：非泛型 struct 实现了泛型接口实例（如 Getter<i32>）=====
            // iface_name 中带 '<...>'，需要把 T 替换成具体类型，否则会生成含 T 的 C 签名导致链接失败。
            // 泛型结构体（如 AsyncComputeFuture<T>: Future<!T>）不得走此分支：否则会生成
            // uya_vtable_Future_err_T_AsyncComputeFuture 等非法占位（应由下方 mono_instances 单态生成）。
            if is_generic_interface_c99(iface_decl) != 0 && lt != null && is_generic_struct_c99(decl) == 0 {
                // 解析 `<...>` 内的类型参数（仅支持简单命名类型，足够覆盖测试用例）
                const gt: *byte = strrchr(iface_name as *byte, 62);  // '>'
                if gt != null && gt > lt {
                    var args: [&ASTNode: 8] = [];
                    var arg_count: i32 = 0;
                    var p: *byte = lt + 1;
                    while p < gt && arg_count < 8 {
                        while p < gt && (*p == 32 || *p == 9 || *p == 10 || *p == 13) { p = p + 1; } // ws
                        const start: *byte = p;
                        while p < gt && *p != 44 { p = p + 1; } // ','
                        var end: *byte = p;
                        while end > start && (*(end - 1) == 32 || *(end - 1) == 9 || *(end - 1) == 10 || *(end - 1) == 13) { end = end - 1; }
                        const len: i32 = ptr_diff(end, start);
                        if len > 0 {
                            const name_buf: &byte = compiler_arena_alloc(codegen.arena, (len + 1) as usize) as &byte;
                            if name_buf != null {
                                memcpy(name_buf as *void, start as *void, len as usize);
                                if len >= 0 && len < 1000000 {
                                    name_buf[len] = 0;
                                }
                                var type_arg_node: &ASTNode = null;
                                // Future<!usize> 等：尖括号内为 !Payload，须建成错误联合类型节点，不能当作名为 "!usize" 的命名类型
                                if len > 1 && (name_buf[0] as i32) == 33 {
                                    const inner_n: &ASTNode = ast_new_node(ASTNodeType.AST_TYPE_NAMED, 0, 0, codegen.arena, null);
                                    if inner_n != null {
                                        inner_n.type_named_name = &name_buf[1] as &byte;
                                        inner_n.type_named_type_args = null;
                                        inner_n.type_named_type_arg_count = 0;
                                        const eu_n: &ASTNode = ast_new_node(ASTNodeType.AST_TYPE_ERROR_UNION, 0, 0, codegen.arena, null);
                                        if eu_n != null {
                                            eu_n.type_error_union_payload_type = inner_n;
                                            type_arg_node = eu_n;
                                        }
                                    }
                                } else {
                                    const tn: &ASTNode = ast_new_node(ASTNodeType.AST_TYPE_NAMED, 0, 0, codegen.arena, null);
                                    if tn != null {
                                        tn.type_named_name = name_buf;
                                        tn.type_named_type_args = null;
                                        tn.type_named_type_arg_count = 0;
                                        type_arg_node = tn;
                                    }
                                }
                                if type_arg_node != null {
                                    args[arg_count] = type_arg_node;
                                    arg_count = arg_count + 1;
                                }
                            }
                        }
                        if p < gt && *p == 44 { p = p + 1; }
                    }

                    if arg_count == iface_decl.interface_decl_type_param_count && arg_count > 0 {
                        const arg_arr: & & ASTNode = &args[0] as & & ASTNode;
                        // 若类型实参未解析（如 T），不要在模板处生成 vtable（应由具体单态实例生成）
                        if has_unresolved_mono_type_args(iface_decl, arg_arr, arg_count) != 0 {
                            // fallthrough：让后续 mono_instances 分支去处理具体实例
                            // 注意：不要 continue
                        } else {
                        const mono_iface: &byte = get_mono_struct_name(codegen, iface_decl.interface_decl_name, arg_arr, arg_count);
                        const safe_mono_iface: &byte = get_safe_c_identifier(codegen, mono_iface);
                        if safe_mono_iface != null {
                            // 设置类型参数上下文：让 c99_type_to_c 把 T -> i32/f32
                            const saved_sp: &TypeParam = codegen.struct_type_params;
                            const saved_spc: i32 = codegen.struct_type_param_count;
                            const saved_sa: & & ASTNode = codegen.struct_type_args;
                            const saved_sac: i32 = codegen.struct_type_arg_count;
                            codegen.struct_type_params = iface_decl.interface_decl_type_params;
                            codegen.struct_type_param_count = iface_decl.interface_decl_type_param_count;
                            codegen.struct_type_args = arg_arr;
                            codegen.struct_type_arg_count = arg_count;

                            // 确保该泛型接口实例的 interface/vtable struct 已定义
                            const iface_struct_len2: i32 = strlen(safe_mono_iface as *byte) + 32;
                            const iface_struct_name2: &byte = compiler_arena_alloc(codegen.arena, iface_struct_len2 as usize) as &byte;
                            const vtable_struct_name2: &byte = compiler_arena_alloc(codegen.arena, iface_struct_len2 as usize) as &byte;
                            if iface_struct_name2 != null && vtable_struct_name2 != null {
                                snprintf(iface_struct_name2 as *byte, iface_struct_len2, "uya_interface_%s" as *byte, safe_mono_iface as *byte);
                                snprintf(vtable_struct_name2 as *byte, iface_struct_len2, "uya_vtable_%s" as *byte, safe_mono_iface as *byte);
                                if is_struct_defined(codegen, iface_struct_name2) == 0 {
                                    fprintf(codegen.emit_stream as *void, "struct uya_interface_%s { void *vtable; void *data; };\n" as *byte, safe_mono_iface as *byte);
                                    fprintf(codegen.emit_stream as *void, "struct uya_vtable_%s {\n" as *byte, safe_mono_iface as *byte);
                                    codegen.indent_level = codegen.indent_level + 1;
                                    var sigsA: [&ASTNode: C99_MAX_INTERFACE_METHODS] = [];
                                    const scA: i32 = collect_interface_method_sigs(codegen, iface_decl.interface_decl_name, &sigsA[0], C99_MAX_INTERFACE_METHODS);
                                    var sjA: i32 = 0;
                                    while sjA < scA && sjA < C99_MAX_INTERFACE_METHODS {
                                        const msigA: &ASTNode = sigsA[sjA];
                                        if msigA != null && msigA.type == ASTNodeType.AST_FN_DECL {
                                            const retA: &byte = convert_array_return_type_iface_vtable(codegen, msigA.fn_decl_return_type);
                                            const mnA: &byte = get_safe_c_identifier(codegen, msigA.fn_decl_name);
                                            const pcA: i32 = msigA.fn_decl_param_count;
                                            c99_emit_indent(codegen);
                                            fprintf(codegen.emit_stream as *void, "%s (*%s)(void *self" as *byte, retA as *byte, mnA as *byte);
                                            var pkA: i32 = 1;
                                            while pkA < pcA && msigA.fn_decl_params != null {
                                                const pA: &ASTNode = msigA.fn_decl_params[pkA];
                                                if pA != null && pA.type == ASTNodeType.AST_VAR_DECL {
                                                    fprintf(codegen.emit_stream as *void, ", %s" as *byte, c99_type_to_c(codegen, pA.var_decl_type) as *byte);
                                                }
                                                pkA = pkA + 1;
                                            }
                                            fputs(");\n" as *byte, codegen.emit_stream as *void);
                                        }
                                        sjA = sjA + 1;
                                    }
                                    codegen.indent_level = codegen.indent_level - 1;
                                    fputs("};\n" as *byte, codegen.emit_stream as *void);
                                    mark_struct_defined(codegen, iface_struct_name2);
                                    mark_struct_defined(codegen, vtable_struct_name2);
                                }
                            }

                            // 生成 vtable 常量：uya_vtable_<ifaceMono>_<Struct>
                            var all_sigsA2: [&ASTNode: 128] = [];
                            const sig_countA2: i32 = collect_interface_method_sigs(codegen, iface_decl.interface_decl_name, &all_sigsA2[0], 128);
                            c99_emit_vtable_var_open(codegen, vtable_externs_out, safe_mono_iface, safe_struct);
                            var kA: i32 = 0;
                            while kA < sig_countA2 && kA < C99_MAX_INTERFACE_METHODS {
                                const msigA2: &ASTNode = all_sigsA2[kA];
                                if msigA2 == null || msigA2.type != ASTNodeType.AST_FN_DECL {
                                    kA = kA + 1;
                                    continue;
                                }
                                const mnameA: &byte = msigA2.fn_decl_name;
                                const implA: &ASTNode = find_instance_method_in_struct_c99(codegen, struct_name, mnameA);
                                const cnameA: &byte = get_method_c_name(codegen, struct_name, mnameA);
                                if kA > 0 {
                                    c99_emit_comma_space(codegen);
                                }
                                if implA != null && cnameA != null {
                                    const retA2: &byte = convert_array_return_type_iface_vtable(codegen, msigA2.fn_decl_return_type);
                                    const pcA2: i32 = msigA2.fn_decl_param_count;
                                    fprintf(codegen.emit_stream as *void, "(%s (*)(void *self" as *byte, retA2 as *byte);
                                    var kiA2: i32 = 1;
                                    while kiA2 < pcA2 && msigA2.fn_decl_params != null {
                                        const pkA2: &ASTNode = msigA2.fn_decl_params[kiA2];
                                        if pkA2 != null && pkA2.type == ASTNodeType.AST_VAR_DECL {
                                            fprintf(codegen.emit_stream as *void, ", %s" as *byte, c99_type_to_c(codegen, pkA2.var_decl_type) as *byte);
                                        }
                                        kiA2 = kiA2 + 1;
                                    }
                                    fprintf(codegen.emit_stream as *void, "))&%s" as *byte, cnameA as *byte);
                                } else {
                                    fputs("NULL" as *byte, codegen.emit_stream as *void);
                                }
                                kA = kA + 1;
                            }
                            fputs(" };\n" as *byte, codegen.emit_stream as *void);

                            codegen.struct_type_params = saved_sp;
                            codegen.struct_type_param_count = saved_spc;
                            codegen.struct_type_args = saved_sa;
                            codegen.struct_type_arg_count = saved_sac;
                            j = j + 1;
                            continue;
                        }
                        }
                    }
                }
            }

            // 泛型接口：为已生成的结构体单态实例生成 vtable 常量（如 Future<i32>）
            if is_generic_interface_c99(iface_decl) != 0 && codegen.mono_instance_count > 0 {
                var mi: i32 = 0;
                while mi < codegen.mono_instance_count {
                    const inst: &MonoInstanceCodegen = &codegen.mono_instances[mi];
                    if inst.is_function != 0 || inst.generic_name == null ||
                        strcmp(inst.generic_name as *byte, struct_name as *byte) != 0 ||
                        inst.type_args == null || inst.type_arg_count <= 0 {
                        mi = mi + 1;
                        continue;
                    }
                    if has_unresolved_mono_type_args(decl, inst.type_args, inst.type_arg_count) != 0 ||
                        has_unresolved_mono_type_args(iface_decl, inst.type_args, iface_decl.interface_decl_type_param_count) != 0 {
                        mi = mi + 1;
                        continue;
                    }

                    // struct 可能不是泛型：这种情况下不需要 mono_struct
                    var mono_struct: &byte = struct_name;
                    if decl.struct_decl_type_param_count > 0 && decl.struct_decl_type_params != null {
                        mono_struct = get_mono_struct_name(codegen, struct_name, inst.type_args, inst.type_arg_count);
                    }
                    // AsyncComputeFuture<T> : Future<!T> — Future 的单态实参应为 !T（如 err_i64），不能直接用 T（i64）。
                    var iface_mono_args_ptr: & & ASTNode = inst.type_args;
                    var iface_mono_arg_count: i32 = iface_decl.interface_decl_type_param_count;
                    if struct_name != null && strcmp(struct_name as *byte, "AsyncComputeFuture" as *byte) == 0 &&
                        iface_decl.interface_decl_name != null &&
                        strcmp(iface_decl.interface_decl_name as *byte, "Future" as *byte) == 0 &&
                        decl.struct_decl_type_param_count == 1 && inst.type_arg_count == 1 &&
                        iface_decl.interface_decl_type_param_count == 1 &&
                        inst.type_args != null && inst.type_args[0] != null && codegen.arena != null {
                        const eu_wrap: &ASTNode = ast_new_node(ASTNodeType.AST_TYPE_ERROR_UNION, decl.line, decl.column, codegen.arena, decl.filename);
                        if eu_wrap != null {
                            eu_wrap.type_error_union_payload_type = inst.type_args[0];
                            const ap2: & & ASTNode = compiler_arena_alloc(codegen.arena, @size_of(&ASTNode)) as & & ASTNode;
                            if ap2 != null {
                                ap2[0] = eu_wrap;
                                iface_mono_args_ptr = ap2;
                                iface_mono_arg_count = 1;
                            }
                        }
                    }
                    const mono_iface: &byte = get_mono_struct_name(codegen, iface_decl.interface_decl_name, iface_mono_args_ptr, iface_mono_arg_count);
                    const safe_mono_struct: &byte = get_safe_c_identifier(codegen, mono_struct);
                    const safe_mono_iface: &byte = get_safe_c_identifier(codegen, mono_iface);
                    if safe_mono_struct == null || safe_mono_iface == null {
                        mi = mi + 1;
                        continue;
                    }

                    const saved_sp: &TypeParam = codegen.struct_type_params;
                    const saved_spc: i32 = codegen.struct_type_param_count;
                    const saved_sa: & & ASTNode = codegen.struct_type_args;
                    const saved_sac: i32 = codegen.struct_type_arg_count;
                    codegen.struct_type_params = iface_decl.interface_decl_type_params;
                    codegen.struct_type_param_count = iface_decl.interface_decl_type_param_count;
                    codegen.struct_type_args = iface_mono_args_ptr;
                    codegen.struct_type_arg_count = iface_mono_arg_count;

                    // 确保该泛型接口实例的 interface/vtable struct 已定义（即便未显式作为类型出现）
                    const iface_struct_len: i32 = strlen(safe_mono_iface as *byte) + 32;
                    const iface_struct_name: &byte = compiler_arena_alloc(codegen.arena, iface_struct_len as usize) as &byte;
                    const vtable_struct_name: &byte = compiler_arena_alloc(codegen.arena, iface_struct_len as usize) as &byte;
                    if iface_struct_name != null && vtable_struct_name != null {
                        snprintf(iface_struct_name as *byte, iface_struct_len, "uya_interface_%s" as *byte, safe_mono_iface as *byte);
                        snprintf(vtable_struct_name as *byte, iface_struct_len, "uya_vtable_%s" as *byte, safe_mono_iface as *byte);
                        if is_struct_defined(codegen, iface_struct_name) == 0 {
                            fprintf(codegen.emit_stream as *void, "struct uya_interface_%s { void *vtable; void *data; };\n" as *byte, safe_mono_iface as *byte);
                            fprintf(codegen.emit_stream as *void, "struct uya_vtable_%s {\n" as *byte, safe_mono_iface as *byte);
                            codegen.indent_level = codegen.indent_level + 1;
                            var sigs0: [&ASTNode: C99_MAX_INTERFACE_METHODS] = [];
                            const sc0: i32 = collect_interface_method_sigs(codegen, iface_decl.interface_decl_name, &sigs0[0], C99_MAX_INTERFACE_METHODS);
                            var sj: i32 = 0;
                            while sj < sc0 && sj < C99_MAX_INTERFACE_METHODS {
                                const msig0: &ASTNode = sigs0[sj];
                                if msig0 != null && msig0.type == ASTNodeType.AST_FN_DECL {
                                    const ret0: &byte = convert_array_return_type_iface_vtable(codegen, msig0.fn_decl_return_type);
                                    const mn0: &byte = get_safe_c_identifier(codegen, msig0.fn_decl_name);
                                    const pc0: i32 = msig0.fn_decl_param_count;
                                    c99_emit_indent(codegen);
                                    fprintf(codegen.emit_stream as *void, "%s (*%s)(void *self" as *byte, ret0 as *byte, mn0 as *byte);
                                    var pk0: i32 = 1;
                                    while pk0 < pc0 && msig0.fn_decl_params != null {
                                        const p0: &ASTNode = msig0.fn_decl_params[pk0];
                                        if p0 != null && p0.type == ASTNodeType.AST_VAR_DECL {
                                            fprintf(codegen.emit_stream as *void, ", %s" as *byte, c99_type_to_c(codegen, p0.var_decl_type) as *byte);
                                        }
                                        pk0 = pk0 + 1;
                                    }
                                    fputs(");\n" as *byte, codegen.emit_stream as *void);
                                }
                                sj = sj + 1;
                            }
                            codegen.indent_level = codegen.indent_level - 1;
                            fputs("};\n" as *byte, codegen.emit_stream as *void);
                            mark_struct_defined(codegen, iface_struct_name);
                            mark_struct_defined(codegen, vtable_struct_name);
                        }
                    }

                    var all_sigs2: [&ASTNode: 128] = [];
                    const sig_count2: i32 = collect_interface_method_sigs(codegen, iface_decl.interface_decl_name, &all_sigs2[0], 128);
                    c99_emit_vtable_var_open(codegen, vtable_externs_out, safe_mono_iface, safe_mono_struct);
                    var k: i32 = 0;
                    while k < sig_count2 && k < C99_MAX_INTERFACE_METHODS {
                        const msig: &ASTNode = all_sigs2[k];
                        if msig == null || msig.type != ASTNodeType.AST_FN_DECL {
                            k = k + 1;
                            continue;
                        }
                        const mname: &byte = msig.fn_decl_name;
                        const impl: &ASTNode = find_instance_method_in_struct_c99(codegen, mono_struct, mname);
                        const cname: &byte = get_method_c_name(codegen, mono_struct, mname);
                        if k > 0 {
                            c99_emit_comma_space(codegen);
                        }
                        if impl != null && cname != null {
                            const ret_c: &byte = convert_array_return_type_iface_vtable(codegen, msig.fn_decl_return_type);
                            const pc: i32 = msig.fn_decl_param_count;
                            fprintf(codegen.emit_stream as *void, "(%s (*)(void *self" as *byte, ret_c as *byte);
                            var ki: i32 = 1;
                            while ki < pc && msig.fn_decl_params != null {
                                const pk: &ASTNode = msig.fn_decl_params[ki];
                                if pk != null && pk.type == ASTNodeType.AST_VAR_DECL {
                                    fprintf(codegen.emit_stream as *void, ", %s" as *byte, c99_type_to_c(codegen, pk.var_decl_type) as *byte);
                                }
                                ki = ki + 1;
                            }
                            fprintf(codegen.emit_stream as *void, "))&%s" as *byte, cname as *byte);
                        } else {
                            fputs("NULL" as *byte, codegen.emit_stream as *void);
                        }
                        k = k + 1;
                    }
                    fputs(" };\n" as *byte, codegen.emit_stream as *void);

                    codegen.struct_type_params = saved_sp;
                    codegen.struct_type_param_count = saved_spc;
                    codegen.struct_type_args = saved_sa;
                    codegen.struct_type_arg_count = saved_sac;

                    mi = mi + 1;
                }
            } else {
                const safe_iface: &byte = get_safe_c_identifier(codegen, iface_base);
                
                var all_sigs2: [&ASTNode: 128] = [];
                const sig_count2: i32 = collect_interface_method_sigs(codegen, iface_base, &all_sigs2[0], 128);
                
                c99_emit_vtable_var_open(codegen, vtable_externs_out, safe_iface, safe_struct);
                var k: i32 = 0;
                while k < sig_count2 && k < C99_MAX_INTERFACE_METHODS {
                    const msig: &ASTNode = all_sigs2[k];
                    if msig == null || msig.type != ASTNodeType.AST_FN_DECL {
                        k = k + 1;
                        continue;
                    }
                    const mname: &byte = msig.fn_decl_name;
                    const impl: &ASTNode = find_instance_method_in_struct_c99(codegen, struct_name, mname);
                    const cname: &byte = get_method_c_name(codegen, struct_name, mname);
                    if k > 0 {
                        c99_emit_comma_space(codegen);
                    }
                    if impl != null && cname != null {
                        const ret_c: &byte = convert_array_return_type(codegen, msig.fn_decl_return_type);
                        const pc: i32 = msig.fn_decl_param_count;
                        fprintf(codegen.emit_stream as *void, "(%s (*)(void *self" as *byte, ret_c as *byte);
                        var ki: i32 = 1;
                        while ki < pc && msig.fn_decl_params != null {
                            const pk: &ASTNode = msig.fn_decl_params[ki];
                            if pk != null && pk.type == ASTNodeType.AST_VAR_DECL {
                                fprintf(codegen.emit_stream as *void, ", %s" as *byte, c99_type_to_c(codegen, pk.var_decl_type) as *byte);
                            }
                            ki = ki + 1;
                        }
                        fprintf(codegen.emit_stream as *void, "))&%s" as *byte, cname as *byte);
                    } else {
                        fputs("NULL" as *byte, codegen.emit_stream as *void);
                    }
                    k = k + 1;
                }
                fputs(" };\n" as *byte, codegen.emit_stream as *void);
            }
            j = j + 1;
        }
        i = i + 1;
    }
    if vtable_externs_out != null {
        fputs("\n#endif /* UYA_VTABLE_EXTERNS_H */\n" as *byte, vtable_externs_out as *void);
        _ = fclose(vtable_externs_out as *void);
    }
    emit_pending_slice_structs(codegen);
}

// 查找结构体字段类型（C99 版本，返回 ASTNode）
fn c99_find_struct_field_type(codegen: &C99CodeGenerator, struct_decl: &ASTNode, field_name: &byte) &ASTNode {
    if codegen == null || struct_decl == null || struct_decl.type != ASTNodeType.AST_STRUCT_DECL || field_name == null {
        return null;
    }
    
    var i: i32 = 0;
    while i < struct_decl.struct_decl_field_count {
        const field: &ASTNode = struct_decl.struct_decl_fields[i];
        if field != null && field.type == ASTNodeType.AST_VAR_DECL {
            if field.var_decl_name != null && strcmp(field.var_decl_name as *byte, field_name as *byte) == 0 {
                return field.var_decl_type;
            }
        }
        i = i + 1;
    }
    
    return null;
}

// 生成结构体定义
fn gen_struct_definition(codegen: &C99CodeGenerator, struct_decl: &ASTNode) i32 {
    if struct_decl == null || struct_decl.type != ASTNodeType.AST_STRUCT_DECL {
        return -1;
    }
    
    const struct_name: &byte = get_safe_c_identifier(codegen, struct_decl.struct_decl_name);
    if struct_name == null {
        return -1;
    }
    
    // 如果已定义，跳过
    if is_struct_defined(codegen, struct_name) != 0 {
        return 0;
    }
    
    // 先生成字段依赖的值类型结构体（保证完整类型在 C 中可用）
    emit_struct_deps_for_struct(codegen, struct_decl);
    
    // 为含 @frame(...) 的字段生成 struct uya_async_xxx; 前向声明
    const field_count_fwd: i32 = struct_decl.struct_decl_field_count;
    var fi_fwd: i32 = 0;
    while fi_fwd < field_count_fwd {
        const field_fwd: &ASTNode = struct_decl.struct_decl_fields[fi_fwd];
        if field_fwd != null && field_fwd.type == ASTNodeType.AST_VAR_DECL && field_fwd.var_decl_type != null {
            c99_emit_async_frame_forward_for_type(codegen, field_fwd.var_decl_type);
            ensure_value_type_deps_emitted(codegen, field_fwd.var_decl_type);
        }
        fi_fwd = fi_fwd + 1;
    }
    
    // 添加结构体定义标记
    add_struct_definition(codegen, struct_name);
    
    // 输出结构体定义
    c99_emit_indent(codegen);
    fprintf(codegen.emit_stream as *void, "struct %s {\n" as *byte, struct_name as *byte);
    codegen.indent_level = codegen.indent_level + 1;
    
    // 生成字段
    const field_count: i32 = struct_decl.struct_decl_field_count;
    
    // 如果是空结构体，添加一个占位符字段以确保大小为 1（符合 Uya 规范）
    if field_count == 0 {
        c99_emit_indent(codegen);
        fputs("char _empty;\n" as *byte, codegen.emit_stream as *void);
    } else {
        var i: i32 = 0;
        while i < field_count {
            const field: &ASTNode = struct_decl.struct_decl_fields[i];
            if field == null || field.type != ASTNodeType.AST_VAR_DECL {
                return -1;
            }
            
            const field_name: &byte = get_safe_c_identifier(codegen, field.var_decl_name);
            const field_type: &ASTNode = field.var_decl_type;
            
            if field_name == null || field_type == null {
                return -1;
            }
            
            // 检查是否为数组类型
            if field_type.type == ASTNodeType.AST_TYPE_ARRAY {
                const element_type: &ASTNode = field_type.type_array_element_type;
                const size_expr: &ASTNode = field_type.type_array_size_expr;
                const elem_type_c: &byte = c99_type_to_c(codegen, element_type);
                
                // 评估数组大小
                var array_size: i32 = -1;
                if size_expr != null {
                    array_size = eval_const_expr(codegen, size_expr);
                    if array_size <= 0 {
                        array_size = 1;  // 占位符
                    }
                } else {
                    array_size = 1;  // 占位符
                }
                
                c99_emit_indent(codegen);
                fprintf(codegen.emit_stream as *void, "%s %s[%d];\n" as *byte, elem_type_c as *byte, field_name as *byte, array_size);
            } else {
                const field_type_c: &byte = c99_type_to_c(codegen, field_type);
                c99_emit_indent(codegen);
                fprintf(codegen.emit_stream as *void, "%s %s;\n" as *byte, field_type_c as *byte, field_name as *byte);
            }
            
            i = i + 1;
        }
    }
    
    codegen.indent_level = codegen.indent_level - 1;
    c99_emit_indent(codegen);
    fputs("};\n" as *byte, codegen.emit_stream as *void);
    
    // 标记为已定义
    mark_struct_defined(codegen, struct_name);
    return 0;
}

// 检查结构体是否是泛型结构体（有类型参数）
fn is_generic_struct_c99(struct_decl: &ASTNode) i32 {
    if struct_decl == null || struct_decl.type != ASTNodeType.AST_STRUCT_DECL {
        return 0;
    }
    if struct_decl.struct_decl_type_param_count > 0 {
        return 1;
    }
    return 0;
}

// 检查联合体是否是泛型联合体（有类型参数）
fn is_generic_union_c99(union_decl: &ASTNode) i32 {
    if union_decl == null || union_decl.type != ASTNodeType.AST_UNION_DECL {
        return 0;
    }
    if union_decl.union_decl_type_param_count > 0 {
        return 1;
    }
    return 0;
}

// 检查单态化类型参数是否包含未解析的类型参数
// 例如：Container<T> 中 T 还是类型参数，而不是具体类型（如 i32）
fn has_unresolved_mono_type_args(generic_decl: &ASTNode, type_args: & & ASTNode, type_arg_count: i32) i32 {
    if generic_decl == null || type_args == null || type_arg_count <= 0 {
        return 0;
    }
    
    var type_params: &TypeParam = null;
    var type_param_count: i32 = 0;
    
    if generic_decl.type == ASTNodeType.AST_STRUCT_DECL {
        type_params = generic_decl.struct_decl_type_params;
        type_param_count = generic_decl.struct_decl_type_param_count;
    } else if generic_decl.type == ASTNodeType.AST_INTERFACE_DECL {
        type_params = generic_decl.interface_decl_type_params;
        type_param_count = generic_decl.interface_decl_type_param_count;
    } else if generic_decl.type == ASTNodeType.AST_FN_DECL {
        type_params = generic_decl.fn_decl_type_params;
        type_param_count = generic_decl.fn_decl_type_param_count;
    } else if generic_decl.type == ASTNodeType.AST_UNION_DECL {
        type_params = generic_decl.union_decl_type_params;
        type_param_count = generic_decl.union_decl_type_param_count;
    }
    
    if type_params == null || type_param_count == 0 {
        return 0;
    }
    
    var i: i32 = 0;
    while i < type_arg_count {
        const original_arg: &ASTNode = type_args[i];
        var arg: &ASTNode = original_arg;
        var allow_err_void_mono: i32 = 0;
        // 递归剥离外层包装：!T / ptr T
        if arg != null && arg.type == ASTNodeType.AST_TYPE_ERROR_UNION {
            if arg.type_error_union_payload_type != null &&
                arg.type_error_union_payload_type.type == ASTNodeType.AST_TYPE_NAMED &&
                arg.type_error_union_payload_type.type_named_name != null &&
                strcmp(arg.type_error_union_payload_type.type_named_name as *byte, "void" as *byte) == 0 {
                // Future<!void>/Poll<!void> 这类实例是有效单态；不能在剥离后把 payload `void` 误判成“未解析实参”。
                allow_err_void_mono = 1;
            }
            arg = arg.type_error_union_payload_type;
        }
        if arg != null && arg.type == ASTNodeType.AST_TYPE_POINTER {
            arg = arg.type_pointer_pointed_type;
        }
        if arg != null && arg.type == ASTNodeType.AST_TYPE_NAMED && arg.type_named_name != null {
            const name: &byte = arg.type_named_name;
            if strcmp(name as *byte, "void" as *byte) == 0 {
                if allow_err_void_mono == 0 {
                    return 1;  // plain void 仍不作为有效单态化实参
                }
                i = i + 1;
                continue;
            }
            var j: i32 = 0;
            while j < type_param_count && j < 64 {
                if type_params != null {
                    const tp_name: &byte = type_params[j].name;
                    if tp_name != null && strcmp(tp_name as *byte, name as *byte) == 0 {
                        return 1;  // 类型实参是未解析的类型参数
                    }
                }
                j = j + 1;
            }
        }
        i = i + 1;
    }
    return 0;
}

// 辅助函数：将类型参数追加到后缀字符串中（递归处理嵌套泛型）
fn append_type_arg_suffix(codegen: &C99CodeGenerator, type_arg: &ASTNode, 
                          suffix: &byte, suffix_len: i32, max_len: i32) i32 {
    if type_arg == null || suffix_len >= max_len - 1 {
        return suffix_len;
    }
    
    var result_len: i32 = suffix_len;
    
    if type_arg.type == ASTNodeType.AST_TYPE_NAMED && type_arg.type_named_name != null {
        var type_name: &byte = type_arg.type_named_name;
        
        // 在单态化上下文中替换类型参数（如 T → i32）
        // 先函数/方法形参，再结构体/联合体单态形参（与 substitute_type_arg 一致；避免残留 Future vtable 的 struct_type_* 把 T 解成 !i32，单态名成 AsyncComputeFuture_err_i32）。
        // c99_type_to_c_uncached 命名类型「裸 T」仍先 struct 再 current，用于 Poll<!T> 等字段；后缀拼接走本函数，二者分工。
        var resolved_type: &ASTNode = type_arg;
        var found: i32 = 0;
        
        if codegen.current_type_params != null && codegen.current_type_param_count > 0 {
            var tp_idx: i32 = 0;
            while tp_idx < codegen.current_type_param_count && tp_idx < codegen.current_type_arg_count {
                if codegen.current_type_params[tp_idx].name != null &&
                    strcmp(codegen.current_type_params[tp_idx].name as *byte, type_name as *byte) == 0 {
                    if codegen.current_type_args != null && codegen.current_type_args[tp_idx] != null {
                        resolved_type = codegen.current_type_args[tp_idx];
                        if resolved_type.type == ASTNodeType.AST_TYPE_NAMED &&
                           resolved_type.type_named_name != null {
                            type_name = resolved_type.type_named_name;
                        }
                        found = 1;
                    }
                    break;
                }
                tp_idx = tp_idx + 1;
            }
        }
        
        if found == 0 && codegen.struct_type_params != null && codegen.struct_type_param_count > 0 {
            var sp_idx: i32 = 0;
            while sp_idx < codegen.struct_type_param_count && sp_idx < codegen.struct_type_arg_count {
                if codegen.struct_type_params[sp_idx].name != null &&
                    strcmp(codegen.struct_type_params[sp_idx].name as *byte, type_name as *byte) == 0 {
                    if codegen.struct_type_args != null && codegen.struct_type_args[sp_idx] != null {
                        resolved_type = codegen.struct_type_args[sp_idx];
                        found = 1;
                        if resolved_type.type == ASTNodeType.AST_TYPE_NAMED &&
                           resolved_type.type_named_name != null {
                            type_name = resolved_type.type_named_name;
                        }
                    }
                    break;
                }
                sp_idx = sp_idx + 1;
            }
        }
        
        // 添加基础类型名
        // 若解析到的类型不是命名类型（如 !i32），则递归处理解析后的类型本身
        if found != 0 && resolved_type != null && resolved_type.type != ASTNodeType.AST_TYPE_NAMED {
            return append_type_arg_suffix(codegen, resolved_type, suffix, result_len, max_len);
        }

        var j: i32 = 0;
        while type_name[j] != 0 && result_len < max_len - 1 {
            suffix[result_len] = type_name[j];
            result_len = result_len + 1;
            j = j + 1;
        }
        
        // 检查是否有嵌套类型参数（如 Pair<i32, i32>）
        const actual_type: &ASTNode = resolved_type;
        if actual_type.type == ASTNodeType.AST_TYPE_NAMED &&
           actual_type.type_named_type_arg_count > 0 &&
           actual_type.type_named_type_args != null {
            // 递归处理嵌套类型参数
            var k: i32 = 0;
            while k < actual_type.type_named_type_arg_count {
                if result_len < max_len - 1 {
                    suffix[result_len] = 95 as byte;  // '_'
                    result_len = result_len + 1;
                }
                result_len = append_type_arg_suffix(codegen,
                    actual_type.type_named_type_args[k],
                    suffix, result_len, max_len);
                k = k + 1;
            }
        }
    } else if type_arg.type == ASTNodeType.AST_TYPE_POINTER {
        // 指针类型：ptr_T
        const ptr_prefix: &byte = "ptr_";
        var k: i32 = 0;
        while ptr_prefix[k] != 0 && result_len < max_len - 1 {
            suffix[result_len] = ptr_prefix[k];
            result_len = result_len + 1;
            k = k + 1;
        }
        const pointed: &ASTNode = type_arg.type_pointer_pointed_type;
        result_len = append_type_arg_suffix(codegen, pointed, suffix, result_len, max_len);
    } else if type_arg.type == ASTNodeType.AST_TYPE_ERROR_UNION {
        // 错误联合类型：err_T
        const err_prefix: &byte = "err_";
        var k: i32 = 0;
        while err_prefix[k] != 0 && result_len < max_len - 1 {
            suffix[result_len] = err_prefix[k];
            result_len = result_len + 1;
            k = k + 1;
        }
        const payload: &ASTNode = type_arg.type_error_union_payload_type;
        result_len = append_type_arg_suffix(codegen, payload, suffix, result_len, max_len);
    }
    
    return result_len;
}

fn normalize_redundant_err_suffix(suffix: &byte) void {
    if suffix == null {
        return;
    }
    var read_i: i32 = 0;
    var write_i: i32 = 0;
    while suffix[read_i] != 0 {
        if suffix[read_i] == 101 as byte &&
            suffix[read_i + 1] == 114 as byte &&
            suffix[read_i + 2] == 114 as byte &&
            suffix[read_i + 3] == 95 as byte {
            suffix[write_i] = 101 as byte;
            suffix[write_i + 1] = 114 as byte;
            suffix[write_i + 2] = 114 as byte;
            suffix[write_i + 3] = 95 as byte;
            write_i = write_i + 4;
            read_i = read_i + 4;
            while suffix[read_i] == 101 as byte &&
                suffix[read_i + 1] == 114 as byte &&
                suffix[read_i + 2] == 114 as byte &&
                suffix[read_i + 3] == 95 as byte {
                read_i = read_i + 4;
            }
            continue;
        }
        suffix[write_i] = suffix[read_i];
        write_i = write_i + 1;
        read_i = read_i + 1;
    }
    suffix[write_i] = 0;
}

// 获取单态化结构体名称
// 例如：Pair<i32, i64> -> Pair_i32_i64
// 嵌套泛型：Box<Pair<i32, i32>> -> Box_Pair_i32_i32
fn get_mono_struct_name(codegen: &C99CodeGenerator, generic_name: &byte, type_args: & &ASTNode, type_arg_count: i32) &byte {
    if codegen == null || generic_name == null || type_args == null || type_arg_count <= 0 {
        return generic_name;
    }
    
    // 构建后缀
    var suffix: [byte: C99_SUFFIX_BUF_SIZE] = [0: C99_SUFFIX_BUF_SIZE];
    var suffix_len: i32 = 0;

    var i: i32 = 0;
    while i < type_arg_count {
        if i > 0 {
            if suffix_len >= 0 && suffix_len < C99_SUFFIX_BUF_SIZE {
                suffix[suffix_len] = 95 as byte;  // '_'
            }
            suffix_len = suffix_len + 1;
        }
        suffix_len = append_type_arg_suffix(codegen, type_args[i], &suffix[0], suffix_len, C99_SUFFIX_BUF_SIZE);
        i = i + 1;
    }
    if suffix_len >= 0 && suffix_len < C99_SUFFIX_BUF_SIZE {
        suffix[suffix_len] = 0;
    }
    normalize_redundant_err_suffix(&suffix[0] as &byte);
    
    // 分配并构建完整名称
    const safe_name: &byte = get_safe_c_identifier(codegen, generic_name);
    const name_len: i32 = (strlen(safe_name as *byte) as i32) + 1 + suffix_len + 1;
    const mono_name: &byte = compiler_arena_alloc(codegen.arena, name_len as usize) as &byte;
    if mono_name == null {
        return generic_name;
    }
    snprintf(mono_name as *byte, name_len, "%s_%s" as *byte, safe_name as *byte, suffix as *byte);
    
    return mono_name;
}

// 获取单态化联合体名称（与 get_mono_struct_name 规则一致，如 Foo<i32> -> Foo_i32）
fn get_mono_union_name(codegen: &C99CodeGenerator, generic_name: &byte, type_args: & &ASTNode, type_arg_count: i32) &byte {
    if codegen == null || generic_name == null || type_args == null || type_arg_count <= 0 {
        return generic_name;
    }
    var suffix: [byte: C99_SUFFIX_BUF_SIZE] = [0: C99_SUFFIX_BUF_SIZE];
    var suffix_len: i32 = 0;
    var i: i32 = 0;
    while i < type_arg_count {
        if i > 0 {
            if suffix_len >= 0 && suffix_len < C99_SUFFIX_BUF_SIZE {
                suffix[suffix_len] = 95 as byte;
            }
            suffix_len = suffix_len + 1;
        }
        suffix_len = append_type_arg_suffix(codegen, type_args[i], &suffix[0], suffix_len, C99_SUFFIX_BUF_SIZE);
        i = i + 1;
    }
    if suffix_len >= 0 && suffix_len < C99_SUFFIX_BUF_SIZE {
        suffix[suffix_len] = 0;
    }
    normalize_redundant_err_suffix(&suffix[0] as &byte);
    const safe_name: &byte = get_safe_c_identifier(codegen, generic_name);
    const name_len: i32 = (strlen(safe_name as *byte) as i32) + 1 + suffix_len + 1;
    const mono_name: &byte = compiler_arena_alloc(codegen.arena, name_len as usize) as &byte;
    if mono_name == null {
        return generic_name;
    }
    snprintf(mono_name as *byte, name_len, "%s_%s" as *byte, safe_name as *byte, suffix as *byte);
    return mono_name;
}

fn c99_codegen_ensure_mono_struct(codegen: &C99CodeGenerator, generic_name: &byte,
    type_args: & &ASTNode, type_arg_count: i32) void {
    if codegen == null || generic_name == null || type_args == null || type_arg_count <= 0 {
        return;
    }
    const resolved_args: & & ASTNode = compiler_arena_alloc(codegen.arena,
        (@size_of(&ASTNode) * (type_arg_count as usize))) as & & ASTNode;
    if resolved_args == null {
        return;
    }
    var ai: i32 = 0;
    while ai < type_arg_count {
        resolved_args[ai] = substitute_type_arg(codegen, type_args[ai]);
        ai = ai + 1;
    }
    const wanted_mono_name: &byte = get_mono_struct_name(codegen, generic_name, resolved_args, type_arg_count);
    var i: i32 = 0;
    while i < codegen.mono_instance_count {
        const inst: MonoInstanceCodegen = codegen.mono_instances[i];
        if inst.is_function == 0 && inst.generic_name != null &&
            strcmp(inst.generic_name as *byte, generic_name as *byte) == 0 &&
            inst.type_arg_count == type_arg_count && inst.type_args != null {
            const inst_mono_name: &byte = get_mono_struct_name(codegen, inst.generic_name,
                inst.type_args, inst.type_arg_count);
            if inst_mono_name != null && wanted_mono_name != null &&
                strcmp(inst_mono_name as *byte, wanted_mono_name as *byte) == 0 {
                return;
            }
        }
        i = i + 1;
    }
    if codegen.mono_instance_count >= C99_MAX_MONO_INSTANCES {
        return;
    }
    const idx_u: usize = codegen.mono_instance_count as usize;
    if idx_u >= C99_MAX_MONO_INSTANCES as usize {
        return;
    }
    codegen.mono_instances[idx_u].generic_name = generic_name;
    codegen.mono_instances[idx_u].is_function = 0;
    codegen.mono_instances[idx_u].type_arg_count = type_arg_count;
    codegen.mono_instances[idx_u].type_args = resolved_args;
    codegen.mono_instance_count = codegen.mono_instance_count + 1;
}

// 从已去掉 leading `const ` 的 C 类型串提取首个 typedef 标识符（遇空格、制表、* 结束）。
// 若以 `struct ` 开头则返回 0，由调用方走 struct 前缀分支。
fn c99_extract_first_typedef_ident(type_c: &byte, out: &byte, out_max: i32) i32 {
    if type_c == null || out == null || out_max < 2 {
        return 0;
    }
    var p: *byte = type_c as *byte;
    while p[0] == 32 || p[0] == 9 {
        p = p + 1;
    }
    if strncmp(p as *byte, "struct " as *byte, 7) == 0 {
        return 0;
    }
    var q: *byte = p;
    while q[0] != 0 && q[0] != 32 && q[0] != 9 && q[0] != 42 {
        q = q + 1;
    }
    const n: i32 = (q - p) as i32;
    if n <= 0 || n >= out_max {
        return 0;
    }
    var i: i32 = 0;
    while i < n {
        out[i] = p[i];
        i = i + 1;
    }
    out[n] = 0;
    return n;
}

// typedef（如 AsyncComputeI32Future）→ 别名目标为泛型 struct 时，返回 arena 分配的单态 struct 名；否则 null。
fn resolve_typedef_to_mono_struct_name_if_generic(codegen: &C99CodeGenerator, type_c_strip_const: &byte) &byte {
    if codegen == null || type_c_strip_const == null || codegen.program_node == null || codegen.arena == null {
        return null;
    }
    var key: [byte: C99_GENERIC_NAME_BUF_SIZE] = [];
    const kl: i32 = c99_extract_first_typedef_ident(type_c_strip_const, &key[0] as &byte, C99_GENERIC_NAME_BUF_SIZE);
    if kl <= 0 {
        return null;
    }
    const alias_decl: &ASTNode = find_type_alias_from_program(codegen.program_node, &key[0] as &byte);
    if alias_decl == null || alias_decl.type != ASTNodeType.AST_TYPE_ALIAS ||
        alias_decl.type_alias_target_type == null {
        return null;
    }
    const targ: &ASTNode = alias_decl.type_alias_target_type;
    if targ.type != ASTNodeType.AST_TYPE_NAMED || targ.type_named_name == null {
        return null;
    }
    const base_sn: &byte = targ.type_named_name;
    const decl_s: &ASTNode = find_struct_decl_c99(codegen, base_sn);
    if decl_s == null || decl_s.type != ASTNodeType.AST_STRUCT_DECL ||
        is_generic_struct_c99(decl_s) == 0 ||
        targ.type_named_type_arg_count <= 0 || targ.type_named_type_args == null {
        return null;
    }
    const ms: &byte = get_mono_struct_name(codegen, base_sn,
        targ.type_named_type_args, targ.type_named_type_arg_count);
    if ms == null {
        return null;
    }
    const pos_ms_tmp: !i32 = strlen(ms as *byte) as! i32;
    const pos_ms: i32 = pos_ms_tmp.value;
    if pos_ms <= 0 || pos_ms >= C99_GENERIC_NAME_BUF_SIZE {
        return null;
    }
    const copy_ms: &byte = compiler_arena_alloc(codegen.arena, (pos_ms + 1) as usize) as &byte;
    if copy_ms == null {
        return null;
    }
    memcpy(copy_ms as *void, ms as *void, pos_ms as usize);
    if pos_ms >= 0 && pos_ms < 1000000 {
        copy_ms[pos_ms] = 0;
    }
    return copy_ms;
}

// 辅助函数：在程序 AST 中查找结构体声明
fn find_struct_decl_in_program_c99(codegen: &C99CodeGenerator, struct_name: &byte) &ASTNode {
    if codegen.program_node == null || codegen.program_node.type != ASTNodeType.AST_PROGRAM {
        return null;
    }
    const decls: & &ASTNode = codegen.program_node.program_decls;
    const decl_count: i32 = codegen.program_node.program_decl_count;
    var i: i32 = 0;
    while i < decl_count {
        const decl: &ASTNode = decls[i];
        if decl != null && decl.type == ASTNodeType.AST_STRUCT_DECL && 
           decl.struct_decl_name != null &&
           strcmp(decl.struct_decl_name as *byte, struct_name as *byte) == 0 {
            return decl;
        }
        i = i + 1;
    }
    return null;
}

// 辅助函数：先生成嵌套泛型依赖的结构体（递归处理）
fn ensure_nested_generic_struct_defined(codegen: &C99CodeGenerator, type_node: &ASTNode) void {
    if type_node == null || type_node.type != ASTNodeType.AST_TYPE_NAMED {
        return;
    }
    
    var type_name: &byte = type_node.type_named_name;
    if type_name == null {
        return;
    }
    
    // 检查是否是类型参数（如 T），如果是，替换为实际类型
    var resolved_type: &ASTNode = type_node;
    if codegen.current_type_params != null && codegen.current_type_param_count > 0 {
        var tp_idx: i32 = 0;
        while tp_idx < codegen.current_type_param_count && tp_idx < codegen.current_type_arg_count {
            if codegen.current_type_params[tp_idx].name != null &&
               strcmp(codegen.current_type_params[tp_idx].name as *byte, type_name as *byte) == 0 {
                if codegen.current_type_args != null && codegen.current_type_args[tp_idx] != null {
                    resolved_type = codegen.current_type_args[tp_idx];
                    if resolved_type.type_named_name != null {
                        type_name = resolved_type.type_named_name;
                    }
                }
                break;
            }
            tp_idx = tp_idx + 1;
        }
    }
    
    // 如果这个类型有类型参数（是泛型实例化），需要先生成它
    if resolved_type.type == ASTNodeType.AST_TYPE_NAMED &&
       resolved_type.type_named_type_arg_count > 0 &&
       resolved_type.type_named_type_args != null {
        // 递归处理嵌套的类型参数
        var k: i32 = 0;
        while k < resolved_type.type_named_type_arg_count {
            ensure_nested_generic_struct_defined(codegen, resolved_type.type_named_type_args[k]);
            k = k + 1;
        }
        
        // 找到泛型结构体的声明
        const nested_struct_decl: &ASTNode = find_struct_decl_in_program_c99(codegen, resolved_type.type_named_name);
        if nested_struct_decl != null && is_generic_struct_c99(nested_struct_decl) != 0 {
            // 递归生成嵌套的泛型结构体
            gen_mono_struct_definition(codegen, nested_struct_decl,
                resolved_type.type_named_type_args,
                resolved_type.type_named_type_arg_count);
            c99_emit_newline(codegen);
        } else {
            const nested_union_decl: &ASTNode = find_union_decl_c99(codegen, resolved_type.type_named_name);
            if nested_union_decl != null && is_generic_union_c99(nested_union_decl) != 0 &&
                resolved_type.type_named_type_arg_count > 0 && resolved_type.type_named_type_args != null {
                const mono_union_name: &byte = get_mono_union_name(codegen, resolved_type.type_named_name,
                    resolved_type.type_named_type_args,
                    resolved_type.type_named_type_arg_count);
                if mono_union_name != null {
                    var tag_buf: [byte: 128] = [0: 128];
                    var tlen: i32 = snprintf(&tag_buf[0] as *byte, 128, "uya_tagged_%s" as *byte, get_safe_c_identifier(codegen, mono_union_name) as *byte);
                    if tlen > 0 && tlen < 128 && is_struct_defined(codegen, &tag_buf[0] as &byte) == 0 {
                        gen_mono_union_definition(codegen, nested_union_decl,
                            resolved_type.type_named_type_args,
                            resolved_type.type_named_type_arg_count);
                        c99_emit_newline(codegen);
                    }
                }
            }
        }
    }
}

fn ensure_value_type_deps_emitted(codegen: &C99CodeGenerator, type_node: &ASTNode) void {
    if codegen == null || type_node == null {
        return;
    }
    if type_node.type == ASTNodeType.AST_TYPE_POINTER || type_node.type == ASTNodeType.AST_TYPE_SLICE {
        return;
    }
    if type_node.type == ASTNodeType.AST_TYPE_ARRAY && type_node.type_array_element_type != null {
        ensure_value_type_deps_emitted(codegen, type_node.type_array_element_type);
        return;
    }
    if type_node.type == ASTNodeType.AST_TYPE_TUPLE && type_node.type_tuple_element_types != null {
        var ti: i32 = 0;
        while ti < type_node.type_tuple_element_count {
            ensure_value_type_deps_emitted(codegen, type_node.type_tuple_element_types[ti]);
            ti = ti + 1;
        }
        return;
    }
    if type_node.type == ASTNodeType.AST_TYPE_ATOMIC && type_node.type_atomic_inner_type != null {
        ensure_value_type_deps_emitted(codegen, type_node.type_atomic_inner_type);
        return;
    }
    if type_node.type == ASTNodeType.AST_TYPE_ERROR_UNION && type_node.type_error_union_payload_type != null {
        ensure_value_type_deps_emitted(codegen, type_node.type_error_union_payload_type);
        return;
    }
    if type_node.type != ASTNodeType.AST_TYPE_NAMED || type_node.type_named_name == null {
        return;
    }
    if type_node.type_named_type_arg_count > 0 && type_node.type_named_type_args != null {
        var ai: i32 = 0;
        while ai < type_node.type_named_type_arg_count {
            ensure_value_type_deps_emitted(codegen, type_node.type_named_type_args[ai]);
            ai = ai + 1;
        }
        ensure_nested_generic_struct_defined(codegen, type_node);
    }
    ensure_union_emitted_for_type_node(codegen, type_node);
    ensure_struct_emitted_for_type_node(codegen, type_node);
}

fn substitute_type_arg_explicit(codegen: &C99CodeGenerator, type_node: &ASTNode,
    type_params: &TypeParam, type_args: & &ASTNode, type_arg_count: i32) &ASTNode {
    if codegen == null || type_node == null {
        return type_node;
    }
    if type_node.type == ASTNodeType.AST_TYPE_NAMED && type_node.type_named_name != null {
        const name: &byte = type_node.type_named_name;
        var i: i32 = 0;
        while i < type_arg_count {
            if type_params != null && type_params[i].name != null &&
                strcmp(type_params[i].name as *byte, name as *byte) == 0 {
                if type_args != null && type_args[i] != null {
                    return type_args[i];
                }
            }
            i = i + 1;
        }
        if type_node.type_named_type_arg_count > 0 && type_node.type_named_type_args != null {
            const arg_count: i32 = type_node.type_named_type_arg_count;
            const args: & & ASTNode = compiler_arena_alloc(codegen.arena, (@size_of(&ASTNode) * arg_count) as usize) as & & ASTNode;
            var changed: i32 = 0;
            if args != null {
                i = 0;
                while i < arg_count {
                    const substituted_arg: &ASTNode = substitute_type_arg_explicit(codegen,
                        type_node.type_named_type_args[i], type_params, type_args, type_arg_count);
                    args[i] = substituted_arg;
                    if substituted_arg != type_node.type_named_type_args[i] {
                        changed = 1;
                    }
                    i = i + 1;
                }
                if changed != 0 {
                    const new_named: &ASTNode = ast_new_node(ASTNodeType.AST_TYPE_NAMED, type_node.line, type_node.column, codegen.arena, type_node.filename);
                    if new_named != null {
                        new_named.type_named_name = type_node.type_named_name;
                        new_named.type_named_type_args = args;
                        new_named.type_named_type_arg_count = arg_count;
                        return new_named;
                    }
                }
            }
        }
    }
    if type_node.type == ASTNodeType.AST_TYPE_POINTER && type_node.type_pointer_pointed_type != null {
        const pointed: &ASTNode = substitute_type_arg_explicit(codegen, type_node.type_pointer_pointed_type, type_params, type_args, type_arg_count);
        if pointed != type_node.type_pointer_pointed_type {
            const new_ptr: &ASTNode = ast_new_node(ASTNodeType.AST_TYPE_POINTER, type_node.line, type_node.column, codegen.arena, type_node.filename);
            if new_ptr != null {
                new_ptr.type_pointer_pointed_type = pointed;
                new_ptr.type_pointer_is_ffi_pointer = type_node.type_pointer_is_ffi_pointer;
                new_ptr.type_pointer_is_const = type_node.type_pointer_is_const;
                return new_ptr;
            }
        }
    }
    if type_node.type == ASTNodeType.AST_TYPE_ARRAY && type_node.type_array_element_type != null {
        const elem: &ASTNode = substitute_type_arg_explicit(codegen, type_node.type_array_element_type, type_params, type_args, type_arg_count);
        if elem != type_node.type_array_element_type {
            const new_arr: &ASTNode = ast_new_node(ASTNodeType.AST_TYPE_ARRAY, type_node.line, type_node.column, codegen.arena, type_node.filename);
            if new_arr != null {
                new_arr.type_array_element_type = elem;
                new_arr.type_array_size_expr = type_node.type_array_size_expr;
                return new_arr;
            }
        }
    }
    if type_node.type == ASTNodeType.AST_TYPE_SLICE && type_node.type_slice_element_type != null {
        const elem: &ASTNode = substitute_type_arg_explicit(codegen, type_node.type_slice_element_type, type_params, type_args, type_arg_count);
        if elem != type_node.type_slice_element_type {
            const new_slice: &ASTNode = ast_new_node(ASTNodeType.AST_TYPE_SLICE, type_node.line, type_node.column, codegen.arena, type_node.filename);
            if new_slice != null {
                new_slice.type_slice_element_type = elem;
                new_slice.type_slice_size_expr = type_node.type_slice_size_expr;
                new_slice.type_slice_element_const = type_node.type_slice_element_const;
                return new_slice;
            }
        }
    }
    if type_node.type == ASTNodeType.AST_TYPE_ERROR_UNION && type_node.type_error_union_payload_type != null {
        const payload: &ASTNode = substitute_type_arg_explicit(codegen, type_node.type_error_union_payload_type, type_params, type_args, type_arg_count);
        if payload != type_node.type_error_union_payload_type {
            const new_err: &ASTNode = ast_new_node(ASTNodeType.AST_TYPE_ERROR_UNION, type_node.line, type_node.column, codegen.arena, type_node.filename);
            if new_err != null {
                new_err.type_error_union_payload_type = payload;
                return new_err;
            }
        }
    }
    return type_node;
}

// 生成单态化结构体定义
fn gen_mono_struct_definition(codegen: &C99CodeGenerator, struct_decl: &ASTNode,
                               type_args: & &ASTNode, type_arg_count: i32) i32 {
    if codegen == null || struct_decl == null || struct_decl.type != ASTNodeType.AST_STRUCT_DECL {
        return -1;
    }
    
    const orig_name: &byte = struct_decl.struct_decl_name;
    const subst_args: & & ASTNode = compiler_arena_alloc(codegen.arena, (@size_of(&ASTNode) * type_arg_count) as usize) as & & ASTNode;
    if subst_args == null {
        return -1;
    }
    var subst_i: i32 = 0;
    while subst_i < type_arg_count {
        if type_args[subst_i] != null {
            subst_args[subst_i] = substitute_type_arg(codegen, type_args[subst_i]);
        } else {
            subst_args[subst_i] = null;
        }
        subst_i = subst_i + 1;
    }
    if has_unresolved_mono_type_args(struct_decl, subst_args, type_arg_count) != 0 {
        return 0;
    }
    const mono_name: &byte = get_mono_struct_name(codegen, orig_name, subst_args, type_arg_count);
    
    // 如果已定义，跳过
    if is_struct_defined(codegen, mono_name) != 0 {
        return 0;
    }
    
    // 设置单态化上下文
    const saved_type_params: &TypeParam = codegen.current_type_params;
    const saved_type_param_count: i32 = codegen.current_type_param_count;
    const saved_type_args: & &ASTNode = codegen.current_type_args;
    const saved_type_arg_count: i32 = codegen.current_type_arg_count;
    const saved_struct_type_params: &TypeParam = codegen.struct_type_params;
    const saved_struct_type_param_count: i32 = codegen.struct_type_param_count;
    const saved_struct_type_args: & &ASTNode = codegen.struct_type_args;
    const saved_struct_type_arg_count: i32 = codegen.struct_type_arg_count;
    
    codegen.current_type_params = struct_decl.struct_decl_type_params;
    codegen.current_type_param_count = struct_decl.struct_decl_type_param_count;
    codegen.current_type_args = subst_args;
    codegen.current_type_arg_count = type_arg_count;
    // c99_type_to_c 对裸类型参数优先读取 struct_type_*；若这里沿用外层残留上下文，
    // Future<T> 这类单态字段里的 Poll<T> 会把 T 解析到错误的外层实例，生成 err_err_... 名称。
    codegen.struct_type_params = struct_decl.struct_decl_type_params;
    codegen.struct_type_param_count = struct_decl.struct_decl_type_param_count;
    codegen.struct_type_args = subst_args;
    codegen.struct_type_arg_count = type_arg_count;

    // 与普通结构体定义保持一致：单态化后的值字段仍可能依赖非指针结构体
    // （例如 TaskQueueSlot<i32> 的 Waker 字段）。若不先发射依赖，types 头里会出现
    // 不完整类型字段，镜像 split-C 会直接编译失败。
    emit_struct_deps_for_mono_struct(codegen, struct_decl, subst_args, type_arg_count);
    
    // 先生成依赖的值类型定义（含泛型 union / 普通 union / 结构体）
    const field_count: i32 = struct_decl.struct_decl_field_count;
    var fi: i32 = 0;
    while fi < field_count {
        const field: &ASTNode = struct_decl.struct_decl_fields[fi];
        if field != null && field.type == ASTNodeType.AST_VAR_DECL && field.var_decl_type != null {
            const resolved_field_type: &ASTNode = substitute_type_arg_explicit(codegen, field.var_decl_type,
                struct_decl.struct_decl_type_params, subst_args, type_arg_count);
            ensure_value_type_deps_emitted(codegen, resolved_field_type);
        }
        fi = fi + 1;
    }
    
    // 再次检查是否已定义（可能在处理依赖时被定义）
    if is_struct_defined(codegen, mono_name) != 0 {
        codegen.current_type_params = saved_type_params;
        codegen.current_type_param_count = saved_type_param_count;
        codegen.current_type_args = saved_type_args;
        codegen.current_type_arg_count = saved_type_arg_count;
        codegen.struct_type_params = saved_struct_type_params;
        codegen.struct_type_param_count = saved_struct_type_param_count;
        codegen.struct_type_args = saved_struct_type_args;
        codegen.struct_type_arg_count = saved_struct_type_arg_count;
        return 0;
    }
    
    // 为含 @frame(...) 的字段生成 struct uya_async_xxx; 前向声明
    var fi_mono_fwd: i32 = 0;
    while fi_mono_fwd < field_count {
        const field_mono_fwd: &ASTNode = struct_decl.struct_decl_fields[fi_mono_fwd];
        if field_mono_fwd != null && field_mono_fwd.type == ASTNodeType.AST_VAR_DECL && field_mono_fwd.var_decl_type != null {
            const resolved_field_type_fwd: &ASTNode = substitute_type_arg_explicit(codegen, field_mono_fwd.var_decl_type,
                struct_decl.struct_decl_type_params, subst_args, type_arg_count);
            c99_emit_async_frame_forward_for_type(codegen, resolved_field_type_fwd);
            ensure_value_type_deps_emitted(codegen, resolved_field_type_fwd);
        }
        fi_mono_fwd = fi_mono_fwd + 1;
    }
    
    // 添加结构体定义标记
    add_struct_definition(codegen, mono_name);
    
    // 输出结构体定义
    fprintf(codegen.emit_stream as *void, "struct %s {\n" as *byte, mono_name as *byte);
    codegen.indent_level = codegen.indent_level + 1;
    
    // 生成字段（field_count 和 fi 已在前面定义）
    if field_count == 0 {
        c99_emit_indent(codegen);
        fputs("char _empty;\n" as *byte, codegen.emit_stream as *void);
    } else {
        fi = 0;
        while fi < field_count {
            const field: &ASTNode = struct_decl.struct_decl_fields[fi];
            if field == null || field.type != ASTNodeType.AST_VAR_DECL {
                codegen.indent_level = codegen.indent_level - 1;
                codegen.current_type_params = saved_type_params;
                codegen.current_type_param_count = saved_type_param_count;
                codegen.current_type_args = saved_type_args;
                codegen.current_type_arg_count = saved_type_arg_count;
                codegen.struct_type_params = saved_struct_type_params;
                codegen.struct_type_param_count = saved_struct_type_param_count;
                codegen.struct_type_args = saved_struct_type_args;
                codegen.struct_type_arg_count = saved_struct_type_arg_count;
                return -1;
            }
            
            const field_name: &byte = get_safe_c_identifier(codegen, field.var_decl_name);
            const field_type: &ASTNode = field.var_decl_type;
            
            if field_name == null || field_type == null {
                codegen.indent_level = codegen.indent_level - 1;
                codegen.current_type_params = saved_type_params;
                codegen.current_type_param_count = saved_type_param_count;
                codegen.current_type_args = saved_type_args;
                codegen.current_type_arg_count = saved_type_arg_count;
                codegen.struct_type_params = saved_struct_type_params;
                codegen.struct_type_param_count = saved_struct_type_param_count;
                codegen.struct_type_args = saved_struct_type_args;
                codegen.struct_type_arg_count = saved_struct_type_arg_count;
                return -1;
            }
            
            var emit_field_type: &ASTNode = field_type;
            const resolved_field_type: &ASTNode = substitute_type_arg_explicit(codegen, field_type,
                struct_decl.struct_decl_type_params, subst_args, type_arg_count);
            if resolved_field_type != null {
                emit_field_type = resolved_field_type;
            }

            if emit_field_type != null && emit_field_type.type == ASTNodeType.AST_TYPE_ARRAY {
                const element_type: &ASTNode = emit_field_type.type_array_element_type;
                const size_expr: &ASTNode = emit_field_type.type_array_size_expr;
                const elem_type_c: &byte = c99_type_to_c(codegen, element_type);
                var array_size: i32 = 1;
                if size_expr != null {
                    array_size = eval_const_expr(codegen, size_expr);
                    if array_size <= 0 {
                        array_size = 1;
                    }
                }
                c99_emit_indent(codegen);
                fprintf(codegen.emit_stream as *void, "%s %s[%d];\n" as *byte, elem_type_c as *byte, field_name as *byte, array_size);
            } else {
                var field_type_c: &byte = null;
                if emit_field_type != null && emit_field_type.type == ASTNodeType.AST_TYPE_NAMED &&
                    emit_field_type.type_named_name != null &&
                    emit_field_type.type_named_type_arg_count > 0 &&
                    emit_field_type.type_named_type_args != null {
                    const generic_name: &byte = emit_field_type.type_named_name;
                    const generic_arg_count: i32 = emit_field_type.type_named_type_arg_count;
                    const generic_args: & & ASTNode = compiler_arena_alloc(codegen.arena, (@size_of(&ASTNode) * generic_arg_count) as usize) as & & ASTNode;
                    if generic_args != null {
                        var gi: i32 = 0;
                        while gi < generic_arg_count {
                            generic_args[gi] = substitute_type_arg_explicit(codegen,
                                emit_field_type.type_named_type_args[gi],
                                struct_decl.struct_decl_type_params, subst_args, type_arg_count);
                            gi = gi + 1;
                        }
                        const iface_decl: &ASTNode = find_interface_decl_c99(codegen, generic_name);
                        if iface_decl != null && iface_decl.interface_decl_type_param_count > 0 {
                            const mono_iface_name: &byte = get_mono_struct_name(codegen, generic_name, generic_args, generic_arg_count);
                            if mono_iface_name != null {
                                const mono_iface_len: i32 = (strlen(mono_iface_name as *byte) as i32) + 24;
                                const mono_iface_buf: &byte = compiler_arena_alloc(codegen.arena, mono_iface_len as usize) as &byte;
                                if mono_iface_buf != null {
                                    snprintf(mono_iface_buf as *byte, mono_iface_len, "struct uya_interface_%s" as *byte, mono_iface_name as *byte);
                                    field_type_c = mono_iface_buf;
                                }
                            }
                        }
                        if field_type_c == null {
                            const generic_union_decl: &ASTNode = find_union_decl_c99(codegen, generic_name);
                            if generic_union_decl != null && is_generic_union_c99(generic_union_decl) != 0 {
                                const mono_union_name: &byte = get_mono_union_name(codegen, generic_name, generic_args, generic_arg_count);
                                if mono_union_name != null {
                                    const mono_union_len: i32 = (strlen(mono_union_name as *byte) as i32) + 24;
                                    const mono_union_buf: &byte = compiler_arena_alloc(codegen.arena, mono_union_len as usize) as &byte;
                                    if mono_union_buf != null {
                                        snprintf(mono_union_buf as *byte, mono_union_len, "struct uya_tagged_%s" as *byte, mono_union_name as *byte);
                                        field_type_c = mono_union_buf;
                                    }
                                }
                            }
                        }
                        if field_type_c == null {
                            const mono_struct_name: &byte = get_mono_struct_name(codegen, generic_name, generic_args, generic_arg_count);
                            if mono_struct_name != null {
                                const mono_struct_len: i32 = (strlen(mono_struct_name as *byte) as i32) + 8;
                                const mono_struct_buf: &byte = compiler_arena_alloc(codegen.arena, mono_struct_len as usize) as &byte;
                                if mono_struct_buf != null {
                                    snprintf(mono_struct_buf as *byte, mono_struct_len, "struct %s" as *byte, mono_struct_name as *byte);
                                    field_type_c = mono_struct_buf;
                                }
                            }
                        }
                    }
                }
                if field_type_c == null {
                    field_type_c = c99_type_to_c(codegen, emit_field_type);
                }
                c99_emit_indent(codegen);
                fprintf(codegen.emit_stream as *void, "%s %s;\n" as *byte, field_type_c as *byte, field_name as *byte);
            }
            fi = fi + 1;
        }
    }
    
    codegen.indent_level = codegen.indent_level - 1;
    fputs("};\n" as *byte, codegen.emit_stream as *void);
    
    // 标记为已定义
    mark_struct_defined(codegen, mono_name);
    
    // 恢复上下文
    codegen.current_type_params = saved_type_params;
    codegen.current_type_param_count = saved_type_param_count;
    codegen.current_type_args = saved_type_args;
    codegen.current_type_arg_count = saved_type_arg_count;
    codegen.struct_type_params = saved_struct_type_params;
    codegen.struct_type_param_count = saved_struct_type_param_count;
    codegen.struct_type_args = saved_struct_type_args;
    codegen.struct_type_arg_count = saved_struct_type_arg_count;
    
    return 0;
}

// 若 type_node 为泛型结构体类型（如 Future<i32>），先输出其单态化定义，供 err_union 等依赖使用
fn ensure_mono_struct_emitted_for_type_node(codegen: &C99CodeGenerator, type_node: &ASTNode) void {
    if codegen == null || type_node == null || type_node.type != ASTNodeType.AST_TYPE_NAMED {
        return;
    }
    if type_node.type_named_name == null || type_node.type_named_type_arg_count <= 0 {
        return;
    }
    const struct_decl: &ASTNode = find_struct_decl_c99(codegen, type_node.type_named_name);
    if struct_decl == null || is_generic_struct_c99(struct_decl) == 0 {
        return;
    }
    if type_node.type_named_type_args == null {
        return;
    }
    const mono_name: &byte = get_mono_struct_name(codegen, type_node.type_named_name,
        type_node.type_named_type_args, type_node.type_named_type_arg_count);
    if is_struct_defined(codegen, mono_name) != 0 {
        return;
    }
    gen_mono_struct_definition(codegen, struct_decl,
        type_node.type_named_type_args, type_node.type_named_type_arg_count);
}

// 确保 type_node 对应的结构体已输出（泛型则单态化，非泛型则直接定义），供 err_union 等依赖使用，避免 incomplete type
fn ensure_struct_emitted_for_type_node(codegen: &C99CodeGenerator, type_node: &ASTNode) void {
    if codegen == null || type_node == null || type_node.type != ASTNodeType.AST_TYPE_NAMED {
        return;
    }
    if type_node.type_named_name == null {
        return;
    }
    if type_node.type_named_type_arg_count > 0 {
        ensure_mono_struct_emitted_for_type_node(codegen, type_node);
        return;
    }
    const struct_name: &byte = type_node.type_named_name;
    const struct_decl: &ASTNode = find_struct_decl_c99(codegen, struct_name);
    if struct_decl == null {
        return;
    }
    if is_generic_struct_c99(struct_decl) != 0 {
        var j: i32 = 0;
        while j < codegen.mono_instance_count {
            if codegen.mono_instances[j].generic_name != null &&
                strcmp(codegen.mono_instances[j].generic_name as *byte, struct_decl.struct_decl_name as *byte) == 0 &&
                codegen.mono_instances[j].is_function == 0 &&
                has_unresolved_mono_type_args(struct_decl,
                    codegen.mono_instances[j].type_args,
                    codegen.mono_instances[j].type_arg_count) == 0 {
                const mono_name: &byte = get_mono_struct_name(codegen, struct_decl.struct_decl_name,
                    codegen.mono_instances[j].type_args, codegen.mono_instances[j].type_arg_count);
                if mono_name != null && strcmp(mono_name as *byte, struct_name as *byte) == 0 {
                    if is_struct_defined(codegen, mono_name) == 0 {
                        gen_mono_struct_definition(codegen, struct_decl,
                            codegen.mono_instances[j].type_args,
                            codegen.mono_instances[j].type_arg_count);
                    }
                    return;
                }
            }
            j = j + 1;
        }
        return;
    }
    const c_name: &byte = get_safe_c_identifier(codegen, struct_name);
    if c_name == null {
        return;
    }
    if is_struct_defined(codegen, c_name) != 0 {
        return;
    }
    gen_struct_definition(codegen, struct_decl);
}

// 确保 type_node 对应的联合体已输出（供 err_union 的 payload 为 union 时使用，避免 incomplete type）
fn ensure_union_emitted_for_type_node(codegen: &C99CodeGenerator, type_node: &ASTNode) void {
    if codegen == null || type_node == null || type_node.type != ASTNodeType.AST_TYPE_NAMED {
        return;
    }
    if type_node.type_named_name == null {
        return;
    }
    const union_decl: &ASTNode = find_union_decl_c99(codegen, type_node.type_named_name);
    if union_decl == null {
        return;
    }
    if type_node.type_named_type_arg_count > 0 && type_node.type_named_type_args != null &&
        is_generic_union_c99(union_decl) != 0 {
        const mono_name: &byte = get_mono_union_name(codegen, type_node.type_named_name,
            type_node.type_named_type_args, type_node.type_named_type_arg_count);
        if mono_name == null {
            return;
        }
        var tag_buf: [byte: 128] = [0: 128];
        const tlen: i32 = snprintf(&tag_buf[0] as *byte, 128, "uya_tagged_%s" as *byte, get_safe_c_identifier(codegen, mono_name) as *byte);
        if tlen > 0 && tlen < 128 && is_struct_defined(codegen, &tag_buf[0] as &byte) == 0 {
            gen_mono_union_definition(codegen, union_decl,
                type_node.type_named_type_args, type_node.type_named_type_arg_count);
        }
        return;
    }
    emit_struct_deps_for_union(codegen, union_decl);
    gen_union_definition(codegen, union_decl);
}
