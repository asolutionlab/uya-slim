// expr.uya - C99 代码生成器表达式模块
// 提供表达式代码生成功能
//
// 注意：需要先包含 internal.uya（包含类型定义和函数声明）
// 由于 Uya Mini 不支持模块系统，这里假设相关类型已经定义

// ===== 常量定义 =====
const FMT_BUF_SIZE: i32 = 64;
const NAME_BUF_SIZE: i32 = 256;
const TEMP_BUF_SIZE: i32 = 256;
const TEMP_BUF_LIMIT: i32 = 255;
const NUM_BUF_SIZE: i32 = 32;
const STRUCT_NAME_BUF_SIZE: i32 = 128;
const SHORT_NAME_BUF_SIZE: i32 = 64;

// ===== 外部函数声明 =====
// C 标准库函数（在 extern_decls.uya 中声明）

// 数组元素是否为聚合（结构体或数组），若是则结构体初始化用 {{0}}，否则用 {0}，避免 -Wbraces / -Wmissing-braces
fn array_element_is_aggregate_c99(codegen: &C99CodeGenerator, array_type: &ASTNode) i32 {
    if codegen == null || array_type == null || array_type.type != ASTNodeType.AST_TYPE_ARRAY {
        return 0;
    }
    const elem: &ASTNode = array_type.type_array_element_type;
    if elem == null {
        return 0;
    }
    if elem.type == ASTNodeType.AST_TYPE_POINTER {
        return 0;
    }
    if elem.type == ASTNodeType.AST_TYPE_ARRAY {
        return 1;
    }
    if elem.type == ASTNodeType.AST_TYPE_NAMED && elem.type_named_name != null &&
        (find_struct_decl_c99(codegen, elem.type_named_name) != null ||
         find_union_decl_c99(codegen, elem.type_named_name) != null) {
        return 1;
    }
    return 0;
}

fn c99_mmu_access_kind_literal(codegen: &C99CodeGenerator) &byte {
    if codegen != null && codegen.emitting_assign_lhs != 0 {
        return "UYA_MMU_ACCESS_W" as &byte;
    }
    return "UYA_MMU_ACCESS_R" as &byte;
}

fn c99_type_is_pointer_to_array_c(type_c: &byte) i32 {
    if type_c == null {
        return 0;
    }
    const bracket: *byte = strchr(type_c as *byte, 91);  // '['
    const asterisk: *byte = strrchr(type_c as *byte, 42);  // '*'
    if bracket == null || asterisk == null || bracket >= asterisk {
        return 0;
    }
    const asterisk_offset: i32 = ptr_diff(asterisk, type_c as *byte);
    var after_asterisk_offset: i32 = asterisk_offset + 1;
    const type_c_len: i32 = strlen(type_c as *byte);
    while after_asterisk_offset < type_c_len && type_c[after_asterisk_offset] == 32 {  // ' '
        after_asterisk_offset = after_asterisk_offset + 1;
    }
    if after_asterisk_offset >= type_c_len || type_c[after_asterisk_offset] == 0 {
        return 1;
    }
    return 0;
}

fn c99_emit_mmu_wrapped_member_access(codegen: &C99CodeGenerator, object: &ASTNode, safe_field_name: &byte, is_pointer: i32, field_atomic_load_inner: &byte) void {
    if codegen == null || object == null || safe_field_name == null {
        return;
    }
    const access_mode: &byte = c99_mmu_access_kind_literal(codegen);
    if field_atomic_load_inner != null {
        fputs("({ __auto_type _uya_obj = (" as *byte, codegen.emit_stream as *void);
        gen_expr(codegen, object);
        fputs("); " as *byte, codegen.emit_stream as *void);
        if is_pointer != 0 {
            fprintf(codegen.emit_stream as *void, "__typeof__(_uya_obj) _uya_translated = (__typeof__(_uya_obj))uya_mmu_translate((void *)_uya_obj, sizeof(*_uya_obj), %s); " as *byte, access_mode as *byte);
        } else {
            fprintf(codegen.emit_stream as *void, "__typeof__(_uya_obj) *_uya_translated = (__typeof__(_uya_obj) *)uya_mmu_translate((void *)&_uya_obj, sizeof(_uya_obj), %s); " as *byte, access_mode as *byte);
        }
        fprintf(codegen.emit_stream as *void, "__atomic_load_n((%s *)&(_uya_translated->%s), __ATOMIC_SEQ_CST)" as *byte, field_atomic_load_inner as *byte, safe_field_name as *byte);
        fputs("; })" as *byte, codegen.emit_stream as *void);
        return;
    }
    fputs("(({ __auto_type _uya_obj = (" as *byte, codegen.emit_stream as *void);
    gen_expr(codegen, object);
    fputs("); " as *byte, codegen.emit_stream as *void);
    if is_pointer != 0 {
        fprintf(codegen.emit_stream as *void, "__typeof__(_uya_obj) _uya_translated = (__typeof__(_uya_obj))uya_mmu_translate((void *)_uya_obj, sizeof(*_uya_obj), %s); _uya_translated; }))" as *byte, access_mode as *byte);
    } else {
        fprintf(codegen.emit_stream as *void, "__typeof__(_uya_obj) *_uya_translated = (__typeof__(_uya_obj) *)uya_mmu_translate((void *)&_uya_obj, sizeof(_uya_obj), %s); _uya_translated; }))" as *byte, access_mode as *byte);
    }
    fprintf(codegen.emit_stream as *void, "->%s" as *byte, safe_field_name as *byte);
}

fn c99_emit_mmu_wrapped_array_access(codegen: &C99CodeGenerator, array: &ASTNode, index: &ASTNode) void {
    if codegen == null || array == null || index == null {
        return;
    }
    const access_mode: &byte = c99_mmu_access_kind_literal(codegen);
    fputc(42, codegen.emit_stream as *void);
    fputs("(({ __auto_type _uya_base = (" as *byte, codegen.emit_stream as *void);
    gen_expr(codegen, array);
    fputs("); __auto_type _uya_idx = (" as *byte, codegen.emit_stream as *void);
    gen_expr(codegen, index);
    fprintf(codegen.emit_stream as *void, "); __typeof__(_uya_base[0]) *_uya_translated = (__typeof__(_uya_base[0]) *)uya_mmu_translate((void *)_uya_base, sizeof(_uya_base[0]) * ((size_t)_uya_idx + 1U), %s); _uya_translated + _uya_idx; }))" as *byte, access_mode as *byte);
}

fn c99_emit_mmu_wrapped_deref(codegen: &C99CodeGenerator, operand: &ASTNode) void {
    if codegen == null || operand == null {
        return;
    }
    const access_mode: &byte = c99_mmu_access_kind_literal(codegen);
    fputc(42, codegen.emit_stream as *void);
    fputs("(({ __auto_type _uya_ptr = (" as *byte, codegen.emit_stream as *void);
    gen_expr(codegen, operand);
    fputs("); __typeof__(*_uya_ptr) *_uya_translated = (__typeof__(*_uya_ptr) *)uya_mmu_translate((void *)_uya_ptr, sizeof(*_uya_ptr), " as *byte, codegen.emit_stream as *void);
    fprintf(codegen.emit_stream as *void, "%s" as *byte, access_mode as *byte);
    fputs("); _uya_translated; }))" as *byte, codegen.emit_stream as *void);
}

// 已知 C 变参函数对应的 va_list 版本（用于 ... 转发）
fn get_vprintf_style_name(c_name: &byte) &byte {
    if c_name == null {
        return null;
    }
    if str_equals(c_name as *byte, "printf" as *byte) != 0 {
        return "vprintf" as &byte;
    }
    if str_equals(c_name as *byte, "sprintf" as *byte) != 0 {
        return "vsprintf" as &byte;
    }
    if str_equals(c_name as *byte, "fprintf" as *byte) != 0 {
        return "vfprintf" as &byte;
    }
    if str_equals(c_name as *byte, "snprintf" as *byte) != 0 {
        return "vsnprintf" as &byte;
    }
    return null;
}

// 根据 C 类型字符串返回无符号类型（用于包装运算）
fn unsigned_type_for_wrapping(type_c: &byte) &byte {
    if type_c == null { return "unsigned" as &byte; }
    if strstr(type_c as *byte, "int8" as *byte) != null { return "uint8_t" as &byte; }
    if strstr(type_c as *byte, "int16" as *byte) != null { return "uint16_t" as &byte; }
    if strstr(type_c as *byte, "int32" as *byte) != null { return "uint32_t" as &byte; }
    if strstr(type_c as *byte, "int64" as *byte) != null { return "uint64_t" as &byte; }
    return "unsigned" as &byte;
}

// 根据 C 类型字符串生成整数极值字面量（用于饱和运算）
fn gen_saturate_limit_from_type_c(codegen: &C99CodeGenerator, type_c: &byte, is_max: i32) void {
    if type_c == null {
        if is_max != 0 { fputs("2147483647LL" as *byte, codegen.emit_stream as *void); } else { fputs("(-2147483647LL-1LL)" as *byte, codegen.emit_stream as *void); }
        return;
    }
    if strstr(type_c as *byte, "int8" as *byte) != null {
        if is_max != 0 { fputs("127" as *byte, codegen.emit_stream as *void); } else { fputs("(-128)" as *byte, codegen.emit_stream as *void); }
        return;
    }
    if strstr(type_c as *byte, "int16" as *byte) != null {
        if is_max != 0 { fputs("32767" as *byte, codegen.emit_stream as *void); } else { fputs("(-32768)" as *byte, codegen.emit_stream as *void); }
        return;
    }
    if strstr(type_c as *byte, "int32" as *byte) != null {
        if is_max != 0 { fputs("2147483647LL" as *byte, codegen.emit_stream as *void); } else { fputs("(-2147483647LL-1LL)" as *byte, codegen.emit_stream as *void); }
        return;
    }
    if strstr(type_c as *byte, "int64" as *byte) != null {
        if is_max != 0 { fputs("9223372036854775807LL" as *byte, codegen.emit_stream as *void); } else { fputs("(-9223372036854775807LL-1LL)" as *byte, codegen.emit_stream as *void); }
        return;
    }
    if is_max != 0 { fputs("2147483647LL" as *byte, codegen.emit_stream as *void); } else { fputs("(-2147483647LL-1LL)" as *byte, codegen.emit_stream as *void); }
}

// 根据整数类型与 max/min 生成 C 极值字面量（resolved_kind 为 TypeKind 值）
fn gen_int_limit_literal(codegen: &C99CodeGenerator, is_max: i32, resolved_kind: i32) void {
    if resolved_kind == 0 {
        fputs("0" as *byte, codegen.emit_stream as *void);
        return;
    }
    const k_tmp: !TypeKind = resolved_kind as! TypeKind;
    const k: TypeKind = k_tmp.value;
    if k == TypeKind.TYPE_I8 {
        if is_max != 0 { fputs("127" as *byte, codegen.emit_stream as *void); } else { fputs("(-128)" as *byte, codegen.emit_stream as *void); }
    } else if k == TypeKind.TYPE_I16 {
        if is_max != 0 { fputs("32767" as *byte, codegen.emit_stream as *void); } else { fputs("(-32768)" as *byte, codegen.emit_stream as *void); }
    } else if k == TypeKind.TYPE_I32 {
        if is_max != 0 { fputs("2147483647LL" as *byte, codegen.emit_stream as *void); } else { fputs("(-2147483647LL-1LL)" as *byte, codegen.emit_stream as *void); }
    } else if k == TypeKind.TYPE_I64 {
        if is_max != 0 { fputs("9223372036854775807LL" as *byte, codegen.emit_stream as *void); } else { fputs("(-9223372036854775807LL-1LL)" as *byte, codegen.emit_stream as *void); }
    } else if k == TypeKind.TYPE_U8 || k == TypeKind.TYPE_BYTE {
        if is_max != 0 { fputs("255" as *byte, codegen.emit_stream as *void); } else { fputs("0" as *byte, codegen.emit_stream as *void); }
    } else if k == TypeKind.TYPE_U16 {
        if is_max != 0 { fputs("65535" as *byte, codegen.emit_stream as *void); } else { fputs("0" as *byte, codegen.emit_stream as *void); }
    } else if k == TypeKind.TYPE_U32 {
        if is_max != 0 { fputs("4294967295U" as *byte, codegen.emit_stream as *void); } else { fputs("0" as *byte, codegen.emit_stream as *void); }
    } else if k == TypeKind.TYPE_USIZE {
        if is_max != 0 { fputs("((size_t)-1)" as *byte, codegen.emit_stream as *void); } else { fputs("0" as *byte, codegen.emit_stream as *void); }
    } else if k == TypeKind.TYPE_U64 {
        if is_max != 0 { fputs("18446744073709551615ULL" as *byte, codegen.emit_stream as *void); } else { fputs("0" as *byte, codegen.emit_stream as *void); }
    } else {
        fputs("0" as *byte, codegen.emit_stream as *void);
    }
}

fn c99_emit_string_interp_fill(codegen: &C99CodeGenerator, expr: &ASTNode, buf_name: &byte) void {
    if codegen == null || expr == null || expr.type != ASTNodeType.AST_STRING_INTERP || buf_name == null {
        return;
    }
    const n: i32 = expr.string_interp_segment_count;
    if n <= 0 {
        return;
    }
    const fill_id: i32 = codegen.interp_fill_counter;
    codegen.interp_fill_counter = codegen.interp_fill_counter + 1;
    c99_emit_indent(codegen);
    fprintf(codegen.emit_stream as *void, "int _off_%d = 0;\n" as *byte, fill_id);
    var i: i32 = 0;
    while i < n {
        const seg: &ASTStringInterpSegment = &expr.string_interp_segments[i];
        if seg.is_text != 0 {
            var len: usize = 0;
            if seg.text != null {
                len = strlen(seg.text as *byte);
            }
            // 直接内联输出字符串字面量，不使用常量表
            c99_emit_indent(codegen);
            fprintf(codegen.emit_stream as *void, "__uya_memcpy(%s + _off_%d, " as *byte, buf_name as *byte, fill_id);
            fputs("(const uint8_t *)\"" as *byte, codegen.emit_stream as *void);
            if seg.text != null {
                escape_string_for_c(codegen.emit_stream as *void, seg.text);
            }
            fputs("\", " as *byte, codegen.emit_stream as *void);
            fprintf(codegen.emit_stream as *void, "%zu);\n" as *byte, len);
            c99_emit_indent(codegen);
            fprintf(codegen.emit_stream as *void, "_off_%d += %zu;\n" as *byte, fill_id, len);
        } else {
            var fmt_buf: [byte: FMT_BUF_SIZE] = [];
            fmt_buf[0] = 37;
            var j: i32 = 1;
            if seg.format_spec != null && seg.format_spec[0] != 0 {
                var k: i32 = 0;
                while seg.format_spec[k] != 0 && j < FMT_BUF_SIZE - 2 {
                    fmt_buf[j] = seg.format_spec[k];
                    j = j + 1;
                    k = k + 1;
                }
            } else {
                // 默认插值格式：数值为 %d，但对字节指针/切片按 C 字符串 %s 输出。
                // 注意：插值段最终通过 sprintf("%<fmt>", <expr>) 填入缓冲，因此这里要同时决定格式与参数形态。
                const expr_c: &byte = get_c_type_of_expr(codegen, seg.expr);
                var is_slice_u8: i32 = 0;
                var is_byte_ptr: i32 = 0;

                if expr_c != null && strstr(expr_c as *byte, "uya_slice_" as *byte) != null {
                    // slice 在 C 中为 struct { .ptr, .len }，gen_print_expr 当前默认不对其做特殊处理，
                    // 这里把默认格式改为 %s 并在 sprintf 参数处传入 `.ptr`。
                    is_slice_u8 = 1;
                } else if expr_c != null && strstr(expr_c as *byte, "*" as *byte) != null {
                    // 指向字节的指针：const unsigned char* / const uint8_t* 等
                    if strstr(expr_c as *byte, "uint8_t" as *byte) != null ||
                       strstr(expr_c as *byte, "int8_t" as *byte) != null ||
                       strstr(expr_c as *byte, "unsigned char" as *byte) != null {
                        is_byte_ptr = 1;
                    }
                }

                if is_slice_u8 != 0 || is_byte_ptr != 0 {
                    fmt_buf[1] = 115; // 's'
                    j = 2;
                } else {
                    fmt_buf[1] = 100; // 'd'
                    j = 2;
                }
            }
            if j >= 0 && j < FMT_BUF_SIZE {
                fmt_buf[j] = 0;
            }
            // 直接内联输出格式字符串
            c99_emit_indent(codegen);
            fprintf(codegen.emit_stream as *void, "_off_%d += sprintf(%s + _off_%d, \"%s\", " as *byte, fill_id, buf_name as *byte, fill_id, &fmt_buf[0] as *byte);

            // 按最终 fmt（此处仅处理默认 %s）决定 sprintf 参数应输出成何种表达式。
            if fmt_buf[1] == 115 { // 's'
                const expr_c3: &byte = get_c_type_of_expr(codegen, seg.expr);
                if expr_c3 != null && strstr(expr_c3 as *byte, "uya_slice_" as *byte) != null {
                    // slice struct
                    fputs("(char *)(( " as *byte, codegen.emit_stream as *void);
                    fputs(expr_c3 as *byte, codegen.emit_stream as *void);
                    fputs(")" as *byte, codegen.emit_stream as *void);
                    gen_expr(codegen, seg.expr);
                    fputs(").ptr" as *byte, codegen.emit_stream as *void);
                } else {
                    // byte pointer
                    fputs("(char *)" as *byte, codegen.emit_stream as *void);
                    gen_expr(codegen, seg.expr);
                }
            } else {
                gen_expr(codegen, seg.expr);
            }
            fputs(");\n" as *byte, codegen.emit_stream as *void);
        }
        i = i + 1;
    }
    c99_emit_indent(codegen);
    fprintf(codegen.emit_stream as *void, "%s[_off_%d] = '\\0';\n" as *byte, buf_name as *byte, fill_id);
}

fn gen_expr(codegen: &C99CodeGenerator, expr: &ASTNode) void {
    if expr == null {
        return;
    }
    
    // v0.7.3 优化支持：检查是否已优化
    if expr.is_optimized != 0 {
        // 常量折叠：直接输出优化后的值
        fprintf(codegen.emit_stream as *void, "/* optimized */ %d" as *byte, expr.optimized_value);
        return;
    }
    
    if expr.type == ASTNodeType.AST_NUMBER {
        // 根据字面量后缀生成对应的 C 代码格式（超出 i32 时用 number_value_i64 避免截断）
        const suffix: i32 = expr.literal_suffix;
        const val: i64 = expr.number_value_i64;
        const i32_max: i32 = 2147483647;
        const i32_min: i32 = 0 - i32_max - 1;
        
        // 判断是否需要 i64 格式
        const needs_i64: i32 = (suffix == 4) || 
                               (val < i32_min as i64) || (val > i32_max as i64);
        
        if suffix == 7 || suffix == 5 || suffix == 6 {  // U32, U8, U16
            // u8, u16：始终在 i32 正范围内；u32 可至 0xFFFFFFFF，不可 val as i32 再 %dU（如 0x80000000u32 会错成 (-U)）
            if suffix == 7 && val > i32_max as i64 {
                fprintf(codegen.emit_stream as *void, "((uint32_t)%lluULL)" as *byte, val);
            } else {
                fprintf(codegen.emit_stream as *void, "%dU" as *byte, val as i32);
            }
        } else if suffix == 8 || suffix == 9 {  // U64, USIZE
            // u64, usize 类型：使用 ULL 后缀；超出 i32 时用高/低 32 位拼成 64 位
            if val < i32_min as i64 || val > i32_max as i64 {
                const mask32: i64 = 4294967295;
                const low32: i64 = val & mask32;
                const high32: i64 = (val >> 32) & mask32;
                fprintf(codegen.emit_stream as *void, "((uint64_t)(uint32_t)0x%XULL + ((uint64_t)(uint32_t)0x%XULL << 32))" as *byte, low32 as i32, high32 as i32);
            } else {
                fprintf(codegen.emit_stream as *void, "%dULL" as *byte, val as i32);
            }
        } else if needs_i64 != 0 {
            // i64 类型或超出 i32 范围：使用 LL 后缀
            if val < i32_min as i64 || val > i32_max as i64 {
                // 超出 i32 时用高/低 32 位拼成 64 位常量，避免 val as i32 截断
                const mask32: i64 = 4294967295;
                const low32: i64 = val & mask32;
                const high32: i64 = (val >> 32) & mask32;
                fprintf(codegen.emit_stream as *void, "((int64_t)(uint32_t)0x%XULL + ((int64_t)(uint32_t)0x%XULL << 32))" as *byte, low32 as i32, high32 as i32);
            } else {
                fprintf(codegen.emit_stream as *void, "%dLL" as *byte, val as i32);
            }
        } else {
            // i8, i16, i32 或无后缀：C 中 INT_MIN 用 (-2147483647-1)；用 @min 比较避免字面量溢出
            const i32_min_val: i32 = @min;
            if (val as i32) == i32_min_val {
                fputs("(-2147483647LL-1LL)" as *byte, codegen.emit_stream as *void);
            } else {
                fprintf(codegen.emit_stream as *void, "%d" as *byte, val as i32);
            }
        }
    } else if expr.type == ASTNodeType.AST_FLOAT {
        // 根据浮点字面量后缀生成对应的 C 代码格式
        const suffix: i32 = expr.float_literal_suffix;
        const val: f64 = expr.float_literal_value;
        if suffix == 10 {  // F32
            // 必须保持“浮点字面量”形态；像 123.0 若输出成 123，会在 printf("%f", ...) 这类可变参调用中错传成 int。
            fprintf(codegen.emit_stream as *void, "%#.9gF" as *byte, val);
        } else if suffix == 11 {  // F64
            fprintf(codegen.emit_stream as *void, "%#.17g" as *byte, val);
        } else {
            fprintf(codegen.emit_stream as *void, "%#.17g" as *byte, val);
        }
    } else if expr.type == ASTNodeType.AST_BOOL {
        if expr.bool_literal_value != 0 {
            fputs("true" as *byte, codegen.emit_stream as *void);
        } else {
            fputs("false" as *byte, codegen.emit_stream as *void);
        }
    } else if expr.type == ASTNodeType.AST_CHAR {
        fprintf(codegen.emit_stream as *void, "%d" as *byte, expr.char_literal_value);
    } else if expr.type == ASTNodeType.AST_INT_LIMIT {
        gen_int_limit_literal(codegen, expr.int_limit_is_max, expr.int_limit_resolved_kind);
    } else if expr.type == ASTNodeType.AST_SRC_NAME {
        // @src_name - 提取文件名
        const filename: &byte = expr.filename;
        var basename: &byte = null;
        if filename == null {
            basename = "(unknown)" as &byte;
        } else {
            // 提取文件名（去掉路径）
            basename = strrchr(filename as *byte, 47) as &byte;  // '/' = ASCII 47
            if basename == null {
                basename = strrchr(filename as *byte, 92) as &byte;  // '\\' = ASCII 92
            }
            if basename != null {
                // 跳过 '/' 或 '\\'
                basename = (basename as i64 + 1) as &byte;
            } else {
                basename = filename;
            }
        }
        const str_const: &byte = find_string_constant(codegen, basename);
        if str_const != null {
            fprintf(codegen.emit_stream as *void, "%s" as *byte, str_const as *byte);
        } else {
            fputs("\"\"" as *byte, codegen.emit_stream as *void);
        }
    } else if expr.type == ASTNodeType.AST_SRC_PATH {
        // @src_path - 输出完整路径
        const filepath: &byte = expr.filename;
        var path: &byte = null;
        if filepath == null {
            path = "(unknown)" as &byte;
        } else {
            path = filepath;
        }
        const str_const: &byte = find_string_constant(codegen, path);
        if str_const != null {
            fprintf(codegen.emit_stream as *void, "%s" as *byte, str_const as *byte);
        } else {
            fputs("\"\"" as *byte, codegen.emit_stream as *void);
        }
    } else if expr.type == ASTNodeType.AST_SRC_LINE {
        // @src_line - 输出行号
        fprintf(codegen.emit_stream as *void, "%d" as *byte, expr.line);
    } else if expr.type == ASTNodeType.AST_SRC_COL {
        // @src_col - 输出列号
        fprintf(codegen.emit_stream as *void, "%d" as *byte, expr.column);
    } else if expr.type == ASTNodeType.AST_FUNC_NAME {
        // @func_name - 输出函数名
        var func_name: &byte = "(unknown)" as &byte;
        if codegen.current_function_decl != null &&
           codegen.current_function_decl.type == ASTNodeType.AST_FN_DECL &&
           codegen.current_function_decl.fn_decl_name != null {
            func_name = codegen.current_function_decl.fn_decl_name;
        }
        const str_const: &byte = find_string_constant(codegen, func_name);
        if str_const != null {
            fprintf(codegen.emit_stream as *void, "%s" as *byte, str_const as *byte);
        } else {
            fputs("\"\"" as *byte, codegen.emit_stream as *void);
        }
    } else if expr.type == ASTNodeType.AST_SYSCALL {
        // @syscall(nr, arg1, ..., arg6) 返回 !i64
        // 生成：({ long _uya_syscall_ret = uya_syscallN(nr, arg1, ...);
        //         struct err_union_int64_t _uya_result;
        //         if (_uya_syscall_ret < 0) { _uya_result.error_id = (int)(-_uya_syscall_ret); }
        //         else { _uya_result.error_id = 0; _uya_result.value = _uya_syscall_ret; }
        //         _uya_result; })
        fputs("({ " as *byte, codegen.emit_stream as *void);
        
        // 生成系统调用
        var use_microapp_syscall: i32 = 0;
        if codegen.container_mode != 0 {
            if expr.filename == null {
                use_microapp_syscall = 1;
            } else if strstr(expr.filename as *byte, "/lib/" as *byte) == null &&
                      strncmp(expr.filename as *byte, "lib/" as *byte, 4) != 0 {
                use_microapp_syscall = 1;
            }
        }
        if use_microapp_syscall != 0 {
            fputs("long _uya_syscall_ret = uya_microapp_syscall" as *byte, codegen.emit_stream as *void);
        } else {
            fputs("long _uya_syscall_ret = uya_syscall" as *byte, codegen.emit_stream as *void);
        }
        fprintf(codegen.emit_stream as *void, "%d(" as *byte, expr.syscall_arg_count);
        
        // 生成系统调用号
        gen_expr(codegen, expr.syscall_number);
        
        // 生成参数
        var sc_i: i32 = 0;
        while sc_i < expr.syscall_arg_count {
            c99_emit_comma_space(codegen);
            gen_expr(codegen, expr.syscall_args[sc_i]);
            sc_i = sc_i + 1;
        }
        
        fputs("); " as *byte, codegen.emit_stream as *void);
        
        // 生成错误联合类型包装
        fputs("struct err_union_int64_t _uya_result; " as *byte, codegen.emit_stream as *void);
        fputs("if (_uya_syscall_ret < 0) { " as *byte, codegen.emit_stream as *void);
        fputs("_uya_result.error_id = (int)(-_uya_syscall_ret); " as *byte, codegen.emit_stream as *void);
        fputs("} else { " as *byte, codegen.emit_stream as *void);
        fputs("_uya_result.error_id = 0; " as *byte, codegen.emit_stream as *void);
        fputs("_uya_result.value = _uya_syscall_ret; " as *byte, codegen.emit_stream as *void);
        fputs("} " as *byte, codegen.emit_stream as *void);
        fputs("_uya_result; " as *byte, codegen.emit_stream as *void);
        fputs("})" as *byte, codegen.emit_stream as *void);
    } else if expr.type == ASTNodeType.AST_VA_START {
        // Uya: @va_start(&ap, last) -> C: va_start(ap, last)
        // 注意：C 的 va_start 第一个参数是 va_list，不是 va_list*
        fputs("va_start(" as *byte, codegen.emit_stream as *void);
        // 如果第一个参数是取地址表达式，去掉 &
        if expr.va_start_ap != null && expr.va_start_ap.type == ASTNodeType.AST_UNARY_EXPR && (expr.va_start_ap.unary_expr_op as TokenType) == TokenType.TOKEN_AMPERSAND {
            gen_expr(codegen, expr.va_start_ap.unary_expr_operand);
        } else {
            gen_expr(codegen, expr.va_start_ap);
        }
        c99_emit_comma_space(codegen);
        gen_expr(codegen, expr.va_start_last_param);
        fputc(41, codegen.emit_stream as *void);
    } else if expr.type == ASTNodeType.AST_VA_END {
        // Uya: @va_end(&ap) -> C: va_end(ap)
        fputs("va_end(" as *byte, codegen.emit_stream as *void);
        // 如果第一个参数是取地址表达式，去掉 &
        if expr.va_end_ap != null && expr.va_end_ap.type == ASTNodeType.AST_UNARY_EXPR && (expr.va_end_ap.unary_expr_op as TokenType) == TokenType.TOKEN_AMPERSAND {
            gen_expr(codegen, expr.va_end_ap.unary_expr_operand);
        } else {
            gen_expr(codegen, expr.va_end_ap);
        }
        fputc(41, codegen.emit_stream as *void);
    } else if expr.type == ASTNodeType.AST_VA_ARG {
        const type_c: &byte = c99_type_to_c(codegen, expr.va_arg_arg_type);
        fputs("va_arg(" as *byte, codegen.emit_stream as *void);
        gen_expr(codegen, expr.va_arg_ap);
        if type_c != null {
            fprintf(codegen.emit_stream as *void, ", %s" as *byte, type_c as *byte);
        } else {
            fputs(", int" as *byte, codegen.emit_stream as *void);
        }
        fputc(41, codegen.emit_stream as *void);
    } else if expr.type == ASTNodeType.AST_VA_COPY {
        // Uya: @va_copy(&dest, src) -> C: va_copy(dest, src)
        fputs("va_copy(" as *byte, codegen.emit_stream as *void);
        // 如果第一个参数是取地址表达式，去掉 &
        if expr.va_copy_dest != null && expr.va_copy_dest.type == ASTNodeType.AST_UNARY_EXPR && (expr.va_copy_dest.unary_expr_op as TokenType) == TokenType.TOKEN_AMPERSAND {
            gen_expr(codegen, expr.va_copy_dest.unary_expr_operand);
        } else {
            gen_expr(codegen, expr.va_copy_dest);
        }
        c99_emit_comma_space(codegen);
        gen_expr(codegen, expr.va_copy_src);
        fputc(41, codegen.emit_stream as *void);
    } else if expr.type == ASTNodeType.AST_ASM {
        // @asm { ... } 内联汇编块
        // 生成 __asm__ volatile (...) 语句
        gen_asm_block(codegen, expr);
    } else if expr.type == ASTNodeType.AST_ASM_TARGET {
        // @asm_target() - 返回编译期平台常量
        // 平台枚举值：
        // x86_64_linux = 0, x86_64_macos = 1, x86_64_windows = 2
        // arm64_linux = 3, arm64_macos = 4, arm64_windows = 5
        // riscv64_linux = 6
        // 使用条件编译检测平台
        fputs("(UYA_ASM_TARGET_X86_64_LINUX)" as *byte, codegen.emit_stream as *void);
    } else if expr.type == ASTNodeType.AST_PRINT || expr.type == ASTNodeType.AST_PRINTLN {
        gen_print_expr(codegen, expr);
        } else if expr.type == ASTNodeType.AST_STRING {
        // 字符串常量在收集阶段已添加则用名称；宏展开产生的字面量未收集则内联输出，避免文件末尾定义导致 C 中“先声明后使用”错误
        const str_const: &byte = find_string_constant(codegen, expr.string_literal_value);
        if str_const != null {
            fprintf(codegen.emit_stream as *void, "(uint8_t *)%s" as *byte, str_const as *byte);
        } else if expr.string_literal_value != null {
            fputs("(uint8_t *)\"" as *byte, codegen.emit_stream as *void);
            escape_string_for_c(codegen.emit_stream, expr.string_literal_value);
            fputc(34, codegen.emit_stream as *void);
        } else {
            fputs("(uint8_t *)\"\"" as *byte, codegen.emit_stream as *void);
        }
    } else if expr.type == ASTNodeType.AST_MC_TYPE {
        var actual_operand: &ASTNode = expr.mc_type_operand;
        if actual_operand != null {
            const substituted: &ASTNode = substitute_type_arg(codegen, actual_operand);
            if substituted != null {
                actual_operand = substituted;
            }
            const type_info: &ASTNode = create_type_info_struct(actual_operand, codegen.arena, expr.line, expr.column, codegen.checker);
            if type_info != null {
                gen_expr(codegen, type_info);
                return;
            }
        }
        fputs("0" as *byte, codegen.emit_stream as *void);
    } else if expr.type == ASTNodeType.AST_MC_SOURCE {
        // @mc_source 应在宏展开时已替换为 AST_STRING；未替换时输出空字符串
        fputs("(uint8_t *)\"\"" as *byte, codegen.emit_stream as *void);
    } else if expr.type == ASTNodeType.AST_STRING_INTERP {
        if codegen.string_interp_buf != null {
            fputs(codegen.string_interp_buf as *byte, codegen.emit_stream as *void);
        } else {
            fputs("((char*)0)" as *byte, codegen.emit_stream as *void);
        }
    } else if expr.type == ASTNodeType.AST_ERROR_VALUE {
        var id: i32 = c99_get_or_add_error_id(codegen, expr.error_value_name);
        if id == 0 {
            id = 1;
        }
        fprintf(codegen.emit_stream as *void, "%dU" as *byte, id);
    } else if expr.type == ASTNodeType.AST_TRY_EXPR {
        gen_try_expr(codegen, expr);
        } else if expr.type == ASTNodeType.AST_AWAIT_EXPR {
        // @await expression:
        // 阶段 B（正统语义）：Pending 必须走 Poll.Pending，由 @async_fn 状态机的 poll 驱动。
        // 因此这里不再生成“把 Pending 伪装成 error.AsyncPending”的控制流。
        // 目前 @await 节点应由 @async_fn 专用 codegen 路径消解；此处仅保底输出操作数，避免崩溃。
        const operand: &ASTNode = expr.await_expr_operand;
        if operand == null {
            fputs("0" as *byte, codegen.emit_stream as *void);
            return;
        }
        gen_expr(codegen, operand);
    } else if expr.type == ASTNodeType.AST_CATCH_EXPR {
        gen_catch_expr(codegen, expr);
        } else if expr.type == ASTNodeType.AST_BINARY_EXPR {
        gen_binary_expr(codegen, expr);
        } else if expr.type == ASTNodeType.AST_UNARY_EXPR {
        gen_unary_expr(codegen, expr);
        } else if expr.type == ASTNodeType.AST_MEMBER_ACCESS {
        gen_member_access(codegen, expr);
        } else if expr.type == ASTNodeType.AST_SLICE_EXPR {
        gen_slice_expr(codegen, expr);
        } else if expr.type == ASTNodeType.AST_ARRAY_ACCESS {
        gen_array_access(codegen, expr);
        } else if expr.type == ASTNodeType.AST_STRUCT_INIT {
        gen_struct_init(codegen, expr);
        } else if expr.type == ASTNodeType.AST_ARRAY_LITERAL {
        gen_array_literal(codegen, expr);
        } else if expr.type == ASTNodeType.AST_TUPLE_LITERAL {
        // 元组字面量 (e0, e1, ...) -> (struct { T0 f0; T1 f1; }){ .f0 = e0, .f1 = e1 }
        const elements: & & ASTNode = expr.tuple_literal_elements;
        const n: i32 = expr.tuple_literal_element_count;
        if n <= 0 || elements == null {
            fputs("(struct { int32_t f0; }){ .f0 = 0 }" as *byte, codegen.emit_stream as *void);
        } else {
            var total_len: i32 = 64;
            var i: i32 = 0;
            while i < n {
                const et: &byte = get_c_type_of_expr(codegen, elements[i]);
                total_len = total_len + strlen(et as *byte) + 24;
                i = i + 1;
            }
            const type_buf: &byte = compiler_arena_alloc(codegen.arena, total_len) as &byte;
            if type_buf == null {
                fputs("(struct { int32_t f0; }){ .f0 = 0 }" as *byte, codegen.emit_stream as *void);
            } else {
                var off: i32 = 0;
                off = off + snprintf(type_buf as *byte + off, total_len - off, "struct { " as *byte);
                i = 0;
                while i < n {
                    const et: &byte = get_c_type_of_expr(codegen, elements[i]);
                    var et_str: &byte = ("int32_t" as *byte) as &byte;
                    if et != null {
                        et_str = et;
                    }
                    off = off + snprintf(type_buf as *byte + off, total_len - off, "%s f%d; " as *byte, et_str as *byte, i);
                    i = i + 1;
                }
                snprintf(type_buf as *byte + off, total_len - off, "}" as *byte);
                fprintf(codegen.emit_stream as *void, "(%s){" as *byte, type_buf as *byte);
                i = 0;
                while i < n {
                    fprintf(codegen.emit_stream as *void, ".f%d = " as *byte, i);
                    gen_expr(codegen, elements[i]);
                    if i < n - 1 {
                        c99_emit_comma_space(codegen);
                    }
                    i = i + 1;
                }
                fputc(125, codegen.emit_stream as *void);  // '}'
            }
        }
    } else if expr.type == ASTNodeType.AST_PARAMS {
        // @params -> 当前函数参数的元组复合字面量 (struct { T0 f0; ... }){ .f0 = p0, ... }
        const cur_fn: &ASTNode = codegen.current_function_decl;
        if cur_fn == null || cur_fn.type != ASTNodeType.AST_FN_DECL || cur_fn.fn_decl_param_count <= 0 || cur_fn.fn_decl_params == null {
            fputs("(struct { int32_t f0; }){ .f0 = 0 }" as *byte, codegen.emit_stream as *void);
        } else {
            const params: & & ASTNode = cur_fn.fn_decl_params;
            const n: i32 = cur_fn.fn_decl_param_count;
            var total_len: i32 = 128;
            var i: i32 = 0;
            while i < n {
                const p: &ASTNode = params[i];
                if p != null && p.type == ASTNodeType.AST_VAR_DECL && p.var_decl_type != null {
                    total_len = total_len + 64;
                }
                i = i + 1;
            }
            const type_buf: &byte = compiler_arena_alloc(codegen.arena, total_len) as &byte;
            if type_buf == null {
                fputs("(struct { int32_t f0; }){ .f0 = 0 }" as *byte, codegen.emit_stream as *void);
            } else {
                var off: i32 = 0;
                off = off + snprintf(type_buf as *byte + off, total_len - off, "struct { " as *byte);
                i = 0;
                while i < n {
                    const p: &ASTNode = params[i];
                    var et: &byte = "int32_t" as *byte;
                    if p != null && p.type == ASTNodeType.AST_VAR_DECL && p.var_decl_type != null {
                        const etc: &byte = c99_type_to_c(codegen, p.var_decl_type);
                        if etc != null {
                            et = etc;
                        }
                    }
                    off = off + snprintf(type_buf as *byte + off, total_len - off, "%s f%d; " as *byte, et as *byte, i);
                    i = i + 1;
                }
                snprintf(type_buf as *byte + off, total_len - off, "}" as *byte);
                fprintf(codegen.emit_stream as *void, "(%s){" as *byte, type_buf as *byte);
                i = 0;
                while i < n {
                    fprintf(codegen.emit_stream as *void, ".f%d = " as *byte, i);
                    const p: &ASTNode = params[i];
                    if p != null && p.type == ASTNodeType.AST_VAR_DECL && p.var_decl_name != null {
                        const pname: &byte = get_safe_c_identifier(codegen, p.var_decl_name);
                        fprintf(codegen.emit_stream as *void, "%s" as *byte, pname as *byte);
                    } else {
                        fputs("0" as *byte, codegen.emit_stream as *void);
                    }
                    if i < n - 1 {
                        c99_emit_comma_space(codegen);
                    }
                    i = i + 1;
                }
                fputc(125, codegen.emit_stream as *void);  // '}'
            }
        }
    } else if expr.type == ASTNodeType.AST_PTR_FROM_USIZE {
        // @ptr_from_usize(value) 生成 (void *)(uintptr_t)(value)
        fputs("(void *)(uintptr_t)(" as *byte, codegen.emit_stream as *void);
        if expr.ptr_from_usize_value == null {
            fputs("0" as *byte, codegen.emit_stream as *void);
        } else {
            gen_expr(codegen, expr.ptr_from_usize_value);
        }
        fputc(41, codegen.emit_stream as *void);  // ')'
    } else if expr.type == ASTNodeType.AST_USIZE_FROM_PTR {
        // @usize_from_ptr(ptr) 生成 (uintptr_t)(ptr)
        fputs("(uintptr_t)(" as *byte, codegen.emit_stream as *void);
        if expr.usize_from_ptr_ptr == null {
            fputs("0" as *byte, codegen.emit_stream as *void);
        } else {
            gen_expr(codegen, expr.usize_from_ptr_ptr);
        }
        fputc(41, codegen.emit_stream as *void);  // ')'
    } else if expr.type == ASTNodeType.AST_ERROR_ID {
        // @error_id(err) 提取错误值的数值 ID。
        const operand: &ASTNode = expr.error_id_operand;
        if operand == null {
            fputs("0U" as *byte, codegen.emit_stream as *void);
        } else if operand.type == ASTNodeType.AST_ERROR_VALUE {
            fputs("((uint32_t)(" as *byte, codegen.emit_stream as *void);
            gen_expr(codegen, operand);
            fputs("))" as *byte, codegen.emit_stream as *void);
        } else {
            fputs("((uint32_t)((" as *byte, codegen.emit_stream as *void);
            gen_expr(codegen, operand);
            fputs(").error_id))" as *byte, codegen.emit_stream as *void);
        }
    } else if expr.type == ASTNodeType.AST_SIZEOF {
        gen_sizeof_expr(codegen, expr);
        } else if expr.type == ASTNodeType.AST_LEN {
        gen_len_expr(codegen, expr);
        } else if expr.type == ASTNodeType.AST_ALIGNOF {
        const target: &ASTNode = expr.alignof_expr_target;
        const is_type: i32 = expr.alignof_expr_is_type;
        
        // 获取类型字符串
        var type_c: &byte = null;
        if target == null {
            type_c = ("int" as *byte) as &byte;
        } else if is_type != 0 {
            type_c = c99_type_to_c(codegen, target);
        } else {
            // 即使 is_type = 0，也检查是否是类型标识符（如 alignof(usize) 中的 usize）
            if target.type == ASTNodeType.AST_IDENTIFIER {
                const name: &byte = target.identifier_name;
                if name != null && is_c_keyword(name) == 0 {
                    const safe_name: &byte = get_safe_c_identifier(codegen, name);
                    if is_struct_in_table(codegen, safe_name) != 0 {
                        // 结构体类型
                        const str_len: i32 = strlen(safe_name as *byte) + 8;  // "struct " + name + '\0'
                        const buf: &byte = compiler_arena_alloc(codegen.arena, str_len) as &byte;
                        if buf != null {
                            snprintf(buf as *byte, str_len, "struct %s" as *byte, safe_name as *byte);
                            type_c = buf;
                        }
                    } else {
                        // 对于变量名，需要获取变量的类型（从局部/全局变量表查找，按原名）
                        type_c = get_identifier_type_c(codegen, name);
                        if type_c == null {
                            // 如果找不到，可能是类型名（如 alignof(usize)）
                            type_c = c99_type_to_c(codegen, target);
                        }
                    }
                } else {
                    type_c = c99_type_to_c(codegen, target);
                }
            } else {
                // 其他表达式类型：尝试从变量表查找（如成员访问的基变量）
                type_c = c99_type_to_c(codegen, target);
            }
        }
        
        if type_c == null {
            type_c = ("void" as *byte) as &byte;
        }
        
        // void 类型不能用于 uya_alignof 宏（struct { char c; void t; } 非法），直接输出 1
        if strcmp(type_c as *byte, "void" as *byte) == 0 {
            fputs("1" as *byte, codegen.emit_stream as *void);
            return;
        }
        
        // 检查类型是否是数组类型（包含 '['）
        const bracket: *byte = strchr(type_c as *byte, 91);  // '['
        if bracket != null {
            // 数组类型：提取元素类型（数组的对齐值等于元素类型的对齐值）
            const elem_len: i32 = ptr_diff(bracket, type_c as *byte);
            const elem_type: &u8 = compiler_arena_alloc(codegen.arena, elem_len + 1) as &u8;
            if elem_type != null {
                memcpy(elem_type as *void, type_c as *void, elem_len);
                elem_type[elem_len] = 0;
                // 移除可能的 const 限定符（如果存在）
                // @align_of 返回 i32，需要显式转换为 int32_t 避免无符号算术警告
                if strncmp(elem_type as *byte, "const " as *byte, 6) == 0 {
                    fputs("(int32_t)uya_alignof(" as *byte, codegen.emit_stream as *void);
                    fprintf(codegen.emit_stream as *void, "%s" as *byte, &elem_type[6] as *byte);
                    fputc(41, codegen.emit_stream as *void);  // ')'
                } else {
                    fputs("(int32_t)uya_alignof(" as *byte, codegen.emit_stream as *void);
                    fprintf(codegen.emit_stream as *void, "%s" as *byte, elem_type as *byte);
                    fputc(41, codegen.emit_stream as *void);  // ')'
                }
            } else {
                // 分配失败，回退到原始类型（会失败，但至少不会崩溃）
                fputs("(int32_t)uya_alignof(" as *byte, codegen.emit_stream as *void);
                fprintf(codegen.emit_stream as *void, "%s" as *byte, type_c as *byte);
                fputc(41, codegen.emit_stream as *void);  // ')'
            }
        } else {
            // 非数组类型：直接使用
            // @align_of 返回 i32，需要显式转换为 int32_t 避免无符号算术警告
            fputs("(int32_t)uya_alignof(" as *byte, codegen.emit_stream as *void);
            fprintf(codegen.emit_stream as *void, "%s" as *byte, type_c as *byte);
            fputc(41, codegen.emit_stream as *void);  // ')'
        }
    } else if expr.type == ASTNodeType.AST_CAST_EXPR {
        gen_cast_expr(codegen, expr);
        } else if expr.type == ASTNodeType.AST_IDENTIFIER {
        const name: &byte = expr.identifier_name;
        if name != null && strcmp(name as *byte, "null" as *byte) == 0 {
            fputs("NULL" as *byte, codegen.emit_stream as *void);
        } else {
            const ref_name: &byte = get_c_name_for_identifier_ref(codegen, name);
            const type_c: &byte = get_identifier_type_c(codegen, name);
            // 如果是原子类型，生成原子 load
            const inner_type: &byte = get_atomic_inner_type_c(codegen, type_c);
            if inner_type != null {
                fprintf(codegen.emit_stream as *void, "__atomic_load_n((%s *)&%s, __ATOMIC_SEQ_CST)" as *byte, inner_type as *byte, ref_name as *byte);
            } else {
                fprintf(codegen.emit_stream as *void, "%s" as *byte, ref_name as *byte);
            }
        }
    } else if expr.type == ASTNodeType.AST_CALL_EXPR {
        gen_call_expr(codegen, expr);
        } else if expr.type == ASTNodeType.AST_ASSIGN {
        // 赋值表达式（右结合）：dest = src；dest 为 _ 时仅求值右侧
        const dest: &ASTNode = expr.assign_dest;
        const src: &ASTNode = expr.assign_src;
        
        fputc(40, codegen.emit_stream as *void);  // '('
        if dest.type == ASTNodeType.AST_UNDERSCORE {
            gen_expr(codegen, src);
        } else {
            gen_expr(codegen, dest);
            fputs(" = " as *byte, codegen.emit_stream as *void);
            gen_expr(codegen, src);
        }
        fputc(41, codegen.emit_stream as *void);  // ')'
    } else if expr.type == ASTNodeType.AST_MATCH_EXPR {
        gen_match_expr(codegen, expr);
        } else if expr.type == ASTNodeType.AST_BLOCK {
        // 块表达式：使用 GCC 语句表达式扩展 ({ stmts; last_expr; })
        // 最后一条语句如果是表达式，作为整个块的值
        const block_stmts: & & ASTNode = expr.block_stmts;
        const block_count: i32 = expr.block_stmt_count;
        
        fputs("({ " as *byte, codegen.emit_stream as *void);
        
        // 找到最后一个非声明的表达式作为返回值
        var last_expr_idx: i32 = -1;
        var j: i32 = block_count - 1;
        while j >= 0 {
            const bs: &ASTNode = block_stmts[j];
            if bs == null {
                j = j - 1;
                continue;
            }
            if bs.type == ASTNodeType.AST_VAR_DECL {
                j = j - 1;
                continue;
            }
            if bs.type == ASTNodeType.AST_IF_STMT || bs.type == ASTNodeType.AST_WHILE_STMT ||
                bs.type == ASTNodeType.AST_FOR_STMT || bs.type == ASTNodeType.AST_RETURN_STMT ||
                bs.type == ASTNodeType.AST_BREAK_STMT || bs.type == ASTNodeType.AST_CONTINUE_STMT ||
                bs.type == ASTNodeType.AST_BLOCK || bs.type == ASTNodeType.AST_ASSIGN ||
                bs.type == ASTNodeType.AST_DEFER_STMT || bs.type == ASTNodeType.AST_ERRDEFER_STMT {
                j = j - 1;
                continue;
            }
            last_expr_idx = j;
            break;
        }
        
        // 块末为 if 且（try 期望错误联合类型或常见 encode_to_to_json 形态）时：生成 _block_ret 并赋两分支，使语句表达式有确定类型
        var use_if_as_value: i32 = 0;
        var last_stmt: &ASTNode = null;
        if block_count > 0 {
            last_stmt = block_stmts[block_count - 1];
            if last_stmt != null && last_stmt.type == ASTNodeType.AST_IF_STMT &&
                last_stmt.if_stmt_then_branch != null && last_stmt.if_stmt_then_branch.type == ASTNodeType.AST_ERROR_VALUE &&
                last_stmt.if_stmt_else_branch != null {
                use_if_as_value = 1;
                last_expr_idx = -1;
            }
        }
        
        var k: i32 = 0;
        while k < block_count {
            const bs: &ASTNode = block_stmts[k];
            if bs == null {
                k = k + 1;
                continue;
            }
            if use_if_as_value != 0 && k == block_count - 1 {
                var union_c: &byte = codegen.expected_block_union_type;
                if union_c == null { union_c = ("struct err_union_size_t" as *byte) as &byte; }
                const cond: &ASTNode = last_stmt.if_stmt_condition;
                const then_b: &ASTNode = last_stmt.if_stmt_then_branch;
                const else_b: &ASTNode = last_stmt.if_stmt_else_branch;
                const err_id: i32 = c99_get_or_add_error_id(codegen, then_b.error_value_name);
        const err_id_u_tmp: !u32 = err_id as! u32;
        var err_id_u: u32 = err_id_u_tmp.value;
                if err_id_u == 0 { err_id_u = 1; }
                fprintf(codegen.emit_stream as *void, "%s _block_ret; if (" as *byte, union_c as *byte);
                gen_expr(codegen, cond);
                fprintf(codegen.emit_stream as *void, ") { _block_ret = (%s){ .error_id = %uU, .value = 0 }; } else { _block_ret = (%s){ .error_id = 0, .value = " as *byte, union_c as *byte, err_id_u, union_c as *byte);
                gen_expr(codegen, else_b);
                fputs(" }; } _block_ret; " as *byte, codegen.emit_stream as *void);
            } else if k == last_expr_idx {
                // 块结果为数组类型且最后一条是变量引用时，用复合字面量拷贝，避免 C 中数组名 decay 成指针导致 .value = 赋值失败
                // 从块内同名的 VAR_DECL 取数组类型（不依赖 checker 当前作用域）
                var array_type_node: &ASTNode = null;
                if bs.type == ASTNodeType.AST_IDENTIFIER && bs.identifier_name != null {
                    var si: i32 = 0;
                    while si < block_count {
                        const st: &ASTNode = block_stmts[si];
                        if st != null && st.type == ASTNodeType.AST_VAR_DECL && st.var_decl_name != null &&
                            strcmp(st.var_decl_name as *byte, bs.identifier_name as *byte) == 0 &&
                            st.var_decl_type != null && st.var_decl_type.type == ASTNodeType.AST_TYPE_ARRAY {
                            array_type_node = st.var_decl_type;
                            break;
                        }
                        si = si + 1;
                    }
                }
                var use_array_compound: i32 = 0;
                if array_type_node != null && array_type_node.type_array_element_type != null &&
                    array_type_node.type_array_size_expr != null && array_type_node.type_array_size_expr.type == ASTNodeType.AST_NUMBER {
                    use_array_compound = 1;
                }
                if use_array_compound != 0 {
                    const elem_c: &byte = c99_type_to_c(codegen, array_type_node.type_array_element_type);
                    const n: i32 = array_type_node.type_array_size_expr.number_value;
                    if n > 0 && n <= 64 {
                        const var_name: &byte = bs.identifier_name;
                        fprintf(codegen.emit_stream as *void, "(%s[%d]){ " as *byte, elem_c as *byte, n);
                        var i: i32 = 0;
                        while i < n {
                            if i > 0 { fputs(", " as *byte, codegen.emit_stream as *void); }
                            fprintf(codegen.emit_stream as *void, "%s[%d]" as *byte, var_name as *byte, i);
                            i = i + 1;
                        }
                        fputs(" }" as *byte, codegen.emit_stream as *void);
                    } else {
                        gen_expr(codegen, bs);
                    }
                } else {
                    gen_expr(codegen, bs);
                }
                fputs("; " as *byte, codegen.emit_stream as *void);
            } else {
                gen_stmt(codegen, bs);
            }
            k = k + 1;
        }
        
        fputs("})" as *byte, codegen.emit_stream as *void);
    } else {
        fputs("0" as *byte, codegen.emit_stream as *void);
    }
}

// `thread_type_is_*` 与 std.thread 中 @mc 分发一致，供下方折叠判断使用。
fn c99_thread_type_is_expected_type_name(callee_name: &byte) &byte {
    if callee_name == null {
        return null;
    }
    if strcmp(callee_name as *byte, "thread_type_is_i32" as *byte) == 0 {
        return "i32" as &byte;
    }
    if strcmp(callee_name as *byte, "thread_type_is_usize" as *byte) == 0 {
        return "usize" as &byte;
    }
    if strcmp(callee_name as *byte, "thread_type_is_u32" as *byte) == 0 {
        return "u32" as &byte;
    }
    if strcmp(callee_name as *byte, "thread_type_is_i64" as *byte) == 0 {
        return "i64" as &byte;
    }
    if strcmp(callee_name as *byte, "thread_type_is_u64" as *byte) == 0 {
        return "u64" as &byte;
    }
    if strcmp(callee_name as *byte, "thread_type_is_i16" as *byte) == 0 {
        return "i16" as &byte;
    }
    if strcmp(callee_name as *byte, "thread_type_is_u16" as *byte) == 0 {
        return "u16" as &byte;
    }
    if strcmp(callee_name as *byte, "thread_type_is_i8" as *byte) == 0 {
        return "i8" as &byte;
    }
    if strcmp(callee_name as *byte, "thread_type_is_u8" as *byte) == 0 {
        return "u8" as &byte;
    }
    if strcmp(callee_name as *byte, "thread_type_is_bool" as *byte) == 0 {
        return "bool" as &byte;
    }
    if strcmp(callee_name as *byte, "thread_type_is_f32" as *byte) == 0 {
        return "f32" as &byte;
    }
    if strcmp(callee_name as *byte, "thread_type_is_f64" as *byte) == 0 {
        return "f64" as &byte;
    }
    return null;
}

// 泛型结构体方法内 `thread_type_is_*(T)`：在 C 端折叠为 0/1（顶层泛型 fn 由优化器裁剪，方法体不经该路径）。
fn c99_emit_thread_type_is_on_struct_type_param(codegen: &C99CodeGenerator, callee_name: &byte, arg0: &ASTNode) i32 {
    if codegen == null || callee_name == null || arg0 == null || arg0.type != ASTNodeType.AST_IDENTIFIER {
        return 0;
    }
    const want: &byte = c99_thread_type_is_expected_type_name(callee_name);
    if want == null {
        return 0;
    }
    if codegen.struct_type_params == null || codegen.struct_type_args == null {
        return 0;
    }
    if codegen.struct_type_param_count <= 0 || codegen.struct_type_arg_count != codegen.struct_type_param_count {
        return 0;
    }
    const arg_id: &byte = arg0.identifier_name;
    if arg_id == null {
        return 0;
    }
    var pi: i32 = 0;
    while pi < codegen.struct_type_param_count {
        if codegen.struct_type_params[pi].name != null &&
            strcmp(codegen.struct_type_params[pi].name as *byte, arg_id as *byte) == 0 {
            const conc: &ASTNode = codegen.struct_type_args[pi];
            if conc != null && conc.type == ASTNodeType.AST_TYPE_NAMED && conc.type_named_name != null {
                if strcmp(conc.type_named_name as *byte, want as *byte) == 0 {
                    fputs("1" as *byte, codegen.emit_stream as *void);
                } else {
                    fputs("0" as *byte, codegen.emit_stream as *void);
                }
                return 1;
            }
            return 0;
        }
        pi = pi + 1;
    }
    return 0;
}

// 形参 &[T]：C 侧均为按值 struct uya_slice_*（含仅有 extern 声明的函数，手写 C 须与此一致）。
fn c99_fn_decl_slice_param_pass_by_value(fn_decl: &ASTNode, param_index: i32) i32 {
    if fn_decl == null || fn_decl.type != ASTNodeType.AST_FN_DECL {
        return 0;
    }
    if param_index < 0 || param_index >= fn_decl.fn_decl_param_count {
        return 0;
    }
    const param: &ASTNode = fn_decl.fn_decl_params[param_index];
    if param == null || param.type != ASTNodeType.AST_VAR_DECL || param.var_decl_type == null {
        return 0;
    }
    const pt: &ASTNode = param.var_decl_type;
    // 解析器里 &[T] 为 AST_TYPE_SLICE；少数路径可能为 POINTER->SLICE
    if pt.type == ASTNodeType.AST_TYPE_SLICE {
        return 1;
    }
    if pt.type == ASTNodeType.AST_TYPE_POINTER && pt.type_pointer_pointed_type != null &&
        pt.type_pointer_pointed_type.type == ASTNodeType.AST_TYPE_SLICE {
        return 1;
    }
    return 0;
}

// 形参 AST 是否为 &[const byte]（与 checker 中字符串字面量可传 slice 一致）
fn c99_param_type_ast_is_const_byte_slice(param_type_ast: &ASTNode) i32 {
    if param_type_ast == null {
        return 0;
    }
    var slice_ty: &ASTNode = param_type_ast;
    if param_type_ast.type == ASTNodeType.AST_TYPE_POINTER && param_type_ast.type_pointer_pointed_type != null &&
        param_type_ast.type_pointer_pointed_type.type == ASTNodeType.AST_TYPE_SLICE {
        slice_ty = param_type_ast.type_pointer_pointed_type;
    }
    if slice_ty.type != ASTNodeType.AST_TYPE_SLICE {
        return 0;
    }
    if slice_ty.type_slice_element_const == 0 {
        return 0;
    }
    const et: &ASTNode = slice_ty.type_slice_element_type;
    if et == null || et.type != ASTNodeType.AST_TYPE_NAMED || et.type_named_name == null {
        return 0;
    }
    if strcmp(et.type_named_name as *byte, "byte" as *byte) == 0 {
        return 1;
    }
    return 0;
}

// 字符串字面量实参在对应形参为 &[const byte] 且按值 slice ABI 时，生成复合字面量而非裸指针（与 checker_check_expr_type 一致）
fn c99_string_literal_passes_as_const_byte_slice_value(callee_fn: &ASTNode, param_index: i32, arg: &ASTNode) i32 {
    if callee_fn == null || arg == null || arg.type != ASTNodeType.AST_STRING || arg.string_literal_value == null {
        return 0;
    }
    if callee_fn.type != ASTNodeType.AST_FN_DECL || param_index < 0 || param_index >= callee_fn.fn_decl_param_count {
        return 0;
    }
    const p: &ASTNode = callee_fn.fn_decl_params[param_index];
    if p == null || p.type != ASTNodeType.AST_VAR_DECL || p.var_decl_type == null {
        return 0;
    }
    if c99_fn_decl_slice_param_pass_by_value(callee_fn, param_index) == 0 {
        return 0;
    }
    return c99_param_type_ast_is_const_byte_slice(p.var_decl_type);
}

// 输出与 gen_expr(AST_STRING) 相同的 (uint8_t *) 指针表达式（不含外层 slice 复合字面量）
fn c99_emit_string_literal_uint8_ptr_expr(codegen: &C99CodeGenerator, expr: &ASTNode) void {
    if codegen == null || expr == null || expr.type != ASTNodeType.AST_STRING {
        fputs("(uint8_t *)\"\"" as *byte, codegen.emit_stream as *void);
        return;
    }
    if expr.string_literal_value == null {
        fputs("(uint8_t *)\"\"" as *byte, codegen.emit_stream as *void);
        return;
    }
    const str_const: &byte = find_string_constant(codegen, expr.string_literal_value);
    if str_const != null {
        fprintf(codegen.emit_stream as *void, "(uint8_t *)%s" as *byte, str_const as *byte);
    } else {
        fputs("(uint8_t *)\"" as *byte, codegen.emit_stream as *void);
        escape_string_for_c(codegen.emit_stream, expr.string_literal_value);
        fputc(34, codegen.emit_stream as *void);
    }
}

// 调用实参：对按值 slice ABI，将 &expr（expr 为切片值）生成为 expr。
fn c99_emit_call_arg_expr(codegen: &C99CodeGenerator, fn_decl: &ASTNode, param_index: i32, arg: &ASTNode) void {
    if arg != null && arg.type == ASTNodeType.AST_UNARY_EXPR &&
        (arg.unary_expr_op as TokenType) == TokenType.TOKEN_AMPERSAND &&
        c99_fn_decl_slice_param_pass_by_value(fn_decl, param_index) != 0 {
        const operand: &ASTNode = arg.unary_expr_operand;
        if operand != null {
            const op_ty: &byte = get_c_type_of_expr(codegen, operand);
            if op_ty != null && strstr(op_ty as *byte, "uya_slice_" as *byte) != null &&
                strchr(op_ty as *byte, 42) == null {
                gen_expr(codegen, operand);
                return;
            }
        }
    }
    if fn_decl != null && arg != null && arg.type == ASTNodeType.AST_STRING &&
        c99_string_literal_passes_as_const_byte_slice_value(fn_decl, param_index, arg) != 0 {
        var sl: i32 = 0;
        while arg.string_literal_value[sl] != 0 {
            sl = sl + 1;
        }
        fputs("(struct uya_slice_uint8_t){ .ptr = " as *byte, codegen.emit_stream as *void);
        c99_emit_string_literal_uint8_ptr_expr(codegen, arg);
        fprintf(codegen.emit_stream as *void, ", .len = (size_t)%d }" as *byte, sl);
        return;
    }
    gen_expr(codegen, arg);
}

fn c99_async_frame_fn_decl_from_expr(codegen: &C99CodeGenerator, expr: &ASTNode) &ASTNode {
    if codegen == null || expr == null || codegen.checker == null {
        return null;
    }
    var object_type: Type = checker_infer_type(codegen.checker, expr);
    if object_type.kind == TypeKind.TYPE_POINTER && object_type.pointer_to != null {
        object_type = object_type.pointer_to[0];
    }
    if checker_is_async_frame_type(codegen.checker, &object_type) == 0 || object_type.struct_name == null {
        return null;
    }
    if strncmp(object_type.struct_name as *byte, "uya_async_" as *byte, 10) != 0 {
        return null;
    }
    return find_function_decl_c99(codegen, &object_type.struct_name[10] as &byte);
}

fn c99_async_frame_helper_name(codegen: &C99CodeGenerator, async_struct_name: &byte, method_name: &byte) &byte {
    if codegen == null || async_struct_name == null || method_name == null {
        return null;
    }
    if strncmp(async_struct_name as *byte, "uya_async_" as *byte, 10) != 0 {
        return null;
    }
    const base_name: &byte = &async_struct_name[10] as &byte;
    var suffix: &byte = null;
    if strcmp(method_name as *byte, "start" as *byte) == 0 {
        suffix = "_frame_start" as *byte;
    } else if strcmp(method_name as *byte, "poll" as *byte) == 0 {
        suffix = "_poll" as *byte;
    } else if strcmp(method_name as *byte, "stop" as *byte) == 0 {
        suffix = "_frame_stop" as *byte;
    } else {
        return null;
    }
    const total_len: usize = strlen(base_name as *byte) + strlen(suffix as *byte) + 1;
    const result: &byte = compiler_arena_alloc(codegen.arena, total_len) as &byte;
    if result == null {
        return null;
    }
    strcpy(result as *byte, base_name as *byte);
    strcat(result as *byte, suffix as *byte);
    return result;
}

// 生成调用表达式
fn gen_call_expr(codegen: &C99CodeGenerator, expr: &ASTNode) void {
        const callee: &ASTNode = expr.call_expr_callee;
        const args: & & ASTNode = expr.call_expr_args;
        const arg_count: i32 = expr.call_expr_arg_count;
        const has_ellipsis: i32 = expr.call_expr_has_ellipsis_forward;
        var callee_name: &byte = null;
        if callee != null && callee.type == ASTNodeType.AST_IDENTIFIER {
            callee_name = callee.identifier_name;
        }

        if callee_name != null && arg_count == 1 && args != null && args[0] != null &&
            c99_emit_thread_type_is_on_struct_type_param(codegen, callee_name, args[0]) != 0 {
            return;
        }

        if c99_gen_simd_builtin_call(codegen, expr) != 0 {
            return;
        }
        
        // 检测字符串函数，设置 needs_string_h 标志
        if callee_name != null {
            if is_string_function(callee_name) != 0 {
                codegen.needs_string_h = 1;
            }
        }

        // 插值仅作 printf/fprintf 格式参数时：脱糖为单次 printf(fmt, ...)，无中间缓冲
        if callee_name != null && args != null && has_ellipsis == 0 {
            if strcmp(callee_name as *byte, "printf" as *byte) == 0 && arg_count == 1 && args[0] != null && args[0].type == ASTNodeType.AST_STRING_INTERP {
                const interp: &ASTNode = args[0];
                const safe: &byte = get_safe_c_identifier(codegen, "printf" as &byte);
                fprintf(codegen.emit_stream as *void, "%s(" as *byte, safe as *byte);
                emit_printf_fmt_inline(codegen, interp);
                var i: i32 = 0;
                while i < interp.string_interp_segment_count {
                    const seg: &ASTStringInterpSegment = &interp.string_interp_segments[i];
                    if seg.is_text == 0 && seg.expr != null {
                        c99_emit_comma_space(codegen);
                        gen_expr(codegen, seg.expr);
                    }
                    i = i + 1;
                }
                fputc(41, codegen.emit_stream as *void);
                return;
            } else if strcmp(callee_name as *byte, "fprintf" as *byte) == 0 && arg_count == 2 && args[1] != null && args[1].type == ASTNodeType.AST_STRING_INTERP {
                const interp: &ASTNode = args[1];
                const safe: &byte = get_safe_c_identifier(codegen, "fprintf" as &byte);
                fprintf(codegen.emit_stream as *void, "%s(" as *byte, safe as *byte);
                gen_expr(codegen, args[0]);
                c99_emit_comma_space(codegen);
                emit_printf_fmt_inline(codegen, interp);
                var i: i32 = 0;
                while i < interp.string_interp_segment_count {
                    const seg: &ASTStringInterpSegment = &interp.string_interp_segments[i];
                    if seg.is_text == 0 && seg.expr != null {
                        c99_emit_comma_space(codegen);
                        gen_expr(codegen, seg.expr);
                    }
                    i = i + 1;
                }
                fputc(41, codegen.emit_stream as *void);
                return;
            }
        }

        // 查找函数声明（用于检查参数类型）
        var fn_decl: &ASTNode = null;
        if callee != null && callee.type == ASTNodeType.AST_IDENTIFIER {
            fn_decl = find_function_decl_c99(codegen, callee_name);
            // 如果是字符串函数（无论是普通函数还是 extern 函数），都需要设置 needs_string_h
            if is_string_function(callee_name) != 0 {
                codegen.needs_string_h = 1;
            }
        } else if callee != null && callee.type == ASTNodeType.AST_MEMBER_ACCESS && callee.member_access_is_module_access != 0 {
            // 模块限定调用：查找对应的 extern "libc" 声明
            fn_decl = find_function_decl_c99(codegen, callee.member_access_field_name);
        }
        
        // 无 ... 转发的调用不生成 va_list（零开销转发）
        var do_va_forward: i32 = 0;
        if has_ellipsis != 0 && codegen.current_function_decl != null &&
            codegen.current_function_decl.type == ASTNodeType.AST_FN_DECL &&
            codegen.current_function_decl.fn_decl_is_varargs != 0 &&
            codegen.current_function_decl.fn_decl_param_count > 0 &&
            callee_name != null {
            do_va_forward = 1;
        }
        var vname: &byte = null;
        var last_param: &byte = null;
        if do_va_forward != 0 {
            vname = get_vprintf_style_name(callee_name);
            const cur_fn: &ASTNode = codegen.current_function_decl;
            const last_p: &ASTNode = cur_fn.fn_decl_params[cur_fn.fn_decl_param_count - 1];
            if last_p != null && last_p.type == ASTNodeType.AST_VAR_DECL {
                last_param = last_p.var_decl_name;
            }
        }
        var arg_idx: i32 = 0;
        while arg_idx < arg_count && arg_idx < C99_MAX_CALL_ARGS {
            codegen.interp_arg_temp_names[arg_idx] = null;
            arg_idx = arg_idx + 1;
        }
        arg_idx = 0;
        while arg_idx < arg_count && arg_idx < C99_MAX_CALL_ARGS {
            const arg: &ASTNode = expr.call_expr_args[arg_idx];
            if arg != null && arg.type == ASTNodeType.AST_STRING_INTERP && arg.string_interp_computed_size > 0 {
                var name_buf: [byte: SHORT_NAME_BUF_SIZE] = [];
                snprintf(&name_buf[0] as *byte, SHORT_NAME_BUF_SIZE, "__uya_interp_%d" as *byte, codegen.interp_temp_counter);
                codegen.interp_temp_counter = codegen.interp_temp_counter + 1;
                const temp_name: &byte = c99_arena_strdup(codegen.arena, &name_buf[0] as &byte);
                if temp_name != null {
                    codegen.interp_arg_temp_names[arg_idx] = temp_name;
                    c99_emit_indent(codegen);
                    fprintf(codegen.emit_stream as *void, "char %s[%d];\n" as *byte, temp_name as *byte, arg.string_interp_computed_size);
                    c99_emit_string_interp_fill(codegen, arg, temp_name);
                }
            }
            arg_idx = arg_idx + 1;
        }
        var did_interface_call: i32 = 0;
        // 模块限定调用（module.func(args)）：生成 module_func(args)
        // 注意：extern "libc" fn 不添加模块前缀
        if callee != null && callee.type == ASTNodeType.AST_MEMBER_ACCESS && callee.member_access_is_module_access != 0 {
            const module_name: &byte = callee.member_access_module_name;
            const mod_callee: &byte = callee.member_access_field_name;
            
            // 检查是否是 extern "libc" fn
            const is_libc_fn: i32 = is_extern_libc_function(codegen, mod_callee);
            
            // 生成模块前缀函数名（extern "libc" fn 除外）
            if module_name != null && mod_callee != null {
                if is_libc_fn != 0 {
                    // extern "libc" fn 直接使用原始函数名
                    const func_name: &byte = get_safe_c_identifier(codegen, mod_callee);
                    fprintf(codegen.emit_stream as *void, "%s(" as *byte, func_name as *byte);
                } else {
                    var prefixed_name: [i8: NAME_BUF_SIZE] = [];
                    var pi: i32 = 0;
                    var p: &i8 = module_name as &i8;
                    while p[0] != 0 && pi < NAME_BUF_SIZE / 2 {
                        if p[0] == 46 {  // '.'
                            prefixed_name[pi] = 95;  // '_'
                        } else {
                            prefixed_name[pi] = p[0];
                        }
                        pi = pi + 1;
                        p = p + 1;
                    }
                    if pi >= 0 && pi < NAME_BUF_SIZE {
                        prefixed_name[pi] = 95;  // '_'
                    }
                    pi = pi + 1;
                    p = mod_callee as &i8;
                    while p[0] != 0 && pi < NAME_BUF_SIZE - 6 {
                        prefixed_name[pi] = p[0];
                        pi = pi + 1;
                        p = p + 1;
                    }
                    if pi >= 0 && pi < NAME_BUF_SIZE {
                        prefixed_name[pi] = 0;
                    }
                    
                    const func_name: &byte = get_safe_c_identifier(codegen, &prefixed_name[0]);
                    fprintf(codegen.emit_stream as *void, "%s(" as *byte, func_name as *byte);
                }
            } else {
                const func_name: &byte = get_safe_c_identifier(codegen, mod_callee);
                fprintf(codegen.emit_stream as *void, "%s(" as *byte, func_name as *byte);
            }
            var ai: i32 = 0;
            while ai < arg_count {
                if ai > 0 {
                    c99_emit_comma_space(codegen);
                }
                const libc_param_c: &byte = get_extern_libc_param_c_type(fn_decl, ai);
                if libc_param_c != null {
                    if strcmp(libc_param_c as *byte, "char *" as *byte) == 0 {
                        fputs("(char *)" as *byte, codegen.emit_stream as *void);
                    } else {
                        fputs("(const char *)" as *byte, codegen.emit_stream as *void);
                    }
                } else if expr.call_expr_args[ai] != null && expr.call_expr_args[ai].type == ASTNodeType.AST_STRING {
                    if c99_string_literal_passes_as_const_byte_slice_value(fn_decl, ai, expr.call_expr_args[ai]) == 0 {
                        fputs("(uint8_t *)" as *byte, codegen.emit_stream as *void);
                    }
                }
                c99_emit_call_arg_expr(codegen, fn_decl, ai, expr.call_expr_args[ai]);
                ai = ai + 1;
            }
            fputc(41, codegen.emit_stream as *void);
            return;
        }
        // 联合体变体构造：UnionName.variant(expr) 或 Foo<i32>.variant(expr)
        if callee != null && callee.type == ASTNodeType.AST_MEMBER_ACCESS {
            const obj: &ASTNode = callee.member_access_object;
            const method_name: &byte = callee.member_access_field_name;
            if obj != null && (arg_count == 1 || arg_count == 0) && (arg_count == 0 || (expr.call_expr_args != null && expr.call_expr_args[0] != null)) {
                var union_decl: &ASTNode = null;
                var uname: &byte = null;
                if obj.type == ASTNodeType.AST_IDENTIFIER && obj.identifier_name != null {
                    union_decl = find_union_decl_c99(codegen, obj.identifier_name);
                    if union_decl != null {
                        if union_decl.union_decl_type_param_count > 0 {
                            // 支持语法：Poll<i32>.Ready(x)
                            // 解析器可能把 <...> 类型实参挂在 call_expr_type_args 上（而不是 obj 为 AST_TYPE_NAMED）。
                            if expr.call_expr_type_arg_count > 0 && expr.call_expr_type_args != null {
                                const mono: &byte = get_mono_union_name(codegen, obj.identifier_name,
                                    expr.call_expr_type_args,
                                    expr.call_expr_type_arg_count);
                                if mono != null && strchr(mono as *byte, 95) != null { uname = get_safe_c_identifier(codegen, mono); }
                            }
                            // 变量初始化 const p: Poll<i32> = Poll<i32>.Ready(42)：优先用期望类型实参（测试等非泛型上下文中无 call_expr_type_args）
                            if uname == null && codegen.expected_type != null && codegen.expected_type.type == ASTNodeType.AST_TYPE_NAMED &&
                                codegen.expected_type.type_named_type_arg_count > 0 && codegen.expected_type.type_named_type_args != null {
                                const mono: &byte = get_mono_union_name(codegen, obj.identifier_name,
                                    codegen.expected_type.type_named_type_args,
                                    codegen.expected_type.type_named_type_arg_count);
                                if mono != null && strchr(mono as *byte, 95) != null {
                                    uname = get_safe_c_identifier(codegen, mono);
                                }
                            }
                            if uname == null && codegen.current_function_return_type != null && codegen.current_function_return_type.type == ASTNodeType.AST_TYPE_ERROR_UNION &&
                                codegen.current_function_return_type.type_error_union_payload_type != null {
                                const payload: &ASTNode = codegen.current_function_return_type.type_error_union_payload_type;
                                if payload.type == ASTNodeType.AST_TYPE_NAMED && payload.type_named_type_arg_count >= 1 && payload.type_named_type_args != null {
                                    const mono: &byte = get_mono_union_name(codegen, obj.identifier_name, payload.type_named_type_args, 1);
                                    if mono != null && strchr(mono as *byte, 95) != null { uname = get_safe_c_identifier(codegen, mono); }
                                }
                            }
                            if uname == null && codegen.current_function_return_type != null && codegen.current_function_return_type.type == ASTNodeType.AST_TYPE_NAMED &&
                                codegen.current_function_return_type.type_named_type_arg_count >= 1 &&
                                codegen.current_function_return_type.type_named_type_args != null {
                                const ret: &ASTNode = codegen.current_function_return_type;
                                const mono: &byte = get_mono_union_name(codegen, obj.identifier_name, ret.type_named_type_args, 1);
                                if mono != null && strchr(mono as *byte, 95) != null { uname = get_safe_c_identifier(codegen, mono); }
                            }
                            if uname == null {
                            var found_mono: i32 = 0;
                            var mono_idx: i32 = -1;
                            var j: i32 = 0;
                            while j < codegen.mono_instance_count {
                                if codegen.mono_instances[j].generic_name != null &&
                                    strcmp(codegen.mono_instances[j].generic_name as *byte, obj.identifier_name as *byte) == 0 &&
                                    codegen.mono_instances[j].is_function == 0 {
                                    if found_mono != 0 {
                                        mono_idx = -1;
                                        break;
                                    }
                                    found_mono = 1;
                                    mono_idx = j;
                                }
                                j = j + 1;
                            }
                            if mono_idx >= 0 && codegen.mono_instances[mono_idx].type_args != null && codegen.mono_instances[mono_idx].type_arg_count > 0 {
                                const mono: &byte = get_mono_union_name(codegen, obj.identifier_name,
                                    codegen.mono_instances[mono_idx].type_args,
                                    codegen.mono_instances[mono_idx].type_arg_count);
                                if mono != null && strchr(mono as *byte, 95) != null { uname = get_safe_c_identifier(codegen, mono); }
                            } else if codegen.current_type_params != null && codegen.current_type_arg_count == union_decl.union_decl_type_param_count && codegen.current_type_args != null {
                                // 泛型函数内 Poll.Ready(x) 等：用当前函数类型实参解析单态名（如 task_ready 内 Poll -> Poll_i32）
                                const mono: &byte = get_mono_union_name(codegen, obj.identifier_name,
                                    codegen.current_type_args,
                                    codegen.current_type_arg_count);
                                if mono != null && strchr(mono as *byte, 95) != null { uname = get_safe_c_identifier(codegen, mono); }
                            }
                            if uname == null && codegen.current_function_return_type != null && codegen.current_function_return_type.type == ASTNodeType.AST_TYPE_NAMED &&
                                codegen.current_function_return_type.type_named_name != null && str_equals(codegen.current_function_return_type.type_named_name, obj.identifier_name) != 0 &&
                                codegen.current_function_return_type.type_named_type_arg_count > 0 && codegen.current_function_return_type.type_named_type_args != null {
                                // 如 return Poll<!i32>.Pending({}); 当前函数返回 Poll<!i32>，用其类型实参解析单态名
                                const mono: &byte = get_mono_union_name(codegen, obj.identifier_name,
                                    codegen.current_function_return_type.type_named_type_args,
                                    codegen.current_function_return_type.type_named_type_arg_count);
                                if mono != null && strchr(mono as *byte, 95) != null { uname = get_safe_c_identifier(codegen, mono); }
                            } else if codegen.current_function_return_type != null && codegen.current_function_return_type.type == ASTNodeType.AST_TYPE_NAMED &&
                                codegen.current_function_return_type.type_named_type_arg_count == 1 &&
                                codegen.current_function_return_type.type_named_type_args != null {
                                const ret_type: &ASTNode = codegen.current_function_return_type;
                                const mono: &byte = get_mono_union_name(codegen, obj.identifier_name,
                                    ret_type.type_named_type_args, 1);
                                if mono != null && strchr(mono as *byte, 95) != null {
                                    uname = get_safe_c_identifier(codegen, mono);
                                }
                            }
                            if uname == null && codegen.struct_type_args != null && codegen.struct_type_arg_count >= 1 {
                                const mono: &byte = get_mono_union_name(codegen, obj.identifier_name,
                                    codegen.struct_type_args, 1);
                                if mono != null && strchr(mono as *byte, 95) != null { uname = get_safe_c_identifier(codegen, mono); }
                            }
                            if uname == null && codegen.current_function_return_type != null {
                                var ret_node: &ASTNode = codegen.current_function_return_type;
                                if ret_node.type == ASTNodeType.AST_TYPE_ERROR_UNION && ret_node.type_error_union_payload_type != null {
                                    ret_node = ret_node.type_error_union_payload_type;
                                }
                                if ret_node.type == ASTNodeType.AST_TYPE_NAMED {
                                const ret_c: &byte = c99_type_to_c(codegen, ret_node);
                                if ret_c != null && strchr(ret_c as *byte, 95) != null {
                                    var start: *byte = ret_c as *byte;
                                    if strncmp(start, "struct " as *byte, 7) == 0 { start = start + 7; }
                                    const us: *byte = strchr(start, 95);
                                    if us != null && us[1] != 0 {
                                        const suffix: &byte = &us[1] as &byte;
                                        const need: i32 = 6 + strlen(suffix as *byte) + 1;
                                        if need > 0 && need < 128 {
                                            const buf: &byte = compiler_arena_alloc(codegen.arena, need as usize) as &byte;
                                            if buf != null {
                                                snprintf(buf as *byte, need, "Poll_%s" as *byte, suffix as *byte);
                                                uname = get_safe_c_identifier(codegen, buf);
                                            }
                                        }
                                    }
                                }
                            }
                            }
                            if uname == null && codegen.current_function_return_type != null && codegen.current_function_return_type.type == ASTNodeType.AST_TYPE_NAMED &&
                                codegen.current_function_return_type.type_named_name != null && codegen.current_function_return_type.type_named_type_arg_count > 0 &&
                                codegen.current_function_return_type.type_named_type_args != null {
                                // 多类型参时从结构体字段推导：如 Task<T,U> 的 state: Poll<T>
                                const ret_type: &ASTNode = codegen.current_function_return_type;
                                const ret_struct: &ASTNode = find_struct_decl_c99(codegen, ret_type.type_named_name);
                                if ret_struct != null && ret_struct.struct_decl_fields != null && ret_struct.struct_decl_type_params != null && ret_struct.struct_decl_type_param_count > 0 {
                                    var fi: i32 = 0;
                                    while fi < ret_struct.struct_decl_field_count && uname == null {
                                        const field: &ASTNode = ret_struct.struct_decl_fields[fi];
                                        if field != null && field.type == ASTNodeType.AST_VAR_DECL && field.var_decl_type != null &&
                                            field.var_decl_type.type == ASTNodeType.AST_TYPE_NAMED && field.var_decl_type.type_named_name != null &&
                                            str_equals(field.var_decl_type.type_named_name, obj.identifier_name) != 0 &&
                                            field.var_decl_type.type_named_type_arg_count == 1 && field.var_decl_type.type_named_type_args != null {
                                            const fa: &ASTNode = field.var_decl_type.type_named_type_args[0];
                                            var param_idx: i32 = -1;
                                            if fa != null && fa.type == ASTNodeType.AST_TYPE_NAMED && fa.type_named_name != null {
                                                var pi: i32 = 0;
                                                while pi < ret_struct.struct_decl_type_param_count {
                                                    if ret_struct.struct_decl_type_params[pi].name != null &&
                                                        strcmp(ret_struct.struct_decl_type_params[pi].name as *byte, fa.type_named_name as *byte) == 0 {
                                                        param_idx = pi;
                                                        break;
                                                    }
                                                    pi = pi + 1;
                                                }
                                            }
                                            if param_idx >= 0 && param_idx < ret_type.type_named_type_arg_count && ret_type.type_named_type_args != null {
                                                const one_arg: & & ASTNode = compiler_arena_alloc(codegen.arena, @size_of(&ASTNode)) as & & ASTNode;
                                                if one_arg != null {
                                                    one_arg[0] = ret_type.type_named_type_args[param_idx];
                                                    const mono: &byte = get_mono_union_name(codegen, obj.identifier_name, one_arg, 1);
                                                    if mono != null && mono != obj.identifier_name {
                                                        uname = get_safe_c_identifier(codegen, mono);
                                                    }
                                                }
                                            }
                                            break;
                                        }
                                        fi = fi + 1;
                                    }
                                }
                                {
                                    if uname == null {
                                        uname = get_safe_c_identifier(codegen, union_decl.union_decl_name);
                                    }
                                }
                            } else {
                                uname = get_safe_c_identifier(codegen, union_decl.union_decl_name);
                            }
                            }
                        } else {
                            uname = get_safe_c_identifier(codegen, union_decl.union_decl_name);
                        }
                    }
                } else if obj.type == ASTNodeType.AST_TYPE_NAMED && obj.type_named_name != null {
                    union_decl = find_union_decl_c99(codegen, obj.type_named_name);
                    if union_decl != null {
                        if union_decl.union_decl_type_param_count > 0 && obj.type_named_type_arg_count > 0 && obj.type_named_type_args != null {
                            const mono: &byte = get_mono_union_name(codegen, obj.type_named_name, obj.type_named_type_args, obj.type_named_type_arg_count);
                            uname = get_safe_c_identifier(codegen, mono);
                        }
                        if uname == null && union_decl.union_decl_type_param_count > 0 && codegen.struct_type_args != null && codegen.struct_type_arg_count >= 1 {
                            const mono: &byte = get_mono_union_name(codegen, obj.type_named_name, codegen.struct_type_args, 1);
                            if mono != null && strchr(mono as *byte, 95) != null { uname = get_safe_c_identifier(codegen, mono); }
                        }
                        if uname == null && codegen.current_function_return_type != null && codegen.current_function_return_type.type == ASTNodeType.AST_TYPE_NAMED {
                            const ret_c: &byte = c99_type_to_c(codegen, codegen.current_function_return_type);
                            if ret_c != null && strchr(ret_c as *byte, 95) != null {
                                var start: *byte = ret_c as *byte;
                                if strncmp(start, "struct " as *byte, 7) == 0 { start = start + 7; }
                                const us: *byte = strchr(start, 95);
                                if us != null && us[1] != 0 {
                                    const suffix: &byte = &us[1] as &byte;
                                    const need: i32 = 6 + strlen(suffix as *byte) + 1;
                                    if need > 0 && need < 128 {
                                        const buf: &byte = compiler_arena_alloc(codegen.arena, need as usize) as &byte;
                                        if buf != null {
                                            snprintf(buf as *byte, need, "Poll_%s" as *byte, suffix as *byte);
                                            uname = get_safe_c_identifier(codegen, buf);
                                        }
                                    }
                                }
                            }
                        }
                        if uname == null && codegen.current_function_return_type != null && codegen.current_function_return_type.type == ASTNodeType.AST_TYPE_ERROR_UNION &&
                            codegen.current_function_return_type.type_error_union_payload_type != null {
                            const payload: &ASTNode = codegen.current_function_return_type.type_error_union_payload_type;
                            if payload.type == ASTNodeType.AST_TYPE_NAMED && payload.type_named_type_arg_count >= 1 && payload.type_named_type_args != null {
                                const mono: &byte = get_mono_union_name(codegen, obj.type_named_name, payload.type_named_type_args, 1);
