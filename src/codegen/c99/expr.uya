        }
        const result_c: &byte = c99_type_to_c(codegen, target_ast);
        const elem_c: &byte = c99_type_to_c(codegen, target_ast.type_vector_element_type);
        const lanes: i32 = eval_const_expr(codegen, target_ast.type_vector_size_expr);
        const scalar_name: &byte = c99_make_temp_name(codegen, "__uya_simd_splat_" as &byte);
        if result_c == null || elem_c == null || scalar_name == null || lanes <= 0 {
            return 0;
        }
        const elem_base: &byte = c99_type_c_skip_const(elem_c);
        if c99_simd_sse_i32_u32_f32_two_or_x4_lane_ok(lanes) != 0 && elem_base != null &&
            (strcmp(elem_base as *byte, "int32_t" as *byte) == 0 || strcmp(elem_base as *byte, "uint32_t" as *byte) == 0 ||
            strcmp(elem_base as *byte, "float" as *byte) == 0) {
            const out_struct: &byte = c99_make_temp_name(codegen, "__uya_sp_o_" as &byte);
            if out_struct == null {
                return 0;
            }
            fputs("({ " as *byte, codegen.emit_stream as *void);
            fprintf(codegen.emit_stream as *void, "%s %s = (" as *byte, elem_c as *byte, scalar_name as *byte);
            gen_expr(codegen, expr.call_expr_args[0]);
            fputs("); " as *byte, codegen.emit_stream as *void);
            fprintf(codegen.emit_stream as *void, "%s %s; " as *byte, result_c as *byte, out_struct as *byte);
            var sp_step: i32 = 4;
            if lanes == 2 {
                sp_step = 2;
            }
            var sp_off: i32 = 0;
            while sp_off < lanes {
                if strcmp(elem_base as *byte, "float" as *byte) == 0 {
                    if lanes == 2 {
                        if sp_off == 0 {
                            fprintf(codegen.emit_stream as *void, "uya_simd_sse_splat_f32x2(%s.lanes, %s); " as *byte, out_struct as *byte, scalar_name as *byte);
                        } else {
                            fprintf(codegen.emit_stream as *void, "uya_simd_sse_splat_f32x2(&%s.lanes[%d], %s); " as *byte, out_struct as *byte, sp_off, scalar_name as *byte);
                        }
                    } else {
                        if sp_off == 0 {
                            fprintf(codegen.emit_stream as *void, "uya_simd_sse_splat_f32x4(%s.lanes, %s); " as *byte, out_struct as *byte, scalar_name as *byte);
                        } else {
                            fprintf(codegen.emit_stream as *void, "uya_simd_sse_splat_f32x4(&%s.lanes[%d], %s); " as *byte, out_struct as *byte, sp_off, scalar_name as *byte);
                        }
                    }
                } else {
                    if lanes == 2 {
                        if sp_off == 0 {
                            fprintf(codegen.emit_stream as *void, "uya_simd_sse_splat_i32x2(%s.lanes, %s); " as *byte, out_struct as *byte, scalar_name as *byte);
                        } else {
                            fprintf(codegen.emit_stream as *void, "uya_simd_sse_splat_i32x2(&%s.lanes[%d], %s); " as *byte, out_struct as *byte, sp_off, scalar_name as *byte);
                        }
                    } else {
                        if sp_off == 0 {
                            fprintf(codegen.emit_stream as *void, "uya_simd_sse_splat_i32x4(%s.lanes, %s); " as *byte, out_struct as *byte, scalar_name as *byte);
                        } else {
                            fprintf(codegen.emit_stream as *void, "uya_simd_sse_splat_i32x4(&%s.lanes[%d], %s); " as *byte, out_struct as *byte, sp_off, scalar_name as *byte);
                        }
                    }
                }
                sp_off = sp_off + sp_step;
            }
            fprintf(codegen.emit_stream as *void, "%s; })" as *byte, out_struct as *byte);
            return 1;
        }
        if c99_simd_sse_x4_tile_lane_count_ok(lanes) != 0 && elem_base != null &&
            (strcmp(elem_base as *byte, "int16_t" as *byte) == 0 || strcmp(elem_base as *byte, "uint16_t" as *byte) == 0) {
            const out_i16: &byte = c99_make_temp_name(codegen, "__uya_sp_o_" as &byte);
            if out_i16 == null {
                return 0;
            }
            fputs("({ " as *byte, codegen.emit_stream as *void);
            fprintf(codegen.emit_stream as *void, "%s %s = (" as *byte, elem_c as *byte, scalar_name as *byte);
            gen_expr(codegen, expr.call_expr_args[0]);
            fputs("); " as *byte, codegen.emit_stream as *void);
            fprintf(codegen.emit_stream as *void, "%s %s; " as *byte, result_c as *byte, out_i16 as *byte);
            var sp16: i32 = 0;
            while sp16 < lanes {
                const rem16: i32 = lanes - sp16;
                if rem16 >= 8 {
                    if strcmp(elem_base as *byte, "int16_t" as *byte) == 0 {
                        if sp16 == 0 {
                            fprintf(codegen.emit_stream as *void, "uya_simd_sse_splat_i16x8(%s.lanes, %s); " as *byte,
                                out_i16 as *byte, scalar_name as *byte);
                        } else {
                            fprintf(codegen.emit_stream as *void, "uya_simd_sse_splat_i16x8(&%s.lanes[%d], %s); " as *byte,
                                out_i16 as *byte, sp16, scalar_name as *byte);
                        }
                    } else {
                        if sp16 == 0 {
                            fprintf(codegen.emit_stream as *void, "uya_simd_sse_splat_u16x8(%s.lanes, %s); " as *byte,
                                out_i16 as *byte, scalar_name as *byte);
                        } else {
                            fprintf(codegen.emit_stream as *void, "uya_simd_sse_splat_u16x8(&%s.lanes[%d], %s); " as *byte,
                                out_i16 as *byte, sp16, scalar_name as *byte);
                        }
                    }
                    sp16 = sp16 + 8;
                } else {
                    if strcmp(elem_base as *byte, "int16_t" as *byte) == 0 {
                        if sp16 == 0 {
                            fprintf(codegen.emit_stream as *void, "uya_simd_sse_splat_i16x4(%s.lanes, %s); " as *byte,
                                out_i16 as *byte, scalar_name as *byte);
                        } else {
                            fprintf(codegen.emit_stream as *void, "uya_simd_sse_splat_i16x4(&%s.lanes[%d], %s); " as *byte,
                                out_i16 as *byte, sp16, scalar_name as *byte);
                        }
                    } else {
                        if sp16 == 0 {
                            fprintf(codegen.emit_stream as *void, "uya_simd_sse_splat_u16x4(%s.lanes, %s); " as *byte,
                                out_i16 as *byte, scalar_name as *byte);
                        } else {
                            fprintf(codegen.emit_stream as *void, "uya_simd_sse_splat_u16x4(&%s.lanes[%d], %s); " as *byte,
                                out_i16 as *byte, sp16, scalar_name as *byte);
                        }
                    }
                    sp16 = sp16 + 4;
                }
            }
            fprintf(codegen.emit_stream as *void, "%s; })" as *byte, out_i16 as *byte);
            return 1;
        }
        if c99_simd_sse_i8_u8_lane_ok(lanes) != 0 && elem_base != null &&
            (strcmp(elem_base as *byte, "int8_t" as *byte) == 0 || strcmp(elem_base as *byte, "uint8_t" as *byte) == 0) {
            const out_i8: &byte = c99_make_temp_name(codegen, "__uya_sp_o_" as &byte);
            if out_i8 == null {
                return 0;
            }
            fputs("({ " as *byte, codegen.emit_stream as *void);
            fprintf(codegen.emit_stream as *void, "%s %s = (" as *byte, elem_c as *byte, scalar_name as *byte);
            gen_expr(codegen, expr.call_expr_args[0]);
            fputs("); " as *byte, codegen.emit_stream as *void);
            fprintf(codegen.emit_stream as *void, "%s %s; " as *byte, result_c as *byte, out_i8 as *byte);
            var sp8: i32 = 0;
            while sp8 < lanes {
                const rem_i8: i32 = lanes - sp8;
                if strcmp(elem_base as *byte, "int8_t" as *byte) == 0 {
                    if rem_i8 >= 16 {
                        if sp8 == 0 {
                            fprintf(codegen.emit_stream as *void, "uya_simd_sse_splat_i8x16(%s.lanes, %s); " as *byte,
                                out_i8 as *byte, scalar_name as *byte);
                        } else {
                            fprintf(codegen.emit_stream as *void, "uya_simd_sse_splat_i8x16(&%s.lanes[%d], %s); " as *byte,
                                out_i8 as *byte, sp8, scalar_name as *byte);
                        }
                        sp8 = sp8 + 16;
                    } else if rem_i8 >= 8 {
                        if sp8 == 0 {
                            fprintf(codegen.emit_stream as *void, "uya_simd_sse_splat_i8x8(%s.lanes, %s); " as *byte,
                                out_i8 as *byte, scalar_name as *byte);
                        } else {
                            fprintf(codegen.emit_stream as *void, "uya_simd_sse_splat_i8x8(&%s.lanes[%d], %s); " as *byte,
                                out_i8 as *byte, sp8, scalar_name as *byte);
                        }
                        sp8 = sp8 + 8;
                    } else if rem_i8 >= 4 {
                        if sp8 == 0 {
                            fprintf(codegen.emit_stream as *void, "uya_simd_sse_splat_i8x4(%s.lanes, %s); " as *byte,
                                out_i8 as *byte, scalar_name as *byte);
                        } else {
                            fprintf(codegen.emit_stream as *void, "uya_simd_sse_splat_i8x4(&%s.lanes[%d], %s); " as *byte,
                                out_i8 as *byte, sp8, scalar_name as *byte);
                        }
                        sp8 = sp8 + 4;
                    } else {
                        if sp8 == 0 {
                            fprintf(codegen.emit_stream as *void, "uya_simd_sse_splat_i8x2(%s.lanes, %s); " as *byte,
                                out_i8 as *byte, scalar_name as *byte);
                        } else {
                            fprintf(codegen.emit_stream as *void, "uya_simd_sse_splat_i8x2(&%s.lanes[%d], %s); " as *byte,
                                out_i8 as *byte, sp8, scalar_name as *byte);
                        }
                        sp8 = sp8 + 2;
                    }
                } else {
                    if rem_i8 >= 16 {
                        if sp8 == 0 {
                            fprintf(codegen.emit_stream as *void, "uya_simd_sse_splat_u8x16(%s.lanes, %s); " as *byte,
                                out_i8 as *byte, scalar_name as *byte);
                        } else {
                            fprintf(codegen.emit_stream as *void, "uya_simd_sse_splat_u8x16(&%s.lanes[%d], %s); " as *byte,
                                out_i8 as *byte, sp8, scalar_name as *byte);
                        }
                        sp8 = sp8 + 16;
                    } else if rem_i8 >= 8 {
                        if sp8 == 0 {
                            fprintf(codegen.emit_stream as *void, "uya_simd_sse_splat_u8x8(%s.lanes, %s); " as *byte,
                                out_i8 as *byte, scalar_name as *byte);
                        } else {
                            fprintf(codegen.emit_stream as *void, "uya_simd_sse_splat_u8x8(&%s.lanes[%d], %s); " as *byte,
                                out_i8 as *byte, sp8, scalar_name as *byte);
                        }
                        sp8 = sp8 + 8;
                    } else if rem_i8 >= 4 {
                        if sp8 == 0 {
                            fprintf(codegen.emit_stream as *void, "uya_simd_sse_splat_u8x4(%s.lanes, %s); " as *byte,
                                out_i8 as *byte, scalar_name as *byte);
                        } else {
                            fprintf(codegen.emit_stream as *void, "uya_simd_sse_splat_u8x4(&%s.lanes[%d], %s); " as *byte,
                                out_i8 as *byte, sp8, scalar_name as *byte);
                        }
                        sp8 = sp8 + 4;
                    } else {
                        if sp8 == 0 {
                            fprintf(codegen.emit_stream as *void, "uya_simd_sse_splat_u8x2(%s.lanes, %s); " as *byte,
                                out_i8 as *byte, scalar_name as *byte);
                        } else {
                            fprintf(codegen.emit_stream as *void, "uya_simd_sse_splat_u8x2(&%s.lanes[%d], %s); " as *byte,
                                out_i8 as *byte, sp8, scalar_name as *byte);
                        }
                        sp8 = sp8 + 2;
                    }
                }
            }
            fprintf(codegen.emit_stream as *void, "%s; })" as *byte, out_i8 as *byte);
            return 1;
        }
        if c99_simd_sse_i64_u64_lane_ok(lanes) != 0 && elem_base != null &&
            (strcmp(elem_base as *byte, "int64_t" as *byte) == 0 || strcmp(elem_base as *byte, "uint64_t" as *byte) == 0) {
            const out_i64: &byte = c99_make_temp_name(codegen, "__uya_sp_o_" as &byte);
            if out_i64 == null {
                return 0;
            }
            fputs("({ " as *byte, codegen.emit_stream as *void);
            fprintf(codegen.emit_stream as *void, "%s %s = (" as *byte, elem_c as *byte, scalar_name as *byte);
            gen_expr(codegen, expr.call_expr_args[0]);
            fputs("); " as *byte, codegen.emit_stream as *void);
            fprintf(codegen.emit_stream as *void, "%s %s; " as *byte, result_c as *byte, out_i64 as *byte);
            var sp64: i32 = 0;
            while sp64 < lanes {
                if strcmp(elem_base as *byte, "int64_t" as *byte) == 0 {
                    if sp64 == 0 {
                        fprintf(codegen.emit_stream as *void, "uya_simd_sse_splat_i64x2(%s.lanes, %s); " as *byte,
                            out_i64 as *byte, scalar_name as *byte);
                    } else {
                        fprintf(codegen.emit_stream as *void, "uya_simd_sse_splat_i64x2(&%s.lanes[%d], %s); " as *byte,
                            out_i64 as *byte, sp64, scalar_name as *byte);
                    }
                } else {
                    if sp64 == 0 {
                        fprintf(codegen.emit_stream as *void, "uya_simd_sse_splat_u64x2(%s.lanes, %s); " as *byte,
                            out_i64 as *byte, scalar_name as *byte);
                    } else {
                        fprintf(codegen.emit_stream as *void, "uya_simd_sse_splat_u64x2(&%s.lanes[%d], %s); " as *byte,
                            out_i64 as *byte, sp64, scalar_name as *byte);
                    }
                }
                sp64 = sp64 + 2;
            }
            fprintf(codegen.emit_stream as *void, "%s; })" as *byte, out_i64 as *byte);
            return 1;
        }
        fputs("({ " as *byte, codegen.emit_stream as *void);
        fprintf(codegen.emit_stream as *void, "%s %s = (" as *byte, elem_c as *byte, scalar_name as *byte);
        gen_expr(codegen, expr.call_expr_args[0]);
        fputs("); (" as *byte, codegen.emit_stream as *void);
        fprintf(codegen.emit_stream as *void, "%s){" as *byte, result_c as *byte);
        fputs(".lanes = {" as *byte, codegen.emit_stream as *void);
        var i: i32 = 0;
        while i < lanes {
            if i > 0 {
                fputs(", " as *byte, codegen.emit_stream as *void);
            }
            fprintf(codegen.emit_stream as *void, "%s" as *byte, scalar_name as *byte);
            i = i + 1;
        }
        fputs("} }; })" as *byte, codegen.emit_stream as *void);
        return 1;
    }

    if str_equals(method_name, "load" as *byte) != 0 {
        var target_ld: &ASTNode = expr.simd_splat_target_type;
        if target_ld == null && codegen.expected_type != null {
            target_ld = c99_resolve_simd_type_ast_from_type_node(codegen, codegen.expected_type);
        }
        if target_ld == null && codegen.current_function_return_type != null {
            target_ld = c99_resolve_simd_type_ast_from_type_node(codegen, codegen.current_function_return_type);
        }
        if target_ld == null || target_ld.type != ASTNodeType.AST_TYPE_VECTOR ||
            target_ld.type_vector_element_type == null || target_ld.type_vector_size_expr == null {
            return 0;
        }
        const result_ld: &byte = c99_type_to_c(codegen, target_ld);
        const lanes_ld: i32 = eval_const_expr(codegen, target_ld.type_vector_size_expr);
        const tmp_ld: &byte = c99_make_temp_name(codegen, "__uya_simd_load_" as &byte);
        if result_ld == null || tmp_ld == null || lanes_ld <= 0 {
            return 0;
        }
        fputs("({ " as *byte, codegen.emit_stream as *void);
        fprintf(codegen.emit_stream as *void, "%s %s; __uya_memcpy(&%s, (const void*)(" as *byte, result_ld as *byte, tmp_ld as *byte, tmp_ld as *byte);
        gen_expr(codegen, expr.call_expr_args[0]);
        fprintf(codegen.emit_stream as *void, "), sizeof(%s)); %s; })" as *byte, tmp_ld as *byte, tmp_ld as *byte);
        return 1;
    }

    if str_equals(method_name, "any" as *byte) != 0 || str_equals(method_name, "all" as *byte) != 0 {
        const mask_ast: &ASTNode = c99_resolve_simd_type_ast_from_expr(codegen, expr.call_expr_args[0]);
        if mask_ast == null || mask_ast.type != ASTNodeType.AST_TYPE_MASK || mask_ast.type_mask_size_expr == null {
            return 0;
        }
        const mask_c: &byte = c99_type_to_c(codegen, mask_ast);
        const mask_name: &byte = c99_make_temp_name(codegen, "__uya_simd_mask_" as &byte);
        const lanes: i32 = eval_const_expr(codegen, mask_ast.type_mask_size_expr);
        if mask_c == null || mask_name == null || lanes <= 0 {
            return 0;
        }
        fputs("({ " as *byte, codegen.emit_stream as *void);
        fprintf(codegen.emit_stream as *void, "%s %s = " as *byte, mask_c as *byte, mask_name as *byte);
        gen_expr(codegen, expr.call_expr_args[0]);
        fputs("; (" as *byte, codegen.emit_stream as *void);
        var i: i32 = 0;
        while i < lanes {
            if i > 0 {
                if str_equals(method_name, "all" as *byte) != 0 {
                    fputs(" && " as *byte, codegen.emit_stream as *void);
                } else {
                    fputs(" || " as *byte, codegen.emit_stream as *void);
                }
            }
            fprintf(codegen.emit_stream as *void, "%s.lanes[%d]" as *byte, mask_name as *byte, i);
            i = i + 1;
        }
        fputs("); })" as *byte, codegen.emit_stream as *void);
        return 1;
    }

    return 0;
}

fn c99_gen_simd_binary_expr(codegen: &C99CodeGenerator, expr: &ASTNode) i32 {
    if codegen == null || expr == null {
        return 0;
    }
    var left_type_ast: &ASTNode = c99_resolve_simd_type_ast_from_expr(codegen, expr.binary_expr_left);
    var right_type_ast: &ASTNode = c99_resolve_simd_type_ast_from_expr(codegen, expr.binary_expr_right);
    if left_type_ast == null && right_type_ast != null && c99_expr_is_vector_splat(expr.binary_expr_left) != 0 {
        left_type_ast = right_type_ast;
    }
    if right_type_ast == null && left_type_ast != null && c99_expr_is_vector_splat(expr.binary_expr_right) != 0 {
        right_type_ast = left_type_ast;
    }
    const result_type_ast: &ASTNode = c99_resolve_simd_type_ast_from_expr(codegen, expr);
    if left_type_ast == null || right_type_ast == null || result_type_ast == null ||
        (result_type_ast.type != ASTNodeType.AST_TYPE_VECTOR && result_type_ast.type != ASTNodeType.AST_TYPE_MASK) {
        return 0;
    }
    const left_c: &byte = c99_type_to_c(codegen, left_type_ast);
    const right_c: &byte = c99_type_to_c(codegen, right_type_ast);
    const result_c: &byte = c99_type_to_c(codegen, result_type_ast);
    const left_name: &byte = c99_make_temp_name(codegen, "__uya_simd_l_" as &byte);
    const right_name: &byte = c99_make_temp_name(codegen, "__uya_simd_r_" as &byte);
    const result_name: &byte = c99_make_temp_name(codegen, "__uya_simd_res_" as &byte);
    var lanes: i32 = 0;
    if result_type_ast.type == ASTNodeType.AST_TYPE_VECTOR && result_type_ast.type_vector_size_expr != null {
        lanes = eval_const_expr(codegen, result_type_ast.type_vector_size_expr);
    } else if result_type_ast.type == ASTNodeType.AST_TYPE_MASK && result_type_ast.type_mask_size_expr != null {
        lanes = eval_const_expr(codegen, result_type_ast.type_mask_size_expr);
    }
    if left_c == null || right_c == null || result_c == null || left_name == null || right_name == null || result_name == null ||
        lanes <= 0 {
        return 0;
    }

    fputs("({ " as *byte, codegen.emit_stream as *void);
    fprintf(codegen.emit_stream as *void, "%s %s = " as *byte, left_c as *byte, left_name as *byte);
    gen_expr(codegen, expr.binary_expr_left);
    fputs("; " as *byte, codegen.emit_stream as *void);
    fprintf(codegen.emit_stream as *void, "%s %s = " as *byte, right_c as *byte, right_name as *byte);
    gen_expr(codegen, expr.binary_expr_right);
    fputs("; " as *byte, codegen.emit_stream as *void);
    fprintf(codegen.emit_stream as *void, "%s %s; " as *byte, result_c as *byte, result_name as *byte);

    const simd_op_tmp: !TokenType = expr.binary_expr_op as! TokenType;
    const simd_op: TokenType = simd_op_tmp.value;
    if result_type_ast.type == ASTNodeType.AST_TYPE_VECTOR && result_type_ast.type_vector_element_type != null &&
        (simd_op == TokenType.TOKEN_PLUS_PIPE || simd_op == TokenType.TOKEN_MINUS_PIPE || simd_op == TokenType.TOKEN_ASTERISK_PIPE ||
        simd_op == TokenType.TOKEN_PLUS_PERCENT || simd_op == TokenType.TOKEN_MINUS_PERCENT || simd_op == TokenType.TOKEN_ASTERISK_PERCENT) {
        const elem_c: &byte = c99_type_to_c(codegen, result_type_ast.type_vector_element_type);
        if elem_c == null {
            return 0;
        }
        var base_type: &byte = elem_c;
        if elem_c != null && strncmp(elem_c as *byte, "const " as *byte, 6) == 0 {
            base_type = (elem_c as *byte + 6) as &byte;
        }
        if base_type == null {
            base_type = "int32_t" as &byte;
        }
        var j: i32 = 0;
        while j < lanes {
            fprintf(codegen.emit_stream as *void, "%s.lanes[%d] = " as *byte, result_name as *byte, j);
            c99_emit_simd_lane_sat_wrap(codegen, simd_op, elem_c, base_type, left_name, right_name, j);
            fputs("; " as *byte, codegen.emit_stream as *void);
            j = j + 1;
        }
        fprintf(codegen.emit_stream as *void, "%s; })" as *byte, result_name as *byte);
        return 1;
    }

    if c99_simd_try_emit_x86_sse_binary(codegen, result_type_ast, left_type_ast, simd_op, result_name, left_name, right_name, lanes) == 0 {
        c99_simd_emit_per_lane_binary_assign(codegen, result_name, left_name, right_name, lanes, simd_op);
    }

    fprintf(codegen.emit_stream as *void, "%s; })" as *byte, result_name as *byte);
    return 1;
}

fn c99_gen_simd_unary_expr(codegen: &C99CodeGenerator, expr: &ASTNode) i32 {
    if codegen == null || expr == null || expr.unary_expr_operand == null {
        return 0;
    }
    const operand_type_ast: &ASTNode = c99_resolve_simd_type_ast_from_expr(codegen, expr.unary_expr_operand);
    const result_type_ast: &ASTNode = operand_type_ast;
    if result_type_ast == null || operand_type_ast == null ||
        (result_type_ast.type != ASTNodeType.AST_TYPE_VECTOR && result_type_ast.type != ASTNodeType.AST_TYPE_MASK) {
        return 0;
    }
    const unary_op_tmp: !TokenType = expr.unary_expr_op as! TokenType;
    const unary_op: TokenType = unary_op_tmp.value;
    if unary_op != TokenType.TOKEN_EXCLAMATION &&
        unary_op != TokenType.TOKEN_MINUS &&
        unary_op != TokenType.TOKEN_TILDE {
        return 0;
    }
    const operand_c: &byte = c99_type_to_c(codegen, operand_type_ast);
    const result_c: &byte = c99_type_to_c(codegen, result_type_ast);
    const operand_name: &byte = c99_make_temp_name(codegen, "__uya_simd_in_" as &byte);
    const result_name: &byte = c99_make_temp_name(codegen, "__uya_simd_out_" as &byte);
    var lanes: i32 = 0;
    if result_type_ast.type == ASTNodeType.AST_TYPE_VECTOR && result_type_ast.type_vector_size_expr != null {
        lanes = eval_const_expr(codegen, result_type_ast.type_vector_size_expr);
    } else if result_type_ast.type == ASTNodeType.AST_TYPE_MASK && result_type_ast.type_mask_size_expr != null {
        lanes = eval_const_expr(codegen, result_type_ast.type_mask_size_expr);
    }
    if operand_c == null || result_c == null || operand_name == null || result_name == null || lanes <= 0 {
        return 0;
    }

    fputs("({ " as *byte, codegen.emit_stream as *void);
    fprintf(codegen.emit_stream as *void, "%s %s = " as *byte, operand_c as *byte, operand_name as *byte);
    gen_expr(codegen, expr.unary_expr_operand);
    fputs("; " as *byte, codegen.emit_stream as *void);
    fprintf(codegen.emit_stream as *void, "%s %s; " as *byte, result_c as *byte, result_name as *byte);

    if unary_op == TokenType.TOKEN_MINUS {
        if c99_simd_try_emit_x86_sse_unary_minus(codegen, result_type_ast, result_name, operand_name, lanes) != 0 {
            fprintf(codegen.emit_stream as *void, "%s; })" as *byte, result_name as *byte);
            return 1;
        }
    }

    var i: i32 = 0;
    while i < lanes {
        fprintf(codegen.emit_stream as *void, "%s.lanes[%d] = (" as *byte, result_name as *byte, i);
        if unary_op == TokenType.TOKEN_EXCLAMATION {
            fputs("!" as *byte, codegen.emit_stream as *void);
        } else if unary_op == TokenType.TOKEN_MINUS {
            fputs("-" as *byte, codegen.emit_stream as *void);
        } else if unary_op == TokenType.TOKEN_TILDE {
            fputs("~" as *byte, codegen.emit_stream as *void);
        }
        fprintf(codegen.emit_stream as *void, "%s.lanes[%d]); " as *byte, operand_name as *byte, i);
        i = i + 1;
    }

    fprintf(codegen.emit_stream as *void, "%s; })" as *byte, result_name as *byte);
    return 1;
}

fn gen_binary_expr(codegen: &C99CodeGenerator, expr: &ASTNode) void {
        const left: &ASTNode = expr.binary_expr_left;
        const right: &ASTNode = expr.binary_expr_right;
        const op_tmp: !TokenType = expr.binary_expr_op as! TokenType;
        const op: TokenType = op_tmp.value;
        
        if left == null || right == null {
            fputs("0" as *byte, codegen.emit_stream as *void);
            return;
        }
        if c99_gen_simd_binary_expr(codegen, expr) != 0 {
            return;
        }
        // 错误类型比较：err == error.X 或 error.X == err -> .error_id 比较
        if op == TokenType.TOKEN_EQUAL || op == TokenType.TOKEN_NOT_EQUAL {
            if gen_error_value_comparison(codegen, left, right, op) != 0 {
                return;
            }
        }
        
        // 检查是否是结构体比较（== 或 !=）
        var is_struct_comparison: i32 = 0;
        if (op == TokenType.TOKEN_EQUAL || op == TokenType.TOKEN_NOT_EQUAL) && left != null && right != null {
            // 检查左操作数是否是结构体类型
            if left.type == ASTNodeType.AST_IDENTIFIER {
                if is_identifier_struct_type(codegen, left.identifier_name) != 0 {
                    is_struct_comparison = 1;
                }
            } else if left.type == ASTNodeType.AST_STRUCT_INIT {
                is_struct_comparison = 1;
            }
        }
        
        if is_struct_comparison != 0 {
            // 解析出结构体声明，空结构体直接输出 (1)/(0)
            var struct_decl: &ASTNode = null;
            if left.type == ASTNodeType.AST_IDENTIFIER {
                const type_c: &byte = get_identifier_type_c(codegen, left.identifier_name);
                if type_c != null {
                    const struct_prefix: *byte = strstr(type_c as *byte, "struct " as *byte);
                    if struct_prefix != null {
                        const name_start: &byte = (struct_prefix + 7) as &byte;
                        struct_decl = find_struct_decl_c99(codegen, name_start);
                    }
                }
            } else if left.type == ASTNodeType.AST_STRUCT_INIT {
                struct_decl = find_struct_decl_c99(codegen, left.struct_init_struct_name);
            }
            if struct_decl != null && struct_decl.struct_decl_field_count == 0 {
                if op == TokenType.TOKEN_EQUAL {
                    fputs("(1)" as *byte, codegen.emit_stream as *void);
                } else if op == TokenType.TOKEN_NOT_EQUAL {
                    fputs("(0)" as *byte, codegen.emit_stream as *void);
                }
            } else if struct_decl != null && struct_decl.type == ASTNodeType.AST_STRUCT_DECL && struct_decl.struct_decl_field_count > 0 {
                // 按字段比较，与 C 编译器一致，避免 padding 未初始化导致 memcmp 结果错误
                if op == TokenType.TOKEN_NOT_EQUAL {
                    fputs("(!(" as *byte, codegen.emit_stream as *void);
                } else {
                    fputc(40, codegen.emit_stream as *void);  // '('
                }
                var i: i32 = 0;
                while i < struct_decl.struct_decl_field_count {
                    const field: &ASTNode = struct_decl.struct_decl_fields[i];
                    if field != null && field.type == ASTNodeType.AST_VAR_DECL {
                        const field_type: &ASTNode = field.var_decl_type;
                        const safe_field: &byte = get_safe_c_identifier(codegen, field.var_decl_name);
                        if safe_field != null {
                            var field_needs_memcmp: i32 = 0;
                            if field_type != null {
                                if field_type.type == ASTNodeType.AST_TYPE_NAMED {
                                    const type_name: &byte = field_type.type_named_name;
                                    if type_name != null && find_struct_decl_c99(codegen, type_name) != null {
                                        field_needs_memcmp = 1;
                                    }
                                } else if field_type.type == ASTNodeType.AST_TYPE_ARRAY {
                                    field_needs_memcmp = 1;
                                }
                            }
                            gen_struct_field_comparison(codegen, left, right, field);
                            if i < struct_decl.struct_decl_field_count - 1 {
                                fputs(" && " as *byte, codegen.emit_stream as *void);
                            }
                        }
                    }
                    i = i + 1;
                }
                fputc(41, codegen.emit_stream as *void);  // ')'
                if op == TokenType.TOKEN_NOT_EQUAL {
                    fputc(41, codegen.emit_stream as *void);  // ')'
                }
            } else {
                // 回退：无法按字段比较时用 memcmp
                gen_struct_memcmp_comparison(codegen, left, right, op);
            }
        } else if op == TokenType.TOKEN_PLUS_PIPE || op == TokenType.TOKEN_MINUS_PIPE || op == TokenType.TOKEN_ASTERISK_PIPE ||
            op == TokenType.TOKEN_PLUS_PERCENT || op == TokenType.TOKEN_MINUS_PERCENT || op == TokenType.TOKEN_ASTERISK_PERCENT {
            // 饱和运算 +| -| *| 或包装运算 +% -% *%
            var type_c: &byte = get_c_type_of_expr(codegen, left);
            if type_c == null { type_c = "int32_t" as &byte; }
            if op == TokenType.TOKEN_PLUS_PIPE || op == TokenType.TOKEN_MINUS_PIPE || op == TokenType.TOKEN_ASTERISK_PIPE {
                var base_type: &byte = type_c;
                if type_c != null && strncmp(type_c as *byte, "const " as *byte, 6) == 0 { base_type = (type_c as *byte + 6) as &byte; }
                if base_type == null { base_type = "int32_t" as &byte; }
                fputs("({ " as *byte, codegen.emit_stream as *void);
                fprintf(codegen.emit_stream as *void, "%s _l = (" as *byte, base_type as *byte);
                gen_expr(codegen, left);
                fputs("); " as *byte, codegen.emit_stream as *void);
                fprintf(codegen.emit_stream as *void, "%s _r = (" as *byte, base_type as *byte);
                gen_expr(codegen, right);
                fputs("); " as *byte, codegen.emit_stream as *void);
                fprintf(codegen.emit_stream as *void, "%s _s; " as *byte, base_type as *byte);
                if op == TokenType.TOKEN_PLUS_PIPE {
                    fputs("__builtin_add_overflow(_l, _r, &_s) ? (_l>=0 && _r>=0 ? " as *byte, codegen.emit_stream as *void);
                } else if op == TokenType.TOKEN_MINUS_PIPE {
                    fputs("__builtin_sub_overflow(_l, _r, &_s) ? (_l>=0 && _r<0 ? " as *byte, codegen.emit_stream as *void);
                } else {
                    fprintf(codegen.emit_stream as *void, "%s _res; " as *byte, base_type as *byte);
                    fputs("if (__builtin_mul_overflow(_l, _r, &_s)) _res = ((_l>=0 && _r>=0) || (_l<0 && _r<0)) ? " as *byte, codegen.emit_stream as *void);
                }
                gen_saturate_limit_from_type_c(codegen, type_c, 1);
                fputs(" : " as *byte, codegen.emit_stream as *void);
                gen_saturate_limit_from_type_c(codegen, type_c, 0);
                if op == TokenType.TOKEN_ASTERISK_PIPE {
                    fputs("; else _res = _s; _res; })" as *byte, codegen.emit_stream as *void);
                } else {
                    fputs(") : _s; })" as *byte, codegen.emit_stream as *void);
                }
            } else {
                const ut: &byte = unsigned_type_for_wrapping(type_c);
                fprintf(codegen.emit_stream as *void, "((%s)((%s)(" as *byte, type_c as *byte, ut as *byte);
                gen_expr(codegen, left);
                if op == TokenType.TOKEN_PLUS_PERCENT { fputs(") + (" as *byte, codegen.emit_stream as *void); }
                else if op == TokenType.TOKEN_MINUS_PERCENT { fputs(") - (" as *byte, codegen.emit_stream as *void); }
                else { fputs(") * (" as *byte, codegen.emit_stream as *void); }
                fprintf(codegen.emit_stream as *void, "%s)(" as *byte, ut as *byte);
                gen_expr(codegen, right);
                fputs(")))" as *byte, codegen.emit_stream as *void);
            }
        } else {
            // 普通二元表达式
            fputc(40, codegen.emit_stream as *void);  // '('
            gen_expr(codegen, left);
            // 操作符映射
            if op == TokenType.TOKEN_PLUS {
                fputs(" + " as *byte, codegen.emit_stream as *void);
            } else if op == TokenType.TOKEN_MINUS {
                fputs(" - " as *byte, codegen.emit_stream as *void);
            } else if op == TokenType.TOKEN_ASTERISK {
                fputs(" * " as *byte, codegen.emit_stream as *void);
            } else if op == TokenType.TOKEN_SLASH {
                fputs(" / " as *byte, codegen.emit_stream as *void);
            } else if op == TokenType.TOKEN_PERCENT {
                fputs(" % " as *byte, codegen.emit_stream as *void);
            } else if op == TokenType.TOKEN_EQUAL {
                fputs(" == " as *byte, codegen.emit_stream as *void);
            } else if op == TokenType.TOKEN_NOT_EQUAL {
                fputs(" != " as *byte, codegen.emit_stream as *void);
            } else if op == TokenType.TOKEN_LESS {
                fputs(" < " as *byte, codegen.emit_stream as *void);
            } else if op == TokenType.TOKEN_GREATER {
                fputs(" > " as *byte, codegen.emit_stream as *void);
            } else if op == TokenType.TOKEN_LESS_EQUAL {
                fputs(" <= " as *byte, codegen.emit_stream as *void);
            } else if op == TokenType.TOKEN_GREATER_EQUAL {
                fputs(" >= " as *byte, codegen.emit_stream as *void);
            } else if op == TokenType.TOKEN_LOGICAL_AND {
                fputs(" && " as *byte, codegen.emit_stream as *void);
            } else if op == TokenType.TOKEN_LOGICAL_OR {
                fputs(" || " as *byte, codegen.emit_stream as *void);
            } else if op == TokenType.TOKEN_AMPERSAND {
                fputs(" & " as *byte, codegen.emit_stream as *void);
            } else if op == TokenType.TOKEN_PIPE {
                fputs(" | " as *byte, codegen.emit_stream as *void);
            } else if op == TokenType.TOKEN_CARET {
                fputs(" ^ " as *byte, codegen.emit_stream as *void);
            } else if op == TokenType.TOKEN_LSHIFT {
                fputs(" << " as *byte, codegen.emit_stream as *void);
            } else if op == TokenType.TOKEN_RSHIFT {
                fputs(" >> " as *byte, codegen.emit_stream as *void);
            } else {
                fputs(" + " as *byte, codegen.emit_stream as *void); // 默认为加法
            }
            gen_expr(codegen, right);
            fputc(41, codegen.emit_stream as *void);  // ')'
        }
}

// 生成成员访问表达式
fn gen_member_access(codegen: &C99CodeGenerator, expr: &ASTNode) void {
        const object: &ASTNode = expr.member_access_object;
        const field_name: &byte = expr.member_access_field_name;
        
        if object == null || field_name == null {
            return;
        }
        
        // 模块限定访问（module.item）：输出模块前缀项名
        if expr.member_access_is_module_access != 0 {
            const module_name: &byte = expr.member_access_module_name;
            if module_name != null && field_name != null {
                if strcmp(module_name as *byte, "std" as *byte) == 0 {
                    const variant_name: &byte = std_cfg_current_value(field_name);
                    const builtin_enum_name: &byte = std_cfg_selector_enum_name(field_name);
                    if variant_name != null && builtin_enum_name != null {
                        const safe_enum_name: &byte = get_safe_c_identifier(codegen, builtin_enum_name);
                        const safe_variant_name: &byte = get_safe_c_identifier(codegen, variant_name);
                        fputs(safe_enum_name as *byte, codegen.emit_stream as *void);
                        fputc(95, codegen.emit_stream as *void);
                        fputs(safe_variant_name as *byte, codegen.emit_stream as *void);
                        return;
                    }
                }
                // 生成模块前缀名称（module_name.item_name -> module_name_item_name）
                var prefixed_name: [i8: NAME_BUF_SIZE] = [];
                var pi: i32 = 0;
                var p: &i8 = module_name as &i8;
                while p[0] != 0 && pi < NAME_BUF_SIZE / 2 {
                    if p[0] == 46 {  // '.'
                        prefixed_name[pi] = 95;  // '_'
                    } else {
                        prefixed_name[pi] = p[0];
                    }
                    pi = pi + 1;
                    p = p + 1;
                }
                if pi >= 0 && pi < NAME_BUF_SIZE {
                    prefixed_name[pi] = 95;  // '_'
                }
                pi = pi + 1;
                p = field_name as &i8;
                while p[0] != 0 && pi < NAME_BUF_SIZE - 6 {
                    prefixed_name[pi] = p[0];
                    pi = pi + 1;
                    p = p + 1;
                }
                if pi >= 0 && pi < NAME_BUF_SIZE {
                    prefixed_name[pi] = 0;
                }
                
                const safe_name: &byte = get_safe_c_identifier(codegen, &prefixed_name[0]);
                fprintf(codegen.emit_stream as *void, "%s" as *byte, safe_name as *byte);
            } else {
                const safe_name: &byte = get_safe_c_identifier(codegen, field_name);
                fprintf(codegen.emit_stream as *void, "%s" as *byte, safe_name as *byte);
            }
            return;
        }
        
        // libc.stderr/stdin/stdout：输出裸名以匹配 C 标准（C 使用 stderr 而非 libc.stderr）
        if object.type == ASTNodeType.AST_IDENTIFIER && object.identifier_name != null {
            const object_type_c: &byte = get_identifier_type_c(codegen, object.identifier_name);
            if object_type_c == null && strcmp(object.identifier_name as *byte, "std" as *byte) == 0 && field_name != null {
                const variant_name2: &byte = std_cfg_current_value(field_name);
                const builtin_enum_name2: &byte = std_cfg_selector_enum_name(field_name);
                if variant_name2 != null && builtin_enum_name2 != null {
                    const safe_enum_name2: &byte = get_safe_c_identifier(codegen, builtin_enum_name2);
                    const safe_variant_name2: &byte = get_safe_c_identifier(codegen, variant_name2);
                    fputs(safe_enum_name2 as *byte, codegen.emit_stream as *void);
                    fputc(95, codegen.emit_stream as *void);
                    fputs(safe_variant_name2 as *byte, codegen.emit_stream as *void);
                    return;
                }
            }
            if object_type_c == null && strcmp(object.identifier_name as *byte, "libc" as *byte) == 0 && field_name != null {
                if strcmp(field_name as *byte, "stderr" as *byte) == 0 || strcmp(field_name as *byte, "stdin" as *byte) == 0 || strcmp(field_name as *byte, "stdout" as *byte) == 0 {
                    fprintf(codegen.emit_stream as *void, "%s" as *byte, field_name as *byte);
                    return;
                }
            }
            // syscall.xxx：无 member_access_module_name 时回退为 syscall_xxx（标准库 syscall 层）
            if object_type_c == null && strcmp(object.identifier_name as *byte, "syscall" as *byte) == 0 && field_name != null {
                var fallback_name: [i8: NAME_BUF_SIZE] = [];
                var fi: i32 = 0;
                var fp: &i8 = ("syscall_" as *byte) as &i8;
                while fp[0] != 0 && fi < NAME_BUF_SIZE - 1 {
                    fallback_name[fi] = fp[0];
                    fi = fi + 1;
                    fp = fp + 1;
                }
                fp = field_name as &i8;
                while fp[0] != 0 && fi < NAME_BUF_SIZE - 1 {
                    fallback_name[fi] = fp[0];
                    fi = fi + 1;
                    fp = fp + 1;
                }
                if fi < NAME_BUF_SIZE { fallback_name[fi] = 0; }
                const safe_fb: &byte = get_safe_c_identifier(codegen, &fallback_name[0]);
                fprintf(codegen.emit_stream as *void, "%s" as *byte, safe_fb as *byte);
                return;
            }
        }
        
        // 检查是否是枚举值访问（EnumName.Variant）
        if object.type == ASTNodeType.AST_IDENTIFIER {
            const enum_name: &byte = object.identifier_name;
            if enum_name != null {
                // 检查是否是枚举类型名称（不检查变量表，直接检查枚举声明）
                const enum_decl: &ASTNode = find_enum_decl_c99(codegen, enum_name);
                if enum_decl != null {
                    // 是枚举类型，查找变体值
                    const enum_value: i32 = find_enum_variant_value(codegen, enum_decl, field_name);
                    if enum_value >= 0 {
                        // 找到变体，输出带枚举名前缀的 C 枚举值名称，避免跨枚举重名
                        const safe_enum_name3: &byte = get_safe_c_identifier(codegen, enum_name);
                        const safe_variant_name: &byte = get_safe_c_identifier(codegen, field_name);
                        fputs(safe_enum_name3 as *byte, codegen.emit_stream as *void);
                        fputc(95, codegen.emit_stream as *void);
                        fputs(safe_variant_name as *byte, codegen.emit_stream as *void);
                        return;
                    }
                }
            }
        }
        
        // 普通字段访问（结构体字段）或元组下标（.0, .1 -> .f0, .f1）
        var safe_field_name: &byte = null;
        if field_name[0] >= 48 && field_name[0] <= 57 {
            const idx: i32 = atoi(field_name as *byte);
            const buf: &byte = compiler_arena_alloc(codegen.arena, 16) as &byte;
            if buf != null {
                snprintf(buf as *byte, 16, "f%d" as *byte, idx);
                safe_field_name = buf;
            } else {
                safe_field_name = ("f0" as *byte) as &byte;
            }
        } else {
            safe_field_name = get_safe_c_identifier(codegen, field_name);
        }
        if safe_field_name == null {
            safe_field_name = ("f0" as *byte) as &byte;
        }
        
        // 统一基于对象表达式的结果类型决定使用 '.' 还是 '->'。
        // 这样链式访问会自然递归成立，不再依赖局部特判。
        const is_pointer: i32 = is_expr_pointer_type(codegen, object);
        
        // 原子结构体成员：读值须 __atomic_load_n；取址/原子 store 首参时由 atomic_member_plain_lvalue 抑制
        var field_atomic_load_inner: &byte = null;
        if codegen.atomic_member_plain_lvalue == 0 && codegen.emitting_assign_lhs == 0 {
            const struct_decl_ma: &ASTNode = c99_resolve_struct_decl_for_member_object(codegen, object);
            if struct_decl_ma != null {
                const ft_ma: &ASTNode = c99_find_struct_field_type(codegen, struct_decl_ma, field_name);
                if ft_ma != null && ft_ma.type == ASTNodeType.AST_TYPE_ATOMIC {
                    const ftc_ma: &byte = c99_type_to_c(codegen, ft_ma);
                    field_atomic_load_inner = get_atomic_inner_type_c(codegen, ftc_ma);
                }
            }
        }
        if codegen.container_mode != 0 {
            c99_emit_mmu_wrapped_member_access(codegen, object, safe_field_name, is_pointer, field_atomic_load_inner);
            return;
        }

        if field_atomic_load_inner != null {
            fprintf(codegen.emit_stream as *void, "__atomic_load_n((%s *)&(" as *byte, field_atomic_load_inner as *byte);
        }
        
        if codegen.emitting_assign_lhs != 0 && object.type == ASTNodeType.AST_IDENTIFIER && object.identifier_name != null &&
            strcmp(object.identifier_name as *byte, "self" as *byte) == 0 && codegen.current_method_struct_name != null {
            const safe_struct: &byte = get_safe_c_identifier(codegen, codegen.current_method_struct_name);
            if safe_struct != null {
                fprintf(codegen.emit_stream as *void, "((struct %s *)self)" as *byte, safe_struct as *byte);
            } else {
                gen_expr(codegen, object);
            }
        } else {
            gen_expr(codegen, object);
        }
        if is_pointer != 0 {
            // 指针类型使用 -> 操作符
            fprintf(codegen.emit_stream as *void, "->%s" as *byte, safe_field_name as *byte);
        } else {
            // 非指针类型使用 . 操作符
            fprintf(codegen.emit_stream as *void, ".%s" as *byte, safe_field_name as *byte);
        }
        if field_atomic_load_inner != null {
            fputs("), __ATOMIC_SEQ_CST)" as *byte, codegen.emit_stream as *void);
        }
}

// 生成 sizeof 表达式
fn gen_sizeof_expr(codegen: &C99CodeGenerator, expr: &ASTNode) void {
        const target: &ASTNode = expr.sizeof_expr_target;
        const is_type: i32 = expr.sizeof_expr_is_type;
        var emit_target: &ASTNode = target;
        if target != null && is_type != 0 {
            const resolved_target: &ASTNode = substitute_type_arg(codegen, target);
            if resolved_target != null {
                emit_target = resolved_target;
            }
        }
        // @size_of 返回 i32，需要显式转换为 int32_t 避免无符号算术警告
        fputs("(int32_t)sizeof(" as *byte, codegen.emit_stream as *void);
        if emit_target == null {
            fputs("int" as *byte, codegen.emit_stream as *void);
        } else if is_type != 0 {
            // 显式检查是否是结构体类型（即使在 c99_type_to_c 中查找失败）
            if emit_target.type == ASTNodeType.AST_TYPE_NAMED {
                const name: &byte = emit_target.type_named_name;
                if name != null && is_c_keyword(name) == 0 {
                    // 检查是否是结构体（检查是否在表中，不管是否已定义）
                    const safe_name: &byte = get_safe_c_identifier(codegen, name);
                    if is_struct_in_table(codegen, safe_name) != 0 {
                        fprintf(codegen.emit_stream as *void, "struct %s" as *byte, safe_name as *byte);
                    } else {
                        // 如果不在表中，尝试从程序节点中查找结构体声明
                        if codegen.program_node != null {
                            const decl_count: i32 = codegen.program_node.program_decl_count;
                            var found: i32 = 0;
                            var i: i32 = 0;
                            while i < decl_count {
                                const decl: &ASTNode = codegen.program_node.program_decls[i];
                                if decl != null && decl.type == ASTNodeType.AST_STRUCT_DECL {
                                    const struct_name: &byte = decl.struct_decl_name;
                                    if struct_name != null {
                                        const safe_struct_name: &byte = get_safe_c_identifier(codegen, struct_name);
                                        if strcmp(safe_struct_name as *byte, safe_name as *byte) == 0 {
                                            fprintf(codegen.emit_stream as *void, "struct %s" as *byte, safe_name as *byte);
                                            found = 1;
                                            break;
                                        }
                                    }
                                }
                                i = i + 1;
                            }
                            if found == 0 {
                                // 不是结构体，使用默认类型转换
                                const type_c: &byte = c99_type_to_c(codegen, emit_target);
                                fprintf(codegen.emit_stream as *void, "%s" as *byte, type_c as *byte);
                            }
                        } else {
                            const type_c: &byte = c99_type_to_c(codegen, emit_target);
                            fprintf(codegen.emit_stream as *void, "%s" as *byte, type_c as *byte);
                        }
                    }
                } else {
                    const type_c: &byte = c99_type_to_c(codegen, emit_target);
                    fprintf(codegen.emit_stream as *void, "%s" as *byte, type_c as *byte);
                }
            } else {
                const type_c: &byte = c99_type_to_c(codegen, emit_target);
                // 检查是否是数组指针类型（包含 [数字] *，且 * 在末尾）
                const bracket: *byte = strchr(type_c as *byte, 91);  // '['
                const asterisk: *byte = strrchr(type_c as *byte, 42);  // '*' 从后往前找最后一个 *
                if bracket != null && asterisk != null && bracket < asterisk {
                    // 检查 * 是否在末尾（后面只有空格或结束）
                    const asterisk_offset: i32 = ptr_diff(asterisk, type_c as *byte);
                    var after_asterisk_offset: i32 = asterisk_offset + 1;
                    const type_c_len: i32 = strlen(type_c as *byte);
                    while after_asterisk_offset < type_c_len && type_c[after_asterisk_offset] == 32 {  // ' '
                        after_asterisk_offset = after_asterisk_offset + 1;
                    }
                    if after_asterisk_offset >= type_c_len || type_c[after_asterisk_offset] == 0 {
                        // 数组指针类型：T[N] * -> T(*)[N]
                        // 找到 ']' 的位置
                        const close_bracket: *byte = strchr(bracket, 93);  // ']'
                        if close_bracket != null {
                            const base_len: i32 = ptr_diff(bracket, type_c as *byte);
                            const array_spec_len: i32 = ptr_diff(close_bracket, bracket) + 1;
                            // 注意：Uya Mini 不支持 %.*s，需要手动处理
                            var temp_buf: [byte: TEMP_BUF_SIZE] = [];
                            var j: i32 = 0;
                            while j < base_len && j < TEMP_BUF_SIZE - 1 {
                                temp_buf[j] = type_c[j];
                                j = j + 1;
                            }
                            if j >= 0 && j < TEMP_BUF_SIZE {
                                temp_buf[j] = 0;
                            }
                            fprintf(codegen.emit_stream as *void, "%s(*)" as *byte, &temp_buf[0] as *byte);
                            // 输出数组规格
                            j = 0;
                            while j < array_spec_len && j < TEMP_BUF_SIZE - 1 {
                                temp_buf[j] = bracket[j];
                                j = j + 1;
                            }
                            if j >= 0 && j < TEMP_BUF_SIZE {
                                temp_buf[j] = 0;
                            }
                            fprintf(codegen.emit_stream as *void, "%s" as *byte, &temp_buf[0] as *byte);
                        } else {
                            fprintf(codegen.emit_stream as *void, "%s" as *byte, type_c as *byte);
                        }
                    } else {
                        fprintf(codegen.emit_stream as *void, "%s" as *byte, type_c as *byte);
                    }
                } else {
                    fprintf(codegen.emit_stream as *void, "%s" as *byte, type_c as *byte);
                }
            }
        } else {
            // 即使 is_type = 0，也检查是否是结构体标识符（如 sizeof(Point) 中的 Point）
            if target.type == ASTNodeType.AST_IDENTIFIER || target.type == ASTNodeType.AST_TYPE_NAMED {
                var name: &byte = null;
                if target.type == ASTNodeType.AST_IDENTIFIER {
                    name = target.identifier_name;
                } else {
                    name = target.type_named_name;
                }
                if name != null && is_c_keyword(name) == 0 {
                    const safe_name: &byte = get_safe_c_identifier(codegen, name);
                    if is_struct_in_table(codegen, safe_name) != 0 {
                        fprintf(codegen.emit_stream as *void, "struct %s" as *byte, safe_name as *byte);
                    } else {
                        var is_enum: i32 = is_enum_in_table(codegen, safe_name);
                        if is_enum == 0 && find_enum_decl_c99(codegen, safe_name) != null {
                            is_enum = 1;
                        }
                        if is_enum != 0 {
                            fprintf(codegen.emit_stream as *void, "enum %s" as *byte, safe_name as *byte);
                        } else {
                            gen_expr(codegen, target);
                        }
                    }
                } else {
                    gen_expr(codegen, target);
                }
            } else {
                gen_expr(codegen, target);
            }
        }
        fputc(41, codegen.emit_stream as *void);  // ')'
}

// 生成 len 表达式
fn gen_len_expr(codegen: &C99CodeGenerator, expr: &ASTNode) void {
        const array: &ASTNode = expr.len_expr_array;
        
        if array == null {
            fputs("0" as *byte, codegen.emit_stream as *void);
            return;
        }
        if array.type == ASTNodeType.AST_SLICE_EXPR {
            fputc(40, codegen.emit_stream as *void);
            gen_expr(codegen, array);
            fputs(").len" as *byte, codegen.emit_stream as *void);
            return;
        }
        if array.type == ASTNodeType.AST_MEMBER_ACCESS {
            const type_c: &byte = get_c_type_of_expr(codegen, array);
            if type_c != null && strstr(type_c as *byte, "uya_slice_" as *byte) != null {
                gen_expr(codegen, array);
                fputs(".len" as *byte, codegen.emit_stream as *void);
                return;
            }
        }
        if array.type == ASTNodeType.AST_IDENTIFIER {
            const type_c: &byte = get_identifier_type_c(codegen, array.identifier_name);
            if type_c != null && strstr(type_c as *byte, "uya_slice_" as *byte) != null {
                gen_expr(codegen, array);
                fputs(".len" as *byte, codegen.emit_stream as *void);
                return;
            }
        }
        
        // 检查数组表达式是否是标识符（局部变量或参数）
        if array.type == ASTNodeType.AST_IDENTIFIER {
            const var_name: &byte = array.identifier_name;
            
            // 查找变量类型以确定数组大小
            var found: i32 = 0;
            var array_size: i32 = -1;
            
            // 检查局部变量
            var i: i32 = codegen.local_variable_count - 1;
            while i >= 0 {
                if strcmp(codegen.local_variables[i].name as *byte, var_name as *byte) == 0 {
                    const type_c: &byte = codegen.local_variables[i].type_c;
                    if type_c != null {
                        // 从类型字符串中提取数组大小，格式如 "int32_t[3]"
                        const bracket: *byte = strchr(type_c as *byte, 91);  // '['
                        if bracket != null {
                            const bracket_offset: i32 = ptr_diff(bracket, type_c as *byte);
                            const close_bracket: *byte = strchr(&type_c[bracket_offset + 1] as *byte, 93);  // ']'
                            if close_bracket != null {
                                // 提取数字部分
                                const num_len: i32 = ptr_diff(close_bracket, bracket) - 1;
                                var num_buf: [byte: NUM_BUF_SIZE] = [];
                                if num_len < NUM_BUF_SIZE && num_len > 0 {
                                    memcpy(&num_buf[0] as *void, &type_c[bracket_offset + 1] as *void, num_len);
                                    num_buf[num_len] = 0;
                                    array_size = atoi(&num_buf[0] as *byte);
                                    if array_size > 0 {
                                        fprintf(codegen.emit_stream as *void, "%d" as *byte, array_size);
                                        found = 1;
                                        break;
                                    }
                                }
                            }
                        }
                    }
                    break;
                }
                i = i - 1;
            }
            
            // 如果找到数组大小，直接输出
            if found != 0 {
                return;
            }
        }
        
        // 备用方案：使用 sizeof 计算（适用于非参数数组）
        // 注意：这只适用于栈分配的数组，不适用于函数参数
        fputs("sizeof(" as *byte, codegen.emit_stream as *void);
        gen_expr(codegen, array);
        fputs(") / sizeof((" as *byte, codegen.emit_stream as *void);
        gen_expr(codegen, array);
        fputs(")[0])" as *byte, codegen.emit_stream as *void);
}

// 生成结构体初始化
fn gen_struct_init(codegen: &C99CodeGenerator, expr: &ASTNode) void {
        const orig_name: &byte = expr.struct_init_struct_name;
        var struct_name: &byte = null;
        if expr.struct_init_type_arg_count > 0 && expr.struct_init_type_args != null {
            // 使用单态化结构体名称
            struct_name = get_mono_struct_name(codegen, orig_name,
                expr.struct_init_type_args,
                expr.struct_init_type_arg_count);
        } else {
            struct_name = get_safe_c_identifier(codegen, orig_name);
        }
        
        const init_field_count: i32 = expr.struct_init_field_count;
        
        // 查找结构体声明以获取字段默认值
        var struct_decl: &ASTNode = null;
        if codegen.program_node != null && codegen.program_node.type == ASTNodeType.AST_PROGRAM {
            var di: i32 = 0;
            while di < codegen.program_node.program_decl_count {
                const decl: &ASTNode = codegen.program_node.program_decls[di];
                if decl != null && decl.type == ASTNodeType.AST_STRUCT_DECL && 
                    decl.struct_decl_name != null && str_equals(decl.struct_decl_name, orig_name) != 0 {
                    struct_decl = decl;
                    break;
                }
                di = di + 1;
            }
        }
        
        // 单态结构体字面量（如 Future<i32>{ state: Poll<i32>.Pending() }）：设置 struct 类型实参上下文，使字段值中的 T 解析为 i32
        var saved_stp: &TypeParam = null;
        var saved_stp_count: i32 = 0;
        var saved_sta: & & ASTNode = null;
        var saved_sta_count: i32 = 0;
        if expr.struct_init_type_arg_count > 0 && expr.struct_init_type_args != null && struct_decl != null &&
            struct_decl.struct_decl_type_params != null && struct_decl.struct_decl_type_param_count > 0 {
            saved_stp = codegen.struct_type_params;
            saved_stp_count = codegen.struct_type_param_count;
            saved_sta = codegen.struct_type_args;
            saved_sta_count = codegen.struct_type_arg_count;
            var resolved_init_args: & & ASTNode = expr.struct_init_type_args;
            const resolved_count: i32 = expr.struct_init_type_arg_count;
            const resolved_buf: & & ASTNode = compiler_arena_alloc(codegen.arena, @size_of(&ASTNode) * resolved_count) as & & ASTNode;
            if resolved_buf != null {
                var rai: i32 = 0;
                while rai < resolved_count {
                    resolved_buf[rai] = substitute_type_arg(codegen, expr.struct_init_type_args[rai]);
                    rai = rai + 1;
                }
                resolved_init_args = resolved_buf;
            }
            codegen.struct_type_params = struct_decl.struct_decl_type_params;
            codegen.struct_type_param_count = struct_decl.struct_decl_type_param_count;
            codegen.struct_type_args = resolved_init_args;
            codegen.struct_type_arg_count = expr.struct_init_type_arg_count;
        }
        
        var struct_init_needs_memcpy: i32 = 0;
        if struct_decl != null {
            var mi: i32 = 0;
            while mi < init_field_count {
                const mf_name: &byte = expr.struct_init_field_names[mi];
                const mf_value: &ASTNode = expr.struct_init_field_values[mi];
                const mf_type: &ASTNode = c99_find_struct_field_type(codegen, struct_decl, mf_name);
                if mf_type != null && mf_type.type == ASTNodeType.AST_TYPE_ARRAY &&
                    mf_value != null && mf_value.type == ASTNodeType.AST_IDENTIFIER {
                    struct_init_needs_memcpy = 1;
                    break;
                }
                mi = mi + 1;
            }
        }
        if struct_init_needs_memcpy != 0 && struct_decl != null {
            fprintf(codegen.emit_stream as *void, "({ struct %s _uya_tmp = (struct %s){" as *byte, struct_name as *byte, struct_name as *byte);
        } else {
            fprintf(codegen.emit_stream as *void, "(struct %s){" as *byte, struct_name as *byte);
        }
        
        // 如果找到结构体声明，按结构体字段顺序生成初始化值（包含默认值）
        if struct_decl != null && struct_decl.struct_decl_fields != null {
            const struct_field_count: i32 = struct_decl.struct_decl_field_count;
            var output_count: i32 = 0;
            
            var fi: i32 = 0;
            while fi < struct_field_count {
                const field: &ASTNode = struct_decl.struct_decl_fields[fi];
                if field == null || field.type != ASTNodeType.AST_VAR_DECL || field.var_decl_name == null {
                    fi = fi + 1;
                    continue;
                }
                
                const field_name: &byte = field.var_decl_name;
                const safe_field_name: &byte = get_safe_c_identifier(codegen, field_name);
                
                // 查找用户是否提供了这个字段的值
                var user_value: &ASTNode = null;
                var ui: i32 = 0;
                while ui < init_field_count {
                    if expr.struct_init_field_names[ui] != null && 
                        str_equals(expr.struct_init_field_names[ui], field_name) != 0 {
                        user_value = expr.struct_init_field_values[ui];
                        break;
                    }
                    ui = ui + 1;
                }
                
                if output_count > 0 {
                    c99_emit_comma_space(codegen);
                }
                fprintf(codegen.emit_stream as *void, ".%s = " as *byte, safe_field_name as *byte);
                
                if user_value != null {
                    // 使用用户提供的值
                    const saved_expected: &ASTNode = codegen.expected_type;
                    // 为字段表达式设置 expected_type，帮助泛型 union/struct 构造选择正确的单态名（如 Poll<T> -> Poll_i32）
                    if field.var_decl_type != null {
                        var resolved: &ASTNode = field.var_decl_type;
                        if codegen.struct_type_params != null && codegen.struct_type_args != null &&
                            codegen.struct_type_param_count > 0 && codegen.struct_type_arg_count == codegen.struct_type_param_count &&
                            field.var_decl_type.type == ASTNodeType.AST_TYPE_NAMED &&
                            field.var_decl_type.type_named_type_arg_count > 0 && field.var_decl_type.type_named_type_args != null {
                            const tmp: &ASTNode = ast_new_node(ASTNodeType.AST_TYPE_NAMED, expr.line, expr.column, codegen.arena, expr.filename);
                            if tmp != null {
                                tmp.type_named_name = field.var_decl_type.type_named_name;
                                const n: i32 = field.var_decl_type.type_named_type_arg_count;
                                const args: & & ASTNode = compiler_arena_alloc(codegen.arena, @size_of(&ASTNode) * n) as & & ASTNode;
                                if args != null {
                                    var ai: i32 = 0;
                                    while ai < n {
                                        var a: &ASTNode = field.var_decl_type.type_named_type_args[ai];
                                        if a != null && a.type == ASTNodeType.AST_TYPE_NAMED && a.type_named_name != null {
                                            var pi: i32 = 0;
                                            while pi < codegen.struct_type_param_count {
                                                if codegen.struct_type_params[pi].name != null &&
                                                    str_equals(codegen.struct_type_params[pi].name, a.type_named_name) != 0 {
                                                    a = codegen.struct_type_args[pi];
                                                    break;
                                                }
                                                pi = pi + 1;
                                            }
                                        }
                                        args[ai] = a;
                                        ai = ai + 1;
                                    }
                                    tmp.type_named_type_args = args;
                                    tmp.type_named_type_arg_count = n;
                                    resolved = tmp;
                                }
                            }
                        }
                        codegen.expected_type = resolved;
                    }
                    if struct_init_needs_memcpy != 0 && field.var_decl_type != null &&
                        field.var_decl_type.type == ASTNodeType.AST_TYPE_ARRAY &&
                        user_value.type == ASTNodeType.AST_IDENTIFIER {
                        if array_element_is_aggregate_c99(codegen, field.var_decl_type) != 0 {
                            fputs("{{0}}" as *byte, codegen.emit_stream as *void);
                        } else {
                            fputs("{0}" as *byte, codegen.emit_stream as *void);
                        }
                    } else if field.var_decl_type != null &&
                        field.var_decl_type.type == ASTNodeType.AST_TYPE_SLICE &&
                        user_value.type == ASTNodeType.AST_UNARY_EXPR &&
                        (user_value.unary_expr_op as TokenType) == TokenType.TOKEN_AMPERSAND &&
                        user_value.unary_expr_operand != null &&
                        user_value.unary_expr_operand.type == ASTNodeType.AST_SLICE_EXPR {
                        fputs("*(" as *byte, codegen.emit_stream as *void);
                        gen_expr(codegen, user_value);
                        fputs(")" as *byte, codegen.emit_stream as *void);
                    } else {
                        gen_expr(codegen, user_value);
                    }
                    codegen.expected_type = saved_expected;
                } else if field.var_decl_init != null {
                    // 使用字段默认值
                    gen_expr(codegen, field.var_decl_init);
                } else {
                    // 没有默认值，使用零值；数组字段：元素为聚合用 {{0}}，否则用 {0}
                    const ft: &ASTNode = field.var_decl_type;
                    if ft != null && ft.type == ASTNodeType.AST_TYPE_ARRAY {
                        if array_element_is_aggregate_c99(codegen, ft) != 0 {
                            fputs("{{0}}" as *byte, codegen.emit_stream as *void);
                        } else {
                            fputs("{0}" as *byte, codegen.emit_stream as *void);
                        }
                    } else if ft != null && ft.type == ASTNodeType.AST_TYPE_NAMED && ft.type_named_name != null {
                        const named_struct_decl: &ASTNode = find_struct_decl_c99(codegen, ft.type_named_name);
                        if named_struct_decl != null {
                            const safe_ft_name: &byte = get_safe_c_identifier(codegen, ft.type_named_name);
                            fprintf(codegen.emit_stream as *void, "(struct %s){0}" as *byte, safe_ft_name as *byte);
                        } else {
                            const named_union_decl: &ASTNode = find_union_decl_c99(codegen, ft.type_named_name);
                            if named_union_decl != null {
                                const safe_ft_name2: &byte = get_safe_c_identifier(codegen, ft.type_named_name);
                                fprintf(codegen.emit_stream as *void, "(union %s){0}" as *byte, safe_ft_name2 as *byte);
                            } else {
                                fputs("0" as *byte, codegen.emit_stream as *void);
                            }
                        }
                    } else {
                        fputs("0" as *byte, codegen.emit_stream as *void);
                    }
                }
                output_count = output_count + 1;
                fi = fi + 1;
            }
        } else {
            // 回退：只生成用户提供的字段
            var i: i32 = 0;
            while i < init_field_count {
                const safe_field_name: &byte = get_safe_c_identifier(codegen, expr.struct_init_field_names[i]);
                fprintf(codegen.emit_stream as *void, ".%s = " as *byte, safe_field_name as *byte);
                gen_expr(codegen, expr.struct_init_field_values[i]);
                if i < init_field_count - 1 {
                    c99_emit_comma_space(codegen);
                }
                i = i + 1;
            }
        }
        if saved_stp != null {
            codegen.struct_type_params = saved_stp;
            codegen.struct_type_param_count = saved_stp_count;
            codegen.struct_type_args = saved_sta;
            codegen.struct_type_arg_count = saved_sta_count;
        }
        fputc(125, codegen.emit_stream as *void);  // '}'
        if struct_init_needs_memcpy != 0 && struct_decl != null {
            fputs("; " as *byte, codegen.emit_stream as *void);
            var ci: i32 = 0;
            while ci < init_field_count {
                const cf_name: &byte = expr.struct_init_field_names[ci];
                const cf_value: &ASTNode = expr.struct_init_field_values[ci];
                const cf_type: &ASTNode = c99_find_struct_field_type(codegen, struct_decl, cf_name);
                if cf_type != null && cf_type.type == ASTNodeType.AST_TYPE_ARRAY &&
                    cf_value != null && cf_value.type == ASTNodeType.AST_IDENTIFIER {
                    const safe_cf_name: &byte = get_safe_c_identifier(codegen, cf_name);
                    fprintf(codegen.emit_stream as *void, "__uya_memcpy(_uya_tmp.%s, " as *byte, safe_cf_name as *byte);
                    gen_expr(codegen, cf_value);
                    fprintf(codegen.emit_stream as *void, ", sizeof(_uya_tmp.%s)); " as *byte, safe_cf_name as *byte);
                }
                ci = ci + 1;
            }
            fputs("_uya_tmp; })" as *byte, codegen.emit_stream as *void);
        }
}

// 生成 match 表达式
fn gen_match_expr(codegen: &C99CodeGenerator, expr: &ASTNode) void {
        // match expr { pat => result, ... } 作为表达式：GCC 语句表达式
        const match_expr: &ASTNode = expr.match_expr_expr;
        var m_type: &byte = get_c_type_of_expr(codegen, match_expr);
        if m_type == null {
            m_type = "int32_t" as &byte;
        }
        var res_type: &byte = "int32_t" as &byte;
        var need_err_union_wrap: i32 = 0;
        if codegen.expected_block_union_type != null && strstr(codegen.expected_block_union_type as *byte, "err_union_" as *byte) != null {
            res_type = codegen.expected_block_union_type;
            need_err_union_wrap = 1;
        } else {
            const mt: &byte = get_c_type_of_expr(codegen, expr);
            if mt != null {
                res_type = mt;
            }
        }
        if codegen.expected_block_union_type == null || strstr(codegen.expected_block_union_type as *byte, "err_union_" as *byte) == null {
            if res_type == null || strcmp(res_type as *byte, "void" as *byte) == 0 {
                res_type = "int32_t" as &byte;
            }
        }
        if codegen.expected_block_union_type == null || strstr(codegen.expected_block_union_type as *byte, "err_union_" as *byte) == null {
            if res_type != null && strcmp(res_type as *byte, "int32_t" as *byte) == 0 && expr.match_expr_arm_count > 0 {
                const t: &byte = get_c_type_of_expr(codegen, expr.match_expr_arms[0].result_expr);
                if t != null && strcmp(t as *byte, "int32_t" as *byte) != 0 {
                    res_type = t;
                }
            }
        } else if expr.match_expr_arm_count > 0 {
            const t: &byte = get_c_type_of_expr(codegen, expr.match_expr_arms[0].result_expr);
            if t != null && strcmp(t as *byte, "int32_t" as *byte) != 0 {
                res_type = t;
            }
        }
        if res_type != null && strncmp(res_type as *byte, "struct " as *byte, 7) == 0 &&
            strstr(res_type as *byte, "err_union_" as *byte) == null {
            var k: i32 = 0;
            while k < expr.match_expr_arm_count {
                const res_k: &ASTNode = expr.match_expr_arms[k].result_expr;
                if (expr.match_expr_arms[k].kind == MatchPatternKind.MATCH_PAT_ELSE || expr.match_expr_arms[k].kind == MatchPatternKind.MATCH_PAT_WILDCARD) &&
                    res_k != null && res_k.type == ASTNodeType.AST_ERROR_VALUE {
                    const payload_name: &byte = &res_type[7];
                    const buf: &byte = compiler_arena_alloc(codegen.arena, (16 + strlen(payload_name as *byte)) as usize) as &byte;
                    if buf != null {
                        snprintf(buf as *byte, 64, "struct err_union_%s" as *byte, payload_name as *byte);
                        res_type = buf;
                        need_err_union_wrap = 1;
                    }
                    k = expr.match_expr_arm_count;
                    break;
                }
                k = k + 1;
            }
        }
        // 检测是否是指针类型（以 " *" 结尾）
        var is_ptr: i32 = 0;
        const m_type_len: i32 = strlen(m_type as *byte);
        if m_type_len > 2 {
            const last2: &byte = m_type as &byte + m_type_len - 2;
            if strcmp(last2 as *byte, " *" as *byte) == 0 || strcmp(last2 as *byte, "* " as *byte) == 0 {
                is_ptr = 1;
            }
        }
        // 访问运算符：指针用 ->，值用 .
        var acc: &byte = "." as &byte;
        if is_ptr != 0 {
            acc = "->" as &byte;
        }
        fputs("({ " as *byte, codegen.emit_stream as *void);
        fprintf(codegen.emit_stream as *void, "%s _uya_m = " as *byte, m_type as *byte);
        gen_expr(codegen, match_expr);
        fputs("; " as *byte, codegen.emit_stream as *void);
        fprintf(codegen.emit_stream as *void, "%s _uya_r; " as *byte, res_type as *byte);
        var first: i32 = 1;
        var i: i32 = 0;
        while i < expr.match_expr_arm_count {
            var prefix: &byte = "else " as *byte;
            if first != 0 {
                prefix = "" as *byte;
                first = 0;
            }
            if expr.match_expr_arms[i].kind == MatchPatternKind.MATCH_PAT_LITERAL {
                if expr.match_expr_arms[i].literal_is_bool != 0 {
                    if expr.match_expr_arms[i].literal_int_value != 0 {
                        fprintf(codegen.emit_stream as *void, "%sif (_uya_m == 1) _uya_r = " as *byte, prefix as *byte);
                    } else {
                        fprintf(codegen.emit_stream as *void, "%sif (_uya_m == 0) _uya_r = " as *byte, prefix as *byte);
                    }
                } else {
                    fprintf(codegen.emit_stream as *void, "%sif (_uya_m == %d) _uya_r = " as *byte, prefix as *byte, expr.match_expr_arms[i].literal_int_value);
                }
                gen_expr(codegen, expr.match_expr_arms[i].result_expr);
                fputs("; " as *byte, codegen.emit_stream as *void);
            } else if expr.match_expr_arms[i].kind == MatchPatternKind.MATCH_PAT_UNION && expr.match_expr_arms[i].variant_name != null {
                const union_decl: &ASTNode = find_union_decl_by_variant_c99(codegen, expr.match_expr_arms[i].variant_name);
                if union_decl != null {
                    const idx: i32 = find_union_variant_index(union_decl, expr.match_expr_arms[i].variant_name);
                    const uname: &byte = get_safe_c_identifier(codegen, union_decl.union_decl_name);
                    const vname: &byte = get_safe_c_identifier(codegen, expr.match_expr_arms[i].variant_name);
                    if idx >= 0 && uname != null && vname != null {
                        const vnode: &ASTNode = union_decl.union_decl_variants[idx];
                        var vtype: &byte = "int" as &byte;
                        const saved_sp: &TypeParam = codegen.struct_type_params;
                        const saved_sa: & & ASTNode = codegen.struct_type_args;
                        const saved_spc: i32 = codegen.struct_type_param_count;
                        const saved_sac: i32 = codegen.struct_type_arg_count;
                        if set_union_mono_context_from_tagged_type(codegen, union_decl, m_type) != 0 { }
                        if vnode != null && vnode.type == ASTNodeType.AST_VAR_DECL && vnode.var_decl_type != null {
                            vtype = c99_type_to_c(codegen, vnode.var_decl_type);
                        }
                        codegen.struct_type_params = saved_sp;
                        codegen.struct_type_args = saved_sa;
                        codegen.struct_type_param_count = saved_spc;
                        codegen.struct_type_arg_count = saved_sac;
                        var bind: &byte = null;
                        if expr.match_expr_arms[i].var_name != null && strcmp(expr.match_expr_arms[i].var_name as *byte, "_" as *byte) != 0 {
                            bind = get_safe_c_identifier(codegen, expr.match_expr_arms[i].var_name);
                        }
                        if bind != null {
                            fprintf(codegen.emit_stream as *void, "%sif (_uya_m%s_tag == %d) { %s %s = _uya_m%su.%s; _uya_r = " as *byte, prefix as &byte, acc as &byte, idx, vtype as &byte, bind as &byte, acc as &byte, vname as &byte);
                            if expr.match_expr_arms[i].var_name != null && codegen.local_variable_count < C99_MAX_LOCAL_VARS {
                                codegen.local_variables[codegen.local_variable_count].name = expr.match_expr_arms[i].var_name;
                                codegen.local_variables[codegen.local_variable_count].type_c = vtype;
                                codegen.local_variables[codegen.local_variable_count].type_node = null;
                                codegen.local_variable_count = codegen.local_variable_count + 1;
                            }
                        } else {
                            fprintf(codegen.emit_stream as *void, "%sif (_uya_m%s_tag == %d) _uya_r = " as *byte, prefix as &byte, acc as &byte, idx);
                        }
                        var wrap_array_payload: i32 = 0;
                        var wrap_array_src_name: &byte = null;
                        if need_err_union_wrap != 0 && res_type != null {
                            const wrap_result: &ASTNode = expr.match_expr_arms[i].result_expr;
                            if wrap_result != null && wrap_result.type == ASTNodeType.AST_BLOCK && wrap_result.block_stmts != null {
                                var last_expr: &ASTNode = null;
                                var wj: i32 = wrap_result.block_stmt_count - 1;
                                while wj >= 0 {
                                    const wsj: &ASTNode = wrap_result.block_stmts[wj];
                                    if wsj != null && wsj.type != ASTNodeType.AST_VAR_DECL &&
                                        wsj.type != ASTNodeType.AST_RETURN_STMT && wsj.type != ASTNodeType.AST_IF_STMT &&
                                        wsj.type != ASTNodeType.AST_WHILE_STMT && wsj.type != ASTNodeType.AST_FOR_STMT &&
                                        wsj.type != ASTNodeType.AST_BREAK_STMT && wsj.type != ASTNodeType.AST_CONTINUE_STMT &&
                                        wsj.type != ASTNodeType.AST_DEFER_STMT && wsj.type != ASTNodeType.AST_ERRDEFER_STMT &&
                                        wsj.type != ASTNodeType.AST_ASSIGN {
                                        last_expr = wsj;
                                        break;
                                    }
                                    wj = wj - 1;
                                }
                                if last_expr != null && last_expr.type == ASTNodeType.AST_IDENTIFIER && last_expr.identifier_name != null {
                                    var wi: i32 = 0;
                                    while wi < wrap_result.block_stmt_count {
                                        const ws: &ASTNode = wrap_result.block_stmts[wi];
                                        if ws != null && ws.type == ASTNodeType.AST_VAR_DECL && ws.var_decl_name != null &&
                                            str_equals(ws.var_decl_name, last_expr.identifier_name) != 0 &&
                                            ws.var_decl_type != null && ws.var_decl_type.type == ASTNodeType.AST_TYPE_ARRAY {
                                            wrap_array_payload = 1;
                                            wrap_array_src_name = last_expr.identifier_name;
                                            break;
                                        }
                                        wi = wi + 1;
                                    }
                                }
                            }
                            if wrap_array_payload != 0 {
                                if wrap_result != null && wrap_result.type == ASTNodeType.AST_BLOCK &&
                                    wrap_result.block_stmts != null && wrap_array_src_name != null {
                                    fprintf(codegen.emit_stream as *void, "({ %s _uya_wrap = (%s){ .error_id = 0 }; " as *byte, res_type as *byte, res_type as *byte);
                                    var bi: i32 = 0;
                                    while bi < wrap_result.block_stmt_count {
                                        const bs: &ASTNode = wrap_result.block_stmts[bi];
                                        // 末尾数组标识符仅作为块结果，不作为独立语句发射
                                        if bs != null && bs.type == ASTNodeType.AST_IDENTIFIER &&
                                            bs.identifier_name != null && str_equals(bs.identifier_name, wrap_array_src_name) != 0 {
                                            bi = bi + 1;
                                            continue;
                                        }
                                        if bs != null {
                                            gen_stmt(codegen, bs);
                                        }
                                        bi = bi + 1;
                                    }
                                    fprintf(codegen.emit_stream as *void, "__uya_memcpy(_uya_wrap.value, %s, sizeof(_uya_wrap.value)); _uya_wrap; })" as *byte, wrap_array_src_name as *byte);
                                } else {
                                    // 兜底：保持旧路径
                                    fprintf(codegen.emit_stream as *void, "({ %s _uya_wrap = (%s){ .error_id = 0 }; __uya_memcpy(_uya_wrap.value, " as *byte, res_type as *byte, res_type as *byte);
                                    gen_expr(codegen, expr.match_expr_arms[i].result_expr);
                                    fputs(", sizeof(_uya_wrap.value)); _uya_wrap; })" as *byte, codegen.emit_stream as *void);
                                }
                            } else if wrap_result != null && wrap_result.type == ASTNodeType.AST_ERROR_VALUE {
                                fprintf(codegen.emit_stream as *void, "(%s){ .error_id = " as *byte, res_type as *byte);
                                gen_expr(codegen, wrap_result);
                                fputs(" } " as *byte, codegen.emit_stream as *void);
                            } else {
                                fprintf(codegen.emit_stream as *void, "(%s){ .error_id = 0, .value = " as *byte, res_type as *byte);
                                const wrap_payload_c: &byte = c99_err_union_match_bind_payload_c(codegen, res_type);
                                if wrap_payload_c != null {
                                    fprintf(codegen.emit_stream as *void, "(%s)(" as *byte, wrap_payload_c as *byte);
                                }
                                gen_expr(codegen, expr.match_expr_arms[i].result_expr);
                                if wrap_payload_c != null {
                                    fputs(")" as *byte, codegen.emit_stream as *void);
                                }
                                fputs(" } " as *byte, codegen.emit_stream as *void);
                            }
                        } else {
                            gen_expr(codegen, expr.match_expr_arms[i].result_expr);
                        }
                        if bind != null {
                            if expr.match_expr_arms[i].var_name != null && codegen.local_variable_count > 0 {
                                codegen.local_variable_count = codegen.local_variable_count - 1;
                            }
                            fputs("; } " as *byte, codegen.emit_stream as *void);
                        } else {
                            fputs("; " as *byte, codegen.emit_stream as *void);
                        }
                    }
                }
            } else if expr.match_expr_arms[i].kind == MatchPatternKind.MATCH_PAT_ENUM {
                const enum_decl: &ASTNode = find_enum_decl_c99(codegen, expr.match_expr_arms[i].enum_name);
                var ev: i32 = -1;
                if enum_decl != null {
                    ev = find_enum_variant_value(codegen, enum_decl, expr.match_expr_arms[i].variant_name);
                }
                if ev >= 0 {
                    fprintf(codegen.emit_stream as *void, "%sif (_uya_m == %d) _uya_r = " as *byte, prefix as *byte, ev);
                } else {
                    fprintf(codegen.emit_stream as *void, "%sif (0) _uya_r = " as *byte, prefix as *byte);
                }
                gen_expr(codegen, expr.match_expr_arms[i].result_expr);
                fputs("; " as *byte, codegen.emit_stream as *void);
            } else if expr.match_expr_arms[i].kind == MatchPatternKind.MATCH_PAT_BIND {
                const v: &byte = get_safe_c_identifier(codegen, expr.match_expr_arms[i].var_name);
                const bind_payload: &byte = c99_err_union_match_bind_payload_c(codegen, m_type);
                if v != null && bind_payload != null {
                    fprintf(codegen.emit_stream as *void, "%sif (_uya_m.error_id == 0U) { %s %s = _uya_m.value; _uya_r = " as *byte, prefix as *byte, bind_payload as *byte, v as *byte);
                    if expr.match_expr_arms[i].var_name != null && codegen.local_variable_count < C99_MAX_LOCAL_VARS {
                        codegen.local_variables[codegen.local_variable_count].name = expr.match_expr_arms[i].var_name;
                        codegen.local_variables[codegen.local_variable_count].type_c = bind_payload;
                        codegen.local_variables[codegen.local_variable_count].type_node = null;
                        codegen.local_variable_count = codegen.local_variable_count + 1;
                    }
                } else if v != null {
                    fprintf(codegen.emit_stream as *void, "%s{ %s %s = _uya_m; _uya_r = " as *byte, prefix as *byte, m_type as *byte, v as *byte);
                    if expr.match_expr_arms[i].var_name != null && codegen.local_variable_count < C99_MAX_LOCAL_VARS {
                        codegen.local_variables[codegen.local_variable_count].name = expr.match_expr_arms[i].var_name;
                        codegen.local_variables[codegen.local_variable_count].type_c = m_type;
                        codegen.local_variables[codegen.local_variable_count].type_node = null;
                        codegen.local_variable_count = codegen.local_variable_count + 1;
                    }
                }
                gen_expr(codegen, expr.match_expr_arms[i].result_expr);
                if v != null {
                    if expr.match_expr_arms[i].var_name != null && codegen.local_variable_count > 0 {
                        codegen.local_variable_count = codegen.local_variable_count - 1;
                    }
                    fputs("; } " as *byte, codegen.emit_stream as *void);
                } else {
                    fputs("; " as *byte, codegen.emit_stream as *void);
                }
            } else if expr.match_expr_arms[i].kind == MatchPatternKind.MATCH_PAT_WILDCARD || expr.match_expr_arms[i].kind == MatchPatternKind.MATCH_PAT_ELSE {
                fprintf(codegen.emit_stream as *void, "%s{ _uya_r = " as *byte, prefix as *byte);
                const else_result: &ASTNode = expr.match_expr_arms[i].result_expr;
                var use_err_union: i32 = 0;
                var err_union_type: &byte = null;
                if else_result != null && else_result.type == ASTNodeType.AST_ERROR_VALUE && res_type != null {
                    if strstr(res_type as *byte, "err_union_" as *byte) != null {
                        use_err_union = 1;
                        err_union_type = res_type;
                    } else if strncmp(res_type as *byte, "struct " as *byte, 7) == 0 {
                        const payload_name: &byte = &res_type[7];
                        const buf: &byte = compiler_arena_alloc(codegen.arena, (16 + strlen(payload_name as *byte)) as usize) as &byte;
                        if buf != null {
                            snprintf(buf as *byte, 64, "struct err_union_%s" as *byte, payload_name as *byte);
                            use_err_union = 1;
                            err_union_type = buf;
                        }
                    }
                }
                if use_err_union != 0 && err_union_type != null {
                    var err_id: i32 = c99_get_or_add_error_id(codegen, else_result.error_value_name);
                    if err_id == 0 { err_id = 1; }
                    fprintf(codegen.emit_stream as *void, "(%s){ .error_id = %uU }" as *byte, err_union_type as *byte, err_id as u32);
                } else {
                    gen_expr(codegen, else_result);
                }
                fputs("; } " as *byte, codegen.emit_stream as *void);
            } else if expr.match_expr_arms[i].kind == MatchPatternKind.MATCH_PAT_ERROR {
                var id: i32 = c99_get_or_add_error_id(codegen, expr.match_expr_arms[i].error_name);
                if id == 0 {
                    id = 1;
                }
                fprintf(codegen.emit_stream as *void, "%sif (_uya_m.error_id == %uU) _uya_r = " as *byte, prefix as *byte, id as u32);
                gen_expr(codegen, expr.match_expr_arms[i].result_expr);
                fputs("; " as *byte, codegen.emit_stream as *void);
            }
            i = i + 1;
        }
        fputs("_uya_r; })" as *byte, codegen.emit_stream as *void);
}

// 生成 catch 表达式
fn gen_catch_expr(codegen: &C99CodeGenerator, expr: &ASTNode) void {
        const operand: &ASTNode = expr.catch_expr_operand;
        const block: &ASTNode = expr.catch_expr_catch_block;
        const err_name: &byte = expr.catch_expr_err_name;
        const ret_type: &ASTNode = codegen.current_function_return_type;
        if operand == null || block == null {
            fputs("0" as *byte, codegen.emit_stream as *void);
            return;
        }
        var operand_union_c: &byte = get_c_type_of_expr(codegen, operand);
        var operand_is_err_union: i32 = 0;
        // union_c / payload_c 须先于下方「从函数声明补全 err_union」块使用，避免对未声明变量赋值
        var union_c: &byte = ("int32_t" as *byte) as &byte;
        var payload_c: &byte = ("int32_t" as *byte) as &byte;
        if operand_union_c != null && strstr(operand_union_c as *byte, "err_union_" as *byte) != null {
            operand_is_err_union = 1;
        }
        // 额外检查：操作数是否是函数调用，如果是，直接从函数声明获取返回类型
        // 这修复了 get_c_type_of_expr 对某些函数调用返回 int32_t 的问题
        if operand_is_err_union == 0 && operand != null && operand.type == ASTNodeType.AST_CALL_EXPR {
            const callee: &ASTNode = operand.call_expr_callee;
            if callee != null && callee.type == ASTNodeType.AST_IDENTIFIER && callee.identifier_name != null {
                const fn_decl: &ASTNode = find_function_decl_c99(codegen, callee.identifier_name);
                if fn_decl != null && fn_decl.type == ASTNodeType.AST_FN_DECL && fn_decl.fn_decl_return_type != null {
                    const fn_return_type: &ASTNode = fn_decl.fn_decl_return_type;
                    const fn_return_c: &byte = c99_type_to_c(codegen, fn_return_type);
                    if fn_return_c != null && strstr(fn_return_c as *byte, "err_union_" as *byte) != null {
                        // 找到了！函数返回错误联合类型
                        operand_union_c = fn_return_c;
                        operand_is_err_union = 1;
                    }
                }
            }
        }
        if operand_is_err_union != 0 {
            union_c = operand_union_c;
            if operand != null && operand.type == ASTNodeType.AST_CAST_EXPR && operand.cast_expr_is_force_cast != 0 && operand.cast_expr_target_type != null {
                payload_c = c99_type_to_c(codegen, operand.cast_expr_target_type);
            } else {
                var payload_inferred: i32 = 0;
                // 从错误联合类型名称推断 payload 类型
                if operand_union_c != null && strcmp(operand_union_c as *byte, "struct err_union_void" as *byte) == 0 {
                    payload_c = "void" as &byte;
                    payload_inferred = 1;
                } else if operand_union_c != null && strcmp(operand_union_c as *byte, "struct err_union_int32_t" as *byte) == 0 {
                    payload_c = "int32_t" as &byte;
                    payload_inferred = 1;
                } else if operand_union_c != null && strcmp(operand_union_c as *byte, "struct err_union_int64_t" as *byte) == 0 {
                    payload_c = "int64_t" as &byte;
                    payload_inferred = 1;
                } else if operand_union_c != null && strcmp(operand_union_c as *byte, "struct err_union_intptr_t" as *byte) == 0 {
                    payload_c = "intptr_t" as &byte;
                    payload_inferred = 1;
                } else if operand_union_c != null && strncmp(operand_union_c as *byte, "struct err_union_struct" as *byte, 23) == 0 {
                    // err_union_structLinuxEpoll -> payload "struct LinuxEpoll"
                    const rest: *byte = operand_union_c as *byte + 23;
                    var buf: [byte: 128] = [];
                    snprintf(&buf[0] as *byte, 128, "struct %s" as *byte, rest);
                    payload_c = c99_arena_strdup(codegen.arena, &buf[0] as &byte);
                    if payload_c == null {
                        payload_c = "int32_t" as &byte;
                    }
                    payload_inferred = 1;
                } else if operand_union_c != null && strncmp(operand_union_c as *byte, "struct err_union_" as *byte, 17) == 0 {
                    // err_union_LinuxEpoll 等 -> payload "struct LinuxEpoll"；err_union_Xptr -> payload "struct X *"
                    const rest: *byte = operand_union_c as *byte + 17;
                    if strcmp(rest, "int32_t" as *byte) == 0 || strcmp(rest, "int64_t" as *byte) == 0
                        || strcmp(rest, "uint32_t" as *byte) == 0 || strcmp(rest, "uint64_t" as *byte) == 0
                        || strcmp(rest, "intptr_t" as *byte) == 0 || strcmp(rest, "void" as *byte) == 0
                        || strcmp(rest, "size_t" as *byte) == 0 || strcmp(rest, "uintptr_t" as *byte) == 0
                        || strcmp(rest, "ssize_t" as *byte) == 0 || strcmp(rest, "bool" as *byte) == 0
                        || strcmp(rest, "double" as *byte) == 0 {
                        payload_c = rest;
                        payload_inferred = 1;
                    } else if strcmp(rest, "f64" as *byte) == 0 {
                        payload_c = ("double" as *byte) as &byte;
                        payload_inferred = 1;
                    } else {
                        const rest_len: i32 = strlen(rest);
                        if rest_len >= 3 && rest[rest_len - 3] == 112 && rest[rest_len - 2] == 116 && rest[rest_len - 1] == 114 {
                            // 以 "ptr" 结尾：payload 为指针类型 "struct X *"
                            var buf: [byte: 128] = [];
                            if rest_len - 3 < 125 {
                                memcpy(&buf[0] as *void, rest as *void, (rest_len - 3) as usize);
                                buf[rest_len - 3] = 0;
                                var buf2: [byte: 132] = [];
                                snprintf(&buf2[0] as *byte, 132, "struct %s *" as *byte, &buf[0] as *byte);
                                payload_c = c99_arena_strdup(codegen.arena, &buf2[0] as &byte);
                            }
                            if payload_c == null {
                                payload_c = "void*" as &byte;
                            }
                            payload_inferred = 1;
                        } else {
                            // rest 如 Vec4i32：可能是 type alias（typedef 名），不是 C struct tag；err_union 字段类型与 c99_type_to_c 一致
                            const alias_decl: &ASTNode = find_type_alias_from_program(codegen.program_node, rest as &byte);
                            if alias_decl != null && alias_decl.type_alias_name != null {
                                payload_c = get_safe_c_identifier(codegen, alias_decl.type_alias_name);
                                if payload_c == null {
                                    var buf_a: [byte: 128] = [];
                                    snprintf(&buf_a[0] as *byte, 128, "struct %s" as *byte, rest);
                                    payload_c = c99_arena_strdup(codegen.arena, &buf_a[0] as &byte);
                                    if payload_c == null {
                                        payload_c = "int32_t" as &byte;
                                    }
                                }
                            } else {
                                var buf: [byte: 128] = [];
                                snprintf(&buf[0] as *byte, 128, "struct %s" as *byte, rest);
                                payload_c = c99_arena_strdup(codegen.arena, &buf[0] as &byte);
                                if payload_c == null {
                                    payload_c = "int32_t" as &byte;
                                }
                            }
                            payload_inferred = 1;
                        }
                    }
                }
                if payload_inferred == 0 && ret_type != null && ret_type.type == ASTNodeType.AST_TYPE_ERROR_UNION &&
                    ret_type.type_error_union_payload_type != null && (operand == null || operand.type != ASTNodeType.AST_CALL_EXPR) {
                    // 仅在无法从操作数错误联合本身恢复 payload 时，才退回外层函数返回类型。
                    payload_c = c99_type_to_c(codegen, ret_type.type_error_union_payload_type);
                    payload_inferred = 1;
                }
                if payload_inferred == 0 {
                    payload_c = "int32_t" as &byte;
                }
            }
        } else if operand != null && operand.type == ASTNodeType.AST_CALL_EXPR {
            // 操作数是函数调用，尝试从函数声明获取返回类型
            const callee: &ASTNode = operand.call_expr_callee;
            if callee != null && callee.type == ASTNodeType.AST_IDENTIFIER && callee.identifier_name != null {
                const fn_decl: &ASTNode = find_function_decl_c99(codegen, callee.identifier_name);
                if fn_decl != null && fn_decl.type == ASTNodeType.AST_FN_DECL && fn_decl.fn_decl_return_type != null {
                    union_c = c99_type_to_c(codegen, fn_decl.fn_decl_return_type);
                    const payload_node: &ASTNode = fn_decl.fn_decl_return_type.type_error_union_payload_type;
                    if payload_node != null {
                        payload_c = c99_type_to_c(codegen, payload_node);
                    } else {
                        payload_c = "void" as &byte;
                    }
                } else {
                    fputs("0" as *byte, codegen.emit_stream as *void);
                    return;
                }
            } else {
                fputs("0" as *byte, codegen.emit_stream as *void);
                return;
            }
        } else if ret_type != null && ret_type.type == ASTNodeType.AST_TYPE_ERROR_UNION {
            union_c = c99_type_to_c(codegen, ret_type);
            const payload_node: &ASTNode = ret_type.type_error_union_payload_type;
            if payload_node != null {
                payload_c = c99_type_to_c(codegen, payload_node);
            } else {
                payload_c = "void" as &byte;
            }
        } else {
            fputs("0" as *byte, codegen.emit_stream as *void);
            return;
        }
        const n: i32 = block.block_stmt_count;
        var last_stmt: &ASTNode = null;
        if n > 0 {
            last_stmt = block.block_stmts[n - 1];
        }
        var is_void_payload: i32 = 0;
        if payload_c != null && strcmp(payload_c as *byte, "void" as *byte) == 0 {
            is_void_payload = 1;
        } else {
            is_void_payload = 0;
        }
        fprintf(codegen.emit_stream as *void, "({ %s _uya_catch_tmp = " as *byte, union_c as *byte);
        gen_expr(codegen, operand);
        if is_void_payload == 0 {
            fputs("; __typeof__(_uya_catch_tmp.value) _uya_catch_result" as *byte, codegen.emit_stream as *void);
        }
        fputs("; if (_uya_catch_tmp.error_id != 0) {\n" as *byte, codegen.emit_stream as *void);
        codegen.indent_level = codegen.indent_level + 1;
        if err_name != null {
            const safe: &byte = get_safe_c_identifier(codegen, err_name);
            c99_emit_indent(codegen);
            fprintf(codegen.emit_stream as *void, "%s %s = _uya_catch_tmp;\n" as *byte, union_c as *byte, safe as *byte);
        }
        var i: i32 = 0;
        while i < n {
            const s: &ASTNode = block.block_stmts[i];
            if s != null {
                if i == n - 1 && last_stmt != null && last_stmt.type != ASTNodeType.AST_RETURN_STMT && is_void_payload == 0 {
                    c99_emit_indent(codegen);
                    fputs("_uya_catch_result = (" as *byte, codegen.emit_stream as *void);
                    gen_expr(codegen, s);
                    fputs(");\n" as *byte, codegen.emit_stream as *void);
                } else {
                    gen_stmt(codegen, s);
                }
            }
            i = i + 1;
        }
        codegen.indent_level = codegen.indent_level - 1;
        c99_emit_indent(codegen);
        if is_void_payload != 0 {
            fputs("} else { /* void payload */ } 0; })" as *byte, codegen.emit_stream as *void);
        } else {
            fputs("} else _uya_catch_result = _uya_catch_tmp.value; _uya_catch_result; })" as *byte, codegen.emit_stream as *void);
        }
}

// 生成数组访问表达式
fn gen_array_access(codegen: &C99CodeGenerator, expr: &ASTNode) void {
        const array: &ASTNode = expr.array_access_array;
        const index: &ASTNode = expr.array_access_index;
        
        if array.type == ASTNodeType.AST_SLICE_EXPR {
            if codegen.container_mode != 0 {
                const access_mode: &byte = c99_mmu_access_kind_literal(codegen);
                fputc(42, codegen.emit_stream as *void);
                fputs("(({ __auto_type _uya_base = (" as *byte, codegen.emit_stream as *void);
                gen_expr(codegen, array);
                fputs(").ptr; __auto_type _uya_idx = (" as *byte, codegen.emit_stream as *void);
                gen_expr(codegen, index);
                fputs("); __typeof__(_uya_base[0]) *_uya_translated = (__typeof__(_uya_base[0]) *)uya_mmu_translate((void *)_uya_base, sizeof(_uya_base[0]) * ((size_t)_uya_idx + 1U), " as *byte, codegen.emit_stream as *void);
                fprintf(codegen.emit_stream as *void, "%s" as *byte, access_mode as *byte);
                fputs("); _uya_translated + _uya_idx; }))" as *byte, codegen.emit_stream as *void);
                return;
            }
            fputc(40, codegen.emit_stream as *void);
            gen_expr(codegen, array);
            fputs(").ptr[" as *byte, codegen.emit_stream as *void);
            gen_expr(codegen, index);
            fputc(93, codegen.emit_stream as *void);
            return;
        }
        if array.type == ASTNodeType.AST_MEMBER_ACCESS {
            const type_c: &byte = get_c_type_of_expr(codegen, array);
            if type_c != null && strstr(type_c as *byte, "uya_slice_" as *byte) != null {
                if codegen.container_mode != 0 {
                    const access_mode2: &byte = c99_mmu_access_kind_literal(codegen);
                    const is_pointer2: i32 = is_expr_pointer_type(codegen, array);
                    fputc(42, codegen.emit_stream as *void);
                    fputs("(({ __auto_type _uya_base = (" as *byte, codegen.emit_stream as *void);
                    if is_pointer2 != 0 {
                        gen_expr(codegen, array);
                        fputs("->ptr; __auto_type _uya_idx = (" as *byte, codegen.emit_stream as *void);
                    } else {
                        gen_expr(codegen, array);
                        fputs(").ptr; __auto_type _uya_idx = (" as *byte, codegen.emit_stream as *void);
                    }
                    gen_expr(codegen, index);
                    fputs("); __typeof__(_uya_base[0]) *_uya_translated = (__typeof__(_uya_base[0]) *)uya_mmu_translate((void *)_uya_base, sizeof(_uya_base[0]) * ((size_t)_uya_idx + 1U), " as *byte, codegen.emit_stream as *void);
                    fprintf(codegen.emit_stream as *void, "%s" as *byte, access_mode2 as *byte);
                    fputs("); _uya_translated + _uya_idx; }))" as *byte, codegen.emit_stream as *void);
                    return;
                }
                fputc(40, codegen.emit_stream as *void);
                gen_expr(codegen, array);
                fputs(").ptr[" as *byte, codegen.emit_stream as *void);
                gen_expr(codegen, index);
                fputc(93, codegen.emit_stream as *void);
                return;
            }
        }
        if array.type == ASTNodeType.AST_IDENTIFIER {
            const type_c: &byte = get_identifier_type_c(codegen, array.identifier_name);
            if type_c != null && strstr(type_c as *byte, "uya_slice_" as *byte) != null {
                // 检查标识符是否是指针类型
                const safe_name: &byte = get_safe_c_identifier(codegen, array.identifier_name);
                const is_pointer: i32 = is_identifier_pointer_type(codegen, safe_name);
                if codegen.container_mode != 0 {
                    const access_mode3: &byte = c99_mmu_access_kind_literal(codegen);
                    fputc(42, codegen.emit_stream as *void);
                    fputs("(({ __auto_type _uya_base = (" as *byte, codegen.emit_stream as *void);
                    if is_pointer != 0 {
                        gen_expr(codegen, array);
                        fputs("->ptr; __auto_type _uya_idx = (" as *byte, codegen.emit_stream as *void);
                    } else {
                        fputc(40, codegen.emit_stream as *void);
                        gen_expr(codegen, array);
                        fputs(").ptr; __auto_type _uya_idx = (" as *byte, codegen.emit_stream as *void);
                    }
                    gen_expr(codegen, index);
                    fputs("); __typeof__(_uya_base[0]) *_uya_translated = (__typeof__(_uya_base[0]) *)uya_mmu_translate((void *)_uya_base, sizeof(_uya_base[0]) * ((size_t)_uya_idx + 1U), " as *byte, codegen.emit_stream as *void);
                    fprintf(codegen.emit_stream as *void, "%s" as *byte, access_mode3 as *byte);
                    fputs("); _uya_translated + _uya_idx; }))" as *byte, codegen.emit_stream as *void);
                    return;
                }
                if is_pointer != 0 {
                    // 指针类型使用 -> 操作符
                    gen_expr(codegen, array);
                    fputs("->ptr[" as *byte, codegen.emit_stream as *void);
                } else {
                    // 非指针类型使用 . 操作符
                    fputc(40, codegen.emit_stream as *void);
                    gen_expr(codegen, array);
                    fputs(").ptr[" as *byte, codegen.emit_stream as *void);
                }
                gen_expr(codegen, index);
                fputc(93, codegen.emit_stream as *void);
                return;
            }
        }
        
        // 注意：对于指向数组的指针（如 uint8_t (*)[4096]），
        // 在 C 中可以直接使用 file_paths_buffer[i]，不需要 (*file_paths_buffer)[i]
        // 因为 file_paths_buffer[i] 会自动解引用
        if codegen.container_mode != 0 {
            c99_emit_mmu_wrapped_array_access(codegen, array, index);
            return;
        }
        gen_expr(codegen, array);
        fputc(91, codegen.emit_stream as *void);  // '['
        gen_expr(codegen, index);
        fputc(93, codegen.emit_stream as *void);  // ']'
}

/// as! 从 !S 包成 !T 时，error_id==0 分支是否可用 C 强转 _uya_asbang_src.value → T.value（标量/同类型可以；标量→结构体或不同结构体不可以，须写 {0}）。
fn c99_asbang_err_success_allows_value_cast(codegen: &C99CodeGenerator, src_expr: &ASTNode, dest_payload_ast: &ASTNode, line: i32, col: i32, filename: &byte) i32 {
    if codegen == null || codegen.checker == null || src_expr == null || dest_payload_ast == null {
        return 0;
    }
    const dc: &byte = c99_mono_type_to_c(codegen, dest_payload_ast);
    if dc == null {
        return 0;
    }
    var dc_struct: i32 = 0;
    if strncmp(dc as *byte, "struct " as *byte, 7) == 0 {
        dc_struct = 1;
    }
    const st: Type = checker_infer_type(codegen.checker, src_expr);
    var sc: &byte = null;
    if st.kind == TypeKind.TYPE_ERROR_UNION && st.error_union_payload_type != null {
        const spl: Type = st.error_union_payload_type[0];
        sc = c99_type_to_c_from_inferred_type(codegen, spl, line, col, filename);
    }
    // catch 等上下文中推断可能非 !T，回退：仅当 C 名为已知标量 err_union_*（避免把 !Http1AsyncResponse 当标量）
    if sc == null {
        const src_union_c: &byte = get_c_type_of_expr(codegen, src_expr);
        if src_union_c == null || strstr(src_union_c as *byte, "err_union_" as *byte) == null {
            return 0;
        }
        var prim_src: i32 = 0;
        if strstr(src_union_c as *byte, "err_union_int32_t" as *byte) != null ||
            strstr(src_union_c as *byte, "err_union_int64_t" as *byte) != null ||
            strstr(src_union_c as *byte, "err_union_intptr_t" as *byte) != null ||
            strstr(src_union_c as *byte, "err_union_size_t" as *byte) != null ||
            strstr(src_union_c as *byte, "err_union_ssize_t" as *byte) != null ||
            strstr(src_union_c as *byte, "err_union_uint32_t" as *byte) != null ||
            strstr(src_union_c as *byte, "err_union_uint64_t" as *byte) != null ||
            strstr(src_union_c as *byte, "err_union_uint8_t" as *byte) != null ||
            strstr(src_union_c as *byte, "err_union_int16_t" as *byte) != null ||
            strstr(src_union_c as *byte, "err_union_uint16_t" as *byte) != null ||
            strstr(src_union_c as *byte, "err_union_bool" as *byte) != null {
            prim_src = 1;
        }
        if prim_src == 0 {
            return 0;
        }
        if dc_struct != 0 {
            return 0;
        }
        return 1;
    }
    if strcmp(sc as *byte, dc as *byte) == 0 {
        return 1;
    }
    var sc_struct: i32 = 0;
    if strncmp(sc as *byte, "struct " as *byte, 7) == 0 {
        sc_struct = 1;
    }
    if dc_struct != 0 && strcmp(sc as *byte, dc as *byte) != 0 {
        return 0;
    }
    if sc_struct != 0 && strcmp(sc as *byte, dc as *byte) != 0 {
        return 0;
    }
    // int32_t 与 i32 映射的 C 字符串可能不同（如 int vs int32_t），但同属非聚合，仍可强转源 .value
    if sc_struct == 0 && dc_struct == 0 {
        return 1;
    }
    return 0;
}

// 生成类型转换表达式
fn gen_cast_expr(codegen: &C99CodeGenerator, expr: &ASTNode) void {
        const src_expr: &ASTNode = expr.cast_expr_expr;
        const target_type: &ASTNode = expr.cast_expr_target_type;
        const is_force_cast: i32 = expr.cast_expr_is_force_cast;
        const type_c: &byte = c99_type_to_c(codegen, target_type);
        // as! 写入 err_union.value 须用载荷的 C 类型；目标在 AST 中可能是 T 或 !T（后者时 type_c 为 struct err_union_*）
        var payload_for_val: &ASTNode = target_type;
        if target_type != null && target_type.type == ASTNodeType.AST_TYPE_ERROR_UNION &&
            target_type.type_error_union_payload_type != null {
            payload_for_val = target_type.type_error_union_payload_type;
        }
        var value_field_c: &byte = c99_mono_type_to_c(codegen, payload_for_val);
        if payload_for_val == null {
            value_field_c = type_c;
        }
        if is_force_cast != 0 {
            // as! 强转：返回 !T。当源为 !i64 等错误联合时，需解包再包装
            const src_union_c: &byte = get_c_type_of_expr(codegen, src_expr);
            var src_is_err_union: i32 = 0;
            if src_union_c != null && strstr(src_union_c as *byte, "err_union_" as *byte) != null {
                src_is_err_union = 1;
            }
            const tmp: &ASTNode = ast_new_node(ASTNodeType.AST_TYPE_ERROR_UNION, 0, 0, codegen.arena, null);
            var union_c: &byte = "void" as &byte;
            if tmp != null {
                tmp.type_error_union_payload_type = target_type;
                union_c = c99_type_to_c(codegen, tmp);
            }
            var is_void: i32 = 0;
            if target_type != null && target_type.type == ASTNodeType.AST_TYPE_NAMED && target_type.type_named_name != null && strcmp(target_type.type_named_name as *byte, "void" as *byte) == 0 {
                is_void = 1;
            }
            if src_is_err_union != 0 && is_void == 0 {
                const allow_val_cast: i32 = c99_asbang_err_success_allows_value_cast(codegen, src_expr, payload_for_val, expr.line, expr.column, expr.filename);
                fprintf(codegen.emit_stream as *void, "({ %s _uya_asbang_src = " as *byte, src_union_c as *byte);
                gen_expr(codegen, src_expr);
                fprintf(codegen.emit_stream as *void, "; %s _uya_asbang; " as *byte, union_c as *byte);
                fputs("if (_uya_asbang_src.error_id != 0) { " as *byte, codegen.emit_stream as *void);
                fputs("_uya_asbang.error_id = _uya_asbang_src.error_id; " as *byte, codegen.emit_stream as *void);
                fprintf(codegen.emit_stream as *void, "_uya_asbang.value = (%s){0}; " as *byte, value_field_c as *byte);
                fputs("} else { _uya_asbang.error_id = 0; " as *byte, codegen.emit_stream as *void);
                // 成功分支：同载荷 C 类型或数值互转可用强转；!i32 as! !Http1AsyncResponse 等须写 {0}，禁止 (struct T)(int32_t)。
                if allow_val_cast != 0 {
                    fprintf(codegen.emit_stream as *void, "_uya_asbang.value = (%s)(_uya_asbang_src.value); " as *byte, value_field_c as *byte);
                } else {
                    fprintf(codegen.emit_stream as *void, "_uya_asbang.value = (%s){0}; " as *byte, value_field_c as *byte);
                }
                fputs("} _uya_asbang; })" as *byte, codegen.emit_stream as *void);
            } else if src_is_err_union != 0 && is_void != 0 {
                fprintf(codegen.emit_stream as *void, "({ %s _uya_asbang_src = " as *byte, src_union_c as *byte);
                gen_expr(codegen, src_expr);
                fprintf(codegen.emit_stream as *void, "; %s _uya_asbang; " as *byte, union_c as *byte);
                fputs("_uya_asbang.error_id = _uya_asbang_src.error_id; _uya_asbang; })" as *byte, codegen.emit_stream as *void);
            } else {
                fprintf(codegen.emit_stream as *void, "({ %s _uya_asbang = { .error_id = 0" as *byte, union_c as *byte);
                if is_void == 0 {
                    fprintf(codegen.emit_stream as *void, ", .value = (%s)(" as *byte, value_field_c as *byte);
                    gen_expr(codegen, src_expr);
                    fputs(") }; _uya_asbang; })" as *byte, codegen.emit_stream as *void);
                } else {
                    fputs(" }; " as *byte, codegen.emit_stream as *void);
                    gen_expr(codegen, src_expr);
                    fputs("; _uya_asbang; })" as *byte, codegen.emit_stream as *void);
                }
            }
        } else {
            // 特殊处理：null as * *byte -> (const uint8_t **)NULL（用于 strtol/strtod，匹配 libc 签名）
            var is_null_to_byte_ptr_ptr: i32 = 0;
            if src_expr != null && src_expr.type == ASTNodeType.AST_IDENTIFIER && src_expr.identifier_name != null && strcmp(src_expr.identifier_name as *byte, "null" as *byte) == 0 {
                // 检查目标类型是否是 * *byte（优先检查 AST 结构，然后检查类型字符串）
                if target_type != null && target_type.type == ASTNodeType.AST_TYPE_POINTER {
                    const inner_type: &ASTNode = target_type.type_pointer_pointed_type;
                    if inner_type != null && inner_type.type == ASTNodeType.AST_TYPE_POINTER {
                        const inner_inner_type: &ASTNode = inner_type.type_pointer_pointed_type;
                        if inner_inner_type != null && inner_inner_type.type == ASTNodeType.AST_TYPE_NAMED && inner_inner_type.type_named_name != null && strcmp(inner_inner_type.type_named_name as *byte, "byte" as *byte) == 0 {
                            is_null_to_byte_ptr_ptr = 1;
                        }
                    }
                }
                // 如果 AST 结构检查没有匹配，再检查类型字符串
                if is_null_to_byte_ptr_ptr == 0 && type_c != null {
                    if strcmp(type_c as *byte, "uint8_t **" as *byte) == 0 {
                        is_null_to_byte_ptr_ptr = 1;
                    } else {
                        var has_uint8: i32 = 0;
                        var has_double_star: i32 = 0;
                        if strstr(type_c as *byte, "uint8_t" as *byte) != null {
                            has_uint8 = 1;
                        }
                        if strstr(type_c as *byte, "**" as *byte) != null {
                            has_double_star = 1;
                        }
                        if has_uint8 != 0 && has_double_star != 0 {
                            is_null_to_byte_ptr_ptr = 1;
                        }
                    }
                }
            }
            if is_null_to_byte_ptr_ptr != 0 {
                fputs("(const uint8_t **)NULL" as *byte, codegen.emit_stream as *void);
            } else {
                fputc(40, codegen.emit_stream as *void);  // '('
                fprintf(codegen.emit_stream as *void, "%s)" as *byte, type_c as *byte);
                gen_expr(codegen, src_expr);
            }
        }
}

/// 生成数组字面量内部（不含外层花括号），供 gen_array_literal 与 async 状态机 memcpy 等复用。
fn gen_array_literal_contents(codegen: &C99CodeGenerator, expr: &ASTNode) void {
        if expr == null {
            return;
        }
        const element_count: i32 = expr.array_literal_element_count;
        const repeat_count_expr: &ASTNode = expr.array_literal_repeat_count_expr;
        if repeat_count_expr != null && element_count >= 1 {
            var nn: i32 = eval_const_expr(codegen, repeat_count_expr);
            if nn <= 0 {
                nn = 1;
            }
            var i: i32 = 0;
            while i < nn {
                gen_expr(codegen, expr.array_literal_elements[0]);
                if i < nn - 1 {
                    c99_emit_comma_space(codegen);
                }
                i = i + 1;
            }
        } else if element_count > 0 {
            var i: i32 = 0;
            while i < element_count {
                gen_expr(codegen, expr.array_literal_elements[i]);
                if i < element_count - 1 {
                    c99_emit_comma_space(codegen);
                }
                i = i + 1;
            }
        } else {
            // 空数组字面量：生成 {0}
            fputs("0" as *byte, codegen.emit_stream as *void);
        }
}

// 生成数组字面量
fn gen_array_literal(codegen: &C99CodeGenerator, expr: &ASTNode) void {
        fputc(123, codegen.emit_stream as *void);  // '{'
        gen_array_literal_contents(codegen, expr);
        fputc(125, codegen.emit_stream as *void);  // '}'
}

// 生成切片表达式
fn gen_slice_expr(codegen: &C99CodeGenerator, expr: &ASTNode) void {
        const base: &ASTNode = expr.slice_expr_base;
        const start_expr: &ASTNode = expr.slice_expr_start_expr;
        const len_expr: &ASTNode = expr.slice_expr_len_expr;
        const slice_type_c: &byte = get_slice_struct_type_c(codegen, expr);
        var slice_type_str: &byte = ("struct uya_slice_int32_t" as *byte) as &byte;
        if slice_type_c != null {
            slice_type_str = slice_type_c;
        }
        fprintf(codegen.emit_stream as *void, "(%s){ .ptr = " as *byte, slice_type_str as *byte);
        if base.type == ASTNodeType.AST_SLICE_EXPR {
            fputc(40, codegen.emit_stream as *void);
            gen_expr(codegen, base);
            fputs(").ptr + " as *byte, codegen.emit_stream as *void);
        } else if base.type == ASTNodeType.AST_IDENTIFIER {
            const type_c: &byte = get_identifier_type_c(codegen, base.identifier_name);
            if type_c != null && strstr(type_c as *byte, "uya_slice_" as *byte) != null {
                if strchr(type_c as *byte, 42) != null {
                    gen_expr(codegen, base);
                    fputs("->ptr + " as *byte, codegen.emit_stream as *void);
                } else {
                    fputc(40, codegen.emit_stream as *void);
                    gen_expr(codegen, base);
                    fputs(").ptr + " as *byte, codegen.emit_stream as *void);
                }
            } else {
                // byte 切片 .ptr 需 uint8_t*；arena_alloc 等常为 void*，C99 禁止 void* 算术，用 (uint8_t *) 避免 -Wpointer-arith
                var need_uint8_cast: i32 = 0;
                if slice_type_str != null && strstr(slice_type_str as *byte, "uya_slice_uint8_t" as *byte) != null {
                    need_uint8_cast = 1;
                }
                if need_uint8_cast == 0 && type_c != null && strstr(type_c as *byte, "void" as *byte) != null && strstr(type_c as *byte, "*" as *byte) != null {
                    need_uint8_cast = 1;
                }
                if need_uint8_cast != 0 {
                    fputs("(uint8_t *)(" as *byte, codegen.emit_stream as *void);
                    gen_expr(codegen, base);
                    fputs(") + " as *byte, codegen.emit_stream as *void);
                } else {
                    gen_expr(codegen, base);
                    fputs(" + " as *byte, codegen.emit_stream as *void);
                }
            }
        } else {
            // byte 切片或 base 为 void* 时转 (uint8_t *) 避免 -Wpointer-arith
            var need_uint8_cast: i32 = 0;
            if slice_type_str != null && strstr(slice_type_str as *byte, "uya_slice_uint8_t" as *byte) != null {
                need_uint8_cast = 1;
            }
            if need_uint8_cast == 0 {
                const base_type_c: &byte = get_c_type_of_expr(codegen, base);
                if base_type_c != null && strstr(base_type_c as *byte, "void" as *byte) != null && strstr(base_type_c as *byte, "*" as *byte) != null {
                    need_uint8_cast = 1;
                }
            }
            if need_uint8_cast != 0 {
                fputs("(uint8_t *)(" as *byte, codegen.emit_stream as *void);
                gen_expr(codegen, base);
                fputs(") + " as *byte, codegen.emit_stream as *void);
            } else {
                gen_expr(codegen, base);
                fputs(" + " as *byte, codegen.emit_stream as *void);
            }
        }
        gen_expr(codegen, start_expr);
        fputs(", .len = " as *byte, codegen.emit_stream as *void);
        gen_expr(codegen, len_expr);
        fputc(125, codegen.emit_stream as *void);  // '}'
}

// 生成 @print/@println 表达式
fn gen_print_expr(codegen: &C99CodeGenerator, expr: &ASTNode) void {
        // @print(expr) / @println(expr) - 打印表达式
        if expr.print_expr != null {
            const inner: &ASTNode = expr.print_expr;
            var fmt: &byte = null;
            var need_cast: i32 = 0;  // 是否需要 (char *) 转换

            // 表达式场景（例如：const printed: i32 = @println("x=${s}");）
            // 需要自己生成插值缓冲区；否则 gen_expr(AST_STRING_INTERP) 会在 string_interp_buf 为空时返回 (char*)0。
            if inner.type == ASTNodeType.AST_STRING_INTERP && inner.string_interp_segment_count > 0 {
                const temp_name_idx: i32 = codegen.interp_temp_counter;
                codegen.interp_temp_counter = codegen.interp_temp_counter + 1;

                var interp_size: i32 = inner.string_interp_computed_size;
                if interp_size <= 0 {
                    interp_size = 256;
                }

                // 使用 GCC statement-expression（({ ... })）让它在表达式位置也能返回值。
                fputs("({" as *byte, codegen.emit_stream as *void);
                fprintf(codegen.emit_stream as *void, "char __uya_interp_%d[%d];\n" as *byte, temp_name_idx, interp_size);

                var name_buf: [byte: 32] = [];
                snprintf(&name_buf[0] as *byte, 32, "__uya_interp_%d" as *byte, temp_name_idx);
                c99_emit_string_interp_fill(codegen, inner, &name_buf[0] as &byte);

                if codegen.is_nostdlib != 0 {
                    // nostdlib 只支持写入字节；println 多写一个 '\n'
                    fprintf(codegen.emit_stream as *void,
                        "int __uya_interp_res = uya_write(1, (char *)__uya_interp_%d, uya_strlen((char *)__uya_interp_%d));\n" as *byte,
                        temp_name_idx, temp_name_idx);
                    if expr.type == ASTNodeType.AST_PRINTLN {
                        fputs("uya_write(1, \"\\n\", 1);\n" as *byte, codegen.emit_stream as *void);
                    }
                    fputs("__uya_interp_res; })" as *byte, codegen.emit_stream as *void);
                } else {
                    if expr.type == ASTNodeType.AST_PRINTLN {
                        fprintf(codegen.emit_stream as *void, "printf(\"%%s\\n\", __uya_interp_%d); })" as *byte, temp_name_idx);
                    } else {
                        fprintf(codegen.emit_stream as *void, "printf(\"%%s\", __uya_interp_%d); })" as *byte, temp_name_idx);
                    }
                }
                return;
            }

            // 根据表达式类型确定格式字符串
            if inner.type == ASTNodeType.AST_NUMBER {
                // 整数字面量：默认按 i32 处理
                fmt = "%d";
            } else if inner.type == ASTNodeType.AST_FLOAT {
                fmt = "%g";
            } else if inner.type == ASTNodeType.AST_BOOL {
                fmt = "%d";
            } else if inner.type == ASTNodeType.AST_STRING || inner.type == ASTNodeType.AST_STRING_INTERP {
                fmt = "%s";
                need_cast = 1;
            } else if inner.type == ASTNodeType.AST_CAST_EXPR {
                // 强制转换：根据目标类型选择格式
                if inner.cast_expr_target_type != null {
                    const target: &ASTNode = inner.cast_expr_target_type;
                    if target.type == ASTNodeType.AST_TYPE_NAMED && target.type_named_name != null {
                        const name: &byte = target.type_named_name;
                        if str_equals(name as *byte, "i8" as *byte) != 0 ||
                           str_equals(name as *byte, "i16" as *byte) != 0 ||
                           str_equals(name as *byte, "i32" as *byte) != 0 ||
                           str_equals(name as *byte, "i64" as *byte) != 0 {
                            fmt = "%lld";
                        } else if str_equals(name as *byte, "u8" as *byte) != 0 ||
                                  str_equals(name as *byte, "u16" as *byte) != 0 ||
                                  str_equals(name as *byte, "u32" as *byte) != 0 ||
                                  str_equals(name as *byte, "u64" as *byte) != 0 ||
                                  str_equals(name as *byte, "usize" as *byte) != 0 {
                            fmt = "%llu";
                        } else if str_equals(name as *byte, "f32" as *byte) != 0 ||
                                  str_equals(name as *byte, "f64" as *byte) != 0 {
                            fmt = "%g";
                        } else if str_equals(name as *byte, "bool" as *byte) != 0 {
                            fmt = "%d";
                        }
                    }
                }
            } else if inner.type == ASTNodeType.AST_IDENTIFIER {
                // 固定 i8/u8 数组在变量表中为 "const int8_t[N]" / "uint8_t[N]" 等，须用 %%s 而非 %%lld
                var id_ty: &byte = null;
                if inner.identifier_name != null {
                    id_ty = get_identifier_type_c(codegen, inner.identifier_name);
                }
                if id_ty != null {
                    var ip: *byte = id_ty as *byte;
                    if strncmp(ip, "const " as *byte, 6) == 0 {
                        ip = ip + 6;
                    }
                    if strncmp(ip, "int8_t" as *byte, 6) == 0 && ip[6] == 91 {
                        fmt = "%s";
                        need_cast = 1;
                    } else if strncmp(ip, "uint8_t" as *byte, 7) == 0 && ip[7] == 91 {
                        fmt = "%s";
                        need_cast = 1;
                    }
                }
                if fmt == null {
                    fmt = "%lld";
                }
            } else if inner.type == ASTNodeType.AST_BINARY_EXPR {
                // 二元表达式：整数或浮点运算
                fmt = "%lld";
            }

            if fmt == null {
                fmt = "%lld";  // 默认整数格式
            }

            // nostdlib 模式：使用 syscall write，仅支持字符串
            if codegen.is_nostdlib != 0 && (inner.type == ASTNodeType.AST_STRING || inner.type == ASTNodeType.AST_STRING_INTERP) {
                // 生成 uya_write(1, "string", len) 调用
                fputs("uya_write(1, " as *byte, codegen.emit_stream as *void);
                if need_cast != 0 {
                    fputs("(char *)" as *byte, codegen.emit_stream as *void);
                }
                gen_expr(codegen, expr.print_expr);
                // 计算字符串长度（内联 strlen）
                fputs(", uya_strlen(" as *byte, codegen.emit_stream as *void);
                if need_cast != 0 {
                    fputs("(char *)" as *byte, codegen.emit_stream as *void);
                }
                gen_expr(codegen, expr.print_expr);
                fputs("))" as *byte, codegen.emit_stream as *void);
                // 如果是 println，再输出换行符
                if expr.type == ASTNodeType.AST_PRINTLN {
                    fputs("; uya_write(1, \"\\n\", 1)" as *byte, codegen.emit_stream as *void);
                }
            } else {
                // 普通模式：生成 printf 调用
                if expr.type == ASTNodeType.AST_PRINTLN {
                    fprintf(codegen.emit_stream as *void, "printf(\"%s\\n\", " as *byte, fmt as *byte);
                } else {
                    fprintf(codegen.emit_stream as *void, "printf(\"%s\", " as *byte, fmt as *byte);
                }

                if need_cast != 0 {
                    fputs("(char *)" as *byte, codegen.emit_stream as *void);
                }

                gen_expr(codegen, expr.print_expr);
                fputc(41, codegen.emit_stream as *void);
            }
        }
}

/// try 错误分支的 return 右侧表达式：普通函数为 err_union；async poll 内须包成 Poll.Ready。
/// kind：0 为仅传播 error_id（.value 由复合字面量零初始化）；1 为整包 _uya_try_tmp（如 !void）。
fn c99_try_emit_error_return_value(codegen: &C99CodeGenerator, ret_union_c: &byte, kind: i32) void {
    if codegen.async_state_var != null && codegen.async_poll_ret_c != null && codegen.async_poll_union_c != null {
        if kind != 0 {
            fprintf(codegen.emit_stream as *void, "(%s){ ._tag = 1, .u = (%s){ .Ready = _uya_try_tmp } }" as *byte,
                codegen.async_poll_ret_c as *byte, codegen.async_poll_union_c as *byte);
        } else {
            fprintf(codegen.emit_stream as *void, "(%s){ ._tag = 1, .u = (%s){ .Ready = (%s){ .error_id = _uya_try_tmp.error_id } } }" as *byte,
                codegen.async_poll_ret_c as *byte, codegen.async_poll_union_c as *byte, ret_union_c as *byte);
        }
    } else {
        if kind != 0 {
            fputs("_uya_try_tmp" as *byte, codegen.emit_stream as *void);
        } else {
            fprintf(codegen.emit_stream as *void, "(%s){ .error_id = _uya_try_tmp.error_id }" as *byte, ret_union_c as *byte);
        }
    }
}

// 生成 try 表达式
fn gen_try_expr(codegen: &C99CodeGenerator, expr: &ASTNode) void {
        if codegen != null && expr != null && codegen.async_expr_subst_try_expr != null &&
            @usize_from_ptr(expr as &void) == @usize_from_ptr(codegen.async_expr_subst_try_expr as &void) {
            const subst_name: &byte = get_safe_c_identifier(codegen, codegen.async_expr_subst_name);
            if codegen.async_state_var != null && subst_name != null {
                fprintf(codegen.emit_stream as *void, "%s->_uya_bind_%s" as *byte,
                    codegen.async_state_var as *byte, subst_name as *byte);
                return;
            }
        }
        const operand: &ASTNode = expr.try_expr_operand;
        var try_ret_type: &ASTNode = codegen.current_function_return_type;
        if codegen.async_state_var != null && codegen.async_poll_try_propagate_type != null {
            try_ret_type = codegen.async_poll_try_propagate_type;
        }
        if operand == null {
            fputs("0" as *byte, codegen.emit_stream as *void);
            return;
        }
        var operand_union_c: &byte = get_c_type_of_expr(codegen, operand);
        // 操作数为 AST_BLOCK 时（如 encode_to_to_json 展开的块）get_c_type_of_expr 可能未返回错误联合类型，按 !usize 处理
        if operand.type == ASTNodeType.AST_BLOCK && (operand_union_c == null || strstr(operand_union_c as *byte, "err_union_" as *byte) == null) {
            const payload_type: &ASTNode = ast_new_node(ASTNodeType.AST_TYPE_NAMED, 0, 0, codegen.arena, null);
            if payload_type != null {
                payload_type.type_named_name = "usize" as &byte;
                const err_union_type: &ASTNode = ast_new_node(ASTNodeType.AST_TYPE_ERROR_UNION, 0, 0, codegen.arena, null);
                if err_union_type != null {
                    err_union_type.type_error_union_payload_type = payload_type;
                    operand_union_c = c99_type_to_c(codegen, err_union_type);
                }
            }
        }
        var operand_is_err_union: i32 = 0;
        if operand_union_c != null && strstr(operand_union_c as *byte, "err_union_" as *byte) != null {
            operand_is_err_union = 1;
        }
        
        // 检查返回类型是否是 !void
        var ret_is_void: i32 = 0;
        if try_ret_type != null && try_ret_type.type == ASTNodeType.AST_TYPE_ERROR_UNION && try_ret_type.type_error_union_payload_type != null {
            const payload: &ASTNode = try_ret_type.type_error_union_payload_type;
            if payload.type == ASTNodeType.AST_TYPE_NAMED && payload.type_named_name != null {
                if strcmp(payload.type_named_name as *byte, "void" as *byte) == 0 {
                    ret_is_void = 1;
                }
            }
        }
        
        // 检查操作数类型是否是 !void
        var operand_is_void: i32 = 0;
        if operand_union_c != null && strcmp(operand_union_c as *byte, "struct err_union_void" as *byte) == 0 {
            operand_is_void = 1;
        }
        
        if operand_is_err_union == 0 || try_ret_type == null || try_ret_type.type != ASTNodeType.AST_TYPE_ERROR_UNION {
            if try_ret_type != null && try_ret_type.type == ASTNodeType.AST_TYPE_ERROR_UNION {
                var union_c: &byte = c99_type_to_c(codegen, try_ret_type);
                var try_payload_ast: &ASTNode = null;
                if codegen.checker != null {
                    var try_union_c: &byte = null;
                    if operand.type == ASTNodeType.AST_MATCH_EXPR && operand.match_expr_arm_count > 0 && operand.match_expr_arms != null {
                        var first_result: &ASTNode = operand.match_expr_arms[0].result_expr;
                        if first_result != null && first_result.type != ASTNodeType.AST_ERROR_VALUE {
                            var payload_ast: &ASTNode = null;
                            if first_result.type == ASTNodeType.AST_BLOCK && first_result.block_stmts != null {
                                var block_tail_expr: &ASTNode = null;
                                var si: i32 = first_result.block_stmt_count - 1;
                                while si >= 0 {
                                    const st: &ASTNode = first_result.block_stmts[si];
                                    if st != null && st.type != ASTNodeType.AST_VAR_DECL &&
                                        st.type != ASTNodeType.AST_RETURN_STMT && st.type != ASTNodeType.AST_IF_STMT &&
                                        st.type != ASTNodeType.AST_WHILE_STMT && st.type != ASTNodeType.AST_FOR_STMT &&
                                        st.type != ASTNodeType.AST_BREAK_STMT && st.type != ASTNodeType.AST_CONTINUE_STMT &&
                                        st.type != ASTNodeType.AST_DEFER_STMT && st.type != ASTNodeType.AST_ERRDEFER_STMT &&
                                        st.type != ASTNodeType.AST_ASSIGN && st.type != ASTNodeType.AST_EXPR_STMT {
                                        block_tail_expr = st;
                                        si = -1;
                                    }
                                    si = si - 1;
                                }
                                if block_tail_expr != null && block_tail_expr.type == ASTNodeType.AST_IDENTIFIER &&
                                    block_tail_expr.identifier_name != null {
                                    si = first_result.block_stmt_count - 1;
                                    while si >= 0 {
                                        const st2: &ASTNode = first_result.block_stmts[si];
                                        if st2 != null && st2.type == ASTNodeType.AST_VAR_DECL &&
                                            st2.var_decl_name != null && st2.var_decl_type != null &&
                                            strcmp(st2.var_decl_name as *byte, block_tail_expr.identifier_name as *byte) == 0 {
                                            payload_ast = st2.var_decl_type;
                                            si = -1;
                                        }
                                        si = si - 1;
                                    }
                                }
                            }
                            if payload_ast != null { try_payload_ast = payload_ast; }
                            if payload_ast == null {
                                var infer_node: &ASTNode = first_result;
                                if first_result.type == ASTNodeType.AST_BLOCK && first_result.block_stmt_count > 0 && first_result.block_stmts != null {
                                    var sj: i32 = first_result.block_stmt_count - 1;
                                    while sj >= 0 {
                                        const st3: &ASTNode = first_result.block_stmts[sj];
                                        if st3 != null && st3.type != ASTNodeType.AST_VAR_DECL &&
                                            st3.type != ASTNodeType.AST_RETURN_STMT && st3.type != ASTNodeType.AST_IF_STMT &&
                                            st3.type != ASTNodeType.AST_WHILE_STMT && st3.type != ASTNodeType.AST_FOR_STMT &&
                                            st3.type != ASTNodeType.AST_BREAK_STMT && st3.type != ASTNodeType.AST_CONTINUE_STMT &&
                                            st3.type != ASTNodeType.AST_DEFER_STMT && st3.type != ASTNodeType.AST_ERRDEFER_STMT &&
                                            st3.type != ASTNodeType.AST_ASSIGN && st3.type != ASTNodeType.AST_EXPR_STMT {
                                            infer_node = st3;
                                            sj = -1;
                                        }
                                        sj = sj - 1;
                                    }
                                }
                                const payload_type: Type = checker_infer_type(codegen.checker, infer_node);
                                if payload_type.kind == TypeKind.TYPE_ERROR_UNION {
                                    const try_ast: &ASTNode = type_to_ast(codegen.checker, &payload_type, expr.line, expr.column, expr.filename);
                                    if try_ast != null { try_union_c = c99_type_to_c(codegen, try_ast); }
                                } else if payload_type.kind != TypeKind.TYPE_VOID {
                                    const payload_ptr: &Type = compiler_arena_alloc(codegen.checker.arena, @size_of(Type)) as &Type;
                                    if payload_ptr != null {
                                        payload_ptr[0] = payload_type;
                                        const eu_type: Type = make_error_union_type(codegen.checker.arena, payload_ptr);
                                        const try_ast: &ASTNode = type_to_ast(codegen.checker, &eu_type, expr.line, expr.column, expr.filename);
                                        if try_ast != null { try_union_c = c99_type_to_c(codegen, try_ast); }
                                    }
                                }
                            } else {
                                const eu_node: &ASTNode = ast_new_node(ASTNodeType.AST_TYPE_ERROR_UNION, expr.line, expr.column, codegen.arena, expr.filename);
                                if eu_node != null {
                                    eu_node.type_error_union_payload_type = payload_ast;
                                    try_union_c = c99_type_to_c(codegen, eu_node);
                                }
                            }
                        }
                    }
                    if try_union_c == null {
                        if operand != null && operand.type == ASTNodeType.AST_AWAIT_EXPR &&
                            operand.await_expr_operand != null && codegen.current_function_decl != null {
                            const await_try_ast: &ASTNode = c99_async_await_result_ast(codegen, operand, codegen.current_function_decl);
                            if await_try_ast != null {
                                try_union_c = c99_type_to_c(codegen, await_try_ast);
                            }
                        }
                    }
                    if try_union_c == null {
                        const try_type: Type = checker_infer_type(codegen.checker, operand);
                        if try_type.kind == TypeKind.TYPE_ERROR_UNION {
                            const try_ast: &ASTNode = type_to_ast(codegen.checker, &try_type, expr.line, expr.column, expr.filename);
                            if try_ast != null { try_union_c = c99_type_to_c(codegen, try_ast); }
                        }
                    }
                    if try_union_c != null && strstr(try_union_c as *byte, "err_union_" as *byte) != null {
                        union_c = try_union_c;
                    }
                }
                const ret_union_c: &byte = c99_type_to_c(codegen, try_ret_type);
                fprintf(codegen.emit_stream as *void, "({ %s _uya_try_tmp = " as *byte, union_c as *byte);
                const saved_expected_block: &byte = codegen.expected_block_union_type;
                codegen.expected_block_union_type = union_c;
                gen_expr(codegen, operand);
                codegen.expected_block_union_type = saved_expected_block;
                if ret_is_void != 0 {
                    fputs("; if (_uya_try_tmp.error_id != 0) return " as *byte, codegen.emit_stream as *void);
                    c99_try_emit_error_return_value(codegen, ret_union_c, 1);
                    fputs("; })" as *byte, codegen.emit_stream as *void);
                } else {
                    fputs("; if (_uya_try_tmp.error_id != 0) return " as *byte, codegen.emit_stream as *void);
                    c99_try_emit_error_return_value(codegen, ret_union_c, 0);
                    fputs("; " as *byte, codegen.emit_stream as *void);
                    if try_payload_ast != null && try_payload_ast.type == ASTNodeType.AST_TYPE_ARRAY && try_payload_ast.type_array_element_type != null &&
                        try_payload_ast.type_array_size_expr != null && try_payload_ast.type_array_size_expr.type == ASTNodeType.AST_NUMBER {
                        const elem_c: &byte = c99_type_to_c(codegen, try_payload_ast.type_array_element_type);
                        const n: i32 = try_payload_ast.type_array_size_expr.number_value;
                        if n > 0 && n <= 64 {
                            fprintf(codegen.emit_stream as *void, "(%s[%d]){ " as *byte, elem_c as *byte, n);
                            var ti: i32 = 0;
                            while ti < n {
                                if ti > 0 { fputs(", " as *byte, codegen.emit_stream as *void); }
                                fprintf(codegen.emit_stream as *void, "_uya_try_tmp.value[%d]" as *byte, ti);
                                ti = ti + 1;
                            }
                            fputs(" }; })" as *byte, codegen.emit_stream as *void);
                        } else {
                            fputs("_uya_try_tmp.value; })" as *byte, codegen.emit_stream as *void);
                        }
                    } else {
                        fputs("_uya_try_tmp.value; })" as *byte, codegen.emit_stream as *void);
                    }
                }
            } else {
                // 非 error union 返回类型，无法使用 try
                fputs("0" as *byte, codegen.emit_stream as *void);
            }
            return;
        }
        const ret_union_c2: &byte = c99_type_to_c(codegen, try_ret_type);
        fprintf(codegen.emit_stream as *void, "({ %s _uya_try_tmp = " as *byte, operand_union_c as *byte);
        const saved_expected_block: &byte = codegen.expected_block_union_type;
        codegen.expected_block_union_type = operand_union_c;
        gen_expr(codegen, operand);
        codegen.expected_block_union_type = saved_expected_block;
        // 错误传播时需转换为函数返回类型
        if operand_is_void != 0 {
            // 操作数是 !void，没有值可解包
            fputs("; if (_uya_try_tmp.error_id != 0) return " as *byte, codegen.emit_stream as *void);
            c99_try_emit_error_return_value(codegen, ret_union_c2, 0);
            fputs("; })" as *byte, codegen.emit_stream as *void);
        } else {
            // 操作数有值，需要解包。即使函数返回 !void，try 表达式本身也需要返回解包的值
            fputs("; if (_uya_try_tmp.error_id != 0) return " as *byte, codegen.emit_stream as *void);
            c99_try_emit_error_return_value(codegen, ret_union_c2, 0);
            fputs("; _uya_try_tmp.value; })" as *byte, codegen.emit_stream as *void);
        }
}

// 生成从数组字面量创建的切片（&[value: N] 或 &[elem1, elem2, ...]）
// unar_expr: 整个取地址表达式 &array_literal
fn gen_slice_from_array_literal(codegen: &C99CodeGenerator, unary_expr: &ASTNode) void {
    const array_expr: &ASTNode = unary_expr.unary_expr_operand;
    
    // 从整个取地址表达式获取切片类型
    const slice_type_c: &byte = get_c_type_of_expr(codegen, unary_expr);
    var slice_type_str: &byte = ("struct uya_slice_int32_t" as *byte) as &byte;
    if slice_type_c != null {
        slice_type_str = slice_type_c;
    }
    
    const element_count: i32 = array_expr.array_literal_element_count;
    const repeat_count_expr: &ASTNode = array_expr.array_literal_repeat_count_expr;
    
    // 计算实际长度
    var actual_len: i32 = element_count;
    if repeat_count_expr != null && element_count >= 1 {
        actual_len = eval_const_expr(codegen, repeat_count_expr);
        if actual_len < 0 {
            actual_len = 0;
        }
    }
    
    // 生成切片结构体
    fprintf(codegen.emit_stream as *void, "(%s){ .ptr = (" as *byte, slice_type_str as *byte);
    
    if actual_len > 0 {
        // 获取元素类型（从数组字面量的第一个元素）
        const elem_type_c: &byte = get_c_type_of_expr(codegen, array_expr.array_literal_elements[0]);
        var elem_type_str: &byte = ("int32_t" as *byte) as &byte;
        if elem_type_c != null {
            elem_type_str = elem_type_c;
        }
        
        // 生成数组复合字面量
        fprintf(codegen.emit_stream as *void, "%s[%d]){" as *byte, elem_type_str as *byte, actual_len);
        
        if repeat_count_expr != null && element_count >= 1 {
            // [value: N] 形式
            var i: i32 = 0;
            while i < actual_len {
                gen_expr(codegen, array_expr.array_literal_elements[0]);
                if i < actual_len - 1 {
                    c99_emit_comma_space(codegen);
                }
                i = i + 1;
            }
        } else {
            // [elem1, elem2, ...] 形式
            var i: i32 = 0;
            while i < element_count {
                gen_expr(codegen, array_expr.array_literal_elements[i]);
                if i < element_count - 1 {
                    c99_emit_comma_space(codegen);
                }
                i = i + 1;
            }
        }
        fputs("}" as *byte, codegen.emit_stream as *void);
    } else {
        // 空切片：使用 NULL 指针
        fputs("void *)0" as *byte, codegen.emit_stream as *void);
    }
    
    // 生成长度字段
    fprintf(codegen.emit_stream as *void, ", .len = %d }" as *byte, actual_len);
}

// 生成一元表达式
fn gen_unary_expr(codegen: &C99CodeGenerator, expr: &ASTNode) void {
        const op_tmp: !TokenType = expr.unary_expr_op as! TokenType;
        const op: TokenType = op_tmp.value;
        const operand: &ASTNode = expr.unary_expr_operand;

        if c99_gen_simd_unary_expr(codegen, expr) != 0 {
            return;
        }
        
        // 特殊处理：& 作用于数组字面量，生成切片
        if op == TokenType.TOKEN_AMPERSAND && operand.type == ASTNodeType.AST_ARRAY_LITERAL {
            gen_slice_from_array_literal(codegen, expr);
            return;
        }
        
        // & 作用于原子成员：gen_expr 内需裸左值（标志仅在 gen_expr(operand) 前后置位，避免早退泄漏）
        var amp_atomic_member_plain: i32 = 0;
        if op == TokenType.TOKEN_AMPERSAND && operand.type == ASTNodeType.AST_MEMBER_ACCESS && operand.member_access_is_module_access == 0 {
            const st_amp: &ASTNode = c99_resolve_struct_decl_for_member_object(codegen, operand.member_access_object);
            if st_amp != null && operand.member_access_field_name != null {
                const ft_amp: &ASTNode = c99_find_struct_field_type(codegen, st_amp, operand.member_access_field_name);
                if ft_amp != null && ft_amp.type == ASTNodeType.AST_TYPE_ATOMIC {
                    amp_atomic_member_plain = 1;
                }
            }
        }
        
        // 特殊处理：& 作用于原子类型变量，直接取地址（不生成原子 load）
        // 例如：&value（value 是 atomic i32）应该生成 &value 而不是 &__atomic_load_n(&value, ...)
        if op == TokenType.TOKEN_AMPERSAND && operand.type == ASTNodeType.AST_IDENTIFIER {
            const name: &byte = operand.identifier_name;
            if name != null {
                const ref_name: &byte = get_c_name_for_identifier_ref(codegen, name);
                const type_c: &byte = get_identifier_type_c(codegen, name);
                // 如果是原子类型，直接输出 &variable
                if type_c != null && strstr(type_c as *byte, "_Atomic" as *byte) != null {
                    fprintf(codegen.emit_stream as *void, "&%s" as *byte, ref_name as *byte);
                    return;
                }
            }
        }
        
        // 避免 i32 INT_MIN：用 @min 比较；且 "(-" + "-2147483648" 会变成 "--" 被解析为递减
        if op == TokenType.TOKEN_MINUS && operand.type == ASTNodeType.AST_NUMBER {
            const nv: i64 = operand.number_value;
            const i32_min_val: i32 = @min;
            if (nv as i32) == i32_min_val {
                fputs("(-2147483647LL-1LL)" as *byte, codegen.emit_stream as *void);
                return;
            }
        }
        if op == TokenType.TOKEN_ASTERISK && codegen.container_mode != 0 {
            c99_emit_mmu_wrapped_deref(codegen, operand);
            return;
        }
        fputc(40, codegen.emit_stream as *void);  // '('
        if op == TokenType.TOKEN_ASTERISK {
            fputs("*" as *byte, codegen.emit_stream as *void);
        } else if op == TokenType.TOKEN_AMPERSAND {
            fputs("&" as *byte, codegen.emit_stream as *void);
        } else if op == TokenType.TOKEN_MINUS {
            fputs("-" as *byte, codegen.emit_stream as *void);
        } else if op == TokenType.TOKEN_EXCLAMATION {
            fputs("!" as *byte, codegen.emit_stream as *void);
        } else if op == TokenType.TOKEN_TILDE {
            fputs("~" as *byte, codegen.emit_stream as *void);
        } else if op == TokenType.TOKEN_PLUS {
            fputs("+" as *byte, codegen.emit_stream as *void);
        } else {
            fputs("+" as *byte, codegen.emit_stream as *void); // 默认
        }
        if amp_atomic_member_plain != 0 {
            codegen.atomic_member_plain_lvalue = 1;
        }
        gen_expr(codegen, operand);
        if amp_atomic_member_plain != 0 {
            codegen.atomic_member_plain_lvalue = 0;
        }
        fputc(41, codegen.emit_stream as *void);  // ')'
}

// 检测是否是字符串函数
fn is_string_function(name: &byte) i32 {
    if name == null { return 0; }
    if strcmp(name as *byte, "strcmp" as *byte) == 0 { return 1; }
    if strcmp(name as *byte, "strncmp" as *byte) == 0 { return 1; }
    if strcmp(name as *byte, "strlen" as *byte) == 0 { return 1; }
    if strcmp(name as *byte, "strcpy" as *byte) == 0 { return 1; }
    if strcmp(name as *byte, "strncpy" as *byte) == 0 { return 1; }
    if strcmp(name as *byte, "strcat" as *byte) == 0 { return 1; }
    if strcmp(name as *byte, "strncat" as *byte) == 0 { return 1; }
    if strcmp(name as *byte, "strchr" as *byte) == 0 { return 1; }
    if strcmp(name as *byte, "strrchr" as *byte) == 0 { return 1; }
    if strcmp(name as *byte, "strstr" as *byte) == 0 { return 1; }
    if strcmp(name as *byte, "strdup" as &byte) == 0 { return 1; }
    if strcmp(name as *byte, "strndup" as &byte) == 0 { return 1; }
    return 0;
}

// 生成 @asm 块的 C99 内联汇编代码
// 所有指令合并到单个 __asm__ volatile 块中
fn gen_asm_block(codegen: &C99CodeGenerator, expr: &ASTNode) void {
    // 生成 __asm__ volatile (...)
    // 格式：__asm__ volatile ("instr1\n\tinstr2\n\t..." : outputs : inputs : clobbers);

    // 开始内联汇编
    fputs("__asm__ volatile (\"" as *byte, codegen.emit_stream as *void);

    // 输出所有指令字符串
    var instr_idx: i32 = 0;
    while instr_idx < expr.asm_instruction_count {
        const instr: &u8 = expr.asm_instructions[instr_idx] as &u8;
        if instr != null {
            var i: i32 = 0;
            while instr[i] != 0 {
                const c: byte = instr[i] as byte;
                if c == 34 {  // "
                    fputs("\\\"" as *byte, codegen.emit_stream as *void);
                } else if c == 10 {  // \n
                    fputs("\\n" as *byte, codegen.emit_stream as *void);
                } else if c == 9 {  // \t
                    fputs("\\t" as *byte, codegen.emit_stream as *void);
                } else if c == 92 {  // \
                    fputs("\\\\" as *byte, codegen.emit_stream as *void);
                } else {
                    fputc(c as i32, codegen.emit_stream as *void);
                }
                i = i + 1;
            }
        }
        // 每条指令后加换行
        fputs("\\n\\t" as *byte, codegen.emit_stream as *void);
        instr_idx = instr_idx + 1;
    }
    fputs("\"\n" as *byte, codegen.emit_stream as *void);

    // 输出部分：收集所有指令的输出
    fputs("    : " as *byte, codegen.emit_stream as *void);
    instr_idx = 0;
    var output_offset: i32 = 0;
    var has_prev_output: i32 = 0;
    while instr_idx < expr.asm_instruction_count {
        const output_count: i32 = expr.asm_output_counts[instr_idx];
        var out_idx: i32 = 0;
        while out_idx < output_count {
            if has_prev_output != 0 {
                fputs(", " as *byte, codegen.emit_stream as *void);
            }
            fputs("\"=r\"(" as *byte, codegen.emit_stream as *void);
            gen_expr(codegen, expr.asm_outputs[output_offset + out_idx]);
            fputc(41, codegen.emit_stream as *void);  // )
            has_prev_output = 1;
            out_idx = out_idx + 1;
        }
        output_offset = output_offset + output_count;
        instr_idx = instr_idx + 1;
    }
    fputs("\n" as *byte, codegen.emit_stream as *void);

    // 输入部分：收集所有指令的输入
    fputs("    : " as *byte, codegen.emit_stream as *void);
    instr_idx = 0;
    var input_offset: i32 = 0;
    var has_prev_input: i32 = 0;
    while instr_idx < expr.asm_instruction_count {
        const input_count: i32 = expr.asm_input_counts[instr_idx];
        var in_idx: i32 = 0;
        while in_idx < input_count {
            if has_prev_input != 0 {
                fputs(", " as *byte, codegen.emit_stream as *void);
            }
            fputs("\"r\"(" as *byte, codegen.emit_stream as *void);
            gen_expr(codegen, expr.asm_inputs[input_offset + in_idx]);
            fputc(41, codegen.emit_stream as *void);  // )
            has_prev_input = 1;
            in_idx = in_idx + 1;
        }
        input_offset = input_offset + input_count;
        instr_idx = instr_idx + 1;
    }
    fputs("\n" as *byte, codegen.emit_stream as *void);

    // Clobbers 部分
    fputs("    : " as *byte, codegen.emit_stream as *void);
    var has_prev: i32 = 0;
    if expr.asm_clobbers_memory != 0 {
        fputs("\"memory\"" as *byte, codegen.emit_stream as *void);
        has_prev = 1;
    }
    var clobber_idx: i32 = 0;
    while clobber_idx < expr.asm_clobber_count {
        if has_prev != 0 {
            fputs(", " as *byte, codegen.emit_stream as *void);
        }
        fputc(34, codegen.emit_stream as *void);  // "
        fputs(expr.asm_clobbers[clobber_idx] as *byte, codegen.emit_stream as *void);
        fputc(34, codegen.emit_stream as *void);  // "
        has_prev = 1;
        clobber_idx = clobber_idx + 1;
    }

    fputs("\n" as *byte, codegen.emit_stream as *void);
    fputs("    );\n" as *byte, codegen.emit_stream as *void);
}
