fn c99_gen_simd_builtin_call(codegen: &C99CodeGenerator, expr: &ASTNode) i32 {
    const method_name: &byte = c99_simd_vector_builtin_method(expr);
    if method_name == null {
        return 0;
    }

    if str_equals(method_name, "store" as *byte) != 0 {
        if expr.call_expr_arg_count != 2 || expr.call_expr_args == null ||
            expr.call_expr_args[0] == null || expr.call_expr_args[1] == null {
            return 0;
        }
        var target_st: &ASTNode = expr.simd_splat_target_type;
        if target_st == null {
            target_st = c99_resolve_simd_type_ast_from_expr(codegen, expr.call_expr_args[1]);
        }
        if target_st == null || target_st.type != ASTNodeType.AST_TYPE_VECTOR ||
            target_st.type_vector_size_expr == null {
            return 0;
        }
        const result_st: &byte = c99_type_to_c(codegen, target_st);
        const lanes_st: i32 = eval_const_expr(codegen, target_st.type_vector_size_expr);
        const tmp_st: &byte = c99_make_temp_name(codegen, "__uya_simd_store_" as &byte);
        if result_st == null || tmp_st == null || lanes_st <= 0 {
            return 0;
        }
        fputs("({ " as *byte, codegen.emit_stream as *void);
        fprintf(codegen.emit_stream as *void, "%s %s = " as *byte, result_st as *byte, tmp_st as *byte);
        gen_expr(codegen, expr.call_expr_args[1]);
        fputs("; __uya_memcpy((void*)(" as *byte, codegen.emit_stream as *void);
        gen_expr(codegen, expr.call_expr_args[0]);
        fprintf(codegen.emit_stream as *void, "), &%s, sizeof(%s)); 0; })" as *byte, tmp_st as *byte, tmp_st as *byte);
        return 1;
    }

    if str_equals(method_name, "select" as *byte) != 0 {
        if expr.call_expr_arg_count != 3 || expr.call_expr_args == null ||
            expr.call_expr_args[0] == null || expr.call_expr_args[1] == null || expr.call_expr_args[2] == null {
            return 0;
        }
        var target_sel: &ASTNode = expr.simd_splat_target_type;
        if target_sel == null {
            target_sel = c99_resolve_simd_type_ast_from_expr(codegen, expr.call_expr_args[1]);
        }
        if target_sel == null {
            target_sel = c99_resolve_simd_type_ast_from_expr(codegen, expr.call_expr_args[2]);
        }
        if target_sel == null || target_sel.type != ASTNodeType.AST_TYPE_VECTOR ||
            target_sel.type_vector_element_type == null || target_sel.type_vector_size_expr == null {
            return 0;
        }
        const result_sel: &byte = c99_type_to_c(codegen, target_sel);
        const lanes_sel: i32 = eval_const_expr(codegen, target_sel.type_vector_size_expr);
        const m_nm: &byte = c99_make_temp_name(codegen, "__uya_simd_sel_m_" as &byte);
        const a_nm: &byte = c99_make_temp_name(codegen, "__uya_simd_sel_a_" as &byte);
        const b_nm: &byte = c99_make_temp_name(codegen, "__uya_simd_sel_b_" as &byte);
        const out_nm: &byte = c99_make_temp_name(codegen, "__uya_simd_sel_o_" as &byte);
        if result_sel == null || lanes_sel <= 0 || m_nm == null || a_nm == null || b_nm == null || out_nm == null {
            return 0;
        }
        const mask_ast_sel: &ASTNode = c99_resolve_simd_type_ast_from_expr(codegen, expr.call_expr_args[0]);
        if mask_ast_sel == null || mask_ast_sel.type != ASTNodeType.AST_TYPE_MASK || mask_ast_sel.type_mask_size_expr == null {
            return 0;
        }
        const lanes_m: i32 = eval_const_expr(codegen, mask_ast_sel.type_mask_size_expr);
        if lanes_m != lanes_sel {
            return 0;
        }
        const mask_c2: &byte = c99_type_to_c(codegen, mask_ast_sel);
        if mask_c2 == null {
            return 0;
        }
        fputs("({ " as *byte, codegen.emit_stream as *void);
        fprintf(codegen.emit_stream as *void, "%s %s = " as *byte, mask_c2 as *byte, m_nm as *byte);
        gen_expr(codegen, expr.call_expr_args[0]);
        fputs("; " as *byte, codegen.emit_stream as *void);
        fprintf(codegen.emit_stream as *void, "%s %s = " as *byte, result_sel as *byte, a_nm as *byte);
        gen_expr(codegen, expr.call_expr_args[1]);
        fputs("; " as *byte, codegen.emit_stream as *void);
        fprintf(codegen.emit_stream as *void, "%s %s = " as *byte, result_sel as *byte, b_nm as *byte);
        gen_expr(codegen, expr.call_expr_args[2]);
        fputs("; " as *byte, codegen.emit_stream as *void);
        fprintf(codegen.emit_stream as *void, "%s %s; " as *byte, result_sel as *byte, out_nm as *byte);
        const elem_ty_sel: &ASTNode = target_sel.type_vector_element_type;
        const elem_c_sel: &byte = c99_type_to_c(codegen, elem_ty_sel);
        const elem_base_sel: &byte = c99_type_c_skip_const(elem_c_sel);
        var use_sel_x4: i32 = 0;
        var use_sel_x2: i32 = 0;
        if lanes_sel == 4 && elem_base_sel != null {
