}

// @vector.reduce_min(v)：标量 while 循环取最小值
fn c99_gen_simd_reduce_min_call(codegen: &C99CodeGenerator, expr: &ASTNode) i32 {
    if expr.call_expr_arg_count != 1 || expr.call_expr_args == null || expr.call_expr_args[0] == null {
        return 0;
    }
    var target_rmin: &ASTNode = expr.simd_splat_target_type;
    if target_rmin == null {
        target_rmin = c99_resolve_simd_type_ast_from_expr(codegen, expr.call_expr_args[0]);
    }
    if target_rmin == null || target_rmin.type != ASTNodeType.AST_TYPE_VECTOR ||
        target_rmin.type_vector_element_type == null || target_rmin.type_vector_size_expr == null {
        return 0;
    }
    const vec_c: &byte = c99_type_to_c(codegen, target_rmin);
    const lanes_rmin: i32 = eval_const_expr(codegen, target_rmin.type_vector_size_expr);
    const elem_ty_rmin: &ASTNode = target_rmin.type_vector_element_type;
    const elem_c_rmin: &byte = c99_type_to_c(codegen, elem_ty_rmin);
    var v_nm: &byte = c99_make_temp_name(codegen, "__uya_rmin_v_" as &byte);
    var s_nm: &byte = c99_make_temp_name(codegen, "__uya_rmin_s_" as &byte);
    if vec_c == null || lanes_rmin <= 0 || elem_c_rmin == null || v_nm == null || s_nm == null {
        return 0;
    }
    // i32/u32/f32 ×2/×4：优先 SSE helpers（SSE4.1 _mm_min_epi32 等在 helpers 内带条件编译）
    if lanes_rmin == 2 {
        if str_equals(elem_c_rmin, "int32_t") != 0 {
            fputs("({ " as *byte, codegen.emit_stream as *void);
            fprintf(codegen.emit_stream as *void, "%s %s = " as *byte, vec_c as *byte, v_nm as *byte);
            gen_expr(codegen, expr.call_expr_args[0]);
            fprintf(codegen.emit_stream as *void, "; %s %s; uya_simd_sse_reduce_min_i32x2(&%s, &%s); %s; })" as *byte, elem_c_rmin as *byte, s_nm as *byte, s_nm as *byte, v_nm as *byte, s_nm as *byte);
            return 1;
        }
        if str_equals(elem_c_rmin, "uint32_t") != 0 {
            fputs("({ " as *byte, codegen.emit_stream as *void);
            fprintf(codegen.emit_stream as *void, "%s %s = " as *byte, vec_c as *byte, v_nm as *byte);
            gen_expr(codegen, expr.call_expr_args[0]);
            fprintf(codegen.emit_stream as *void, "; %s %s; uya_simd_sse_reduce_min_u32x2(&%s, &%s); %s; })" as *byte, elem_c_rmin as *byte, s_nm as *byte, s_nm as *byte, v_nm as *byte, s_nm as *byte);
            return 1;
        }
        if str_equals(elem_c_rmin, "float") != 0 {
            fputs("({ " as *byte, codegen.emit_stream as *void);
            fprintf(codegen.emit_stream as *void, "%s %s = " as *byte, vec_c as *byte, v_nm as *byte);
            gen_expr(codegen, expr.call_expr_args[0]);
            fprintf(codegen.emit_stream as *void, "; %s %s; uya_simd_sse_reduce_min_f32x2(&%s, &%s); %s; })" as *byte, elem_c_rmin as *byte, s_nm as *byte, s_nm as *byte, v_nm as *byte, s_nm as *byte);
            return 1;
        }
    }
    if lanes_rmin == 4 {
        if str_equals(elem_c_rmin, "int32_t") != 0 {
            fputs("({ " as *byte, codegen.emit_stream as *void);
            fprintf(codegen.emit_stream as *void, "%s %s = " as *byte, vec_c as *byte, v_nm as *byte);
            gen_expr(codegen, expr.call_expr_args[0]);
            fprintf(codegen.emit_stream as *void, "; %s %s; uya_simd_sse_reduce_min_i32x4(&%s, &%s); %s; })" as *byte, elem_c_rmin as *byte, s_nm as *byte, s_nm as *byte, v_nm as *byte, s_nm as *byte);
            return 1;
        }
        if str_equals(elem_c_rmin, "uint32_t") != 0 {
            fputs("({ " as *byte, codegen.emit_stream as *void);
            fprintf(codegen.emit_stream as *void, "%s %s = " as *byte, vec_c as *byte, v_nm as *byte);
            gen_expr(codegen, expr.call_expr_args[0]);
            fprintf(codegen.emit_stream as *void, "; %s %s; uya_simd_sse_reduce_min_u32x4(&%s, &%s); %s; })" as *byte, elem_c_rmin as *byte, s_nm as *byte, s_nm as *byte, v_nm as *byte, s_nm as *byte);
            return 1;
        }
        if str_equals(elem_c_rmin, "float") != 0 {
            fputs("({ " as *byte, codegen.emit_stream as *void);
            fprintf(codegen.emit_stream as *void, "%s %s = " as *byte, vec_c as *byte, v_nm as *byte);
            gen_expr(codegen, expr.call_expr_args[0]);
            fprintf(codegen.emit_stream as *void, "; %s %s; uya_simd_sse_reduce_min_f32x4(&%s, &%s); %s; })" as *byte, elem_c_rmin as *byte, s_nm as *byte, s_nm as *byte, v_nm as *byte, s_nm as *byte);
            return 1;
        }
    }
    // x8 或不支持类型：标量 while 循环
    {
        const i_nm: &byte = c99_make_temp_name(codegen, "__uya_rmin_i_" as &byte);
        if i_nm == null { return 0; }
        fputs("({ " as *byte, codegen.emit_stream as *void);
        fprintf(codegen.emit_stream as *void, "%s %s = " as *byte, vec_c as *byte, v_nm as *byte);
        gen_expr(codegen, expr.call_expr_args[0]);
        fputs("; " as *byte, codegen.emit_stream as *void);
        fprintf(codegen.emit_stream as *void, "%s %s = %s.lanes[0]; " as *byte, elem_c_rmin as *byte, s_nm as *byte, v_nm as *byte);
        fprintf(codegen.emit_stream as *void, "int %s = 1; " as *byte, i_nm as *byte);
        fprintf(codegen.emit_stream as *void, "while (%s < %d) { " as *byte, i_nm as *byte, lanes_rmin);
        fprintf(codegen.emit_stream as *void, "if (%s.lanes[%s] < %s) { %s = %s.lanes[%s]; } " as *byte,
            v_nm as *byte, i_nm as *byte, s_nm as *byte, s_nm as *byte, v_nm as *byte, i_nm as *byte);
        fprintf(codegen.emit_stream as *void, "%s = %s + 1; } " as *byte, i_nm as *byte, i_nm as *byte);
        fprintf(codegen.emit_stream as *void, "%s; })" as *byte, s_nm as *byte);
    }
    return 1;
}

// @vector.reduce_max(v)：SSE/NEON ×2/×4 fast path + 标量 fallback
fn c99_gen_simd_reduce_max_call(codegen: &C99CodeGenerator, expr: &ASTNode) i32 {
    if expr.call_expr_arg_count != 1 || expr.call_expr_args == null || expr.call_expr_args[0] == null {
