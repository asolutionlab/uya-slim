        is_i16 = 1;
    }
    var is_u16_simd: i32 = 0;
    if fast_kind == 41 || fast_kind == 42 || fast_kind == 43 || fast_kind == 117 || fast_kind == 118 ||
        fast_kind == 119 || fast_kind == 120 || fast_kind == 121 || fast_kind == 122 {
        is_u16_simd = 1;
    }
    var is_i8_u8_simd: i32 = 0;
    if (fast_kind >= 123 && fast_kind <= 142) || (fast_kind >= 163 && fast_kind <= 174) {
        is_i8_u8_simd = 1;
    }
    var is_i64_u64_simd: i32 = 0;
    if (fast_kind >= 143 && fast_kind <= 162) || (fast_kind >= 175 && fast_kind <= 186) {
        is_i64_u64_simd = 1;
    }
    if is_f64 != 0 {
        if lanes != 2 && lanes != 4 {
            return 0;
        }
    } else if is_i16 != 0 || is_u16_simd != 0 {
        if lanes != 4 && lanes != 8 {
            return 0;
        }
    } else if is_i8_u8_simd != 0 {
        if c99_simd_sse_i8_u8_lane_ok(lanes) == 0 {
            return 0;
        }
    } else if is_i64_u64_simd != 0 {
        if c99_simd_sse_i64_u64_lane_ok(lanes) == 0 {
            return 0;
        }
