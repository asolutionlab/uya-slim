                strcmp(elem_base_sel as *byte, "uint32_t" as *byte) == 0 ||
                strcmp(elem_base_sel as *byte, "float" as *byte) == 0 {
                use_sel_x4 = 1;
            }
        }
        if lanes_sel == 2 && elem_base_sel != null {
            if strcmp(elem_base_sel as *byte, "int32_t" as *byte) == 0 ||
                strcmp(elem_base_sel as *byte, "uint32_t" as *byte) == 0 ||
                strcmp(elem_base_sel as *byte, "float" as *byte) == 0 {
                use_sel_x2 = 1;
            }
        }
        if use_sel_x4 != 0 {
            if strcmp(elem_base_sel as *byte, "int32_t" as *byte) == 0 {
                fprintf(codegen.emit_stream as *void, "uya_simd_sse_select_i32x4(&%s, &%s, &%s, &%s); " as *byte,
                    out_nm as *byte, m_nm as *byte, a_nm as *byte, b_nm as *byte);
            } else {
                if strcmp(elem_base_sel as *byte, "uint32_t" as *byte) == 0 {
                    fprintf(codegen.emit_stream as *void, "uya_simd_sse_select_u32x4(&%s, &%s, &%s, &%s); " as *byte,
                        out_nm as *byte, m_nm as *byte, a_nm as *byte, b_nm as *byte);
                } else {
                    fprintf(codegen.emit_stream as *void, "uya_simd_sse_select_f32x4(&%s, &%s, &%s, &%s); " as *byte,
                        out_nm as *byte, m_nm as *byte, a_nm as *byte, b_nm as *byte);
                }
            }
        } else {
            if use_sel_x2 != 0 {
                if strcmp(elem_base_sel as *byte, "int32_t" as *byte) == 0 {
                    fprintf(codegen.emit_stream as *void, "uya_simd_sse_select_i32x2(&%s, &%s, &%s, &%s); " as *byte,
                        out_nm as *byte, m_nm as *byte, a_nm as *byte, b_nm as *byte);
                } else {
                    if strcmp(elem_base_sel as *byte, "uint32_t" as *byte) == 0 {
                        fprintf(codegen.emit_stream as *void, "uya_simd_sse_select_u32x2(&%s, &%s, &%s, &%s); " as *byte,
                            out_nm as *byte, m_nm as *byte, a_nm as *byte, b_nm as *byte);
                    } else {
                        fprintf(codegen.emit_stream as *void, "uya_simd_sse_select_f32x2(&%s, &%s, &%s, &%s); " as *byte,
                            out_nm as *byte, m_nm as *byte, a_nm as *byte, b_nm as *byte);
                    }
                }
            } else {
                var si: i32 = 0;
                while si < lanes_sel {
                    fprintf(codegen.emit_stream as *void, "%s.lanes[%d] = %s.lanes[%d] ? %s.lanes[%d] : %s.lanes[%d]; " as *byte,
                        out_nm as *byte, si, m_nm as *byte, si, a_nm as *byte, si, b_nm as *byte, si);
                    si = si + 1;
                }
            }
        }
        fprintf(codegen.emit_stream as *void, "%s; })" as *byte, out_nm as *byte);
        return 1;
    }

    if str_equals(method_name, "reduce_add" as *byte) != 0 {
        return c99_gen_simd_reduce_add_call(codegen, expr);
    }

    if str_equals(method_name, "reduce_mul" as *byte) != 0 {
        return c99_gen_simd_reduce_mul_call(codegen, expr);
    }

    if str_equals(method_name, "reduce_min" as *byte) != 0 {
        return c99_gen_simd_reduce_min_call(codegen, expr);
    }

    if str_equals(method_name, "reduce_max" as *byte) != 0 {
        return c99_gen_simd_reduce_max_call(codegen, expr);
    }

    if expr.call_expr_arg_count != 1 || expr.call_expr_args == null || expr.call_expr_args[0] == null {
        return 0;
    }

    if str_equals(method_name, "splat" as *byte) != 0 {
        var target_ast: &ASTNode = expr.simd_splat_target_type;
        if target_ast == null && codegen.expected_type != null {
            target_ast = c99_resolve_simd_type_ast_from_type_node(codegen, codegen.expected_type);
        }
