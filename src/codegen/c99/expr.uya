                    k = k + 1;
                }
                fputs(" *)(" as *byte, codegen.emit_stream as *void);
                gen_expr(codegen, obj);
                if is_ptr {
                    fprintf(codegen.emit_stream as *void, ")->vtable)->%s((" as *byte, safe_method as *byte);
                } else {
                    fprintf(codegen.emit_stream as *void, ").vtable)->%s((" as *byte, safe_method as *byte);
                }
                gen_expr(codegen, obj);
                if is_ptr {
                    fputs(")->data" as *byte, codegen.emit_stream as *void);
                } else {
                    fputs(").data" as *byte, codegen.emit_stream as *void);
