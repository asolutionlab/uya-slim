            fprintf(codegen.emit_stream as *void, "%s %s = " as *byte, vec_c as *byte, v_nm as *byte);
            gen_expr(codegen, expr.call_expr_args[0]);
            fprintf(codegen.emit_stream as *void, "; %s %s; uya_simd_sse_reduce_max_i32x2(&%s, &%s); %s; })" as *byte, elem_c_rmax as *byte, s_nm as *byte, s_nm as *byte, v_nm as *byte, s_nm as *byte);
