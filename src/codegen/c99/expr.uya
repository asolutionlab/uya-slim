                }
                if union_decl != null && uname != null {
                    const idx: i32 = find_union_variant_index(union_decl, method_name);
                    if idx >= 0 {
                        const vname_c: &byte = get_safe_c_identifier(codegen, method_name);
                        if vname_c != null {
                            const vnode: &ASTNode = union_decl.union_decl_variants[idx];
                            const is_void: i32 = (vnode != null && vnode.type == ASTNodeType.AST_VAR_DECL && vnode.var_decl_type != null &&
                                vnode.var_decl_type.type == ASTNodeType.AST_TYPE_NAMED && vnode.var_decl_type.type_named_name != null &&
                                strcmp(vnode.var_decl_type.type_named_name as *byte, "void" as *byte) == 0) as i32;
                            if union_decl.union_decl_is_extern != 0 {
                                fprintf(codegen.emit_stream as *void, "((union %s){ .%s = " as *byte, uname as *byte, vname_c as *byte);
                                if is_void != 0 {
                                    fputs("0" as *byte, codegen.emit_stream as *void);
                                } else {
                                    gen_expr(codegen, expr.call_expr_args[0]);
                                }
                                fputs(" })" as *byte, codegen.emit_stream as *void);
                            } else {
                                fprintf(codegen.emit_stream as *void, "((struct uya_tagged_%s){ ._tag = %d, .u = (union %s){ .%s = " as *byte, uname as *byte, idx, uname as *byte, vname_c as *byte);
                                if is_void != 0 {
                                    fputs("0" as *byte, codegen.emit_stream as *void);
                                } else {
                                    gen_expr(codegen, expr.call_expr_args[0]);
                                }
                                fputs(" } })" as *byte, codegen.emit_stream as *void);
                            }
                            return;
                        }
                    }
                }
            }
            const obj_type_c: &byte = get_c_type_of_expr(codegen, obj);
            if obj_type_c != null && strstr(obj_type_c as *byte, "uya_interface_" as *byte) != null {
                const p: *byte = strstr(obj_type_c as *byte, "uya_interface_" as *byte);
                const iface_start: &byte = &p[14] as &byte;
                const safe_method: &byte = get_safe_c_identifier(codegen, method_name);
                const is_ptr: bool = (strchr(obj_type_c as *byte, 42) != null);
                fputs("((struct uya_vtable_" as *byte, codegen.emit_stream as *void);
                var k: i32 = 0;
