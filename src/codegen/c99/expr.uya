            fprintf(codegen.emit_stream as *void, "%s %s = " as *byte, vec_c as *byte, v_nm as *byte);
            gen_expr(codegen, expr.call_expr_args[0]);
            fprintf(codegen.emit_stream as *void, "; %s %s; uya_simd_sse_reduce_max_f32x4(&%s, &%s); %s; })" as *byte, elem_c_rmax as *byte, s_nm as *byte, s_nm as *byte, v_nm as *byte, s_nm as *byte);
            return 1;
        }
    }
    // x8 或不支持类型：标量 while 循环
    {
        const i_nm: &byte = c99_make_temp_name(codegen, "__uya_rmax_i_" as &byte);
        if i_nm == null { return 0; }
        fputs("({ " as *byte, codegen.emit_stream as *void);
        fprintf(codegen.emit_stream as *void, "%s %s = " as *byte, vec_c as *byte, v_nm as *byte);
        gen_expr(codegen, expr.call_expr_args[0]);
        fputs("; " as *byte, codegen.emit_stream as *void);
        fprintf(codegen.emit_stream as *void, "%s %s = %s.lanes[0]; " as *byte, elem_c_rmax as *byte, s_nm as *byte, v_nm as *byte);
        fprintf(codegen.emit_stream as *void, "int %s = 1; " as *byte, i_nm as *byte);
        fprintf(codegen.emit_stream as *void, "while (%s < %d) { " as *byte, i_nm as *byte, lanes_rmax);
        fprintf(codegen.emit_stream as *void, "if (%s.lanes[%s] > %s) { %s = %s.lanes[%s]; } " as *byte,
            v_nm as *byte, i_nm as *byte, s_nm as *byte, s_nm as *byte, v_nm as *byte, i_nm as *byte);
        fprintf(codegen.emit_stream as *void, "%s = %s + 1; } " as *byte, i_nm as *byte, i_nm as *byte);
        fprintf(codegen.emit_stream as *void, "%s; })" as *byte, s_nm as *byte);
    }
    return 1;
}

fn c99_find_identifier_type_node(codegen: &C99CodeGenerator, name: &byte) &ASTNode {
    if codegen == null || name == null {
        return null;
    }
    var local_i: i32 = codegen.local_variable_count - 1;
    while local_i >= 0 {
        if codegen.local_variables[local_i].name != null &&
            str_equals(codegen.local_variables[local_i].name, name) != 0 &&
            codegen.local_variables[local_i].type_node != null {
            return codegen.local_variables[local_i].type_node;
        }
        local_i = local_i - 1;
    }
    if codegen.current_function_decl != null && codegen.current_function_decl.fn_decl_params != null {
        var i: i32 = 0;
        while i < codegen.current_function_decl.fn_decl_param_count {
            const param: &ASTNode = codegen.current_function_decl.fn_decl_params[i];
            if param != null && param.type == ASTNodeType.AST_VAR_DECL && param.var_decl_name != null &&
                str_equals(param.var_decl_name, name) != 0 {
                return param.var_decl_type;
            }
            i = i + 1;
        }
        if codegen.current_function_decl.fn_decl_body != null {
            const found_local: &ASTNode = c99_find_var_decl_type_in_node(codegen.current_function_decl.fn_decl_body, name);
            if found_local != null {
                return found_local;
            }
        }
    }
    if codegen.program_node != null && codegen.program_node.program_decls != null {
        var i: i32 = 0;
        while i < codegen.program_node.program_decl_count {
            const decl: &ASTNode = codegen.program_node.program_decls[i];
            if decl != null && decl.type == ASTNodeType.AST_VAR_DECL && decl.var_decl_name != null &&
                str_equals(decl.var_decl_name, name) != 0 {
                return decl.var_decl_type;
            }
            i = i + 1;
        }
    }
    return null;
}

fn c99_resolve_simd_type_ast_from_expr(codegen: &C99CodeGenerator, expr: &ASTNode) &ASTNode {
    if codegen == null || expr == null {
        return null;
    }
    if expr.type == ASTNodeType.AST_MEMBER_ACCESS && expr.member_access_object != null &&
        expr.member_access_field_name != null {
        const st: &ASTNode = c99_resolve_struct_decl_for_member_object(codegen, expr.member_access_object);
        if st != null {
            const ft: &ASTNode = c99_find_struct_field_type(codegen, st, expr.member_access_field_name);
            return c99_resolve_simd_type_ast_from_type_node(codegen, ft);
        }
    }
    if expr.type == ASTNodeType.AST_IDENTIFIER && expr.identifier_name != null {
        const type_node: &ASTNode = c99_find_identifier_type_node(codegen, expr.identifier_name);
        return c99_resolve_simd_type_ast_from_type_node(codegen, type_node);
    }
    if expr.type == ASTNodeType.AST_CALL_EXPR {
        const method_name: &byte = c99_simd_vector_builtin_method(expr);
        if method_name != null && str_equals(method_name, "splat" as *byte) != 0 {
            if expr.simd_splat_target_type != null {
                return expr.simd_splat_target_type;
            }
            if codegen.expected_type != null {
                const ex: &ASTNode = c99_resolve_simd_type_ast_from_type_node(codegen, codegen.expected_type);
                if ex != null && ex.type == ASTNodeType.AST_TYPE_VECTOR {
                    return ex;
                }
            }
            if codegen.current_function_return_type != null {
                const rt: &ASTNode = c99_resolve_simd_type_ast_from_type_node(codegen, codegen.current_function_return_type);
                if rt != null && rt.type == ASTNodeType.AST_TYPE_VECTOR {
                    return rt;
                }
            }
        }
        if method_name != null && str_equals(method_name, "load" as *byte) != 0 {
            if expr.simd_splat_target_type != null {
                return expr.simd_splat_target_type;
            }
            if codegen.expected_type != null {
                const exl: &ASTNode = c99_resolve_simd_type_ast_from_type_node(codegen, codegen.expected_type);
                if exl != null && exl.type == ASTNodeType.AST_TYPE_VECTOR {
                    return exl;
                }
            }
            if codegen.current_function_return_type != null {
                const rtl: &ASTNode = c99_resolve_simd_type_ast_from_type_node(codegen, codegen.current_function_return_type);
                if rtl != null && rtl.type == ASTNodeType.AST_TYPE_VECTOR {
                    return rtl;
                }
            }
        }
        if method_name != null && str_equals(method_name, "select" as *byte) != 0 {
            if expr.simd_splat_target_type != null {
                return expr.simd_splat_target_type;
            }
            if codegen.expected_type != null {
                const exs: &ASTNode = c99_resolve_simd_type_ast_from_type_node(codegen, codegen.expected_type);
                if exs != null && exs.type == ASTNodeType.AST_TYPE_VECTOR {
                    return exs;
                }
            }
            if codegen.current_function_return_type != null {
                const rts: &ASTNode = c99_resolve_simd_type_ast_from_type_node(codegen, codegen.current_function_return_type);
                if rts != null && rts.type == ASTNodeType.AST_TYPE_VECTOR {
                    return rts;
                }
            }
        }
    }
    if expr.type == ASTNodeType.AST_UNARY_EXPR && expr.unary_expr_operand != null {
        return c99_resolve_simd_type_ast_from_expr(codegen, expr.unary_expr_operand);
    }
    if expr.type == ASTNodeType.AST_BINARY_EXPR && expr.binary_expr_left != null && expr.binary_expr_right != null {
        var left_type_ast: &ASTNode = c99_resolve_simd_type_ast_from_expr(codegen, expr.binary_expr_left);
        var right_type_ast: &ASTNode = c99_resolve_simd_type_ast_from_expr(codegen, expr.binary_expr_right);
        if left_type_ast == null && right_type_ast != null && c99_expr_is_vector_splat(expr.binary_expr_left) != 0 {
            left_type_ast = right_type_ast;
        }
        if right_type_ast == null && left_type_ast != null && c99_expr_is_vector_splat(expr.binary_expr_right) != 0 {
            right_type_ast = left_type_ast;
        }
        if left_type_ast == null && right_type_ast != null && c99_expr_is_vector_load(expr.binary_expr_left) != 0 {
            left_type_ast = right_type_ast;
        }
        if right_type_ast == null && left_type_ast != null && c99_expr_is_vector_load(expr.binary_expr_right) != 0 {
            right_type_ast = left_type_ast;
        }
        if left_type_ast == null && right_type_ast != null && c99_expr_is_vector_select(expr.binary_expr_left) != 0 {
            left_type_ast = right_type_ast;
        }
        if right_type_ast == null && left_type_ast != null && c99_expr_is_vector_select(expr.binary_expr_right) != 0 {
            right_type_ast = left_type_ast;
        }
        if left_type_ast == null || right_type_ast == null {
            return null;
        }
        const op_tmp: !TokenType = expr.binary_expr_op as! TokenType;
        const op: TokenType = op_tmp.value;
        if op == TokenType.TOKEN_EQUAL || op == TokenType.TOKEN_NOT_EQUAL || op == TokenType.TOKEN_LESS ||
            op == TokenType.TOKEN_GREATER || op == TokenType.TOKEN_LESS_EQUAL || op == TokenType.TOKEN_GREATER_EQUAL {
            if left_type_ast.type != ASTNodeType.AST_TYPE_VECTOR || left_type_ast.type_vector_size_expr == null {
                return null;
            }
            const mask_type_ast: &ASTNode = ast_new_node(ASTNodeType.AST_TYPE_MASK, expr.line, expr.column, codegen.arena, expr.filename);
            if mask_type_ast != null {
