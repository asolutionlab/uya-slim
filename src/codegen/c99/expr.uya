    if target_rmax == null {
        target_rmax = c99_resolve_simd_type_ast_from_expr(codegen, expr.call_expr_args[0]);
    }
    if target_rmax == null || target_rmax.type != ASTNodeType.AST_TYPE_VECTOR ||
        target_rmax.type_vector_element_type == null || target_rmax.type_vector_size_expr == null {
        return 0;
    }
    const vec_c: &byte = c99_type_to_c(codegen, target_rmax);
    const lanes_rmax: i32 = eval_const_expr(codegen, target_rmax.type_vector_size_expr);
