                                }
                                fputs(" })" as *byte, codegen.output as *void);
                            } else {
                                fprintf(codegen.output as *void, "((struct uya_tagged_%s){ ._tag = %d, .u = (union %s){ .%s = " as *byte, uname as *byte, idx, uname as *byte, vname_c as *byte);
                                if is_void != 0 {
