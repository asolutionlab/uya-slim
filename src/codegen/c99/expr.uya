        var lc8: i32 = 0;
        while lc8 < lanes {
            c99_simd_emit_sse_binary_fast_at(codegen, fast_kind, result_name, left_name, right_name, lc8, lanes);
            const rem8: i32 = lanes - lc8;
            var st8: i32 = 16;
            if rem8 < 16 {
                st8 = 8;
            }
            if rem8 < 8 {
                st8 = 4;
            }
            if rem8 < 4 {
                st8 = 2;
            }
            lc8 = lc8 + st8;
        }
        return 1;
    }
    var lane_chunk: i32 = 0;
    var chunk_step: i32 = 4;
    if fast_kind == 34 || fast_kind == 35 || fast_kind == 39 || fast_kind == 40 {
        chunk_step = 2;
    } else if is_i64_u64_simd != 0 {
        chunk_step = 2;
    } else if fast_kind == 36 || fast_kind == 37 || fast_kind == 38 || fast_kind == 41 || fast_kind == 42 ||
        fast_kind == 43 || fast_kind == 111 || fast_kind == 112 || fast_kind == 113 || fast_kind == 114 ||
        fast_kind == 115 || fast_kind == 116 || fast_kind == 117 || fast_kind == 118 || fast_kind == 119 ||
        fast_kind == 120 || fast_kind == 121 || fast_kind == 122 {
        chunk_step = 8;
    }
    if lanes == 2 {
        if (fast_kind >= 10 && fast_kind <= 33) || (fast_kind >= 101 && fast_kind <= 110) ||
            (fast_kind >= 201 && fast_kind <= 206) {
            chunk_step = 2;
        }
    }
    while lane_chunk < lanes {
        c99_simd_emit_sse_binary_fast_at(codegen, fast_kind, result_name, left_name, right_name, lane_chunk, lanes);
        lane_chunk = lane_chunk + chunk_step;
    }
    return 1;
}

fn c99_simd_try_emit_x86_sse_unary_minus(codegen: &C99CodeGenerator, result_type_ast: &ASTNode, result_name: &byte,
    operand_name: &byte, lanes: i32) i32 {
    if codegen == null || result_type_ast == null || result_name == null || operand_name == null {
        return 0;
    }
    if result_type_ast.type != ASTNodeType.AST_TYPE_VECTOR || result_type_ast.type_vector_element_type == null {
        return 0;
    }
    const vec_elem_c: &byte = c99_type_c_skip_const(c99_type_to_c(codegen, result_type_ast.type_vector_element_type));
    if vec_elem_c == null {
        return 0;
    }
    if strcmp(vec_elem_c as *byte, "double" as *byte) == 0 {
        if lanes != 2 && lanes != 4 {
            return 0;
        }
        var df: i32 = 0;
        while df < lanes {
            var prd: [byte: 96] = [];
            var pod: [byte: 96] = [];
            if df == 0 {
                snprintf(&prd[0] as *byte, SIMD_VEC_LANE_PTR_SZ, "%s.lanes" as *byte, result_name as *byte);
                snprintf(&pod[0] as *byte, SIMD_VEC_LANE_PTR_SZ, "%s.lanes" as *byte, operand_name as *byte);
            } else {
                snprintf(&prd[0] as *byte, SIMD_VEC_LANE_PTR_SZ, "&%s.lanes[%d]" as *byte, result_name as *byte, df);
                snprintf(&pod[0] as *byte, SIMD_VEC_LANE_PTR_SZ, "&%s.lanes[%d]" as *byte, operand_name as *byte, df);
            }
            fprintf(codegen.emit_stream as *void, "uya_simd_sse_neg_f64x2(%s, %s); " as *byte, &prd[0] as *byte, &pod[0] as *byte);
            df = df + 2;
        }
        return 1;
    }
    if strcmp(vec_elem_c as *byte, "int16_t" as *byte) == 0 {
        if lanes != 4 && lanes != 8 {
            return 0;
        }
        if lanes == 4 {
            fprintf(codegen.emit_stream as *void, "uya_simd_sse_neg_i16x4(%s.lanes, %s.lanes); " as *byte,
                result_name as *byte, operand_name as *byte);
        } else {
            fprintf(codegen.emit_stream as *void, "uya_simd_sse_neg_i16x8(%s.lanes, %s.lanes); " as *byte,
                result_name as *byte, operand_name as *byte);
        }
        return 1;
    }
    if c99_simd_sse_i8_u8_lane_ok(lanes) != 0 &&
        (strcmp(vec_elem_c as *byte, "int8_t" as *byte) == 0 || strcmp(vec_elem_c as *byte, "uint8_t" as *byte) == 0) {
        var n8: i32 = 0;
        while n8 < lanes {
            var prn: [byte: 96] = [];
            var pon: [byte: 96] = [];
            if n8 == 0 {
                snprintf(&prn[0] as *byte, SIMD_VEC_LANE_PTR_SZ, "%s.lanes" as *byte, result_name as *byte);
                snprintf(&pon[0] as *byte, SIMD_VEC_LANE_PTR_SZ, "%s.lanes" as *byte, operand_name as *byte);
            } else {
                snprintf(&prn[0] as *byte, SIMD_VEC_LANE_PTR_SZ, "&%s.lanes[%d]" as *byte, result_name as *byte, n8);
                snprintf(&pon[0] as *byte, SIMD_VEC_LANE_PTR_SZ, "&%s.lanes[%d]" as *byte, operand_name as *byte, n8);
            }
            const rn8: i32 = lanes - n8;
            if strcmp(vec_elem_c as *byte, "int8_t" as *byte) == 0 {
                if rn8 >= 16 {
                    fprintf(codegen.emit_stream as *void, "uya_simd_sse_neg_i8x16(%s, %s); " as *byte, &prn[0] as *byte, &pon[0] as *byte);
                    n8 = n8 + 16;
                } else if rn8 >= 8 {
                    fprintf(codegen.emit_stream as *void, "uya_simd_sse_neg_i8x8(%s, %s); " as *byte, &prn[0] as *byte, &pon[0] as *byte);
                    n8 = n8 + 8;
                } else if rn8 >= 4 {
                    fprintf(codegen.emit_stream as *void, "uya_simd_sse_neg_i8x4(%s, %s); " as *byte, &prn[0] as *byte, &pon[0] as *byte);
                    n8 = n8 + 4;
                } else {
                    fprintf(codegen.emit_stream as *void, "uya_simd_sse_neg_i8x2(%s, %s); " as *byte, &prn[0] as *byte, &pon[0] as *byte);
                    n8 = n8 + 2;
                }
            } else {
                if rn8 >= 16 {
                    fprintf(codegen.emit_stream as *void, "uya_simd_sse_neg_u8x16(%s, %s); " as *byte, &prn[0] as *byte, &pon[0] as *byte);
                    n8 = n8 + 16;
                } else if rn8 >= 8 {
                    fprintf(codegen.emit_stream as *void, "uya_simd_sse_neg_u8x8(%s, %s); " as *byte, &prn[0] as *byte, &pon[0] as *byte);
                    n8 = n8 + 8;
                } else if rn8 >= 4 {
                    fprintf(codegen.emit_stream as *void, "uya_simd_sse_neg_u8x4(%s, %s); " as *byte, &prn[0] as *byte, &pon[0] as *byte);
                    n8 = n8 + 4;
                } else {
                    fprintf(codegen.emit_stream as *void, "uya_simd_sse_neg_u8x2(%s, %s); " as *byte, &prn[0] as *byte, &pon[0] as *byte);
                    n8 = n8 + 2;
                }
            }
        }
        return 1;
    }
    if c99_simd_sse_i64_u64_lane_ok(lanes) != 0 &&
        (strcmp(vec_elem_c as *byte, "int64_t" as *byte) == 0 || strcmp(vec_elem_c as *byte, "uint64_t" as *byte) == 0) {
        var n64: i32 = 0;
        while n64 < lanes {
            var pr6: [byte: 96] = [];
            var po6: [byte: 96] = [];
            if n64 == 0 {
                snprintf(&pr6[0] as *byte, SIMD_VEC_LANE_PTR_SZ, "%s.lanes" as *byte, result_name as *byte);
                snprintf(&po6[0] as *byte, SIMD_VEC_LANE_PTR_SZ, "%s.lanes" as *byte, operand_name as *byte);
            } else {
                snprintf(&pr6[0] as *byte, SIMD_VEC_LANE_PTR_SZ, "&%s.lanes[%d]" as *byte, result_name as *byte, n64);
                snprintf(&po6[0] as *byte, SIMD_VEC_LANE_PTR_SZ, "&%s.lanes[%d]" as *byte, operand_name as *byte, n64);
            }
            if strcmp(vec_elem_c as *byte, "int64_t" as *byte) == 0 {
                fprintf(codegen.emit_stream as *void, "uya_simd_sse_neg_i64x2(%s, %s); " as *byte, &pr6[0] as *byte, &po6[0] as *byte);
            } else {
                fprintf(codegen.emit_stream as *void, "uya_simd_sse_neg_u64x2(%s, %s); " as *byte, &pr6[0] as *byte, &po6[0] as *byte);
            }
            n64 = n64 + 2;
        }
        return 1;
    }
    if lanes == 2 && strcmp(vec_elem_c as *byte, "int32_t" as *byte) == 0 {
        fprintf(codegen.emit_stream as *void, "uya_simd_sse_neg_i32x2(%s.lanes, %s.lanes); " as *byte,
            result_name as *byte, operand_name as *byte);
        return 1;
    }
    if lanes == 2 && strcmp(vec_elem_c as *byte, "float" as *byte) == 0 {
        fprintf(codegen.emit_stream as *void, "uya_simd_sse_neg_f32x2(%s.lanes, %s.lanes); " as *byte,
            result_name as *byte, operand_name as *byte);
        return 1;
    }
    if c99_simd_sse_x4_tile_lane_count_ok(lanes) == 0 {
        return 0;
    }
    if strcmp(vec_elem_c as *byte, "int32_t" as *byte) == 0 {
        var uchunk: i32 = 0;
        while uchunk < lanes {
            var pr: [byte: 96] = [];
            var po: [byte: 96] = [];
            if uchunk == 0 {
                snprintf(&pr[0] as *byte, SIMD_VEC_LANE_PTR_SZ, "%s.lanes" as *byte, result_name as *byte);
                snprintf(&po[0] as *byte, SIMD_VEC_LANE_PTR_SZ, "%s.lanes" as *byte, operand_name as *byte);
            } else {
                snprintf(&pr[0] as *byte, SIMD_VEC_LANE_PTR_SZ, "&%s.lanes[%d]" as *byte, result_name as *byte, uchunk);
                snprintf(&po[0] as *byte, SIMD_VEC_LANE_PTR_SZ, "&%s.lanes[%d]" as *byte, operand_name as *byte, uchunk);
            }
            fprintf(codegen.emit_stream as *void, "uya_simd_sse_neg_i32x4(%s, %s); " as *byte, &pr[0] as *byte, &po[0] as *byte);
            uchunk = uchunk + 4;
        }
        return 1;
    }
    if strcmp(vec_elem_c as *byte, "float" as *byte) == 0 {
        var uchunk2: i32 = 0;
        while uchunk2 < lanes {
            var pr2: [byte: 96] = [];
            var po2: [byte: 96] = [];
            if uchunk2 == 0 {
                snprintf(&pr2[0] as *byte, SIMD_VEC_LANE_PTR_SZ, "%s.lanes" as *byte, result_name as *byte);
                snprintf(&po2[0] as *byte, SIMD_VEC_LANE_PTR_SZ, "%s.lanes" as *byte, operand_name as *byte);
            } else {
                snprintf(&pr2[0] as *byte, SIMD_VEC_LANE_PTR_SZ, "&%s.lanes[%d]" as *byte, result_name as *byte, uchunk2);
                snprintf(&po2[0] as *byte, SIMD_VEC_LANE_PTR_SZ, "&%s.lanes[%d]" as *byte, operand_name as *byte, uchunk2);
            }
            fprintf(codegen.emit_stream as *void, "uya_simd_sse_neg_f32x4(%s, %s); " as *byte, &pr2[0] as *byte, &po2[0] as *byte);
            uchunk2 = uchunk2 + 4;
        }
        return 1;
    }
    return 0;
}

fn c99_emit_simd_binary_operator(codegen: &C99CodeGenerator, op: TokenType) void {
    if op == TokenType.TOKEN_PLUS {
        fputs(" + " as *byte, codegen.emit_stream as *void);
    } else if op == TokenType.TOKEN_MINUS {
        fputs(" - " as *byte, codegen.emit_stream as *void);
    } else if op == TokenType.TOKEN_ASTERISK {
        fputs(" * " as *byte, codegen.emit_stream as *void);
    } else if op == TokenType.TOKEN_SLASH {
        fputs(" / " as *byte, codegen.emit_stream as *void);
    } else if op == TokenType.TOKEN_PERCENT {
        fputs(" % " as *byte, codegen.emit_stream as *void);
    } else if op == TokenType.TOKEN_EQUAL {
        fputs(" == " as *byte, codegen.emit_stream as *void);
    } else if op == TokenType.TOKEN_NOT_EQUAL {
        fputs(" != " as *byte, codegen.emit_stream as *void);
    } else if op == TokenType.TOKEN_LESS {
        fputs(" < " as *byte, codegen.emit_stream as *void);
    } else if op == TokenType.TOKEN_GREATER {
        fputs(" > " as *byte, codegen.emit_stream as *void);
    } else if op == TokenType.TOKEN_LESS_EQUAL {
        fputs(" <= " as *byte, codegen.emit_stream as *void);
    } else if op == TokenType.TOKEN_GREATER_EQUAL {
        fputs(" >= " as *byte, codegen.emit_stream as *void);
    } else if op == TokenType.TOKEN_AMPERSAND {
        fputs(" & " as *byte, codegen.emit_stream as *void);
    } else if op == TokenType.TOKEN_PIPE {
        fputs(" | " as *byte, codegen.emit_stream as *void);
    } else if op == TokenType.TOKEN_CARET {
        fputs(" ^ " as *byte, codegen.emit_stream as *void);
    } else if op == TokenType.TOKEN_LSHIFT {
        fputs(" << " as *byte, codegen.emit_stream as *void);
    } else if op == TokenType.TOKEN_RSHIFT {
        fputs(" >> " as *byte, codegen.emit_stream as *void);
    } else {
        fputs(" + " as *byte, codegen.emit_stream as *void);
    }
}

// 单个 SIMD 向量通道上的饱和 / 包装二元运算（与标量 +| / +% 等语义一致）
fn c99_emit_simd_lane_sat_wrap(codegen: &C99CodeGenerator, op: TokenType, type_c: &byte, base_type: &byte,
    left_name: &byte, right_name: &byte, lane: i32) void {
    if codegen == null || type_c == null || base_type == null || left_name == null || right_name == null {
        return;
    }
    if op == TokenType.TOKEN_PLUS_PIPE || op == TokenType.TOKEN_MINUS_PIPE || op == TokenType.TOKEN_ASTERISK_PIPE {
        fputs("({ " as *byte, codegen.emit_stream as *void);
        fprintf(codegen.emit_stream as *void, "%s _l = %s.lanes[%d]; " as *byte, base_type as *byte, left_name as *byte, lane);
        fprintf(codegen.emit_stream as *void, "%s _r = %s.lanes[%d]; " as *byte, base_type as *byte, right_name as *byte, lane);
        fprintf(codegen.emit_stream as *void, "%s _s; " as *byte, base_type as *byte);
        if op == TokenType.TOKEN_PLUS_PIPE {
            fputs("__builtin_add_overflow(_l, _r, &_s) ? (_l>=0 && _r>=0 ? " as *byte, codegen.emit_stream as *void);
        } else if op == TokenType.TOKEN_MINUS_PIPE {
            fputs("__builtin_sub_overflow(_l, _r, &_s) ? (_l>=0 && _r<0 ? " as *byte, codegen.emit_stream as *void);
        } else {
            fprintf(codegen.emit_stream as *void, "%s _res; " as *byte, base_type as *byte);
            fputs("if (__builtin_mul_overflow(_l, _r, &_s)) _res = ((_l>=0 && _r>=0) || (_l<0 && _r<0)) ? " as *byte, codegen.emit_stream as *void);
        }
        gen_saturate_limit_from_type_c(codegen, type_c, 1);
        fputs(" : " as *byte, codegen.emit_stream as *void);
        gen_saturate_limit_from_type_c(codegen, type_c, 0);
        if op == TokenType.TOKEN_ASTERISK_PIPE {
            fputs("; else _res = _s; _res; })" as *byte, codegen.emit_stream as *void);
        } else {
            fputs(") : _s; })" as *byte, codegen.emit_stream as *void);
        }
        return;
    }
    const ut: &byte = unsigned_type_for_wrapping(type_c);
    fprintf(codegen.emit_stream as *void, "((%s)((%s)(%s.lanes[%d]) " as *byte, type_c as *byte, ut as *byte, left_name as *byte, lane);
    if op == TokenType.TOKEN_PLUS_PERCENT {
        fputs("+ " as *byte, codegen.emit_stream as *void);
    } else if op == TokenType.TOKEN_MINUS_PERCENT {
        fputs("- " as *byte, codegen.emit_stream as *void);
    } else {
        fputs("* " as *byte, codegen.emit_stream as *void);
    }
    fprintf(codegen.emit_stream as *void, "(%s)(%s.lanes[%d])))" as *byte, ut as *byte, right_name as *byte, lane);
}

fn c99_resolve_simd_type_ast_from_type_node(codegen: &C99CodeGenerator, type_node: &ASTNode) &ASTNode {
    if codegen == null || type_node == null {
        return null;
    }
    if type_node.type == ASTNodeType.AST_TYPE_VECTOR || type_node.type == ASTNodeType.AST_TYPE_MASK {
        return type_node;
    }
    if type_node.type == ASTNodeType.AST_TYPE_NAMED && type_node.type_named_name != null && codegen.program_node != null {
        const type_alias: &ASTNode = find_type_alias_from_program(codegen.program_node, type_node.type_named_name);
        if type_alias != null && type_alias.type_alias_target_type != null {
            return c99_resolve_simd_type_ast_from_type_node(codegen, type_alias.type_alias_target_type);
        }
    }
    return null;
}

// 从类型节点解析到结构体声明（支持 type 别名链）
fn c99_resolve_struct_decl_from_type_node(codegen: &C99CodeGenerator, type_node: &ASTNode) &ASTNode {
    if codegen == null || type_node == null {
        return null;
    }
    var cur: &ASTNode = type_node;
    var guard: i32 = 0;
    while cur != null && guard < 64 {
        guard = guard + 1;
        if cur.type != ASTNodeType.AST_TYPE_NAMED || cur.type_named_name == null {
            return null;
        }
        const sd: &ASTNode = find_struct_decl_c99(codegen, cur.type_named_name);
        if sd != null {
            return sd;
        }
        if codegen.program_node == null {
            return null;
        }
        const alias: &ASTNode = find_type_alias_from_program(codegen.program_node, cur.type_named_name);
        if alias != null && alias.type_alias_target_type != null {
            cur = alias.type_alias_target_type;
            continue;
        }
        return null;
    }
    return null;
}

// 成员访问链左侧对应的结构体声明（用于 b.data、outer.inner.f 等）
fn c99_resolve_struct_decl_for_member_object(codegen: &C99CodeGenerator, object: &ASTNode) &ASTNode {
    if codegen == null || object == null {
        return null;
    }
    if object.type == ASTNodeType.AST_MEMBER_ACCESS {
        if object.member_access_object == null || object.member_access_field_name == null {
            return null;
        }
        const inner_struct: &ASTNode = c99_resolve_struct_decl_for_member_object(codegen, object.member_access_object);
        if inner_struct == null {
            return null;
        }
        const ft: &ASTNode = c99_find_struct_field_type(codegen, inner_struct, object.member_access_field_name);
        return c99_resolve_struct_decl_from_type_node(codegen, ft);
    }
    if object.type == ASTNodeType.AST_IDENTIFIER && object.identifier_name != null {
        const tn: &ASTNode = c99_find_identifier_type_node(codegen, object.identifier_name);
        var cur_type: &ASTNode = tn;
        while cur_type != null && cur_type.type == ASTNodeType.AST_TYPE_POINTER &&
            cur_type.type_pointer_pointed_type != null {
            cur_type = cur_type.type_pointer_pointed_type;
        }
        return c99_resolve_struct_decl_from_type_node(codegen, cur_type);
    }
    return null;
}

fn c99_find_var_decl_type_in_node(node: &ASTNode, name: &byte) &ASTNode {
    if node == null || name == null {
        return null;
    }
    if node.type == ASTNodeType.AST_VAR_DECL && node.var_decl_name != null &&
        str_equals(node.var_decl_name, name) != 0 {
        return node.var_decl_type;
    }
    if node.type == ASTNodeType.AST_BLOCK && node.block_stmts != null {
        var i: i32 = 0;
        while i < node.block_stmt_count {
            const found: &ASTNode = c99_find_var_decl_type_in_node(node.block_stmts[i], name);
            if found != null {
                return found;
            }
            i = i + 1;
        }
        return null;
    }
    if node.type == ASTNodeType.AST_IF_STMT {
        const found_then: &ASTNode = c99_find_var_decl_type_in_node(node.if_stmt_then_branch, name);
        if found_then != null {
            return found_then;
        }
        return c99_find_var_decl_type_in_node(node.if_stmt_else_branch, name);
    }
    if node.type == ASTNodeType.AST_WHILE_STMT {
        return c99_find_var_decl_type_in_node(node.while_stmt_body, name);
    }
    if node.type == ASTNodeType.AST_FOR_STMT {
        return c99_find_var_decl_type_in_node(node.for_stmt_body, name);
    }
    return null;
}

fn c99_expr_is_vector_splat(expr: &ASTNode) i32 {
    if expr == null || expr.type != ASTNodeType.AST_CALL_EXPR {
        return 0;
    }
    const mn: &byte = c99_simd_vector_builtin_method(expr);
    if mn == null || str_equals(mn, "splat" as *byte) == 0 {
        return 0;
    }
    return 1;
}

fn c99_expr_is_vector_load(expr: &ASTNode) i32 {
