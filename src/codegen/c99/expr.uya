// 按通道标量赋值（与 SSE #else 分支共用）
fn c99_simd_emit_per_lane_binary_assign(codegen: &C99CodeGenerator, result_name: &byte, left_name: &byte, right_name: &byte,
    lanes: i32, simd_op: TokenType) void {
    if codegen == null || result_name == null || left_name == null || right_name == null || lanes <= 0 {
        return;
    }
    var ii: i32 = 0;
    while ii < lanes {
        fprintf(codegen.emit_stream as *void, "%s.lanes[%d] = (" as *byte, result_name as *byte, ii);
        fprintf(codegen.emit_stream as *void, "%s.lanes[%d]" as *byte, left_name as *byte, ii);
        c99_emit_simd_binary_operator(codegen, simd_op);
        fprintf(codegen.emit_stream as *void, "%s.lanes[%d]); " as *byte, right_name as *byte, ii);
        ii = ii + 1;
    }
}

// SSE/NEON x4 分块：语言合法宽度中除 2× 外均为 4 的倍数（4/8/16/32/64）
fn c99_simd_sse_x4_tile_lane_count_ok(lanes: i32) i32 {
    if lanes == 4 || lanes == 8 || lanes == 16 || lanes == 32 || lanes == 64 {
        return 1;
    }
    return 0;
}

// i32/u32/f32 向量与对应掩码：2 通道走 x2 助手，其余走 x4 分块
fn c99_simd_sse_i32_u32_f32_two_or_x4_lane_ok(lanes: i32) i32 {
    if lanes == 2 {
        return 1;
    }
    return c99_simd_sse_x4_tile_lane_count_ok(lanes);
}

// i8/u8：合法宽度 2/4/8/16/32/64（16 字节分块）
fn c99_simd_sse_i8_u8_lane_ok(lanes: i32) i32 {
    if lanes == 2 || lanes == 4 || lanes == 8 || lanes == 16 || lanes == 32 || lanes == 64 {
        return 1;
    }
    return 0;
}

// i64/u64：仅 i64x2/u64x2 助手，按 2 通道分块
fn c99_simd_sse_i64_u64_lane_ok(lanes: i32) i32 {
    if lanes == 2 {
        return 1;
    }
    return c99_simd_sse_x4_tile_lane_count_ok(lanes);
}

// x86_64 SSE / ARM NEON：4/8/16/32/64 宽（8=2×x4，16=4×x4，32=8×x4，64=16×x4）i32/u32/f32 部分二元式；返回 1 已输出助手调用；返回 0 时标量赋值
fn c99_simd_try_emit_x86_sse_binary(codegen: &C99CodeGenerator, result_type_ast: &ASTNode, left_type_ast: &ASTNode,
    simd_op: TokenType, result_name: &byte, left_name: &byte, right_name: &byte, lanes: i32) i32 {
    if codegen == null || result_type_ast == null || result_name == null || left_name == null || right_name == null {
        return 0;
    }
    var fast_kind: i32 = 0;
    var is_f64: i32 = 0;
    // 101–106：掩码 i32；107–110：掩码 u32 有序比较；201–206：掩码 f32；10–17：i32 向量（16=÷，17=%）；20–27：u32 向量（22=×，26=÷，27=%）；30+：f32
    if result_type_ast.type == ASTNodeType.AST_TYPE_MASK {
        if left_type_ast == null || left_type_ast.type != ASTNodeType.AST_TYPE_VECTOR ||
            left_type_ast.type_vector_element_type == null {
            return 0;
        }
        const mask_elem_c: &byte = c99_type_c_skip_const(c99_type_to_c(codegen, left_type_ast.type_vector_element_type));
        if mask_elem_c == null {
            return 0;
        }
        if strcmp(mask_elem_c as *byte, "int32_t" as *byte) == 0 {
            if simd_op == TokenType.TOKEN_EQUAL {
                fast_kind = 101;
            } else if simd_op == TokenType.TOKEN_NOT_EQUAL {
                fast_kind = 102;
            } else if simd_op == TokenType.TOKEN_LESS {
                fast_kind = 103;
            } else if simd_op == TokenType.TOKEN_GREATER {
                fast_kind = 104;
            } else if simd_op == TokenType.TOKEN_LESS_EQUAL {
                fast_kind = 105;
            } else if simd_op == TokenType.TOKEN_GREATER_EQUAL {
                fast_kind = 106;
            } else {
                return 0;
            }
        } else if strcmp(mask_elem_c as *byte, "uint32_t" as *byte) == 0 {
            if simd_op == TokenType.TOKEN_EQUAL {
                fast_kind = 101;
            } else if simd_op == TokenType.TOKEN_NOT_EQUAL {
                fast_kind = 102;
            } else if simd_op == TokenType.TOKEN_LESS {
                fast_kind = 107;
            } else if simd_op == TokenType.TOKEN_GREATER {
                fast_kind = 108;
            } else if simd_op == TokenType.TOKEN_LESS_EQUAL {
                fast_kind = 109;
            } else if simd_op == TokenType.TOKEN_GREATER_EQUAL {
                fast_kind = 110;
            } else {
                return 0;
            }
        } else if strcmp(mask_elem_c as *byte, "float" as *byte) == 0 {
            if simd_op == TokenType.TOKEN_EQUAL {
                fast_kind = 201;
            } else if simd_op == TokenType.TOKEN_NOT_EQUAL {
                fast_kind = 202;
            } else if simd_op == TokenType.TOKEN_LESS {
                fast_kind = 203;
            } else if simd_op == TokenType.TOKEN_LESS_EQUAL {
                fast_kind = 204;
            } else if simd_op == TokenType.TOKEN_GREATER {
                fast_kind = 205;
            } else if simd_op == TokenType.TOKEN_GREATER_EQUAL {
                fast_kind = 206;
            } else {
