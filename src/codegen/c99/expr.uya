        if str_equals(elem_c_rmax, "uint32_t") != 0 {
            fputs("({ " as *byte, codegen.emit_stream as *void);
            fprintf(codegen.emit_stream as *void, "%s %s = " as *byte, vec_c as *byte, v_nm as *byte);
            gen_expr(codegen, expr.call_expr_args[0]);
            fprintf(codegen.emit_stream as *void, "; %s %s; uya_simd_sse_reduce_max_u32x2(&%s, &%s); %s; })" as *byte, elem_c_rmax as *byte, s_nm as *byte, s_nm as *byte, v_nm as *byte, s_nm as *byte);
            return 1;
        }
        if str_equals(elem_c_rmax, "float") != 0 {
            fputs("({ " as *byte, codegen.emit_stream as *void);
            fprintf(codegen.emit_stream as *void, "%s %s = " as *byte, vec_c as *byte, v_nm as *byte);
            gen_expr(codegen, expr.call_expr_args[0]);
            fprintf(codegen.emit_stream as *void, "; %s %s; uya_simd_sse_reduce_max_f32x2(&%s, &%s); %s; })" as *byte, elem_c_rmax as *byte, s_nm as *byte, s_nm as *byte, v_nm as *byte, s_nm as *byte);
            return 1;
        }
    }
    if lanes_rmax == 4 {
        if str_equals(elem_c_rmax, "int32_t") != 0 {
            fputs("({ " as *byte, codegen.emit_stream as *void);
            fprintf(codegen.emit_stream as *void, "%s %s = " as *byte, vec_c as *byte, v_nm as *byte);
            gen_expr(codegen, expr.call_expr_args[0]);
            fprintf(codegen.emit_stream as *void, "; %s %s; uya_simd_sse_reduce_max_i32x4(&%s, &%s); %s; })" as *byte, elem_c_rmax as *byte, s_nm as *byte, s_nm as *byte, v_nm as *byte, s_nm as *byte);
            return 1;
        }
        if str_equals(elem_c_rmax, "uint32_t") != 0 {
            fputs("({ " as *byte, codegen.emit_stream as *void);
            fprintf(codegen.emit_stream as *void, "%s %s = " as *byte, vec_c as *byte, v_nm as *byte);
            gen_expr(codegen, expr.call_expr_args[0]);
            fprintf(codegen.emit_stream as *void, "; %s %s; uya_simd_sse_reduce_max_u32x4(&%s, &%s); %s; })" as *byte, elem_c_rmax as *byte, s_nm as *byte, s_nm as *byte, v_nm as *byte, s_nm as *byte);
            return 1;
