                        gen_expr(codegen, expr.call_expr_args[i]);
                    }
                    i = i + 1;
                }
                fputc(41, codegen.emit_stream as *void);
                did_interface_call = 1;
            } else if obj_type_c != null && strstr(obj_type_c as *byte, "uya_interface_" as *byte) == null {
                var base: *byte = obj_type_c as *byte;
                if strncmp(base, "const " as *byte, 6) == 0 { base = base + 6; }
                var struct_name_buf: [byte: STRUCT_NAME_BUF_SIZE] = [];
                var slen: i32 = 0;
                if strncmp(base, "struct " as *byte, 7) == 0 {
                    const start: *byte = base + 7;
                    var end: *byte = strchr(start, 32);
                    if end == null { end = start + strlen(start); }
                    const asterisk: *byte = strchr(start, 42);
                    if asterisk != null && asterisk < end { end = asterisk; }
                    while end > start && ((end - 1)[0] == 32 || (end - 1)[0] == 9) { end = end - 1; }
                    if end > start {
                        slen = (end - start) as i32;
                        if slen > 0 && slen < STRUCT_NAME_BUF_SIZE {
                            var k: i32 = 0;
                            while k < slen {
                                struct_name_buf[k] = start[k];
                                k = k + 1;
                            }
                            struct_name_buf[slen] = 0;
                        } else {
                            slen = 0;
                        }
                    }
                } else if codegen.program_node != null {
                    const ms_td: &byte = resolve_typedef_to_mono_struct_name_if_generic(codegen, base);
                    if ms_td != null {
                        var p2: i32 = 0;
                        while ms_td[p2] != 0 && p2 < STRUCT_NAME_BUF_SIZE - 1 {
                            struct_name_buf[p2] = ms_td[p2];
                            p2 = p2 + 1;
                        }
                        struct_name_buf[p2] = 0;
                        if p2 > 0 {
                            slen = p2;
                        }
                    }
                }
                if slen > 0 && slen < STRUCT_NAME_BUF_SIZE {
                            const frame_helper_name: &byte = c99_async_frame_helper_name(codegen, &struct_name_buf[0] as &byte, method_name);
                            if frame_helper_name != null {
                                const async_fn_decl: &ASTNode = c99_async_frame_fn_decl_from_expr(codegen, obj);
                                var prefix: &byte = "&" as *byte;
                                if strchr(obj_type_c as *byte, 42) != null { prefix = "" as *byte; }
                                fprintf(codegen.emit_stream as *void, "%s(%s(" as *byte, frame_helper_name as *byte, prefix);
                                gen_expr(codegen, obj);
                                fputs(")" as *byte, codegen.emit_stream as *void);
                                var frame_ai: i32 = 0;
                                while frame_ai < arg_count {
                                    c99_emit_comma_space(codegen);
                                    if codegen.interp_arg_temp_names[frame_ai] != null {
                                        fputs("(uint8_t *)" as *byte, codegen.emit_stream as *void);
                                        fputs(codegen.interp_arg_temp_names[frame_ai] as *byte, codegen.emit_stream as *void);
                                    } else if async_fn_decl != null && strcmp(method_name as *byte, "start" as *byte) == 0 {
                                        if expr.call_expr_args[frame_ai] != null && expr.call_expr_args[frame_ai].type == ASTNodeType.AST_STRING {
                                            if c99_string_literal_passes_as_const_byte_slice_value(async_fn_decl, frame_ai, expr.call_expr_args[frame_ai]) == 0 {
                                                fputs("(uint8_t *)" as *byte, codegen.emit_stream as *void);
                                            }
                                        }
                                        c99_emit_call_arg_expr(codegen, async_fn_decl, frame_ai, expr.call_expr_args[frame_ai]);
                                    } else {
                                        gen_expr(codegen, expr.call_expr_args[frame_ai]);
                                    }
                                    frame_ai = frame_ai + 1;
                                }
                                fputc(41, codegen.emit_stream as *void);
                                did_interface_call = 1;
                            }
                            if did_interface_call == 0 {
                            const union_decl: &ASTNode = find_union_decl_by_tagged_c99(codegen, &struct_name_buf[0]);
                            if union_decl != null {
                                const method_fn: &ASTNode = find_method_in_union_c99(codegen, union_decl.union_decl_name, method_name);
                                if method_fn != null {
                                    const cname: &byte = get_method_c_name(codegen, union_decl.union_decl_name, method_name);
                                    if cname != null {
                                        var prefix: &byte = "&" as *byte;
                                        if method_fn.fn_decl_param_count > 0 && method_fn.fn_decl_params != null &&
                                            method_fn.fn_decl_params[0] != null && method_fn.fn_decl_params[0].type == ASTNodeType.AST_VAR_DECL &&
                                            method_fn.fn_decl_params[0].var_decl_type != null &&
                                            method_fn.fn_decl_params[0].var_decl_type.type != ASTNodeType.AST_TYPE_POINTER {
                                            prefix = "" as *byte;
                                        }
                                        if strchr(obj_type_c as *byte, 42) != null { prefix = "" as *byte; }
                                        fprintf(codegen.emit_stream as *void, "%s(%s(" as *byte, cname as *byte, prefix);
                                        gen_expr(codegen, obj);
                                        fputs(")" as *byte, codegen.emit_stream as *void);
                                        var i: i32 = 0;
                                        while i < arg_count {
                                            c99_emit_comma_space(codegen);
                                            if codegen.interp_arg_temp_names[i] != null {
                                                fputs("(uint8_t *)" as *byte, codegen.emit_stream as *void);
                                                fputs(codegen.interp_arg_temp_names[i] as *byte, codegen.emit_stream as *void);
                                            } else {
                                                if expr.call_expr_args[i] != null && expr.call_expr_args[i].type == ASTNodeType.AST_STRING {
                                                    if c99_string_literal_passes_as_const_byte_slice_value(method_fn, i + 1, expr.call_expr_args[i]) == 0 {
                                                        fputs("(uint8_t *)" as *byte, codegen.emit_stream as *void);
                                                    }
                                                }
                                                c99_emit_call_arg_expr(codegen, method_fn, i + 1, expr.call_expr_args[i]);
                                            }
                                            i = i + 1;
                                        }
                                        fputc(41, codegen.emit_stream as *void);
                                        did_interface_call = 1;
                                    }
                                }
                            }
                            }
                            if did_interface_call == 0 {
                                const method_fn: &ASTNode = find_method_in_struct_c99(codegen, &struct_name_buf[0], method_name);
                                if method_fn != null {
                                    // 检查是否是泛型方法调用
                                    var cname: &byte = null;
                                    if expr.call_expr_type_arg_count > 0 && expr.call_expr_type_args != null && method_fn.fn_decl_type_param_count > 0 {
                                        // 泛型方法：构建单态化方法名
                                        // 格式：StructName_method_name_TypeArg1_TypeArg2...
                                        var mono_method_name: [byte: NAME_BUF_SIZE] = [];
                                        var pos: i32 = 0;
                                        pos = pos + snprintf(&mono_method_name[0] as *byte, NAME_BUF_SIZE, "%s_%s" as *byte, &struct_name_buf[0] as *byte, method_name as *byte);
                                        
                                        // 添加类型参数后缀
                                        var ti: i32 = 0;
                                        while ti < expr.call_expr_type_arg_count && pos < NAME_BUF_SIZE - 6 {
                                            pos = pos + snprintf(&mono_method_name[pos] as *byte, NAME_BUF_SIZE - pos, "_" as *byte);
                                            const type_arg: &ASTNode = expr.call_expr_type_args[ti];
                                            if type_arg != null && type_arg.type == ASTNodeType.AST_TYPE_NAMED && type_arg.type_named_name != null {
                                                pos = pos + snprintf(&mono_method_name[pos] as *byte, NAME_BUF_SIZE - pos, "%s" as *byte, type_arg.type_named_name as *byte);
                                            }
                                            ti = ti + 1;
                                        }
                                        
                                        cname = get_safe_c_identifier(codegen, &mono_method_name[0]);
                                    } else {
                                        // 非泛型方法
                                        cname = get_method_c_name(codegen, &struct_name_buf[0], method_name);
                                    }
                                    if cname != null {
                                        var prefix: &byte = "&" as *byte;
                                        if method_fn.fn_decl_param_count > 0 && method_fn.fn_decl_params != null &&
                                            method_fn.fn_decl_params[0] != null && method_fn.fn_decl_params[0].type == ASTNodeType.AST_VAR_DECL &&
                                            method_fn.fn_decl_params[0].var_decl_type != null &&
                                            method_fn.fn_decl_params[0].var_decl_type.type != ASTNodeType.AST_TYPE_POINTER {
                                            prefix = "" as *byte;
                                        }
                                        if strchr(obj_type_c as *byte, 42) != null { prefix = "" as *byte; }
                                        fprintf(codegen.emit_stream as *void, "%s(%s(" as *byte, cname as *byte, prefix);
                                        gen_expr(codegen, obj);
                                        fputs(")" as *byte, codegen.emit_stream as *void);
                                        var i: i32 = 0;
                                        while i < arg_count {
                                            c99_emit_comma_space(codegen);
                                            if codegen.interp_arg_temp_names[i] != null {
                                                fputs("(uint8_t *)" as *byte, codegen.emit_stream as *void);
                                                fputs(codegen.interp_arg_temp_names[i] as *byte, codegen.emit_stream as *void);
                                            } else {
                                                if expr.call_expr_args[i] != null && expr.call_expr_args[i].type == ASTNodeType.AST_STRING {
                                                    if c99_string_literal_passes_as_const_byte_slice_value(method_fn, i + 1, expr.call_expr_args[i]) == 0 {
                                                        fputs("(uint8_t *)" as *byte, codegen.emit_stream as *void);
                                                    }
                                                }
                                                c99_emit_call_arg_expr(codegen, method_fn, i + 1, expr.call_expr_args[i]);
                                            }
                                            i = i + 1;
                                        }
                                        fputc(41, codegen.emit_stream as *void);
                                        did_interface_call = 1;
                                    }
                                }
                            }
                }
            }
        }
        if did_interface_call == 0 {
        if do_va_forward != 0 && vname != null && last_param != null {
            const last_safe: &byte = get_safe_c_identifier(codegen, last_param);
            c99_emit(codegen, "((void)0, ({\n" as *byte);
            codegen.indent_level = codegen.indent_level + 1;
            c99_emit(codegen, "va_list uya_va;\n" as *byte);
            c99_emit_indent(codegen);
            fprintf(codegen.emit_stream as *void, "va_start(uya_va, %s);\n" as *byte, last_safe as *byte);
            fprintf(codegen.emit_stream as *void, "%*sint32_t _uya_ret = %s(" as *byte, codegen.indent_level * 4, "" as *byte, vname as *byte);
            var i: i32 = 0;
            while i < arg_count {
                if i > 0 {
                    c99_emit_comma_space(codegen);
                }
                if codegen.interp_arg_temp_names[i] != null {
                    const libc_param_c: &byte = get_extern_libc_param_c_type(fn_decl, i);
                    if libc_param_c != null && strcmp(libc_param_c as *byte, "char *" as *byte) == 0 {
                        fputs("(char *)" as *byte, codegen.emit_stream as *void);
                    } else if libc_param_c != null {
                        fputs("(const char *)" as *byte, codegen.emit_stream as *void);
                    } else {
                        fputs("(uint8_t *)" as *byte, codegen.emit_stream as *void);
                    }
                    fputs(codegen.interp_arg_temp_names[i] as *byte, codegen.emit_stream as *void);
                } else {
                    if expr.call_expr_args[i] != null && expr.call_expr_args[i].type == ASTNodeType.AST_STRING {
                        const libc_param_c: &byte = get_extern_libc_param_c_type(fn_decl, i);
                        if libc_param_c != null {
                            fputs("(const char *)" as *byte, codegen.emit_stream as *void);
                        } else if c99_string_literal_passes_as_const_byte_slice_value(fn_decl, i, expr.call_expr_args[i]) == 0 {
                            fputs("(uint8_t *)" as *byte, codegen.emit_stream as *void);
                        }
                    }
                    c99_emit_call_arg_expr(codegen, fn_decl, i, expr.call_expr_args[i]);
                }
                i = i + 1;
            }
            fputs(", uya_va);\n" as *byte, codegen.emit_stream as *void);
            c99_emit(codegen, "va_end(uya_va);\n" as *byte);
            c99_emit(codegen, "_uya_ret;\n" as *byte);
            codegen.indent_level = codegen.indent_level - 1;
            c99_emit(codegen, "}))" as *byte);
        } else {
            // 生成被调用函数名
            if callee != null && callee.type == ASTNodeType.AST_IDENTIFIER {
                const func_name: &byte = callee.identifier_name;
                var safe_name: &byte = get_c_name_for_global_function(codegen, func_name, 0);
                if expr.call_expr_type_arg_count > 0 && expr.call_expr_type_args != null {
                    const gen_decl: &ASTNode = find_generic_fn_decl_for_mono_call(codegen, func_name, expr.call_expr_type_arg_count);
                    const mono_name: &byte = get_mono_function_name(codegen, func_name, expr.call_expr_type_args, expr.call_expr_type_arg_count, gen_decl);
                    safe_name = get_safe_c_identifier(codegen, mono_name);
                }
                const libc_ret_c: &byte = get_extern_libc_return_c_type(fn_decl);
                if libc_ret_c != null && strcmp(libc_ret_c as *byte, "const char *" as *byte) == 0 {
                    fputs("(const char *)" as *byte, codegen.emit_stream as *void);
                } else if libc_ret_c != null && strcmp(libc_ret_c as *byte, "char *" as *byte) == 0 {
                    fputs("(char *)" as *byte, codegen.emit_stream as *void);
                } else if callee_name != null && strcmp(callee_name as *byte, "readdir" as *byte) == 0 {
                    fputs("(struct Dirent *)" as *byte, codegen.emit_stream as *void);
                }
                fprintf(codegen.emit_stream as *void, "%s(" as *byte, safe_name as *byte);
                // 单参数 printf 用字面量格式避免 -Wformat-security
                if callee_name != null && strcmp(callee_name as *byte, "printf" as *byte) == 0 && arg_count == 1 {
                    fputs("\"%s\", " as *byte, codegen.emit_stream as *void);
                }
            } else {
                fputs("unknown(" as *byte, codegen.emit_stream as *void);
            }
            
            // 生成参数
            var i: i32 = 0;
            while i < arg_count {
            if codegen.interp_arg_temp_names[i] != null {
                const libc_param_c: &byte = get_extern_libc_param_c_type(fn_decl, i);
                if libc_param_c != null && strcmp(libc_param_c as *byte, "char *" as *byte) == 0 {
                    fputs("(char *)" as *byte, codegen.emit_stream as *void);
                } else if libc_param_c != null {
                    fputs("(const char *)" as *byte, codegen.emit_stream as *void);
                } else {
                    fputs("(uint8_t *)" as *byte, codegen.emit_stream as *void);
                }
                fputs(codegen.interp_arg_temp_names[i] as *byte, codegen.emit_stream as *void);
            } else {
            // fprintf 的格式参数为第 2 个 (i==1)，snprintf 的格式参数为第 3 个 (i==2)；强制 (const char *) 消除 -Wformat= 警告
            var is_format_arg: i32 = 0;
            if callee_name != null && ((strcmp(callee_name as *byte, "fprintf" as *byte) == 0 && i == 1) || (strcmp(callee_name as *byte, "snprintf" as *byte) == 0 && i == 2)) {
                is_format_arg = 1;
            }
            if is_format_arg != 0 && expr.call_expr_args[i] != null {
                const fmt: &ASTNode = expr.call_expr_args[i];
                if fmt.type == ASTNodeType.AST_STRING {
                    const name: &byte = add_string_constant(codegen, fmt.string_literal_value);
                    if name != null {
                        fprintf(codegen.emit_stream as *void, "(const char *)%s" as *byte, name as *byte);
                    } else {
                        fputs("(const char *)\"" as *byte, codegen.emit_stream as *void);
                        escape_string_for_c(codegen.emit_stream, fmt.string_literal_value);
                        fputc(34, codegen.emit_stream as *void);
                    }
                } else if fmt.type == ASTNodeType.AST_CAST_EXPR && fmt.cast_expr_expr != null && fmt.cast_expr_expr.type == ASTNodeType.AST_STRING {
                    const name: &byte = add_string_constant(codegen, fmt.cast_expr_expr.string_literal_value);
                    if name != null {
                        fprintf(codegen.emit_stream as *void, "(const char *)%s" as *byte, name as *byte);
                    } else {
                        fputs("(const char *)\"" as *byte, codegen.emit_stream as *void);
                        escape_string_for_c(codegen.emit_stream, fmt.cast_expr_expr.string_literal_value);
                        fputc(34, codegen.emit_stream as *void);
                    }
                } else {
                    fputs("(const char *)" as *byte, codegen.emit_stream as *void);
                    gen_expr(codegen, fmt);
                }
            } else {
            // 检查参数是否是字符串常量或 *byte 类型，如果是则添加类型转换以消除 const 警告
            var is_string_arg: i32 = 0;
            if expr.call_expr_args[i] != null && expr.call_expr_args[i].type == ASTNodeType.AST_STRING {
                is_string_arg = 1;
            }
            // 检查参数是否是 *byte 类型的标识符或字符串常量
            var is_byte_ptr_arg: i32 = 0;
            if expr.call_expr_args[i] != null && expr.call_expr_args[i].type == ASTNodeType.AST_IDENTIFIER {
                const arg_name: &byte = expr.call_expr_args[i].identifier_name;
                const arg_type_c: &byte = get_identifier_type_c(codegen, arg_name);
                if arg_type_c != null && strcmp(arg_type_c as *byte, "uint8_t *" as *byte) == 0 {
                    is_byte_ptr_arg = 1;
                } else if arg_type_c == null {
                    // 检查是否是字符串常量（字符串常量名称通常以 "str" 开头）
                    if arg_name != null && strncmp(arg_name as *byte, "str" as *byte, 3) == 0 {
                        // 检查是否是字符串常量表中的名称
                        var j: i32 = 0;
                        while j < codegen.string_constant_count {
                            if strcmp(codegen.string_constants[j].name as *byte, arg_name as *byte) == 0 {
                                is_byte_ptr_arg = 1;
                                break;
                            }
                            j = j + 1;
                        }
                    }
                }
            }
            // 检查是否是 strtol 或 strtod 的第二个参数（endptr），需要转换为 char **
            var is_strtol_strtod_endptr: i32 = 0;
            var is_strtol_strtod_null: i32 = 0;
            if callee_name != null && i == 1 &&
               (strcmp(callee_name as *byte, "strtol" as *byte) == 0 ||
                strcmp(callee_name as *byte, "strtod" as *byte) == 0) {
                // 检查参数是否是 null as * *byte 类型
                if expr.call_expr_args[i] != null {
                    const arg: &ASTNode = expr.call_expr_args[i];
                    if arg.type == ASTNodeType.AST_CAST_EXPR {
                        const cast_type: &ASTNode = arg.cast_expr_target_type;
                        const src_expr: &ASTNode = arg.cast_expr_expr;
                        if cast_type != null && cast_type.type == ASTNodeType.AST_TYPE_POINTER {
                            const inner_type: &ASTNode = cast_type.type_pointer_pointed_type;
                            if inner_type != null && inner_type.type == ASTNodeType.AST_TYPE_POINTER {
                                const inner_inner_type: &ASTNode = inner_type.type_pointer_pointed_type;
                                if inner_inner_type != null && inner_inner_type.type == ASTNodeType.AST_TYPE_NAMED &&
                                   inner_inner_type.type_named_name != null &&
                                   strcmp(inner_inner_type.type_named_name as *byte, "byte" as *byte) == 0 {
                                    is_strtol_strtod_endptr = 1;
                                    // 检查源表达式是否是 null（null 被解析为 AST_IDENTIFIER）
                                    if src_expr != null && src_expr.type == ASTNodeType.AST_IDENTIFIER &&
                                       src_expr.identifier_name != null &&
                                       strcmp(src_expr.identifier_name as *byte, "null" as *byte) == 0 {
                                        is_strtol_strtod_null = 1;
                                    }
                                }
                            }
                        }
                    }
                }
            }
            
            var apply_string_byte_ptr_cast: i32 = 0;
            if is_string_arg != 0 {
                if fn_decl == null || expr.call_expr_args[i] == null ||
                   c99_string_literal_passes_as_const_byte_slice_value(fn_decl, i, expr.call_expr_args[i]) == 0 {
                    apply_string_byte_ptr_cast = 1;
                }
            }
            if is_byte_ptr_arg != 0 || apply_string_byte_ptr_cast != 0 {
                // sys_read 的 buf 参数（i==1）为写入目标，必须用 (uint8_t *) 避免 -Wdiscarded-qualifiers
                // sys_open 的 pathname（i==0）：C 版不添加 cast，与 C 输出一致
                const libc_param_c: &byte = get_extern_libc_param_c_type(fn_decl, i);
                if callee_name != null && strcmp(callee_name as *byte, "sys_read" as *byte) == 0 && i == 1 {
                    fputs("(uint8_t *)" as *byte, codegen.emit_stream as *void);
                } else if callee_name != null && strcmp(callee_name as *byte, "sys_open" as *byte) == 0 && i == 0 {
                    // 不添加 cast，与 C 版一致
                } else if libc_param_c != null && strcmp(libc_param_c as *byte, "char *" as *byte) == 0 {
                    fputs("(char *)" as *byte, codegen.emit_stream as *void);
                } else if libc_param_c != null {
                    fputs("(const char *)" as *byte, codegen.emit_stream as *void);
                } else {
                    fputs("(uint8_t *)" as *byte, codegen.emit_stream as *void);
                }
            }
            
            // 检查是否是大结构体参数且函数期望指针
            // 对于 extern 函数，如果参数类型是大结构体（>16字节），则传递地址
            var need_address: i32 = 0;
            if fn_decl != null && fn_decl.type == ASTNodeType.AST_FN_DECL {
                const body: &ASTNode = fn_decl.fn_decl_body;
                var is_extern: i32 = 0;
                if body == null {
                    is_extern = 1;
                }
                
                if is_extern != 0 && expr.call_expr_args[i] != null && i < fn_decl.fn_decl_param_count {
                    const param: &ASTNode = fn_decl.fn_decl_params[i];
                    if param != null && param.type == ASTNodeType.AST_VAR_DECL {
                        const param_type: &ASTNode = param.var_decl_type;
                        if param_type != null && param_type.type == ASTNodeType.AST_TYPE_NAMED {
                            const struct_size: i32 = calculate_struct_size(codegen, param_type);
                            if struct_size > 16 {
                                // 函数期望指针，需要传递地址
                                need_address = 1;
                            }
                        }
                    }
                }
            }
            
            if need_address != 0 {
                fputc(38, codegen.emit_stream as *void);  // '&'
            }
            // 装箱：当形参是接口类型（值或指针）且实参是实现了该接口的结构体时，生成 vtable+data
            var did_box: i32 = 0;
            if fn_decl != null && fn_decl.type == ASTNodeType.AST_FN_DECL && i < fn_decl.fn_decl_param_count {
                const param: &ASTNode = fn_decl.fn_decl_params[i];
                if param != null && param.type == ASTNodeType.AST_VAR_DECL && param.var_decl_type != null {
                    var param_type_name: &byte = null;
                    var param_is_iface_ptr: i32 = 0;
                    var param_iface_type: &ASTNode = null;
                    if param.var_decl_type.type == ASTNodeType.AST_TYPE_NAMED {
                        param_type_name = param.var_decl_type.type_named_name;
                        param_iface_type = param.var_decl_type;
                    } else if param.var_decl_type.type == ASTNodeType.AST_TYPE_POINTER &&
                               param.var_decl_type.type_pointer_pointed_type != null &&
                               param.var_decl_type.type_pointer_pointed_type.type == ASTNodeType.AST_TYPE_NAMED {
                        param_type_name = param.var_decl_type.type_pointer_pointed_type.type_named_name;
                        param_is_iface_ptr = 1;
                        param_iface_type = param.var_decl_type.type_pointer_pointed_type;
                    }
                    const iface: &ASTNode = find_interface_decl_c99(codegen, param_type_name);
                    if iface != null && expr.call_expr_args[i] != null {
                        var struct_name_for_check: &byte = null;
                        var arg_is_pointer_like: i32 = 0;
                        const arg: &ASTNode = expr.call_expr_args[i];
                        if arg.type == ASTNodeType.AST_IDENTIFIER {
                            const arg_type_c: &byte = get_identifier_type_c(codegen, arg.identifier_name);
                            if arg_type_c != null {
                                var atc: &byte = arg_type_c;
                                if strncmp(atc as *byte, "const " as *byte, 6) == 0 {
                                    atc = &arg_type_c[6] as &byte;
                                }
                                if strncmp(atc as *byte, "struct " as *byte, 7) == 0 &&
                                    strstr(atc as *byte, "uya_interface_" as *byte) == null {
                                    var snbuf: [byte: SHORT_NAME_BUF_SIZE] = [];
                                    const start: &byte = &atc[7] as &byte;
                                    var pos: i32 = 0;
                                    while start[pos] != 0 && start[pos] != 32 && start[pos] != 42 && pos < SHORT_NAME_BUF_SIZE - 1 {
                                        snbuf[pos] = start[pos];
                                        pos = pos + 1;
                                    }
                                    snbuf[pos] = 0;
                                    if pos > 0 && struct_implements_interface_c99(codegen, &snbuf[0] as &byte, param_type_name) != 0 {
                                        struct_name_for_check = &snbuf[0] as &byte;
                                    }
                                }
                                // typedef：与 stmt / 成员调用共用 resolve（支持 `Foo *` 等的首标识符提取）
                                if struct_name_for_check == null && codegen.program_node != null &&
                                    strstr(atc as *byte, "uya_interface_" as *byte) == null {
                                    const ms_box: &byte = resolve_typedef_to_mono_struct_name_if_generic(codegen, atc);
                                    if ms_box != null && struct_implements_interface_c99(codegen, ms_box, param_type_name) != 0 {
                                        struct_name_for_check = ms_box;
                                    }
                                }
                            }
                        } else if arg.type == ASTNodeType.AST_STRUCT_INIT {
                            const st_name: &byte = arg.struct_init_struct_name;
                            if st_name != null && struct_implements_interface_c99(codegen, st_name, param_type_name) != 0 {
                                struct_name_for_check = st_name;
                            }
                        } else if arg.type == ASTNodeType.AST_UNARY_EXPR &&
                            (arg.unary_expr_op as TokenType) == TokenType.TOKEN_AMPERSAND &&
                            arg.unary_expr_operand != null {
                            const operand_type_c: &byte = get_c_type_of_expr(codegen, arg.unary_expr_operand);
                            if operand_type_c != null {
                                var otc: &byte = operand_type_c;
                                if strncmp(otc as *byte, "const " as *byte, 6) == 0 {
                                    otc = &operand_type_c[6] as &byte;
                                }
                                if strncmp(otc as *byte, "struct " as *byte, 7) == 0 &&
                                    strstr(otc as *byte, "uya_interface_" as *byte) == null {
                                    var snbuf_ptr: [byte: SHORT_NAME_BUF_SIZE] = [];
                                    const start_ptr: &byte = &otc[7] as &byte;
                                    var pos_ptr: i32 = 0;
                                    while start_ptr[pos_ptr] != 0 && start_ptr[pos_ptr] != 32 &&
                                        start_ptr[pos_ptr] != 42 && pos_ptr < SHORT_NAME_BUF_SIZE - 1 {
                                        snbuf_ptr[pos_ptr] = start_ptr[pos_ptr];
                                        pos_ptr = pos_ptr + 1;
                                    }
                                    snbuf_ptr[pos_ptr] = 0;
                                    if pos_ptr > 0 && struct_implements_interface_c99(codegen, &snbuf_ptr[0] as &byte, param_type_name) != 0 {
                                        struct_name_for_check = &snbuf_ptr[0] as &byte;
                                        arg_is_pointer_like = 1;
                                    }
                                }
                            }
                        }
                        if struct_name_for_check != null {
                            var iface_mono: &byte = param_type_name;
                            if param_iface_type != null &&
                                param_iface_type.type_named_type_arg_count > 0 && param_iface_type.type_named_type_args != null {
                                iface_mono = get_mono_struct_name(codegen, param_type_name,
                                    param_iface_type.type_named_type_args, param_iface_type.type_named_type_arg_count);
                            }
                            var struct_mono: &byte = struct_name_for_check;
                            if arg.type == ASTNodeType.AST_STRUCT_INIT &&
                                arg.struct_init_type_arg_count > 0 && arg.struct_init_type_args != null {
                                struct_mono = get_mono_struct_name(codegen, struct_name_for_check,
                                    arg.struct_init_type_args, arg.struct_init_type_arg_count);
                            }
                            const safe_iface: &byte = get_safe_c_identifier(codegen, iface_mono);
                            const safe_struct: &byte = get_safe_c_identifier(codegen, struct_mono);
                            if param_is_iface_ptr != 0 {
                                fprintf(codegen.emit_stream as *void, "&(struct uya_interface_%s){ .vtable = (void*)&uya_vtable_%s_%s, .data = (void*)(" as *byte,
                                        safe_iface as *byte, safe_iface as *byte, safe_struct as *byte);
                                gen_expr(codegen, expr.call_expr_args[i]);
                                fputs(") }" as *byte, codegen.emit_stream as *void);
                            } else if arg_is_pointer_like != 0 {
                                fprintf(codegen.emit_stream as *void, "(struct uya_interface_%s){ .vtable = (void*)&uya_vtable_%s_%s, .data = (void*)(" as *byte,
                                        safe_iface as *byte, safe_iface as *byte, safe_struct as *byte);
                                gen_expr(codegen, expr.call_expr_args[i]);
                                fputs(") }" as *byte, codegen.emit_stream as *void);
                            } else {
                                fprintf(codegen.emit_stream as *void, "(struct uya_interface_%s){ .vtable = (void*)&uya_vtable_%s_%s, .data = (void*)&(" as *byte,
                                        safe_iface as *byte, safe_iface as *byte, safe_struct as *byte);
                                gen_expr(codegen, expr.call_expr_args[i]);
                                fputs(") }" as *byte, codegen.emit_stream as *void);
                            }
                            did_box = 1;
                        }
                    }
                }
            }
            if did_box == 0 {
                if is_strtol_strtod_endptr != 0 && is_strtol_strtod_null != 0 {
                    // strtol 和 strtod 的第二个参数如果是 null as * *byte，生成 (const uint8_t **)NULL 匹配 libc 签名
                    fputs("(const uint8_t **)NULL" as *byte, codegen.emit_stream as *void);
                } else {
                    c99_emit_call_arg_expr(codegen, fn_decl, i, expr.call_expr_args[i]);
                }
            }
            }
            }  // is_format_arg == 0 的 else 结束
            if i < arg_count - 1 {
                c99_emit_comma_space(codegen);
            }
            i = i + 1;
        }
        fputc(41, codegen.emit_stream as *void);  // ')'
        }
        }
}

// 生成二元表达式
// 生成错误类型比较代码
fn gen_error_value_comparison(codegen: &C99CodeGenerator, left: &ASTNode, right: &ASTNode, op: TokenType) i32 {
    // err == error.X 或 error.X == err -> .error_id 比较
    if left != null && right != null {
        if left.type == ASTNodeType.AST_IDENTIFIER && right.type == ASTNodeType.AST_ERROR_VALUE {
            var id: i32 = c99_get_or_add_error_id(codegen, right.error_value_name);
            if id == 0 {
                id = 1;
            }
            const safe: &byte = get_c_name_for_identifier_ref(codegen, left.identifier_name);
            if op == TokenType.TOKEN_NOT_EQUAL {
                fprintf(codegen.emit_stream as *void, "(%s.error_id != %dU)" as *byte, safe as *byte, id);
            } else {
                fprintf(codegen.emit_stream as *void, "(%s.error_id == %dU)" as *byte, safe as *byte, id);
            }
            return 1;
        }
        if left.type == ASTNodeType.AST_ERROR_VALUE && right.type == ASTNodeType.AST_IDENTIFIER {
            var id: i32 = c99_get_or_add_error_id(codegen, left.error_value_name);
            if id == 0 {
                id = 1;
            }
            const safe: &byte = get_c_name_for_identifier_ref(codegen, right.identifier_name);
            if op == TokenType.TOKEN_NOT_EQUAL {
                fprintf(codegen.emit_stream as *void, "(%dU != %s.error_id)" as *byte, id, safe as *byte);
            } else {
                fprintf(codegen.emit_stream as *void, "(%dU == %s.error_id)" as *byte, id, safe as *byte);
            }
            return 1;
        }
    }
    return 0;
}
// 生成结构体字段比较代码
fn gen_struct_field_comparison(codegen: &C99CodeGenerator, left: &ASTNode, right: &ASTNode, field: &ASTNode) void {
    const field_type: &ASTNode = field.var_decl_type;
    const safe_field: &byte = get_safe_c_identifier(codegen, field.var_decl_name);
    if safe_field == null { return; }
    
    var field_needs_memcmp: i32 = 0;
    if field_type != null {
        if field_type.type == ASTNodeType.AST_TYPE_NAMED {
            const type_name: &byte = field_type.type_named_name;
            if type_name != null && find_struct_decl_c99(codegen, type_name) != null {
                field_needs_memcmp = 1;
            }
        } else if field_type.type == ASTNodeType.AST_TYPE_ARRAY {
            field_needs_memcmp = 1;
        }
    }
    
    if field_needs_memcmp != 0 {
        fputs("(__uya_memcmp(&(" as *byte, codegen.emit_stream as *void);
        gen_expr(codegen, left);
        fputs(")." as *byte, codegen.emit_stream as *void);
        fputs(safe_field as *byte, codegen.emit_stream as *void);
        fputs(", &(" as *byte, codegen.emit_stream as *void);
        gen_expr(codegen, right);
        fputs(")." as *byte, codegen.emit_stream as *void);
        fputs(safe_field as *byte, codegen.emit_stream as *void);
        fputs(", sizeof((" as *byte, codegen.emit_stream as *void);
        gen_expr(codegen, left);
        fputs(")." as *byte, codegen.emit_stream as *void);
        fputs(safe_field as *byte, codegen.emit_stream as *void);
        fputs(")) == 0)" as *byte, codegen.emit_stream as *void);
    } else {
        fputs("((" as *byte, codegen.emit_stream as *void);
        gen_expr(codegen, left);
        fputs(")." as *byte, codegen.emit_stream as *void);
        fputs(safe_field as *byte, codegen.emit_stream as *void);
        fputs(" == (" as *byte, codegen.emit_stream as *void);
        gen_expr(codegen, right);
        fputs(")." as *byte, codegen.emit_stream as *void);
        fputs(safe_field as *byte, codegen.emit_stream as *void);
        fputs(")" as *byte, codegen.emit_stream as *void);
    }
}

// 生成结构体 memcmp 比较（回退方案）
fn gen_struct_memcmp_comparison(codegen: &C99CodeGenerator, left: &ASTNode, right: &ASTNode, op: TokenType) void {
    fputc(40, codegen.emit_stream as *void);  // '('
    if left.type == ASTNodeType.AST_IDENTIFIER {
        fputs("__uya_memcmp(&" as *byte, codegen.emit_stream as *void);
        gen_expr(codegen, left);
        fputs(", &" as *byte, codegen.emit_stream as *void);
        gen_expr(codegen, right);
        fputs(", sizeof(" as *byte, codegen.emit_stream as *void);
        gen_expr(codegen, left);
        fputs("))" as *byte, codegen.emit_stream as *void);
    } else if left.type == ASTNodeType.AST_STRUCT_INIT {
        const struct_name: &byte = left.struct_init_struct_name;
        fputs("__uya_memcmp(&" as *byte, codegen.emit_stream as *void);
        gen_expr(codegen, left);
        fputs(", &" as *byte, codegen.emit_stream as *void);
        gen_expr(codegen, right);
        const safe_struct_name: &byte = get_safe_c_identifier(codegen, struct_name);
        fprintf(codegen.emit_stream as *void, ", sizeof(struct %s))" as *byte, safe_struct_name as *byte);
    } else {
        fputs("__uya_memcmp(&" as *byte, codegen.emit_stream as *void);
        gen_expr(codegen, left);
        fputs(", &" as *byte, codegen.emit_stream as *void);
        gen_expr(codegen, right);
        fputs(", sizeof(" as *byte, codegen.emit_stream as *void);
        gen_expr(codegen, left);
        fputs("))" as *byte, codegen.emit_stream as *void);
    }
    if op == TokenType.TOKEN_EQUAL {
        fputs(" == 0)" as *byte, codegen.emit_stream as *void);
    } else if op == TokenType.TOKEN_NOT_EQUAL {
        fputs(" != 0)" as *byte, codegen.emit_stream as *void);
    } else {
        fputc(41, codegen.emit_stream as *void);  // ')'
    }
}

fn c99_make_temp_name(codegen: &C99CodeGenerator, prefix: &byte) &byte {
    var name_buf: [byte: SHORT_NAME_BUF_SIZE] = [];
    snprintf(&name_buf[0] as *byte, SHORT_NAME_BUF_SIZE, "%s%d" as *byte, prefix as *byte, codegen.interp_temp_counter);
    codegen.interp_temp_counter = codegen.interp_temp_counter + 1;
    return c99_arena_strdup(codegen.arena, &name_buf[0] as &byte);
}

fn c99_type_c_skip_const(elem_c: &byte) &byte {
    if elem_c != null && strncmp(elem_c as *byte, "const " as *byte, 6) == 0 {
        return &(elem_c[6]);
    }
    return elem_c;
}

// 8× 向量：对第二个 4 通道块用 &name.lanes[4] 调用 uya_simd_sse_*x4
const SIMD_VEC_LANE_PTR_SZ: i32 = 96;
fn c99_simd_emit_sse_binary_fast_at(codegen: &C99CodeGenerator, fast_kind: i32, result_name: &byte, left_name: &byte, right_name: &byte, lane_off: i32, lanes: i32) void {
    if codegen == null {
        return;
    }
    var pr: [byte: 96] = [];
    var pl: [byte: 96] = [];
    var pb: [byte: 96] = [];
    if lane_off == 0 {
        snprintf(&pr[0] as *byte, SIMD_VEC_LANE_PTR_SZ, "%s.lanes" as *byte, result_name as *byte);
        snprintf(&pl[0] as *byte, SIMD_VEC_LANE_PTR_SZ, "%s.lanes" as *byte, left_name as *byte);
        snprintf(&pb[0] as *byte, SIMD_VEC_LANE_PTR_SZ, "%s.lanes" as *byte, right_name as *byte);
    } else {
        snprintf(&pr[0] as *byte, SIMD_VEC_LANE_PTR_SZ, "&%s.lanes[%d]" as *byte, result_name as *byte, lane_off);
        snprintf(&pl[0] as *byte, SIMD_VEC_LANE_PTR_SZ, "&%s.lanes[%d]" as *byte, left_name as *byte, lane_off);
        snprintf(&pb[0] as *byte, SIMD_VEC_LANE_PTR_SZ, "&%s.lanes[%d]" as *byte, right_name as *byte, lane_off);
    }
    if fast_kind == 101 {
        if lanes == 2 {
            fprintf(codegen.emit_stream as *void, "uya_simd_sse_eq_i32x2_mask(%s, %s, %s); " as *byte,
                &pr[0] as *byte, &pl[0] as *byte, &pb[0] as *byte);
        } else {
            fprintf(codegen.emit_stream as *void, "uya_simd_sse_eq_i32x4_mask(%s, %s, %s); " as *byte,
                &pr[0] as *byte, &pl[0] as *byte, &pb[0] as *byte);
        }
    } else if fast_kind == 102 {
        if lanes == 2 {
            fprintf(codegen.emit_stream as *void, "uya_simd_sse_ne_i32x2_mask(%s, %s, %s); " as *byte,
                &pr[0] as *byte, &pl[0] as *byte, &pb[0] as *byte);
        } else {
            fprintf(codegen.emit_stream as *void, "uya_simd_sse_ne_i32x4_mask(%s, %s, %s); " as *byte,
                &pr[0] as *byte, &pl[0] as *byte, &pb[0] as *byte);
        }
    } else if fast_kind == 103 {
        if lanes == 2 {
            fprintf(codegen.emit_stream as *void, "uya_simd_sse_lt_i32x2_mask(%s, %s, %s); " as *byte,
                &pr[0] as *byte, &pl[0] as *byte, &pb[0] as *byte);
        } else {
            fprintf(codegen.emit_stream as *void, "uya_simd_sse_lt_i32x4_mask(%s, %s, %s); " as *byte,
                &pr[0] as *byte, &pl[0] as *byte, &pb[0] as *byte);
        }
    } else if fast_kind == 104 {
        if lanes == 2 {
            fprintf(codegen.emit_stream as *void, "uya_simd_sse_gt_i32x2_mask(%s, %s, %s); " as *byte,
                &pr[0] as *byte, &pl[0] as *byte, &pb[0] as *byte);
        } else {
            fprintf(codegen.emit_stream as *void, "uya_simd_sse_gt_i32x4_mask(%s, %s, %s); " as *byte,
                &pr[0] as *byte, &pl[0] as *byte, &pb[0] as *byte);
        }
    } else if fast_kind == 105 {
        if lanes == 2 {
            fprintf(codegen.emit_stream as *void, "uya_simd_sse_le_i32x2_mask(%s, %s, %s); " as *byte,
                &pr[0] as *byte, &pl[0] as *byte, &pb[0] as *byte);
        } else {
            fprintf(codegen.emit_stream as *void, "uya_simd_sse_le_i32x4_mask(%s, %s, %s); " as *byte,
                &pr[0] as *byte, &pl[0] as *byte, &pb[0] as *byte);
        }
    } else if fast_kind == 106 {
        if lanes == 2 {
            fprintf(codegen.emit_stream as *void, "uya_simd_sse_ge_i32x2_mask(%s, %s, %s); " as *byte,
                &pr[0] as *byte, &pl[0] as *byte, &pb[0] as *byte);
        } else {
            fprintf(codegen.emit_stream as *void, "uya_simd_sse_ge_i32x4_mask(%s, %s, %s); " as *byte,
                &pr[0] as *byte, &pl[0] as *byte, &pb[0] as *byte);
        }
    } else if fast_kind == 107 {
        if lanes == 2 {
            fprintf(codegen.emit_stream as *void, "uya_simd_sse_lt_u32x2_mask(%s, %s, %s); " as *byte,
                &pr[0] as *byte, &pl[0] as *byte, &pb[0] as *byte);
        } else {
            fprintf(codegen.emit_stream as *void, "uya_simd_sse_lt_u32x4_mask(%s, %s, %s); " as *byte,
                &pr[0] as *byte, &pl[0] as *byte, &pb[0] as *byte);
        }
    } else if fast_kind == 108 {
        if lanes == 2 {
            fprintf(codegen.emit_stream as *void, "uya_simd_sse_gt_u32x2_mask(%s, %s, %s); " as *byte,
                &pr[0] as *byte, &pl[0] as *byte, &pb[0] as *byte);
        } else {
            fprintf(codegen.emit_stream as *void, "uya_simd_sse_gt_u32x4_mask(%s, %s, %s); " as *byte,
                &pr[0] as *byte, &pl[0] as *byte, &pb[0] as *byte);
        }
    } else if fast_kind == 109 {
        if lanes == 2 {
            fprintf(codegen.emit_stream as *void, "uya_simd_sse_le_u32x2_mask(%s, %s, %s); " as *byte,
                &pr[0] as *byte, &pl[0] as *byte, &pb[0] as *byte);
        } else {
            fprintf(codegen.emit_stream as *void, "uya_simd_sse_le_u32x4_mask(%s, %s, %s); " as *byte,
                &pr[0] as *byte, &pl[0] as *byte, &pb[0] as *byte);
        }
    } else if fast_kind == 110 {
        if lanes == 2 {
            fprintf(codegen.emit_stream as *void, "uya_simd_sse_ge_u32x2_mask(%s, %s, %s); " as *byte,
                &pr[0] as *byte, &pl[0] as *byte, &pb[0] as *byte);
        } else {
            fprintf(codegen.emit_stream as *void, "uya_simd_sse_ge_u32x4_mask(%s, %s, %s); " as *byte,
                &pr[0] as *byte, &pl[0] as *byte, &pb[0] as *byte);
        }
    } else if fast_kind == 201 {
        if lanes == 2 {
            fprintf(codegen.emit_stream as *void, "uya_simd_sse_eq_f32x2_mask(%s, %s, %s); " as *byte,
                &pr[0] as *byte, &pl[0] as *byte, &pb[0] as *byte);
        } else {
            fprintf(codegen.emit_stream as *void, "uya_simd_sse_eq_f32x4_mask(%s, %s, %s); " as *byte,
                &pr[0] as *byte, &pl[0] as *byte, &pb[0] as *byte);
        }
    } else if fast_kind == 202 {
        if lanes == 2 {
            fprintf(codegen.emit_stream as *void, "uya_simd_sse_ne_f32x2_mask(%s, %s, %s); " as *byte,
                &pr[0] as *byte, &pl[0] as *byte, &pb[0] as *byte);
        } else {
            fprintf(codegen.emit_stream as *void, "uya_simd_sse_ne_f32x4_mask(%s, %s, %s); " as *byte,
                &pr[0] as *byte, &pl[0] as *byte, &pb[0] as *byte);
        }
    } else if fast_kind == 203 {
        if lanes == 2 {
            fprintf(codegen.emit_stream as *void, "uya_simd_sse_lt_f32x2_mask(%s, %s, %s); " as *byte,
                &pr[0] as *byte, &pl[0] as *byte, &pb[0] as *byte);
        } else {
            fprintf(codegen.emit_stream as *void, "uya_simd_sse_lt_f32x4_mask(%s, %s, %s); " as *byte,
                &pr[0] as *byte, &pl[0] as *byte, &pb[0] as *byte);
        }
    } else if fast_kind == 204 {
        if lanes == 2 {
            fprintf(codegen.emit_stream as *void, "uya_simd_sse_le_f32x2_mask(%s, %s, %s); " as *byte,
                &pr[0] as *byte, &pl[0] as *byte, &pb[0] as *byte);
        } else {
            fprintf(codegen.emit_stream as *void, "uya_simd_sse_le_f32x4_mask(%s, %s, %s); " as *byte,
                &pr[0] as *byte, &pl[0] as *byte, &pb[0] as *byte);
        }
    } else if fast_kind == 205 {
        if lanes == 2 {
            fprintf(codegen.emit_stream as *void, "uya_simd_sse_gt_f32x2_mask(%s, %s, %s); " as *byte,
                &pr[0] as *byte, &pl[0] as *byte, &pb[0] as *byte);
        } else {
            fprintf(codegen.emit_stream as *void, "uya_simd_sse_gt_f32x4_mask(%s, %s, %s); " as *byte,
                &pr[0] as *byte, &pl[0] as *byte, &pb[0] as *byte);
        }
