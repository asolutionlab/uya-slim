fn c99_collect_simd_reduce_max_emit_flags_from_call(codegen: &C99CodeGenerator, expr: &ASTNode) void {
    if codegen == null || expr == null || c99_expr_is_vector_reduce_max(expr) == 0 {
        return;
    }
    if expr.call_expr_arg_count < 1 || expr.call_expr_args == null || expr.call_expr_args[0] == null {
        return;
    }
    var target_rmax: &ASTNode = expr.simd_splat_target_type;
    if target_rmax == null {
        target_rmax = c99_resolve_simd_type_ast_from_expr(codegen, expr.call_expr_args[0]);
    }
    if target_rmax == null || target_rmax.type != ASTNodeType.AST_TYPE_VECTOR ||
        target_rmax.type_vector_element_type == null || target_rmax.type_vector_size_expr == null {
        return;
    }
    const lanes_rmax: i32 = eval_const_expr(codegen, target_rmax.type_vector_size_expr);
    const elem_c_rmax: &byte = c99_type_to_c(codegen, target_rmax.type_vector_element_type);
    const elem_base_rmax: &byte = c99_type_c_skip_const(elem_c_rmax);
    if elem_base_rmax == null {
        return;
    }
    if lanes_rmax == 4 {
        if strcmp(elem_base_rmax as *byte, "int32_t" as *byte) == 0 {
            codegen.simd_emit_reduce_max_i32x4 = 1;
            return;
        }
        if strcmp(elem_base_rmax as *byte, "uint32_t" as *byte) == 0 {
            codegen.simd_emit_reduce_max_u32x4 = 1;
            return;
        }
        if strcmp(elem_base_rmax as *byte, "float" as *byte) == 0 {
            codegen.simd_emit_reduce_max_f32x4 = 1;
        }
        return;
    }
    if lanes_rmax == 2 {
        if strcmp(elem_base_rmax as *byte, "int32_t" as *byte) == 0 {
            codegen.simd_emit_reduce_max_i32x2 = 1;
            return;
        }
        if strcmp(elem_base_rmax as *byte, "uint32_t" as *byte) == 0 {
            codegen.simd_emit_reduce_max_u32x2 = 1;
            return;
        }
        if strcmp(elem_base_rmax as *byte, "float" as *byte) == 0 {
            codegen.simd_emit_reduce_max_f32x2 = 1;
        }
    }
}

fn c99_expr_is_vector_reduce_min(expr: &ASTNode) i32 {
    if expr == null || expr.type != ASTNodeType.AST_CALL_EXPR {
        return 0;
