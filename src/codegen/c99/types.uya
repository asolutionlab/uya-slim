    fputs("static inline void uya_simd_sse_div_u32x4(void *r, const void *a, const void *b) {\n" as *byte, codegen.output as *void);
    fputs("  uint32_t *rr = (uint32_t *)r; const uint32_t *aa = (const uint32_t *)a; const uint32_t *bb = (const uint32_t *)b;\n" as *byte, codegen.output as *void);
    fputs("  int _i; for (_i = 0; _i < 4; _i++) rr[_i] = aa[_i] / bb[_i];\n}\n" as *byte, codegen.output as *void);
    fputs("static inline void uya_simd_sse_rem_u32x4(void *r, const void *a, const void *b) {\n" as *byte, codegen.output as *void);
    fputs("  uint32_t *rr = (uint32_t *)r; const uint32_t *aa = (const uint32_t *)a; const uint32_t *bb = (const uint32_t *)b;\n" as *byte, codegen.output as *void);
    fputs("  int _i; for (_i = 0; _i < 4; _i++) rr[_i] = aa[_i] % bb[_i];\n}\n" as *byte, codegen.output as *void);
    fputs("static inline void uya_simd_sse_shl_i32x4(void *r, const void *a, const void *b) {\n" as *byte, codegen.output as *void);
    fputs("  int32_t *rr = (int32_t *)r; const int32_t *aa = (const int32_t *)a; const int32_t *bb = (const int32_t *)b;\n" as *byte, codegen.output as *void);
    fputs("  int _i; for (_i = 0; _i < 4; _i++) rr[_i] = aa[_i] << bb[_i];\n}\n" as *byte, codegen.output as *void);
    fputs("static inline void uya_simd_sse_shr_i32x4(void *r, const void *a, const void *b) {\n" as *byte, codegen.output as *void);
    fputs("  int32_t *rr = (int32_t *)r; const int32_t *aa = (const int32_t *)a; const int32_t *bb = (const int32_t *)b;\n" as *byte, codegen.output as *void);
    fputs("  int _i; for (_i = 0; _i < 4; _i++) rr[_i] = aa[_i] >> bb[_i];\n}\n" as *byte, codegen.output as *void);
    fputs("static inline void uya_simd_sse_shl_u32x4(void *r, const void *a, const void *b) {\n" as *byte, codegen.output as *void);
    fputs("  uint32_t *rr = (uint32_t *)r; const uint32_t *aa = (const uint32_t *)a; const uint32_t *bb = (const uint32_t *)b;\n" as *byte, codegen.output as *void);
    fputs("  int _i; for (_i = 0; _i < 4; _i++) rr[_i] = aa[_i] << bb[_i];\n}\n" as *byte, codegen.output as *void);
    fputs("static inline void uya_simd_sse_shr_u32x4(void *r, const void *a, const void *b) {\n" as *byte, codegen.output as *void);
    fputs("  uint32_t *rr = (uint32_t *)r; const uint32_t *aa = (const uint32_t *)a; const uint32_t *bb = (const uint32_t *)b;\n" as *byte, codegen.output as *void);
