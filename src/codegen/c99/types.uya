        fputs("  __m128 x = _mm_loadu_ps((const float *)v);\n" as *byte, codegen.output as *void);
        fputs("  __m128 t = _mm_max_ps(x, _mm_shuffle_ps(x, x, _MM_SHUFFLE(2, 3, 0, 1));\n" as *byte, codegen.output as *void);
        fputs("  t = _mm_max_ps(t, _mm_shuffle_ps(t, t, _MM_SHUFFLE(1, 0, 3, 2)));\n" as *byte, codegen.output as *void);
        fputs("  *(float *)r = _mm_cvtss_f32(t);\n}\n" as *byte, codegen.output as *void);
    }
    // ×2 variants: all scalar (no SSE2 horizontal min/max)
