        fputs("  const float *p = (const float *)v; *(float *)r = p[0] + p[1];\n}\n" as *byte, codegen.output as *void);
    }
    if codegen.simd_emit_reduce_add_i32x4 != 0 {
        fputs("static inline void uya_simd_sse_reduce_add_i32x4(void *r, const void *v) {\n" as *byte, codegen.output as *void);
        fputs("  const int32_t *p = (const int32_t *)v; int32_t s = p[0]; int _i; for (_i = 1; _i < 4; _i++) s = s + p[_i]; *(int32_t *)r = s;\n}\n" as *byte, codegen.output as *void);
    }
    if codegen.simd_emit_reduce_add_u32x4 != 0 {
        fputs("static inline void uya_simd_sse_reduce_add_u32x4(void *r, const void *v) {\n" as *byte, codegen.output as *void);
        fputs("  const uint32_t *p = (const uint32_t *)v; uint32_t s = p[0]; int _i; for (_i = 1; _i < 4; _i++) s = s + p[_i]; *(uint32_t *)r = s;\n}\n" as *byte, codegen.output as *void);
    }
    if codegen.simd_emit_reduce_add_f32x4 != 0 {
        fputs("static inline void uya_simd_sse_reduce_add_f32x4(void *r, const void *v) {\n" as *byte, codegen.output as *void);
        fputs("  const float *p = (const float *)v; float s = p[0]; int _i; for (_i = 1; _i < 4; _i++) s = s + p[_i]; *(float *)r = s;\n}\n" as *byte, codegen.output as *void);
    }
    // i32/u32/f32 ×2 的 @vector.reduce_mul 助手（标量）
    if codegen.simd_emit_reduce_mul_i32x2 != 0 {
        fputs("static inline void uya_simd_sse_reduce_mul_i32x2(void *r, const void *v) {\n" as *byte, codegen.output as *void);
        fputs("  const int32_t *p = (const int32_t *)v; *(int32_t *)r = p[0] * p[1];\n}\n" as *byte, codegen.output as *void);
    }
    if codegen.simd_emit_reduce_mul_u32x2 != 0 {
        fputs("static inline void uya_simd_sse_reduce_mul_u32x2(void *r, const void *v) {\n" as *byte, codegen.output as *void);
        fputs("  const uint32_t *p = (const uint32_t *)v; *(uint32_t *)r = p[0] * p[1];\n}\n" as *byte, codegen.output as *void);
    }
    if codegen.simd_emit_reduce_mul_f32x2 != 0 {
        fputs("static inline void uya_simd_sse_reduce_mul_f32x2(void *r, const void *v) {\n" as *byte, codegen.output as *void);
        fputs("  const float *p = (const float *)v; *(float *)r = p[0] * p[1];\n}\n" as *byte, codegen.output as *void);
    }
    // i32/u32/f32 ×4 的 @vector.reduce_mul 助手（标量）
    if codegen.simd_emit_reduce_mul_i32x4 != 0 {
        fputs("static inline void uya_simd_sse_reduce_mul_i32x4(void *r, const void *v) {\n" as *byte, codegen.output as *void);
        fputs("  const int32_t *p = (const int32_t *)v; int32_t s = p[0]; int _i; for (_i = 1; _i < 4; _i++) s = s * p[_i]; *(int32_t *)r = s;\n}\n" as *byte, codegen.output as *void);
    }
    if codegen.simd_emit_reduce_mul_u32x4 != 0 {
        fputs("static inline void uya_simd_sse_reduce_mul_u32x4(void *r, const void *v) {\n" as *byte, codegen.output as *void);
        fputs("  const uint32_t *p = (const uint32_t *)v; uint32_t s = p[0]; int _i; for (_i = 1; _i < 4; _i++) s = s * p[_i]; *(uint32_t *)r = s;\n}\n" as *byte, codegen.output as *void);
    }
    if codegen.simd_emit_reduce_mul_f32x4 != 0 {
        fputs("static inline void uya_simd_sse_reduce_mul_f32x4(void *r, const void *v) {\n" as *byte, codegen.output as *void);
        fputs("  const float *p = (const float *)v; float s = p[0]; int _i; for (_i = 1; _i < 4; _i++) s = s * p[_i]; *(float *)r = s;\n}\n" as *byte, codegen.output as *void);
    }
    // scalar reduce_mul helpers 已在上方 reduce_add_scalar 中与 reduce_add helpers 一起输出
    // 此函数保留为空（向后兼容），实际发射在 reduce_add_scalar 中一次性完成
