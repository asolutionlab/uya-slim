// i32/u32/f32 ×2/×4 的 @vector.reduce_min/@vector.reduce_max 助手（SSE2/SSE4.1；i32/u32 ×4 用 SSE4.1 _mm_min_epi32/_mm_max_epi32；其余回退标量）
fn emit_simd_runtime_helpers_i32_u32_f32_reduce_min_max_x86_sse(codegen: &C99CodeGenerator) void {
    if codegen == null || codegen.output == null {
        return;
    }
    // reduce_min i32x4（i32x2 标量回退）
