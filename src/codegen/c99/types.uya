        fputs("  const float *aa = (const float *)a; const float *bb = (const float *)b;\n" as *byte, codegen.output as *void);
        fputs("  int _i; for (_i = 0; _i < 2; _i++) rr[_i] = MM[_i] ? aa[_i] : bb[_i];\n}\n" as *byte, codegen.output as *void);
    }
    if codegen.simd_emit_select_i32x4 != 0 {
        fputs("static inline void uya_simd_sse_select_i32x4(void *r, const void *m, const void *a, const void *b) {\n" as *byte, codegen.output as *void);
        fputs("  int32_t *rr = (int32_t *)r; const bool *MM = (const bool *)m;\n" as *byte, codegen.output as *void);
        fputs("  const int32_t *aa = (const int32_t *)a; const int32_t *bb = (const int32_t *)b;\n" as *byte, codegen.output as *void);
        fputs("  int _i; for (_i = 0; _i < 4; _i++) rr[_i] = MM[_i] ? aa[_i] : bb[_i];\n}\n" as *byte, codegen.output as *void);
    }
    if codegen.simd_emit_select_u32x4 != 0 {
        fputs("static inline void uya_simd_sse_select_u32x4(void *r, const void *m, const void *a, const void *b) {\n" as *byte, codegen.output as *void);
        fputs("  uint32_t *rr = (uint32_t *)r; const bool *MM = (const bool *)m;\n" as *byte, codegen.output as *void);
        fputs("  const uint32_t *aa = (const uint32_t *)a; const uint32_t *bb = (const uint32_t *)b;\n" as *byte, codegen.output as *void);
        fputs("  int _i; for (_i = 0; _i < 4; _i++) rr[_i] = MM[_i] ? aa[_i] : bb[_i];\n}\n" as *byte, codegen.output as *void);
    }
