// i32/u32/f32 ×2/×4 的 @vector.select 助手：按需输出（见 simd_emit_select_*、c99_simd_any_select_helpers_needed）
fn emit_simd_runtime_helpers_i32_u32_f32_select_x86_sse(codegen: &C99CodeGenerator) void {
    if codegen == null || codegen.output == null {
        return;
    }
    if codegen.simd_emit_select_i32x2 != 0 {
        fputs("static inline void uya_simd_sse_select_i32x2(void *r, const void *m, const void *a, const void *b) {\n" as *byte, codegen.output as *void);
        fputs("  const bool *M = (const bool *)m;\n" as *byte, codegen.output as *void);
        fputs("  __m128i mk = _mm_set_epi32(0, 0, -(int)M[1], -(int)M[0]);\n" as *byte, codegen.output as *void);
        fputs("  __m128i va = _mm_loadl_epi64((const __m128i *)(const void *)a);\n" as *byte, codegen.output as *void);
        fputs("  __m128i vb = _mm_loadl_epi64((const __m128i *)(const void *)b);\n" as *byte, codegen.output as *void);
        fputs("  _mm_storel_epi64((__m128i *)(void *)r, _mm_or_si128(_mm_and_si128(va, mk), _mm_andnot_si128(mk, vb)));\n}\n" as *byte, codegen.output as *void);
    }
    if codegen.simd_emit_select_u32x2 != 0 {
        fputs("static inline void uya_simd_sse_select_u32x2(void *r, const void *m, const void *a, const void *b) {\n" as *byte, codegen.output as *void);
        fputs("  const bool *M = (const bool *)m;\n" as *byte, codegen.output as *void);
        fputs("  __m128i mk = _mm_set_epi32(0, 0, -(int)M[1], -(int)M[0]);\n" as *byte, codegen.output as *void);
        fputs("  __m128i va = _mm_loadl_epi64((const __m128i *)(const void *)a);\n" as *byte, codegen.output as *void);
        fputs("  __m128i vb = _mm_loadl_epi64((const __m128i *)(const void *)b);\n" as *byte, codegen.output as *void);
        fputs("  _mm_storel_epi64((__m128i *)(void *)r, _mm_or_si128(_mm_and_si128(va, mk), _mm_andnot_si128(mk, vb)));\n}\n" as *byte, codegen.output as *void);
    }
    if codegen.simd_emit_select_f32x2 != 0 {
        fputs("static inline void uya_simd_sse_select_f32x2(void *r, const void *m, const void *a, const void *b) {\n" as *byte, codegen.output as *void);
        fputs("  const bool *M = (const bool *)m;\n" as *byte, codegen.output as *void);
        fputs("  __m128i mki = _mm_set_epi32(0, 0, -(int)M[1], -(int)M[0]);\n" as *byte, codegen.output as *void);
        fputs("  __m128 mk = _mm_castsi128_ps(mki);\n" as *byte, codegen.output as *void);
        fputs("  __m128 va = _mm_castsi128_ps(_mm_loadl_epi64((const __m128i *)(const void *)a));\n" as *byte, codegen.output as *void);
        fputs("  __m128 vb = _mm_castsi128_ps(_mm_loadl_epi64((const __m128i *)(const void *)b));\n" as *byte, codegen.output as *void);
        fputs("  _mm_storel_epi64((__m128i *)(void *)r, _mm_castps_si128(_mm_or_ps(_mm_and_ps(va, mk), _mm_andnot_ps(mk, vb))));\n}\n" as *byte, codegen.output as *void);
    }
    if codegen.simd_emit_select_i32x4 != 0 {
        fputs("static inline void uya_simd_sse_select_i32x4(void *r, const void *m, const void *a, const void *b) {\n" as *byte, codegen.output as *void);
