        fputs("  __m128i mk = _mm_set_epi32(-(int)M[3], -(int)M[2], -(int)M[1], -(int)M[0]);\n" as *byte, codegen.output as *void);
        fputs("  __m128i va = _mm_loadu_si128((const __m128i *)(const void *)a);\n" as *byte, codegen.output as *void);
        fputs("  __m128i vb = _mm_loadu_si128((const __m128i *)(const void *)b);\n" as *byte, codegen.output as *void);
        fputs("  _mm_storeu_si128((__m128i *)(void *)r, _mm_or_si128(_mm_and_si128(va, mk), _mm_andnot_si128(mk, vb)));\n}\n" as *byte, codegen.output as *void);
    }
    if codegen.simd_emit_select_f32x4 != 0 {
        fputs("static inline void uya_simd_sse_select_f32x4(void *r, const void *m, const void *a, const void *b) {\n" as *byte, codegen.output as *void);
        fputs("  const bool *M = (const bool *)m;\n" as *byte, codegen.output as *void);
        fputs("  __m128i mki = _mm_set_epi32(-(int)M[3], -(int)M[2], -(int)M[1], -(int)M[0]);\n" as *byte, codegen.output as *void);
        fputs("  __m128 mk = _mm_castsi128_ps(mki);\n" as *byte, codegen.output as *void);
        fputs("  __m128 va = _mm_loadu_ps((const float *)a); __m128 vb = _mm_loadu_ps((const float *)b);\n" as *byte, codegen.output as *void);
        fputs("  _mm_storeu_ps((float *)r, _mm_or_ps(_mm_and_ps(va, mk), _mm_andnot_ps(mk, vb)));\n}\n" as *byte, codegen.output as *void);
    }
}

// i32/u32/f32 ×2/×4 的 @vector.reduce_add 助手（SSE2；见 simd_emit_reduce_add_*）
fn emit_simd_runtime_helpers_i32_u32_f32_reduce_add_x86_sse(codegen: &C99CodeGenerator) void {
    if codegen == null || codegen.output == null {
        return;
    }
    if codegen.simd_emit_reduce_add_i32x2 != 0 {
        fputs("static inline void uya_simd_sse_reduce_add_i32x2(void *r, const void *v) {\n" as *byte, codegen.output as *void);
        fputs("  __m128i x = _mm_loadl_epi64((const __m128i *)(const void *)v);\n" as *byte, codegen.output as *void);
        fputs("  int32_t a0 = _mm_cvtsi128_si32(x);\n" as *byte, codegen.output as *void);
        fputs("  int32_t a1 = _mm_cvtsi128_si32(_mm_shuffle_epi32(x, _MM_SHUFFLE(0, 0, 0, 1)));\n" as *byte, codegen.output as *void);
        fputs("  *(int32_t *)r = a0 + a1;\n}\n" as *byte, codegen.output as *void);
    }
    if codegen.simd_emit_reduce_add_u32x2 != 0 {
        fputs("static inline void uya_simd_sse_reduce_add_u32x2(void *r, const void *v) {\n" as *byte, codegen.output as *void);
        fputs("  __m128i x = _mm_loadl_epi64((const __m128i *)(const void *)v);\n" as *byte, codegen.output as *void);
        fputs("  uint32_t a0 = (uint32_t)_mm_cvtsi128_si32(x);\n" as *byte, codegen.output as *void);
        fputs("  uint32_t a1 = (uint32_t)_mm_cvtsi128_si32(_mm_shuffle_epi32(x, _MM_SHUFFLE(0, 0, 0, 1)));\n" as *byte, codegen.output as *void);
        fputs("  *(uint32_t *)r = a0 + a1;\n}\n" as *byte, codegen.output as *void);
    }
    if codegen.simd_emit_reduce_add_f32x2 != 0 {
        fputs("static inline void uya_simd_sse_reduce_add_f32x2(void *r, const void *v) {\n" as *byte, codegen.output as *void);
        fputs("  __m128 x = _mm_castsi128_ps(_mm_loadl_epi64((const __m128i *)(const void *)v));\n" as *byte, codegen.output as *void);
        fputs("  __m128 t = _mm_shuffle_ps(x, x, _MM_SHUFFLE(1, 1, 1, 1));\n" as *byte, codegen.output as *void);
        fputs("  x = _mm_add_ss(x, t);\n" as *byte, codegen.output as *void);
        fputs("  *(float *)r = _mm_cvtss_f32(x);\n}\n" as *byte, codegen.output as *void);
    }
    if codegen.simd_emit_reduce_add_i32x4 != 0 {
        fputs("static inline void uya_simd_sse_reduce_add_i32x4(void *r, const void *v) {\n" as *byte, codegen.output as *void);
        fputs("  __m128i x = _mm_loadu_si128((const __m128i *)(const void *)v);\n" as *byte, codegen.output as *void);
        fputs("  __m128i t = _mm_shuffle_epi32(x, _MM_SHUFFLE(2, 3, 0, 1));\n" as *byte, codegen.output as *void);
        fputs("  x = _mm_add_epi32(x, t);\n" as *byte, codegen.output as *void);
        fputs("  t = _mm_shuffle_epi32(x, _MM_SHUFFLE(1, 0, 3, 2));\n" as *byte, codegen.output as *void);
        fputs("  x = _mm_add_epi32(x, t);\n" as *byte, codegen.output as *void);
        fputs("  *(int32_t *)r = _mm_cvtsi128_si32(x);\n}\n" as *byte, codegen.output as *void);
    }
    if codegen.simd_emit_reduce_add_u32x4 != 0 {
        fputs("static inline void uya_simd_sse_reduce_add_u32x4(void *r, const void *v) {\n" as *byte, codegen.output as *void);
        fputs("  __m128i x = _mm_loadu_si128((const __m128i *)(const void *)v);\n" as *byte, codegen.output as *void);
        fputs("  __m128i t = _mm_shuffle_epi32(x, _MM_SHUFFLE(2, 3, 0, 1));\n" as *byte, codegen.output as *void);
        fputs("  x = _mm_add_epi32(x, t);\n" as *byte, codegen.output as *void);
        fputs("  t = _mm_shuffle_epi32(x, _MM_SHUFFLE(1, 0, 3, 2));\n" as *byte, codegen.output as *void);
        fputs("  x = _mm_add_epi32(x, t);\n" as *byte, codegen.output as *void);
        fputs("  *(uint32_t *)r = (uint32_t)_mm_cvtsi128_si32(x);\n}\n" as *byte, codegen.output as *void);
    }
    if codegen.simd_emit_reduce_add_f32x4 != 0 {
