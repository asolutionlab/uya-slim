// types.uya - C99 代码生成器类型系统模块
// 提供类型映射和类型检查功能
//
// 注意：需要先包含 internal.uya（包含类型定义和函数声明）
// 由于 Uya Mini 不支持模块系统，这里假设相关类型已经定义

// ===== 外部函数声明 =====
// C 标准库函数（在 extern_decls.uya 中声明）

// 方法参数类型映射：将 Self 替换为 struct_name，用于生成结构体方法签名
fn c99_type_to_c_with_self(codegen: &C99CodeGenerator, type_node: &ASTNode, self_struct_name: &byte) &byte {
    return c99_type_to_c_with_self_opt(codegen, type_node, self_struct_name, 0);
}

// const_self: 保留兼容参数；Self 的 const 语义应与普通指针一致，由 type_pointer_is_const 决定
//   &Self -> struct X *
//   &const Self -> const struct X *
//   *Self / *const Self 同理
// 联合体方法使用 struct uya_tagged_UnionName *，结构体方法使用 struct StructName *
fn c99_type_to_c_with_self_opt(codegen: &C99CodeGenerator, type_node: &ASTNode, self_struct_name: &byte, const_self: i32) &byte {
    if type_node == null || self_struct_name == null {
        return c99_type_to_c(codegen, type_node);
    }
    var is_union: i32 = 0;
    if find_union_decl_c99(codegen, self_struct_name) != null {
        is_union = 1;
    }
    if type_node.type == ASTNodeType.AST_TYPE_POINTER && type_node.type_pointer_pointed_type != null {
        const pt: &ASTNode = type_node.type_pointer_pointed_type;
        if pt.type == ASTNodeType.AST_TYPE_NAMED && pt.type_named_name != null &&
            strcmp(pt.type_named_name as *byte, "Self" as *byte) == 0 {
            var use_const: i32 = 0;
            _ = const_self;
            if type_node.type_pointer_is_const != 0 {
                use_const = 1;
            }
            const safe: &byte = get_safe_c_identifier(codegen, self_struct_name);
            var len: i32 = strlen(safe as *byte) + 32;
            const buf: &byte = arena_alloc(codegen.arena, len as usize) as &byte;
            if buf != null {
                if is_union != 0 {
                    if use_const != 0 {
                        snprintf(buf as *byte, len, "const struct uya_tagged_%s *" as *byte, safe as *byte);
                    } else {
                        snprintf(buf as *byte, len, "struct uya_tagged_%s *" as *byte, safe as *byte);
                    }
                } else {
                    if use_const != 0 {
                        snprintf(buf as *byte, len, "const struct %s *" as *byte, safe as *byte);
                    } else {
                        snprintf(buf as *byte, len, "struct %s *" as *byte, safe as *byte);
                    }
                }
                return buf;
            }
        }
    } else if type_node.type == ASTNodeType.AST_TYPE_NAMED && type_node.type_named_name != null &&
               strcmp(type_node.type_named_name as *byte, "Self" as *byte) == 0 {
        const safe: &byte = get_safe_c_identifier(codegen, self_struct_name);
        var len: i32 = strlen(safe as *byte) + 8;
        if is_union != 0 { len = strlen(safe as *byte) + 22; }
        const buf: &byte = arena_alloc(codegen.arena, len) as &byte;
        if buf != null {
            if is_union != 0 {
                snprintf(buf as *byte, len, "struct uya_tagged_%s" as *byte, safe as *byte);
            } else {
                snprintf(buf as *byte, len, "struct %s" as *byte, safe as *byte);
            }
            return buf;
        }
    }
    return c99_type_to_c(codegen, type_node);
}

// 类型转换递归深度限制（防止 Future/Poll 等泛型导致的无限递归）
const C99_TYPE_CONV_MAX_DEPTH: i32 = 64;
const C99_TYPE_TO_C_CACHE_BITS: i32 = 12;
const C99_TYPE_TO_C_CACHE_SIZE: i32 = 4096;
const C99_TYPE_TO_C_CACHE_MASK: i32 = 4095;

var g_c99_type_to_c_cached_codegen: &C99CodeGenerator = null;
var g_c99_type_to_c_cache_nodes: [&ASTNode: C99_TYPE_TO_C_CACHE_SIZE] = [];
var g_c99_type_to_c_cache_values: [&byte: C99_TYPE_TO_C_CACHE_SIZE] = [];
var g_c99_type_to_c_cache_method_params: [&TypeParam: C99_TYPE_TO_C_CACHE_SIZE] = [];
var g_c99_type_to_c_cache_method_args: [& & ASTNode: C99_TYPE_TO_C_CACHE_SIZE] = [];
var g_c99_type_to_c_cache_method_arg_counts: [i32: C99_TYPE_TO_C_CACHE_SIZE] = [];
var g_c99_type_to_c_cache_struct_params: [&TypeParam: C99_TYPE_TO_C_CACHE_SIZE] = [];
var g_c99_type_to_c_cache_struct_args: [& & ASTNode: C99_TYPE_TO_C_CACHE_SIZE] = [];
var g_c99_type_to_c_cache_struct_arg_counts: [i32: C99_TYPE_TO_C_CACHE_SIZE] = [];

fn c99_type_to_c_reset_cache() void {
    var i: i32 = 0;
    while i < C99_TYPE_TO_C_CACHE_SIZE {
        g_c99_type_to_c_cache_nodes[i] = null;
        g_c99_type_to_c_cache_values[i] = null;
        g_c99_type_to_c_cache_method_params[i] = null;
        g_c99_type_to_c_cache_method_args[i] = null;
        g_c99_type_to_c_cache_method_arg_counts[i] = 0;
        g_c99_type_to_c_cache_struct_params[i] = null;
        g_c99_type_to_c_cache_struct_args[i] = null;
        g_c99_type_to_c_cache_struct_arg_counts[i] = 0;
        i = i + 1;
    }
    g_c99_type_to_c_cached_codegen = null;
}

fn c99_type_to_c_cache_ensure(codegen: &C99CodeGenerator) void {
    if codegen == null {
        return;
    }
    if g_c99_type_to_c_cached_codegen == codegen {
        return;
    }
    c99_type_to_c_reset_cache();
    g_c99_type_to_c_cached_codegen = codegen;
}

fn c99_type_to_c_cache_slot(codegen: &C99CodeGenerator, type_node: &ASTNode) i32 {
    var h: usize = 0;
    if type_node != null {
        h = @usize_from_ptr(type_node as &void);
    }
    if codegen != null && codegen.current_type_params != null {
        h = h + (@usize_from_ptr(codegen.current_type_params as &void) * 131usize);
    }
    if codegen != null && codegen.current_type_args != null {
        h = h + (@usize_from_ptr(codegen.current_type_args as &void) * 257usize);
    }
    if codegen != null && codegen.struct_type_params != null {
        h = h + (@usize_from_ptr(codegen.struct_type_params as &void) * 389usize);
    }
    if codegen != null && codegen.struct_type_args != null {
        h = h + (@usize_from_ptr(codegen.struct_type_args as &void) * 521usize);
    }
    if codegen != null {
        h = h + ((codegen.current_type_arg_count as usize) * 17usize);
        h = h + ((codegen.struct_type_arg_count as usize) * 29usize);
    }
    return (h as i32) & C99_TYPE_TO_C_CACHE_MASK;
}

fn c99_type_to_c_cache_lookup(codegen: &C99CodeGenerator, type_node: &ASTNode) &byte {
    if codegen == null || type_node == null {
        return null;
    }
    c99_type_to_c_cache_ensure(codegen);
    const slot: i32 = c99_type_to_c_cache_slot(codegen, type_node);
    if g_c99_type_to_c_cache_nodes[slot] != type_node {
        return null;
    }
    if g_c99_type_to_c_cache_method_params[slot] != codegen.current_type_params ||
        g_c99_type_to_c_cache_method_args[slot] != codegen.current_type_args ||
        g_c99_type_to_c_cache_method_arg_counts[slot] != codegen.current_type_arg_count ||
        g_c99_type_to_c_cache_struct_params[slot] != codegen.struct_type_params ||
        g_c99_type_to_c_cache_struct_args[slot] != codegen.struct_type_args ||
        g_c99_type_to_c_cache_struct_arg_counts[slot] != codegen.struct_type_arg_count {
        return null;
    }
    return g_c99_type_to_c_cache_values[slot];
}

fn c99_type_to_c_cache_store(codegen: &C99CodeGenerator, type_node: &ASTNode, result: &byte) void {
    if codegen == null || type_node == null || result == null {
        return;
    }
    c99_type_to_c_cache_ensure(codegen);
    const slot: i32 = c99_type_to_c_cache_slot(codegen, type_node);
    g_c99_type_to_c_cache_nodes[slot] = type_node;
    g_c99_type_to_c_cache_values[slot] = result;
    g_c99_type_to_c_cache_method_params[slot] = codegen.current_type_params;
    g_c99_type_to_c_cache_method_args[slot] = codegen.current_type_args;
    g_c99_type_to_c_cache_method_arg_counts[slot] = codegen.current_type_arg_count;
    g_c99_type_to_c_cache_struct_params[slot] = codegen.struct_type_params;
    g_c99_type_to_c_cache_struct_args[slot] = codegen.struct_type_args;
    g_c99_type_to_c_cache_struct_arg_counts[slot] = codegen.struct_type_arg_count;
}

fn c99_make_simd_name_suffix(codegen: &C99CodeGenerator, type_c: &byte) &byte {
    if codegen == null || type_c == null {
        return null;
    }

    var src: &byte = type_c;
    if strncmp(src as *byte, "const " as *byte, 6) == 0 {
        src = &src[6];
    }
    if strncmp(src as *byte, "struct " as *byte, 7) == 0 {
        src = &src[7];
    } else if strncmp(src as *byte, "enum " as *byte, 5) == 0 {
        src = &src[5];
    }

    const buf: &byte = arena_alloc(codegen.arena, STRUCT_NAME_BUF_SIZE) as &byte;
    if buf == null {
        return null;
    }

    var i: i32 = 0;
    var j: i32 = 0;
    while src[i] != 0 && j < STRUCT_NAME_BUF_SIZE - 1 {
        const c: byte = src[i];
        if (c >= 97 && c <= 122) || (c >= 65 && c <= 90) || (c >= 48 && c <= 57) || c == 95 {
            buf[j] = c;
            j = j + 1;
        } else if c == 42 {
            if j < STRUCT_NAME_BUF_SIZE - 4 {
                buf[j] = 95;      // _
                buf[j + 1] = 112; // p
                buf[j + 2] = 116; // t
                buf[j + 3] = 114; // r
                j = j + 4;
            }
        } else if c == 32 || c == 45 {
            if j > 0 && buf[j - 1] != 95 {
                buf[j] = 95;
                j = j + 1;
            }
        }
        i = i + 1;
    }
    buf[j] = 0;
    return buf;
}

// 记录翻译单元中出现的向量元素标量类型，用于按需输出 SIMD 运行库（含 i8/u8/i64/u64 与 i16/u16/f64）
fn c99_simd_update_max_lanes_for_element(codegen: &C99CodeGenerator, element_type: &ASTNode, lanes: i32) void {
    if codegen == null || element_type == null || lanes <= 0 {
        return;
    }
    const ec: &byte = c99_type_to_c(codegen, element_type);
    if ec == null {
        return;
    }
    if strcmp(ec as *byte, "int8_t" as *byte) == 0 {
        if lanes > codegen.simd_max_lanes_i8 {
            codegen.simd_max_lanes_i8 = lanes;
        }
    } else if strcmp(ec as *byte, "uint8_t" as *byte) == 0 {
        if lanes > codegen.simd_max_lanes_u8 {
            codegen.simd_max_lanes_u8 = lanes;
        }
    } else if strcmp(ec as *byte, "int64_t" as *byte) == 0 {
        if lanes > codegen.simd_max_lanes_i64 {
            codegen.simd_max_lanes_i64 = lanes;
        }
    } else if strcmp(ec as *byte, "uint64_t" as *byte) == 0 {
        if lanes > codegen.simd_max_lanes_u64 {
            codegen.simd_max_lanes_u64 = lanes;
        }
    } else if strcmp(ec as *byte, "int16_t" as *byte) == 0 {
        if lanes > codegen.simd_max_lanes_i16 {
            codegen.simd_max_lanes_i16 = lanes;
        }
    } else if strcmp(ec as *byte, "uint16_t" as *byte) == 0 {
        if lanes > codegen.simd_max_lanes_u16 {
            codegen.simd_max_lanes_u16 = lanes;
        }
    } else if strcmp(ec as *byte, "double" as *byte) == 0 {
        if lanes > codegen.simd_max_lanes_f64 {
            codegen.simd_max_lanes_f64 = lanes;
        }
    } else if strcmp(ec as *byte, "int32_t" as *byte) == 0 {
        if lanes > codegen.simd_max_lanes_i32 {
            codegen.simd_max_lanes_i32 = lanes;
        }
    } else if strcmp(ec as *byte, "uint32_t" as *byte) == 0 {
        if lanes > codegen.simd_max_lanes_u32 {
            codegen.simd_max_lanes_u32 = lanes;
        }
    } else if strcmp(ec as *byte, "float" as *byte) == 0 {
        if lanes > codegen.simd_max_lanes_f32 {
            codegen.simd_max_lanes_f32 = lanes;
        }
    }
}

fn c99_register_simd_struct(codegen: &C99CodeGenerator, name: &byte, element_type: &ASTNode, lanes: i32, is_mask: i32) void {
    if codegen == null || name == null {
        return;
    }

    var i: i32 = 0;
    while i < codegen.simd_struct_count {
        if codegen.simd_struct_names[i] != null && strcmp(codegen.simd_struct_names[i] as *byte, name as *byte) == 0 {
            return;
        }
        i = i + 1;
    }

    if codegen.simd_struct_count < C99_MAX_SIMD_STRUCTS {
        codegen.simd_struct_names[codegen.simd_struct_count] = name;
        codegen.simd_struct_element_types[codegen.simd_struct_count] = element_type;
        codegen.simd_struct_lane_counts[codegen.simd_struct_count] = lanes;
        codegen.simd_struct_is_mask[codegen.simd_struct_count] = is_mask;
        codegen.simd_struct_count = codegen.simd_struct_count + 1;
        if is_mask == 0 && element_type != null {
            codegen.simd_vector_struct_reg_count = codegen.simd_vector_struct_reg_count + 1;
            c99_simd_update_max_lanes_for_element(codegen, element_type, lanes);
        }
        add_struct_definition(codegen, name);
    }
}

// 类型映射函数
fn c99_type_to_c(codegen: &C99CodeGenerator, type_node: &ASTNode) &byte {
    const cached: &byte = c99_type_to_c_cache_lookup(codegen, type_node);
    if cached != null {
        return cached;
    }
    const result: &byte = c99_type_to_c_uncached(codegen, type_node);
    c99_type_to_c_cache_store(codegen, type_node, result);
    return result;
}

fn c99_type_to_c_uncached(codegen: &C99CodeGenerator, type_node: &ASTNode) &byte {
    if type_node == null {
        return ("void" as *byte) as &byte;
    }
    if codegen != null && codegen.type_conv_depth >= C99_TYPE_CONV_MAX_DEPTH {
        return ("int32_t" as *byte) as &byte;
    }
    
    // 在单态化上下文中，先进行类型参数替换
    // 二级查找：先查找方法的类型参数，再查找结构体的类型参数
    if type_node.type == ASTNodeType.AST_TYPE_NAMED && type_node.type_named_name != null {
        const tp_name: &byte = type_node.type_named_name;
        
        // 第一级：查找方法的类型参数
        if codegen.current_type_params != null && codegen.current_type_param_count > 0 {
            var tpi: i32 = 0;
            while tpi < codegen.current_type_param_count {
                if codegen.current_type_params[tpi].name != null &&
                    strcmp(codegen.current_type_params[tpi].name as *byte, tp_name as *byte) == 0 {
                    // 找到匹配的类型参数，使用对应的类型实参
                    if codegen.current_type_args != null && tpi < codegen.current_type_arg_count {
                        // 防止无限递归：如果替换后的类型实参和当前节点相同，跳过
                        if codegen.current_type_args[tpi] == type_node {
                            return tp_name;  // 返回原始名称，避免无限递归
                        }
                        codegen.type_conv_depth = codegen.type_conv_depth + 1;
                        const r: &byte = c99_type_to_c(codegen, codegen.current_type_args[tpi]);
                        codegen.type_conv_depth = codegen.type_conv_depth - 1;
                        return r;
                    }
                }
                tpi = tpi + 1;
            }
        }
        
        // 第二级：查找结构体的类型参数
        if codegen.struct_type_params != null && codegen.struct_type_param_count > 0 {
            var spi: i32 = 0;
            while spi < codegen.struct_type_param_count {
                if codegen.struct_type_params[spi].name != null &&
                    strcmp(codegen.struct_type_params[spi].name as *byte, tp_name as *byte) == 0 {
                    if codegen.struct_type_args != null && spi < codegen.struct_type_arg_count {
                        if codegen.struct_type_args[spi] == type_node {
                            return tp_name;
                        }
                        codegen.type_conv_depth = codegen.type_conv_depth + 1;
                        const r2: &byte = c99_type_to_c(codegen, codegen.struct_type_args[spi]);
                        codegen.type_conv_depth = codegen.type_conv_depth - 1;
                        return r2;
                    }
                }
                spi = spi + 1;
            }
        }
    }
    
    // 处理复合类型中的类型参数替换（指针类型）
    if type_node.type == ASTNodeType.AST_TYPE_POINTER && type_node.type_pointer_pointed_type != null {
        const inner: &ASTNode = type_node.type_pointer_pointed_type;
        if inner.type == ASTNodeType.AST_TYPE_NAMED && inner.type_named_name != null {
            const inner_name: &byte = inner.type_named_name;
            var found_in_method: i32 = 0;
            var found_in_struct: i32 = 0;
            var inner_c: &byte = null;
            
            // 第一级：查找方法的类型参数
            if codegen.current_type_params != null && codegen.current_type_param_count > 0 {
                var tpj: i32 = 0;
                while tpj < codegen.current_type_param_count {
                    if codegen.current_type_params[tpj].name != null &&
                        strcmp(codegen.current_type_params[tpj].name as *byte, inner_name as *byte) == 0 {
                        if codegen.current_type_args != null && tpj < codegen.current_type_arg_count {
                            inner_c = c99_type_to_c(codegen, codegen.current_type_args[tpj]);
                            found_in_method = 1;
                            break;
                        }
                    }
                    tpj = tpj + 1;
                }
            }
            
            // 第二级：查找结构体的类型参数
            if found_in_method == 0 && codegen.struct_type_params != null && codegen.struct_type_param_count > 0 {
                var spj: i32 = 0;
                while spj < codegen.struct_type_param_count {
                    if codegen.struct_type_params[spj].name != null &&
                        strcmp(codegen.struct_type_params[spj].name as *byte, inner_name as *byte) == 0 {
                        if codegen.struct_type_args != null && spj < codegen.struct_type_arg_count {
                            inner_c = c99_type_to_c(codegen, codegen.struct_type_args[spj]);
                            found_in_struct = 1;
                            break;
                        }
                    }
                    spj = spj + 1;
                }
            }
            
            if (found_in_method != 0 || found_in_struct != 0) && inner_c != null {
                const len: i32 = strlen(inner_c as *byte) + 4;
                const buf: &byte = arena_alloc(codegen.arena, len) as &byte;
                if buf != null {
                    snprintf(buf as *byte, len, "%s *" as *byte, inner_c as *byte);
                    return buf;
                }
            }
        }
    }
    
    if type_node.type == ASTNodeType.AST_TYPE_NAMED {
        const name: &byte = type_node.type_named_name;
        if name == null {
            return ("void" as *byte) as &byte;
        }
        
        // 检查是否有类型实参（泛型结构体/联合体实例化）
        if type_node.type_named_type_arg_count > 0 && type_node.type_named_type_args != null {
            // 泛型接口实例：Future<i32> 等 -> struct uya_interface_Future_i32
            // 说明：接口与结构体可能同名（如 std.async 的 Future），这里优先接口以匹配 checker/type_from_ast 的行为。
            const iface_decl: &ASTNode = find_interface_decl_c99(codegen, name);
            if iface_decl != null && iface_decl.interface_decl_type_param_count > 0 {
                const mono_name_i: &byte = get_mono_struct_name(codegen, name,
                    type_node.type_named_type_args,
                    type_node.type_named_type_arg_count);
                const mn_len_i: i32 = (strlen(mono_name_i as *byte) as i32) + 24;
                const buf_i: &byte = arena_alloc(codegen.arena, mn_len_i as usize) as &byte;
                if buf_i != null {
                    snprintf(buf_i as *byte, mn_len_i, "struct uya_interface_%s" as *byte, mono_name_i as *byte);
                    return buf_i;
                }
                return ("void" as *byte) as &byte;
            }
            const ud: &ASTNode = find_union_decl_c99(codegen, name);
            if ud != null && is_generic_union_c99(ud) != 0 {
                const mono_name: &byte = get_mono_union_name(codegen, name,
                    type_node.type_named_type_args,
                    type_node.type_named_type_arg_count);
                const mn_len: i32 = (strlen(mono_name as *byte) as i32) + 24;
                const buf: &byte = arena_alloc(codegen.arena, mn_len as usize) as &byte;
                if buf != null {
                    snprintf(buf as *byte, mn_len, "struct uya_tagged_%s" as *byte, mono_name as *byte);
                    return buf;
                }
                return ("void" as *byte) as &byte;
            }
            const mono_name: &byte = get_mono_struct_name(codegen, name,
                type_node.type_named_type_args,
                type_node.type_named_type_arg_count);
            const mn_len: i32 = (strlen(mono_name as *byte) as i32) + 8;  // "struct " + name + '\0'
            const buf: &byte = arena_alloc(codegen.arena, mn_len as usize) as &byte;
            if buf != null {
                snprintf(buf as *byte, mn_len, "struct %s" as *byte, mono_name as *byte);
                return buf;
            }
            return ("void" as *byte) as &byte;
        }
        
        // 基础类型映射
        if strcmp(name as *byte, "i8" as *byte) == 0 {
            return ("int8_t" as *byte) as &byte;
        } else if strcmp(name as *byte, "i16" as *byte) == 0 {
            return ("int16_t" as *byte) as &byte;
        } else if strcmp(name as *byte, "i32" as *byte) == 0 {
            return ("int32_t" as *byte) as &byte;
        } else if strcmp(name as *byte, "i64" as *byte) == 0 {
            return ("int64_t" as *byte) as &byte;
        } else if strcmp(name as *byte, "u8" as *byte) == 0 {
            return ("uint8_t" as *byte) as &byte;
        } else if strcmp(name as *byte, "u16" as *byte) == 0 {
            return ("uint16_t" as *byte) as &byte;
        } else if strcmp(name as *byte, "u32" as *byte) == 0 {
            return ("uint32_t" as *byte) as &byte;
        } else if strcmp(name as *byte, "usize" as *byte) == 0 {
            return ("size_t" as *byte) as &byte;
        } else if strcmp(name as *byte, "isize" as *byte) == 0 {
            return ("intptr_t" as *byte) as &byte;
        } else if strcmp(name as *byte, "u64" as *byte) == 0 {
            return ("uint64_t" as *byte) as &byte;
        } else if strcmp(name as *byte, "bool" as *byte) == 0 {
            return ("bool" as *byte) as &byte;
        } else if strcmp(name as *byte, "byte" as *byte) == 0 {
            return ("uint8_t" as *byte) as &byte;
        } else if strcmp(name as *byte, "f32" as *byte) == 0 {
            return ("float" as *byte) as &byte;
        } else if strcmp(name as *byte, "f64" as *byte) == 0 {
            return ("double" as *byte) as &byte;
        } else if strcmp(name as *byte, "void" as *byte) == 0 {
            return ("void" as *byte) as &byte;
        } else if strcmp(name as *byte, "@asm_reg" as *byte) == 0 {
            // 通用寄存器类型 - 编译器自动分配，使用 register 关键字
            return ("register int64_t" as *byte) as &byte;
        } else if strcmp(name as *byte, "@asm_reg_x64" as *byte) == 0 {
            // x86-64 通用寄存器 - 64位
            return ("register int64_t" as *byte) as &byte;
        } else if strcmp(name as *byte, "@asm_reg_x86" as *byte) == 0 {
            // x86 通用寄存器 - 32位
            return ("register int32_t" as *byte) as &byte;
        } else if strcmp(name as *byte, "@asm_reg_arm64" as *byte) == 0 {
            // ARM64 通用寄存器 - 64位
            return ("register int64_t" as *byte) as &byte;
        } else if strcmp(name as *byte, "@asm_reg_riscv" as *byte) == 0 {
            // RISC-V 通用寄存器 - 64位
            return ("register int64_t" as *byte) as &byte;
        } else if strcmp(name as *byte, "@asm_reg_x64_xmm" as *byte) == 0 {
            // x86-64 SSE 寄存器 - 128位
            return ("__m128" as *byte) as &byte;
        } else if strcmp(name as *byte, "@asm_reg_x64_ymm" as *byte) == 0 {
            // x86-64 AVX/AVX2 寄存器 - 256位
            return ("__m256" as *byte) as &byte;
        } else if strcmp(name as *byte, "@asm_reg_x64_zmm" as *byte) == 0 {
            // x86-64 AVX-512 寄存器 - 512位
            return ("__m512" as *byte) as &byte;
        } else if strcmp(name as *byte, "@asm_reg_arm64_v" as *byte) == 0 {
            // ARM64 NEON 寄存器 - 128位
            return ("int128x1_t" as *byte) as &byte;
        } else if strcmp(name as *byte, "@asm_mem" as *byte) == 0 {
            // 内存操作数类型 - 指针
            return ("void *" as *byte) as &byte;
        } else if strcmp(name as *byte, "va_list" as *byte) == 0 {
            // va_list 类型 - 直接映射到 C 的 va_list
            return ("va_list" as *byte) as &byte;
        } else {
            // 结构体、接口或枚举类型
            const safe_name: &byte = get_safe_c_identifier(codegen, name);

            // 检查是否是接口类型（使用带缓存的 find_interface_decl_c99）
            const iface_decl: &ASTNode = find_interface_decl_c99(codegen, name);
            if iface_decl != null {
                const len: i32 = strlen(safe_name as *byte) + 24;
                const buf: &byte = arena_alloc(codegen.arena, len) as &byte;
                if buf != null {
                    snprintf(buf as *byte, len, "struct uya_interface_%s" as *byte, safe_name as *byte);
                    return buf;
                }
                return ("void" as *byte) as &byte;
            }

            // 检查是否是联合体类型：extern union 用 union Name，普通联合体用 struct uya_tagged_Name
            {
                const ud: &ASTNode = find_union_decl_c99(codegen, name);
                if ud != null {
                    if ud.union_decl_is_extern != 0 {
                        const len_ext: i32 = strlen(safe_name as *byte) + 10;
                        const buf_ext: &byte = arena_alloc(codegen.arena, len_ext) as &byte;
                        if buf_ext != null {
                            snprintf(buf_ext as *byte, len_ext, "union %s" as *byte, safe_name as *byte);
                            return buf_ext;
                        }
                    } else {
                        const len_u: i32 = strlen(safe_name as *byte) + 22;
                        const buf_u: &byte = arena_alloc(codegen.arena, len_u) as &byte;
                        if buf_u != null {
                            snprintf(buf_u as *byte, len_u, "struct uya_tagged_%s" as *byte, safe_name as *byte);
                            return buf_u;
                        }
                    }
                    return ("void" as *byte) as &byte;
                }
            }
            
            // 显式检查是否是结构体（检查是否在表中，不管是否已定义）
            // 优先使用表查找，更可靠
            if is_struct_in_table(codegen, safe_name) != 0 {
                // 使用 arena 分配器来分配字符串，避免 static 缓冲区被覆盖
                // "struct " (7 chars) + name + '\0' = strlen(safe_name) + 8
                const str_len: i32 = strlen(safe_name as *byte) + 8;
                const buf: &byte = arena_alloc(codegen.arena, str_len) as &byte;
                if buf != null {
                    snprintf(buf as *byte, str_len, "struct %s" as *byte, safe_name as *byte);
                    return buf;
                }
                return ("void" as *byte) as &byte; // 内存不足时的回退方案
            }
            
            // 如果表查找失败，尝试从程序节点中查找结构体声明（备用方案）
            if codegen.program_node != null {
                const decl_count: i32 = codegen.program_node.program_decl_count;
                var i: i32 = 0;
                while i < decl_count {
                    const decl: &ASTNode = codegen.program_node.program_decls[i];
                    if decl != null && decl.type == ASTNodeType.AST_STRUCT_DECL {
                        const struct_name: &byte = decl.struct_decl_name;
                        if struct_name != null {
                            const safe_struct_name: &byte = get_safe_c_identifier(codegen, struct_name);
                            // 比较 safe_name 和 safe_struct_name
                            if strcmp(safe_struct_name as *byte, safe_name as *byte) == 0 {
                                // 找到结构体声明，添加 struct 前缀
                                const len2: i32 = strlen(safe_name as *byte) + 8; // "struct " + name + '\0'
                                const buf2: &byte = arena_alloc(codegen.arena, len2) as &byte;
                                if buf2 != null {
                                    snprintf(buf2 as *byte, len2, "struct %s" as *byte, safe_name as *byte);
                                    return buf2;
                                }
                                return ("void" as *byte) as &byte;
                            }
                        }
                    }
                    i = i + 1;
                }
            }
            
            // 检查是否是枚举（检查是否在表中，不管是否已定义）
            if is_enum_in_table(codegen, safe_name) != 0 {
                // 使用 arena 分配器来分配字符串
                // "enum " (5 chars) + name + '\0' = strlen(safe_name) + 6
                const len3: i32 = strlen(safe_name as *byte) + 6;
                const buf3: &byte = arena_alloc(codegen.arena, len3) as &byte;
                if buf3 != null {
                    snprintf(buf3 as *byte, len3, "enum %s" as *byte, safe_name as *byte);
                    return buf3;
                }
                return ("void" as *byte) as &byte;
            }
            
            // 如果不在表中，尝试从程序节点中查找枚举声明（备用方案）
            if codegen.program_node != null {
                const decl_count2: i32 = codegen.program_node.program_decl_count;
                var i2: i32 = 0;
                while i2 < decl_count2 {
                    const decl2: &ASTNode = codegen.program_node.program_decls[i2];
                    if decl2 != null && decl2.type == ASTNodeType.AST_ENUM_DECL {
                        const enum_name: &byte = decl2.enum_decl_name;
                        if enum_name != null {
                            const safe_enum_name: &byte = get_safe_c_identifier(codegen, enum_name);
                            // 比较 safe_name 和 safe_enum_name
                            if strcmp(safe_enum_name as *byte, safe_name as *byte) == 0 {
                                // 找到枚举声明，添加 enum 前缀
                                const len4: i32 = strlen(safe_name as *byte) + 6; // "enum " + name + '\0'
                                const buf4: &byte = arena_alloc(codegen.arena, len4) as &byte;
                                if buf4 != null {
                                    snprintf(buf4 as *byte, len4, "enum %s" as *byte, safe_name as *byte);
                                    return buf4;
                                }
                                return ("void" as *byte) as &byte;
                            }
                        }
                    }
                    i2 = i2 + 1;
                }
            }
            
            // 未知类型，直接返回名称
            return safe_name;
        }
    } else if type_node.type == ASTNodeType.AST_TYPE_POINTER {
        const pointed_type: &ASTNode = type_node.type_pointer_pointed_type;
        const pointee_type_raw: &byte = c99_type_to_c(codegen, pointed_type);
        // 使用 c99_arena_strdup 复制结果，避免缓冲区被覆盖
        const pointee_type: &byte = c99_arena_strdup(codegen.arena, pointee_type_raw);
        if pointee_type == null {
            return ("void*" as *byte) as &byte;
        }
        
        // 检查是否是只读指针（&const T 或 *const T）
        const is_const: i32 = type_node.type_pointer_is_const;
        
        // 分配缓冲区（在 Arena 中）
        var extra_len: i32 = 3;  // " *" + null
        if is_const != 0 {
            extra_len = 15;  // "const " (6) + " *" (2) + null (1) = 9，增加更多安全边距，设为 15
        }
        // 确保缓冲区足够大：pointee_type + "const " (6) + " *" (2) + null (1)
        // 增加额外的安全边距，确保不会截断
        const str_len: i32 = strlen(pointee_type as *byte) + extra_len + 8;  // 额外 8 字节安全边距
        const result: &byte = arena_alloc(codegen.arena, str_len) as &byte;
        if result == null {
            return ("void*" as *byte) as &byte;
        }
        
        // 如果指向数组类型，生成指向数组的指针（T [N] -> T (*)[N]）
        // 正确 C 语法是 base_type (*)[N]，而非 element_type[N] (*)[N]
        const bracket: *byte = strchr(pointee_type as *byte, 91);  // '['
        if bracket != null {
            const base_len: i32 = ptr_diff(bracket, pointee_type as *byte);
            const dims: *byte = bracket;
            const dims_len: i32 = strlen(dims);
            // 重新分配更大的缓冲区
            var total_len: i32 = base_len + dims_len + 8; // " (*)" + null
            if is_const != 0 {
                total_len = base_len + dims_len + 15; // " const (*)" + null
            }
            const arr_ptr: &byte = arena_alloc(codegen.arena, total_len) as &byte;
            if arr_ptr == null {
                if is_const != 0 {
                    snprintf(result as *byte, str_len, "const %s *" as *byte, pointee_type as *byte);
                } else {
                    snprintf(result as *byte, str_len, "%s *" as *byte, pointee_type as *byte);
                }
                return result;
            }
            // 提取 base_type（[ 之前的部分），生成 T (*)[N] 而非 T[N] (*)[N]
            var base_buf: [byte: STRUCT_NAME_BUF_SIZE] = [];
            if base_len >= 0 && base_len < STRUCT_NAME_BUF_SIZE {
                memcpy(&base_buf[0] as *void, pointee_type as *void, base_len);
                base_buf[base_len] = 0;
                if is_const != 0 {
                    snprintf(arr_ptr as *byte, total_len, "const %s (*)%s" as *byte, &base_buf[0] as *byte, dims);
                } else {
                    snprintf(arr_ptr as *byte, total_len, "%s (*)%s" as *byte, &base_buf[0] as *byte, dims);
                }
            } else {
                if is_const != 0 {
                    snprintf(arr_ptr as *byte, total_len, "const %s *" as *byte, pointee_type as *byte);
                } else {
                    snprintf(arr_ptr as *byte, total_len, "%s *" as *byte, pointee_type as *byte);
                }
            }
            return arr_ptr;
        }
        
        // 生成指针类型：*byte 或 *const void 等
        if is_const != 0 {
            snprintf(result as *byte, str_len, "const %s *" as *byte, pointee_type as *byte);
            // 使用 c99_arena_strdup 复制结果，避免缓冲区被覆盖
            const copied: &byte = c99_arena_strdup(codegen.arena, result);
            if copied != null {
                return copied;
            }
        } else {
            // *byte 类型根据 is_const 标志决定是否添加 const
            // 非 const 的 *byte 生成非 const 指针（如 fmt: *byte -> uint8_t *）
            snprintf(result as *byte, str_len, "%s *" as *byte, pointee_type as *byte);
            // 使用 c99_arena_strdup 复制结果，避免缓冲区被覆盖
            const copied: &byte = c99_arena_strdup(codegen.arena, result);
            if copied != null {
                return copied;
            }
        }
        return result;
    } else if type_node.type == ASTNodeType.AST_TYPE_ATOMIC {
        // 原子类型 atomic T -> _Atomic(T)
        const inner_type: &ASTNode = type_node.type_atomic_inner_type;
        if inner_type == null {
            return ("void" as *byte) as &byte;
        }
        const inner_c: &byte = c99_type_to_c(codegen, inner_type);
        const inner_len: i32 = strlen(inner_c as *byte);
        const len: i32 = inner_len + 12;  // "_Atomic()" + inner type + null
        const result: &byte = arena_alloc(codegen.arena, len) as &byte;
        if result == null {
            return ("void" as *byte) as &byte;
        }
        snprintf(result as *byte, len, "_Atomic(%s)" as *byte, inner_c as *byte);
        return result;
    } else if type_node.type == ASTNodeType.AST_TYPE_VECTOR {
        const element_type: &ASTNode = type_node.type_vector_element_type;
        const size_expr: &ASTNode = type_node.type_vector_size_expr;
        if element_type == null || size_expr == null {
            return ("void" as *byte) as &byte;
        }
        var lanes: i32 = eval_const_expr(codegen, size_expr);
        if lanes <= 0 {
            lanes = 1;
        }
        const element_c: &byte = c99_type_to_c(codegen, element_type);
        const suffix: &byte = c99_make_simd_name_suffix(codegen, element_c);
        if suffix == null {
            return ("void" as *byte) as &byte;
        }
        var name_buf: [byte: STRUCT_NAME_BUF_SIZE] = [];
        snprintf(&name_buf[0] as *byte, STRUCT_NAME_BUF_SIZE, "uya_simd_vector_%s_%d" as *byte, suffix as *byte, lanes);
        const name_copy: &byte = c99_arena_strdup(codegen.arena, &name_buf[0]);
        if name_copy == null {
            return ("void" as *byte) as &byte;
        }
        if is_struct_defined(codegen, name_copy) == 0 {
            c99_register_simd_struct(codegen, name_copy, element_type, lanes, 0);
        }
        const len: i32 = strlen(name_copy as *byte) + 9;
        const result: &byte = arena_alloc(codegen.arena, len) as &byte;
        if result == null {
            return ("void" as *byte) as &byte;
        }
        snprintf(result as *byte, len, "struct %s" as *byte, name_copy as *byte);
        return result;
    } else if type_node.type == ASTNodeType.AST_TYPE_MASK {
        const size_expr: &ASTNode = type_node.type_mask_size_expr;
        if size_expr == null {
            return ("void" as *byte) as &byte;
        }
        var lanes: i32 = eval_const_expr(codegen, size_expr);
        if lanes <= 0 {
            lanes = 1;
        }
        var name_buf: [byte: STRUCT_NAME_BUF_SIZE] = [];
        snprintf(&name_buf[0] as *byte, STRUCT_NAME_BUF_SIZE, "uya_simd_mask_%d" as *byte, lanes);
        const name_copy: &byte = c99_arena_strdup(codegen.arena, &name_buf[0]);
        if name_copy == null {
            return ("void" as *byte) as &byte;
        }
        if is_struct_defined(codegen, name_copy) == 0 {
            c99_register_simd_struct(codegen, name_copy, null, lanes, 1);
        }
        const len: i32 = strlen(name_copy as *byte) + 9;
        const result: &byte = arena_alloc(codegen.arena, len) as &byte;
        if result == null {
            return ("void" as *byte) as &byte;
        }
        snprintf(result as *byte, len, "struct %s" as *byte, name_copy as *byte);
        return result;
    } else if type_node.type == ASTNodeType.AST_TYPE_ERROR_UNION {
        // 错误联合类型 !T -> struct { uint32_t error_id; T value; }
        // 注意：只收集类型信息，不立即输出结构体定义（延迟到 emit_pending_err_union_structs）
        const payload_node: &ASTNode = type_node.type_error_union_payload_type;
        if payload_node == null {
            return ("void" as *byte) as &byte;
        }
        // 使用 c99_mono_type_to_c 来处理单态化上下文中的类型参数
        const payload_c: &byte = c99_mono_type_to_c(codegen, payload_node);
        var is_void: i32 = 0;
        if payload_node.type == ASTNodeType.AST_TYPE_NAMED && payload_node.type_named_name != null && strcmp(payload_node.type_named_name as *byte, "void" as *byte) == 0 {
            is_void = 1;
        }
        var struct_name_buf: [byte: STRUCT_NAME_BUF_SIZE] = [];
        if is_void != 0 {
            snprintf(&struct_name_buf[0] as *byte, STRUCT_NAME_BUF_SIZE, "err_union_void" as *byte);
        } else {
            // 从 payload_c 生成名称；需避免 !(!T) 等递归导致的 "err_union_structerr_union_..."
            // 若 payload_c 为 "struct err_union_X"，递归剥离直到得到基础类型（如 int32_t）
            var p: &byte = payload_c;
            if strncmp(payload_c as *byte, "struct " as *byte, 7) == 0 {
                p = &payload_c[7];
            }
            while strncmp(p as *byte, "err_union_" as *byte, 10) == 0 {
                p = &p[10];
            }
            // 若剥离后为空或为 "err"/"err_" 等 fragment（递归命名残留），回退为 int32_t
            if p[0] == 0 || (strncmp(p as *byte, "err" as *byte, 3) == 0 && (p[3] == 0 || p[3] == 95 as byte)) {
                p = "int32_t" as &byte;
            }
            var safe: [byte: SHORT_NAME_BUF_SIZE] = [];
            var j: i32 = 0;
            while p[0] != 0 && j < SHORT_NAME_BUF_SIZE - 1 {
                const c: i32 = p[0] as i32;
                // 保留字母、数字、下划线和星号（用于指针类型）
                if (c >= 97 && c <= 122) || (c >= 65 && c <= 90) || (c >= 48 && c <= 57) || c == 95 {
                    safe[j] = p[0];
                    j = j + 1;
                } else if c == 42 {
                    // * 替换为 ptr
                    if j < SHORT_NAME_BUF_SIZE - 4 {
                        safe[j] = 112;  // 'p'
                        safe[j + 1] = 116;  // 't'
                        safe[j + 2] = 114;  // 'r'
                        j = j + 3;
                    }
                }
                p = p + 1;
            }
            if j >= 0 && j < SHORT_NAME_BUF_SIZE {
                safe[j] = 0;
            }
            if j > 0 {
                snprintf(&struct_name_buf[0] as *byte, STRUCT_NAME_BUF_SIZE, "err_union_%s" as *byte, &safe[0] as *byte);
            } else {
                snprintf(&struct_name_buf[0] as *byte, STRUCT_NAME_BUF_SIZE, "err_union_T" as *byte);
            }
        }
        const name_copy: &byte = c99_arena_strdup(codegen.arena, &struct_name_buf[0]);
        if name_copy == null {
            return ("void" as *byte) as &byte;
        }
        if is_struct_defined(codegen, name_copy) == 0 {
            // 添加到结构体定义表（标记为已注册，但不输出定义）
            add_struct_definition(codegen, name_copy);
            // 添加到待输出列表
            if codegen.err_union_struct_count < C99_MAX_ERR_UNION_STRUCTS {
                codegen.err_union_struct_names[codegen.err_union_struct_count] = name_copy;
                codegen.err_union_payload_types[codegen.err_union_struct_count] = payload_node;
                codegen.err_union_struct_count = codegen.err_union_struct_count + 1;
            }
        }
        const len: i32 = strlen(name_copy as *byte) + 9;
        const result: &byte = arena_alloc(codegen.arena, len) as &byte;
        if result == null {
            return ("void" as *byte) as &byte;
        }
        snprintf(result as *byte, len, "struct %s" as *byte, name_copy as *byte);
        return result;
    } else if type_node.type == ASTNodeType.AST_TYPE_ARRAY {
        const element_type: &ASTNode = type_node.type_array_element_type;
        const size_expr: &ASTNode = type_node.type_array_size_expr;
        
        // 评估数组大小（编译时常量）
        var array_size: i32 = -1;
        if size_expr != null {
            array_size = eval_const_expr(codegen, size_expr);
            if array_size <= 0 {
                // 如果评估失败或大小无效，使用占位符大小
                array_size = 1;  // 占位符
            }
        } else {
            // 无大小表达式（如 [T]），在 C99 中需要指定大小
            // 暂时使用占位符
            array_size = 1;
        }
        
        // 对于嵌套数组，需要正确处理维度顺序
        // 例如：[[i32: 2]: 3] 应该生成 int32_t[3][2]，而不是 int32_t[2][3]
        
        // 如果元素类型也是数组，先获取其基础类型和累积维度
        if element_type.type == ASTNodeType.AST_TYPE_ARRAY {
            // 递归获取内部数组的维度和基础类型
            var base_type: &byte = null;
            var dims: [i32: 10] = [];
            var dim_count: i32 = 0;
            
            var current_type: &ASTNode = type_node;
            while current_type != null && current_type.type == ASTNodeType.AST_TYPE_ARRAY && dim_count < 10 {
                const curr_size_expr: &ASTNode = current_type.type_array_size_expr;
                var curr_size: i32 = 1;
                if curr_size_expr != null {
                    curr_size = eval_const_expr(codegen, curr_size_expr);
                    if curr_size <= 0 {
                        curr_size = 1;
                    }
                }
                dims[dim_count] = curr_size;
                dim_count = dim_count + 1;
                current_type = current_type.type_array_element_type;
            }
            
            // 现在 current_type 是基础类型（不是数组）
            base_type = c99_type_to_c(codegen, current_type);
            
            // 构建结果类型：base_type[dims[0]][dims[1]]...
            // 维度按顺序输出：外层维度在前，内层维度在后
            // 例如：[[i32: 2]: 3] -> dims = [3, 2] -> int32_t[3][2]
            const total_len: i32 = strlen(base_type as *byte) + dim_count * 16 + 1;  // 足够空间
            const result: &byte = arena_alloc(codegen.arena, total_len) as &byte;
            if result == null {
                return ("void" as *byte) as &byte;
            }
            
            strcpy(result as *byte, base_type as *byte);
            var i: i32 = 0;
            while i < dim_count {
                var dim_str: [byte: NUM_BUF_SIZE] = [];
                snprintf(&dim_str[0] as *byte, 16, "[%d]" as *byte, dims[i]);
                strcat(result as *byte, &dim_str[0] as *byte);
                i = i + 1;
            }
            
            return result;
        } else {
            // 单层数组，直接生成
            const element_c: &byte = c99_type_to_c(codegen, element_type);
            
            // 分配缓冲区
            const buf_len: i32 = strlen(element_c as *byte) + 32;  // 元素类型 + "[%d]" + null
            const result: &byte = arena_alloc(codegen.arena, buf_len) as &byte;
            if result == null {
                return ("void" as *byte) as &byte;
            }
            
            snprintf(result as *byte, buf_len, "%s[%d]" as *byte, element_c as *byte, array_size);
            return result;
        }
    } else if type_node.type == ASTNodeType.AST_TYPE_SLICE {
        const element_type: &ASTNode = type_node.type_slice_element_type;
        if element_type == null {
            return ("void" as *byte) as &byte;
        }
        const elem_c: &byte = c99_type_to_c(codegen, element_type);
        if elem_c == null {
            return ("void" as *byte) as &byte;
        }
        var elem_simple: &byte = elem_c;
        if strncmp(elem_c as *byte, "struct " as *byte, 7) == 0 {
            elem_simple = &elem_c[7];
        } else if strncmp(elem_c as *byte, "enum " as *byte, 5) == 0 {
            elem_simple = &elem_c[5];
        }
        // 去除指针类型中的 "*" 和前面的空格（用于生成结构体名称）
        // 例如 "uint8_t *" -> "uint8_t"
        var elem_len: usize = strlen(elem_simple as *byte);
        var elem_clean: &byte = elem_simple;
        if elem_len > 0 {
            const elem_ptr: *byte = elem_simple as *byte;
            const last_char: *byte = elem_ptr + (elem_len - 1);
            if last_char[0] == 42 {  // '*'
                // 先去除 const 前缀（如 "const uint8_t *"）
                var working_str: &byte = elem_simple;
                if strncmp(elem_simple as *byte, "const " as *byte, 6) == 0 {
                    working_str = &elem_simple[6];
                }
                
                // 找到最后一个 '*'，向前查找并去除空格
                var end: usize = strlen(working_str as *byte) - 1;
                while end > 0 {
                    const prev_char: *byte = working_str + (end - 1);
                    if prev_char[0] != 32 {  // ' '
                        break;
                    }
                    end = end - 1;
                }
                // 创建临时缓冲区存储去除 "*" 后的名称
                var temp_buf: [byte: STRUCT_NAME_BUF_SIZE] = [];
                if end < STRUCT_NAME_BUF_SIZE {
                    var j: usize = 0;
                    while j < end {
                        const char_ptr: *byte = working_str + j;
                        temp_buf[j] = char_ptr[0];
                        j = j + 1;
                    }
                    temp_buf[j] = 0;  // '\0'
                    elem_clean = c99_arena_strdup(codegen.arena, &temp_buf[0]);
                    if elem_clean == null {
                        return ("void" as *byte) as &byte;
                    }
                }
            }
        }
        var name_buf: [byte: STRUCT_NAME_BUF_SIZE] = [];
        snprintf(&name_buf[0] as *byte, STRUCT_NAME_BUF_SIZE, "uya_slice_%s" as *byte, elem_clean as *byte);
        const safe: &byte = c99_arena_strdup(codegen.arena, &name_buf[0]);
        if safe == null {
            return ("void" as *byte) as &byte;
        }
        if is_struct_defined(codegen, safe) != 0 {
            const len: i32 = strlen(safe as *byte) + 9;
            const result: &byte = arena_alloc(codegen.arena, len) as &byte;
            if result == null {
                return ("void" as *byte) as &byte;
            }
            snprintf(result as *byte, len, "struct %s" as *byte, safe as *byte);
            return result;
        }
        var found: i32 = 0;
        var ii: i32 = 0;
        while ii < codegen.slice_struct_count {
            if codegen.slice_struct_names[ii] != null && strcmp(codegen.slice_struct_names[ii] as *byte, safe as *byte) == 0 {
                found = 1;
                break;
            }
            ii = ii + 1;
        }
        if found == 0 && codegen.slice_struct_count < C99_MAX_SLICE_STRUCTS {
            codegen.slice_struct_names[codegen.slice_struct_count] = safe;
            codegen.slice_struct_element_types[codegen.slice_struct_count] = element_type;
            codegen.slice_struct_count = codegen.slice_struct_count + 1;
            add_struct_definition(codegen, safe);
        }
        const len2: i32 = strlen(safe as *byte) + 9;
        const result2: &byte = arena_alloc(codegen.arena, len2) as &byte;
        if result2 == null {
            return ("void" as *byte) as &byte;
        }
        snprintf(result2 as *byte, len2, "struct %s" as *byte, safe as *byte);
        return result2;
    } else if type_node.type == ASTNodeType.AST_TYPE_TUPLE {
        // 元组类型 (T1, T2, ...) -> struct { T0 f0; T1 f1; ... }
        const n: i32 = type_node.type_tuple_element_count;
        const element_types: & & ASTNode = type_node.type_tuple_element_types;
        if n <= 0 || element_types == null {
            return ("void" as *byte) as &byte;
        }
        var total_len: i32 = 64;
        var i: i32 = 0;
        while i < n {
            const et: &byte = c99_type_to_c(codegen, element_types[i]);
            total_len = total_len + strlen(et as *byte) + 24;
            i = i + 1;
        }
        const result: &byte = arena_alloc(codegen.arena, total_len) as &byte;
        if result == null {
            return ("void" as *byte) as &byte;
        }
        var off: i32 = 0;
        off = off + snprintf(result as *byte + off, total_len - off, "struct { " as *byte);
        i = 0;
        while i < n {
            const et: &byte = c99_type_to_c(codegen, element_types[i]);
            var et_str: &byte = ("void" as *byte) as &byte;
            if et != null {
                et_str = et;
            }
            off = off + snprintf(result as *byte + off, total_len - off, "%s f%d; " as *byte, et_str as *byte, i);
            i = i + 1;
        }
        snprintf(result as *byte + off, total_len - off, "}" as *byte);
        return result;
    } else {
        return ("void" as *byte) as &byte;
    }
}

// 输出所有待生成的切片结构体
fn emit_pending_slice_structs(codegen: &C99CodeGenerator) void {
    if codegen == null {
        return;
    }
    var i: i32 = 0;
    while i < codegen.slice_struct_count {
        const name: &byte = codegen.slice_struct_names[i];
        const elem: &ASTNode = codegen.slice_struct_element_types[i];
        if name == null || elem == null {
            i = i + 1;
            continue;
        }
        if is_struct_defined(codegen, name) != 0 {
            i = i + 1;
            continue;
        }
        const elem_c: &byte = c99_type_to_c(codegen, elem);
        if elem_c == null {
            i = i + 1;
            continue;
        }
        fprintf(codegen.output as *void, "struct %s { %s *ptr; size_t len; };\n" as *byte, name as *byte, elem_c as *byte);
        mark_struct_defined(codegen, name);
        i = i + 1;
    }
}

// err_union 的载荷为 @vector/@mask，或类型别名最终指向它们时，应输出完整 err_union（否则仅前向声明会导致 C 编译失败）
fn c99_err_union_payload_is_emittable(codegen: &C99CodeGenerator, payload_node: &ASTNode) i32 {
    if codegen == null || payload_node == null {
        return 0;
    }
    var cur: &ASTNode = payload_node;
    var depth: i32 = 0;
    while depth < 32 {
        if cur.type == ASTNodeType.AST_TYPE_VECTOR || cur.type == ASTNodeType.AST_TYPE_MASK {
            return 1;
        }
        if cur.type == ASTNodeType.AST_TYPE_NAMED && cur.type_named_name != null &&
            cur.type_named_type_arg_count == 0 && codegen.program_node != null {
            const al: &ASTNode = find_type_alias_from_program(codegen.program_node, cur.type_named_name);
            if al != null && al.type_alias_target_type != null {
                cur = al.type_alias_target_type;
                depth = depth + 1;
                continue;
            }
        }
        break;
    }
    return 0;
}

// 输出所有待生成的错误联合结构体
fn emit_pending_err_union_structs(codegen: &C99CodeGenerator) void {
    if codegen == null {
        return;
    }
    var i: i32 = 0;
    while i < codegen.err_union_struct_count {
        const name: &byte = codegen.err_union_struct_names[i];
        const payload_node: &ASTNode = codegen.err_union_payload_types[i];
        if name == null || payload_node == null {
            i = i + 1;
            continue;
        }
        // 若 payload 为联合体或结构体，先输出其定义，避免 err_union 中引用不完整类型（如 !JsonValue）
        ensure_union_emitted_for_type_node(codegen, payload_node);
        ensure_struct_emitted_for_type_node(codegen, payload_node);
        // 检查是否已定义（可能已被其他路径输出）
        if is_struct_defined(codegen, name) != 0 {
            i = i + 1;
            continue;
        }
        // 检查是否是 void payload
        var is_void: i32 = 0;
        if payload_node.type == ASTNodeType.AST_TYPE_NAMED && payload_node.type_named_name != null && strcmp(payload_node.type_named_name as *byte, "void" as *byte) == 0 {
            is_void = 1;
        }
        const payload_c: &byte = c99_type_to_c(codegen, payload_node);
        if payload_c == null {
            i = i + 1;
            continue;
        }
        // 跳过泛型类型参数（未知类型名称），它们会在单态化时被正确处理
        // 检查 payload_c 是否以已知前缀开头，如果不是则跳过
        if is_void == 0 {
            var is_known_type: i32 = 0;
            if payload_node.type == ASTNodeType.AST_TYPE_ARRAY {
                is_known_type = 1;
            } else if c99_err_union_payload_is_emittable(codegen, payload_node) != 0 {
                is_known_type = 1;
            } else if payload_node.type == ASTNodeType.AST_TYPE_NAMED && payload_node.type_named_name != null &&
                strcmp(payload_node.type_named_name as *byte, "bool" as *byte) == 0 {
                // !bool：c99_type_to_c 在部分上下文中可能非 "bool" 前缀，必须按 AST 放行，否则不输出 struct err_union_bool 导致链接失败
                is_known_type = 1;
            } else {
                if strncmp(payload_c as *byte, "int" as *byte, 3) == 0 ||
                   strncmp(payload_c as *byte, "uint" as *byte, 4) == 0 ||
                   strncmp(payload_c as *byte, "float" as *byte, 5) == 0 ||
                   strncmp(payload_c as *byte, "double" as *byte, 6) == 0 ||
                   strncmp(payload_c as *byte, "char" as *byte, 4) == 0 ||
                   strncmp(payload_c as *byte, "void" as *byte, 4) == 0 ||
                   strncmp(payload_c as *byte, "bool" as *byte, 4) == 0 ||
                   strncmp(payload_c as *byte, "_Bool" as *byte, 5) == 0 ||
                   strncmp(payload_c as *byte, "struct" as *byte, 6) == 0 ||
                   strncmp(payload_c as *byte, "enum" as *byte, 4) == 0 ||
                   strncmp(payload_c as *byte, "intptr_t" as *byte, 8) == 0 ||
                   strncmp(payload_c as *byte, "uintptr_t" as *byte, 9) == 0 ||
                   strncmp(payload_c as *byte, "size_t" as *byte, 6) == 0 ||
                   strncmp(payload_c as *byte, "ssize_t" as *byte, 7) == 0 {
                    is_known_type = 1;
                }
            }
            if is_known_type == 0 {
                i = i + 1;
                continue;
            }
        }
        fprintf(codegen.output as *void, "struct %s { uint32_t error_id;" as *byte, name as *byte);
        if is_void == 0 {
            if payload_node.type == ASTNodeType.AST_TYPE_ARRAY && payload_node.type_array_element_type != null && payload_node.type_array_size_expr != null {
                const elem_c: &byte = c99_type_to_c(codegen, payload_node.type_array_element_type);
                const arr_size: i32 = eval_const_expr(codegen, payload_node.type_array_size_expr);
                if elem_c != null && arr_size > 0 {
                    fprintf(codegen.output as *void, " %s value[%d];" as *byte, elem_c as *byte, arr_size);
                } else {
                    fprintf(codegen.output as *void, " %s value;" as *byte, payload_c as *byte);
                }
            } else {
                fprintf(codegen.output as *void, " %s value;" as *byte, payload_c as *byte);
            }
        }
        fputs(" };\n" as *byte, codegen.output as *void);
        mark_struct_defined(codegen, name);
        i = i + 1;
    }
}

fn emit_pending_simd_structs(codegen: &C99CodeGenerator) void {
    if codegen == null {
        return;
    }

    var i: i32 = 0;
    while i < codegen.simd_struct_count {
        const name: &byte = codegen.simd_struct_names[i];
        const element_type: &ASTNode = codegen.simd_struct_element_types[i];
        const lanes: i32 = codegen.simd_struct_lane_counts[i];
        const is_mask: i32 = codegen.simd_struct_is_mask[i];
        if name == null || lanes <= 0 {
            i = i + 1;
            continue;
        }
        if is_struct_defined(codegen, name) != 0 {
            i = i + 1;
            continue;
        }

        if is_mask != 0 {
            fprintf(codegen.output as *void, "struct %s { bool lanes[%d]; };\n" as *byte, name as *byte, lanes);
            mark_struct_defined(codegen, name);
            i = i + 1;
            continue;
        }

        if element_type == null {
            i = i + 1;
            continue;
        }

        const element_c: &byte = c99_type_to_c(codegen, element_type);
        if element_c == null {
            i = i + 1;
            continue;
        }

        fprintf(codegen.output as *void, "struct %s { %s lanes[%d]; };\n" as *byte, name as *byte, element_c as *byte, lanes);
        mark_struct_defined(codegen, name);
        i = i + 1;
    }
}

// x86_64 SSE2 / ARM NEON：@vector 4 宽 i32/u32/f32 快路径（与 expr.uya 中 uya_simd_sse_* 调用配对；函数名历史保留）
// i8 / u8 / i64 / u64 向量族：按需输出（三档 C 预分支各一份）
fn c99_simd_need_emit_i8_u8_i64_u64(codegen: &C99CodeGenerator, simd_emit_all: i32) i32 {
    if codegen == null {
        return 0;
    }
    if simd_emit_all != 0 {
        return 1;
    }
    if codegen.simd_max_lanes_i8 > 0 || codegen.simd_max_lanes_u8 > 0 {
        return 1;
    }
    if codegen.simd_max_lanes_i64 > 0 || codegen.simd_max_lanes_u64 > 0 {
        return 1;
    }
    return 0;
}

fn c99_simd_need_emit_f64(codegen: &C99CodeGenerator, simd_emit_all: i32) i32 {
    if codegen == null {
        return 0;
    }
    if simd_emit_all != 0 {
        return 1;
    }
    if codegen.simd_max_lanes_f64 > 0 {
        return 1;
    }
    return 0;
}

fn c99_simd_need_emit_i16_u16(codegen: &C99CodeGenerator, simd_emit_all: i32) i32 {
    if codegen == null {
        return 0;
    }
    if simd_emit_all != 0 {
        return 1;
    }
    if codegen.simd_max_lanes_i16 > 0 || codegen.simd_max_lanes_u16 > 0 {
        return 1;
    }
    return 0;
}

fn c99_simd_need_emit_i32_u32_f32(codegen: &C99CodeGenerator, simd_emit_all: i32) i32 {
    if codegen == null {
        return 0;
    }
    if simd_emit_all != 0 {
        return 1;
    }
    if codegen.simd_max_lanes_i32 > 0 || codegen.simd_max_lanes_u32 > 0 || codegen.simd_max_lanes_f32 > 0 {
        return 1;
    }
    // 仅 @vector.select / @vector.reduce_add 等也会置 simd_emit_* 标志，未必抬高 max_lanes
    if codegen.simd_emit_select_i32x2 != 0 || codegen.simd_emit_select_u32x2 != 0 || codegen.simd_emit_select_f32x2 != 0 {
        return 1;
    }
    if codegen.simd_emit_select_i32x4 != 0 || codegen.simd_emit_select_u32x4 != 0 || codegen.simd_emit_select_f32x4 != 0 {
        return 1;
    }
    if codegen.simd_emit_reduce_add_i32x2 != 0 || codegen.simd_emit_reduce_add_u32x2 != 0 || codegen.simd_emit_reduce_add_f32x2 != 0 {
        return 1;
    }
    if codegen.simd_emit_reduce_add_i32x4 != 0 || codegen.simd_emit_reduce_add_u32x4 != 0 || codegen.simd_emit_reduce_add_f32x4 != 0 {
        return 1;
    }
    if codegen.simd_emit_reduce_mul_i32x2 != 0 || codegen.simd_emit_reduce_mul_u32x2 != 0 || codegen.simd_emit_reduce_mul_f32x2 != 0 {
        return 1;
    }
    if codegen.simd_emit_reduce_mul_i32x4 != 0 || codegen.simd_emit_reduce_mul_u32x4 != 0 || codegen.simd_emit_reduce_mul_f32x4 != 0 {
        return 1;
    }
    if codegen.simd_emit_reduce_min_i32x2 != 0 || codegen.simd_emit_reduce_min_u32x2 != 0 || codegen.simd_emit_reduce_min_f32x2 != 0 {
        return 1;
    }
    if codegen.simd_emit_reduce_min_i32x4 != 0 || codegen.simd_emit_reduce_min_u32x4 != 0 || codegen.simd_emit_reduce_min_f32x4 != 0 {
        return 1;
    }
    if codegen.simd_emit_reduce_max_i32x2 != 0 || codegen.simd_emit_reduce_max_u32x2 != 0 || codegen.simd_emit_reduce_max_f32x2 != 0 {
        return 1;
    }
    if codegen.simd_emit_reduce_max_i32x4 != 0 || codegen.simd_emit_reduce_max_u32x4 != 0 || codegen.simd_emit_reduce_max_f32x4 != 0 {
        return 1;
    }
    return 0;
}
// 是否需在 i32/u32/f32 SIMD 段末尾追加 select 助手（与 c99_gen_simd_builtin_call 中快路径配套）
fn c99_simd_any_select_helpers_needed(codegen: &C99CodeGenerator) i32 {
    if codegen == null {
        return 0;
    }
    if codegen.simd_emit_select_i32x2 != 0 || codegen.simd_emit_select_u32x2 != 0 || codegen.simd_emit_select_f32x2 != 0 {
        return 1;
    }
    if codegen.simd_emit_select_i32x4 != 0 || codegen.simd_emit_select_u32x4 != 0 || codegen.simd_emit_select_f32x4 != 0 {
        return 1;
    }
    return 0;
}

// 是否需在 i32/u32/f32 SIMD 段追加 @vector.reduce_add 助手
fn c99_simd_any_reduce_add_helpers_needed(codegen: &C99CodeGenerator) i32 {
    if codegen == null {
        return 0;
    }
    if codegen.simd_emit_reduce_add_i32x2 != 0 || codegen.simd_emit_reduce_add_u32x2 != 0 || codegen.simd_emit_reduce_add_f32x2 != 0 {
        return 1;
    }
    if codegen.simd_emit_reduce_add_i32x4 != 0 || codegen.simd_emit_reduce_add_u32x4 != 0 || codegen.simd_emit_reduce_add_f32x4 != 0 {
        return 1;
    }
    return 0;
}

fn emit_simd_runtime_helpers_i8_u8_i64_u64_x86_sse(codegen: &C99CodeGenerator) void {
    if codegen == null || codegen.output == null {
        return;
    }
    fputs("static inline void uya_simd_sse_i8x16_pred_store_mask(void *m, __m128i pr) {\n" as *byte, codegen.output as *void);
    fputs("  union { __m128i v; int8_t c[16]; } u; u.v = pr;\n" as *byte, codegen.output as *void);
    fputs("  bool *M = (bool *)m; int _k; for (_k = 0; _k < 16; _k++) M[_k] = (u.c[_k] != 0);\n" as *byte, codegen.output as *void);
    fputs("}\n" as *byte, codegen.output as *void);
    fputs("static inline void uya_simd_sse_add_i8x16(void *r, const void *a, const void *b) {\n" as *byte, codegen.output as *void);
    fputs("  __m128i va = _mm_loadu_si128((const __m128i *)(const void *)a);\n" as *byte, codegen.output as *void);
    fputs("  __m128i vb = _mm_loadu_si128((const __m128i *)(const void *)b);\n" as *byte, codegen.output as *void);
    fputs("  _mm_storeu_si128((__m128i *)(void *)r, _mm_add_epi8(va, vb));\n" as *byte, codegen.output as *void);
    fputs("}\n" as *byte, codegen.output as *void);
    fputs("static inline void uya_simd_sse_add_i8x8(void *r, const void *a, const void *b) {\n" as *byte, codegen.output as *void);
    fputs("  unsigned char ta[16] = {0}, tb[16] = {0}, tr[16] = {0};\n" as *byte, codegen.output as *void);
    fputs("  { int _z; unsigned char *_d = ta; const unsigned char *_s = (const unsigned char *)(a); for (_z = 0; _z < 8; _z++) _d[_z] = _s[_z]; }\n" as *byte, codegen.output as *void);
    fputs("  { int _z; unsigned char *_d = tb; const unsigned char *_s = (const unsigned char *)(b); for (_z = 0; _z < 8; _z++) _d[_z] = _s[_z]; }\n" as *byte, codegen.output as *void);
    fputs("  __m128i va = _mm_loadu_si128((const __m128i *)(void *)ta);\n" as *byte, codegen.output as *void);
