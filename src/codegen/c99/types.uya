    fputs("  int _i; for (_i = 0; _i < 4; _i++) rr[_i] = -aa[_i];\n}\n" as *byte, codegen.output as *void);
    fputs("static inline void uya_simd_sse_eq_i32x4_mask(void *m, const void *a, const void *b) {\n" as *byte, codegen.output as *void);
    fputs("  bool *M = (bool *)m; const int32_t *aa = (const int32_t *)a; const int32_t *bb = (const int32_t *)b;\n" as *byte, codegen.output as *void);
    fputs("  int _i; for (_i = 0; _i < 4; _i++) M[_i] = (aa[_i] == bb[_i]);\n}\n" as *byte, codegen.output as *void);
    fputs("static inline void uya_simd_sse_ne_i32x4_mask(void *m, const void *a, const void *b) {\n" as *byte, codegen.output as *void);
    fputs("  bool *M = (bool *)m; const int32_t *aa = (const int32_t *)a; const int32_t *bb = (const int32_t *)b;\n" as *byte, codegen.output as *void);
    fputs("  int _i; for (_i = 0; _i < 4; _i++) M[_i] = (aa[_i] != bb[_i]);\n}\n" as *byte, codegen.output as *void);
    fputs("static inline void uya_simd_sse_lt_i32x4_mask(void *m, const void *a, const void *b) {\n" as *byte, codegen.output as *void);
    fputs("  bool *M = (bool *)m; const int32_t *aa = (const int32_t *)a; const int32_t *bb = (const int32_t *)b;\n" as *byte, codegen.output as *void);
