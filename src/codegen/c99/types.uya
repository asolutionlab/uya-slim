    fputs("static inline void uya_simd_sse_or_i32x2(void *r, const void *a, const void *b) {\n" as *byte, codegen.output as *void);
    fputs("  int32_t *rr = (int32_t *)r; const int32_t *aa = (const int32_t *)a; const int32_t *bb = (const int32_t *)b;\n" as *byte, codegen.output as *void);
    fputs("  int _i; for (_i = 0; _i < 2; _i++) rr[_i] = aa[_i] | bb[_i];\n}\n" as *byte, codegen.output as *void);
    fputs("static inline void uya_simd_sse_xor_i32x2(void *r, const void *a, const void *b) {\n" as *byte, codegen.output as *void);
    fputs("  int32_t *rr = (int32_t *)r; const int32_t *aa = (const int32_t *)a; const int32_t *bb = (const int32_t *)b;\n" as *byte, codegen.output as *void);
    fputs("  int _i; for (_i = 0; _i < 2; _i++) rr[_i] = aa[_i] ^ bb[_i];\n}\n" as *byte, codegen.output as *void);
    fputs("static inline void uya_simd_sse_splat_i32x2(void *r, int32_t s) {\n" as *byte, codegen.output as *void);
    fputs("  int32_t *rr = (int32_t *)r; int _i; for (_i = 0; _i < 2; _i++) rr[_i] = s;\n}\n" as *byte, codegen.output as *void);
    fputs("static inline void uya_simd_sse_neg_i32x2(void *r, const void *a) {\n" as *byte, codegen.output as *void);
    fputs("  int32_t *rr = (int32_t *)r; const int32_t *aa = (const int32_t *)a;\n" as *byte, codegen.output as *void);
    fputs("  int _i; for (_i = 0; _i < 2; _i++) rr[_i] = -aa[_i];\n}\n" as *byte, codegen.output as *void);
    fputs("static inline void uya_simd_sse_eq_i32x2_mask(void *m, const void *a, const void *b) {\n" as *byte, codegen.output as *void);
    fputs("  bool *M = (bool *)m; const int32_t *aa = (const int32_t *)a; const int32_t *bb = (const int32_t *)b;\n" as *byte, codegen.output as *void);
    fputs("  int _i; for (_i = 0; _i < 2; _i++) M[_i] = (aa[_i] == bb[_i]);\n}\n" as *byte, codegen.output as *void);
    fputs("static inline void uya_simd_sse_ne_i32x2_mask(void *m, const void *a, const void *b) {\n" as *byte, codegen.output as *void);
    fputs("  bool *M = (bool *)m; const int32_t *aa = (const int32_t *)a; const int32_t *bb = (const int32_t *)b;\n" as *byte, codegen.output as *void);
    fputs("  int _i; for (_i = 0; _i < 2; _i++) M[_i] = (aa[_i] != bb[_i]);\n}\n" as *byte, codegen.output as *void);
    fputs("static inline void uya_simd_sse_lt_i32x2_mask(void *m, const void *a, const void *b) {\n" as *byte, codegen.output as *void);
    fputs("  bool *M = (bool *)m; const int32_t *aa = (const int32_t *)a; const int32_t *bb = (const int32_t *)b;\n" as *byte, codegen.output as *void);
    fputs("  int _i; for (_i = 0; _i < 2; _i++) M[_i] = (aa[_i] < bb[_i]);\n}\n" as *byte, codegen.output as *void);
    fputs("static inline void uya_simd_sse_gt_i32x2_mask(void *m, const void *a, const void *b) {\n" as *byte, codegen.output as *void);
    fputs("  bool *M = (bool *)m; const int32_t *aa = (const int32_t *)a; const int32_t *bb = (const int32_t *)b;\n" as *byte, codegen.output as *void);
    fputs("  int _i; for (_i = 0; _i < 2; _i++) M[_i] = (aa[_i] > bb[_i]);\n}\n" as *byte, codegen.output as *void);
    fputs("static inline void uya_simd_sse_le_i32x2_mask(void *m, const void *a, const void *b) {\n" as *byte, codegen.output as *void);
    fputs("  bool *M = (bool *)m; const int32_t *aa = (const int32_t *)a; const int32_t *bb = (const int32_t *)b;\n" as *byte, codegen.output as *void);
    fputs("  int _i; for (_i = 0; _i < 2; _i++) M[_i] = (aa[_i] <= bb[_i]);\n}\n" as *byte, codegen.output as *void);
    fputs("static inline void uya_simd_sse_ge_i32x2_mask(void *m, const void *a, const void *b) {\n" as *byte, codegen.output as *void);
    fputs("  bool *M = (bool *)m; const int32_t *aa = (const int32_t *)a; const int32_t *bb = (const int32_t *)b;\n" as *byte, codegen.output as *void);
    fputs("  int _i; for (_i = 0; _i < 2; _i++) M[_i] = (aa[_i] >= bb[_i]);\n}\n" as *byte, codegen.output as *void);
    fputs("static inline void uya_simd_sse_lt_u32x2_mask(void *m, const void *a, const void *b) {\n" as *byte, codegen.output as *void);
    fputs("  bool *M = (bool *)m; const uint32_t *aa = (const uint32_t *)a; const uint32_t *bb = (const uint32_t *)b;\n" as *byte, codegen.output as *void);
    fputs("  int _i; for (_i = 0; _i < 2; _i++) M[_i] = (aa[_i] < bb[_i]);\n}\n" as *byte, codegen.output as *void);
    fputs("static inline void uya_simd_sse_gt_u32x2_mask(void *m, const void *a, const void *b) {\n" as *byte, codegen.output as *void);
    fputs("  bool *M = (bool *)m; const uint32_t *aa = (const uint32_t *)a; const uint32_t *bb = (const uint32_t *)b;\n" as *byte, codegen.output as *void);
    fputs("  int _i; for (_i = 0; _i < 2; _i++) M[_i] = (aa[_i] > bb[_i]);\n}\n" as *byte, codegen.output as *void);
    fputs("static inline void uya_simd_sse_le_u32x2_mask(void *m, const void *a, const void *b) {\n" as *byte, codegen.output as *void);
    fputs("  bool *M = (bool *)m; const uint32_t *aa = (const uint32_t *)a; const uint32_t *bb = (const uint32_t *)b;\n" as *byte, codegen.output as *void);
    fputs("  int _i; for (_i = 0; _i < 2; _i++) M[_i] = (aa[_i] <= bb[_i]);\n}\n" as *byte, codegen.output as *void);
    fputs("static inline void uya_simd_sse_ge_u32x2_mask(void *m, const void *a, const void *b) {\n" as *byte, codegen.output as *void);
    fputs("  bool *M = (bool *)m; const uint32_t *aa = (const uint32_t *)a; const uint32_t *bb = (const uint32_t *)b;\n" as *byte, codegen.output as *void);
    fputs("  int _i; for (_i = 0; _i < 2; _i++) M[_i] = (aa[_i] >= bb[_i]);\n}\n" as *byte, codegen.output as *void);
    fputs("static inline void uya_simd_sse_add_f32x2(void *r, const void *a, const void *b) {\n" as *byte, codegen.output as *void);
    fputs("  float *rr = (float *)r; const float *aa = (const float *)a; const float *bb = (const float *)b;\n" as *byte, codegen.output as *void);
    fputs("  int _i; for (_i = 0; _i < 2; _i++) rr[_i] = aa[_i] + bb[_i];\n}\n" as *byte, codegen.output as *void);
    fputs("static inline void uya_simd_sse_sub_f32x2(void *r, const void *a, const void *b) {\n" as *byte, codegen.output as *void);
    fputs("  float *rr = (float *)r; const float *aa = (const float *)a; const float *bb = (const float *)b;\n" as *byte, codegen.output as *void);
    fputs("  int _i; for (_i = 0; _i < 2; _i++) rr[_i] = aa[_i] - bb[_i];\n}\n" as *byte, codegen.output as *void);
    fputs("static inline void uya_simd_sse_mul_f32x2(void *r, const void *a, const void *b) {\n" as *byte, codegen.output as *void);
    fputs("  float *rr = (float *)r; const float *aa = (const float *)a; const float *bb = (const float *)b;\n" as *byte, codegen.output as *void);
    fputs("  int _i; for (_i = 0; _i < 2; _i++) rr[_i] = aa[_i] * bb[_i];\n}\n" as *byte, codegen.output as *void);
    fputs("static inline void uya_simd_sse_div_f32x2(void *r, const void *a, const void *b) {\n" as *byte, codegen.output as *void);
    fputs("  float *rr = (float *)r; const float *aa = (const float *)a; const float *bb = (const float *)b;\n" as *byte, codegen.output as *void);
    fputs("  int _i; for (_i = 0; _i < 2; _i++) rr[_i] = aa[_i] / bb[_i];\n}\n" as *byte, codegen.output as *void);
    fputs("static inline void uya_simd_sse_splat_f32x2(void *r, float s) {\n" as *byte, codegen.output as *void);
    fputs("  float *rr = (float *)r; int _i; for (_i = 0; _i < 2; _i++) rr[_i] = s;\n}\n" as *byte, codegen.output as *void);
    fputs("static inline void uya_simd_sse_neg_f32x2(void *r, const void *a) {\n" as *byte, codegen.output as *void);
    fputs("  float *rr = (float *)r; const float *aa = (const float *)a;\n" as *byte, codegen.output as *void);
    fputs("  int _i; for (_i = 0; _i < 2; _i++) rr[_i] = -aa[_i];\n}\n" as *byte, codegen.output as *void);
    fputs("static inline void uya_simd_sse_eq_f32x2_mask(void *m, const void *a, const void *b) {\n" as *byte, codegen.output as *void);
    fputs("  bool *M = (bool *)m; const float *aa = (const float *)a; const float *bb = (const float *)b;\n" as *byte, codegen.output as *void);
    fputs("  int _i; for (_i = 0; _i < 2; _i++) M[_i] = (aa[_i] == bb[_i]);\n}\n" as *byte, codegen.output as *void);
    fputs("static inline void uya_simd_sse_ne_f32x2_mask(void *m, const void *a, const void *b) {\n" as *byte, codegen.output as *void);
    fputs("  bool *M = (bool *)m; const float *aa = (const float *)a; const float *bb = (const float *)b;\n" as *byte, codegen.output as *void);
    fputs("  int _i; for (_i = 0; _i < 2; _i++) M[_i] = (aa[_i] != bb[_i]);\n}\n" as *byte, codegen.output as *void);
    fputs("static inline void uya_simd_sse_lt_f32x2_mask(void *m, const void *a, const void *b) {\n" as *byte, codegen.output as *void);
    fputs("  bool *M = (bool *)m; const float *aa = (const float *)a; const float *bb = (const float *)b;\n" as *byte, codegen.output as *void);
    fputs("  int _i; for (_i = 0; _i < 2; _i++) M[_i] = (aa[_i] < bb[_i]);\n}\n" as *byte, codegen.output as *void);
    fputs("static inline void uya_simd_sse_le_f32x2_mask(void *m, const void *a, const void *b) {\n" as *byte, codegen.output as *void);
    fputs("  bool *M = (bool *)m; const float *aa = (const float *)a; const float *bb = (const float *)b;\n" as *byte, codegen.output as *void);
    fputs("  int _i; for (_i = 0; _i < 2; _i++) M[_i] = (aa[_i] <= bb[_i]);\n}\n" as *byte, codegen.output as *void);
    fputs("static inline void uya_simd_sse_gt_f32x2_mask(void *m, const void *a, const void *b) {\n" as *byte, codegen.output as *void);
    fputs("  bool *M = (bool *)m; const float *aa = (const float *)a; const float *bb = (const float *)b;\n" as *byte, codegen.output as *void);
    fputs("  int _i; for (_i = 0; _i < 2; _i++) M[_i] = (aa[_i] > bb[_i]);\n}\n" as *byte, codegen.output as *void);
    fputs("static inline void uya_simd_sse_ge_f32x2_mask(void *m, const void *a, const void *b) {\n" as *byte, codegen.output as *void);
    fputs("  bool *M = (bool *)m; const float *aa = (const float *)a; const float *bb = (const float *)b;\n" as *byte, codegen.output as *void);
    fputs("  int _i; for (_i = 0; _i < 2; _i++) M[_i] = (aa[_i] >= bb[_i]);\n}\n" as *byte, codegen.output as *void);
}
fn emit_simd_x86_sse_runtime_helpers(codegen: &C99CodeGenerator) void {
    if codegen == null || codegen.output == null || codegen.simd_struct_count <= 0 {
        return;
    }
    var simd_emit_all: i32 = 0;
    if codegen.simd_vector_struct_reg_count == 0 && codegen.simd_struct_count > 0 {
        simd_emit_all = 1;
    }
    fputs("// SIMD lowering：x86_64 SSE 或 ARM NEON（GCC/Clang）；否则标量 static inline\n" as *byte, codegen.output as *void);
    fputs("#if (defined(__GNUC__) || defined(__clang__)) && (defined(__x86_64__) || defined(_M_X64)) && defined(__SSE2__)\n" as *byte, codegen.output as *void);
    fputs("#include <emmintrin.h>\n#include <xmmintrin.h>\n" as *byte, codegen.output as *void);
    fputs("#define UYA_HAVE_SIMD_X86_SSE 1\n" as *byte, codegen.output as *void);
    fputs("#else\n#define UYA_HAVE_SIMD_X86_SSE 0\n#endif\n" as *byte, codegen.output as *void);
    fputs("#if (defined(__GNUC__) || defined(__clang__)) && defined(__ARM_NEON)\n" as *byte, codegen.output as *void);
    fputs("#define UYA_HAVE_SIMD_ARM_NEON 1\n" as *byte, codegen.output as *void);
    fputs("#else\n#define UYA_HAVE_SIMD_ARM_NEON 0\n#endif\n" as *byte, codegen.output as *void);
    fputs("#if UYA_HAVE_SIMD_X86_SSE\n" as *byte, codegen.output as *void);
    if c99_simd_need_emit_i32_u32_f32(codegen, simd_emit_all) != 0 {
        emit_simd_runtime_helpers_i32_u32_f32_x86_sse(codegen);
        if c99_simd_any_select_helpers_needed(codegen) != 0 {
            emit_simd_runtime_helpers_i32_u32_f32_select_x86_sse(codegen);
        }
        if c99_simd_any_reduce_add_helpers_needed(codegen) != 0 {
            emit_simd_runtime_helpers_i32_u32_f32_reduce_add_x86_sse(codegen);
        }
        if codegen.simd_emit_reduce_mul_i32x2 != 0 || codegen.simd_emit_reduce_mul_u32x2 != 0 || codegen.simd_emit_reduce_mul_f32x2 != 0 ||
            codegen.simd_emit_reduce_mul_i32x4 != 0 || codegen.simd_emit_reduce_mul_u32x4 != 0 || codegen.simd_emit_reduce_mul_f32x4 != 0 {
            emit_simd_runtime_helpers_i32_u32_f32_reduce_mul_x86_sse(codegen);
        }
        if codegen.simd_emit_reduce_min_i32x2 != 0 || codegen.simd_emit_reduce_min_u32x2 != 0 || codegen.simd_emit_reduce_min_f32x2 != 0 ||
            codegen.simd_emit_reduce_min_i32x4 != 0 || codegen.simd_emit_reduce_min_u32x4 != 0 || codegen.simd_emit_reduce_min_f32x4 != 0 ||
            codegen.simd_emit_reduce_max_i32x2 != 0 || codegen.simd_emit_reduce_max_u32x2 != 0 || codegen.simd_emit_reduce_max_f32x2 != 0 ||
            codegen.simd_emit_reduce_max_i32x4 != 0 || codegen.simd_emit_reduce_max_u32x4 != 0 || codegen.simd_emit_reduce_max_f32x4 != 0 {
            emit_simd_runtime_helpers_i32_u32_f32_reduce_min_max_x86_sse(codegen);
        }
    }
    if c99_simd_need_emit_i8_u8_i64_u64(codegen, simd_emit_all) != 0 {
        emit_simd_runtime_helpers_i8_u8_i64_u64_x86_sse(codegen);
    }
    if c99_simd_need_emit_f64(codegen, simd_emit_all) != 0 {
        emit_simd_runtime_helpers_f64_x86_sse(codegen);
    }
    if c99_simd_need_emit_i16_u16(codegen, simd_emit_all) != 0 {
        emit_simd_runtime_helpers_i16_u16_x86_sse(codegen);
    }
    if c99_simd_need_emit_i32_u32_f32(codegen, simd_emit_all) != 0 {
        fputs("static inline void uya_simd_sse_splat_f32x4(void *r, float s) {\n" as *byte, codegen.output as *void);
        fputs("  _mm_storeu_ps((float *)r, _mm_set1_ps(s));\n}\n" as *byte, codegen.output as *void);
        fputs("static inline void uya_simd_sse_neg_f32x4(void *r, const void *a) {\n" as *byte, codegen.output as *void);
        fputs("  __m128 va = _mm_loadu_ps((const float *)a);\n" as *byte, codegen.output as *void);
        fputs("  _mm_storeu_ps((float *)r, _mm_sub_ps(_mm_setzero_ps(), va));\n}\n" as *byte, codegen.output as *void);
        fputs("static inline void uya_simd_sse_f32x4_pred_store_mask(void *m, __m128 pr) {\n" as *byte, codegen.output as *void);
        fputs("  union { __m128 v; uint32_t u[4]; } x; x.v = pr;\n" as *byte, codegen.output as *void);
        fputs("  bool *M = (bool *)m; M[0] = x.u[0] != 0U; M[1] = x.u[1] != 0U; M[2] = x.u[2] != 0U; M[3] = x.u[3] != 0U;\n}\n" as *byte, codegen.output as *void);
        fputs("static inline void uya_simd_sse_eq_f32x4_mask(void *m, const void *a, const void *b) {\n" as *byte, codegen.output as *void);
        fputs("  __m128 va = _mm_loadu_ps((const float *)a); __m128 vb = _mm_loadu_ps((const float *)b);\n" as *byte, codegen.output as *void);
        fputs("  uya_simd_sse_f32x4_pred_store_mask(m, _mm_cmpeq_ps(va, vb));\n}\n" as *byte, codegen.output as *void);
        fputs("static inline void uya_simd_sse_ne_f32x4_mask(void *m, const void *a, const void *b) {\n" as *byte, codegen.output as *void);
        fputs("  __m128 va = _mm_loadu_ps((const float *)a); __m128 vb = _mm_loadu_ps((const float *)b);\n" as *byte, codegen.output as *void);
        fputs("  uya_simd_sse_f32x4_pred_store_mask(m, _mm_cmpneq_ps(va, vb));\n}\n" as *byte, codegen.output as *void);
        fputs("static inline void uya_simd_sse_lt_f32x4_mask(void *m, const void *a, const void *b) {\n" as *byte, codegen.output as *void);
        fputs("  __m128 va = _mm_loadu_ps((const float *)a); __m128 vb = _mm_loadu_ps((const float *)b);\n" as *byte, codegen.output as *void);
        fputs("  uya_simd_sse_f32x4_pred_store_mask(m, _mm_cmplt_ps(va, vb));\n}\n" as *byte, codegen.output as *void);
        fputs("static inline void uya_simd_sse_le_f32x4_mask(void *m, const void *a, const void *b) {\n" as *byte, codegen.output as *void);
        fputs("  __m128 va = _mm_loadu_ps((const float *)a); __m128 vb = _mm_loadu_ps((const float *)b);\n" as *byte, codegen.output as *void);
        fputs("  uya_simd_sse_f32x4_pred_store_mask(m, _mm_cmple_ps(va, vb));\n}\n" as *byte, codegen.output as *void);
        fputs("static inline void uya_simd_sse_gt_f32x4_mask(void *m, const void *a, const void *b) {\n" as *byte, codegen.output as *void);
        fputs("  __m128 va = _mm_loadu_ps((const float *)a); __m128 vb = _mm_loadu_ps((const float *)b);\n" as *byte, codegen.output as *void);
        fputs("  uya_simd_sse_f32x4_pred_store_mask(m, _mm_cmpgt_ps(va, vb));\n}\n" as *byte, codegen.output as *void);
        fputs("static inline void uya_simd_sse_ge_f32x4_mask(void *m, const void *a, const void *b) {\n" as *byte, codegen.output as *void);
        fputs("  __m128 va = _mm_loadu_ps((const float *)a); __m128 vb = _mm_loadu_ps((const float *)b);\n" as *byte, codegen.output as *void);
        fputs("  uya_simd_sse_f32x4_pred_store_mask(m, _mm_cmpge_ps(va, vb));\n}\n" as *byte, codegen.output as *void);
    }
    fputs("#elif UYA_HAVE_SIMD_ARM_NEON\n" as *byte, codegen.output as *void);
    fputs("#include <arm_neon.h>\n" as *byte, codegen.output as *void);
    if c99_simd_need_emit_i8_u8_i64_u64(codegen, simd_emit_all) != 0 {
        emit_simd_runtime_helpers_i8_u8_i64_u64_arm_neon(codegen);
    }
    if c99_simd_need_emit_i32_u32_f32(codegen, simd_emit_all) != 0 {
        emit_simd_runtime_helpers_i32_u32_f32_arm_neon(codegen);
        if c99_simd_any_select_helpers_needed(codegen) != 0 {
            emit_simd_runtime_helpers_i32_u32_f32_select_arm_neon(codegen);
        }
        if c99_simd_any_reduce_add_helpers_needed(codegen) != 0 {
            emit_simd_runtime_helpers_i32_u32_f32_reduce_add_arm_neon(codegen);
        }
        if codegen.simd_emit_reduce_mul_i32x2 != 0 || codegen.simd_emit_reduce_mul_u32x2 != 0 || codegen.simd_emit_reduce_mul_f32x2 != 0 ||
            codegen.simd_emit_reduce_mul_i32x4 != 0 || codegen.simd_emit_reduce_mul_u32x4 != 0 || codegen.simd_emit_reduce_mul_f32x4 != 0 {
            emit_simd_runtime_helpers_i32_u32_f32_reduce_mul_arm_neon(codegen);
        }
        if codegen.simd_emit_reduce_min_i32x2 != 0 || codegen.simd_emit_reduce_min_u32x2 != 0 || codegen.simd_emit_reduce_min_f32x2 != 0 ||
            codegen.simd_emit_reduce_min_i32x4 != 0 || codegen.simd_emit_reduce_min_u32x4 != 0 || codegen.simd_emit_reduce_min_f32x4 != 0 ||
            codegen.simd_emit_reduce_max_i32x2 != 0 || codegen.simd_emit_reduce_max_u32x2 != 0 || codegen.simd_emit_reduce_max_f32x2 != 0 ||
            codegen.simd_emit_reduce_max_i32x4 != 0 || codegen.simd_emit_reduce_max_u32x4 != 0 || codegen.simd_emit_reduce_max_f32x4 != 0 {
            emit_simd_runtime_helpers_i32_u32_f32_reduce_min_max_arm_neon(codegen);
