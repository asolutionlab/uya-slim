        fputs("static inline void uya_simd_sse_reduce_min_i32x4(void *r, const void *v) {\n" as *byte, codegen.output as *void);
        fputs("#if defined(__SSE4_1__)\n" as *byte, codegen.output as *void);
        fputs("  __m128i x = _mm_loadu_si128((const __m128i *)(const void *)v);\n" as *byte, codegen.output as *void);
        fputs("  __m128i t = _mm_shuffle_epi32(x, _MM_SHUFFLE(2, 3, 0, 1));\n" as *byte, codegen.output as *void);
        fputs("  x = _mm_min_epi32(x, t);\n" as *byte, codegen.output as *void);
        fputs("  t = _mm_shuffle_epi32(x, _MM_SHUFFLE(1, 0, 3, 2));\n" as *byte, codegen.output as *void);
        fputs("  x = _mm_min_epi32(x, t);\n" as *byte, codegen.output as *void);
        fputs("  *(int32_t *)r = _mm_cvtsi128_si32(x);\n" as *byte, codegen.output as *void);
        fputs("#else\n" as *byte, codegen.output as *void);
        fputs("  const int32_t *p = (const int32_t *)v; int32_t s = p[0]; int _i; for (_i = 1; _i < 4; _i++) if (p[_i] < s) s = p[_i]; *(int32_t *)r = s;\n" as *byte, codegen.output as *void);
        fputs("#endif\n}\n" as *byte, codegen.output as *void);
    }
    if codegen.simd_emit_reduce_min_u32x4 != 0 {
        fputs("static inline void uya_simd_sse_reduce_min_u32x4(void *r, const void *v) {\n" as *byte, codegen.output as *void);
        fputs("#if defined(__SSE4_1__)\n" as *byte, codegen.output as *void);
        fputs("  __m128i x = _mm_loadu_si128((const __m128i *)(const void *)v);\n" as *byte, codegen.output as *void);
        fputs("  __m128i t = _mm_shuffle_epi32(x, _MM_SHUFFLE(2, 3, 0, 1));\n" as *byte, codegen.output as *void);
        fputs("  x = _mm_min_epu32(x, t);\n" as *byte, codegen.output as *void);
        fputs("  t = _mm_shuffle_epi32(x, _MM_SHUFFLE(1, 0, 3, 2));\n" as *byte, codegen.output as *void);
        fputs("  x = _mm_min_epu32(x, t);\n" as *byte, codegen.output as *void);
        fputs("  *(uint32_t *)r = (uint32_t)_mm_cvtsi128_si32(x);\n" as *byte, codegen.output as *void);
        fputs("#else\n" as *byte, codegen.output as *void);
        fputs("  const uint32_t *p = (const uint32_t *)v; uint32_t s = p[0]; int _i; for (_i = 1; _i < 4; _i++) if (p[_i] < s) s = p[_i]; *(uint32_t *)r = s;\n" as *byte, codegen.output as *void);
        fputs("#endif\n}\n" as *byte, codegen.output as *void);
    }
    if codegen.simd_emit_reduce_min_f32x4 != 0 {
        fputs("static inline void uya_simd_sse_reduce_min_f32x4(void *r, const void *v) {\n" as *byte, codegen.output as *void);
        fputs("  __m128 x = _mm_loadu_ps((const float *)v);\n" as *byte, codegen.output as *void);
        fputs("  __m128 t = _mm_min_ps(x, _mm_shuffle_ps(x, x, _MM_SHUFFLE(2, 3, 0, 1));\n" as *byte, codegen.output as *void);
        fputs("  t = _mm_min_ps(t, _mm_shuffle_ps(t, t, _MM_SHUFFLE(1, 0, 3, 2));\n" as *byte, codegen.output as *void);
        fputs("  *(float *)r = _mm_cvtss_f32(t);\n}\n" as *byte, codegen.output as *void);
