            const owner_type: Type = exec_lower_member_base_type(ctx, object_ast);
            if owner_type.kind == TypeKind.TYPE_INTERFACE && owner_type.interface_name != null {
                const method_sig: &ASTNode = find_interface_method_sig(ctx.checker.program_node, owner_type.interface_name, method_name);
                const method_index: i32 = exec_lower_interface_method_index(ctx, &owner_type, method_name);
                if method_sig == null || method_index < 0 {
