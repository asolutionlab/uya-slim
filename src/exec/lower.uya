// exec/lower.uya - checked AST to minimal Exec HIR lowering

use libc;

const EXEC_MAX_LOCALS: i32 = 256;
// 保持平铺数组查找的热路径简单，同时给编译器本体 staged smoke 留足全局槽位。
const EXEC_MAX_GLOBALS: i32 = 1024;
const EXEC_MAX_SCOPE_DEPTH: i32 = 64;
const EXEC_MAX_INTERFACE_METHODS: i32 = 64;
const EXEC_MAX_MODULE_GLOBAL_REQUESTS: i32 = 256;

struct ExecLowerContext {
    arena: &CompilerArena,
    checker: &TypeChecker,
    function_decl: &ASTNode,
    global_names: [&byte: EXEC_MAX_GLOBALS],
    global_decls: [&ASTNode: EXEC_MAX_GLOBALS],
    global_types: [Type: EXEC_MAX_GLOBALS],
    global_is_const: [i32: EXEC_MAX_GLOBALS],
    global_count: i32,
    local_names: [&byte: EXEC_MAX_LOCALS],
    local_slots: [i32: EXEC_MAX_LOCALS],
    local_types: [Type: EXEC_MAX_LOCALS],
    local_is_param: [i32: EXEC_MAX_LOCALS],
    slot_names: [&byte: EXEC_MAX_LOCALS],
    slot_types: [Type: EXEC_MAX_LOCALS],
    slot_is_param: [i32: EXEC_MAX_LOCALS],
    active_local_count: i32,
    next_slot: i32,
    max_slot_count: i32,
    scope_markers: [i32: EXEC_MAX_SCOPE_DEPTH],
    scope_depth: i32,
}

fn exec_lower_set_unsupported(node: &ASTNode, reason: &byte) i32 {
    exec_backend_set_unsupported_error(node, reason, ExecUnsupportedReason.EXEC_UNSUPPORTED_GENERIC);
    return 2;
}

fn exec_lower_set_unsupported_reason(node: &ASTNode, reason: &byte, code: ExecUnsupportedReason) i32 {
    exec_backend_set_unsupported_error(node, reason, code);
    return 2;
}

fn exec_lower_fail_expr(node: &ASTNode, reason: &byte) &HIRExpr {
    _ = exec_lower_set_unsupported(node, reason);
    return null;
}

fn exec_lower_fail_expr_reason(node: &ASTNode, reason: &byte, code: ExecUnsupportedReason) &HIRExpr {
    _ = exec_lower_set_unsupported_reason(node, reason, code);
    return null;
}

fn exec_lower_fail_block(node: &ASTNode, reason: &byte) &HIRBlock {
    _ = exec_lower_set_unsupported(node, reason);
    return null;
}

fn exec_lower_fail_block_reason(node: &ASTNode, reason: &byte, code: ExecUnsupportedReason) &HIRBlock {
    _ = exec_lower_set_unsupported_reason(node, reason, code);
    return null;
}

fn exec_type_is_scalar_supported(type: Type) i32 {
    if type.kind == TypeKind.TYPE_I8 ||
        type.kind == TypeKind.TYPE_I16 ||
        type.kind == TypeKind.TYPE_I32 ||
        type.kind == TypeKind.TYPE_I64 ||
        type.kind == TypeKind.TYPE_U8 ||
        type.kind == TypeKind.TYPE_U16 ||
        type.kind == TypeKind.TYPE_U32 ||
        type.kind == TypeKind.TYPE_U64 ||
        type.kind == TypeKind.TYPE_USIZE ||
        type.kind == TypeKind.TYPE_BOOL ||
        type.kind == TypeKind.TYPE_BYTE ||
        type.kind == TypeKind.TYPE_VOID {
        return 1;
    }
    return 0;
}

fn exec_type_is_string_pointer_supported(type: Type) i32 {
    if type.kind != TypeKind.TYPE_POINTER || type.pointer_to == null {
        return 0;
    }
    if type.pointer_to.kind == TypeKind.TYPE_BYTE {
        return 1;
    }
    return 0;
}

fn exec_lower_is_supported_extern_lib(fn_decl: &ASTNode) i32 {
    if fn_decl == null || fn_decl.type != ASTNodeType.AST_FN_DECL {
        return 0;
    }
    if fn_decl.fn_decl_extern_lib_name == null {
        return 1;
    }
    if str_equals(fn_decl.fn_decl_extern_lib_name, "libc" as &byte) != 0 {
        return 1;
    }
    return 0;
}

fn exec_lower_is_exact_scalar_type(type: Type, kind: TypeKind) i32 {
    if type.kind == kind {
        return 1;
    }
    return 0;
}

fn exec_lower_match_host_call(fn_decl: &ASTNode, call_arg_count: i32) ExecHostCallId {
    if fn_decl == null || fn_decl.type != ASTNodeType.AST_FN_DECL {
        return ExecHostCallId.EXEC_HOST_CALL_NONE;
    }
    if fn_decl.fn_decl_is_extern == 0 {
        return ExecHostCallId.EXEC_HOST_CALL_NONE;
    }
    if fn_decl.fn_decl_name == null || fn_decl.fn_decl_return_type == null {
        return ExecHostCallId.EXEC_HOST_CALL_NONE;
    }
    if fn_decl.fn_decl_is_varargs == 0 {
        if str_equals(fn_decl.fn_decl_name, "puts" as &byte) != 0 &&
            fn_decl.fn_decl_param_count == 1 && call_arg_count == 1 {
            return ExecHostCallId.EXEC_HOST_CALL_PUTS;
        }
        if str_equals(fn_decl.fn_decl_name, "atoi" as &byte) != 0 &&
            fn_decl.fn_decl_param_count == 1 && call_arg_count == 1 {
            return ExecHostCallId.EXEC_HOST_CALL_ATOI;
        }
        if str_equals(fn_decl.fn_decl_name, "atoll" as &byte) != 0 &&
            fn_decl.fn_decl_param_count == 1 && call_arg_count == 1 {
            return ExecHostCallId.EXEC_HOST_CALL_ATOLL;
        }
        if str_equals(fn_decl.fn_decl_name, "isqrt" as &byte) != 0 &&
            fn_decl.fn_decl_param_count == 1 && call_arg_count == 1 {
            return ExecHostCallId.EXEC_HOST_CALL_ISQRT;
        }
        if str_equals(fn_decl.fn_decl_name, "strcmp" as &byte) != 0 &&
            fn_decl.fn_decl_param_count == 2 && call_arg_count == 2 {
            return ExecHostCallId.EXEC_HOST_CALL_STRCMP;
        }
        if str_equals(fn_decl.fn_decl_name, "llabs" as &byte) != 0 &&
            fn_decl.fn_decl_param_count == 1 && call_arg_count == 1 {
            return ExecHostCallId.EXEC_HOST_CALL_LLABS;
        }
        return ExecHostCallId.EXEC_HOST_CALL_NONE;
    }
    if str_equals(fn_decl.fn_decl_name, "fprintf" as &byte) != 0 && call_arg_count == 2 {
        return ExecHostCallId.EXEC_HOST_CALL_FPRINTF_FIXED;
    }
    if str_equals(fn_decl.fn_decl_name, "printf" as &byte) != 0 && call_arg_count == 1 {
        return ExecHostCallId.EXEC_HOST_CALL_PRINTF_FIXED;
    }
    if str_equals(fn_decl.fn_decl_name, "sprintf" as &byte) != 0 && call_arg_count == 2 {
        return ExecHostCallId.EXEC_HOST_CALL_SPRINTF_FIXED;
    }
    if str_equals(fn_decl.fn_decl_name, "snprintf" as &byte) != 0 && call_arg_count == 3 {
        return ExecHostCallId.EXEC_HOST_CALL_SNPRINTF_FIXED;
    }
    return ExecHostCallId.EXEC_HOST_CALL_NONE;
}

fn exec_lower_extern_prefers_host_call(fn_decl: &ASTNode) i32 {
    if fn_decl == null || fn_decl.type != ASTNodeType.AST_FN_DECL || fn_decl.fn_decl_name == null {
        return 0;
    }
    if str_equals(fn_decl.fn_decl_name, "puts" as &byte) != 0 ||
        str_equals(fn_decl.fn_decl_name, "atoll" as &byte) != 0 ||
        str_equals(fn_decl.fn_decl_name, "llabs" as &byte) != 0 {
        return 1;
    }
    return 0;
}

fn exec_lower_host_call_overrides_body(fn_decl: &ASTNode, host_call_id: ExecHostCallId) i32 {
    if fn_decl == null || host_call_id == ExecHostCallId.EXEC_HOST_CALL_NONE {
        return 0;
    }
    return exec_lower_extern_prefers_host_call(fn_decl);
}

fn exec_lower_extern_can_run_in_vm(checker: &TypeChecker, fn_decl: &ASTNode) i32 {
    if fn_decl == null || fn_decl.type != ASTNodeType.AST_FN_DECL {
        return 0;
    }
    if fn_decl.fn_decl_is_extern == 0 {
        return (fn_decl.fn_decl_body != null) as i32;
    }
    if fn_decl.fn_decl_is_varargs != 0 {
        return 0;
    }
    if exec_lower_extern_prefers_host_call(fn_decl) != 0 {
        return 0;
    }
    return (fn_decl.fn_decl_body != null) as i32;
}

fn exec_type_uses_simd(ty: Type) i32 {
    if ty.kind == TypeKind.TYPE_VECTOR || ty.kind == TypeKind.TYPE_MASK {
        return 1;
    }
    if ty.kind == TypeKind.TYPE_ARRAY && ty.element_type != null {
        return exec_type_uses_simd(ty.element_type[0]);
    }
    if ty.kind == TypeKind.TYPE_SLICE && ty.slice_element_type != null {
        return exec_type_uses_simd(ty.slice_element_type[0]);
    }
    if ty.kind == TypeKind.TYPE_TUPLE && ty.tuple_element_types != null {
        var i: i32 = 0;
        while i < ty.tuple_count {
            if exec_type_uses_simd(ty.tuple_element_types[i]) != 0 {
                return 1;
            }
            i = i + 1;
        }
    }
    if ty.kind == TypeKind.TYPE_ERROR_UNION && ty.error_union_payload_type != null {
        return exec_type_uses_simd(ty.error_union_payload_type[0]);
    }
    return 0;
}

fn exec_type_is_aggregate_supported(ty: Type) i32 {
    if ty.kind == TypeKind.TYPE_ARRAY && ty.element_type != null {
        return exec_type_is_vm_value_supported(ty.element_type[0]);
    }
    if ty.kind == TypeKind.TYPE_SLICE && ty.slice_element_type != null {
        return exec_type_is_vm_value_supported(ty.slice_element_type[0]);
    }
    if ty.kind == TypeKind.TYPE_TUPLE && ty.tuple_element_types != null {
        var ti: i32 = 0;
        while ti < ty.tuple_count {
            if exec_type_is_vm_value_supported(ty.tuple_element_types[ti]) == 0 {
                return 0;
            }
            ti = ti + 1;
        }
        return 1;
    }
    if ty.kind == TypeKind.TYPE_STRUCT && type_get_struct_name(&ty) != null {
        return 1;
    }
    return 0;
}

fn exec_type_is_vm_value_supported(type: Type) i32 {
    if exec_type_is_scalar_supported(type) != 0 {
        return 1;
    }
    if type.kind == TypeKind.TYPE_ENUM {
        return 1;
    }
    if type.kind == TypeKind.TYPE_INTERFACE {
        return 1;
    }
    if type.kind == TypeKind.TYPE_UNION {
        return 1;
    }
    if type.kind == TypeKind.TYPE_POINTER {
        return 1;
    }
    if type.kind == TypeKind.TYPE_ERROR {
        return 1;
    }
    if type.kind == TypeKind.TYPE_ERROR_UNION && type.error_union_payload_type != null {
        return exec_type_is_vm_value_supported(type.error_union_payload_type[0]);
    }
    if exec_type_is_aggregate_supported(type) != 0 {
        return 1;
    }
    return 0;
}

fn exec_lower_expr_type(ctx: &ExecLowerContext, expr: &ASTNode) Type {
    if ctx == null || ctx.checker == null || expr == null {
        return Type {
            kind: TypeKind.TYPE_VOID,
            data: TypeData.named(null as &byte),
            enum_name: null,
            interface_name: null,
            interface_type_args: null,
            interface_type_arg_count: 0,
            struct_name: null,
            union_name: null,
            pointer_to: null,
            is_ffi_pointer: 0,
            element_type: null,
            array_size: 0,
            slice_element_type: null,
            slice_len: 0,
            slice_element_is_const: 0,
            tuple_element_types: null,
            tuple_count: 0,
            error_union_payload_type: null,
            error_error_id: 0,
            atomic_inner_type: null,
            generic_param_name: null,
            struct_type_args: null,
            struct_type_arg_count: 0,
            union_type_args: null,
            union_type_arg_count: 0,
        };
    }
    if expr.type == ASTNodeType.AST_PRINT || expr.type == ASTNodeType.AST_PRINTLN {
        return make_i32_type();
    }
    const prev_in_function: i32 = ctx.checker.in_function;
    const prev_function_decl: &ASTNode = ctx.checker.current_function_decl;
    if ctx.function_decl != null {
        ctx.checker.in_function = 1;
        ctx.checker.current_function_decl = ctx.function_decl;
    }
    const inferred: Type = checker_infer_type(ctx.checker, expr);
    ctx.checker.in_function = prev_in_function;
    ctx.checker.current_function_decl = prev_function_decl;
    return inferred;
}

fn exec_lower_push_scope(ctx: &ExecLowerContext) void {
    if ctx == null || ctx.scope_depth >= EXEC_MAX_SCOPE_DEPTH {
        return;
    }
    if ctx.scope_depth >= 0 && ctx.scope_depth < EXEC_MAX_SCOPE_DEPTH {
        ctx.scope_markers[ctx.scope_depth] = ctx.active_local_count;
    }
    ctx.scope_depth = ctx.scope_depth + 1;
}

fn exec_lower_pop_scope(ctx: &ExecLowerContext) void {
    if ctx == null || ctx.scope_depth <= 0 {
        return;
    }
    ctx.scope_depth = ctx.scope_depth - 1;
    if ctx.scope_depth >= 0 && ctx.scope_depth < EXEC_MAX_SCOPE_DEPTH {
        ctx.active_local_count = ctx.scope_markers[ctx.scope_depth];
        ctx.next_slot = ctx.active_local_count;
    }
}

fn exec_lower_find_slot(ctx: &ExecLowerContext, name: &byte) i32 {
    if ctx == null || name == null {
        return -1;
    }
    var i: i32 = ctx.active_local_count - 1;
    while i >= 0 {
        if i >= 0 && i < EXEC_MAX_LOCALS {
            if ctx.local_names[i] != null && str_equals(ctx.local_names[i], name) != 0 {
                return ctx.local_slots[i];
            }
        }
        i = i - 1;
    }
    return -1;
}

fn exec_lower_find_global_slot(ctx: &ExecLowerContext, name: &byte) i32 {
    if ctx == null || name == null {
        return -1;
    }
    var i: i32 = ctx.global_count - 1;
    while i >= 0 {
        if i >= 0 && i < EXEC_MAX_GLOBALS {
            if ctx.global_names[i] != null && str_equals(ctx.global_names[i], name) != 0 {
                return i;
            }
        }
        i = i - 1;
    }
    return -1;
}

fn exec_lower_find_global_slot_by_decl(ctx: &ExecLowerContext, decl: &ASTNode) i32 {
    if ctx == null || decl == null {
        return -1;
    }
    var i: i32 = 0;
    while i < ctx.global_count {
        if i >= 0 && i < EXEC_MAX_GLOBALS && ctx.global_decls[i] == decl {
            return i;
        }
        i = i + 1;
    }
    return -1;
}

fn exec_lower_seed_globals(ctx: &ExecLowerContext, globals: &HIRGlobalSlot, global_count: i32) void {
    if ctx == null {
        return;
    }
    ctx.global_count = 0;
    if globals == null || global_count <= 0 {
        return;
    }
    var i: i32 = 0;
    while i < global_count && i < EXEC_MAX_GLOBALS {
        ctx.global_names[i] = globals[i].name;
        ctx.global_decls[i] = globals[i].decl;
        ctx.global_types[i] = copy_type(&globals[i].type_ref.type);
        ctx.global_is_const[i] = globals[i].is_const;
        i = i + 1;
    }
    ctx.global_count = i;
}

fn exec_lower_append_local(ctx: &ExecLowerContext, name: &byte, type: &Type, is_param: i32) i32 {
    if ctx == null || name == null || ctx.active_local_count >= EXEC_MAX_LOCALS || ctx.next_slot >= EXEC_MAX_LOCALS {
        return -1;
    }
    const slot: i32 = ctx.next_slot;
    if ctx.active_local_count >= 0 && ctx.active_local_count < EXEC_MAX_LOCALS {
        ctx.local_names[ctx.active_local_count] = name;
        ctx.local_slots[ctx.active_local_count] = slot;
        ctx.local_types[ctx.active_local_count] = copy_type(type);
        ctx.local_is_param[ctx.active_local_count] = is_param;
    }
    if slot >= 0 && slot < EXEC_MAX_LOCALS {
        ctx.slot_names[slot] = name;
        ctx.slot_types[slot] = copy_type(type);
        ctx.slot_is_param[slot] = is_param;
    }
    ctx.active_local_count = ctx.active_local_count + 1;
    ctx.next_slot = slot + 1;
    if ctx.next_slot > ctx.max_slot_count {
        ctx.max_slot_count = ctx.next_slot;
    }
    return slot;
}

fn exec_lower_make_type_ref(type: &Type) HIRTypeRef {
    return HIRTypeRef {
        type: copy_type(type),
    };
}

fn exec_lower_alloc_expr(ctx: &ExecLowerContext, ast_node: &ASTNode, kind: HIRExprKind, type: &Type) &HIRExpr {
    const expr: &HIRExpr = compiler_arena_alloc(ctx.arena, @size_of(HIRExpr)) as &HIRExpr;
    if expr == null {
        exec_backend_set_error(ast_node, "exec: HIRExpr 分配失败" as *byte, 0);
        return null;
    }
    _ = memset(expr as *byte, 0, @size_of(HIRExpr));
    expr.kind = kind;
    expr.ast_node = ast_node;
    expr.type_ref = exec_lower_make_type_ref(type);
    expr.local_slot = -1;
    expr.global_slot = -1;
    return expr;
}

fn exec_lower_alloc_stmt(ctx: &ExecLowerContext, ast_node: &ASTNode, kind: HIRStmtKind) &HIRStmt {
    const stmt: &HIRStmt = compiler_arena_alloc(ctx.arena, @size_of(HIRStmt)) as &HIRStmt;
    if stmt == null {
        exec_backend_set_error(ast_node, "exec: HIRStmt 分配失败" as *byte, 0);
        return null;
    }
    _ = memset(stmt as *byte, 0, @size_of(HIRStmt));
    stmt.kind = kind;
    stmt.ast_node = ast_node;
    stmt.local_slot = -1;
    return stmt;
}

fn exec_lower_extract_block_result_expr(ctx: &ExecLowerContext, block: &ASTNode) &HIRExpr {
    if block == null || block.type != ASTNodeType.AST_BLOCK || block.block_stmt_count != 1 {
        return exec_lower_fail_expr(block, "exec: 当前仅支持单表达式 catch/match 分支块" as *byte);
    }
    const only_stmt: &ASTNode = block.block_stmts[0];
    if only_stmt == null {
        return exec_lower_fail_expr(block, "exec: catch/match 分支块为空" as *byte);
    }
    return exec_lower_expr(ctx, only_stmt);
}

fn exec_lower_make_bool_const_expr(ctx: &ExecLowerContext, ast_node: &ASTNode, value: i32) &HIRExpr {
    const bool_type: Type = make_bool_type();
    const expr: &HIRExpr = exec_lower_alloc_expr(ctx, ast_node, HIRExprKind.HIR_EXPR_CONST, &bool_type);
    if expr == null {
        return null;
    }
    expr.bool_value = value;
    return expr;
}

fn exec_lower_make_int_const_expr(ctx: &ExecLowerContext, ast_node: &ASTNode, type: &Type, value: i64) &HIRExpr {
    const expr: &HIRExpr = exec_lower_alloc_expr(ctx, ast_node, HIRExprKind.HIR_EXPR_CONST, type);
    if expr == null {
        return null;
    }
    expr.int_value = value;
    return expr;
}

fn exec_lower_make_void_pointer_type() Type {
    return Type {
        kind: TypeKind.TYPE_POINTER,
        data: TypeData.pointer(PointerData {
            pointee: null as &Type,
            is_ffi: 0,
        }),
        enum_name: null,
        interface_name: null,
        interface_type_args: null,
        interface_type_arg_count: 0,
        struct_name: null,
        union_name: null,
        pointer_to: null,
        is_ffi_pointer: 0,
        element_type: null,
        array_size: 0,
        slice_element_type: null,
        slice_len: 0,
        slice_element_is_const: 0,
        tuple_element_types: null,
        tuple_count: 0,
        error_union_payload_type: null,
        error_error_id: 0,
        atomic_inner_type: null,
        generic_param_name: null,
        struct_type_args: null,
        struct_type_arg_count: 0,
        union_type_args: null,
        union_type_arg_count: 0,
    };
}

fn exec_lower_make_string_const_expr(ctx: &ExecLowerContext, ast_node: &ASTNode, type: &Type, value: &byte) &HIRExpr {
    const expr: &HIRExpr = exec_lower_alloc_expr(ctx, ast_node, HIRExprKind.HIR_EXPR_CONST, type);
    if expr == null {
        return null;
    }
    expr.string_value = value;
    return expr;
}

fn exec_lower_basename(path: &byte) &byte {
    if path == null {
        return "(unknown)" as &byte;
    }
    var basename: &byte = strrchr(path as *byte, 47) as &byte;
    if basename == null {
        basename = strrchr(path as *byte, 92) as &byte;
    }
    if basename != null {
        return (basename as i64 + 1) as &byte;
    }
    return path;
}

fn exec_lower_known_len(expr_type: &Type) i32 {
    if expr_type == null {
        return -1;
    }
    if expr_type.kind == TypeKind.TYPE_ARRAY {
        const array_len: i32 = type_get_array_size(expr_type);
        if array_len > 0 {
            return array_len;
        }
        if expr_type.array_size > 0 {
            return expr_type.array_size;
        }
        return -1;
    }
    if expr_type.kind == TypeKind.TYPE_SLICE {
        if expr_type.slice_len > 0 {
            return expr_type.slice_len;
        }
    }
    return -1;
}

fn exec_lower_known_len_for_expr(ctx: &ExecLowerContext, expr: &ASTNode) i32 {
    if ctx == null || expr == null {
        return -1;
    }
    if expr.type == ASTNodeType.AST_IDENTIFIER && expr.identifier_name != null {
        const local_slot: i32 = exec_lower_find_slot(ctx, expr.identifier_name);
        if local_slot >= 0 && local_slot < EXEC_MAX_LOCALS {
            return exec_lower_known_len(&ctx.slot_types[local_slot]);
        }
        const global_slot: i32 = exec_lower_find_global_slot(ctx, expr.identifier_name);
        if global_slot >= 0 && global_slot < EXEC_MAX_GLOBALS {
            return exec_lower_known_len(&ctx.global_types[global_slot]);
        }
    }
    const expr_type: Type = exec_lower_expr_type(ctx, expr);
    return exec_lower_known_len(&expr_type);
}

fn exec_lower_named_error_literal(expr: &ASTNode) &ASTNode {
    if expr == null {
        return null;
    }
    if expr.type == ASTNodeType.AST_ERROR_VALUE {
        return expr;
    }
    if expr.type == ASTNodeType.AST_CAST_EXPR && expr.cast_expr_expr != null {
        return exec_lower_named_error_literal(expr.cast_expr_expr);
    }
    return null;
}

fn exec_lower_make_local_expr(ctx: &ExecLowerContext, ast_node: &ASTNode, slot: i32, type: &Type) &HIRExpr {
    const expr: &HIRExpr = exec_lower_alloc_expr(ctx, ast_node, HIRExprKind.HIR_EXPR_LOCAL, type);
    if expr == null {
        return null;
    }
    expr.local_slot = slot;
    return expr;
}

fn exec_lower_make_global_expr(ctx: &ExecLowerContext, ast_node: &ASTNode, slot: i32, type: &Type) &HIRExpr {
    const expr: &HIRExpr = exec_lower_alloc_expr(ctx, ast_node, HIRExprKind.HIR_EXPR_GLOBAL, type);
    if expr == null {
        return null;
    }
    expr.global_slot = slot;
    return expr;
}

fn exec_lower_make_binary_expr(ctx: &ExecLowerContext, ast_node: &ASTNode, op: i32, left: &HIRExpr, right: &HIRExpr, type: &Type) &HIRExpr {
    const expr: &HIRExpr = exec_lower_alloc_expr(ctx, ast_node, HIRExprKind.HIR_EXPR_BINARY, type);
    if expr == null {
        return null;
    }
    expr.binary_op = op;
    expr.left = left;
    expr.right = right;
    return expr;
}

fn exec_lower_make_pointer_type_copy(ctx: &ExecLowerContext, pointee_type: Type) Type {
    if ctx == null || ctx.arena == null {
        return exec_lower_make_void_pointer_type();
    }
    const pointee_copy: &Type = compiler_arena_alloc(ctx.arena, @size_of(Type)) as &Type;
    if pointee_copy == null {
        return exec_lower_make_void_pointer_type();
    }
    pointee_copy[0] = copy_type(&pointee_type);
    return make_pointer_type(ctx.arena, pointee_copy, 0);
}

fn exec_lower_add_unique_decl(out_decls: & & ASTNode, out_count: &i32, decl: &ASTNode) i32 {
    if out_count == null || decl == null {
        return -1;
    }
    var i: i32 = 0;
    while i < out_count[0] {
        if out_decls[i] == decl {
            return 0;
        }
        i = i + 1;
    }
    if out_count[0] >= EXEC_MAX_INTERFACE_METHODS {
        return -1;
    }
    out_decls[out_count[0]] = decl;
    out_count[0] = out_count[0] + 1;
    return 0;
}

fn exec_lower_collect_interface_method_sigs_recursive(ctx: &ExecLowerContext, interface_name: &byte, out_decls: & & ASTNode, out_count: &i32) i32 {
    if ctx == null || ctx.checker == null || ctx.checker.program_node == null ||
        interface_name == null || out_count == null {
        return -1;
    }
    const iface: &ASTNode = find_interface_decl_from_program(ctx.checker.program_node, interface_name);
    if iface == null {
        return -1;
    }
    var i: i32 = 0;
    while i < iface.interface_decl_method_sig_count {
        const sig: &ASTNode = iface.interface_decl_method_sigs[i];
        if sig != null && exec_lower_add_unique_decl(out_decls, out_count, sig) != 0 {
            return -1;
        }
        i = i + 1;
    }
    i = 0;
    while i < iface.interface_decl_composed_count {
        const composed_name: &byte = iface.interface_decl_composed_interfaces[i];
        if composed_name != null &&
            exec_lower_collect_interface_method_sigs_recursive(ctx, composed_name, out_decls, out_count) != 0 {
            return -1;
        }
        i = i + 1;
    }
    return 0;
}

fn exec_lower_collect_interface_method_sigs(ctx: &ExecLowerContext, interface_type: &Type, out_decls: & & ASTNode, out_count: &i32) i32 {
    const interface_name: &byte = type_get_interface_name(interface_type);
    if interface_name == null {
        return -1;
    }
    return exec_lower_collect_interface_method_sigs_recursive(ctx, interface_name, out_decls, out_count);
}

fn exec_lower_interface_method_index(ctx: &ExecLowerContext, interface_type: &Type, method_name: &byte) i32 {
    if ctx == null || method_name == null {
        return -1;
    }
    var sigs: [&ASTNode: EXEC_MAX_INTERFACE_METHODS] = [];
    var sig_count: i32 = 0;
    if exec_lower_collect_interface_method_sigs(ctx, interface_type, &sigs[0] as & & ASTNode, &sig_count) != 0 {
        return -1;
    }
    var i: i32 = 0;
    while i < sig_count {
        const sig: &ASTNode = sigs[i];
        if sig != null && sig.fn_decl_name != null && str_equals(sig.fn_decl_name, method_name) != 0 {
            return i;
        }
        i = i + 1;
    }
    return -1;
}

fn exec_lower_struct_field_type(ctx: &ExecLowerContext, struct_type: Type, field_name: &byte) Type {
    const struct_name: &byte = type_get_struct_name(&struct_type);
    if ctx == null || ctx.checker == null || ctx.checker.program_node == null ||
        struct_name == null || field_name == null {
        return make_void_type();
    }
    const struct_decl: &ASTNode = find_struct_decl_from_program(ctx.checker.program_node, struct_name);
    if struct_decl == null {
        return make_void_type();
    }
    return find_struct_field_type(ctx.checker, struct_decl, field_name);
}

fn exec_lower_make_addr_expr(ctx: &ExecLowerContext, ast_node: &ASTNode, pointee_type: &Type) &HIRExpr {
    if pointee_type == null {
        return null;
    }
    const pointer_type: Type = exec_lower_make_pointer_type_copy(ctx, pointee_type[0]);
    return exec_lower_alloc_expr(ctx, ast_node, HIRExprKind.HIR_EXPR_ADDR, &pointer_type);
}

fn exec_lower_make_ref_expr(ctx: &ExecLowerContext, expr: &ASTNode) &HIRExpr {
    if ctx == null || expr == null {
        return null;
    }
    const expr_type: Type = exec_lower_expr_type(ctx, expr);
    if expr.type == ASTNodeType.AST_IDENTIFIER && expr.identifier_name != null {
        const local_slot: i32 = exec_lower_find_slot(ctx, expr.identifier_name);
        if local_slot >= 0 && local_slot < EXEC_MAX_LOCALS {
            const addr_local: &HIRExpr = exec_lower_make_addr_expr(ctx, expr, &ctx.slot_types[local_slot]);
            if addr_local == null {
                return null;
            }
            addr_local.local_slot = local_slot;
            return addr_local;
        }
        const global_slot: i32 = exec_lower_find_global_slot(ctx, expr.identifier_name);
        if global_slot >= 0 && global_slot < EXEC_MAX_GLOBALS {
            const addr_global: &HIRExpr = exec_lower_make_addr_expr(ctx, expr, &ctx.global_types[global_slot]);
            if addr_global == null {
                return null;
            }
            addr_global.global_slot = global_slot;
            return addr_global;
        }
    }
    if expr.type == ASTNodeType.AST_MEMBER_ACCESS && expr.member_access_object != null && expr.member_access_field_name != null {
        const object_raw_type: Type = exec_lower_expr_type(ctx, expr.member_access_object);
        var base_type: Type = exec_lower_member_base_type(ctx, expr.member_access_object);
        const field_type: Type = exec_lower_expr_type(ctx, expr);
        if base_type.kind == TypeKind.TYPE_POINTER && base_type.pointer_to != null {
            base_type = base_type.pointer_to[0];
        }
        var field_index: i32 = -1;
        if base_type.kind == TypeKind.TYPE_TUPLE {
            field_index = atoi(expr.member_access_field_name as *byte);
        } else {
            field_index = exec_lower_struct_field_index(ctx, base_type, expr.member_access_field_name);
        }
        if field_index < 0 {
            return null;
        }
        var base_ref: &HIRExpr = null;
        if object_raw_type.kind == TypeKind.TYPE_POINTER {
            base_ref = exec_lower_expr(ctx, expr.member_access_object);
        } else {
            base_ref = exec_lower_make_ref_expr(ctx, expr.member_access_object);
        }
        if base_ref == null {
            base_ref = exec_lower_expr(ctx, expr.member_access_object);
        }
        if base_ref == null {
            return null;
        }
        const addr_field: &HIRExpr = exec_lower_make_addr_expr(ctx, expr, &field_type);
        if addr_field == null {
            return null;
        }
        addr_field.left = base_ref;
        addr_field.int_value = field_index as i64;
        return addr_field;
    }
    if expr.type == ASTNodeType.AST_ARRAY_ACCESS && expr.array_access_array != null && expr.array_access_index != null {
        const array_raw_type: Type = exec_lower_expr_type(ctx, expr.array_access_array);
        var base_expr: &HIRExpr = null;
        if array_raw_type.kind == TypeKind.TYPE_POINTER {
            base_expr = exec_lower_expr(ctx, expr.array_access_array);
        } else {
            base_expr = exec_lower_make_ref_expr(ctx, expr.array_access_array);
        }
        if base_expr == null {
            base_expr = exec_lower_expr(ctx, expr.array_access_array);
        }
        const index_expr: &HIRExpr = exec_lower_expr(ctx, expr.array_access_index);
        if base_expr == null || index_expr == null {
            return null;
        }
        const addr_index: &HIRExpr = exec_lower_make_addr_expr(ctx, expr, &expr_type);
        if addr_index == null {
            return null;
        }
        addr_index.left = base_expr;
        addr_index.right = index_expr;
        return addr_index;
    }
    const source_expr: &HIRExpr = exec_lower_expr(ctx, expr);
    if source_expr == null {
        return null;
    }
    const addr_value: &HIRExpr = exec_lower_make_addr_expr(ctx, expr, &expr_type);
    if addr_value == null {
        return null;
    }
    addr_value.left = source_expr;
    return addr_value;
}

fn exec_lower_method_receiver_expr(ctx: &ExecLowerContext, object_expr: &ASTNode, method_decl: &ASTNode) &HIRExpr {
    if ctx == null || object_expr == null || method_decl == null ||
        method_decl.type != ASTNodeType.AST_FN_DECL ||
        method_decl.fn_decl_param_count <= 0 || method_decl.fn_decl_params == null {
        return null;
    }
    const receiver_param: &ASTNode = method_decl.fn_decl_params[0];
    if receiver_param == null || receiver_param.type != ASTNodeType.AST_VAR_DECL || receiver_param.var_decl_type == null {
        return null;
    }
    const receiver_type: Type = type_from_ast(ctx.checker, receiver_param.var_decl_type);
    const object_type: Type = exec_lower_expr_type(ctx, object_expr);
    if receiver_type.kind == TypeKind.TYPE_POINTER {
        if object_type.kind == TypeKind.TYPE_POINTER {
            return exec_lower_expr(ctx, object_expr);
        }
        return exec_lower_make_ref_expr(ctx, object_expr);
    }
    return exec_lower_expr(ctx, object_expr);
}

fn exec_lower_collect_interface_dispatch_decls(ctx: &ExecLowerContext, interface_type: &Type, concrete_type: &Type, out_decls: & & ASTNode, out_count: &i32) i32 {
    const struct_name: &byte = type_get_struct_name(concrete_type);
    if ctx == null || ctx.checker == null || ctx.checker.program_node == null || struct_name == null || out_count == null {
        return -1;
    }
    var sigs: [&ASTNode: EXEC_MAX_INTERFACE_METHODS] = [];
    var sig_count: i32 = 0;
    if exec_lower_collect_interface_method_sigs(ctx, interface_type, &sigs[0] as & & ASTNode, &sig_count) != 0 {
        return -1;
    }
    var i: i32 = 0;
    while i < sig_count {
        const sig: &ASTNode = sigs[i];
        if sig == null || sig.fn_decl_name == null {
            return -1;
        }
        const impl_decl: &ASTNode = find_instance_method_in_struct(ctx.checker.program_node, struct_name, sig.fn_decl_name);
        if impl_decl == null {
            return -1;
        }
        out_decls[i] = impl_decl;
        i = i + 1;
    }
    out_count[0] = sig_count;
    return 0;
}

fn exec_lower_box_interface_expr(ctx: &ExecLowerContext, expr: &ASTNode, interface_type: &Type) &HIRExpr {
    if ctx == null || expr == null {
        return null;
    }
    var actual_type: Type = exec_lower_expr_type(ctx, expr);
    if actual_type.kind == TypeKind.TYPE_VOID {
        actual_type = exec_lower_member_base_type(ctx, expr);
    }
    if actual_type.kind == TypeKind.TYPE_INTERFACE && type_equals(actual_type, interface_type[0]) != 0 {
        return exec_lower_expr(ctx, expr);
    }
    if actual_type.kind != TypeKind.TYPE_STRUCT ||
        actual_type.struct_name == null ||
        interface_type.kind != TypeKind.TYPE_INTERFACE ||
        interface_type.interface_name == null ||
        struct_implements_interface(ctx.checker, actual_type.struct_name, interface_type.interface_name) == 0 {
        return exec_lower_fail_expr(expr, "exec: 无法装箱为 interface" as *byte);
    }
    var dispatch_buf: [&ASTNode: EXEC_MAX_INTERFACE_METHODS] = [];
    var dispatch_count: i32 = 0;
    if exec_lower_collect_interface_dispatch_decls(ctx, interface_type, &actual_type, &dispatch_buf[0] as & & ASTNode, &dispatch_count) != 0 {
        return exec_lower_fail_expr(expr, "exec: interface 方法表构建失败" as *byte);
    }
    const dispatch_decls: & & ASTNode = compiler_arena_alloc(ctx.arena, @size_of(&ASTNode) * dispatch_count as usize) as & & ASTNode;
    if dispatch_count > 0 && dispatch_decls == null {
        exec_backend_set_error(expr, "exec: interface dispatch 表分配失败" as *byte, 0);
        return null;
    }
    var di: i32 = 0;
    while di < dispatch_count {
        dispatch_decls[di] = dispatch_buf[di];
        di = di + 1;
    }
    const source_ref: &HIRExpr = exec_lower_make_ref_expr(ctx, expr);
    var source_expr: &HIRExpr = source_ref;
    if source_expr == null {
        source_expr = exec_lower_expr(ctx, expr);
    }
    if source_expr == null {
        return null;
    }
    const boxed: &HIRExpr = exec_lower_alloc_expr(ctx, expr, HIRExprKind.HIR_EXPR_INTERFACE_BOX, interface_type);
    if boxed == null {
        return null;
    }
    boxed.left = source_expr;
    boxed.dispatch_decls = dispatch_decls;
    boxed.dispatch_decl_count = dispatch_count;
    return boxed;
}

fn exec_lower_coerce_expr(ctx: &ExecLowerContext, expr: &ASTNode, expected_type: &Type) &HIRExpr {
    if ctx == null || expr == null {
        return null;
    }
    if expected_type != null && expr.type == ASTNodeType.AST_INT_LIMIT && is_integer_type(expected_type.kind) != 0 {
        expr.int_limit_resolved_kind = expected_type.kind;
        var int_limit_ok: i32 = 0;
        const int_limit_value: i64 = exec_lower_eval_int_limit(expr, expected_type.kind, &int_limit_ok);
        if int_limit_ok != 0 {
            return exec_lower_make_int_const_expr(ctx, expr, expected_type, int_limit_value);
        }
    }
    var actual_type: Type = exec_lower_expr_type(ctx, expr);
    if actual_type.kind == TypeKind.TYPE_VOID {
        actual_type = exec_lower_member_base_type(ctx, expr);
    }
    if expected_type != null &&
        expected_type.kind == TypeKind.TYPE_INTERFACE && expected_type.interface_name != null &&
        actual_type.kind == TypeKind.TYPE_STRUCT && actual_type.struct_name != null &&
        struct_implements_interface(ctx.checker, actual_type.struct_name, expected_type.interface_name) != 0 {
        return exec_lower_box_interface_expr(ctx, expr, expected_type);
    }
    return exec_lower_expr(ctx, expr);
}

fn exec_lower_struct_field_index(ctx: &ExecLowerContext, struct_type: Type, field_name: &byte) i32 {
    const struct_name: &byte = type_get_struct_name(&struct_type);
    if ctx == null || ctx.checker == null || ctx.checker.program_node == null ||
        struct_type.kind != TypeKind.TYPE_STRUCT || struct_name == null || field_name == null {
        return -1;
    }
    const struct_decl: &ASTNode = find_struct_decl_from_program(ctx.checker.program_node, struct_name);
    if struct_decl == null || struct_decl.struct_decl_fields == null {
        return -1;
    }
    var fi: i32 = 0;
    while fi < struct_decl.struct_decl_field_count {
        const field: &ASTNode = struct_decl.struct_decl_fields[fi];
        if field != null && field.var_decl_name != null && str_equals(field.var_decl_name, field_name) != 0 {
            return fi;
        }
        fi = fi + 1;
    }
    return -1;
}

fn exec_lower_union_variant_index(ctx: &ExecLowerContext, union_type: Type, variant_name: &byte) i32 {
    const union_name: &byte = type_get_union_name(&union_type);
    if ctx == null || ctx.checker == null || ctx.checker.program_node == null ||
        union_name == null || variant_name == null {
        return -1;
    }
    const union_decl: &ASTNode = find_union_decl_from_program(ctx.checker.program_node, union_name);
    if union_decl == null || union_decl.union_decl_variants == null {
        return -1;
    }
    var i: i32 = 0;
    while i < union_decl.union_decl_variant_count {
        const variant_decl: &ASTNode = union_decl.union_decl_variants[i];
        if variant_decl != null && variant_decl.type == ASTNodeType.AST_VAR_DECL &&
            variant_decl.var_decl_name != null && str_equals(variant_decl.var_decl_name, variant_name) != 0 {
            return i;
        }
        i = i + 1;
    }
    return -1;
}

fn exec_lower_union_variant_type(ctx: &ExecLowerContext, union_type: Type, variant_name: &byte) Type {
    const union_name: &byte = type_get_union_name(&union_type);
    if ctx == null || ctx.checker == null || ctx.checker.program_node == null || union_name == null {
        return make_void_type();
    }
    const union_decl: &ASTNode = find_union_decl_from_program(ctx.checker.program_node, union_name);
    if union_decl == null || union_decl.union_decl_variants == null {
        return make_void_type();
    }
    var i: i32 = 0;
    while i < union_decl.union_decl_variant_count {
        const variant_decl: &ASTNode = union_decl.union_decl_variants[i];
        if variant_decl != null && variant_decl.type == ASTNodeType.AST_VAR_DECL &&
            variant_decl.var_decl_name != null && str_equals(variant_decl.var_decl_name, variant_name) != 0 &&
            variant_decl.var_decl_type != null {
            return type_from_ast(ctx.checker, variant_decl.var_decl_type);
        }
        i = i + 1;
    }
    return make_void_type();
}

fn exec_lower_try_union_ctor_expr(ctx: &ExecLowerContext, expr: &ASTNode, expr_type: &Type) &HIRExpr {
    if ctx == null || expr == null || expr.type != ASTNodeType.AST_CALL_EXPR ||
        expr.call_expr_callee == null || expr.call_expr_callee.type != ASTNodeType.AST_MEMBER_ACCESS {
        return null;
    }
    const callee: &ASTNode = expr.call_expr_callee;
    const object: &ASTNode = callee.member_access_object;
    var union_name: &byte = null;
    if object != null && object.type == ASTNodeType.AST_IDENTIFIER && object.identifier_name != null {
        union_name = object.identifier_name;
    } else if object != null && object.type == ASTNodeType.AST_TYPE_NAMED && object.type_named_name != null {
        union_name = object.type_named_name;
    }
    if union_name == null || callee.member_access_field_name == null || ctx.checker == null || ctx.checker.program_node == null {
        return null;
    }
    const union_decl: &ASTNode = find_union_decl_from_program(ctx.checker.program_node, union_name);
    if union_decl == null {
        return null;
    }
    const variant_index: i32 = exec_lower_union_variant_index(ctx, expr_type[0], callee.member_access_field_name);
    if variant_index < 0 {
        return null;
    }
    const variant_type: Type = exec_lower_union_variant_type(ctx, expr_type[0], callee.member_access_field_name);
    var payload_expr: &HIRExpr = null;
    if variant_type.kind == TypeKind.TYPE_VOID {
        if expr.call_expr_arg_count != 0 {
            return exec_lower_fail_expr(expr, "exec: union void 变体当前仅支持空参数构造" as *byte);
        }
    } else {
        if expr.call_expr_arg_count != 1 || expr.call_expr_args == null {
            return exec_lower_fail_expr(expr, "exec: union 变体当前仅支持单参数构造" as *byte);
        }
        payload_expr = exec_lower_expr(ctx, expr.call_expr_args[0]);
        if payload_expr == null {
            return null;
        }
    }
    const hir_union: &HIRExpr = exec_lower_alloc_expr(ctx, expr, HIRExprKind.HIR_EXPR_UNION_INIT, expr_type);
    if hir_union == null {
        return null;
    }
    hir_union.int_value = variant_index as i64;
    hir_union.left = payload_expr;
    return hir_union;
}

fn exec_lower_alloc_items(ctx: &ExecLowerContext, count: i32) & & HIRExpr {
    if count <= 0 {
        return null;
    }
    return compiler_arena_alloc(ctx.arena, @size_of(&HIRExpr) * count as usize) as & & HIRExpr;
}

fn exec_lower_expr_list(ctx: &ExecLowerContext, exprs: & & ASTNode, count: i32) & & HIRExpr {
    const items: & & HIRExpr = exec_lower_alloc_items(ctx, count);
    if count > 0 && items == null {
        exec_backend_set_error(ctx.function_decl, "exec: HIR expr 列表分配失败" as *byte, 0);
        return null;
    }
    var i: i32 = 0;
    while i < count {
        const item: &HIRExpr = exec_lower_expr(ctx, exprs[i]);
        if item == null {
            return null;
        }
        items[i] = item;
        i = i + 1;
    }
    return items;
}

fn exec_lower_member_base_type(ctx: &ExecLowerContext, object: &ASTNode) Type {
    var base_type: Type = exec_lower_expr_type(ctx, object);
    if base_type.kind == TypeKind.TYPE_STRUCT && type_get_struct_name(&base_type) != null {
        return base_type;
    }
    if base_type.kind == TypeKind.TYPE_POINTER && base_type.pointer_to != null {
        return base_type.pointer_to[0];
    }
    if object != null && object.type == ASTNodeType.AST_IDENTIFIER && object.identifier_name != null {
        const symbol: &Symbol = symbol_table_lookup(ctx.checker, object.identifier_name);
        if symbol != null {
            if symbol.type.kind == TypeKind.TYPE_POINTER && symbol.type.pointer_to != null {
                return symbol.type.pointer_to[0];
            }
            return symbol.type;
        }
        const slot: i32 = exec_lower_find_slot(ctx, object.identifier_name);
        if slot >= 0 && slot < EXEC_MAX_LOCALS {
            if ctx.slot_types[slot].kind == TypeKind.TYPE_POINTER && ctx.slot_types[slot].pointer_to != null {
                return ctx.slot_types[slot].pointer_to[0];
            }
            return ctx.slot_types[slot];
        }
        const global_slot: i32 = exec_lower_find_global_slot(ctx, object.identifier_name);
        if global_slot >= 0 && global_slot < EXEC_MAX_GLOBALS {
            if ctx.global_types[global_slot].kind == TypeKind.TYPE_POINTER && ctx.global_types[global_slot].pointer_to != null {
                return ctx.global_types[global_slot].pointer_to[0];
            }
            return ctx.global_types[global_slot];
        }
    }
    if object != null && object.type == ASTNodeType.AST_MEMBER_ACCESS &&
        object.member_access_object != null && object.member_access_field_name != null {
        var parent_type: Type = exec_lower_member_base_type(ctx, object.member_access_object);
        if parent_type.kind == TypeKind.TYPE_POINTER && parent_type.pointer_to != null {
            parent_type = parent_type.pointer_to[0];
        }
        if parent_type.kind == TypeKind.TYPE_TUPLE && parent_type.tuple_element_types != null {
            const tuple_index: i32 = atoi(object.member_access_field_name as *byte);
            if tuple_index >= 0 && tuple_index < parent_type.tuple_count {
                return parent_type.tuple_element_types[tuple_index];
            }
        }
        if parent_type.kind == TypeKind.TYPE_STRUCT {
            const field_type: Type = exec_lower_struct_field_type(ctx, parent_type, object.member_access_field_name);
            if field_type.kind != TypeKind.TYPE_VOID {
                return field_type;
            }
        }
    }
    return base_type;
}

fn exec_lower_make_assign_stmt(ctx: &ExecLowerContext, ast_node: &ASTNode, slot: i32, value: &HIRExpr) &HIRStmt {
    const stmt: &HIRStmt = exec_lower_alloc_stmt(ctx, ast_node, HIRStmtKind.HIR_STMT_ASSIGN);
    if stmt == null {
        return null;
    }
    if value == null {
        exec_backend_set_error(ast_node, "exec: assign 语句值为空" as *byte, 0);
        return null;
    }
    const target: &HIRExpr = exec_lower_make_local_expr(ctx, ast_node, slot, &value.type_ref.type);
    if target == null {
        return null;
    }
    stmt.local_slot = slot;
    stmt.assign_target = target;
    stmt.assign_expr = value;
    return stmt;
}

fn exec_lower_make_dest_expr(ctx: &ExecLowerContext, expr: &ASTNode) &HIRExpr {
    if ctx == null || expr == null {
        return null;
    }
    if expr.type == ASTNodeType.AST_IDENTIFIER {
        return exec_lower_expr(ctx, expr);
    }
    if expr.type == ASTNodeType.AST_MEMBER_ACCESS {
        return exec_lower_expr(ctx, expr);
    }
    if expr.type == ASTNodeType.AST_ARRAY_ACCESS {
        return exec_lower_expr(ctx, expr);
    }
    return exec_lower_fail_expr(expr, "exec: 当前仅支持局部变量/字段/下标赋值" as *byte);
}

fn exec_lower_wrap_block_as_stmt(ctx: &ExecLowerContext, ast_node: &ASTNode, block: &HIRBlock) &HIRStmt {
    const stmt: &HIRStmt = exec_lower_alloc_stmt(ctx, ast_node, HIRStmtKind.HIR_STMT_IF);
    if stmt == null {
        return null;
    }
    const cond: &HIRExpr = exec_lower_make_bool_const_expr(ctx, ast_node, 1);
    if cond == null {
        return null;
    }
    stmt.expr = cond;
    stmt.then_block = block;
    return stmt;
}

fn exec_lower_wrap_stmt_node_as_block(ctx: &ExecLowerContext, stmt_node: &ASTNode) &HIRBlock {
    if ctx == null || stmt_node == null {
        return null;
    }
    if stmt_node.type == ASTNodeType.AST_BLOCK {
        return exec_lower_block(ctx, stmt_node);
    }
    const synthetic_block: &ASTNode = compiler_arena_alloc(ctx.arena, @size_of(ASTNode)) as &ASTNode;
    const synthetic_stmts: & & ASTNode = compiler_arena_alloc(ctx.arena, @size_of(&ASTNode)) as & & ASTNode;
    if synthetic_block == null || synthetic_stmts == null {
        exec_backend_set_error(stmt_node, "exec: defer/errdefer synthetic block 分配失败" as *byte, 0);
        return null;
    }
    _ = memset(synthetic_block as *byte, 0, @size_of(ASTNode));
    synthetic_block.type = ASTNodeType.AST_BLOCK;
    synthetic_block.line = stmt_node.line;
    synthetic_block.column = stmt_node.column;
    synthetic_block.filename = stmt_node.filename;
    synthetic_block.block_stmts = synthetic_stmts;
    synthetic_block.block_stmt_count = 1;
    synthetic_stmts[0] = stmt_node;
    return exec_lower_block(ctx, synthetic_block);
}

fn exec_lower_make_break_block(ctx: &ExecLowerContext, ast_node: &ASTNode) &HIRBlock {
    const block: &HIRBlock = compiler_arena_alloc(ctx.arena, @size_of(HIRBlock)) as &HIRBlock;
    const stmts: & & HIRStmt = compiler_arena_alloc(ctx.arena, @size_of(&HIRStmt)) as & & HIRStmt;
    const stmt: &HIRStmt = exec_lower_alloc_stmt(ctx, ast_node, HIRStmtKind.HIR_STMT_BREAK);
    if block == null || stmts == null || stmt == null {
        exec_backend_set_error(ast_node, "exec: break block 分配失败" as *byte, 0);
        return null;
    }
    _ = memset(block as *byte, 0, @size_of(HIRBlock));
    stmts[0] = stmt;
    block.stmts = stmts;
    block.stmt_count = 1;
    return block;
}

fn exec_lower_make_for_range_stmt(ctx: &ExecLowerContext, stmt_node: &ASTNode) &HIRStmt {
    if stmt_node == null || stmt_node.for_stmt_is_range == 0 {
        return null;
    }
    if stmt_node.for_stmt_var_name == null {
        exec_backend_set_generic_unsupported_error(stmt_node, "exec: 当前 for range 必须显式绑定迭代变量" as *byte);
        return null;
    }
    if stmt_node.for_stmt_is_ref != 0 {
        exec_backend_set_generic_unsupported_error(stmt_node, "exec: 当前不支持 for range 引用绑定" as *byte);
        return null;
    }
    if stmt_node.for_stmt_range_end == null {
        exec_backend_set_generic_unsupported_error(stmt_node, "exec: 当前不支持无上界 for range" as *byte);
        return null;
    }
    const start_expr: &HIRExpr = exec_lower_expr(ctx, stmt_node.for_stmt_range_start);
    const end_expr: &HIRExpr = exec_lower_expr(ctx, stmt_node.for_stmt_range_end);
    if start_expr == null || end_expr == null {
        return null;
    }
    if start_expr.type_ref.type.kind != TypeKind.TYPE_I32 || end_expr.type_ref.type.kind != TypeKind.TYPE_I32 {
        exec_backend_set_generic_unsupported_error(stmt_node, "exec: 当前仅支持 i32 for range" as *byte);
        return null;
    }

    exec_lower_push_scope(ctx);
    const iter_type: Type = make_i32_type();
    const iter_slot: i32 = exec_lower_append_local(ctx, stmt_node.for_stmt_var_name, &iter_type, 0);
    const end_slot: i32 = exec_lower_append_local(ctx, "__exec_for_end" as *byte, &iter_type, 0);
    if iter_slot < 0 || end_slot < 0 {
        exec_lower_pop_scope(ctx);
        exec_backend_set_error(stmt_node, "exec: for range 槽位不足" as *byte, 0);
        return null;
    }

    const user_body: &HIRBlock = exec_lower_block(ctx, stmt_node.for_stmt_body);
    if user_body == null {
        exec_lower_pop_scope(ctx);
        return null;
    }

    const loop_body: &HIRBlock = compiler_arena_alloc(ctx.arena, @size_of(HIRBlock)) as &HIRBlock;
    const loop_stmts: & & HIRStmt = compiler_arena_alloc(ctx.arena, @size_of(&HIRStmt)) as & & HIRStmt;
    if loop_body == null || loop_stmts == null {
        exec_lower_pop_scope(ctx);
        exec_backend_set_error(stmt_node, "exec: for loop body 分配失败" as *byte, 0);
        return null;
    }
    _ = memset(loop_body as *byte, 0, @size_of(HIRBlock));

    const iter_local_for_cond: &HIRExpr = exec_lower_make_local_expr(ctx, stmt_node, iter_slot, &iter_type);
    const end_local_for_cond: &HIRExpr = exec_lower_make_local_expr(ctx, stmt_node, end_slot, &iter_type);
    const cond_type: Type = make_bool_type();
    const cond_expr: &HIRExpr = exec_lower_make_binary_expr(ctx, stmt_node, TokenType.TOKEN_LESS as i32, iter_local_for_cond, end_local_for_cond, &cond_type);
    const then_block: &HIRBlock = compiler_arena_alloc(ctx.arena, @size_of(HIRBlock)) as &HIRBlock;
    const then_stmts: & & HIRStmt = compiler_arena_alloc(ctx.arena, @size_of(&HIRStmt) * 2 as usize) as & & HIRStmt;
    const break_block: &HIRBlock = exec_lower_make_break_block(ctx, stmt_node);
    if cond_expr == null || then_block == null || then_stmts == null || break_block == null {
        exec_lower_pop_scope(ctx);
        exec_backend_set_error(stmt_node, "exec: for 条件块分配失败" as *byte, 0);
        return null;
    }
    _ = memset(then_block as *byte, 0, @size_of(HIRBlock));

    const wrapped_user_body: &HIRStmt = exec_lower_wrap_block_as_stmt(ctx, stmt_node.for_stmt_body, user_body);
    const one_expr: &HIRExpr = exec_lower_alloc_expr(ctx, stmt_node, HIRExprKind.HIR_EXPR_CONST, &iter_type);
    const iter_local_for_inc: &HIRExpr = exec_lower_make_local_expr(ctx, stmt_node, iter_slot, &iter_type);
    if wrapped_user_body == null || one_expr == null || iter_local_for_inc == null {
        exec_lower_pop_scope(ctx);
        return null;
    }
    one_expr.int_value = 1;
    const next_iter_expr: &HIRExpr = exec_lower_make_binary_expr(ctx, stmt_node, TokenType.TOKEN_PLUS as i32, iter_local_for_inc, one_expr, &iter_type);
    const inc_stmt: &HIRStmt = exec_lower_make_assign_stmt(ctx, stmt_node, iter_slot, next_iter_expr);
    if inc_stmt == null {
        exec_lower_pop_scope(ctx);
        return null;
    }
    then_stmts[0] = wrapped_user_body;
    then_stmts[1] = inc_stmt;
    then_block.stmts = then_stmts;
    then_block.stmt_count = 2;

    const cond_stmt: &HIRStmt = exec_lower_alloc_stmt(ctx, stmt_node, HIRStmtKind.HIR_STMT_IF);
    if cond_stmt == null {
        exec_lower_pop_scope(ctx);
        return null;
    }
    cond_stmt.expr = cond_expr;
    cond_stmt.then_block = then_block;
    cond_stmt.else_block = break_block;
    loop_stmts[0] = cond_stmt;
    loop_body.stmts = loop_stmts;
    loop_body.stmt_count = 1;

    const loop_stmt: &HIRStmt = exec_lower_alloc_stmt(ctx, stmt_node, HIRStmtKind.HIR_STMT_LOOP);
    const setup_block: &HIRBlock = compiler_arena_alloc(ctx.arena, @size_of(HIRBlock)) as &HIRBlock;
    const setup_stmts: & & HIRStmt = compiler_arena_alloc(ctx.arena, @size_of(&HIRStmt) * 3 as usize) as & & HIRStmt;
    const init_iter: &HIRStmt = exec_lower_alloc_stmt(ctx, stmt_node, HIRStmtKind.HIR_STMT_VAR_INIT);
    const init_end: &HIRStmt = exec_lower_alloc_stmt(ctx, stmt_node, HIRStmtKind.HIR_STMT_VAR_INIT);
    if loop_stmt == null || setup_block == null || setup_stmts == null || init_iter == null || init_end == null {
        exec_lower_pop_scope(ctx);
        exec_backend_set_error(stmt_node, "exec: for setup block 分配失败" as *byte, 0);
        return null;
    }
    loop_stmt.loop_body = loop_body;
    init_iter.local_slot = iter_slot;
    init_iter.expr = start_expr;
    init_end.local_slot = end_slot;
    init_end.expr = end_expr;
    _ = memset(setup_block as *byte, 0, @size_of(HIRBlock));
    setup_stmts[0] = init_iter;
    setup_stmts[1] = init_end;
    setup_stmts[2] = loop_stmt;
    setup_block.stmts = setup_stmts;
    setup_block.stmt_count = 3;

    const result_stmt: &HIRStmt = exec_lower_wrap_block_as_stmt(ctx, stmt_node, setup_block);
    exec_lower_pop_scope(ctx);
    return result_stmt;
}

fn exec_lower_global_name(decl: &ASTNode) &byte {
    if decl == null {
        return null;
    }
    if decl.type == ASTNodeType.AST_VAR_DECL {
        return decl.var_decl_name;
    }
    if decl.type == ASTNodeType.AST_EXTERN_VAR_DECL {
        return decl.extern_var_decl_name;
    }
    return null;
}

fn exec_lower_global_type_ast(decl: &ASTNode) &ASTNode {
    if decl == null {
        return null;
    }
    if decl.type == ASTNodeType.AST_VAR_DECL {
        return decl.var_decl_type;
    }
    if decl.type == ASTNodeType.AST_EXTERN_VAR_DECL {
        return decl.extern_var_decl_var_type;
    }
    return null;
}

fn exec_lower_global_init_ast(decl: &ASTNode) &ASTNode {
    if decl == null {
        return null;
    }
    if decl.type == ASTNodeType.AST_VAR_DECL {
        return decl.var_decl_init;
    }
    if decl.type == ASTNodeType.AST_EXTERN_VAR_DECL {
        return decl.extern_var_decl_init_expr;
    }
    return null;
}

fn exec_lower_global_is_const(decl: &ASTNode) i32 {
    if decl == null {
        return 0;
    }
    if decl.type == ASTNodeType.AST_VAR_DECL {
        return decl.var_decl_is_const;
    }
    if decl.type == ASTNodeType.AST_EXTERN_VAR_DECL {
        return decl.extern_var_decl_is_const;
    }
    return 0;
}

fn exec_lower_global_is_runtime_decl(decl: &ASTNode) i32 {
    if decl == null {
        return 0;
    }
    if decl.type == ASTNodeType.AST_VAR_DECL {
        return (decl.var_decl_name != null) as i32;
    }
    if decl.type == ASTNodeType.AST_EXTERN_VAR_DECL && decl.extern_var_decl_is_extern == 0 {
        return (decl.extern_var_decl_name != null) as i32;
    }
    return 0;
}

fn exec_lower_decl_is_uya_root_runtime(checker: &TypeChecker, decl: &ASTNode) i32 {
    if checker == null || decl == null || decl.filename == null || checker.uya_root_dir == null {
        return 0;
    }
    const root_len: i32 = strlen(checker.uya_root_dir as *byte) as i32;
    if root_len <= 0 {
        return 0;
    }
    return (strncmp(decl.filename as *byte, checker.uya_root_dir as *byte, root_len) == 0) as i32;
}

fn exec_lower_find_module_export_decl(checker: &TypeChecker, module_name: &byte, item_name: &byte, item_type: i32) &ASTNode {
    if checker == null || module_name == null || item_name == null {
        return null;
    }
    var mh: u32 = hash_string(module_name);
    var mi: i32 = (mh as i32) & (MODULE_TABLE_SIZE - 1);
    var i: i32 = 0;
    while i < MODULE_TABLE_SIZE {
        const slot: i32 = (mi + i) & (MODULE_TABLE_SIZE - 1);
        const module: &ModuleInfo = checker.module_table.slots[slot];
        if module == null {
            break;
        }
        if module.module_name != null && str_equals(module.module_name, module_name) != 0 {
            if module.exports != null {
                var ei: i32 = 0;
                while ei < module.export_count {
                    const export_item: &ExportedItem = &module.exports[ei];
                    if export_item.name != null && str_equals(export_item.name, item_name) != 0 {
                        if item_type == 0 || export_item.item_type == item_type {
                            return export_item.decl_node;
                        }
                    }
                    ei = ei + 1;
                }
            }
            break;
        }
        i = i + 1;
    }
    if str_equals(module_name, "libc" as &byte) != 0 {
        var slot_i: i32 = 0;
        while slot_i < MODULE_TABLE_SIZE {
            const module2: &ModuleInfo = checker.module_table.slots[slot_i];
            if module2 != null && module2.filename != null &&
                (strstr(module2.filename as *byte, "/lib/libc/" as *byte) != null ||
                 strstr(module2.filename as *byte, "lib/libc/" as *byte) != null ||
                 strstr(module2.filename as *byte, "\\lib\\libc\\" as *byte) != null) {
                if module2.exports != null {
                    var export_i: i32 = 0;
                    while export_i < module2.export_count {
                        const export_item2: &ExportedItem = &module2.exports[export_i];
                        if export_item2.name != null && str_equals(export_item2.name, item_name) != 0 {
                            if item_type == 0 || export_item2.item_type == item_type {
                                return export_item2.decl_node;
                            }
                        }
                        export_i = export_i + 1;
                    }
                }
            }
            slot_i = slot_i + 1;
        }
    }
    return null;
}

fn exec_lower_resolve_imported_decl(checker: &TypeChecker, local_name: &byte, item_type: i32) &ASTNode {
    if checker == null || local_name == null {
        return null;
    }
    const imported_item: &ImportedItem = checker_import_table_lookup_local_name(checker, local_name);
    if imported_item == null || imported_item.item_type == (0 - 1) ||
        imported_item.original_name == null || imported_item.module_name == null {
        return null;
    }
    if item_type != 0 && imported_item.item_type != 0 && imported_item.item_type != item_type {
        return null;
    }
    return exec_lower_find_module_export_decl(checker, imported_item.module_name, imported_item.original_name, item_type);
}

fn exec_lower_use_stmt_module_name_equals(use_stmt: &ASTNode, module_name: &byte) i32 {
    if use_stmt == null || use_stmt.type != ASTNodeType.AST_USE_STMT || module_name == null ||
        use_stmt.use_stmt_path_segments == null || use_stmt.use_stmt_path_segment_count <= 0 {
        return 0;
    }
    var i: i32 = 0;
    var module_pos: i32 = 0;
    while i < use_stmt.use_stmt_path_segment_count {
        const segment: &byte = use_stmt.use_stmt_path_segments[i];
        if segment == null {
            return 0;
        }
        var seg_pos: i32 = 0;
        while segment[seg_pos] != 0 as byte {
            if module_name[module_pos] != segment[seg_pos] {
                return 0;
            }
            seg_pos = seg_pos + 1;
            module_pos = module_pos + 1;
        }
        if i + 1 < use_stmt.use_stmt_path_segment_count {
            if module_name[module_pos] != 46 {
                return 0;
            }
            module_pos = module_pos + 1;
        }
        i = i + 1;
    }
    return (module_name[module_pos] == 0 as byte) as i32;
}

fn exec_lower_resolve_module_alias_from_file(checker: &TypeChecker, filename: &byte, local_name: &byte) &byte {
    if checker == null || checker.program_node == null || checker.program_node.type != ASTNodeType.AST_PROGRAM ||
        filename == null || local_name == null {
        return null;
    }
    var i: i32 = 0;
    while i < checker.program_node.program_decl_count {
        const decl: &ASTNode = checker.program_node.program_decls[i];
        if decl != null && decl.type == ASTNodeType.AST_USE_STMT &&
            decl.filename != null && str_equals(decl.filename, filename) != 0 &&
            decl.use_stmt_item_name == null &&
            decl.use_stmt_path_segments != null && decl.use_stmt_path_segment_count > 0 {
            var local_name_candidate: &byte = decl.use_stmt_alias;
            if local_name_candidate == null {
                local_name_candidate = decl.use_stmt_path_segments[decl.use_stmt_path_segment_count - 1];
            }
            if local_name_candidate != null && str_equals(local_name_candidate, local_name) != 0 {
                const module_name_len: i32 = exec_lower_joined_module_name_len(decl.use_stmt_path_segments, decl.use_stmt_path_segment_count);
                if module_name_len > 0 {
                    const module_name: &byte = compiler_arena_alloc(checker.arena, module_name_len as usize + 1 as usize) as &byte;
                    if module_name != null {
                        exec_lower_write_joined_module_name(module_name, decl.use_stmt_path_segments, decl.use_stmt_path_segment_count);
                        return module_name;
                    }
                }
            }
        }
        i = i + 1;
    }
    return null;
}

fn exec_lower_joined_module_name_len(segments: & & byte, count: i32) i32 {
    if segments == null || count <= 0 {
        return 0;
    }
    var total: i32 = 0;
    var i: i32 = 0;
    while i < count {
        if segments[i] == null {
            return 0;
        }
        total = total + (strlen(segments[i] as *byte) as i32);
        if i + 1 < count {
            total = total + 1;
        }
        i = i + 1;
    }
    return total;
}

fn exec_lower_write_joined_module_name(out_name: &byte, segments: & & byte, count: i32) void {
    if out_name == null || segments == null || count <= 0 {
        return;
    }
    var pos: i32 = 0;
    var i: i32 = 0;
    while i < count {
        const segment: &byte = segments[i];
        var si: i32 = 0;
        while segment != null && segment[si] != 0 as byte {
            out_name[pos] = segment[si];
            pos = pos + 1;
            si = si + 1;
        }
        if i + 1 < count {
            out_name[pos] = 46;
            pos = pos + 1;
        }
        i = i + 1;
    }
    out_name[pos] = 0 as byte;
}

fn exec_lower_resolve_function_decl(checker: &TypeChecker, callee_name: &byte) &ASTNode {
    if checker == null || callee_name == null {
        return null;
    }
    var decl: &ASTNode = exec_lower_resolve_imported_decl(checker, callee_name, 1);
    if decl != null && decl.type == ASTNodeType.AST_FN_DECL && decl.fn_decl_name != null {
        const reachable_decl: &ASTNode = checker_find_reachable_fn_decl_by_name(checker, decl.fn_decl_name);
        if reachable_decl != null && reachable_decl.type == ASTNodeType.AST_FN_DECL {
            return reachable_decl;
        }
        return decl;
    }
    decl = checker_find_reachable_fn_decl_by_name(checker, callee_name);
    if decl != null && decl.type == ASTNodeType.AST_FN_DECL {
        return decl;
    }
    decl = find_fn_decl_from_program(checker.program_node, callee_name);
    if decl != null && decl.type == ASTNodeType.AST_FN_DECL {
        return checker_canonicalize_fn_decl(checker, decl);
    }
    return null;
}

fn exec_lower_resolve_global_decl(checker: &TypeChecker, name: &byte) &ASTNode {
    if checker == null || name == null {
        return null;
    }
    const imported_decl: &ASTNode = exec_lower_resolve_imported_decl(checker, name, 10);
    if imported_decl != null {
        return imported_decl;
    }
    const symbol: &Symbol = symbol_table_lookup(checker, name);
    if symbol != null && exec_lower_global_is_runtime_decl(symbol.decl_node) != 0 {
        return symbol.decl_node;
    }
    return null;
}

fn exec_lower_find_enum_variant_value(enum_decl: &ASTNode, variant_name: &byte) i32 {
    if enum_decl == null || enum_decl.type != ASTNodeType.AST_ENUM_DECL || variant_name == null ||
        enum_decl.enum_decl_variants == null {
        return -1;
    }
    var current_value: i32 = 0;
    var i: i32 = 0;
    while i < enum_decl.enum_decl_variant_count {
        const variant: &EnumVariant = enum_decl.enum_decl_variants + i;
        if variant == null || variant.name == null {
            i = i + 1;
            continue;
        }
        if variant.value != null {
            current_value = atoi(variant.value as *byte);
        }
        if str_equals(variant.name, variant_name) != 0 {
            return current_value;
        }
        current_value = current_value + 1;
        i = i + 1;
    }
    return -1;
}

fn exec_lower_try_enum_member_const(ctx: &ExecLowerContext, expr: &ASTNode, out_found: &i32) i32 {
    if out_found != null {
        out_found[0] = 0;
    }
    if ctx == null || ctx.checker == null || ctx.checker.program_node == null ||
        expr == null || expr.type != ASTNodeType.AST_MEMBER_ACCESS ||
        expr.member_access_object == null || expr.member_access_field_name == null {
        return -1;
    }
    const object: &ASTNode = expr.member_access_object;
    if object.type != ASTNodeType.AST_IDENTIFIER || object.identifier_name == null {
        return -1;
    }
    const enum_decl: &ASTNode = find_enum_decl_from_program(ctx.checker.program_node, object.identifier_name);
    if enum_decl == null {
        return -1;
    }
    const value: i32 = exec_lower_find_enum_variant_value(enum_decl, expr.member_access_field_name);
    if value < 0 {
        return -1;
    }
    if out_found != null {
        out_found[0] = 1;
    }
    return value;
}

fn exec_lower_eval_int_limit(expr: &ASTNode, fallback_kind: TypeKind, out_ok: &i32) i64 {
    if out_ok != null {
        out_ok[0] = 0;
    }
    if expr == null || expr.type != ASTNodeType.AST_INT_LIMIT {
        return 0;
    }
    var kind: TypeKind = fallback_kind;
    if expr.int_limit_resolved_kind != 0 {
        const kind_tmp: !TypeKind = expr.int_limit_resolved_kind as! TypeKind;
        kind = kind_tmp.value;
    }
    if is_integer_type(kind) == 0 {
        return 0;
    }
    if out_ok != null {
        out_ok[0] = 1;
    }
    if kind == TypeKind.TYPE_I8 {
        if expr.int_limit_is_max != 0 { return 127; }
        return 0 - 128;
    }
    if kind == TypeKind.TYPE_I16 {
        if expr.int_limit_is_max != 0 { return 32767; }
        return 0 - 32768;
    }
    if kind == TypeKind.TYPE_I32 {
        if expr.int_limit_is_max != 0 { return 2147483647; }
        return 0 - 2147483647 - 1;
    }
    if kind == TypeKind.TYPE_I64 {
        if expr.int_limit_is_max != 0 { return 9223372036854775807; }
        return 0 - 9223372036854775807 - 1;
    }
    if kind == TypeKind.TYPE_U8 || kind == TypeKind.TYPE_BYTE {
        if expr.int_limit_is_max != 0 { return 255; }
        return 0;
    }
    if kind == TypeKind.TYPE_U16 {
        if expr.int_limit_is_max != 0 { return 65535; }
        return 0;
    }
    if kind == TypeKind.TYPE_U32 {
        if expr.int_limit_is_max != 0 { return 4294967295; }
        return 0;
    }
    if kind == TypeKind.TYPE_U64 || kind == TypeKind.TYPE_USIZE {
        if expr.int_limit_is_max != 0 { return 0 - 1; }
        return 0;
    }
    if out_ok != null {
        out_ok[0] = 0;
    }
    return 0;
}

fn exec_lower_append_global_slot(checker: &TypeChecker, decl: &ASTNode, globals: &HIRGlobalSlot, out_count: &i32, allow_uya_root_runtime: i32) i32 {
    if checker == null || decl == null || globals == null || out_count == null {
        return -1;
    }
    if allow_uya_root_runtime == 0 && exec_lower_decl_is_uya_root_runtime(checker, decl) != 0 {
        return 0;
    }
    if out_count[0] >= EXEC_MAX_GLOBALS {
        exec_backend_set_error(decl, "exec: global 数量超出上限" as *byte, 0);
        return -1;
    }
    const global_type_ast: &ASTNode = exec_lower_global_type_ast(decl);
    if global_type_ast == null {
        exec_backend_set_error(decl, "exec: global 缺少类型" as *byte, 0);
        return -1;
    }
    const global_type: Type = type_from_ast(checker, global_type_ast);
    if exec_type_is_vm_value_supported(global_type) == 0 {
        if exec_type_uses_simd(global_type) != 0 {
            exec_lower_set_unsupported_reason(decl, "exec: 当前不支持 SIMD" as *byte, ExecUnsupportedReason.EXEC_UNSUPPORTED_SIMD);
            return -1;
        }
        exec_lower_set_unsupported(decl, "exec: 当前仅支持 exec VM 可表示的全局变量" as *byte);
        return -1;
    }
    globals[out_count[0]] = HIRGlobalSlot {
        name: exec_lower_global_name(decl),
        decl: decl,
        slot: out_count[0],
        type_ref: exec_lower_make_type_ref(&global_type),
        is_const: exec_lower_global_is_const(decl),
        init_expr: null,
    };
    out_count[0] = out_count[0] + 1;
    return 0;
}

fn exec_lower_collect_global_slots_from_program(checker: &TypeChecker, program: &ASTNode, globals: &HIRGlobalSlot, out_count: &i32) i32 {
    if checker == null || program == null || globals == null || out_count == null {
        return -1;
    }
    if program.type != ASTNodeType.AST_PROGRAM {
        return 0;
    }
    var decl_idx: i32 = 0;
    while decl_idx < program.program_decl_count {
        const decl: &ASTNode = program.program_decls[decl_idx];
        if decl != null && decl.type == ASTNodeType.AST_PROGRAM {
            if exec_lower_collect_global_slots_from_program(checker, decl, globals, out_count) != 0 {
                return -1;
            }
        } else if exec_lower_global_is_runtime_decl(decl) != 0 {
            if exec_lower_append_global_slot(checker, decl, globals, out_count, 0) != 0 {
                return -1;
            }
        }
        decl_idx = decl_idx + 1;
    }
    return 0;
}

fn exec_lower_collect_global_slots_from_symbols(checker: &TypeChecker, globals: &HIRGlobalSlot, out_count: &i32) i32 {
    if checker == null || globals == null || out_count == null {
        return -1;
    }
    var scope: i32 = 0;
    while scope < @len(checker.scope_heads) {
        var symbol: &Symbol = checker.scope_heads[scope];
        while symbol != null {
            if exec_lower_global_is_runtime_decl(symbol.decl_node) != 0 &&
                exec_lower_find_global_slot_by_decl_in_globals(globals, out_count[0], symbol.decl_node) < 0 {
                if exec_lower_append_global_slot(checker, symbol.decl_node, globals, out_count, 0) != 0 {
                    return -1;
                }
            }
            symbol = symbol.next_in_scope;
        }
        scope = scope + 1;
    }
    return 0;
}

fn exec_lower_collect_global_slots_from_symbol_table(checker: &TypeChecker, globals: &HIRGlobalSlot, out_count: &i32) i32 {
    if checker == null || globals == null || out_count == null {
        return -1;
    }
    var slot: i32 = 0;
    while slot < SYMBOL_TABLE_SIZE {
        const symbol: &Symbol = checker.symbol_table.slots[slot];
        if symbol != null &&
            exec_lower_global_is_runtime_decl(symbol.decl_node) != 0 &&
            exec_lower_find_global_slot_by_decl_in_globals(globals, out_count[0], symbol.decl_node) < 0 {
            if exec_lower_append_global_slot(checker, symbol.decl_node, globals, out_count, 0) != 0 {
                return -1;
            }
        }
        slot = slot + 1;
    }
    return 0;
}

fn exec_lower_collect_global_slots_from_imports(checker: &TypeChecker, globals: &HIRGlobalSlot, out_count: &i32) i32 {
    if checker == null || globals == null || out_count == null {
        return -1;
    }
    var slot: i32 = 0;
    while slot < IMPORT_TABLE_SIZE {
        const import_item: &ImportedItem = checker.import_table.slots[slot];
        if import_item != null && import_item.item_type != (0 - 1) && import_item.local_name != null {
            const decl: &ASTNode = exec_lower_resolve_global_decl(checker, import_item.local_name);
            if decl != null && exec_lower_find_global_slot_by_decl_in_globals(globals, out_count[0], decl) < 0 {
                if exec_lower_append_global_slot(checker, decl, globals, out_count, 1) != 0 {
                    return -1;
                }
            }
        }
        slot = slot + 1;
    }
    return 0;
}

fn exec_lower_add_requested_module_global_name(out_names: & & byte, out_count: &i32, name: &byte) void {
    if out_names == null || out_count == null || name == null {
        return;
    }
    var i: i32 = 0;
    while i < out_count[0] {
        if out_names[i] != null && str_equals(out_names[i], name) != 0 {
            return;
        }
        i = i + 1;
    }
    if out_count[0] >= EXEC_MAX_MODULE_GLOBAL_REQUESTS {
        return;
    }
    out_names[out_count[0]] = name;
    out_count[0] = out_count[0] + 1;
}

fn exec_lower_collect_module_global_use_names_expr(checker: &TypeChecker, expr: &ASTNode, module_name: &byte, out_names: & & byte, out_count: &i32) void {
    if checker == null || expr == null || module_name == null || out_names == null || out_count == null {
        return;
    }
    if expr.type == ASTNodeType.AST_MEMBER_ACCESS {
        var resolved_module_name: &byte = null;
        if expr.member_access_is_module_access != 0 && expr.member_access_module_name != null {
            resolved_module_name = expr.member_access_module_name;
        } else if expr.member_access_object != null &&
            expr.member_access_object.type == ASTNodeType.AST_IDENTIFIER &&
            expr.member_access_object.identifier_name != null {
            const imported_item: &ImportedItem = checker_import_table_lookup_local_name(checker, expr.member_access_object.identifier_name);
            if imported_item != null && imported_item.item_type == (0 - 1) && imported_item.module_name != null {
                resolved_module_name = imported_item.module_name;
            }
            if resolved_module_name == null && expr.filename != null {
                resolved_module_name = exec_lower_resolve_module_alias_from_file(
                    checker, expr.filename, expr.member_access_object.identifier_name);
            }
        }
        if resolved_module_name != null && expr.member_access_field_name != null &&
            str_equals(resolved_module_name, module_name) != 0 {
            exec_lower_add_requested_module_global_name(out_names, out_count, expr.member_access_field_name);
        }
        exec_lower_collect_module_global_use_names_expr(checker, expr.member_access_object, module_name, out_names, out_count);
        return;
    }
    if expr.type == ASTNodeType.AST_CALL_EXPR {
        exec_lower_collect_module_global_use_names_expr(checker, expr.call_expr_callee, module_name, out_names, out_count);
        if expr.call_expr_args != null {
            var i: i32 = 0;
            while i < expr.call_expr_arg_count {
                exec_lower_collect_module_global_use_names_expr(checker, expr.call_expr_args[i], module_name, out_names, out_count);
                i = i + 1;
            }
        }
        return;
    }
    if expr.type == ASTNodeType.AST_ARRAY_ACCESS {
        exec_lower_collect_module_global_use_names_expr(checker, expr.array_access_array, module_name, out_names, out_count);
        exec_lower_collect_module_global_use_names_expr(checker, expr.array_access_index, module_name, out_names, out_count);
        return;
    }
    if expr.type == ASTNodeType.AST_BINARY_EXPR {
        exec_lower_collect_module_global_use_names_expr(checker, expr.binary_expr_left, module_name, out_names, out_count);
        exec_lower_collect_module_global_use_names_expr(checker, expr.binary_expr_right, module_name, out_names, out_count);
        return;
    }
    if expr.type == ASTNodeType.AST_UNARY_EXPR {
        exec_lower_collect_module_global_use_names_expr(checker, expr.unary_expr_operand, module_name, out_names, out_count);
        return;
    }
    if expr.type == ASTNodeType.AST_CAST_EXPR {
        exec_lower_collect_module_global_use_names_expr(checker, expr.cast_expr_expr, module_name, out_names, out_count);
        return;
    }
    if expr.type == ASTNodeType.AST_SLICE_EXPR {
        exec_lower_collect_module_global_use_names_expr(checker, expr.slice_expr_base, module_name, out_names, out_count);
        exec_lower_collect_module_global_use_names_expr(checker, expr.slice_expr_start_expr, module_name, out_names, out_count);
        exec_lower_collect_module_global_use_names_expr(checker, expr.slice_expr_len_expr, module_name, out_names, out_count);
        return;
    }
    if expr.type == ASTNodeType.AST_TRY_EXPR {
        exec_lower_collect_module_global_use_names_expr(checker, expr.try_expr_operand, module_name, out_names, out_count);
        return;
    }
    if expr.type == ASTNodeType.AST_CATCH_EXPR {
        exec_lower_collect_module_global_use_names_expr(checker, expr.catch_expr_operand, module_name, out_names, out_count);
        return;
    }
    if expr.type == ASTNodeType.AST_MATCH_EXPR {
        exec_lower_collect_module_global_use_names_expr(checker, expr.match_expr_expr, module_name, out_names, out_count);
        if expr.match_expr_arms != null {
            var mi: i32 = 0;
            while mi < expr.match_expr_arm_count {
                exec_lower_collect_module_global_use_names_expr(checker, expr.match_expr_arms[mi].result_expr, module_name, out_names, out_count);
                mi = mi + 1;
            }
        }
        return;
    }
    if expr.type == ASTNodeType.AST_STRUCT_INIT && expr.struct_init_field_values != null {
        var si: i32 = 0;
        while si < expr.struct_init_field_count {
            exec_lower_collect_module_global_use_names_expr(checker, expr.struct_init_field_values[si], module_name, out_names, out_count);
            si = si + 1;
        }
        return;
    }
    if expr.type == ASTNodeType.AST_ARRAY_LITERAL && expr.array_literal_elements != null {
        var ai: i32 = 0;
        while ai < expr.array_literal_element_count {
            exec_lower_collect_module_global_use_names_expr(checker, expr.array_literal_elements[ai], module_name, out_names, out_count);
            ai = ai + 1;
        }
        exec_lower_collect_module_global_use_names_expr(checker, expr.array_literal_repeat_count_expr, module_name, out_names, out_count);
        return;
    }
    if expr.type == ASTNodeType.AST_TUPLE_LITERAL && expr.tuple_literal_elements != null {
        var ti: i32 = 0;
        while ti < expr.tuple_literal_element_count {
            exec_lower_collect_module_global_use_names_expr(checker, expr.tuple_literal_elements[ti], module_name, out_names, out_count);
            ti = ti + 1;
        }
        return;
    }
    if expr.type == ASTNodeType.AST_LEN {
        exec_lower_collect_module_global_use_names_expr(checker, expr.len_expr_array, module_name, out_names, out_count);
        return;
    }
    if expr.type == ASTNodeType.AST_PTR_FROM_USIZE {
        exec_lower_collect_module_global_use_names_expr(checker, expr.ptr_from_usize_value, module_name, out_names, out_count);
        return;
    }
    if expr.type == ASTNodeType.AST_USIZE_FROM_PTR {
        exec_lower_collect_module_global_use_names_expr(checker, expr.usize_from_ptr_ptr, module_name, out_names, out_count);
        return;
    }
    if expr.type == ASTNodeType.AST_PRINT || expr.type == ASTNodeType.AST_PRINTLN {
        exec_lower_collect_module_global_use_names_expr(checker, expr.print_expr, module_name, out_names, out_count);
        return;
    }
}

fn exec_lower_collect_module_global_use_names_node(checker: &TypeChecker, node: &ASTNode, module_name: &byte, out_names: & & byte, out_count: &i32) void {
    if checker == null || node == null || module_name == null || out_names == null || out_count == null {
        return;
    }
    exec_lower_collect_module_global_use_names_expr(checker, node, module_name, out_names, out_count);
    if node.type == ASTNodeType.AST_PROGRAM && node.program_decls != null {
        var i: i32 = 0;
        while i < node.program_decl_count {
            exec_lower_collect_module_global_use_names_node(checker, node.program_decls[i], module_name, out_names, out_count);
            i = i + 1;
        }
        return;
    }
    if node.type == ASTNodeType.AST_BLOCK && node.block_stmts != null {
        var bi: i32 = 0;
        while bi < node.block_stmt_count {
            exec_lower_collect_module_global_use_names_node(checker, node.block_stmts[bi], module_name, out_names, out_count);
            bi = bi + 1;
        }
        return;
    }
    if node.type == ASTNodeType.AST_IF_STMT {
        exec_lower_collect_module_global_use_names_node(checker, node.if_stmt_condition, module_name, out_names, out_count);
        exec_lower_collect_module_global_use_names_node(checker, node.if_stmt_then_branch, module_name, out_names, out_count);
        exec_lower_collect_module_global_use_names_node(checker, node.if_stmt_else_branch, module_name, out_names, out_count);
        return;
    }
    if node.type == ASTNodeType.AST_WHILE_STMT {
        exec_lower_collect_module_global_use_names_node(checker, node.while_stmt_condition, module_name, out_names, out_count);
        exec_lower_collect_module_global_use_names_node(checker, node.while_stmt_body, module_name, out_names, out_count);
        return;
    }
    if node.type == ASTNodeType.AST_FOR_STMT {
        exec_lower_collect_module_global_use_names_node(checker, node.for_stmt_range_start, module_name, out_names, out_count);
        exec_lower_collect_module_global_use_names_node(checker, node.for_stmt_range_end, module_name, out_names, out_count);
        exec_lower_collect_module_global_use_names_node(checker, node.for_stmt_array, module_name, out_names, out_count);
        exec_lower_collect_module_global_use_names_node(checker, node.for_stmt_body, module_name, out_names, out_count);
        return;
    }
    if node.type == ASTNodeType.AST_VAR_DECL {
        exec_lower_collect_module_global_use_names_node(checker, node.var_decl_init, module_name, out_names, out_count);
        return;
    }
    if node.type == ASTNodeType.AST_EXTERN_VAR_DECL {
        exec_lower_collect_module_global_use_names_node(checker, node.extern_var_decl_init_expr, module_name, out_names, out_count);
        return;
    }
    if node.type == ASTNodeType.AST_RETURN_STMT {
        exec_lower_collect_module_global_use_names_node(checker, node.return_stmt_expr, module_name, out_names, out_count);
        return;
    }
    if node.type == ASTNodeType.AST_ASSIGN {
        exec_lower_collect_module_global_use_names_node(checker, node.assign_dest, module_name, out_names, out_count);
        exec_lower_collect_module_global_use_names_node(checker, node.assign_src, module_name, out_names, out_count);
        return;
    }
    if node.type == ASTNodeType.AST_DEFER_STMT {
        exec_lower_collect_module_global_use_names_node(checker, node.defer_stmt_body, module_name, out_names, out_count);
        return;
    }
    if node.type == ASTNodeType.AST_ERRDEFER_STMT {
        exec_lower_collect_module_global_use_names_node(checker, node.errdefer_stmt_body, module_name, out_names, out_count);
        return;
    }
    if node.type == ASTNodeType.AST_TEST_STMT {
        exec_lower_collect_module_global_use_names_node(checker, node.test_stmt_body, module_name, out_names, out_count);
        return;
    }
}

fn exec_lower_collect_global_slots_from_module_import(checker: &TypeChecker, module_name: &byte, requested_names: & & byte, requested_count: i32, globals: &HIRGlobalSlot, out_count: &i32) i32 {
    if checker == null || module_name == null || requested_names == null || globals == null || out_count == null {
        return -1;
    }
    if str_equals(module_name, "libc" as &byte) != 0 {
        exec_lower_add_requested_module_global_name(requested_names, &requested_count, "stdin" as &byte);
        exec_lower_add_requested_module_global_name(requested_names, &requested_count, "stdout" as &byte);
        exec_lower_add_requested_module_global_name(requested_names, &requested_count, "stderr" as &byte);
    }
    var ri: i32 = 0;
    while ri < requested_count {
        if requested_names[ri] != null {
            const export_decl: &ASTNode = exec_lower_find_module_export_decl(checker, module_name, requested_names[ri], 10);
            if export_decl != null &&
                exec_lower_global_is_runtime_decl(export_decl) != 0 &&
                exec_lower_find_global_slot_by_decl_in_globals(globals, out_count[0], export_decl) < 0 {
                const export_type_ast: &ASTNode = exec_lower_global_type_ast(export_decl);
                if export_type_ast != null {
                    const export_type: Type = type_from_ast(checker, export_type_ast);
                    if exec_type_is_vm_value_supported(export_type) != 0 {
                        if exec_lower_append_global_slot(checker, export_decl, globals, out_count, 1) != 0 {
                            return -1;
                        }
                    }
                }
                if checker.program_node != null && checker.program_node.type == ASTNodeType.AST_PROGRAM && export_decl.filename != null {
                    var decl_i: i32 = 0;
                    while decl_i < checker.program_node.program_decl_count {
                        const decl2: &ASTNode = checker.program_node.program_decls[decl_i];
                        if decl2 != null && decl2.filename != null &&
                            str_equals(decl2.filename, export_decl.filename) != 0 &&
                            exec_lower_global_is_runtime_decl(decl2) != 0 &&
                            exec_lower_find_global_slot_by_decl_in_globals(globals, out_count[0], decl2) < 0 {
                            const decl2_type_ast: &ASTNode = exec_lower_global_type_ast(decl2);
                            if decl2_type_ast != null {
                                const decl2_type: Type = type_from_ast(checker, decl2_type_ast);
                                if exec_type_is_vm_value_supported(decl2_type) != 0 {
                                    if exec_lower_append_global_slot(checker, decl2, globals, out_count, 1) != 0 {
                                        return -1;
                                    }
                                }
                            }
                        }
                        decl_i = decl_i + 1;
                    }
                }
            }
        }
        ri = ri + 1;
    }
    return 0;
}

fn exec_lower_collect_global_slots_from_module_imports(checker: &TypeChecker, globals: &HIRGlobalSlot, out_count: &i32) i32 {
    if checker == null || globals == null || out_count == null {
        return -1;
    }
    var slot: i32 = 0;
    while slot < IMPORT_TABLE_SIZE {
        const import_item: &ImportedItem = checker.import_table.slots[slot];
        if import_item != null && import_item.item_type == (0 - 1) && import_item.module_name != null {
            var requested_names: [&byte: EXEC_MAX_MODULE_GLOBAL_REQUESTS] = [];
            var requested_count: i32 = 0;
            exec_lower_collect_module_global_use_names_node(checker, checker.program_node, import_item.module_name, &requested_names[0] as & & byte, &requested_count);
            if exec_lower_collect_global_slots_from_module_import(checker, import_item.module_name, &requested_names[0] as & & byte, requested_count, globals, out_count) != 0 {
                return -1;
            }
        }
        slot = slot + 1;
    }
    return 0;
}

fn exec_lower_collect_global_slots_from_use_stmts(checker: &TypeChecker, globals: &HIRGlobalSlot, out_count: &i32) i32 {
    if checker == null || checker.program_node == null || checker.program_node.type != ASTNodeType.AST_PROGRAM ||
        globals == null || out_count == null {
        return -1;
    }
    var decl_i: i32 = 0;
    while decl_i < checker.program_node.program_decl_count {
        const decl: &ASTNode = checker.program_node.program_decls[decl_i];
        if decl != null && decl.type == ASTNodeType.AST_USE_STMT &&
            decl.use_stmt_item_name == null &&
            decl.use_stmt_path_segments != null && decl.use_stmt_path_segment_count > 0 {
            const module_name_len: i32 = exec_lower_joined_module_name_len(decl.use_stmt_path_segments, decl.use_stmt_path_segment_count);
            if module_name_len > 0 {
                const module_name: &byte = compiler_arena_alloc(checker.arena, module_name_len as usize + 1 as usize) as &byte;
                if module_name != null {
                    exec_lower_write_joined_module_name(module_name, decl.use_stmt_path_segments, decl.use_stmt_path_segment_count);
                    var requested_names: [&byte: EXEC_MAX_MODULE_GLOBAL_REQUESTS] = [];
                    var requested_count: i32 = 0;
                    exec_lower_collect_module_global_use_names_node(checker, checker.program_node, module_name, &requested_names[0] as & & byte, &requested_count);
                    if exec_lower_collect_global_slots_from_module_import(checker, module_name, &requested_names[0] as & & byte, requested_count, globals, out_count) != 0 {
                        return -1;
                    }
                }
            }
        }
        decl_i = decl_i + 1;
    }
    return 0;
}

fn exec_lower_find_global_slot_by_decl_in_globals(globals: &HIRGlobalSlot, global_count: i32, decl: &ASTNode) i32 {
    if globals == null || decl == null {
        return -1;
    }
    var i: i32 = 0;
    while i < global_count {
        if globals[i].decl == decl {
            return i;
        }
        i = i + 1;
    }
    return -1;
}

fn exec_lower_collect_global_slots(arena: &CompilerArena, checker: &TypeChecker, program: &ASTNode, out_count: &i32) &HIRGlobalSlot {
    if out_count != null {
        out_count[0] = 0;
    }
    if arena == null || checker == null || program == null || program.type != ASTNodeType.AST_PROGRAM {
        return null;
    }
    const globals: &HIRGlobalSlot = compiler_arena_alloc(arena, @size_of(HIRGlobalSlot) * EXEC_MAX_GLOBALS as usize) as &HIRGlobalSlot;
    if globals == null {
        exec_backend_set_error(program, "exec: global slot 表分配失败" as *byte, 0);
        return null;
    }
    var count: i32 = 0;
    if exec_lower_collect_global_slots_from_program(checker, program, globals, &count) != 0 {
        return null;
    }
    if exec_lower_collect_global_slots_from_symbols(checker, globals, &count) != 0 {
        return null;
    }
    if exec_lower_collect_global_slots_from_symbol_table(checker, globals, &count) != 0 {
        return null;
    }
    if exec_lower_collect_global_slots_from_imports(checker, globals, &count) != 0 {
        return null;
    }
    if exec_lower_collect_global_slots_from_module_imports(checker, globals, &count) != 0 {
        return null;
    }
    if exec_lower_collect_global_slots_from_use_stmts(checker, globals, &count) != 0 {
        return null;
    }
    if out_count != null {
        out_count[0] = count;
    }
    return globals;
}

fn exec_lower_collect_called_decls_from_expr(expr: &HIRExpr, out_decls: & & ASTNode, out_count: &i32) void {
    if expr == null || out_count == null {
        return;
    }
    if expr.kind == HIRExprKind.HIR_EXPR_CALL && expr.callee_decl != null &&
        expr.callee_decl.type == ASTNodeType.AST_FN_DECL &&
        expr.callee_decl.fn_decl_body != null &&
        expr.call_host_id == ExecHostCallId.EXEC_HOST_CALL_NONE &&
        exec_lower_decl_index(out_decls, out_count[0], expr.callee_decl) < 0 {
        if out_count[0] < MAX_REACHABLE_FN_DECLS {
            out_decls[out_count[0]] = expr.callee_decl;
            out_count[0] = out_count[0] + 1;
        }
    }
    if expr.kind == HIRExprKind.HIR_EXPR_INTERFACE_BOX && expr.dispatch_decls != null {
        var di: i32 = 0;
        while di < expr.dispatch_decl_count {
            const dispatch_decl: &ASTNode = expr.dispatch_decls[di];
            if dispatch_decl != null &&
                exec_lower_decl_index(out_decls, out_count[0], dispatch_decl) < 0 &&
                out_count[0] < MAX_REACHABLE_FN_DECLS {
                out_decls[out_count[0]] = dispatch_decl;
                out_count[0] = out_count[0] + 1;
            }
            di = di + 1;
        }
    }
    if expr.left != null {
        exec_lower_collect_called_decls_from_expr(expr.left, out_decls, out_count);
    }
    if expr.right != null {
        exec_lower_collect_called_decls_from_expr(expr.right, out_decls, out_count);
    }
    if expr.extra != null {
        exec_lower_collect_called_decls_from_expr(expr.extra, out_decls, out_count);
    }
    var i: i32 = 0;
    while i < expr.call_arg_count {
        exec_lower_collect_called_decls_from_expr(expr.call_args[i], out_decls, out_count);
        i = i + 1;
    }
    i = 0;
    while i < expr.item_count {
        exec_lower_collect_called_decls_from_expr(expr.items[i], out_decls, out_count);
        i = i + 1;
    }
    i = 0;
    while i < expr.match_arm_count {
        exec_lower_collect_called_decls_from_expr(expr.match_arms[i].result_expr, out_decls, out_count);
        i = i + 1;
    }
}

fn exec_lower_collect_called_decls_from_stmt(stmt: &HIRStmt, out_decls: & & ASTNode, out_count: &i32) void {
    if stmt == null {
        return;
    }
    if stmt.expr != null {
        exec_lower_collect_called_decls_from_expr(stmt.expr, out_decls, out_count);
    }
    if stmt.assign_expr != null {
        exec_lower_collect_called_decls_from_expr(stmt.assign_expr, out_decls, out_count);
    }
    if stmt.assign_target != null {
        exec_lower_collect_called_decls_from_expr(stmt.assign_target, out_decls, out_count);
    }
    if stmt.then_block != null {
        exec_lower_collect_called_decls_from_block(stmt.then_block, out_decls, out_count);
    }
    if stmt.else_block != null {
        exec_lower_collect_called_decls_from_block(stmt.else_block, out_decls, out_count);
    }
    if stmt.loop_body != null {
        exec_lower_collect_called_decls_from_block(stmt.loop_body, out_decls, out_count);
    }
    if stmt.cleanup_block != null {
        exec_lower_collect_called_decls_from_block(stmt.cleanup_block, out_decls, out_count);
    }
}

fn exec_lower_collect_called_decls_from_block(block: &HIRBlock, out_decls: & & ASTNode, out_count: &i32) void {
    if block == null || out_count == null {
        return;
    }
    var i: i32 = 0;
    while i < block.stmt_count {
        exec_lower_collect_called_decls_from_stmt(block.stmts[i], out_decls, out_count);
        i = i + 1;
    }
}

fn exec_lower_lower_global_init_exprs(arena: &CompilerArena, checker: &TypeChecker, globals: &HIRGlobalSlot, global_count: i32, seed_decls: & & ASTNode, seed_count: &i32) i32 {
    if arena == null || checker == null || seed_count == null {
        return -1;
    }
    var i: i32 = 0;
    while i < global_count {
        const decl: &ASTNode = globals[i].decl;
        const init_expr_ast: &ASTNode = exec_lower_global_init_ast(decl);
        if init_expr_ast != null {
            var ctx: ExecLowerContext = ExecLowerContext {
                arena: arena,
                checker: checker,
                function_decl: decl,
                global_names: [],
                global_decls: [],
                global_types: [],
                global_is_const: [],
                global_count: 0,
                local_names: [],
                local_slots: [],
                local_types: [],
                local_is_param: [],
                slot_names: [],
                slot_types: [],
                slot_is_param: [],
                active_local_count: 0,
                next_slot: 0,
                max_slot_count: 0,
                scope_markers: [],
                scope_depth: 0,
            };
            exec_lower_seed_globals(&ctx, globals, global_count);
            const lowered_init: &HIRExpr = exec_lower_coerce_expr(&ctx, init_expr_ast, &globals[i].type_ref.type);
            if lowered_init == null {
                return -1;
            }
            globals[i].init_expr = lowered_init;
            exec_lower_collect_called_decls_from_expr(lowered_init, seed_decls, seed_count);
        }
        i = i + 1;
    }
    return 0;
}

fn exec_lower_build_global_init_function(arena: &CompilerArena, globals: &HIRGlobalSlot, global_count: i32) &HIRFunction {
    if arena == null || globals == null || global_count <= 0 {
        return null;
    }
    var stmt_count: i32 = 0;
    var i: i32 = 0;
    while i < global_count {
        if globals[i].init_expr != null {
            stmt_count = stmt_count + 1;
        }
        i = i + 1;
    }
    if stmt_count == 0 {
        return null;
    }
    const body: &HIRBlock = compiler_arena_alloc(arena, @size_of(HIRBlock)) as &HIRBlock;
    const stmts: & & HIRStmt = compiler_arena_alloc(arena, @size_of(&HIRStmt) * stmt_count as usize) as & & HIRStmt;
    const fn_hir: &HIRFunction = compiler_arena_alloc(arena, @size_of(HIRFunction)) as &HIRFunction;
    if body == null || stmts == null || fn_hir == null {
        exec_backend_set_error(globals[0].decl, "exec: global init function 分配失败" as *byte, 0);
        return null;
    }
    _ = memset(body as *byte, 0, @size_of(HIRBlock));
    _ = memset(fn_hir as *byte, 0, @size_of(HIRFunction));
    var stmt_idx: i32 = 0;
    i = 0;
    while i < global_count {
        if globals[i].init_expr != null {
            const stmt: &HIRStmt = compiler_arena_alloc(arena, @size_of(HIRStmt)) as &HIRStmt;
            const target: &HIRExpr = compiler_arena_alloc(arena, @size_of(HIRExpr)) as &HIRExpr;
            if stmt == null || target == null {
                exec_backend_set_error(globals[i].decl, "exec: global init stmt 分配失败" as *byte, 0);
                return null;
            }
            _ = memset(stmt as *byte, 0, @size_of(HIRStmt));
            _ = memset(target as *byte, 0, @size_of(HIRExpr));
            stmt.kind = HIRStmtKind.HIR_STMT_ASSIGN;
            stmt.ast_node = globals[i].decl;
            target.kind = HIRExprKind.HIR_EXPR_GLOBAL;
            target.ast_node = globals[i].decl;
            target.type_ref = exec_lower_make_type_ref(&globals[i].type_ref.type);
            target.local_slot = -1;
            target.global_slot = globals[i].slot;
            stmt.assign_target = target;
            stmt.assign_expr = globals[i].init_expr;
            stmts[stmt_idx] = stmt;
            stmt_idx = stmt_idx + 1;
        }
        i = i + 1;
    }
    body.stmts = stmts;
    body.stmt_count = stmt_count;
    const void_type: Type = make_void_type();
    fn_hir.name = "__exec_global_init" as &byte;
    fn_hir.decl = globals[0].decl;
    fn_hir.return_type = exec_lower_make_type_ref(&void_type);
    fn_hir.locals = null;
    fn_hir.local_count = 0;
    fn_hir.param_count = 0;
    fn_hir.body = body;
    return fn_hir;
}

fn exec_lower_find_entry_decl(checker: &TypeChecker) &ASTNode {
    if checker == null {
        return null;
    }
    var fallback: &ASTNode = null;
    var i: i32 = 0;
    while i < checker.reachable_fn_decl_count {
        const decl: &ASTNode = checker.reachable_fn_decls[i];
        if decl != null &&
            decl.type == ASTNodeType.AST_FN_DECL &&
            decl.fn_decl_name != null &&
            str_equals(decl.fn_decl_name, "main" as *byte) != 0 &&
            decl.fn_decl_body != null {
            if decl.fn_decl_is_extern == 0 && decl.fn_decl_param_count == 0 {
                return decl;
            }
            if fallback == null {
                fallback = decl;
            }
        }
        i = i + 1;
    }
    return fallback;
}

fn exec_lower_decl_index(decls: & & ASTNode, decl_count: i32, target: &ASTNode) i32 {
    if decls == null || target == null {
        return -1;
    }
    var i: i32 = 0;
    while i < decl_count {
        if decls[i] == target {
            return i;
        }
        i = i + 1;
    }
    return -1;
}

fn exec_lower_expr(ctx: &ExecLowerContext, expr: &ASTNode) &HIRExpr {
    if ctx == null || expr == null {
        return null;
    }
    const expr_type: Type = exec_lower_expr_type(ctx, expr);
    if expr.type == ASTNodeType.AST_SIZEOF || expr.type == ASTNodeType.AST_ALIGNOF {
        const folded_value: i32 = checker_eval_const_expr(ctx.checker, expr);
        if folded_value < 0 {
            return exec_lower_fail_expr(expr, "exec: 编译期 builtin 折叠失败" as *byte);
        }
        return exec_lower_make_int_const_expr(ctx, expr, &expr_type, folded_value as i64);
    }
    if expr.type == ASTNodeType.AST_SRC_NAME {
        return exec_lower_make_string_const_expr(ctx, expr, &expr_type, exec_lower_basename(expr.filename));
    }
    if expr.type == ASTNodeType.AST_SRC_PATH {
        var source_path: &byte = expr.filename;
        if source_path == null {
            source_path = "(unknown)" as &byte;
        }
        return exec_lower_make_string_const_expr(ctx, expr, &expr_type, source_path);
    }
    if expr.type == ASTNodeType.AST_SRC_LINE {
        return exec_lower_make_int_const_expr(ctx, expr, &expr_type, expr.line as i64);
    }
    if expr.type == ASTNodeType.AST_SRC_COL {
        return exec_lower_make_int_const_expr(ctx, expr, &expr_type, expr.column as i64);
    }
    if expr.type == ASTNodeType.AST_FUNC_NAME {
        var func_name: &byte = "(unknown)" as &byte;
        if ctx.function_decl != null && ctx.function_decl.fn_decl_name != null {
            func_name = ctx.function_decl.fn_decl_name;
        }
        return exec_lower_make_string_const_expr(ctx, expr, &expr_type, func_name);
    }
    if expr.type == ASTNodeType.AST_INT_LIMIT {
        var int_limit_ok: i32 = 0;
        const int_limit_value: i64 = exec_lower_eval_int_limit(expr, expr_type.kind, &int_limit_ok);
        if int_limit_ok == 0 {
            return exec_lower_fail_expr(expr, "exec: @max/@min 尚未解析为可表示的整数类型" as *byte);
        }
        return exec_lower_make_int_const_expr(ctx, expr, &expr_type, int_limit_value);
    }
    if expr.type == ASTNodeType.AST_NUMBER {
        if expr_type.kind != TypeKind.TYPE_I8 &&
            expr_type.kind != TypeKind.TYPE_I16 &&
            expr_type.kind != TypeKind.TYPE_I32 &&
            expr_type.kind != TypeKind.TYPE_U32 &&
            expr_type.kind != TypeKind.TYPE_I64 &&
            expr_type.kind != TypeKind.TYPE_U64 &&
            expr_type.kind != TypeKind.TYPE_U8 &&
            expr_type.kind != TypeKind.TYPE_U16 &&
            expr_type.kind != TypeKind.TYPE_USIZE {
            return exec_lower_fail_expr(expr, "exec: 仅支持 exec VM 可表示的整数数字字面量" as *byte);
        }
        return exec_lower_make_int_const_expr(ctx, expr, &expr_type, expr.number_value_i64);
    }
    if expr.type == ASTNodeType.AST_BOOL {
        const hir: &HIRExpr = exec_lower_alloc_expr(ctx, expr, HIRExprKind.HIR_EXPR_CONST, &expr_type);
        if hir == null {
            return null;
        }
        hir.bool_value = expr.bool_literal_value;
        return hir;
    }
    if expr.type == ASTNodeType.AST_CHAR {
        const hir: &HIRExpr = exec_lower_alloc_expr(ctx, expr, HIRExprKind.HIR_EXPR_CONST, &expr_type);
        if hir == null {
            return null;
        }
        hir.int_value = expr.char_literal_value as i64;
        return hir;
    }
    if expr.type == ASTNodeType.AST_STRING {
        return exec_lower_make_string_const_expr(ctx, expr, &expr_type, expr.string_literal_value);
    }
    if expr.type == ASTNodeType.AST_STRING_INTERP {
        return exec_lower_fail_expr_reason(expr, "exec: 当前不支持字符串插值" as *byte, ExecUnsupportedReason.EXEC_UNSUPPORTED_STRING_INTERP);
    }
    if expr.type == ASTNodeType.AST_ERROR_VALUE {
        return exec_lower_make_int_const_expr(ctx, expr, &expr_type, expr_type.error_error_id as i64);
    }
    if expr.type == ASTNodeType.AST_IDENTIFIER {
        if expr.identifier_name != null &&
            str_equals(expr.identifier_name, "null" as &byte) != 0 {
            var null_type: Type = copy_type(&expr_type);
            if null_type.kind != TypeKind.TYPE_POINTER {
                null_type = exec_lower_make_void_pointer_type();
            }
            return exec_lower_make_int_const_expr(ctx, expr, &null_type, 0);
        }
        const slot: i32 = exec_lower_find_slot(ctx, expr.identifier_name);
        if slot >= 0 {
            var local_type: Type = copy_type(&expr_type);
            if slot >= 0 && slot < EXEC_MAX_LOCALS {
                local_type = ctx.slot_types[slot];
            }
            const hir_local: &HIRExpr = exec_lower_alloc_expr(ctx, expr, HIRExprKind.HIR_EXPR_LOCAL, &local_type);
            if hir_local == null {
                return null;
            }
            hir_local.local_slot = slot;
            return hir_local;
        }
        const imported_global_decl: &ASTNode = exec_lower_resolve_global_decl(ctx.checker, expr.identifier_name);
        if imported_global_decl != null {
            const global_slot_by_decl: i32 = exec_lower_find_global_slot_by_decl(ctx, imported_global_decl);
            var resolved_global_slot_by_decl: i32 = global_slot_by_decl;
            if resolved_global_slot_by_decl < 0 && expr.identifier_name != null {
                resolved_global_slot_by_decl = exec_lower_find_global_slot(ctx, expr.identifier_name);
            }
            if resolved_global_slot_by_decl >= 0 {
                var global_type_by_decl: Type = copy_type(&expr_type);
                if resolved_global_slot_by_decl >= 0 && resolved_global_slot_by_decl < EXEC_MAX_GLOBALS {
                    global_type_by_decl = ctx.global_types[resolved_global_slot_by_decl];
                }
                const hir_global_by_decl: &HIRExpr = exec_lower_alloc_expr(ctx, expr, HIRExprKind.HIR_EXPR_GLOBAL, &global_type_by_decl);
                if hir_global_by_decl == null {
                    return null;
                }
                hir_global_by_decl.global_slot = resolved_global_slot_by_decl;
                return hir_global_by_decl;
            }
            if exec_lower_global_is_const(imported_global_decl) != 0 {
                const const_init_expr: &ASTNode = exec_lower_global_init_ast(imported_global_decl);
                if const_init_expr != null && const_init_expr != expr {
                    return exec_lower_expr(ctx, const_init_expr);
                }
            }
            if imported_global_decl != null {
                const global_type_ast2: &ASTNode = exec_lower_global_type_ast(imported_global_decl);
                if global_type_ast2 != null {
                    const global_type2: Type = type_from_ast(ctx.checker, global_type_ast2);
                    if exec_type_is_vm_value_supported(global_type2) == 0 {
                        if exec_type_uses_simd(global_type2) != 0 {
                            return exec_lower_fail_expr_reason(expr, "exec: 当前不支持 SIMD 全局变量" as *byte, ExecUnsupportedReason.EXEC_UNSUPPORTED_SIMD);
                        }
                        return exec_lower_fail_expr(expr, "exec: 当前仅支持 exec VM 可表示的全局变量" as *byte);
                    }
                }
            }
        }
        const global_slot: i32 = exec_lower_find_global_slot(ctx, expr.identifier_name);
        if global_slot >= 0 {
            var global_type: Type = copy_type(&expr_type);
            if global_slot >= 0 && global_slot < EXEC_MAX_GLOBALS {
                global_type = ctx.global_types[global_slot];
            }
            const hir_global: &HIRExpr = exec_lower_alloc_expr(ctx, expr, HIRExprKind.HIR_EXPR_GLOBAL, &global_type);
            if hir_global == null {
                return null;
            }
            hir_global.global_slot = global_slot;
            return hir_global;
        }
        return exec_lower_fail_expr(expr, "exec: 当前仅支持局部变量/参数/全局标识符" as *byte);
    }
    if expr.type == ASTNodeType.AST_MEMBER_ACCESS {
        var enum_found: i32 = 0;
        const enum_value: i32 = exec_lower_try_enum_member_const(ctx, expr, &enum_found);
        if enum_found != 0 {
            return exec_lower_make_int_const_expr(ctx, expr, &expr_type, enum_value as i64);
        }
    }
    if expr.type == ASTNodeType.AST_CAST_EXPR {
        if expr.cast_expr_is_force_cast != 0 {
            return exec_lower_fail_expr_reason(expr, "exec: 当前不支持 as! cast" as *byte, ExecUnsupportedReason.EXEC_UNSUPPORTED_GENERIC);
        }
        if exec_type_is_vm_value_supported(expr_type) == 0 {
            return exec_lower_fail_expr(expr, "exec: cast 目标类型当前不可被 exec VM 表示" as *byte);
        }
        const cast_operand: &HIRExpr = exec_lower_expr(ctx, expr.cast_expr_expr);
        if cast_operand == null {
            return null;
        }
        const hir_cast: &HIRExpr = exec_lower_alloc_expr(ctx, expr, HIRExprKind.HIR_EXPR_CAST, &expr_type);
        if hir_cast == null {
            return null;
        }
        hir_cast.left = cast_operand;
        return hir_cast;
    }
    if expr.type == ASTNodeType.AST_PTR_FROM_USIZE {
        const ptr_operand: &HIRExpr = exec_lower_expr(ctx, expr.ptr_from_usize_value);
        if ptr_operand == null {
            return null;
        }
        const hir_ptr: &HIRExpr = exec_lower_alloc_expr(ctx, expr, HIRExprKind.HIR_EXPR_CAST, &expr_type);
        if hir_ptr == null {
            return null;
        }
        hir_ptr.left = ptr_operand;
        return hir_ptr;
    }
    if expr.type == ASTNodeType.AST_USIZE_FROM_PTR {
        const usize_operand: &HIRExpr = exec_lower_expr(ctx, expr.usize_from_ptr_ptr);
        if usize_operand == null {
            return null;
        }
        const hir_usize: &HIRExpr = exec_lower_alloc_expr(ctx, expr, HIRExprKind.HIR_EXPR_CAST, &expr_type);
        if hir_usize == null {
            return null;
        }
        hir_usize.left = usize_operand;
        return hir_usize;
    }
    if expr.type == ASTNodeType.AST_UNARY_EXPR {
        if (expr.unary_expr_op as TokenType) == TokenType.TOKEN_AMPERSAND {
            return exec_lower_make_ref_expr(ctx, expr.unary_expr_operand);
        }
        if exec_type_is_scalar_supported(expr_type) == 0 {
            if exec_type_uses_simd(expr_type) != 0 {
                return exec_lower_fail_expr_reason(expr, "exec: 当前不支持 SIMD" as *byte, ExecUnsupportedReason.EXEC_UNSUPPORTED_SIMD);
            }
            return exec_lower_fail_expr(expr, "exec: 不支持的 unary 结果类型" as *byte);
        }
        const operand: &HIRExpr = exec_lower_expr(ctx, expr.unary_expr_operand);
        if operand == null {
            return null;
        }
        const hir: &HIRExpr = exec_lower_alloc_expr(ctx, expr, HIRExprKind.HIR_EXPR_UNARY, &expr_type);
        if hir == null {
            return null;
        }
        hir.unary_op = expr.unary_expr_op;
        hir.left = operand;
        return hir;
    }
    if expr.type == ASTNodeType.AST_BINARY_EXPR {
        if exec_type_is_scalar_supported(expr_type) == 0 &&
            expr_type.kind != TypeKind.TYPE_BOOL {
            if exec_type_uses_simd(expr_type) != 0 {
                return exec_lower_fail_expr_reason(expr, "exec: 当前不支持 SIMD" as *byte, ExecUnsupportedReason.EXEC_UNSUPPORTED_SIMD);
            }
            return exec_lower_fail_expr(expr, "exec: 不支持的 binary 结果类型" as *byte);
        }
        const left: &HIRExpr = exec_lower_expr(ctx, expr.binary_expr_left);
        if left == null {
            return null;
        }
        const right: &HIRExpr = exec_lower_expr(ctx, expr.binary_expr_right);
        if right == null {
            return null;
        }
        const hir: &HIRExpr = exec_lower_alloc_expr(ctx, expr, HIRExprKind.HIR_EXPR_BINARY, &expr_type);
        if hir == null {
            return null;
        }
        hir.binary_op = expr.binary_expr_op;
        hir.left = left;
        hir.right = right;
        return hir;
    }
    if expr.type == ASTNodeType.AST_CALL_EXPR {
        const union_ctor: &HIRExpr = exec_lower_try_union_ctor_expr(ctx, expr, &expr_type);
        if union_ctor != null {
            return union_ctor;
        }
        if expr.call_expr_type_arg_count > 0 || expr.call_expr_has_ellipsis_forward != 0 {
            return exec_lower_fail_expr(expr, "exec: 当前不支持泛型调用或 varargs 转发" as *byte);
        }
        if expr.call_expr_arg_count > EXEC_MAX_CALL_ARGS {
            return exec_lower_fail_expr(expr, "exec: 调用参数过多" as *byte);
        }
        if exec_type_is_vm_value_supported(expr_type) == 0 {
            if exec_type_uses_simd(expr_type) != 0 {
                return exec_lower_fail_expr_reason(expr, "exec: 当前不支持 SIMD" as *byte, ExecUnsupportedReason.EXEC_UNSUPPORTED_SIMD);
            }
            return exec_lower_fail_expr(expr, "exec: 当前仅支持标量/错误联合函数返回值" as *byte);
        }
