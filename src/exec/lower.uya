            return null;
        }
        const hir_error_id: &HIRExpr = exec_lower_alloc_expr(ctx, expr, HIRExprKind.HIR_EXPR_ERROR_ID, &expr_type);
        if hir_error_id == null {
            return null;
        }
        hir_error_id.left = operand_error_id;
        return hir_error_id;
    }
    if expr.type == ASTNodeType.AST_ERROR_NAME {
        const operand_name_literal: &ASTNode = exec_lower_named_error_literal(expr.error_name_operand);
        if operand_name_literal != null {
            return exec_lower_make_string_const_expr(ctx, expr, &expr_type, operand_name_literal.error_value_name);
        }
        const operand_error_name: &HIRExpr = exec_lower_expr(ctx, expr.error_name_operand);
        if operand_error_name == null {
            return null;
        }
        const hir_error_name: &HIRExpr = exec_lower_alloc_expr(ctx, expr, HIRExprKind.HIR_EXPR_ERROR_NAME, &expr_type);
        if hir_error_name == null {
            return null;
        }
        hir_error_name.left = operand_error_name;
        return hir_error_name;
    }
    if expr.type == ASTNodeType.AST_TRY_EXPR {
        const operand: &HIRExpr = exec_lower_expr(ctx, expr.try_expr_operand);
        if operand == null {
            return null;
        }
        if operand.type_ref.type.kind != TypeKind.TYPE_ERROR_UNION {
            return exec_lower_fail_expr_reason(expr, "exec: try 操作数不是错误联合" as *byte, ExecUnsupportedReason.EXEC_UNSUPPORTED_TRY_EXPR);
        }
        const hir_try: &HIRExpr = exec_lower_alloc_expr(ctx, expr, HIRExprKind.HIR_EXPR_TRY, &expr_type);
        if hir_try == null {
            return null;
        }
        hir_try.left = operand;
        return hir_try;
    }
    if expr.type == ASTNodeType.AST_CATCH_EXPR {
        if expr.catch_expr_err_name != null {
            return exec_lower_fail_expr_reason(expr, "exec: 当前不支持带错误绑定的 catch" as *byte, ExecUnsupportedReason.EXEC_UNSUPPORTED_CATCH_EXPR);
        }
        const operand2: &HIRExpr = exec_lower_expr(ctx, expr.catch_expr_operand);
        if operand2 == null {
            return null;
        }
        if operand2.type_ref.type.kind != TypeKind.TYPE_ERROR_UNION {
            return exec_lower_fail_expr_reason(expr, "exec: catch 操作数不是错误联合" as *byte, ExecUnsupportedReason.EXEC_UNSUPPORTED_CATCH_EXPR);
        }
        const fallback_expr: &HIRExpr = exec_lower_extract_block_result_expr(ctx, expr.catch_expr_catch_block);
        if fallback_expr == null {
            return null;
        }
        const hir_catch: &HIRExpr = exec_lower_alloc_expr(ctx, expr, HIRExprKind.HIR_EXPR_CATCH, &expr_type);
        if hir_catch == null {
            return null;
        }
        hir_catch.left = operand2;
        hir_catch.right = fallback_expr;
        return hir_catch;
    }
    if expr.type == ASTNodeType.AST_MATCH_EXPR {
        if expr.match_expr_expr == null || expr.match_expr_arms == null || expr.match_expr_arm_count <= 0 {
            return exec_lower_fail_expr_reason(expr, "exec: match 结构无效" as *byte, ExecUnsupportedReason.EXEC_UNSUPPORTED_MATCH_EXPR);
        }
        const subject_expr: &HIRExpr = exec_lower_expr(ctx, expr.match_expr_expr);
        if subject_expr == null {
            return null;
        }
        if subject_expr.type_ref.type.kind == TypeKind.TYPE_UNION {
            const arms_union: &HIRMatchArm = compiler_arena_alloc(ctx.arena, @size_of(HIRMatchArm) * expr.match_expr_arm_count as usize) as &HIRMatchArm;
            if arms_union == null {
                exec_backend_set_error(expr, "exec: union match arms 分配失败" as *byte, 0);
                return null;
            }
            var umi: i32 = 0;
            while umi < expr.match_expr_arm_count {
                const arm_union: ASTMatchArm = expr.match_expr_arms[umi];
                if arm_union.kind != MatchPatternKind.MATCH_PAT_UNION &&
                    arm_union.kind != MatchPatternKind.MATCH_PAT_ELSE &&
                    arm_union.kind != MatchPatternKind.MATCH_PAT_WILDCARD {
                    return exec_lower_fail_expr_reason(expr, "exec: 当前仅支持 union/else/wildcard match" as *byte, ExecUnsupportedReason.EXEC_UNSUPPORTED_MATCH_EXPR);
                }
                var bind_slot: i32 = -1;
                var arm_result_expr2: &HIRExpr = null;
                var variant_index2: i32 = -1;
                if arm_union.kind == MatchPatternKind.MATCH_PAT_UNION {
                    variant_index2 = exec_lower_union_variant_index(ctx, subject_expr.type_ref.type, arm_union.variant_name);
                    if variant_index2 < 0 {
                        return exec_lower_fail_expr_reason(expr, "exec: union match 变体无效" as *byte, ExecUnsupportedReason.EXEC_UNSUPPORTED_MATCH_EXPR);
                    }
                    exec_lower_push_scope(ctx);
                    if arm_union.var_name != null && str_equals(arm_union.var_name, "_" as *byte) == 0 {
                        const bind_type: Type = exec_lower_union_variant_type(ctx, subject_expr.type_ref.type, arm_union.variant_name);
                        if exec_type_is_vm_value_supported(bind_type) == 0 {
                            exec_lower_pop_scope(ctx);
                            return exec_lower_fail_expr_reason(expr, "exec: union match 绑定类型当前不可表示" as *byte, ExecUnsupportedReason.EXEC_UNSUPPORTED_MATCH_EXPR);
                        }
                        bind_slot = exec_lower_append_local(ctx, arm_union.var_name, &bind_type, 0);
                        if bind_slot < 0 {
                            exec_lower_pop_scope(ctx);
                            exec_backend_set_error(expr, "exec: union match 绑定槽位不足" as *byte, 0);
                            return null;
                        }
                    }
                    if arm_union.result_is_block != 0 {
                        arm_result_expr2 = exec_lower_extract_block_result_expr(ctx, arm_union.result_expr);
                    } else {
                        arm_result_expr2 = exec_lower_expr(ctx, arm_union.result_expr);
                    }
                    exec_lower_pop_scope(ctx);
                } else {
                    if arm_union.result_is_block != 0 {
                        arm_result_expr2 = exec_lower_extract_block_result_expr(ctx, arm_union.result_expr);
                    } else {
                        arm_result_expr2 = exec_lower_expr(ctx, arm_union.result_expr);
                    }
                }
                if arm_result_expr2 == null {
                    return null;
                }
                arms_union[umi] = HIRMatchArm {
                    kind: arm_union.kind,
                    int_value: variant_index2 as i64,
                    bool_value: 0,
                    bind_local_slot: bind_slot,
                    result_expr: arm_result_expr2,
                };
                umi = umi + 1;
            }
            const hir_union_match: &HIRExpr = exec_lower_alloc_expr(ctx, expr, HIRExprKind.HIR_EXPR_MATCH, &expr_type);
            if hir_union_match == null {
                return null;
            }
            hir_union_match.left = subject_expr;
            hir_union_match.match_arms = arms_union;
            hir_union_match.match_arm_count = expr.match_expr_arm_count;
            return hir_union_match;
        }
        if exec_type_is_scalar_supported(subject_expr.type_ref.type) == 0 {
            return exec_lower_fail_expr_reason(expr, "exec: 当前仅支持标量 match" as *byte, ExecUnsupportedReason.EXEC_UNSUPPORTED_MATCH_EXPR);
        }
        const arms: &HIRMatchArm = compiler_arena_alloc(ctx.arena, @size_of(HIRMatchArm) * expr.match_expr_arm_count as usize) as &HIRMatchArm;
        if arms == null {
            exec_backend_set_error(expr, "exec: match arms 分配失败" as *byte, 0);
            return null;
        }
        var mi: i32 = 0;
        while mi < expr.match_expr_arm_count {
            const arm: ASTMatchArm = expr.match_expr_arms[mi];
            if arm.kind != MatchPatternKind.MATCH_PAT_LITERAL &&
                arm.kind != MatchPatternKind.MATCH_PAT_ELSE &&
                arm.kind != MatchPatternKind.MATCH_PAT_WILDCARD {
                return exec_lower_fail_expr_reason(expr, "exec: 当前仅支持 literal/else/wildcard match" as *byte, ExecUnsupportedReason.EXEC_UNSUPPORTED_MATCH_EXPR);
            }
            var arm_result_expr: &HIRExpr = null;
            if arm.result_is_block != 0 {
                arm_result_expr = exec_lower_extract_block_result_expr(ctx, arm.result_expr);
            } else {
                arm_result_expr = exec_lower_expr(ctx, arm.result_expr);
            }
            if arm_result_expr == null {
                return null;
            }
            arms[mi] = HIRMatchArm {
                kind: arm.kind,
                int_value: arm.literal_int_value as i64,
                bool_value: arm.literal_is_bool,
                bind_local_slot: -1,
                result_expr: arm_result_expr,
            };
            mi = mi + 1;
        }
        const hir_match: &HIRExpr = exec_lower_alloc_expr(ctx, expr, HIRExprKind.HIR_EXPR_MATCH, &expr_type);
        if hir_match == null {
            return null;
        }
        hir_match.left = subject_expr;
        hir_match.match_arms = arms;
        hir_match.match_arm_count = expr.match_expr_arm_count;
        return hir_match;
    }
    if expr.type == ASTNodeType.AST_ASM {
        return exec_lower_fail_expr_reason(expr, "exec: 当前不支持 inline asm" as *byte, ExecUnsupportedReason.EXEC_UNSUPPORTED_ASM);
    }
    return exec_lower_fail_expr(expr, "exec: 尚未支持的表达式节点" as *byte);
}

fn exec_lower_block(ctx: &ExecLowerContext, block: &ASTNode) &HIRBlock {
    if ctx == null || block == null || block.type != ASTNodeType.AST_BLOCK {
        exec_backend_set_error(block, "exec: block lowering 失败" as *byte, 0);
        return null;
    }
    const hir_block: &HIRBlock = compiler_arena_alloc(ctx.arena, @size_of(HIRBlock)) as &HIRBlock;
    if hir_block == null {
        exec_backend_set_error(block, "exec: HIRBlock 分配失败" as *byte, 0);
        return null;
    }
    _ = memset(hir_block as *byte, 0, @size_of(HIRBlock));
    const stmts: & & HIRStmt = compiler_arena_alloc(ctx.arena, @size_of(&HIRStmt) * block.block_stmt_count as usize) as & & HIRStmt;
    if block.block_stmt_count > 0 && stmts == null {
        exec_backend_set_error(block, "exec: HIRBlock stmt 分配失败" as *byte, 0);
        return null;
    }
    hir_block.stmts = stmts;
    exec_lower_push_scope(ctx);
    var i: i32 = 0;
    while i < block.block_stmt_count {
        const stmt_node: &ASTNode = block.block_stmts[i];
        var stmt: &HIRStmt = null;
        if stmt_node.type == ASTNodeType.AST_VAR_DECL {
            if stmt_node.var_decl_init == null {
                exec_lower_pop_scope(ctx);
                return exec_lower_fail_block(stmt_node, "exec: 当前不支持未初始化局部变量" as *byte);
            }
            var local_type: Type = exec_lower_expr_type(ctx, stmt_node.var_decl_init);
            if stmt_node.var_decl_type != null {
                local_type = type_from_ast(ctx.checker, stmt_node.var_decl_type);
            }
            if exec_type_is_vm_value_supported(local_type) == 0 {
                exec_lower_pop_scope(ctx);
                if exec_type_uses_simd(local_type) != 0 {
                    return exec_lower_fail_block_reason(stmt_node, "exec: 当前不支持 SIMD" as *byte, ExecUnsupportedReason.EXEC_UNSUPPORTED_SIMD);
                }
                return exec_lower_fail_block(stmt_node, "exec: 当前仅支持 exec VM 可表示的局部变量" as *byte);
            }
            const slot: i32 = exec_lower_append_local(ctx, stmt_node.var_decl_name, &local_type, 0);
            if slot < 0 {
                exec_lower_pop_scope(ctx);
                exec_backend_set_error(stmt_node, "exec: 局部变量槽位不足" as *byte, 0);
                return null;
            }
            const init_expr: &HIRExpr = exec_lower_coerce_expr(ctx, stmt_node.var_decl_init, &local_type);
            if init_expr == null {
                exec_lower_pop_scope(ctx);
                return null;
            }
            stmt = exec_lower_alloc_stmt(ctx, stmt_node, HIRStmtKind.HIR_STMT_VAR_INIT);
            if stmt == null {
                exec_lower_pop_scope(ctx);
                return null;
            }
            stmt.local_slot = slot;
            stmt.expr = init_expr;
        } else if stmt_node.type == ASTNodeType.AST_ASSIGN {
            const assign_target: &HIRExpr = exec_lower_make_dest_expr(ctx, stmt_node.assign_dest);
            if assign_target == null {
                exec_lower_pop_scope(ctx);
                return null;
            }
            const value_expr: &HIRExpr = exec_lower_coerce_expr(ctx, stmt_node.assign_src, &assign_target.type_ref.type);
            if value_expr == null {
                exec_lower_pop_scope(ctx);
                return null;
            }
            stmt = exec_lower_alloc_stmt(ctx, stmt_node, HIRStmtKind.HIR_STMT_ASSIGN);
            if stmt == null {
                exec_lower_pop_scope(ctx);
                return null;
            }
            if assign_target.kind == HIRExprKind.HIR_EXPR_LOCAL {
                stmt.local_slot = assign_target.local_slot;
            }
            stmt.assign_target = assign_target;
            stmt.assign_expr = value_expr;
        } else if stmt_node.type == ASTNodeType.AST_CALL_EXPR ||
            stmt_node.type == ASTNodeType.AST_PRINT ||
            stmt_node.type == ASTNodeType.AST_PRINTLN ||
            stmt_node.type == ASTNodeType.AST_BINARY_EXPR ||
            stmt_node.type == ASTNodeType.AST_UNARY_EXPR ||
            stmt_node.type == ASTNodeType.AST_IDENTIFIER ||
            stmt_node.type == ASTNodeType.AST_MEMBER_ACCESS ||
            stmt_node.type == ASTNodeType.AST_ARRAY_ACCESS ||
            stmt_node.type == ASTNodeType.AST_SLICE_EXPR ||
            stmt_node.type == ASTNodeType.AST_STRUCT_INIT ||
            stmt_node.type == ASTNodeType.AST_ARRAY_LITERAL ||
            stmt_node.type == ASTNodeType.AST_TUPLE_LITERAL ||
            stmt_node.type == ASTNodeType.AST_SIZEOF ||
            stmt_node.type == ASTNodeType.AST_LEN ||
            stmt_node.type == ASTNodeType.AST_ALIGNOF ||
            stmt_node.type == ASTNodeType.AST_SRC_NAME ||
            stmt_node.type == ASTNodeType.AST_SRC_PATH ||
            stmt_node.type == ASTNodeType.AST_SRC_LINE ||
            stmt_node.type == ASTNodeType.AST_SRC_COL ||
            stmt_node.type == ASTNodeType.AST_FUNC_NAME ||
            stmt_node.type == ASTNodeType.AST_ERROR_ID ||
            stmt_node.type == ASTNodeType.AST_ERROR_NAME ||
            stmt_node.type == ASTNodeType.AST_MATCH_EXPR ||
            stmt_node.type == ASTNodeType.AST_TRY_EXPR ||
            stmt_node.type == ASTNodeType.AST_CATCH_EXPR {
            const expr_stmt: &HIRExpr = exec_lower_expr(ctx, stmt_node);
            if expr_stmt == null {
                exec_lower_pop_scope(ctx);
                return null;
            }
            stmt = exec_lower_alloc_stmt(ctx, stmt_node, HIRStmtKind.HIR_STMT_EXPR);
            if stmt == null {
                exec_lower_pop_scope(ctx);
                return null;
            }
            stmt.expr = expr_stmt;
        } else if stmt_node.type == ASTNodeType.AST_DEFER_STMT || stmt_node.type == ASTNodeType.AST_ERRDEFER_STMT {
            var cleanup_body: &ASTNode = stmt_node.defer_stmt_body;
            var cleanup_kind: HIRStmtKind = HIRStmtKind.HIR_STMT_DEFER;
            if stmt_node.type == ASTNodeType.AST_ERRDEFER_STMT {
                cleanup_body = stmt_node.errdefer_stmt_body;
                cleanup_kind = HIRStmtKind.HIR_STMT_ERRDEFER;
            }
            if cleanup_body == null {
                exec_lower_pop_scope(ctx);
                return exec_lower_fail_block(stmt_node, "exec: defer/errdefer body 为空" as *byte);
            }
            const cleanup_block: &HIRBlock = exec_lower_wrap_stmt_node_as_block(ctx, cleanup_body);
            if cleanup_block == null {
                exec_lower_pop_scope(ctx);
                return null;
            }
            stmt = exec_lower_alloc_stmt(ctx, stmt_node, cleanup_kind);
            if stmt == null {
                exec_lower_pop_scope(ctx);
                return null;
            }
            stmt.cleanup_block = cleanup_block;
        } else if stmt_node.type == ASTNodeType.AST_IF_STMT {
            const cond_expr: &HIRExpr = exec_lower_expr(ctx, stmt_node.if_stmt_condition);
            if cond_expr == null {
                exec_lower_pop_scope(ctx);
                return null;
            }
            const then_block: &HIRBlock = exec_lower_block(ctx, stmt_node.if_stmt_then_branch);
            if then_block == null {
                exec_lower_pop_scope(ctx);
                return null;
            }
            var else_block: &HIRBlock = null;
            if stmt_node.if_stmt_else_branch != null {
                if stmt_node.if_stmt_else_branch.type == ASTNodeType.AST_BLOCK {
                    else_block = exec_lower_block(ctx, stmt_node.if_stmt_else_branch);
                    if else_block == null {
                        exec_lower_pop_scope(ctx);
                        return null;
                    }
                } else if stmt_node.if_stmt_else_branch.type == ASTNodeType.AST_IF_STMT {
                    else_block = exec_lower_wrap_stmt_node_as_block(ctx, stmt_node.if_stmt_else_branch);
                    if else_block == null {
                        exec_lower_pop_scope(ctx);
                        return null;
                    }
                } else {
                    exec_lower_pop_scope(ctx);
                    return exec_lower_fail_block(stmt_node, "exec: 当前仅支持 block/else-if" as *byte);
                }
            }
            stmt = exec_lower_alloc_stmt(ctx, stmt_node, HIRStmtKind.HIR_STMT_IF);
            if stmt == null {
                exec_lower_pop_scope(ctx);
                return null;
            }
            stmt.expr = cond_expr;
            stmt.then_block = then_block;
            stmt.else_block = else_block;
        } else if stmt_node.type == ASTNodeType.AST_WHILE_STMT {
            const loop_body: &HIRBlock = compiler_arena_alloc(ctx.arena, @size_of(HIRBlock)) as &HIRBlock;
            if loop_body == null {
                exec_lower_pop_scope(ctx);
                exec_backend_set_error(stmt_node, "exec: loop body 分配失败" as *byte, 0);
                return null;
            }
            _ = memset(loop_body as *byte, 0, @size_of(HIRBlock));
            const loop_stmts: & & HIRStmt = compiler_arena_alloc(ctx.arena, @size_of(&HIRStmt) * 2 as usize) as & & HIRStmt;
            if loop_stmts == null {
                exec_lower_pop_scope(ctx);
                exec_backend_set_error(stmt_node, "exec: loop stmt 分配失败" as *byte, 0);
                return null;
            }
            const cond_stmt: &HIRStmt = exec_lower_alloc_stmt(ctx, stmt_node, HIRStmtKind.HIR_STMT_IF);
            const cond_expr: &HIRExpr = exec_lower_expr(ctx, stmt_node.while_stmt_condition);
            const body_block: &HIRBlock = exec_lower_block(ctx, stmt_node.while_stmt_body);
            if cond_stmt == null || cond_expr == null || body_block == null {
                exec_lower_pop_scope(ctx);
                return null;
            }
            const break_block: &HIRBlock = compiler_arena_alloc(ctx.arena, @size_of(HIRBlock)) as &HIRBlock;
            const break_stmts: & & HIRStmt = compiler_arena_alloc(ctx.arena, @size_of(&HIRStmt)) as & & HIRStmt;
            const break_stmt: &HIRStmt = exec_lower_alloc_stmt(ctx, stmt_node, HIRStmtKind.HIR_STMT_BREAK);
            if break_block == null || break_stmts == null || break_stmt == null {
                exec_lower_pop_scope(ctx);
                exec_backend_set_error(stmt_node, "exec: while break block 分配失败" as *byte, 0);
                return null;
            }
            _ = memset(break_block as *byte, 0, @size_of(HIRBlock));
            break_stmts[0] = break_stmt;
            break_block.stmts = break_stmts;
            break_block.stmt_count = 1;
            cond_stmt.expr = cond_expr;
            cond_stmt.then_block = body_block;
            cond_stmt.else_block = break_block;
            loop_stmts[0] = cond_stmt;
            loop_body.stmts = loop_stmts;
            loop_body.stmt_count = 1;
            stmt = exec_lower_alloc_stmt(ctx, stmt_node, HIRStmtKind.HIR_STMT_LOOP);
            if stmt == null {
                exec_lower_pop_scope(ctx);
                return null;
            }
            stmt.loop_body = loop_body;
        } else if stmt_node.type == ASTNodeType.AST_FOR_STMT {
            stmt = exec_lower_make_for_range_stmt(ctx, stmt_node);
            if stmt == null {
                exec_lower_pop_scope(ctx);
                return null;
            }
        } else if stmt_node.type == ASTNodeType.AST_BREAK_STMT {
            stmt = exec_lower_alloc_stmt(ctx, stmt_node, HIRStmtKind.HIR_STMT_BREAK);
        } else if stmt_node.type == ASTNodeType.AST_CONTINUE_STMT {
            stmt = exec_lower_alloc_stmt(ctx, stmt_node, HIRStmtKind.HIR_STMT_CONTINUE);
        } else if stmt_node.type == ASTNodeType.AST_RETURN_STMT {
            stmt = exec_lower_alloc_stmt(ctx, stmt_node, HIRStmtKind.HIR_STMT_RETURN);
            if stmt == null {
                exec_lower_pop_scope(ctx);
                return null;
            }
            if stmt_node.return_stmt_expr != null {
                if ctx.function_decl != null && ctx.function_decl.fn_decl_return_type != null {
                    const return_type: Type = type_from_ast(ctx.checker, ctx.function_decl.fn_decl_return_type);
                    stmt.expr = exec_lower_coerce_expr(ctx, stmt_node.return_stmt_expr, &return_type);
                    if stmt.expr == null {
                        exec_lower_pop_scope(ctx);
                        return null;
                    }
                    if return_type.kind != TypeKind.TYPE_ERROR_UNION &&
                        type_equals(stmt.expr.type_ref.type, return_type) == 0 &&
                        exec_type_is_vm_value_supported(return_type) != 0 {
                        const cast_return: &HIRExpr = exec_lower_alloc_expr(ctx, stmt_node.return_stmt_expr, HIRExprKind.HIR_EXPR_CAST, &return_type);
                        if cast_return == null {
                            exec_lower_pop_scope(ctx);
                            return null;
                        }
                        cast_return.left = stmt.expr;
                        stmt.expr = cast_return;
                    }
                } else {
                    stmt.expr = exec_lower_expr(ctx, stmt_node.return_stmt_expr);
                    if stmt.expr == null {
                        exec_lower_pop_scope(ctx);
                        return null;
                    }
                }
            }
        } else if stmt_node.type == ASTNodeType.AST_BLOCK {
            const nested_block: &HIRBlock = exec_lower_block(ctx, stmt_node);
            if nested_block == null {
                exec_lower_pop_scope(ctx);
                return null;
            }
            const nested_stmt: &HIRStmt = exec_lower_wrap_block_as_stmt(ctx, stmt_node, nested_block);
            if nested_stmt == null {
                exec_lower_pop_scope(ctx);
                return null;
            }
            stmt = nested_stmt;
        } else {
            exec_lower_pop_scope(ctx);
            if stmt_node.type == ASTNodeType.AST_TEST_STMT {
                return exec_lower_fail_block(stmt_node, "exec: 当前不支持 test 语句" as *byte);
            }
            return exec_lower_fail_block(stmt_node, "exec: 尚未支持的语句节点" as *byte);
        }
        if stmt == null {
            exec_lower_pop_scope(ctx);
            return null;
        }
        hir_block.stmts[i] = stmt;
        i = i + 1;
    }
    hir_block.stmt_count = block.block_stmt_count;
    exec_lower_pop_scope(ctx);
    return hir_block;
}

fn exec_lower_function(arena: &CompilerArena, checker: &TypeChecker, fn_decl: &ASTNode, globals: &HIRGlobalSlot, global_count: i32) &HIRFunction {
    if arena == null || checker == null || fn_decl == null || fn_decl.type != ASTNodeType.AST_FN_DECL {
        return null;
    }
    if fn_decl.fn_decl_is_async != 0 {
        exec_lower_set_unsupported_reason(fn_decl, "exec: 当前不支持 async" as *byte, ExecUnsupportedReason.EXEC_UNSUPPORTED_ASYNC);
        return null;
    }
    if fn_decl.fn_decl_is_extern != 0 && exec_lower_extern_can_run_in_vm(checker, fn_decl) == 0 {
        exec_lower_set_unsupported_reason(fn_decl, "exec: 当前不支持 extern ABI" as *byte, ExecUnsupportedReason.EXEC_UNSUPPORTED_EXTERN_ABI);
        return null;
    }
    const saved_self_type_name: &byte = checker.current_self_type_name;
    const saved_self_is_union: i32 = checker.current_self_is_union;
    var owner_is_union: i32 = 0;
    const owner_type_name: &byte = checker_fn_decl_owner_type_name(checker, fn_decl, &owner_is_union);
    if owner_type_name != null {
        checker.current_self_type_name = owner_type_name;
        checker.current_self_is_union = owner_is_union;
    }
    const return_type: Type = type_from_ast(checker, fn_decl.fn_decl_return_type);
    if exec_type_is_vm_value_supported(return_type) == 0 {
        checker.current_self_type_name = saved_self_type_name;
        checker.current_self_is_union = saved_self_is_union;
        if exec_type_uses_simd(return_type) != 0 {
            exec_lower_set_unsupported_reason(fn_decl, "exec: 当前不支持 SIMD" as *byte, ExecUnsupportedReason.EXEC_UNSUPPORTED_SIMD);
            return null;
        }
        exec_lower_set_unsupported(fn_decl, "exec: 当前仅支持标量/错误联合/void 返回值" as *byte);
        return null;
    }
    var ctx: ExecLowerContext = ExecLowerContext {
        arena: arena,
        checker: checker,
        function_decl: fn_decl,
        global_names: [],
        global_decls: [],
        global_types: [],
        global_is_const: [],
        global_count: 0,
        local_names: [],
        local_slots: [],
        local_types: [],
        local_is_param: [],
        slot_names: [],
        slot_types: [],
        slot_is_param: [],
        active_local_count: 0,
        next_slot: 0,
        max_slot_count: 0,
        scope_markers: [],
        scope_depth: 0,
    };
    exec_lower_seed_globals(&ctx, globals, global_count);
    var i: i32 = 0;
    while i < fn_decl.fn_decl_param_count {
        const param: &ASTNode = fn_decl.fn_decl_params[i];
        if param == null || param.type != ASTNodeType.AST_VAR_DECL {
            checker.current_self_type_name = saved_self_type_name;
            checker.current_self_is_union = saved_self_is_union;
            exec_lower_set_unsupported(fn_decl, "exec: 参数节点异常" as *byte);
            return null;
        }
        const param_type: Type = type_from_ast(checker, param.var_decl_type);
        if exec_type_is_vm_value_supported(param_type) == 0 {
            checker.current_self_type_name = saved_self_type_name;
            checker.current_self_is_union = saved_self_is_union;
            if exec_type_uses_simd(param_type) != 0 {
                exec_lower_set_unsupported_reason(param, "exec: 当前不支持 SIMD" as *byte, ExecUnsupportedReason.EXEC_UNSUPPORTED_SIMD);
                return null;
            }
            exec_lower_set_unsupported(param, "exec: 当前仅支持标量/错误联合参数" as *byte);
            return null;
        }
        if exec_lower_append_local(&ctx, param.var_decl_name, &param_type, 1) < 0 {
            checker.current_self_type_name = saved_self_type_name;
            checker.current_self_is_union = saved_self_is_union;
            exec_backend_set_error(param, "exec: 参数槽位不足" as *byte, 0);
            return null;
        }
        i = i + 1;
    }
    const body: &HIRBlock = exec_lower_block(&ctx, fn_decl.fn_decl_body);
    if body == null {
        checker.current_self_type_name = saved_self_type_name;
        checker.current_self_is_union = saved_self_is_union;
        return null;
    }
    const hir_fn: &HIRFunction = compiler_arena_alloc(arena, @size_of(HIRFunction)) as &HIRFunction;
    if hir_fn == null {
        checker.current_self_type_name = saved_self_type_name;
        checker.current_self_is_union = saved_self_is_union;
        exec_backend_set_error(fn_decl, "exec: HIRFunction 分配失败" as *byte, 0);
        return null;
    }
    _ = memset(hir_fn as *byte, 0, @size_of(HIRFunction));
    hir_fn.name = fn_decl.fn_decl_name;
    hir_fn.decl = fn_decl;
    hir_fn.return_type = exec_lower_make_type_ref(&return_type);
    if ctx.max_slot_count > 0 {
        const locals: &HIRLocalSlot = compiler_arena_alloc(arena, @size_of(HIRLocalSlot) * ctx.max_slot_count as usize) as &HIRLocalSlot;
        if locals == null {
            checker.current_self_type_name = saved_self_type_name;
            checker.current_self_is_union = saved_self_is_union;
            exec_backend_set_error(fn_decl, "exec: local slot 表分配失败" as *byte, 0);
            return null;
        }
        i = 0;
        while i < ctx.max_slot_count {
            locals[i].name = ctx.slot_names[i];
            locals[i].slot = i;
            locals[i].type_ref = exec_lower_make_type_ref(&ctx.slot_types[i]);
            locals[i].is_param = ctx.slot_is_param[i];
            i = i + 1;
        }
        hir_fn.locals = locals;
        hir_fn.local_count = ctx.max_slot_count;
    }
    hir_fn.param_count = fn_decl.fn_decl_param_count;
    hir_fn.body = body;
    checker.current_self_type_name = saved_self_type_name;
    checker.current_self_is_union = saved_self_is_union;
    return hir_fn;
}

/// 将 checker 后的可达函数降级为执行友好的 HIR。
/// 参数：`arena` 为执行后端短生命周期 Arena；`checker` 提供类型与可达性；`program` 为 merged checked AST。
/// 返回值：成功时返回 `HIRModule`；遇到当前未支持特性时返回 null，并通过 exec backend 错误状态说明原因。
export fn exec_lower_module(arena: &CompilerArena, checker: &TypeChecker, program: &ASTNode) &HIRModule {
    if arena == null || checker == null || program == null {
        exec_backend_set_error(program, "exec: lowering 输入无效" as *byte, 0);
        return null;
    }
    if g_app_mode_microapp != 0 {
        exec_lower_set_unsupported_reason(program, "exec: 当前不支持 microapp exec backend" as *byte, ExecUnsupportedReason.EXEC_UNSUPPORTED_MICROAPP);
        return null;
    }
    if program.type == ASTNodeType.AST_PROGRAM {
        var decl_idx: i32 = 0;
        while decl_idx < program.program_decl_count {
            const decl: &ASTNode = program.program_decls[decl_idx];
            if decl != null && decl.type == ASTNodeType.AST_C_IMPORT_DECL {
                exec_lower_set_unsupported_reason(decl, "exec: 当前不支持 @c_import" as *byte, ExecUnsupportedReason.EXEC_UNSUPPORTED_C_IMPORT);
                return null;
            }
            decl_idx = decl_idx + 1;
        }
    }
    var global_count: i32 = 0;
    var globals: &HIRGlobalSlot = exec_lower_collect_global_slots(arena, checker, program, &global_count);
    if globals == null {
        return null;
    }
    var main_decl: &ASTNode = exec_lower_find_entry_decl(checker);
    if main_decl == null {
        exec_lower_set_unsupported(program, "exec: 当前仅支持包含显式 fn/export fn main 的程序" as *byte);
        return null;
    }
    var exec_reachable: [&ASTNode: MAX_REACHABLE_FN_DECLS] = [];
    var exec_reachable_count: i32 = 0;
    exec_reachable[0] = main_decl;
    exec_reachable_count = 1;
    if exec_lower_lower_global_init_exprs(arena, checker, globals, global_count, &exec_reachable[0] as & & ASTNode, &exec_reachable_count) != 0 {
        return null;
    }
    const global_init_function: &HIRFunction = exec_lower_build_global_init_function(arena, globals, global_count);
    const functions: & & HIRFunction = compiler_arena_alloc(arena, @size_of(&HIRFunction) * MAX_REACHABLE_FN_DECLS as usize) as & & HIRFunction;
    if functions == null {
        exec_backend_set_error(program, "exec: HIR function 列表分配失败" as *byte, 0);
        return null;
    }
    var count: i32 = 0;
    var entry_fn: &HIRFunction = null;
    var queue: [&ASTNode: MAX_REACHABLE_FN_DECLS] = [];
    var head: i32 = 0;
    var tail: i32 = 0;
    var seed_idx: i32 = 0;
    while seed_idx < exec_reachable_count {
        queue[seed_idx] = exec_reachable[seed_idx];
        seed_idx = seed_idx + 1;
    }
    tail = exec_reachable_count;
    while head < tail {
        const from_decl: &ASTNode = queue[head];
        head = head + 1;
        var edge_idx: i32 = 0;
        while edge_idx < checker.fn_call_edge_count {
            if checker.fn_call_edge_from[edge_idx] == from_decl {
                const to_decl: &ASTNode = checker.fn_call_edge_to[edge_idx];
                if to_decl != null &&
                    to_decl.type == ASTNodeType.AST_FN_DECL &&
                    exec_lower_extern_can_run_in_vm(checker, to_decl) != 0 &&
                    exec_lower_decl_index(&exec_reachable[0] as & & ASTNode, exec_reachable_count, to_decl) < 0 {
                    if exec_reachable_count >= MAX_REACHABLE_FN_DECLS || tail >= MAX_REACHABLE_FN_DECLS {
                        exec_backend_set_error(to_decl, "exec: reachable 函数集合超出上限" as *byte, 0);
                        return null;
                    }
                    exec_reachable[exec_reachable_count] = to_decl;
                    exec_reachable_count = exec_reachable_count + 1;
                    queue[tail] = to_decl;
                    tail = tail + 1;
                }
            }
            edge_idx = edge_idx + 1;
        }
    }
    var i: i32 = 0;
    while i < exec_reachable_count {
        const decl: &ASTNode = exec_reachable[i];
        if decl != null && decl.type == ASTNodeType.AST_FN_DECL && decl.fn_decl_body != null {
            const lowered: &HIRFunction = exec_lower_function(arena, checker, decl, globals, global_count);
            if lowered == null {
                return null;
            }
            functions[count] = lowered;
            if decl == main_decl {
                entry_fn = lowered;
            }
            if lowered.body != null {
                exec_lower_collect_called_decls_from_block(lowered.body, &exec_reachable[0] as & & ASTNode, &exec_reachable_count);
            }
            count = count + 1;
        }
        i = i + 1;
    }
    if entry_fn == null {
        exec_lower_set_unsupported(program, "exec: 无法定位 exec 入口 main" as *byte);
        return null;
    }
    const module: &HIRModule = compiler_arena_alloc(arena, @size_of(HIRModule)) as &HIRModule;
    if module == null {
        exec_backend_set_error(program, "exec: HIRModule 分配失败" as *byte, 0);
        return null;
    }
    _ = memset(module as *byte, 0, @size_of(HIRModule));
    module.functions = functions;
    module.function_count = count;
    module.entry_function = entry_fn;
    module.globals = globals;
    module.global_count = global_count;
    module.global_init_function = global_init_function;
    return module;
}
