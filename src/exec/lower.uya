// exec/lower.uya - checked AST to minimal Exec HIR lowering

use libc;

const EXEC_MAX_LOCALS: i32 = 256;
// 保持平铺数组查找的热路径简单，同时给编译器本体 staged smoke 留足全局槽位。
const EXEC_MAX_GLOBALS: i32 = 1024;
const EXEC_MAX_SCOPE_DEPTH: i32 = 64;
const EXEC_MAX_INTERFACE_METHODS: i32 = 64;
const EXEC_MAX_MODULE_GLOBAL_REQUESTS: i32 = 256;

struct ExecLowerContext {
    arena: &CompilerArena,
    checker: &TypeChecker,
    function_decl: &ASTNode,
    global_names: [&byte: EXEC_MAX_GLOBALS],
    global_decls: [&ASTNode: EXEC_MAX_GLOBALS],
    global_types: [Type: EXEC_MAX_GLOBALS],
    global_is_const: [i32: EXEC_MAX_GLOBALS],
    global_count: i32,
    local_names: [&byte: EXEC_MAX_LOCALS],
    local_slots: [i32: EXEC_MAX_LOCALS],
    local_types: [Type: EXEC_MAX_LOCALS],
    local_is_param: [i32: EXEC_MAX_LOCALS],
    slot_names: [&byte: EXEC_MAX_LOCALS],
    slot_decls: [&ASTNode: EXEC_MAX_LOCALS],
    slot_types: [Type: EXEC_MAX_LOCALS],
    slot_is_param: [i32: EXEC_MAX_LOCALS],
    slot_scope_ids: [i32: EXEC_MAX_LOCALS],
    slot_needs_drop: [i32: EXEC_MAX_LOCALS],
    slot_drop_decls: [&ASTNode: EXEC_MAX_LOCALS],
    active_local_count: i32,
    next_slot: i32,
    max_slot_count: i32,
    next_scope_id: i32,
    scope_markers: [i32: EXEC_MAX_SCOPE_DEPTH],
    scope_ids: [i32: EXEC_MAX_SCOPE_DEPTH],
    scope_depth: i32,
}

fn exec_lower_set_unsupported(node: &ASTNode, reason: &byte) i32 {
    exec_backend_set_unsupported_error(node, reason, ExecUnsupportedReason.EXEC_UNSUPPORTED_GENERIC);
    return 2;
}

fn exec_lower_set_unsupported_reason(node: &ASTNode, reason: &byte, code: ExecUnsupportedReason) i32 {
    exec_backend_set_unsupported_error(node, reason, code);
    return 2;
}

fn exec_lower_fail_expr(node: &ASTNode, reason: &byte) &HIRExpr {
    _ = exec_lower_set_unsupported(node, reason);
    return null;
}

fn exec_lower_fail_expr_reason(node: &ASTNode, reason: &byte, code: ExecUnsupportedReason) &HIRExpr {
    _ = exec_lower_set_unsupported_reason(node, reason, code);
    return null;
}

fn exec_lower_fail_block(node: &ASTNode, reason: &byte) &HIRBlock {
    _ = exec_lower_set_unsupported(node, reason);
    return null;
}

fn exec_lower_fail_block_reason(node: &ASTNode, reason: &byte, code: ExecUnsupportedReason) &HIRBlock {
    _ = exec_lower_set_unsupported_reason(node, reason, code);
    return null;
}

fn exec_lower_get_env_byte(name: &byte) &byte {
    if name == null {
        return null;
    }
    const raw: *byte = getenv(name as *byte);
    if raw == null || raw[0] == 0 {
        return null;
    }
    return raw as &byte;
}

fn exec_lower_detect_host_os_token() &byte {
    const host_os: &byte = exec_lower_get_env_byte("HOST_OS" as *byte);
    if host_os != null {
        return host_os;
    }
    const os_type: &byte = exec_lower_get_env_byte("OSTYPE" as *byte);
    if os_type != null {
        return os_type;
    }
    const mach_type: &byte = exec_lower_get_env_byte("MACHTYPE" as *byte);
    if mach_type != null {
        return mach_type;
    }
    return "linux" as &byte;
}

fn exec_lower_detect_host_arch_token() &byte {
    const host_arch: &byte = exec_lower_get_env_byte("HOST_ARCH" as *byte);
    if host_arch != null {
        return host_arch;
    }
    const host_type: &byte = exec_lower_get_env_byte("HOSTTYPE" as *byte);
    if host_type != null {
        return host_type;
    }
    const mach_type: &byte = exec_lower_get_env_byte("MACHTYPE" as *byte);
    if mach_type != null {
        return mach_type;
    }
    return "x86_64" as &byte;
}

fn exec_lower_host_asm_target_value() i32 {
    const os_token: &byte = exec_lower_detect_host_os_token();
    const arch_token: &byte = exec_lower_detect_host_arch_token();
    const is_linux: i32 = (strstr(os_token as *byte, "linux" as *byte) != null) as i32;
    const is_macos: i32 =
        ((strstr(os_token as *byte, "darwin" as *byte) != null) as i32) |
        ((strstr(os_token as *byte, "macos" as *byte) != null) as i32);
    const is_windows: i32 =
        ((strstr(os_token as *byte, "win" as *byte) != null) as i32) |
        ((strstr(os_token as *byte, "mingw" as *byte) != null) as i32) |
        ((strstr(os_token as *byte, "msys" as *byte) != null) as i32) |
        ((strstr(os_token as *byte, "cygwin" as *byte) != null) as i32);
    const is_x86_64: i32 =
        ((strstr(arch_token as *byte, "x86_64" as *byte) != null) as i32) |
        ((strstr(arch_token as *byte, "amd64" as *byte) != null) as i32);
    const is_arm64: i32 =
        ((strstr(arch_token as *byte, "aarch64" as *byte) != null) as i32) |
        ((strstr(arch_token as *byte, "arm64" as *byte) != null) as i32);
    const is_riscv64: i32 = (strstr(arch_token as *byte, "riscv64" as *byte) != null) as i32;
    if is_x86_64 != 0 {
        if is_macos != 0 { return 1; }
        if is_windows != 0 { return 2; }
        return 0;
    }
    if is_arm64 != 0 {
        if is_macos != 0 { return 4; }
        if is_windows != 0 { return 5; }
        return 3;
    }
    if is_riscv64 != 0 {
        return 6;
    }
    if is_linux != 0 {
        return 0;
    }
    return 0;
}

fn exec_type_is_scalar_supported(type: Type) i32 {
    if type.kind == TypeKind.TYPE_ATOMIC {
        const inner: &Type = type_get_atomic_inner(&type);
        if inner != null {
            return exec_type_is_scalar_supported(inner[0]);
        }
        return 0;
    }
    if type.kind == TypeKind.TYPE_I8 ||
        type.kind == TypeKind.TYPE_I16 ||
        type.kind == TypeKind.TYPE_I32 ||
        type.kind == TypeKind.TYPE_I64 ||
        type.kind == TypeKind.TYPE_U8 ||
        type.kind == TypeKind.TYPE_U16 ||
        type.kind == TypeKind.TYPE_U32 ||
        type.kind == TypeKind.TYPE_U64 ||
        type.kind == TypeKind.TYPE_USIZE ||
        type.kind == TypeKind.TYPE_F32 ||
        type.kind == TypeKind.TYPE_F64 ||
        type.kind == TypeKind.TYPE_BOOL ||
        type.kind == TypeKind.TYPE_BYTE ||
        type.kind == TypeKind.TYPE_VOID {
        return 1;
    }
    return 0;
}

fn exec_lower_type_ast_size_bytes(checker: &TypeChecker, type_ast: &ASTNode, program_node: &ASTNode) i32 {
    if checker == null || type_ast == null || program_node == null {
        return -1;
    }
    const resolved: Type = type_from_ast(checker, type_ast);
    return get_type_size_bytes_v2(checker, &resolved, program_node);
}

fn exec_lower_type_ast_align_bytes(checker: &TypeChecker, type_ast: &ASTNode, program_node: &ASTNode) i32 {
    if checker == null || type_ast == null || program_node == null {
        return -1;
    }
    const resolved: Type = type_from_ast(checker, type_ast);
    return get_type_align_bytes_v2(checker, &resolved, program_node);
}

fn exec_lower_named_decl_size_bytes(checker: &TypeChecker, name: &byte, program_node: &ASTNode) i32 {
    if checker == null || name == null || program_node == null {
        return -1;
    }
    if find_struct_decl_from_program(program_node, name) != null {
        const named_struct: Type = make_named_type(TypeKind.TYPE_STRUCT, name);
        return get_type_size_bytes_v2(checker, &named_struct, program_node);
    }
    if find_union_decl_from_program(program_node, name) != null {
        const named_union: Type = make_named_type(TypeKind.TYPE_UNION, name);
        return get_type_size_bytes_v2(checker, &named_union, program_node);
    }
    if find_interface_decl_from_program(program_node, name) != null {
        const named_iface: Type = make_named_type(TypeKind.TYPE_INTERFACE, name);
        return get_type_size_bytes_v2(checker, &named_iface, program_node);
    }
    if find_enum_decl_from_program(program_node, name) != null {
        const named_enum: Type = make_named_type(TypeKind.TYPE_ENUM, name);
        return get_type_size_bytes_v2(checker, &named_enum, program_node);
    }
    return -1;
}

fn exec_lower_named_decl_align_bytes(checker: &TypeChecker, name: &byte, program_node: &ASTNode) i32 {
    if checker == null || name == null || program_node == null {
        return -1;
    }
    if find_struct_decl_from_program(program_node, name) != null {
        const named_struct: Type = make_named_type(TypeKind.TYPE_STRUCT, name);
        return get_type_align_bytes_v2(checker, &named_struct, program_node);
    }
    if find_union_decl_from_program(program_node, name) != null {
        const named_union: Type = make_named_type(TypeKind.TYPE_UNION, name);
        return get_type_align_bytes_v2(checker, &named_union, program_node);
    }
    if find_interface_decl_from_program(program_node, name) != null {
        const named_iface: Type = make_named_type(TypeKind.TYPE_INTERFACE, name);
        return get_type_align_bytes_v2(checker, &named_iface, program_node);
    }
    if find_enum_decl_from_program(program_node, name) != null {
        const named_enum: Type = make_named_type(TypeKind.TYPE_ENUM, name);
        return get_type_align_bytes_v2(checker, &named_enum, program_node);
    }
    return -1;
}

fn exec_lower_eval_size_align_builtin(ctx: &ExecLowerContext, expr: &ASTNode) i32 {
    if ctx == null || expr == null {
        return -1;
    }
    if expr.type != ASTNodeType.AST_SIZEOF && expr.type != ASTNodeType.AST_ALIGNOF {
        return -1;
    }
    var target: &ASTNode = expr.sizeof_expr_target;
    var is_type_expr: i32 = expr.sizeof_expr_is_type;
    if expr.type == ASTNodeType.AST_ALIGNOF {
        target = expr.alignof_expr_target;
        is_type_expr = expr.alignof_expr_is_type;
    }
    if target == null {
        return -1;
    }
    if is_type_expr != 0 && target.type == ASTNodeType.AST_TYPE_FRAME {
        if expr.type == ASTNodeType.AST_SIZEOF {
            return get_async_frame_size_bytes(ctx.checker, target);
        }
        return get_async_frame_align_bytes(ctx.checker, target);
    }
    if target.type == ASTNodeType.AST_IDENTIFIER && target.identifier_name != null {
        if expr.type == ASTNodeType.AST_SIZEOF {
            const named_size: i32 = exec_lower_named_decl_size_bytes(ctx.checker, target.identifier_name, ctx.checker.program_node);
            if named_size >= 0 {
                return named_size;
            }
        } else {
            const named_align: i32 = exec_lower_named_decl_align_bytes(ctx.checker, target.identifier_name, ctx.checker.program_node);
            if named_align >= 0 {
                return named_align;
            }
        }
    }
    var target_type: Type = checker_infer_type(ctx.checker, target);
    if is_type_expr != 0 {
        target_type = type_from_ast(ctx.checker, target);
    } else if target.type == ASTNodeType.AST_IDENTIFIER && target.identifier_name != null {
        if find_struct_decl_from_program(ctx.checker.program_node, target.identifier_name) != null {
            target_type = make_named_type(TypeKind.TYPE_STRUCT, target.identifier_name);
        } else if find_union_decl_from_program(ctx.checker.program_node, target.identifier_name) != null {
            target_type = make_named_type(TypeKind.TYPE_UNION, target.identifier_name);
        } else if find_interface_decl_from_program(ctx.checker.program_node, target.identifier_name) != null {
            target_type = make_named_type(TypeKind.TYPE_INTERFACE, target.identifier_name);
        }
    }
    if expr.type == ASTNodeType.AST_SIZEOF {
        return get_type_size_bytes_v2(ctx.checker, &target_type, ctx.checker.program_node);
    }
    return get_type_align_bytes_v2(ctx.checker, &target_type, ctx.checker.program_node);
}

fn exec_type_is_string_pointer_supported(type: Type) i32 {
    if type.kind != TypeKind.TYPE_POINTER || type.pointer_to == null {
        return 0;
    }
    if type.pointer_to.kind == TypeKind.TYPE_BYTE {
        return 1;
    }
    return 0;
}

fn exec_lower_is_supported_extern_lib(fn_decl: &ASTNode) i32 {
    if fn_decl == null || fn_decl.type != ASTNodeType.AST_FN_DECL {
        return 0;
    }
    if fn_decl.fn_decl_extern_lib_name == null {
        return 1;
    }
    if str_equals(fn_decl.fn_decl_extern_lib_name, "libc" as &byte) != 0 {
        return 1;
    }
    return 0;
}

fn exec_lower_is_exact_scalar_type(type: Type, kind: TypeKind) i32 {
    if type.kind == kind {
        return 1;
    }
    return 0;
}

fn exec_lower_match_host_call(fn_decl: &ASTNode, call_arg_count: i32) ExecHostCallId {
    if fn_decl == null || fn_decl.type != ASTNodeType.AST_FN_DECL {
        return ExecHostCallId.EXEC_HOST_CALL_NONE;
    }
    if fn_decl.fn_decl_is_extern == 0 {
        return ExecHostCallId.EXEC_HOST_CALL_NONE;
    }
    if fn_decl.fn_decl_name == null || fn_decl.fn_decl_return_type == null {
        return ExecHostCallId.EXEC_HOST_CALL_NONE;
    }
    if fn_decl.fn_decl_is_varargs == 0 {
        if str_equals(fn_decl.fn_decl_name, "puts" as &byte) != 0 &&
            fn_decl.fn_decl_param_count == 1 && call_arg_count == 1 {
            return ExecHostCallId.EXEC_HOST_CALL_PUTS;
        }
        if str_equals(fn_decl.fn_decl_name, "atoi" as &byte) != 0 &&
            fn_decl.fn_decl_param_count == 1 && call_arg_count == 1 {
            return ExecHostCallId.EXEC_HOST_CALL_ATOI;
        }
        if str_equals(fn_decl.fn_decl_name, "atoll" as &byte) != 0 &&
            fn_decl.fn_decl_param_count == 1 && call_arg_count == 1 {
            return ExecHostCallId.EXEC_HOST_CALL_ATOLL;
        }
        if str_equals(fn_decl.fn_decl_name, "isqrt" as &byte) != 0 &&
            fn_decl.fn_decl_param_count == 1 && call_arg_count == 1 {
            return ExecHostCallId.EXEC_HOST_CALL_ISQRT;
        }
        if str_equals(fn_decl.fn_decl_name, "strcmp" as &byte) != 0 &&
            fn_decl.fn_decl_param_count == 2 && call_arg_count == 2 {
            return ExecHostCallId.EXEC_HOST_CALL_STRCMP;
        }
        if str_equals(fn_decl.fn_decl_name, "llabs" as &byte) != 0 &&
            fn_decl.fn_decl_param_count == 1 && call_arg_count == 1 {
            return ExecHostCallId.EXEC_HOST_CALL_LLABS;
        }
        if str_equals(fn_decl.fn_decl_name, "__atomic_compare_exchange_n" as &byte) != 0 &&
            fn_decl.fn_decl_param_count == 6 && call_arg_count == 6 {
            return ExecHostCallId.EXEC_HOST_CALL_ATOMIC_COMPARE_EXCHANGE;
        }
        return ExecHostCallId.EXEC_HOST_CALL_NONE;
    }
    if str_equals(fn_decl.fn_decl_name, "fprintf" as &byte) != 0 && call_arg_count == 2 {
        return ExecHostCallId.EXEC_HOST_CALL_FPRINTF_FIXED;
    }
    if str_equals(fn_decl.fn_decl_name, "printf" as &byte) != 0 && call_arg_count == 1 {
        return ExecHostCallId.EXEC_HOST_CALL_PRINTF_FIXED;
    }
    if str_equals(fn_decl.fn_decl_name, "sprintf" as &byte) != 0 && call_arg_count == 2 {
        return ExecHostCallId.EXEC_HOST_CALL_SPRINTF_FIXED;
    }
    if str_equals(fn_decl.fn_decl_name, "snprintf" as &byte) != 0 && call_arg_count == 3 {
        return ExecHostCallId.EXEC_HOST_CALL_SNPRINTF_FIXED;
    }
    return ExecHostCallId.EXEC_HOST_CALL_NONE;
}

fn exec_lower_extern_prefers_host_call(fn_decl: &ASTNode) i32 {
    return 0;
}

fn exec_lower_host_call_overrides_body(fn_decl: &ASTNode, host_call_id: ExecHostCallId) i32 {
    if fn_decl == null || host_call_id == ExecHostCallId.EXEC_HOST_CALL_NONE {
        return 0;
    }
    return exec_lower_extern_prefers_host_call(fn_decl);
}

fn exec_lower_extern_can_run_in_vm(checker: &TypeChecker, fn_decl: &ASTNode) i32 {
    if fn_decl == null || fn_decl.type != ASTNodeType.AST_FN_DECL {
        return 0;
    }
    if fn_decl.fn_decl_is_extern == 0 {
        return (fn_decl.fn_decl_body != null) as i32;
    }
    if fn_decl.fn_decl_body == null {
        return 0;
    }
    if exec_lower_extern_prefers_host_call(fn_decl) != 0 {
        return 0;
    }
    return 1;
}

fn exec_type_uses_simd(ty: Type) i32 {
    if ty.kind == TypeKind.TYPE_VECTOR || ty.kind == TypeKind.TYPE_MASK {
        return 1;
    }
    if ty.kind == TypeKind.TYPE_ARRAY && ty.element_type != null {
        return exec_type_uses_simd(ty.element_type[0]);
    }
    if ty.kind == TypeKind.TYPE_SLICE && ty.slice_element_type != null {
        return exec_type_uses_simd(ty.slice_element_type[0]);
    }
    if ty.kind == TypeKind.TYPE_TUPLE && ty.tuple_element_types != null {
        var i: i32 = 0;
        while i < ty.tuple_count {
            if exec_type_uses_simd(ty.tuple_element_types[i]) != 0 {
                return 1;
            }
            i = i + 1;
        }
    }
    if ty.kind == TypeKind.TYPE_ERROR_UNION && ty.error_union_payload_type != null {
        return exec_type_uses_simd(ty.error_union_payload_type[0]);
    }
    return 0;
}

fn exec_type_is_aggregate_supported(ty: Type) i32 {
    if ty.kind == TypeKind.TYPE_ARRAY && ty.element_type != null {
        return exec_type_is_vm_value_supported(ty.element_type[0]);
    }
    if ty.kind == TypeKind.TYPE_SLICE && ty.slice_element_type != null {
        return exec_type_is_vm_value_supported(ty.slice_element_type[0]);
    }
    if ty.kind == TypeKind.TYPE_TUPLE && ty.tuple_element_types != null {
        var ti: i32 = 0;
        while ti < ty.tuple_count {
            if exec_type_is_vm_value_supported(ty.tuple_element_types[ti]) == 0 {
                return 0;
            }
            ti = ti + 1;
        }
        return 1;
    }
    if ty.kind == TypeKind.TYPE_STRUCT && type_get_struct_name(&ty) != null {
        return 1;
    }
    return 0;
}

fn exec_type_is_vm_value_supported(type: Type) i32 {
    if exec_type_is_scalar_supported(type) != 0 {
        return 1;
    }
    if type.kind == TypeKind.TYPE_ENUM {
        return 1;
    }
    if type.kind == TypeKind.TYPE_INTERFACE {
        return 1;
    }
    if type.kind == TypeKind.TYPE_UNION {
        return 1;
    }
    if type.kind == TypeKind.TYPE_POINTER {
        return 1;
    }
    if type.kind == TypeKind.TYPE_VA_LIST {
        return 1;
    }
    if type.kind == TypeKind.TYPE_ERROR {
        return 1;
    }
    if type.kind == TypeKind.TYPE_ERROR_UNION && type.error_union_payload_type != null {
        return exec_type_is_vm_value_supported(type.error_union_payload_type[0]);
    }
    if exec_type_is_aggregate_supported(type) != 0 {
        return 1;
    }
    return 0;
}

fn exec_lower_expr_type(ctx: &ExecLowerContext, expr: &ASTNode) Type {
    if ctx == null || ctx.checker == null || expr == null {
        return Type {
            kind: TypeKind.TYPE_VOID,
            data: TypeData.named(null as &byte),
            enum_name: null,
            interface_name: null,
            interface_type_args: null,
            interface_type_arg_count: 0,
            struct_name: null,
            union_name: null,
            pointer_to: null,
            is_ffi_pointer: 0,
            element_type: null,
            array_size: 0,
            slice_element_type: null,
            slice_len: 0,
            slice_element_is_const: 0,
            tuple_element_types: null,
            tuple_count: 0,
            error_union_payload_type: null,
            error_error_id: 0,
            atomic_inner_type: null,
            generic_param_name: null,
            struct_type_args: null,
            struct_type_arg_count: 0,
            union_type_args: null,
            union_type_arg_count: 0,
        };
    }
    if expr.type == ASTNodeType.AST_PRINT || expr.type == ASTNodeType.AST_PRINTLN {
        return make_i32_type();
    }
    if expr.type == ASTNodeType.AST_MATCH_EXPR {
        const lowered_match_type: Type = exec_lower_infer_match_expr_type(ctx, expr);
        if lowered_match_type.kind != TypeKind.TYPE_VOID {
            return lowered_match_type;
        }
    }
    const saved_scope_level: i32 = ctx.checker.scope_level;
    const prev_in_function: i32 = ctx.checker.in_function;
    const prev_function_decl: &ASTNode = ctx.checker.current_function_decl;
    const prev_return_type: Type = copy_type(&ctx.checker.current_return_type);
    if ctx.function_decl != null {
        ctx.checker.in_function = 1;
        ctx.checker.current_function_decl = ctx.function_decl;
        if ctx.function_decl.fn_decl_return_type != null {
            ctx.checker.current_return_type = type_from_ast(ctx.checker, ctx.function_decl.fn_decl_return_type);
        }
    }
    if ctx.active_local_count > 0 {
        checker_enter_scope(ctx.checker);
        var local_i: i32 = 0;
        while local_i < ctx.active_local_count {
            const local_name: &byte = ctx.local_names[local_i];
            if local_name != null {
                var shadowed: i32 = 0;
                var local_j: i32 = local_i + 1;
                while local_j < ctx.active_local_count {
                    if ctx.local_names[local_j] != null &&
                        str_equals(ctx.local_names[local_j], local_name) != 0 {
                        shadowed = 1;
                        break;
                    }
                    local_j = local_j + 1;
                }
                if shadowed == 0 {
                    const temp_symbol: &Symbol = compiler_arena_alloc(ctx.checker.arena, @size_of(Symbol)) as &Symbol;
                    if temp_symbol != null {
                        const local_slot: i32 = ctx.local_slots[local_i];
                        var local_type: Type = copy_type(&ctx.local_types[local_i]);
                        var local_line: i32 = expr.line;
                        var local_column: i32 = expr.column;
                        var local_is_const: i32 = ctx.local_is_param[local_i];
                        if local_slot >= 0 && local_slot < EXEC_MAX_LOCALS {
                            local_type = copy_type(&ctx.slot_types[local_slot]);
                            const local_decl: &ASTNode = ctx.slot_decls[local_slot];
                            if local_decl != null {
                                local_line = local_decl.line;
                                local_column = local_decl.column;
                                if local_decl.type == ASTNodeType.AST_VAR_DECL {
                                    local_is_const = local_decl.var_decl_is_const;
                                }
                            }
                        }
                        temp_symbol.name = local_name;
                        temp_symbol.type = copy_type(&local_type);
                        temp_symbol.is_const = local_is_const;
                        temp_symbol.is_initialized = 1;
                        temp_symbol.scope_level = ctx.checker.scope_level;
                        temp_symbol.line = local_line;
                        temp_symbol.column = local_column;
                        temp_symbol.pointee_of = null;
                        temp_symbol.pointer_known_length = -1;
                        temp_symbol.pointer_length_param = null;
                        temp_symbol.next_in_scope = null;
                        _ = symbol_table_insert(ctx.checker, temp_symbol);
                    }
                }
            }
            local_i = local_i + 1;
        }
    }
    const inferred: Type = checker_infer_type(ctx.checker, expr);
    while ctx.checker.scope_level > saved_scope_level {
        checker_exit_scope(ctx.checker);
    }
    ctx.checker.in_function = prev_in_function;
    ctx.checker.current_function_decl = prev_function_decl;
    ctx.checker.current_return_type = prev_return_type;
    return inferred;
}

fn exec_lower_push_scope(ctx: &ExecLowerContext, scope_id: i32) void {
    if ctx == null || ctx.scope_depth >= EXEC_MAX_SCOPE_DEPTH {
        return;
    }
    if ctx.scope_depth >= 0 && ctx.scope_depth < EXEC_MAX_SCOPE_DEPTH {
        ctx.scope_markers[ctx.scope_depth] = ctx.active_local_count;
        ctx.scope_ids[ctx.scope_depth] = scope_id;
    }
    ctx.scope_depth = ctx.scope_depth + 1;
}

fn exec_lower_pop_scope(ctx: &ExecLowerContext) void {
    if ctx == null || ctx.scope_depth <= 0 {
        return;
    }
    ctx.scope_depth = ctx.scope_depth - 1;
    if ctx.scope_depth >= 0 && ctx.scope_depth < EXEC_MAX_SCOPE_DEPTH {
        ctx.active_local_count = ctx.scope_markers[ctx.scope_depth];
        ctx.next_slot = ctx.active_local_count;
        ctx.scope_ids[ctx.scope_depth] = -1;
    }
}

fn exec_lower_current_scope_id(ctx: &ExecLowerContext) i32 {
    if ctx == null || ctx.scope_depth <= 0 {
        return -1;
    }
    const scope_idx: i32 = ctx.scope_depth - 1;
    if scope_idx >= 0 && scope_idx < EXEC_MAX_SCOPE_DEPTH {
        return ctx.scope_ids[scope_idx];
    }
    return -1;
}

fn exec_lower_find_slot(ctx: &ExecLowerContext, name: &byte) i32 {
    if ctx == null || name == null {
        return -1;
    }
    var i: i32 = ctx.active_local_count - 1;
    while i >= 0 {
        if i >= 0 && i < EXEC_MAX_LOCALS {
            if ctx.local_names[i] != null && str_equals(ctx.local_names[i], name) != 0 {
                return ctx.local_slots[i];
            }
        }
        i = i - 1;
    }
    return -1;
}

fn exec_lower_find_global_slot(ctx: &ExecLowerContext, name: &byte) i32 {
    if ctx == null || name == null {
        return -1;
    }
    var i: i32 = ctx.global_count - 1;
    while i >= 0 {
        if i >= 0 && i < EXEC_MAX_GLOBALS {
            if ctx.global_names[i] != null && str_equals(ctx.global_names[i], name) != 0 {
                return i;
            }
        }
        i = i - 1;
    }
    return -1;
}

fn exec_lower_find_global_slot_by_decl(ctx: &ExecLowerContext, decl: &ASTNode) i32 {
    if ctx == null || decl == null {
        return -1;
    }
    var i: i32 = 0;
    while i < ctx.global_count {
        if i >= 0 && i < EXEC_MAX_GLOBALS && ctx.global_decls[i] == decl {
            return i;
        }
        i = i + 1;
    }
    return -1;
}

fn exec_lower_seed_globals(ctx: &ExecLowerContext, globals: &HIRGlobalSlot, global_count: i32) void {
    if ctx == null {
        return;
    }
    ctx.global_count = 0;
    if globals == null || global_count <= 0 {
        return;
    }
    var i: i32 = 0;
    while i < global_count && i < EXEC_MAX_GLOBALS {
        ctx.global_names[i] = globals[i].name;
        ctx.global_decls[i] = globals[i].decl;
        ctx.global_types[i] = copy_type(&globals[i].type_ref.type);
        ctx.global_is_const[i] = globals[i].is_const;
        i = i + 1;
    }
    ctx.global_count = i;
}

fn exec_lower_find_named_drop_decl(checker: &TypeChecker, named_type: &byte) &ASTNode {
    if checker == null || checker.program_node == null || named_type == null {
        return null;
    }
    const struct_decl: &ASTNode = find_struct_decl_from_program(checker.program_node, named_type);
    if struct_decl != null && struct_decl.struct_decl_methods != null {
        var si: i32 = 0;
        while si < struct_decl.struct_decl_method_count {
            const method: &ASTNode = struct_decl.struct_decl_methods[si];
            if method != null && method.type == ASTNodeType.AST_FN_DECL &&
                method.fn_decl_name != null &&
                str_equals(method.fn_decl_name, "drop" as *byte) != 0 {
                return method;
            }
            si = si + 1;
        }
    }
    const union_decl: &ASTNode = find_union_decl_from_program(checker.program_node, named_type);
    if union_decl != null && union_decl.union_decl_methods != null {
        var ui: i32 = 0;
        while ui < union_decl.union_decl_method_count {
            const method2: &ASTNode = union_decl.union_decl_methods[ui];
            if method2 != null && method2.type == ASTNodeType.AST_FN_DECL &&
                method2.fn_decl_name != null &&
                str_equals(method2.fn_decl_name, "drop" as *byte) != 0 {
                return method2;
            }
            ui = ui + 1;
        }
    }
    return null;
}

fn exec_lower_find_drop_decl(checker: &TypeChecker, decl: &ASTNode, type: &Type) &ASTNode {
    if checker == null || checker.program_node == null || type == null {
        return null;
    }
    if decl != null && decl.type == ASTNodeType.AST_VAR_DECL && decl.var_decl_type != null &&
        decl.var_decl_type.type == ASTNodeType.AST_TYPE_NAMED && decl.var_decl_type.type_named_name != null {
        const by_decl: &ASTNode = exec_lower_find_named_drop_decl(checker, decl.var_decl_type.type_named_name);
        if by_decl != null {
            return by_decl;
        }
    }
    const struct_name: &byte = type_get_struct_name(type);
    if struct_name != null {
        return exec_lower_find_named_drop_decl(checker, struct_name);
    }
    const union_name: &byte = type_get_union_name(type);
    if union_name != null {
        return exec_lower_find_named_drop_decl(checker, union_name);
    }
    return null;
}

fn exec_lower_append_local(ctx: &ExecLowerContext, decl: &ASTNode, name: &byte, type: &Type, is_param: i32) i32 {
    if ctx == null || name == null || ctx.active_local_count >= EXEC_MAX_LOCALS || ctx.next_slot >= EXEC_MAX_LOCALS {
        return -1;
    }
    const slot: i32 = ctx.next_slot;
    var scope_id: i32 = -1;
    var needs_drop: i32 = 0;
    var drop_decl: &ASTNode = null;
    if is_param == 0 {
        scope_id = exec_lower_current_scope_id(ctx);
        drop_decl = exec_lower_find_drop_decl(ctx.checker, decl, type);
        if checker_type_has_drop_method(ctx.checker, type) != 0 &&
            (decl == null || decl.var_decl_was_moved == 0) {
            needs_drop = 1;
        }
    }
    if ctx.active_local_count >= 0 && ctx.active_local_count < EXEC_MAX_LOCALS {
        ctx.local_names[ctx.active_local_count] = name;
        ctx.local_slots[ctx.active_local_count] = slot;
        ctx.local_types[ctx.active_local_count] = copy_type(type);
        ctx.local_is_param[ctx.active_local_count] = is_param;
    }
    if slot >= 0 && slot < EXEC_MAX_LOCALS {
        ctx.slot_names[slot] = name;
        ctx.slot_decls[slot] = decl;
        ctx.slot_types[slot] = copy_type(type);
        ctx.slot_is_param[slot] = is_param;
        ctx.slot_scope_ids[slot] = scope_id;
        ctx.slot_needs_drop[slot] = needs_drop;
        ctx.slot_drop_decls[slot] = drop_decl;
    }
    ctx.active_local_count = ctx.active_local_count + 1;
    ctx.next_slot = slot + 1;
    if ctx.next_slot > ctx.max_slot_count {
        ctx.max_slot_count = ctx.next_slot;
    }
    return slot;
}

fn exec_lower_alloc_scope_id(ctx: &ExecLowerContext) i32 {
    if ctx == null {
        return -1;
    }
    const scope_id: i32 = ctx.next_scope_id;
    ctx.next_scope_id = ctx.next_scope_id + 1;
    return scope_id;
}

fn exec_lower_make_type_ref(type: &Type) HIRTypeRef {
    return HIRTypeRef {
        type: copy_type(type),
    };
}

fn exec_lower_alloc_expr(ctx: &ExecLowerContext, ast_node: &ASTNode, kind: HIRExprKind, type: &Type) &HIRExpr {
    const expr: &HIRExpr = compiler_arena_alloc(ctx.arena, @size_of(HIRExpr)) as &HIRExpr;
    if expr == null {
        exec_backend_set_error(ast_node, "exec: HIRExpr 分配失败" as *byte, 0);
        return null;
    }
    _ = memset(expr as *byte, 0, @size_of(HIRExpr));
    expr.kind = kind;
    expr.ast_node = ast_node;
    expr.type_ref = exec_lower_make_type_ref(type);
    expr.local_slot = -1;
    expr.global_slot = -1;
    return expr;
}

fn exec_lower_alloc_stmt(ctx: &ExecLowerContext, ast_node: &ASTNode, kind: HIRStmtKind) &HIRStmt {
    const stmt: &HIRStmt = compiler_arena_alloc(ctx.arena, @size_of(HIRStmt)) as &HIRStmt;
    if stmt == null {
        exec_backend_set_error(ast_node, "exec: HIRStmt 分配失败" as *byte, 0);
        return null;
    }
    _ = memset(stmt as *byte, 0, @size_of(HIRStmt));
    stmt.kind = kind;
    stmt.ast_node = ast_node;
    stmt.scope_id = -1;
    stmt.local_slot = -1;
    return stmt;
}

fn exec_lower_alloc_scope_stmt(ctx: &ExecLowerContext, ast_node: &ASTNode, kind: HIRStmtKind, scope_id: i32) &HIRStmt {
    const stmt: &HIRStmt = exec_lower_alloc_stmt(ctx, ast_node, kind);
    if stmt == null {
        return null;
    }
    stmt.scope_id = scope_id;
    return stmt;
}

fn exec_lower_alloc_scope_stmt_raw(arena: &CompilerArena, ast_node: &ASTNode, kind: HIRStmtKind, scope_id: i32) &HIRStmt {
    const stmt: &HIRStmt = compiler_arena_alloc(arena, @size_of(HIRStmt)) as &HIRStmt;
    if stmt == null {
        exec_backend_set_error(ast_node, "exec: HIRStmt 分配失败" as *byte, 0);
        return null;
    }
    _ = memset(stmt as *byte, 0, @size_of(HIRStmt));
    stmt.kind = kind;
    stmt.ast_node = ast_node;
    stmt.scope_id = scope_id;
    stmt.local_slot = -1;
    return stmt;
}

fn exec_lower_alloc_scoped_block(ctx: &ExecLowerContext, ast_node: &ASTNode, body_stmt_count: i32) &HIRBlock {
    if ctx == null || body_stmt_count < 0 {
        return null;
    }
    const scope_id: i32 = exec_lower_alloc_scope_id(ctx);
    if scope_id < 0 {
        exec_backend_set_error(ast_node, "exec: scope id 分配失败" as *byte, 0);
        return null;
    }
    const total_stmt_count: i32 = body_stmt_count + 2;
    const block: &HIRBlock = compiler_arena_alloc(ctx.arena, @size_of(HIRBlock)) as &HIRBlock;
    const stmts: & & HIRStmt = compiler_arena_alloc(ctx.arena, @size_of(&HIRStmt) * total_stmt_count as usize) as & & HIRStmt;
    if block == null || stmts == null {
        exec_backend_set_error(ast_node, "exec: HIRBlock 分配失败" as *byte, 0);
        return null;
    }
    _ = memset(block as *byte, 0, @size_of(HIRBlock));
    block.scope_id = scope_id;
    block.stmts = stmts;
    block.stmt_count = total_stmt_count;
    const enter_stmt: &HIRStmt = exec_lower_alloc_scope_stmt(ctx, ast_node, HIRStmtKind.HIR_STMT_SCOPE_ENTER, scope_id);
    const exit_stmt: &HIRStmt = exec_lower_alloc_scope_stmt(ctx, ast_node, HIRStmtKind.HIR_STMT_SCOPE_EXIT, scope_id);
    if enter_stmt == null || exit_stmt == null {
        return null;
    }
    stmts[0] = enter_stmt;
    stmts[total_stmt_count - 1] = exit_stmt;
    return block;
}

fn exec_lower_alloc_scoped_block_raw(arena: &CompilerArena, ast_node: &ASTNode, scope_id: i32, body_stmt_count: i32) &HIRBlock {
    if arena == null || body_stmt_count < 0 {
        return null;
    }
    const total_stmt_count: i32 = body_stmt_count + 2;
    const block: &HIRBlock = compiler_arena_alloc(arena, @size_of(HIRBlock)) as &HIRBlock;
    const stmts: & & HIRStmt = compiler_arena_alloc(arena, @size_of(&HIRStmt) * total_stmt_count as usize) as & & HIRStmt;
    if block == null || stmts == null {
        exec_backend_set_error(ast_node, "exec: HIRBlock 分配失败" as *byte, 0);
        return null;
    }
    _ = memset(block as *byte, 0, @size_of(HIRBlock));
    block.scope_id = scope_id;
    block.stmts = stmts;
    block.stmt_count = total_stmt_count;
    const enter_stmt: &HIRStmt = exec_lower_alloc_scope_stmt_raw(arena, ast_node, HIRStmtKind.HIR_STMT_SCOPE_ENTER, scope_id);
    const exit_stmt: &HIRStmt = exec_lower_alloc_scope_stmt_raw(arena, ast_node, HIRStmtKind.HIR_STMT_SCOPE_EXIT, scope_id);
    if enter_stmt == null || exit_stmt == null {
        return null;
    }
    stmts[0] = enter_stmt;
    stmts[total_stmt_count - 1] = exit_stmt;
    return block;
}

fn exec_lower_extract_block_result_expr(ctx: &ExecLowerContext, block: &ASTNode) &HIRExpr {
    if block == null || block.type != ASTNodeType.AST_BLOCK || block.block_stmt_count != 1 {
        return exec_lower_fail_expr(block, "exec: 当前仅支持单表达式 catch/match 分支块" as *byte);
    }
    const only_stmt: &ASTNode = block.block_stmts[0];
    if only_stmt == null {
        return exec_lower_fail_expr(block, "exec: catch/match 分支块为空" as *byte);
    }
    if only_stmt.type == ASTNodeType.AST_RETURN_STMT && only_stmt.return_stmt_expr != null {
        return exec_lower_expr(ctx, only_stmt.return_stmt_expr);
    }
    return exec_lower_expr(ctx, only_stmt);
}

fn exec_lower_block_last_stmt(block: &ASTNode) &ASTNode {
    if block == null || block.type != ASTNodeType.AST_BLOCK || block.block_stmts == null || block.block_stmt_count <= 0 {
        return null;
    }
    return block.block_stmts[block.block_stmt_count - 1];
}

fn exec_lower_match_arm_return_expr(arm: &ASTMatchArm) &ASTNode {
    if arm == null || arm.result_expr == null {
        return null;
    }
    if arm.result_is_block == 0 {
        return arm.result_expr;
    }
    const block: &ASTNode = arm.result_expr;
    if block.type != ASTNodeType.AST_BLOCK || block.block_stmts == null || block.block_stmt_count != 1 {
        return null;
    }
    const only_stmt: &ASTNode = block.block_stmts[0];
    if only_stmt == null || only_stmt.type != ASTNodeType.AST_RETURN_STMT || only_stmt.return_stmt_expr == null {
        return null;
    }
    return only_stmt.return_stmt_expr;
}

fn exec_lower_match_arm_result_node(arm: &ASTMatchArm) &ASTNode {
    if arm == null || arm.result_expr == null {
        return null;
    }
    if arm.result_is_block == 0 {
        return arm.result_expr;
    }
    const block: &ASTNode = arm.result_expr;
    if block.type != ASTNodeType.AST_BLOCK || block.block_stmts == null || block.block_stmt_count != 1 {
        return null;
    }
    const only_stmt: &ASTNode = block.block_stmts[0];
    if only_stmt == null {
        return null;
    }
    if only_stmt.type == ASTNodeType.AST_RETURN_STMT {
        if only_stmt.return_stmt_expr == null {
            return null;
        }
        return only_stmt.return_stmt_expr;
    }
    return only_stmt;
}

fn exec_lower_infer_match_expr_type(ctx: &ExecLowerContext, expr: &ASTNode) Type {
    if ctx == null || expr == null || expr.type != ASTNodeType.AST_MATCH_EXPR ||
        expr.match_expr_arms == null || expr.match_expr_arm_count <= 0 {
        return make_void_type();
    }
    const subject_type: Type = exec_lower_resolve_exact_type(ctx, expr.match_expr_expr);
    var unified: Type = make_void_type();
    var first: i32 = 1;
    var i: i32 = 0;
    while i < expr.match_expr_arm_count {
        const arm: ASTMatchArm = expr.match_expr_arms[i];
        const arm_expr: &ASTNode = exec_lower_match_arm_result_node(expr.match_expr_arms + i);
        if arm_expr == null {
            return make_void_type();
        }
        var arm_type: Type = make_void_type();
        if arm.kind == MatchPatternKind.MATCH_PAT_UNION &&
            arm.variant_name != null &&
            subject_type.kind == TypeKind.TYPE_UNION {
            exec_lower_push_scope(ctx, -1);
            if arm.var_name != null && str_equals(arm.var_name, "_" as *byte) == 0 {
                const bind_type: Type = exec_lower_union_variant_type(ctx, copy_type(&subject_type), arm.variant_name);
                if bind_type.kind == TypeKind.TYPE_VOID {
                    exec_lower_pop_scope(ctx);
                    return make_void_type();
                }
                if exec_lower_append_local(ctx, null, arm.var_name, &bind_type, 0) < 0 {
                    exec_lower_pop_scope(ctx);
                    return make_void_type();
                }
            }
            arm_type = exec_lower_resolve_exact_type(ctx, arm_expr);
            exec_lower_pop_scope(ctx);
        } else {
            arm_type = exec_lower_resolve_exact_type(ctx, arm_expr);
        }
        if first != 0 {
            unified = copy_type(&arm_type);
            first = 0;
        } else {
            if unified.kind == TypeKind.TYPE_INT_LIMIT && is_integer_type(arm_type.kind) != 0 {
                unified = copy_type(&arm_type);
            } else if arm_type.kind == TypeKind.TYPE_INT_LIMIT && is_integer_type(unified.kind) != 0 {
                arm_type = copy_type(&unified);
            }
            if type_equals(unified, copy_type(&arm_type)) == 0 {
                return make_void_type();
            }
        }
        i = i + 1;
    }
    return unified;
}

fn exec_lower_make_returning_match_expr(ctx: &ExecLowerContext, expr: &ASTNode) &ASTNode {
    if ctx == null || expr == null || expr.type != ASTNodeType.AST_MATCH_EXPR ||
        expr.match_expr_arms == null || expr.match_expr_arm_count <= 0 {
        return null;
    }
    const synthetic_expr: &ASTNode = compiler_arena_alloc(ctx.arena, @size_of(ASTNode)) as &ASTNode;
    const synthetic_arms: &ASTMatchArm = compiler_arena_alloc(ctx.arena, @size_of(ASTMatchArm) * expr.match_expr_arm_count as usize) as &ASTMatchArm;
    if synthetic_expr == null || synthetic_arms == null {
        exec_backend_set_error(expr, "exec: returning match synthetic node 分配失败" as *byte, 0);
        return null;
    }
    synthetic_expr[0] = expr[0];
    synthetic_expr.match_expr_arms = synthetic_arms;
    var i: i32 = 0;
    while i < expr.match_expr_arm_count {
        synthetic_arms[i] = expr.match_expr_arms[i];
        const arm_expr: &ASTNode = exec_lower_match_arm_return_expr(expr.match_expr_arms + i);
        if arm_expr == null {
            return null;
        }
        synthetic_arms[i].result_expr = arm_expr;
        synthetic_arms[i].result_is_block = 0;
        i = i + 1;
    }
    return synthetic_expr;
}

fn exec_lower_try_make_returning_match_stmt(ctx: &ExecLowerContext, stmt_node: &ASTNode) &HIRStmt {
    if ctx == null || stmt_node == null || stmt_node.type != ASTNodeType.AST_MATCH_EXPR {
        return null;
    }
    const synthetic_expr: &ASTNode = exec_lower_make_returning_match_expr(ctx, stmt_node);
    if synthetic_expr == null {
        return null;
    }
    const stmt: &HIRStmt = exec_lower_alloc_stmt(ctx, stmt_node, HIRStmtKind.HIR_STMT_RETURN);
    if stmt == null {
        return null;
    }
    if ctx.function_decl != null && ctx.function_decl.fn_decl_return_type != null {
        const return_type: Type = type_from_ast(ctx.checker, ctx.function_decl.fn_decl_return_type);
        stmt.expr = exec_lower_expr(ctx, synthetic_expr);
        if stmt.expr != null &&
            return_type.kind != TypeKind.TYPE_ERROR_UNION &&
            type_equals(stmt.expr.type_ref.type, return_type) == 0 &&
            exec_type_is_vm_value_supported(return_type) != 0 {
            const cast_return: &HIRExpr = exec_lower_alloc_expr(ctx, stmt_node, HIRExprKind.HIR_EXPR_CAST, &return_type);
            if cast_return == null {
                return null;
            }
            cast_return.left = stmt.expr;
            stmt.expr = cast_return;
        }
    } else {
        stmt.expr = exec_lower_expr(ctx, synthetic_expr);
    }
    if stmt.expr == null {
        return null;
    }
    return stmt;
}

fn exec_lower_make_block_prefix(ctx: &ExecLowerContext, block: &ASTNode) &HIRBlock {
    if ctx == null || block == null || block.type != ASTNodeType.AST_BLOCK || block.block_stmts == null {
        return null;
    }
    if block.block_stmt_count <= 1 {
        return null;
    }
    const prefix_count: i32 = block.block_stmt_count - 1;
    const synthetic_block: &ASTNode = compiler_arena_alloc(ctx.arena, @size_of(ASTNode)) as &ASTNode;
    const synthetic_stmts: & & ASTNode = compiler_arena_alloc(ctx.arena, @size_of(&ASTNode) * prefix_count as usize) as & & ASTNode;
    if synthetic_block == null || synthetic_stmts == null {
        exec_backend_set_error(block, "exec: catch 前缀 block 分配失败" as *byte, 0);
        return null;
    }
    _ = memset(synthetic_block as *byte, 0, @size_of(ASTNode));
    synthetic_block.type = ASTNodeType.AST_BLOCK;
    synthetic_block.line = block.line;
    synthetic_block.column = block.column;
    synthetic_block.filename = block.filename;
    synthetic_block.block_stmts = synthetic_stmts;
    synthetic_block.block_stmt_count = prefix_count;
    var i: i32 = 0;
    while i < prefix_count {
        synthetic_stmts[i] = block.block_stmts[i];
        i = i + 1;
    }
    return exec_lower_block(ctx, synthetic_block);
}

fn exec_lower_make_bool_const_expr(ctx: &ExecLowerContext, ast_node: &ASTNode, value: i32) &HIRExpr {
    const bool_type: Type = make_bool_type();
    const expr: &HIRExpr = exec_lower_alloc_expr(ctx, ast_node, HIRExprKind.HIR_EXPR_CONST, &bool_type);
    if expr == null {
        return null;
    }
    expr.bool_value = value;
    return expr;
}

fn exec_lower_make_int_const_expr(ctx: &ExecLowerContext, ast_node: &ASTNode, type: &Type, value: i64) &HIRExpr {
    const expr: &HIRExpr = exec_lower_alloc_expr(ctx, ast_node, HIRExprKind.HIR_EXPR_CONST, type);
    if expr == null {
        return null;
    }
    expr.int_value = value;
    return expr;
}

fn exec_lower_make_float_const_expr(ctx: &ExecLowerContext, ast_node: &ASTNode, type: &Type, value: f64) &HIRExpr {
    const expr: &HIRExpr = exec_lower_alloc_expr(ctx, ast_node, HIRExprKind.HIR_EXPR_CONST, type);
    if expr == null {
        return null;
    }
    expr.float_value = value;
    return expr;
}

fn exec_lower_pointer_pointee_kind(type: &Type) i32 {
    if type == null || type.kind != TypeKind.TYPE_POINTER || type.pointer_to == null {
        return TypeKind.TYPE_VOID as i32;
    }
    if type.pointer_to[0].kind == TypeKind.TYPE_ATOMIC {
        const inner: &Type = type_get_atomic_inner(&type.pointer_to[0]);
        if inner != null {
            return inner[0].kind as i32;
        }
    }
    return type.pointer_to[0].kind as i32;
}

fn exec_lower_make_void_pointer_type() Type {
    return Type {
        kind: TypeKind.TYPE_POINTER,
        data: TypeData.pointer(PointerData {
            pointee: null as &Type,
            is_ffi: 0,
        }),
        enum_name: null,
        interface_name: null,
        interface_type_args: null,
        interface_type_arg_count: 0,
        struct_name: null,
        union_name: null,
        pointer_to: null,
        is_ffi_pointer: 0,
        element_type: null,
        array_size: 0,
        slice_element_type: null,
        slice_len: 0,
        slice_element_is_const: 0,
        tuple_element_types: null,
        tuple_count: 0,
        error_union_payload_type: null,
        error_error_id: 0,
        atomic_inner_type: null,
        generic_param_name: null,
        struct_type_args: null,
        struct_type_arg_count: 0,
        union_type_args: null,
        union_type_arg_count: 0,
    };
}

fn exec_lower_make_string_const_expr(ctx: &ExecLowerContext, ast_node: &ASTNode, type: &Type, value: &byte) &HIRExpr {
    const expr: &HIRExpr = exec_lower_alloc_expr(ctx, ast_node, HIRExprKind.HIR_EXPR_CONST, type);
    if expr == null {
        return null;
    }
    expr.string_value = value;
    return expr;
}

fn exec_lower_make_zero_expr(ctx: &ExecLowerContext, ast_node: &ASTNode, type: &Type) &HIRExpr {
    return exec_lower_alloc_expr(ctx, ast_node, HIRExprKind.HIR_EXPR_ZERO, type);
}

fn exec_lower_make_repeat_array_init_expr(ctx: &ExecLowerContext, expr: &ASTNode, array_type: &Type) &HIRExpr {
    if ctx == null || expr == null || array_type == null {
        return null;
    }
    if expr.type != ASTNodeType.AST_ARRAY_LITERAL ||
        expr.array_literal_repeat_count_expr == null ||
        expr.array_literal_element_count <= 0 ||
        expr.array_literal_elements == null ||
        array_type.kind != TypeKind.TYPE_ARRAY ||
        array_type.element_type == null {
        return exec_lower_fail_expr(expr, "exec: repeat array literal 目标类型无效" as *byte);
    }
    var repeat_count: i32 = array_type.array_size;
    if repeat_count <= 0 {
        repeat_count = checker_eval_const_expr(ctx.checker, expr.array_literal_repeat_count_expr);
    }
    if repeat_count < 0 {
        return exec_lower_fail_expr(expr, "exec: repeat array literal 次数必须为常量非负值" as *byte);
    }
    const repeated_item: &HIRExpr = exec_lower_coerce_expr(ctx, expr.array_literal_elements[0], array_type.element_type);
    if repeated_item == null {
        return null;
    }
    const repeat_items: & & HIRExpr = compiler_arena_alloc(ctx.arena, @size_of(&HIRExpr)) as & & HIRExpr;
    if repeat_items == null {
        exec_backend_set_error(expr, "exec: repeat array literal items 分配失败" as *byte, 0);
        return null;
    }
    repeat_items[0] = repeated_item;
    const hir_repeat_array: &HIRExpr = exec_lower_alloc_expr(ctx, expr, HIRExprKind.HIR_EXPR_ARRAY_INIT, array_type);
    if hir_repeat_array == null {
        return null;
    }
    hir_repeat_array.items = repeat_items;
    hir_repeat_array.item_count = 1;
    hir_repeat_array.int_value = repeat_count as i64;
    return hir_repeat_array;
}

fn exec_lower_basename(path: &byte) &byte {
    if path == null {
        return "(unknown)" as &byte;
    }
    var basename: &byte = strrchr(path as *byte, 47) as &byte;
    if basename == null {
        basename = strrchr(path as *byte, 92) as &byte;
    }
    if basename != null {
        return (basename as i64 + 1) as &byte;
    }
    return path;
}

fn exec_lower_known_len(expr_type: &Type) i32 {
    if expr_type == null {
        return -1;
    }
    if expr_type.kind == TypeKind.TYPE_ARRAY {
        const array_len: i32 = type_get_array_size(expr_type);
        if array_len > 0 {
            return array_len;
        }
        if expr_type.array_size > 0 {
            return expr_type.array_size;
        }
        return -1;
    }
    if expr_type.kind == TypeKind.TYPE_SLICE {
        if expr_type.slice_len > 0 {
            return expr_type.slice_len;
        }
    }
    return -1;
}

fn exec_lower_known_len_for_expr(ctx: &ExecLowerContext, expr: &ASTNode) i32 {
    if ctx == null || expr == null {
        return -1;
    }
    if expr.type == ASTNodeType.AST_IDENTIFIER && expr.identifier_name != null {
        const local_slot: i32 = exec_lower_find_slot(ctx, expr.identifier_name);
        if local_slot >= 0 && local_slot < EXEC_MAX_LOCALS {
            return exec_lower_known_len(&ctx.slot_types[local_slot]);
        }
        const global_slot: i32 = exec_lower_find_global_slot(ctx, expr.identifier_name);
        if global_slot >= 0 && global_slot < EXEC_MAX_GLOBALS {
            return exec_lower_known_len(&ctx.global_types[global_slot]);
        }
    }
    const expr_type: Type = exec_lower_resolve_exact_type(ctx, expr);
    return exec_lower_known_len(&expr_type);
}

fn exec_lower_named_error_literal(expr: &ASTNode) &ASTNode {
    if expr == null {
        return null;
    }
    if expr.type == ASTNodeType.AST_ERROR_VALUE {
        return expr;
    }
    if expr.type == ASTNodeType.AST_CAST_EXPR && expr.cast_expr_expr != null {
        return exec_lower_named_error_literal(expr.cast_expr_expr);
    }
    return null;
}

fn exec_lower_make_local_expr(ctx: &ExecLowerContext, ast_node: &ASTNode, slot: i32, type: &Type) &HIRExpr {
    const expr: &HIRExpr = exec_lower_alloc_expr(ctx, ast_node, HIRExprKind.HIR_EXPR_LOCAL, type);
    if expr == null {
        return null;
    }
    expr.local_slot = slot;
    return expr;
}

fn exec_lower_make_global_expr(ctx: &ExecLowerContext, ast_node: &ASTNode, slot: i32, type: &Type) &HIRExpr {
    const expr: &HIRExpr = exec_lower_alloc_expr(ctx, ast_node, HIRExprKind.HIR_EXPR_GLOBAL, type);
    if expr == null {
        return null;
    }
    expr.global_slot = slot;
    return expr;
}

fn exec_lower_make_binary_expr(ctx: &ExecLowerContext, ast_node: &ASTNode, op: i32, left: &HIRExpr, right: &HIRExpr, type: &Type) &HIRExpr {
    const expr: &HIRExpr = exec_lower_alloc_expr(ctx, ast_node, HIRExprKind.HIR_EXPR_BINARY, type);
    if expr == null {
        return null;
    }
    expr.binary_op = op;
    expr.left = left;
    expr.right = right;
    return expr;
}

fn exec_lower_make_pointer_type_copy(ctx: &ExecLowerContext, pointee_type: Type) Type {
    if ctx == null || ctx.arena == null {
        return exec_lower_make_void_pointer_type();
    }
    const pointee_copy: &Type = compiler_arena_alloc(ctx.arena, @size_of(Type)) as &Type;
    if pointee_copy == null {
        return exec_lower_make_void_pointer_type();
    }
    pointee_copy[0] = copy_type(&pointee_type);
    return make_pointer_type(ctx.arena, pointee_copy, 0);
}

fn exec_lower_add_unique_decl(out_decls: & & ASTNode, out_count: &i32, decl: &ASTNode) i32 {
    if out_count == null || decl == null {
        return -1;
    }
    var i: i32 = 0;
    while i < out_count[0] {
        if out_decls[i] == decl {
            return 0;
        }
        i = i + 1;
    }
    if out_count[0] >= EXEC_MAX_INTERFACE_METHODS {
        return -1;
    }
    out_decls[out_count[0]] = decl;
    out_count[0] = out_count[0] + 1;
    return 0;
}

fn exec_lower_collect_interface_method_sigs_recursive(ctx: &ExecLowerContext, interface_name: &byte, out_decls: & & ASTNode, out_count: &i32) i32 {
    if ctx == null || ctx.checker == null || ctx.checker.program_node == null ||
        interface_name == null || out_count == null {
        return -1;
    }
    const iface: &ASTNode = find_interface_decl_from_program(ctx.checker.program_node, interface_name);
    if iface == null {
        return -1;
    }
    var i: i32 = 0;
    while i < iface.interface_decl_method_sig_count {
        const sig: &ASTNode = iface.interface_decl_method_sigs[i];
        if sig != null && exec_lower_add_unique_decl(out_decls, out_count, sig) != 0 {
            return -1;
        }
        i = i + 1;
    }
    i = 0;
    while i < iface.interface_decl_composed_count {
        const composed_name: &byte = iface.interface_decl_composed_interfaces[i];
        if composed_name != null &&
            exec_lower_collect_interface_method_sigs_recursive(ctx, composed_name, out_decls, out_count) != 0 {
            return -1;
        }
        i = i + 1;
    }
    return 0;
}

fn exec_lower_collect_interface_method_sigs(ctx: &ExecLowerContext, interface_type: &Type, out_decls: & & ASTNode, out_count: &i32) i32 {
    const interface_name: &byte = type_get_interface_name(interface_type);
    if interface_name == null {
        return -1;
    }
    return exec_lower_collect_interface_method_sigs_recursive(ctx, interface_name, out_decls, out_count);
}

fn exec_lower_interface_method_index(ctx: &ExecLowerContext, interface_type: &Type, method_name: &byte) i32 {
    if ctx == null || method_name == null {
        return -1;
    }
    var sigs: [&ASTNode: EXEC_MAX_INTERFACE_METHODS] = [];
    var sig_count: i32 = 0;
    if exec_lower_collect_interface_method_sigs(ctx, interface_type, &sigs[0] as & & ASTNode, &sig_count) != 0 {
        return -1;
    }
    var i: i32 = 0;
    while i < sig_count {
        const sig: &ASTNode = sigs[i];
        if sig != null && sig.fn_decl_name != null && str_equals(sig.fn_decl_name, method_name) != 0 {
            return i;
        }
        i = i + 1;
    }
    return -1;
}

fn exec_lower_struct_field_type(ctx: &ExecLowerContext, struct_type: Type, field_name: &byte) Type {
    const struct_name: &byte = type_get_struct_name(&struct_type);
    if ctx == null || ctx.checker == null || ctx.checker.program_node == null ||
        struct_name == null || field_name == null {
        return make_void_type();
    }
    const struct_decl: &ASTNode = find_struct_decl_from_program(ctx.checker.program_node, struct_name);
    if struct_decl == null {
        return make_void_type();
    }
    return find_struct_field_type(ctx.checker, struct_decl, field_name);
}

fn exec_lower_resolve_exact_type(ctx: &ExecLowerContext, expr: &ASTNode) Type {
    var resolved: Type = exec_lower_expr_type(ctx, expr);
    if ctx == null || expr == null || resolved.kind != TypeKind.TYPE_VOID {
        return resolved;
    }
    if expr.type == ASTNodeType.AST_IDENTIFIER && expr.identifier_name != null {
        const symbol: &Symbol = symbol_table_lookup(ctx.checker, expr.identifier_name);
        if symbol != null && symbol.type.kind != TypeKind.TYPE_VOID {
            return symbol.type;
        }
        const slot: i32 = exec_lower_find_slot(ctx, expr.identifier_name);
        if slot >= 0 && slot < EXEC_MAX_LOCALS {
            return ctx.slot_types[slot];
        }
        const global_slot: i32 = exec_lower_find_global_slot(ctx, expr.identifier_name);
        if global_slot >= 0 && global_slot < EXEC_MAX_GLOBALS {
            return ctx.global_types[global_slot];
        }
        return resolved;
    }
    if expr.type == ASTNodeType.AST_MEMBER_ACCESS &&
        expr.member_access_object != null && expr.member_access_field_name != null {
        var parent_type: Type = exec_lower_resolve_exact_type(ctx, expr.member_access_object);
        if parent_type.kind == TypeKind.TYPE_POINTER && parent_type.pointer_to != null {
            parent_type = parent_type.pointer_to[0];
        }
        if parent_type.kind == TypeKind.TYPE_TUPLE && parent_type.tuple_element_types != null {
            const tuple_index: i32 = atoi(expr.member_access_field_name as *byte);
            if tuple_index >= 0 && tuple_index < parent_type.tuple_count {
                return parent_type.tuple_element_types[tuple_index];
            }
        }
        if parent_type.kind == TypeKind.TYPE_STRUCT {
            const field_type: Type = exec_lower_struct_field_type(ctx, copy_type(&parent_type), expr.member_access_field_name);
            if field_type.kind != TypeKind.TYPE_VOID {
                return field_type;
            }
        }
        if parent_type.kind == TypeKind.TYPE_SLICE {
            if str_equals(expr.member_access_field_name, "len" as *byte) != 0 {
                return make_usize_type();
            }
            if str_equals(expr.member_access_field_name, "ptr" as *byte) != 0 &&
                parent_type.slice_element_type != null {
                return exec_lower_make_pointer_type_copy(ctx, parent_type.slice_element_type[0]);
            }
        }
        if (parent_type.kind == TypeKind.TYPE_ERROR || parent_type.kind == TypeKind.TYPE_ERROR_UNION) &&
            str_equals(expr.member_access_field_name, "error_id" as *byte) != 0 {
            return make_u32_type();
        }
        if parent_type.kind == TypeKind.TYPE_ERROR_UNION &&
            str_equals(expr.member_access_field_name, "value" as *byte) != 0 &&
            parent_type.error_union_payload_type != null {
            return parent_type.error_union_payload_type[0];
        }
        return resolved;
    }
    if expr.type == ASTNodeType.AST_ARRAY_ACCESS && expr.array_access_array != null {
        const array_type: Type = exec_lower_resolve_exact_type(ctx, expr.array_access_array);
        if array_type.kind == TypeKind.TYPE_ARRAY && array_type.element_type != null {
            return array_type.element_type[0];
        }
        if array_type.kind == TypeKind.TYPE_SLICE && array_type.slice_element_type != null {
            return array_type.slice_element_type[0];
        }
        if array_type.kind == TypeKind.TYPE_POINTER && array_type.pointer_to != null {
            const pointed_type: Type = array_type.pointer_to[0];
            if pointed_type.kind == TypeKind.TYPE_ARRAY && pointed_type.element_type != null {
                return pointed_type.element_type[0];
            }
            return pointed_type;
        }
    }
    if expr.type == ASTNodeType.AST_UNARY_EXPR &&
        expr.unary_expr_operand != null &&
        (expr.unary_expr_op as TokenType) == TokenType.TOKEN_ASTERISK {
        const operand_type: Type = exec_lower_resolve_exact_type(ctx, expr.unary_expr_operand);
        if operand_type.kind == TypeKind.TYPE_POINTER && operand_type.pointer_to != null {
            return operand_type.pointer_to[0];
        }
    }
    return resolved;
}

fn exec_lower_make_addr_expr(ctx: &ExecLowerContext, ast_node: &ASTNode, pointee_type: &Type) &HIRExpr {
    if pointee_type == null {
        return null;
    }
    const pointer_type: Type = exec_lower_make_pointer_type_copy(ctx, pointee_type[0]);
    return exec_lower_alloc_expr(ctx, ast_node, HIRExprKind.HIR_EXPR_ADDR, &pointer_type);
}

fn exec_lower_make_ref_expr(ctx: &ExecLowerContext, expr: &ASTNode) &HIRExpr {
    if ctx == null || expr == null {
        return null;
    }
    const expr_type: Type = exec_lower_resolve_exact_type(ctx, expr);
    if expr.type == ASTNodeType.AST_IDENTIFIER && expr.identifier_name != null {
        const local_slot: i32 = exec_lower_find_slot(ctx, expr.identifier_name);
        if local_slot >= 0 && local_slot < EXEC_MAX_LOCALS {
            const addr_local: &HIRExpr = exec_lower_make_addr_expr(ctx, expr, &ctx.slot_types[local_slot]);
            if addr_local == null {
                return null;
            }
            addr_local.local_slot = local_slot;
            return addr_local;
        }
        const global_slot: i32 = exec_lower_find_global_slot(ctx, expr.identifier_name);
        if global_slot >= 0 && global_slot < EXEC_MAX_GLOBALS {
            const addr_global: &HIRExpr = exec_lower_make_addr_expr(ctx, expr, &ctx.global_types[global_slot]);
            if addr_global == null {
                return null;
            }
            addr_global.global_slot = global_slot;
            return addr_global;
        }
    }
    if expr.type == ASTNodeType.AST_MEMBER_ACCESS && expr.member_access_object != null && expr.member_access_field_name != null {
        const object_raw_type: Type = exec_lower_resolve_exact_type(ctx, expr.member_access_object);
        var base_type: Type = exec_lower_member_base_type(ctx, expr.member_access_object);
        const field_type: Type = exec_lower_resolve_exact_type(ctx, expr);
        if base_type.kind == TypeKind.TYPE_VOID &&
            expr.member_access_object.type == ASTNodeType.AST_ARRAY_ACCESS &&
            expr.member_access_object.array_access_array != null {
            const array_type: Type = exec_lower_resolve_exact_type(ctx, expr.member_access_object.array_access_array);
            if array_type.kind == TypeKind.TYPE_ARRAY && array_type.element_type != null {
                base_type = array_type.element_type[0];
            } else if array_type.kind == TypeKind.TYPE_SLICE && array_type.slice_element_type != null {
                base_type = array_type.slice_element_type[0];
            } else if array_type.kind == TypeKind.TYPE_POINTER && array_type.pointer_to != null {
                const pointed_type: Type = array_type.pointer_to[0];
                if pointed_type.kind == TypeKind.TYPE_ARRAY && pointed_type.element_type != null {
                    base_type = pointed_type.element_type[0];
                } else {
                    base_type = pointed_type;
                }
            }
        }
        if base_type.kind == TypeKind.TYPE_POINTER && base_type.pointer_to != null {
            base_type = base_type.pointer_to[0];
        }
        var field_index: i32 = -1;
        if base_type.kind == TypeKind.TYPE_TUPLE {
            field_index = atoi(expr.member_access_field_name as *byte);
        } else {
            field_index = exec_lower_struct_field_index(ctx, base_type, expr.member_access_field_name);
        }
        if field_index < 0 {
            return null;
        }
        var base_ref: &HIRExpr = null;
        if object_raw_type.kind == TypeKind.TYPE_POINTER {
            base_ref = exec_lower_expr(ctx, expr.member_access_object);
        } else {
            base_ref = exec_lower_make_ref_expr(ctx, expr.member_access_object);
        }
        if base_ref == null {
            base_ref = exec_lower_expr(ctx, expr.member_access_object);
        }
        if base_ref == null {
            return null;
        }
        const addr_field: &HIRExpr = exec_lower_make_addr_expr(ctx, expr, &field_type);
        if addr_field == null {
            return null;
        }
        addr_field.left = base_ref;
        addr_field.int_value = field_index as i64;
        return addr_field;
    }
    if expr.type == ASTNodeType.AST_ARRAY_ACCESS && expr.array_access_array != null && expr.array_access_index != null {
        const array_raw_type: Type = exec_lower_resolve_exact_type(ctx, expr.array_access_array);
        var base_expr: &HIRExpr = null;
        if array_raw_type.kind == TypeKind.TYPE_POINTER {
            base_expr = exec_lower_expr(ctx, expr.array_access_array);
        } else {
            base_expr = exec_lower_make_ref_expr(ctx, expr.array_access_array);
        }
        if base_expr == null {
            base_expr = exec_lower_expr(ctx, expr.array_access_array);
        }
        const index_expr: &HIRExpr = exec_lower_expr(ctx, expr.array_access_index);
        if base_expr == null || index_expr == null {
            return null;
        }
        const addr_index: &HIRExpr = exec_lower_make_addr_expr(ctx, expr, &expr_type);
        if addr_index == null {
            return null;
        }
        addr_index.left = base_expr;
        addr_index.right = index_expr;
        return addr_index;
    }
    const source_expr: &HIRExpr = exec_lower_expr(ctx, expr);
    if source_expr == null {
        return null;
    }
    const addr_value: &HIRExpr = exec_lower_make_addr_expr(ctx, expr, &expr_type);
    if addr_value == null {
        return null;
    }
    addr_value.left = source_expr;
    return addr_value;
}

fn exec_lower_make_va_storage_ref_expr(ctx: &ExecLowerContext, expr: &ASTNode) &HIRExpr {
    if ctx == null || expr == null {
        return null;
    }
    if expr.type == ASTNodeType.AST_UNARY_EXPR &&
        (expr.unary_expr_op as TokenType) == TokenType.TOKEN_AMPERSAND &&
        expr.unary_expr_operand != null {
        return exec_lower_make_ref_expr(ctx, expr.unary_expr_operand);
    }
    return exec_lower_make_ref_expr(ctx, expr);
}

fn exec_lower_method_receiver_expr(ctx: &ExecLowerContext, object_expr: &ASTNode, method_decl: &ASTNode) &HIRExpr {
    if ctx == null || object_expr == null || method_decl == null ||
        method_decl.type != ASTNodeType.AST_FN_DECL ||
        method_decl.fn_decl_param_count <= 0 || method_decl.fn_decl_params == null {
        return null;
    }
    const receiver_param: &ASTNode = method_decl.fn_decl_params[0];
    if receiver_param == null || receiver_param.type != ASTNodeType.AST_VAR_DECL || receiver_param.var_decl_type == null {
        return null;
    }
    const receiver_type: Type = type_from_ast(ctx.checker, receiver_param.var_decl_type);
    const object_type: Type = exec_lower_expr_type(ctx, object_expr);
    if receiver_type.kind == TypeKind.TYPE_POINTER {
        if object_type.kind == TypeKind.TYPE_POINTER {
            return exec_lower_expr(ctx, object_expr);
        }
        return exec_lower_make_ref_expr(ctx, object_expr);
    }
    return exec_lower_expr(ctx, object_expr);
}

fn exec_lower_collect_interface_dispatch_decls(ctx: &ExecLowerContext, interface_type: &Type, concrete_type: &Type, out_decls: & & ASTNode, out_count: &i32) i32 {
    const struct_name: &byte = type_get_struct_name(concrete_type);
    if ctx == null || ctx.checker == null || ctx.checker.program_node == null || struct_name == null || out_count == null {
        return -1;
    }
    var sigs: [&ASTNode: EXEC_MAX_INTERFACE_METHODS] = [];
    var sig_count: i32 = 0;
    if exec_lower_collect_interface_method_sigs(ctx, interface_type, &sigs[0] as & & ASTNode, &sig_count) != 0 {
        return -1;
    }
    var i: i32 = 0;
    while i < sig_count {
        const sig: &ASTNode = sigs[i];
        if sig == null || sig.fn_decl_name == null {
            return -1;
        }
        const impl_decl: &ASTNode = find_instance_method_in_struct(ctx.checker.program_node, struct_name, sig.fn_decl_name);
        if impl_decl == null {
            return -1;
        }
        out_decls[i] = impl_decl;
        i = i + 1;
    }
    out_count[0] = sig_count;
    return 0;
}

fn exec_lower_box_interface_expr(ctx: &ExecLowerContext, expr: &ASTNode, interface_type: &Type) &HIRExpr {
    if ctx == null || expr == null {
        return null;
    }
    var actual_type: Type = exec_lower_expr_type(ctx, expr);
    if actual_type.kind == TypeKind.TYPE_VOID {
        actual_type = exec_lower_member_base_type(ctx, expr);
    }
    if actual_type.kind == TypeKind.TYPE_INTERFACE && type_equals(actual_type, interface_type[0]) != 0 {
        return exec_lower_expr(ctx, expr);
    }
    if actual_type.kind != TypeKind.TYPE_STRUCT ||
        actual_type.struct_name == null ||
        interface_type.kind != TypeKind.TYPE_INTERFACE ||
        interface_type.interface_name == null ||
        struct_implements_interface(ctx.checker, actual_type.struct_name, interface_type.interface_name) == 0 {
        return exec_lower_fail_expr(expr, "exec: 无法装箱为 interface" as *byte);
    }
    var dispatch_buf: [&ASTNode: EXEC_MAX_INTERFACE_METHODS] = [];
    var dispatch_count: i32 = 0;
    if exec_lower_collect_interface_dispatch_decls(ctx, interface_type, &actual_type, &dispatch_buf[0] as & & ASTNode, &dispatch_count) != 0 {
        return exec_lower_fail_expr(expr, "exec: interface 方法表构建失败" as *byte);
    }
    const dispatch_decls: & & ASTNode = compiler_arena_alloc(ctx.arena, @size_of(&ASTNode) * dispatch_count as usize) as & & ASTNode;
    if dispatch_count > 0 && dispatch_decls == null {
        exec_backend_set_error(expr, "exec: interface dispatch 表分配失败" as *byte, 0);
        return null;
    }
    var di: i32 = 0;
    while di < dispatch_count {
        dispatch_decls[di] = dispatch_buf[di];
        di = di + 1;
    }
    const source_ref: &HIRExpr = exec_lower_make_ref_expr(ctx, expr);
    var source_expr: &HIRExpr = source_ref;
    if source_expr == null {
        source_expr = exec_lower_expr(ctx, expr);
    }
    if source_expr == null {
        return null;
    }
    const boxed: &HIRExpr = exec_lower_alloc_expr(ctx, expr, HIRExprKind.HIR_EXPR_INTERFACE_BOX, interface_type);
    if boxed == null {
        return null;
    }
    boxed.left = source_expr;
    boxed.dispatch_decls = dispatch_decls;
    boxed.dispatch_decl_count = dispatch_count;
    return boxed;
}

fn exec_lower_coerce_expr(ctx: &ExecLowerContext, expr: &ASTNode, expected_type: &Type) &HIRExpr {
    if ctx == null || expr == null {
        return null;
    }
    if expected_type != null &&
        expr.type == ASTNodeType.AST_ARRAY_LITERAL &&
        expr.array_literal_repeat_count_expr != null &&
        expected_type.kind == TypeKind.TYPE_ARRAY {
        return exec_lower_make_repeat_array_init_expr(ctx, expr, expected_type);
    }
    if expected_type != null &&
        expr.type == ASTNodeType.AST_ARRAY_LITERAL &&
        expr.array_literal_repeat_count_expr == null &&
        expr.array_literal_element_count == 0 &&
        (expected_type.kind == TypeKind.TYPE_ARRAY || expected_type.kind == TypeKind.TYPE_SLICE) {
        return exec_lower_make_zero_expr(ctx, expr, expected_type);
    }
    if expected_type != null && expr.type == ASTNodeType.AST_INT_LIMIT && is_integer_type(expected_type.kind) != 0 {
        expr.int_limit_resolved_kind = expected_type.kind;
        var int_limit_ok: i32 = 0;
        const int_limit_value: i64 = exec_lower_eval_int_limit(expr, expected_type.kind, &int_limit_ok);
        if int_limit_ok != 0 {
            return exec_lower_make_int_const_expr(ctx, expr, expected_type, int_limit_value);
        }
    }
    if expected_type != null && expr.type == ASTNodeType.AST_NUMBER && is_integer_type(expected_type.kind) != 0 {
        return exec_lower_make_int_const_expr(ctx, expr, expected_type, expr.number_value_i64);
    }
    if expected_type != null && expr.type == ASTNodeType.AST_CHAR && is_integer_type(expected_type.kind) != 0 {
        return exec_lower_make_int_const_expr(ctx, expr, expected_type, expr.char_literal_value as i64);
    }
    if expected_type != null &&
        expected_type.kind == TypeKind.TYPE_INTERFACE && expected_type.interface_name != null {
        var actual_type: Type = exec_lower_expr_type(ctx, expr);
        if actual_type.kind == TypeKind.TYPE_VOID {
            actual_type = exec_lower_member_base_type(ctx, expr);
        }
        if actual_type.kind == TypeKind.TYPE_STRUCT && actual_type.struct_name != null &&
            struct_implements_interface(ctx.checker, actual_type.struct_name, expected_type.interface_name) != 0 {
            return exec_lower_box_interface_expr(ctx, expr, expected_type);
        }
    }
    return exec_lower_expr(ctx, expr);
}

fn exec_lower_struct_field_index(ctx: &ExecLowerContext, struct_type: Type, field_name: &byte) i32 {
    const struct_name: &byte = type_get_struct_name(&struct_type);
    if ctx == null || ctx.checker == null || ctx.checker.program_node == null ||
        struct_name == null || field_name == null {
        return -1;
    }
    const struct_decl: &ASTNode = find_struct_decl_from_program(ctx.checker.program_node, struct_name);
    if struct_decl == null || struct_decl.struct_decl_fields == null {
        return -1;
    }
    var fi: i32 = 0;
    while fi < struct_decl.struct_decl_field_count {
        const field: &ASTNode = struct_decl.struct_decl_fields[fi];
        if field != null && field.var_decl_name != null && str_equals(field.var_decl_name, field_name) != 0 {
            return fi;
        }
        fi = fi + 1;
    }
    return -1;
}

fn exec_lower_union_variant_index(ctx: &ExecLowerContext, union_type: Type, variant_name: &byte) i32 {
    const union_name: &byte = type_get_union_name(&union_type);
    if ctx == null || ctx.checker == null || ctx.checker.program_node == null ||
        union_name == null || variant_name == null {
        return -1;
    }
    const union_decl: &ASTNode = find_union_decl_from_program(ctx.checker.program_node, union_name);
    if union_decl == null || union_decl.union_decl_variants == null {
        return -1;
    }
    var i: i32 = 0;
    while i < union_decl.union_decl_variant_count {
        const variant_decl: &ASTNode = union_decl.union_decl_variants[i];
        if variant_decl != null && variant_decl.type == ASTNodeType.AST_VAR_DECL &&
            variant_decl.var_decl_name != null && str_equals(variant_decl.var_decl_name, variant_name) != 0 {
            return i;
        }
        i = i + 1;
    }
    return -1;
}

fn exec_lower_union_variant_type(ctx: &ExecLowerContext, union_type: Type, variant_name: &byte) Type {
    const union_name: &byte = type_get_union_name(&union_type);
    if ctx == null || ctx.checker == null || ctx.checker.program_node == null || union_name == null {
        return make_void_type();
    }
    const union_decl: &ASTNode = find_union_decl_from_program(ctx.checker.program_node, union_name);
    if union_decl == null || union_decl.union_decl_variants == null {
        return make_void_type();
    }
    var i: i32 = 0;
    while i < union_decl.union_decl_variant_count {
        const variant_decl: &ASTNode = union_decl.union_decl_variants[i];
        if variant_decl != null && variant_decl.type == ASTNodeType.AST_VAR_DECL &&
            variant_decl.var_decl_name != null && str_equals(variant_decl.var_decl_name, variant_name) != 0 &&
            variant_decl.var_decl_type != null {
            return type_from_ast(ctx.checker, variant_decl.var_decl_type);
        }
        i = i + 1;
    }
    return make_void_type();
}

fn exec_lower_try_union_ctor_expr(ctx: &ExecLowerContext, expr: &ASTNode, expr_type: &Type) &HIRExpr {
    if ctx == null || expr == null || expr.type != ASTNodeType.AST_CALL_EXPR ||
        expr.call_expr_callee == null || expr.call_expr_callee.type != ASTNodeType.AST_MEMBER_ACCESS {
        return null;
    }
    const callee: &ASTNode = expr.call_expr_callee;
    const object: &ASTNode = callee.member_access_object;
    var union_name: &byte = null;
    if object != null && object.type == ASTNodeType.AST_IDENTIFIER && object.identifier_name != null {
        union_name = object.identifier_name;
    } else if object != null && object.type == ASTNodeType.AST_TYPE_NAMED && object.type_named_name != null {
        union_name = object.type_named_name;
    }
    if union_name == null || callee.member_access_field_name == null || ctx.checker == null || ctx.checker.program_node == null {
        return null;
    }
    const union_decl: &ASTNode = find_union_decl_from_program(ctx.checker.program_node, union_name);
    if union_decl == null {
        return null;
    }
    const variant_index: i32 = exec_lower_union_variant_index(ctx, expr_type[0], callee.member_access_field_name);
    if variant_index < 0 {
        return null;
    }
    const variant_type: Type = exec_lower_union_variant_type(ctx, expr_type[0], callee.member_access_field_name);
    var payload_expr: &HIRExpr = null;
    if variant_type.kind == TypeKind.TYPE_VOID {
        if expr.call_expr_arg_count != 0 {
            return exec_lower_fail_expr(expr, "exec: union void 变体当前仅支持空参数构造" as *byte);
        }
    } else {
        if expr.call_expr_arg_count != 1 || expr.call_expr_args == null {
            return exec_lower_fail_expr(expr, "exec: union 变体当前仅支持单参数构造" as *byte);
        }
        payload_expr = exec_lower_expr(ctx, expr.call_expr_args[0]);
        if payload_expr == null {
            return null;
        }
    }
    const hir_union: &HIRExpr = exec_lower_alloc_expr(ctx, expr, HIRExprKind.HIR_EXPR_UNION_INIT, expr_type);
    if hir_union == null {
        return null;
    }
    hir_union.int_value = variant_index as i64;
    hir_union.left = payload_expr;
    return hir_union;
}

fn exec_lower_alloc_items(ctx: &ExecLowerContext, count: i32) & & HIRExpr {
    if count <= 0 {
        return null;
    }
    return compiler_arena_alloc(ctx.arena, @size_of(&HIRExpr) * count as usize) as & & HIRExpr;
}

fn exec_lower_expr_list(ctx: &ExecLowerContext, exprs: & & ASTNode, count: i32) & & HIRExpr {
    const items: & & HIRExpr = exec_lower_alloc_items(ctx, count);
    if count > 0 && items == null {
        exec_backend_set_error(ctx.function_decl, "exec: HIR expr 列表分配失败" as *byte, 0);
        return null;
    }
    var i: i32 = 0;
    while i < count {
        const item: &HIRExpr = exec_lower_expr(ctx, exprs[i]);
        if item == null {
            return null;
        }
        items[i] = item;
        i = i + 1;
    }
    return items;
}

fn exec_lower_member_base_type(ctx: &ExecLowerContext, object: &ASTNode) Type {
    var base_type: Type = exec_lower_resolve_exact_type(ctx, object);
    if type_get_struct_name(&base_type) != null {
        return base_type;
    }
    if base_type.kind == TypeKind.TYPE_POINTER && base_type.pointer_to != null {
        return base_type.pointer_to[0];
    }
    if object != null && object.type == ASTNodeType.AST_IDENTIFIER && object.identifier_name != null {
        const symbol: &Symbol = symbol_table_lookup(ctx.checker, object.identifier_name);
        if symbol != null && symbol.type.kind != TypeKind.TYPE_VOID {
            if symbol.type.kind == TypeKind.TYPE_POINTER && symbol.type.pointer_to != null {
                return symbol.type.pointer_to[0];
            }
            return symbol.type;
        }
        const slot: i32 = exec_lower_find_slot(ctx, object.identifier_name);
        if slot >= 0 && slot < EXEC_MAX_LOCALS {
            if ctx.slot_types[slot].kind == TypeKind.TYPE_POINTER && ctx.slot_types[slot].pointer_to != null {
                return ctx.slot_types[slot].pointer_to[0];
            }
            return ctx.slot_types[slot];
        }
        const global_slot: i32 = exec_lower_find_global_slot(ctx, object.identifier_name);
        if global_slot >= 0 && global_slot < EXEC_MAX_GLOBALS {
            if ctx.global_types[global_slot].kind == TypeKind.TYPE_POINTER && ctx.global_types[global_slot].pointer_to != null {
                return ctx.global_types[global_slot].pointer_to[0];
            }
            return ctx.global_types[global_slot];
        }
    }
    if object != null && object.type == ASTNodeType.AST_MEMBER_ACCESS &&
        object.member_access_object != null && object.member_access_field_name != null {
        var parent_type: Type = exec_lower_member_base_type(ctx, object.member_access_object);
        if parent_type.kind == TypeKind.TYPE_POINTER && parent_type.pointer_to != null {
            parent_type = parent_type.pointer_to[0];
        }
        if parent_type.kind == TypeKind.TYPE_TUPLE && parent_type.tuple_element_types != null {
            const tuple_index: i32 = atoi(object.member_access_field_name as *byte);
            if tuple_index >= 0 && tuple_index < parent_type.tuple_count {
                return parent_type.tuple_element_types[tuple_index];
            }
        }
        if parent_type.kind == TypeKind.TYPE_STRUCT {
            const field_type: Type = exec_lower_struct_field_type(ctx, parent_type, object.member_access_field_name);
            if field_type.kind != TypeKind.TYPE_VOID {
                return field_type;
            }
        }
    }
    return base_type;
}

fn exec_lower_make_assign_stmt(ctx: &ExecLowerContext, ast_node: &ASTNode, slot: i32, value: &HIRExpr) &HIRStmt {
    const stmt: &HIRStmt = exec_lower_alloc_stmt(ctx, ast_node, HIRStmtKind.HIR_STMT_ASSIGN);
    if stmt == null {
        return null;
    }
    if value == null {
        exec_backend_set_error(ast_node, "exec: assign 语句值为空" as *byte, 0);
        return null;
    }
    const target: &HIRExpr = exec_lower_make_local_expr(ctx, ast_node, slot, &value.type_ref.type);
    if target == null {
        return null;
    }
    stmt.local_slot = slot;
    stmt.assign_target = target;
    stmt.assign_expr = value;
    return stmt;
}

fn exec_lower_make_dest_expr(ctx: &ExecLowerContext, expr: &ASTNode) &HIRExpr {
    if ctx == null || expr == null {
        return null;
    }
    if expr.type == ASTNodeType.AST_IDENTIFIER {
        return exec_lower_expr(ctx, expr);
    }
    if expr.type == ASTNodeType.AST_MEMBER_ACCESS {
        return exec_lower_expr(ctx, expr);
    }
    if expr.type == ASTNodeType.AST_ARRAY_ACCESS {
        return exec_lower_expr(ctx, expr);
    }
    if expr.type == ASTNodeType.AST_UNARY_EXPR &&
        expr.unary_expr_operand != null &&
        (expr.unary_expr_op as TokenType) == TokenType.TOKEN_ASTERISK {
        return exec_lower_expr(ctx, expr);
    }
    return exec_lower_fail_expr(expr, "exec: 当前仅支持局部变量/字段/下标赋值" as *byte);
}

fn exec_lower_wrap_block_as_stmt(ctx: &ExecLowerContext, ast_node: &ASTNode, block: &HIRBlock) &HIRStmt {
    const stmt: &HIRStmt = exec_lower_alloc_stmt(ctx, ast_node, HIRStmtKind.HIR_STMT_BLOCK);
    if stmt == null {
        return null;
    }
    stmt.then_block = block;
    return stmt;
}

fn exec_lower_wrap_stmt_node_as_block(ctx: &ExecLowerContext, stmt_node: &ASTNode) &HIRBlock {
    if ctx == null || stmt_node == null {
        return null;
    }
    if stmt_node.type == ASTNodeType.AST_BLOCK {
        return exec_lower_block(ctx, stmt_node);
    }
    const synthetic_block: &ASTNode = compiler_arena_alloc(ctx.arena, @size_of(ASTNode)) as &ASTNode;
    const synthetic_stmts: & & ASTNode = compiler_arena_alloc(ctx.arena, @size_of(&ASTNode)) as & & ASTNode;
    if synthetic_block == null || synthetic_stmts == null {
        exec_backend_set_error(stmt_node, "exec: defer/errdefer synthetic block 分配失败" as *byte, 0);
        return null;
    }
    _ = memset(synthetic_block as *byte, 0, @size_of(ASTNode));
    synthetic_block.type = ASTNodeType.AST_BLOCK;
    synthetic_block.line = stmt_node.line;
    synthetic_block.column = stmt_node.column;
    synthetic_block.filename = stmt_node.filename;
    synthetic_block.block_stmts = synthetic_stmts;
    synthetic_block.block_stmt_count = 1;
    synthetic_stmts[0] = stmt_node;
    return exec_lower_block(ctx, synthetic_block);
}

fn exec_lower_make_break_block(ctx: &ExecLowerContext, ast_node: &ASTNode) &HIRBlock {
    const block: &HIRBlock = exec_lower_alloc_scoped_block(ctx, ast_node, 1);
    const stmt: &HIRStmt = exec_lower_alloc_stmt(ctx, ast_node, HIRStmtKind.HIR_STMT_BREAK);
    if block == null || stmt == null {
        exec_backend_set_error(ast_node, "exec: break block 分配失败" as *byte, 0);
        return null;
    }
    block.stmts[1] = stmt;
    return block;
}

fn exec_lower_make_for_range_stmt(ctx: &ExecLowerContext, stmt_node: &ASTNode) &HIRStmt {
    if stmt_node == null || stmt_node.for_stmt_is_range == 0 {
        return null;
    }
    if stmt_node.for_stmt_var_name == null {
        exec_backend_set_generic_unsupported_error(stmt_node, "exec: 当前 for range 必须显式绑定迭代变量" as *byte);
        return null;
    }
    if stmt_node.for_stmt_is_ref != 0 {
        exec_backend_set_generic_unsupported_error(stmt_node, "exec: 当前不支持 for range 引用绑定" as *byte);
        return null;
    }
    if stmt_node.for_stmt_range_end == null {
        exec_backend_set_generic_unsupported_error(stmt_node, "exec: 当前不支持无上界 for range" as *byte);
        return null;
    }
    const start_expr: &HIRExpr = exec_lower_expr(ctx, stmt_node.for_stmt_range_start);
    const end_expr: &HIRExpr = exec_lower_expr(ctx, stmt_node.for_stmt_range_end);
    if start_expr == null || end_expr == null {
        return null;
    }
    if start_expr.type_ref.type.kind != TypeKind.TYPE_I32 || end_expr.type_ref.type.kind != TypeKind.TYPE_I32 {
        exec_backend_set_generic_unsupported_error(stmt_node, "exec: 当前仅支持 i32 for range" as *byte);
        return null;
    }

    exec_lower_push_scope(ctx, -1);
    const iter_type: Type = make_i32_type();
    const iter_slot: i32 = exec_lower_append_local(ctx, null, stmt_node.for_stmt_var_name, &iter_type, 0);
    const end_slot: i32 = exec_lower_append_local(ctx, null, "__exec_for_end" as *byte, &iter_type, 0);
    if iter_slot < 0 || end_slot < 0 {
        exec_lower_pop_scope(ctx);
        exec_backend_set_error(stmt_node, "exec: for range 槽位不足" as *byte, 0);
        return null;
    }

    const user_body: &HIRBlock = exec_lower_block(ctx, stmt_node.for_stmt_body);
    if user_body == null {
        exec_lower_pop_scope(ctx);
        return null;
    }

    const loop_body: &HIRBlock = exec_lower_alloc_scoped_block(ctx, stmt_node, 1);
    if loop_body == null {
        exec_lower_pop_scope(ctx);
        exec_backend_set_error(stmt_node, "exec: for loop body 分配失败" as *byte, 0);
        return null;
    }

    const iter_local_for_cond: &HIRExpr = exec_lower_make_local_expr(ctx, stmt_node, iter_slot, &iter_type);
    const end_local_for_cond: &HIRExpr = exec_lower_make_local_expr(ctx, stmt_node, end_slot, &iter_type);
    const cond_type: Type = make_bool_type();
    const cond_expr: &HIRExpr = exec_lower_make_binary_expr(ctx, stmt_node, TokenType.TOKEN_LESS as i32, iter_local_for_cond, end_local_for_cond, &cond_type);
    const then_block: &HIRBlock = exec_lower_alloc_scoped_block(ctx, stmt_node, 2);
    const break_block: &HIRBlock = exec_lower_make_break_block(ctx, stmt_node);
    if cond_expr == null || then_block == null || break_block == null {
        exec_lower_pop_scope(ctx);
        exec_backend_set_error(stmt_node, "exec: for 条件块分配失败" as *byte, 0);
        return null;
    }

    const wrapped_user_body: &HIRStmt = exec_lower_wrap_block_as_stmt(ctx, stmt_node.for_stmt_body, user_body);
    const one_expr: &HIRExpr = exec_lower_alloc_expr(ctx, stmt_node, HIRExprKind.HIR_EXPR_CONST, &iter_type);
    const iter_local_for_inc: &HIRExpr = exec_lower_make_local_expr(ctx, stmt_node, iter_slot, &iter_type);
    if wrapped_user_body == null || one_expr == null || iter_local_for_inc == null {
        exec_lower_pop_scope(ctx);
        return null;
    }
    one_expr.int_value = 1;
    const next_iter_expr: &HIRExpr = exec_lower_make_binary_expr(ctx, stmt_node, TokenType.TOKEN_PLUS as i32, iter_local_for_inc, one_expr, &iter_type);
    const inc_stmt: &HIRStmt = exec_lower_make_assign_stmt(ctx, stmt_node, iter_slot, next_iter_expr);
    if inc_stmt == null {
        exec_lower_pop_scope(ctx);
        return null;
    }
    then_block.stmts[1] = wrapped_user_body;
    then_block.stmts[2] = inc_stmt;

    const cond_stmt: &HIRStmt = exec_lower_alloc_stmt(ctx, stmt_node, HIRStmtKind.HIR_STMT_IF);
    if cond_stmt == null {
        exec_lower_pop_scope(ctx);
        return null;
    }
    cond_stmt.expr = cond_expr;
    cond_stmt.then_block = then_block;
    cond_stmt.else_block = break_block;
    loop_body.stmts[1] = cond_stmt;

    const loop_stmt: &HIRStmt = exec_lower_alloc_stmt(ctx, stmt_node, HIRStmtKind.HIR_STMT_LOOP);
    const setup_block: &HIRBlock = exec_lower_alloc_scoped_block(ctx, stmt_node, 3);
    const init_iter: &HIRStmt = exec_lower_alloc_stmt(ctx, stmt_node, HIRStmtKind.HIR_STMT_VAR_INIT);
    const init_end: &HIRStmt = exec_lower_alloc_stmt(ctx, stmt_node, HIRStmtKind.HIR_STMT_VAR_INIT);
    if loop_stmt == null || setup_block == null || init_iter == null || init_end == null {
        exec_lower_pop_scope(ctx);
        exec_backend_set_error(stmt_node, "exec: for setup block 分配失败" as *byte, 0);
        return null;
    }
    loop_stmt.loop_body = loop_body;
    init_iter.local_slot = iter_slot;
    init_iter.expr = start_expr;
    init_end.local_slot = end_slot;
    init_end.expr = end_expr;
    setup_block.stmts[1] = init_iter;
    setup_block.stmts[2] = init_end;
    setup_block.stmts[3] = loop_stmt;

    const result_stmt: &HIRStmt = exec_lower_wrap_block_as_stmt(ctx, stmt_node, setup_block);
    exec_lower_pop_scope(ctx);
    return result_stmt;
}

fn exec_lower_global_name(decl: &ASTNode) &byte {
    if decl == null {
        return null;
    }
    if decl.type == ASTNodeType.AST_VAR_DECL {
        return decl.var_decl_name;
    }
    if decl.type == ASTNodeType.AST_EXTERN_VAR_DECL {
        return decl.extern_var_decl_name;
    }
    return null;
}

fn exec_lower_global_type_ast(decl: &ASTNode) &ASTNode {
    if decl == null {
        return null;
    }
    if decl.type == ASTNodeType.AST_VAR_DECL {
        return decl.var_decl_type;
    }
    if decl.type == ASTNodeType.AST_EXTERN_VAR_DECL {
        return decl.extern_var_decl_var_type;
    }
    return null;
}

fn exec_lower_global_init_ast(decl: &ASTNode) &ASTNode {
    if decl == null {
        return null;
    }
    if decl.type == ASTNodeType.AST_VAR_DECL {
        return decl.var_decl_init;
    }
    if decl.type == ASTNodeType.AST_EXTERN_VAR_DECL {
        return decl.extern_var_decl_init_expr;
    }
    return null;
}

fn exec_lower_global_is_const(decl: &ASTNode) i32 {
    if decl == null {
        return 0;
    }
    if decl.type == ASTNodeType.AST_VAR_DECL {
        return decl.var_decl_is_const;
    }
    if decl.type == ASTNodeType.AST_EXTERN_VAR_DECL {
        return decl.extern_var_decl_is_const;
    }
    return 0;
}

fn exec_lower_global_is_runtime_decl(decl: &ASTNode) i32 {
    if decl == null {
        return 0;
    }
    if decl.type == ASTNodeType.AST_VAR_DECL {
        return (decl.var_decl_name != null) as i32;
    }
    if decl.type == ASTNodeType.AST_EXTERN_VAR_DECL && decl.extern_var_decl_is_extern == 0 {
        return (decl.extern_var_decl_name != null) as i32;
    }
    return 0;
}

fn exec_lower_decl_is_uya_root_runtime(checker: &TypeChecker, decl: &ASTNode) i32 {
    if checker == null || decl == null || decl.filename == null || checker.uya_root_dir == null {
        return 0;
    }
    const root_len: i32 = strlen(checker.uya_root_dir as *byte) as i32;
    if root_len <= 0 {
        return 0;
    }
    return (strncmp(decl.filename as *byte, checker.uya_root_dir as *byte, root_len) == 0) as i32;
}

fn exec_lower_find_module_export_decl(checker: &TypeChecker, module_name: &byte, item_name: &byte, item_type: i32) &ASTNode {
    if checker == null || module_name == null || item_name == null {
        return null;
    }
    var mh: u32 = hash_string(module_name);
    var mi: i32 = (mh as i32) & (MODULE_TABLE_SIZE - 1);
    var i: i32 = 0;
    while i < MODULE_TABLE_SIZE {
        const slot: i32 = (mi + i) & (MODULE_TABLE_SIZE - 1);
        const module: &ModuleInfo = checker.module_table.slots[slot];
        if module == null {
            break;
        }
        if module.module_name != null && str_equals(module.module_name, module_name) != 0 {
            if module.exports != null {
                var ei: i32 = 0;
                while ei < module.export_count {
                    const export_item: &ExportedItem = &module.exports[ei];
                    if export_item.name != null && str_equals(export_item.name, item_name) != 0 {
                        if item_type == 0 || export_item.item_type == item_type {
                            return export_item.decl_node;
                        }
                    }
                    ei = ei + 1;
                }
            }
            break;
        }
        i = i + 1;
    }
    if str_equals(module_name, "libc" as &byte) != 0 {
        var slot_i: i32 = 0;
        while slot_i < MODULE_TABLE_SIZE {
            const module2: &ModuleInfo = checker.module_table.slots[slot_i];
            if module2 != null && module2.filename != null &&
                (strstr(module2.filename as *byte, "/lib/libc/" as *byte) != null ||
                 strstr(module2.filename as *byte, "lib/libc/" as *byte) != null ||
                 strstr(module2.filename as *byte, "\\lib\\libc\\" as *byte) != null) {
                if module2.exports != null {
                    var export_i: i32 = 0;
                    while export_i < module2.export_count {
                        const export_item2: &ExportedItem = &module2.exports[export_i];
                        if export_item2.name != null && str_equals(export_item2.name, item_name) != 0 {
                            if item_type == 0 || export_item2.item_type == item_type {
                                return export_item2.decl_node;
                            }
                        }
                        export_i = export_i + 1;
                    }
                }
            }
            slot_i = slot_i + 1;
        }
    }
    return null;
}

fn exec_lower_resolve_imported_decl(checker: &TypeChecker, local_name: &byte, item_type: i32) &ASTNode {
    if checker == null || local_name == null {
        return null;
    }
    const imported_item: &ImportedItem = checker_import_table_lookup_local_name(checker, local_name);
    if imported_item == null || imported_item.item_type == (0 - 1) ||
        imported_item.original_name == null || imported_item.module_name == null {
        return null;
    }
    if item_type != 0 && imported_item.item_type != 0 && imported_item.item_type != item_type {
        return null;
    }
    return exec_lower_find_module_export_decl(checker, imported_item.module_name, imported_item.original_name, item_type);
}

fn exec_lower_resolve_imported_decl_from_file(checker: &TypeChecker, filename: &byte, local_name: &byte, item_type: i32) &ASTNode {
    if checker == null || checker.program_node == null || checker.program_node.type != ASTNodeType.AST_PROGRAM ||
        filename == null || local_name == null {
        return null;
    }
    var i: i32 = 0;
    while i < checker.program_node.program_decl_count {
        const decl: &ASTNode = checker.program_node.program_decls[i];
        if decl != null && decl.type == ASTNodeType.AST_USE_STMT &&
            decl.filename != null && str_equals(decl.filename, filename) != 0 &&
            decl.use_stmt_item_name != null &&
            decl.use_stmt_path_segments != null && decl.use_stmt_path_segment_count > 0 {
            var local_name_candidate: &byte = decl.use_stmt_alias;
            if local_name_candidate == null {
                local_name_candidate = decl.use_stmt_item_name;
            }
            if local_name_candidate != null && str_equals(local_name_candidate, local_name) != 0 {
                const module_segment_count: i32 = decl.use_stmt_path_segment_count - 1;
                if module_segment_count > 0 {
                    const module_name_len: i32 = exec_lower_joined_module_name_len(decl.use_stmt_path_segments, module_segment_count);
                    if module_name_len > 0 {
                        const module_name: &byte = compiler_arena_alloc(checker.arena, module_name_len as usize + 1 as usize) as &byte;
                        if module_name != null {
                            exec_lower_write_joined_module_name(module_name, decl.use_stmt_path_segments, module_segment_count);
                            const export_decl: &ASTNode = exec_lower_find_module_export_decl(checker, module_name, decl.use_stmt_item_name, item_type);
                            if export_decl != null {
                                return export_decl;
                            }
                        }
                    }
                }
            }
        }
        i = i + 1;
    }
    return null;
}

fn exec_lower_resolve_module_self_named_global_from_file(checker: &TypeChecker, filename: &byte, local_name: &byte) &ASTNode {
    if checker == null || filename == null || local_name == null {
        return null;
    }
    const module_name: &byte = exec_lower_resolve_module_alias_from_file(checker, filename, local_name);
    if module_name == null {
        return null;
    }
    return exec_lower_find_module_export_decl(checker, module_name, local_name, 10);
}

fn exec_lower_use_stmt_module_name_equals(use_stmt: &ASTNode, module_name: &byte) i32 {
    if use_stmt == null || use_stmt.type != ASTNodeType.AST_USE_STMT || module_name == null ||
        use_stmt.use_stmt_path_segments == null || use_stmt.use_stmt_path_segment_count <= 0 {
        return 0;
    }
    var i: i32 = 0;
    var module_pos: i32 = 0;
    while i < use_stmt.use_stmt_path_segment_count {
        const segment: &byte = use_stmt.use_stmt_path_segments[i];
        if segment == null {
            return 0;
        }
        var seg_pos: i32 = 0;
        while segment[seg_pos] != 0 as byte {
            if module_name[module_pos] != segment[seg_pos] {
                return 0;
            }
            seg_pos = seg_pos + 1;
            module_pos = module_pos + 1;
        }
        if i + 1 < use_stmt.use_stmt_path_segment_count {
            if module_name[module_pos] != 46 {
                return 0;
            }
            module_pos = module_pos + 1;
        }
        i = i + 1;
    }
    return (module_name[module_pos] == 0 as byte) as i32;
}

fn exec_lower_resolve_module_alias_from_file(checker: &TypeChecker, filename: &byte, local_name: &byte) &byte {
    if checker == null || checker.program_node == null || checker.program_node.type != ASTNodeType.AST_PROGRAM ||
        filename == null || local_name == null {
        return null;
    }
    var i: i32 = 0;
    while i < checker.program_node.program_decl_count {
        const decl: &ASTNode = checker.program_node.program_decls[i];
        if decl != null && decl.type == ASTNodeType.AST_USE_STMT &&
            decl.filename != null && str_equals(decl.filename, filename) != 0 &&
            decl.use_stmt_item_name == null &&
            decl.use_stmt_path_segments != null && decl.use_stmt_path_segment_count > 0 {
            var local_name_candidate: &byte = decl.use_stmt_alias;
            if local_name_candidate == null {
                local_name_candidate = decl.use_stmt_path_segments[decl.use_stmt_path_segment_count - 1];
            }
            if local_name_candidate != null && str_equals(local_name_candidate, local_name) != 0 {
                const module_name_len: i32 = exec_lower_joined_module_name_len(decl.use_stmt_path_segments, decl.use_stmt_path_segment_count);
                if module_name_len > 0 {
                    const module_name: &byte = compiler_arena_alloc(checker.arena, module_name_len as usize + 1 as usize) as &byte;
                    if module_name != null {
                        exec_lower_write_joined_module_name(module_name, decl.use_stmt_path_segments, decl.use_stmt_path_segment_count);
                        return module_name;
                    }
                }
            }
        }
        i = i + 1;
    }
    return null;
}

fn exec_lower_resolve_module_alias_from_program(checker: &TypeChecker, local_name: &byte) &byte {
    if checker == null || checker.program_node == null || checker.program_node.type != ASTNodeType.AST_PROGRAM ||
        local_name == null {
        return null;
    }
    var i: i32 = 0;
    while i < checker.program_node.program_decl_count {
        const decl: &ASTNode = checker.program_node.program_decls[i];
        if decl != null && decl.type == ASTNodeType.AST_USE_STMT &&
            decl.use_stmt_item_name == null &&
            decl.use_stmt_path_segments != null && decl.use_stmt_path_segment_count > 0 {
            var local_name_candidate: &byte = decl.use_stmt_alias;
            if local_name_candidate == null {
                local_name_candidate = decl.use_stmt_path_segments[decl.use_stmt_path_segment_count - 1];
            }
            if local_name_candidate != null && str_equals(local_name_candidate, local_name) != 0 {
                const module_name_len: i32 = exec_lower_joined_module_name_len(decl.use_stmt_path_segments, decl.use_stmt_path_segment_count);
                if module_name_len > 0 {
                    const module_name: &byte = compiler_arena_alloc(checker.arena, module_name_len as usize + 1 as usize) as &byte;
                    if module_name != null {
                        exec_lower_write_joined_module_name(module_name, decl.use_stmt_path_segments, decl.use_stmt_path_segment_count);
                        return module_name;
                    }
                }
            }
        }
        i = i + 1;
    }
    return null;
}

fn exec_lower_resolve_member_access_module_name(checker: &TypeChecker, expr: &ASTNode) &byte {
    if checker == null || expr == null || expr.type != ASTNodeType.AST_MEMBER_ACCESS {
        return null;
    }
    if expr.member_access_is_module_access != 0 && expr.member_access_module_name != null {
        return expr.member_access_module_name;
    }
    if expr.member_access_object == null ||
        expr.member_access_object.type != ASTNodeType.AST_IDENTIFIER ||
        expr.member_access_object.identifier_name == null {
        return null;
    }
    const imported_item: &ImportedItem = checker_import_table_lookup_local_name(checker, expr.member_access_object.identifier_name);
    if imported_item != null && imported_item.item_type == (0 - 1) && imported_item.module_name != null {
        return imported_item.module_name;
    }
    if expr.filename != null {
        const file_module_name: &byte = exec_lower_resolve_module_alias_from_file(
            checker, expr.filename, expr.member_access_object.identifier_name);
        if file_module_name != null {
            return file_module_name;
        }
    }
    return exec_lower_resolve_module_alias_from_program(checker, expr.member_access_object.identifier_name);
}

fn exec_lower_joined_module_name_len(segments: & & byte, count: i32) i32 {
    if segments == null || count <= 0 {
        return 0;
    }
    var total: i32 = 0;
    var i: i32 = 0;
    while i < count {
        if segments[i] == null {
            return 0;
        }
        total = total + (strlen(segments[i] as *byte) as i32);
        if i + 1 < count {
            total = total + 1;
        }
        i = i + 1;
    }
    return total;
}

fn exec_lower_write_joined_module_name(out_name: &byte, segments: & & byte, count: i32) void {
    if out_name == null || segments == null || count <= 0 {
        return;
    }
    var pos: i32 = 0;
    var i: i32 = 0;
    while i < count {
        const segment: &byte = segments[i];
        var si: i32 = 0;
        while segment != null && segment[si] != 0 as byte {
            out_name[pos] = segment[si];
            pos = pos + 1;
            si = si + 1;
        }
        if i + 1 < count {
            out_name[pos] = 46;
            pos = pos + 1;
        }
        i = i + 1;
    }
    out_name[pos] = 0 as byte;
}

fn exec_lower_resolve_function_decl(checker: &TypeChecker, callee_name: &byte) &ASTNode {
    if checker == null || callee_name == null {
        return null;
    }
    var decl: &ASTNode = exec_lower_resolve_imported_decl(checker, callee_name, 1);
    if decl != null && decl.type == ASTNodeType.AST_FN_DECL && decl.fn_decl_name != null {
        const reachable_decl: &ASTNode = checker_find_reachable_fn_decl_by_name(checker, decl.fn_decl_name);
        if reachable_decl != null && reachable_decl.type == ASTNodeType.AST_FN_DECL {
            return reachable_decl;
        }
        return decl;
    }
    decl = checker_find_reachable_fn_decl_by_name(checker, callee_name);
    if decl != null && decl.type == ASTNodeType.AST_FN_DECL {
        return decl;
    }
    decl = find_fn_decl_from_program(checker.program_node, callee_name);
    if decl != null && decl.type == ASTNodeType.AST_FN_DECL {
        return checker_canonicalize_fn_decl(checker, decl);
    }
    return null;
}

fn exec_lower_prefer_bodyful_function_decl(checker: &TypeChecker, fn_decl: &ASTNode, fn_name: &byte) &ASTNode {
    if checker == null {
        return fn_decl;
    }
    var lookup_name: &byte = fn_name;
    if fn_decl != null && fn_decl.type == ASTNodeType.AST_FN_DECL && fn_decl.fn_decl_name != null {
        lookup_name = fn_decl.fn_decl_name;
        if fn_decl.fn_decl_body != null {
            return checker_canonicalize_fn_decl(checker, fn_decl);
        }
    }
    if lookup_name == null {
        return fn_decl;
    }
    const reachable_decl: &ASTNode = checker_find_reachable_fn_decl_by_name(checker, lookup_name);
    if reachable_decl != null && reachable_decl.type == ASTNodeType.AST_FN_DECL && reachable_decl.fn_decl_body != null {
        return reachable_decl;
    }
    const program_decl: &ASTNode = find_fn_decl_from_program(checker.program_node, lookup_name);
    if program_decl != null && program_decl.type == ASTNodeType.AST_FN_DECL && program_decl.fn_decl_body != null {
        return checker_canonicalize_fn_decl(checker, program_decl);
    }
    return fn_decl;
}

fn exec_lower_find_function_decl_in_file(checker: &TypeChecker, filename: &byte, callee_name: &byte) &ASTNode {
    if checker == null || checker.program_node == null || checker.program_node.type != ASTNodeType.AST_PROGRAM ||
        filename == null || callee_name == null {
        return null;
    }
    var i: i32 = 0;
    while i < checker.program_node.program_decl_count {
        const decl: &ASTNode = checker.program_node.program_decls[i];
        if decl != null && decl.type == ASTNodeType.AST_FN_DECL &&
            decl.filename != null && str_equals(decl.filename, filename) != 0 &&
            decl.fn_decl_name != null && str_equals(decl.fn_decl_name, callee_name) != 0 {
            return checker_canonicalize_fn_decl(checker, decl);
        }
        i = i + 1;
    }
    return null;
}

fn exec_lower_resolve_function_decl_from_file(checker: &TypeChecker, filename: &byte, callee_name: &byte) &ASTNode {
    if checker == null || callee_name == null {
        return null;
    }
    if filename != null {
        const file_local_decl: &ASTNode = exec_lower_find_function_decl_in_file(checker, filename, callee_name);
        if file_local_decl != null {
            return file_local_decl;
        }
        var imported_decl: &ASTNode = exec_lower_resolve_imported_decl_from_file(checker, filename, callee_name, 1);
        if imported_decl != null && imported_decl.type == ASTNodeType.AST_FN_DECL {
            imported_decl = checker_canonicalize_fn_decl(checker, imported_decl);
            return exec_lower_prefer_bodyful_function_decl(checker, imported_decl, callee_name);
        }
    }
    return exec_lower_resolve_function_decl(checker, callee_name);
}

fn exec_lower_resolve_global_decl(checker: &TypeChecker, name: &byte) &ASTNode {
    if checker == null || name == null {
        return null;
    }
    const imported_decl: &ASTNode = exec_lower_resolve_imported_decl(checker, name, 10);
    if imported_decl != null {
        return imported_decl;
    }
    const symbol: &Symbol = symbol_table_lookup(checker, name);
    if symbol != null && exec_lower_global_is_runtime_decl(symbol.decl_node) != 0 {
        return symbol.decl_node;
    }
    return null;
}

fn exec_lower_find_enum_variant_value(enum_decl: &ASTNode, variant_name: &byte) i32 {
    if enum_decl == null || enum_decl.type != ASTNodeType.AST_ENUM_DECL || variant_name == null ||
        enum_decl.enum_decl_variants == null {
        return -1;
    }
    var current_value: i32 = 0;
    var i: i32 = 0;
    while i < enum_decl.enum_decl_variant_count {
        const variant: &EnumVariant = enum_decl.enum_decl_variants + i;
        if variant == null || variant.name == null {
            i = i + 1;
            continue;
        }
        if variant.value != null {
            current_value = atoi(variant.value as *byte);
        }
        if str_equals(variant.name, variant_name) != 0 {
            return current_value;
        }
        current_value = current_value + 1;
        i = i + 1;
    }
    return -1;
}

fn exec_lower_try_enum_member_const(ctx: &ExecLowerContext, expr: &ASTNode, out_found: &i32) i32 {
    if out_found != null {
        out_found[0] = 0;
    }
    if ctx == null || ctx.checker == null || ctx.checker.program_node == null ||
        expr == null || expr.type != ASTNodeType.AST_MEMBER_ACCESS ||
        expr.member_access_object == null || expr.member_access_field_name == null {
        return -1;
    }
    const object: &ASTNode = expr.member_access_object;
    if object.type != ASTNodeType.AST_IDENTIFIER || object.identifier_name == null {
        return -1;
    }
    const enum_decl: &ASTNode = find_enum_decl_from_program(ctx.checker.program_node, object.identifier_name);
    if enum_decl == null {
        return -1;
    }
    const value: i32 = exec_lower_find_enum_variant_value(enum_decl, expr.member_access_field_name);
    if value < 0 {
        return -1;
    }
    if out_found != null {
        out_found[0] = 1;
    }
    return value;
}

fn exec_lower_eval_int_limit(expr: &ASTNode, fallback_kind: TypeKind, out_ok: &i32) i64 {
    if out_ok != null {
        out_ok[0] = 0;
    }
    if expr == null || expr.type != ASTNodeType.AST_INT_LIMIT {
        return 0;
    }
    var kind: TypeKind = fallback_kind;
    if expr.int_limit_resolved_kind != 0 {
        const kind_tmp: !TypeKind = expr.int_limit_resolved_kind as! TypeKind;
        kind = kind_tmp.value;
    }
    if is_integer_type(kind) == 0 {
        return 0;
    }
    if out_ok != null {
        out_ok[0] = 1;
    }
    if kind == TypeKind.TYPE_I8 {
        if expr.int_limit_is_max != 0 { return 127; }
        return 0 - 128;
    }
    if kind == TypeKind.TYPE_I16 {
        if expr.int_limit_is_max != 0 { return 32767; }
        return 0 - 32768;
    }
    if kind == TypeKind.TYPE_I32 {
        if expr.int_limit_is_max != 0 { return 2147483647; }
        return 0 - 2147483647 - 1;
    }
    if kind == TypeKind.TYPE_I64 {
        if expr.int_limit_is_max != 0 { return 9223372036854775807; }
        return 0 - 9223372036854775807 - 1;
    }
    if kind == TypeKind.TYPE_U8 || kind == TypeKind.TYPE_BYTE {
        if expr.int_limit_is_max != 0 { return 255; }
        return 0;
    }
    if kind == TypeKind.TYPE_U16 {
        if expr.int_limit_is_max != 0 { return 65535; }
        return 0;
    }
    if kind == TypeKind.TYPE_U32 {
        if expr.int_limit_is_max != 0 { return 4294967295; }
        return 0;
    }
    if kind == TypeKind.TYPE_U64 || kind == TypeKind.TYPE_USIZE {
        if expr.int_limit_is_max != 0 { return 0 - 1; }
        return 0;
    }
    if out_ok != null {
        out_ok[0] = 0;
    }
    return 0;
}

fn exec_lower_append_global_slot(checker: &TypeChecker, decl: &ASTNode, globals: &HIRGlobalSlot, out_count: &i32, allow_uya_root_runtime: i32) i32 {
    if checker == null || decl == null || globals == null || out_count == null {
        return -1;
    }
    if allow_uya_root_runtime == 0 && exec_lower_decl_is_uya_root_runtime(checker, decl) != 0 {
        return 0;
    }
    if out_count[0] >= EXEC_MAX_GLOBALS {
        exec_backend_set_error(decl, "exec: global 数量超出上限" as *byte, 0);
        return -1;
    }
    const global_type_ast: &ASTNode = exec_lower_global_type_ast(decl);
    if global_type_ast == null {
        exec_backend_set_error(decl, "exec: global 缺少类型" as *byte, 0);
        return -1;
    }
    const global_type: Type = type_from_ast(checker, global_type_ast);
    if exec_type_is_vm_value_supported(global_type) == 0 {
        if exec_type_uses_simd(global_type) != 0 {
            exec_lower_set_unsupported_reason(decl, "exec: 当前不支持 SIMD" as *byte, ExecUnsupportedReason.EXEC_UNSUPPORTED_SIMD);
            return -1;
        }
        exec_lower_set_unsupported(decl, "exec: 当前仅支持 exec VM 可表示的全局变量" as *byte);
        return -1;
    }
    globals[out_count[0]] = HIRGlobalSlot {
        name: exec_lower_global_name(decl),
        decl: decl,
        slot: out_count[0],
        type_ref: exec_lower_make_type_ref(&global_type),
        is_const: exec_lower_global_is_const(decl),
        init_expr: null,
    };
    out_count[0] = out_count[0] + 1;
    return 0;
}

fn exec_lower_collect_global_slots_from_program(checker: &TypeChecker, program: &ASTNode, globals: &HIRGlobalSlot, out_count: &i32) i32 {
    if checker == null || program == null || globals == null || out_count == null {
        return -1;
    }
    if program.type != ASTNodeType.AST_PROGRAM {
        return 0;
    }
    var decl_idx: i32 = 0;
    while decl_idx < program.program_decl_count {
        const decl: &ASTNode = program.program_decls[decl_idx];
        if decl != null && decl.type == ASTNodeType.AST_PROGRAM {
            if exec_lower_collect_global_slots_from_program(checker, decl, globals, out_count) != 0 {
                return -1;
            }
        } else if exec_lower_global_is_runtime_decl(decl) != 0 {
            if exec_lower_append_global_slot(checker, decl, globals, out_count, 0) != 0 {
                return -1;
            }
        }
        decl_idx = decl_idx + 1;
    }
    return 0;
}

fn exec_lower_collect_global_slots_from_symbols(checker: &TypeChecker, globals: &HIRGlobalSlot, out_count: &i32) i32 {
    if checker == null || globals == null || out_count == null {
        return -1;
    }
    var scope: i32 = 0;
    while scope < @len(checker.scope_heads) {
        var symbol: &Symbol = checker.scope_heads[scope];
        while symbol != null {
            if exec_lower_global_is_runtime_decl(symbol.decl_node) != 0 &&
                exec_lower_find_global_slot_by_decl_in_globals(globals, out_count[0], symbol.decl_node) < 0 {
                if exec_lower_append_global_slot(checker, symbol.decl_node, globals, out_count, 0) != 0 {
                    return -1;
                }
            }
            symbol = symbol.next_in_scope;
        }
        scope = scope + 1;
    }
    return 0;
}

fn exec_lower_collect_global_slots_from_symbol_table(checker: &TypeChecker, globals: &HIRGlobalSlot, out_count: &i32) i32 {
    if checker == null || globals == null || out_count == null {
        return -1;
    }
    var slot: i32 = 0;
    while slot < SYMBOL_TABLE_SIZE {
        const symbol: &Symbol = checker.symbol_table.slots[slot];
        if symbol != null &&
            exec_lower_global_is_runtime_decl(symbol.decl_node) != 0 &&
            exec_lower_find_global_slot_by_decl_in_globals(globals, out_count[0], symbol.decl_node) < 0 {
            if exec_lower_append_global_slot(checker, symbol.decl_node, globals, out_count, 0) != 0 {
                return -1;
            }
        }
        slot = slot + 1;
    }
    return 0;
}

fn exec_lower_collect_global_slots_from_imports(checker: &TypeChecker, globals: &HIRGlobalSlot, out_count: &i32) i32 {
    if checker == null || globals == null || out_count == null {
        return -1;
    }
    var slot: i32 = 0;
    while slot < IMPORT_TABLE_SIZE {
        const import_item: &ImportedItem = checker.import_table.slots[slot];
        if import_item != null && import_item.item_type != (0 - 1) && import_item.local_name != null {
            const decl: &ASTNode = exec_lower_resolve_global_decl(checker, import_item.local_name);
            if decl != null && exec_lower_find_global_slot_by_decl_in_globals(globals, out_count[0], decl) < 0 {
                if exec_lower_append_global_slot(checker, decl, globals, out_count, 1) != 0 {
                    return -1;
                }
            }
        } else if import_item != null && import_item.item_type == (0 - 1) &&
            import_item.local_name != null && import_item.module_name != null {
            const self_named_decl: &ASTNode = exec_lower_find_module_export_decl(checker, import_item.module_name, import_item.local_name, 10);
            if self_named_decl != null &&
                exec_lower_find_global_slot_by_decl_in_globals(globals, out_count[0], self_named_decl) < 0 {
                if exec_lower_append_global_slot(checker, self_named_decl, globals, out_count, 1) != 0 {
                    return -1;
                }
            }
        }
        slot = slot + 1;
    }
    if checker.program_node != null && checker.program_node.type == ASTNodeType.AST_PROGRAM {
        var decl_i: i32 = 0;
        while decl_i < checker.program_node.program_decl_count {
            const decl2: &ASTNode = checker.program_node.program_decls[decl_i];
            if decl2 != null && decl2.type == ASTNodeType.AST_USE_STMT &&
                decl2.use_stmt_item_name != null {
                var local_name_candidate2: &byte = decl2.use_stmt_alias;
                if local_name_candidate2 == null {
                    local_name_candidate2 = decl2.use_stmt_item_name;
                }
                if local_name_candidate2 != null {
                    const resolved_decl: &ASTNode = exec_lower_resolve_imported_decl_from_file(checker, decl2.filename, local_name_candidate2, 10);
                    if resolved_decl != null &&
                        exec_lower_find_global_slot_by_decl_in_globals(globals, out_count[0], resolved_decl) < 0 {
                        if exec_lower_append_global_slot(checker, resolved_decl, globals, out_count, 1) != 0 {
                            return -1;
                        }
                    }
                }
            } else if decl2 != null && decl2.type == ASTNodeType.AST_USE_STMT &&
                decl2.use_stmt_item_name == null {
                var local_name_candidate3: &byte = decl2.use_stmt_alias;
                if local_name_candidate3 == null &&
                    decl2.use_stmt_path_segments != null && decl2.use_stmt_path_segment_count > 0 {
                    local_name_candidate3 = decl2.use_stmt_path_segments[decl2.use_stmt_path_segment_count - 1];
                }
                if local_name_candidate3 != null {
                    const resolved_decl2: &ASTNode = exec_lower_resolve_module_self_named_global_from_file(checker, decl2.filename, local_name_candidate3);
                    if resolved_decl2 != null &&
                        exec_lower_find_global_slot_by_decl_in_globals(globals, out_count[0], resolved_decl2) < 0 {
                        if exec_lower_append_global_slot(checker, resolved_decl2, globals, out_count, 1) != 0 {
                            return -1;
                        }
                    }
                }
            }
            decl_i = decl_i + 1;
        }
    }
    return 0;
}

fn exec_lower_add_requested_module_global_name(out_names: & & byte, out_count: &i32, name: &byte) void {
    if out_names == null || out_count == null || name == null {
        return;
    }
    var i: i32 = 0;
    while i < out_count[0] {
        if out_names[i] != null && str_equals(out_names[i], name) != 0 {
            return;
        }
        i = i + 1;
    }
    if out_count[0] >= EXEC_MAX_MODULE_GLOBAL_REQUESTS {
        return;
    }
    out_names[out_count[0]] = name;
    out_count[0] = out_count[0] + 1;
}

fn exec_lower_collect_module_global_use_names_expr(checker: &TypeChecker, expr: &ASTNode, module_name: &byte, out_names: & & byte, out_count: &i32) void {
    if checker == null || expr == null || module_name == null || out_names == null || out_count == null {
        return;
    }
    if expr.type == ASTNodeType.AST_MEMBER_ACCESS {
        const resolved_module_name: &byte = exec_lower_resolve_member_access_module_name(checker, expr);
        if resolved_module_name != null && expr.member_access_field_name != null &&
            str_equals(resolved_module_name, module_name) != 0 {
            exec_lower_add_requested_module_global_name(out_names, out_count, expr.member_access_field_name);
        }
        exec_lower_collect_module_global_use_names_expr(checker, expr.member_access_object, module_name, out_names, out_count);
        return;
    }
    if expr.type == ASTNodeType.AST_CALL_EXPR {
        exec_lower_collect_module_global_use_names_expr(checker, expr.call_expr_callee, module_name, out_names, out_count);
        if expr.call_expr_args != null {
            var i: i32 = 0;
            while i < expr.call_expr_arg_count {
                exec_lower_collect_module_global_use_names_expr(checker, expr.call_expr_args[i], module_name, out_names, out_count);
                i = i + 1;
            }
        }
        return;
    }
    if expr.type == ASTNodeType.AST_ARRAY_ACCESS {
        exec_lower_collect_module_global_use_names_expr(checker, expr.array_access_array, module_name, out_names, out_count);
        exec_lower_collect_module_global_use_names_expr(checker, expr.array_access_index, module_name, out_names, out_count);
        return;
    }
    if expr.type == ASTNodeType.AST_BINARY_EXPR {
        exec_lower_collect_module_global_use_names_expr(checker, expr.binary_expr_left, module_name, out_names, out_count);
        exec_lower_collect_module_global_use_names_expr(checker, expr.binary_expr_right, module_name, out_names, out_count);
        return;
    }
    if expr.type == ASTNodeType.AST_UNARY_EXPR {
        exec_lower_collect_module_global_use_names_expr(checker, expr.unary_expr_operand, module_name, out_names, out_count);
        return;
    }
    if expr.type == ASTNodeType.AST_CAST_EXPR {
        exec_lower_collect_module_global_use_names_expr(checker, expr.cast_expr_expr, module_name, out_names, out_count);
        return;
    }
    if expr.type == ASTNodeType.AST_SLICE_EXPR {
        exec_lower_collect_module_global_use_names_expr(checker, expr.slice_expr_base, module_name, out_names, out_count);
        exec_lower_collect_module_global_use_names_expr(checker, expr.slice_expr_start_expr, module_name, out_names, out_count);
        exec_lower_collect_module_global_use_names_expr(checker, expr.slice_expr_len_expr, module_name, out_names, out_count);
        return;
    }
    if expr.type == ASTNodeType.AST_TRY_EXPR {
        exec_lower_collect_module_global_use_names_expr(checker, expr.try_expr_operand, module_name, out_names, out_count);
        return;
    }
    if expr.type == ASTNodeType.AST_CATCH_EXPR {
        exec_lower_collect_module_global_use_names_expr(checker, expr.catch_expr_operand, module_name, out_names, out_count);
        return;
    }
    if expr.type == ASTNodeType.AST_MATCH_EXPR {
        exec_lower_collect_module_global_use_names_expr(checker, expr.match_expr_expr, module_name, out_names, out_count);
        if expr.match_expr_arms != null {
            var mi: i32 = 0;
            while mi < expr.match_expr_arm_count {
                exec_lower_collect_module_global_use_names_expr(checker, expr.match_expr_arms[mi].result_expr, module_name, out_names, out_count);
                mi = mi + 1;
            }
        }
        return;
    }
    if expr.type == ASTNodeType.AST_STRUCT_INIT && expr.struct_init_field_values != null {
        var si: i32 = 0;
        while si < expr.struct_init_field_count {
            exec_lower_collect_module_global_use_names_expr(checker, expr.struct_init_field_values[si], module_name, out_names, out_count);
            si = si + 1;
        }
        return;
    }
    if expr.type == ASTNodeType.AST_ARRAY_LITERAL && expr.array_literal_elements != null {
        var ai: i32 = 0;
        while ai < expr.array_literal_element_count {
            exec_lower_collect_module_global_use_names_expr(checker, expr.array_literal_elements[ai], module_name, out_names, out_count);
            ai = ai + 1;
        }
        exec_lower_collect_module_global_use_names_expr(checker, expr.array_literal_repeat_count_expr, module_name, out_names, out_count);
        return;
    }
    if expr.type == ASTNodeType.AST_TUPLE_LITERAL && expr.tuple_literal_elements != null {
        var ti: i32 = 0;
        while ti < expr.tuple_literal_element_count {
            exec_lower_collect_module_global_use_names_expr(checker, expr.tuple_literal_elements[ti], module_name, out_names, out_count);
            ti = ti + 1;
        }
        return;
    }
    if expr.type == ASTNodeType.AST_LEN {
        exec_lower_collect_module_global_use_names_expr(checker, expr.len_expr_array, module_name, out_names, out_count);
        return;
    }
    if expr.type == ASTNodeType.AST_PTR_FROM_USIZE {
        exec_lower_collect_module_global_use_names_expr(checker, expr.ptr_from_usize_value, module_name, out_names, out_count);
        return;
    }
    if expr.type == ASTNodeType.AST_USIZE_FROM_PTR {
        exec_lower_collect_module_global_use_names_expr(checker, expr.usize_from_ptr_ptr, module_name, out_names, out_count);
        return;
    }
    if expr.type == ASTNodeType.AST_PRINT || expr.type == ASTNodeType.AST_PRINTLN {
        exec_lower_collect_module_global_use_names_expr(checker, expr.print_expr, module_name, out_names, out_count);
        return;
    }
}

fn exec_lower_collect_module_global_use_names_node(checker: &TypeChecker, node: &ASTNode, module_name: &byte, out_names: & & byte, out_count: &i32) void {
    if checker == null || node == null || module_name == null || out_names == null || out_count == null {
        return;
    }
    exec_lower_collect_module_global_use_names_expr(checker, node, module_name, out_names, out_count);
    if node.type == ASTNodeType.AST_PROGRAM && node.program_decls != null {
        var i: i32 = 0;
        while i < node.program_decl_count {
            exec_lower_collect_module_global_use_names_node(checker, node.program_decls[i], module_name, out_names, out_count);
            i = i + 1;
        }
        return;
    }
    if node.type == ASTNodeType.AST_BLOCK && node.block_stmts != null {
        var bi: i32 = 0;
        while bi < node.block_stmt_count {
            exec_lower_collect_module_global_use_names_node(checker, node.block_stmts[bi], module_name, out_names, out_count);
            bi = bi + 1;
        }
        return;
    }
    if node.type == ASTNodeType.AST_IF_STMT {
        exec_lower_collect_module_global_use_names_node(checker, node.if_stmt_condition, module_name, out_names, out_count);
        exec_lower_collect_module_global_use_names_node(checker, node.if_stmt_then_branch, module_name, out_names, out_count);
        exec_lower_collect_module_global_use_names_node(checker, node.if_stmt_else_branch, module_name, out_names, out_count);
        return;
    }
    if node.type == ASTNodeType.AST_WHILE_STMT {
        exec_lower_collect_module_global_use_names_node(checker, node.while_stmt_condition, module_name, out_names, out_count);
        exec_lower_collect_module_global_use_names_node(checker, node.while_stmt_body, module_name, out_names, out_count);
        return;
    }
    if node.type == ASTNodeType.AST_FOR_STMT {
        exec_lower_collect_module_global_use_names_node(checker, node.for_stmt_range_start, module_name, out_names, out_count);
        exec_lower_collect_module_global_use_names_node(checker, node.for_stmt_range_end, module_name, out_names, out_count);
        exec_lower_collect_module_global_use_names_node(checker, node.for_stmt_array, module_name, out_names, out_count);
        exec_lower_collect_module_global_use_names_node(checker, node.for_stmt_body, module_name, out_names, out_count);
        return;
    }
    if node.type == ASTNodeType.AST_VAR_DECL {
        exec_lower_collect_module_global_use_names_node(checker, node.var_decl_init, module_name, out_names, out_count);
        return;
    }
    if node.type == ASTNodeType.AST_EXTERN_VAR_DECL {
        exec_lower_collect_module_global_use_names_node(checker, node.extern_var_decl_init_expr, module_name, out_names, out_count);
        return;
    }
    if node.type == ASTNodeType.AST_RETURN_STMT {
        exec_lower_collect_module_global_use_names_node(checker, node.return_stmt_expr, module_name, out_names, out_count);
        return;
    }
    if node.type == ASTNodeType.AST_ASSIGN {
        exec_lower_collect_module_global_use_names_node(checker, node.assign_dest, module_name, out_names, out_count);
        exec_lower_collect_module_global_use_names_node(checker, node.assign_src, module_name, out_names, out_count);
        return;
    }
    if node.type == ASTNodeType.AST_DEFER_STMT {
        exec_lower_collect_module_global_use_names_node(checker, node.defer_stmt_body, module_name, out_names, out_count);
        return;
    }
    if node.type == ASTNodeType.AST_ERRDEFER_STMT {
        exec_lower_collect_module_global_use_names_node(checker, node.errdefer_stmt_body, module_name, out_names, out_count);
        return;
    }
    if node.type == ASTNodeType.AST_TEST_STMT {
        exec_lower_collect_module_global_use_names_node(checker, node.test_stmt_body, module_name, out_names, out_count);
        return;
    }
}

fn exec_lower_collect_global_slots_from_module_import(checker: &TypeChecker, module_name: &byte, requested_names: & & byte, requested_count: i32, globals: &HIRGlobalSlot, out_count: &i32) i32 {
    if checker == null || module_name == null || requested_names == null || globals == null || out_count == null {
        return -1;
    }
    if str_equals(module_name, "libc" as &byte) != 0 {
        exec_lower_add_requested_module_global_name(requested_names, &requested_count, "stdin" as &byte);
        exec_lower_add_requested_module_global_name(requested_names, &requested_count, "stdout" as &byte);
        exec_lower_add_requested_module_global_name(requested_names, &requested_count, "stderr" as &byte);
    }
    var ri: i32 = 0;
    while ri < requested_count {
        if requested_names[ri] != null {
            const export_decl: &ASTNode = exec_lower_find_module_export_decl(checker, module_name, requested_names[ri], 10);
            if export_decl != null &&
                exec_lower_global_is_runtime_decl(export_decl) != 0 &&
                exec_lower_find_global_slot_by_decl_in_globals(globals, out_count[0], export_decl) < 0 {
                const export_type_ast: &ASTNode = exec_lower_global_type_ast(export_decl);
                if export_type_ast != null {
                    const export_type: Type = type_from_ast(checker, export_type_ast);
                    if exec_type_is_vm_value_supported(export_type) != 0 {
                        if exec_lower_append_global_slot(checker, export_decl, globals, out_count, 1) != 0 {
                            return -1;
                        }
                    }
                }
                if checker.program_node != null && checker.program_node.type == ASTNodeType.AST_PROGRAM && export_decl.filename != null {
                    var decl_i: i32 = 0;
                    while decl_i < checker.program_node.program_decl_count {
                        const decl2: &ASTNode = checker.program_node.program_decls[decl_i];
                        if decl2 != null && decl2.filename != null &&
                            str_equals(decl2.filename, export_decl.filename) != 0 &&
                            exec_lower_global_is_runtime_decl(decl2) != 0 &&
                            exec_lower_find_global_slot_by_decl_in_globals(globals, out_count[0], decl2) < 0 {
                            const decl2_type_ast: &ASTNode = exec_lower_global_type_ast(decl2);
                            if decl2_type_ast != null {
                                const decl2_type: Type = type_from_ast(checker, decl2_type_ast);
                                if exec_type_is_vm_value_supported(decl2_type) != 0 {
                                    if exec_lower_append_global_slot(checker, decl2, globals, out_count, 1) != 0 {
                                        return -1;
                                    }
                                }
                            }
                        }
                        decl_i = decl_i + 1;
                    }
                }
            }
        }
        ri = ri + 1;
    }
    return 0;
}

fn exec_lower_collect_global_slots_from_module_imports(checker: &TypeChecker, globals: &HIRGlobalSlot, out_count: &i32) i32 {
    if checker == null || globals == null || out_count == null {
        return -1;
    }
    var slot: i32 = 0;
    while slot < IMPORT_TABLE_SIZE {
        const import_item: &ImportedItem = checker.import_table.slots[slot];
        if import_item != null && import_item.item_type == (0 - 1) && import_item.module_name != null {
            var requested_names: [&byte: EXEC_MAX_MODULE_GLOBAL_REQUESTS] = [];
            var requested_count: i32 = 0;
            exec_lower_collect_module_global_use_names_node(checker, checker.program_node, import_item.module_name, &requested_names[0] as & & byte, &requested_count);
            if exec_lower_collect_global_slots_from_module_import(checker, import_item.module_name, &requested_names[0] as & & byte, requested_count, globals, out_count) != 0 {
                return -1;
            }
        }
        slot = slot + 1;
    }
    return 0;
}

fn exec_lower_collect_global_slots_from_use_stmts(checker: &TypeChecker, globals: &HIRGlobalSlot, out_count: &i32) i32 {
    if checker == null || checker.program_node == null || checker.program_node.type != ASTNodeType.AST_PROGRAM ||
        globals == null || out_count == null {
        return -1;
    }
    var decl_i: i32 = 0;
    while decl_i < checker.program_node.program_decl_count {
        const decl: &ASTNode = checker.program_node.program_decls[decl_i];
        if decl != null && decl.type == ASTNodeType.AST_USE_STMT &&
            decl.use_stmt_item_name == null &&
            decl.use_stmt_path_segments != null && decl.use_stmt_path_segment_count > 0 {
            const module_name_len: i32 = exec_lower_joined_module_name_len(decl.use_stmt_path_segments, decl.use_stmt_path_segment_count);
            if module_name_len > 0 {
                const module_name: &byte = compiler_arena_alloc(checker.arena, module_name_len as usize + 1 as usize) as &byte;
                if module_name != null {
                    exec_lower_write_joined_module_name(module_name, decl.use_stmt_path_segments, decl.use_stmt_path_segment_count);
                    var requested_names: [&byte: EXEC_MAX_MODULE_GLOBAL_REQUESTS] = [];
                    var requested_count: i32 = 0;
                    exec_lower_collect_module_global_use_names_node(checker, checker.program_node, module_name, &requested_names[0] as & & byte, &requested_count);
                    if exec_lower_collect_global_slots_from_module_import(checker, module_name, &requested_names[0] as & & byte, requested_count, globals, out_count) != 0 {
                        return -1;
                    }
                }
            }
        }
        decl_i = decl_i + 1;
    }
    return 0;
}

fn exec_lower_collect_reachable_runtime_globals_expr(checker: &TypeChecker, expr: &ASTNode, owner_filename: &byte, globals: &HIRGlobalSlot, out_count: &i32) i32 {
    if checker == null || expr == null || owner_filename == null || globals == null || out_count == null {
        return 0;
    }
    if expr.type == ASTNodeType.AST_IDENTIFIER && expr.identifier_name != null {
        const decl: &ASTNode = exec_lower_resolve_global_decl(checker, expr.identifier_name);
        if decl != null &&
            decl.filename != null &&
            exec_lower_global_is_runtime_decl(decl) != 0 &&
            exec_lower_decl_is_uya_root_runtime(checker, decl) != 0 &&
            str_equals(decl.filename, owner_filename) != 0 &&
            exec_lower_find_global_slot_by_decl_in_globals(globals, out_count[0], decl) < 0 {
            if exec_lower_append_global_slot(checker, decl, globals, out_count, 1) != 0 {
                return -1;
            }
        }
        return 0;
    }
    if expr.type == ASTNodeType.AST_MEMBER_ACCESS {
        return exec_lower_collect_reachable_runtime_globals_expr(checker, expr.member_access_object, owner_filename, globals, out_count);
    }
    if expr.type == ASTNodeType.AST_CALL_EXPR {
        if exec_lower_collect_reachable_runtime_globals_expr(checker, expr.call_expr_callee, owner_filename, globals, out_count) != 0 {
            return -1;
        }
        if expr.call_expr_args != null {
            var i: i32 = 0;
            while i < expr.call_expr_arg_count {
                if exec_lower_collect_reachable_runtime_globals_expr(checker, expr.call_expr_args[i], owner_filename, globals, out_count) != 0 {
                    return -1;
                }
                i = i + 1;
            }
        }
        return 0;
    }
    if expr.type == ASTNodeType.AST_ARRAY_ACCESS {
        if exec_lower_collect_reachable_runtime_globals_expr(checker, expr.array_access_array, owner_filename, globals, out_count) != 0 {
            return -1;
        }
        return exec_lower_collect_reachable_runtime_globals_expr(checker, expr.array_access_index, owner_filename, globals, out_count);
    }
    if expr.type == ASTNodeType.AST_BINARY_EXPR {
        if exec_lower_collect_reachable_runtime_globals_expr(checker, expr.binary_expr_left, owner_filename, globals, out_count) != 0 {
            return -1;
        }
        return exec_lower_collect_reachable_runtime_globals_expr(checker, expr.binary_expr_right, owner_filename, globals, out_count);
    }
    if expr.type == ASTNodeType.AST_UNARY_EXPR {
        return exec_lower_collect_reachable_runtime_globals_expr(checker, expr.unary_expr_operand, owner_filename, globals, out_count);
    }
    if expr.type == ASTNodeType.AST_CAST_EXPR {
        return exec_lower_collect_reachable_runtime_globals_expr(checker, expr.cast_expr_expr, owner_filename, globals, out_count);
    }
    if expr.type == ASTNodeType.AST_SLICE_EXPR {
        if exec_lower_collect_reachable_runtime_globals_expr(checker, expr.slice_expr_base, owner_filename, globals, out_count) != 0 ||
            exec_lower_collect_reachable_runtime_globals_expr(checker, expr.slice_expr_start_expr, owner_filename, globals, out_count) != 0 {
            return -1;
        }
        return exec_lower_collect_reachable_runtime_globals_expr(checker, expr.slice_expr_len_expr, owner_filename, globals, out_count);
    }
    if expr.type == ASTNodeType.AST_TRY_EXPR {
        return exec_lower_collect_reachable_runtime_globals_expr(checker, expr.try_expr_operand, owner_filename, globals, out_count);
    }
    if expr.type == ASTNodeType.AST_CATCH_EXPR {
        if exec_lower_collect_reachable_runtime_globals_expr(checker, expr.catch_expr_operand, owner_filename, globals, out_count) != 0 {
            return -1;
        }
        return exec_lower_collect_reachable_runtime_globals_node(checker, expr.catch_expr_catch_block, owner_filename, globals, out_count);
    }
    if expr.type == ASTNodeType.AST_MATCH_EXPR {
        if exec_lower_collect_reachable_runtime_globals_expr(checker, expr.match_expr_expr, owner_filename, globals, out_count) != 0 {
            return -1;
        }
        if expr.match_expr_arms != null {
            var mi: i32 = 0;
            while mi < expr.match_expr_arm_count {
                if exec_lower_collect_reachable_runtime_globals_expr(checker, expr.match_expr_arms[mi].result_expr, owner_filename, globals, out_count) != 0 {
                    return -1;
                }
                mi = mi + 1;
            }
        }
        return 0;
    }
    if expr.type == ASTNodeType.AST_STRUCT_INIT && expr.struct_init_field_values != null {
        var si: i32 = 0;
        while si < expr.struct_init_field_count {
            if exec_lower_collect_reachable_runtime_globals_expr(checker, expr.struct_init_field_values[si], owner_filename, globals, out_count) != 0 {
                return -1;
            }
            si = si + 1;
        }
        return 0;
    }
    if expr.type == ASTNodeType.AST_ARRAY_LITERAL && expr.array_literal_elements != null {
        var ai: i32 = 0;
        while ai < expr.array_literal_element_count {
            if exec_lower_collect_reachable_runtime_globals_expr(checker, expr.array_literal_elements[ai], owner_filename, globals, out_count) != 0 {
                return -1;
            }
            ai = ai + 1;
        }
        return exec_lower_collect_reachable_runtime_globals_expr(checker, expr.array_literal_repeat_count_expr, owner_filename, globals, out_count);
    }
    if expr.type == ASTNodeType.AST_TUPLE_LITERAL && expr.tuple_literal_elements != null {
        var ti: i32 = 0;
        while ti < expr.tuple_literal_element_count {
            if exec_lower_collect_reachable_runtime_globals_expr(checker, expr.tuple_literal_elements[ti], owner_filename, globals, out_count) != 0 {
                return -1;
            }
            ti = ti + 1;
        }
        return 0;
    }
    if expr.type == ASTNodeType.AST_LEN {
        return exec_lower_collect_reachable_runtime_globals_expr(checker, expr.len_expr_array, owner_filename, globals, out_count);
    }
    if expr.type == ASTNodeType.AST_PTR_FROM_USIZE {
        return exec_lower_collect_reachable_runtime_globals_expr(checker, expr.ptr_from_usize_value, owner_filename, globals, out_count);
    }
    if expr.type == ASTNodeType.AST_USIZE_FROM_PTR {
        return exec_lower_collect_reachable_runtime_globals_expr(checker, expr.usize_from_ptr_ptr, owner_filename, globals, out_count);
    }
    if expr.type == ASTNodeType.AST_PRINT || expr.type == ASTNodeType.AST_PRINTLN {
        return exec_lower_collect_reachable_runtime_globals_expr(checker, expr.print_expr, owner_filename, globals, out_count);
    }
    if expr.type == ASTNodeType.AST_ERROR_ID {
        return exec_lower_collect_reachable_runtime_globals_expr(checker, expr.error_id_operand, owner_filename, globals, out_count);
    }
    if expr.type == ASTNodeType.AST_ERROR_NAME {
        return exec_lower_collect_reachable_runtime_globals_expr(checker, expr.error_name_operand, owner_filename, globals, out_count);
    }
    if expr.type == ASTNodeType.AST_SYSCALL {
        if exec_lower_collect_reachable_runtime_globals_expr(checker, expr.syscall_number, owner_filename, globals, out_count) != 0 {
            return -1;
        }
        if expr.syscall_args != null {
            var si2: i32 = 0;
            while si2 < expr.syscall_arg_count {
                if exec_lower_collect_reachable_runtime_globals_expr(checker, expr.syscall_args[si2], owner_filename, globals, out_count) != 0 {
                    return -1;
                }
                si2 = si2 + 1;
            }
        }
        return 0;
    }
    return 0;
}

fn exec_lower_collect_reachable_runtime_globals_node(checker: &TypeChecker, node: &ASTNode, owner_filename: &byte, globals: &HIRGlobalSlot, out_count: &i32) i32 {
    if checker == null || node == null || owner_filename == null || globals == null || out_count == null {
        return 0;
    }
    if node.type == ASTNodeType.AST_BLOCK && node.block_stmts != null {
        var bi: i32 = 0;
        while bi < node.block_stmt_count {
            if exec_lower_collect_reachable_runtime_globals_node(checker, node.block_stmts[bi], owner_filename, globals, out_count) != 0 {
                return -1;
            }
            bi = bi + 1;
        }
        return 0;
    }
    if node.type == ASTNodeType.AST_IF_STMT {
        if exec_lower_collect_reachable_runtime_globals_node(checker, node.if_stmt_condition, owner_filename, globals, out_count) != 0 ||
            exec_lower_collect_reachable_runtime_globals_node(checker, node.if_stmt_then_branch, owner_filename, globals, out_count) != 0 {
            return -1;
        }
        return exec_lower_collect_reachable_runtime_globals_node(checker, node.if_stmt_else_branch, owner_filename, globals, out_count);
    }
    if node.type == ASTNodeType.AST_WHILE_STMT {
        if exec_lower_collect_reachable_runtime_globals_node(checker, node.while_stmt_condition, owner_filename, globals, out_count) != 0 {
            return -1;
        }
        return exec_lower_collect_reachable_runtime_globals_node(checker, node.while_stmt_body, owner_filename, globals, out_count);
    }
    if node.type == ASTNodeType.AST_FOR_STMT {
        if exec_lower_collect_reachable_runtime_globals_node(checker, node.for_stmt_range_start, owner_filename, globals, out_count) != 0 ||
            exec_lower_collect_reachable_runtime_globals_node(checker, node.for_stmt_range_end, owner_filename, globals, out_count) != 0 ||
            exec_lower_collect_reachable_runtime_globals_node(checker, node.for_stmt_array, owner_filename, globals, out_count) != 0 {
            return -1;
        }
        return exec_lower_collect_reachable_runtime_globals_node(checker, node.for_stmt_body, owner_filename, globals, out_count);
    }
    if node.type == ASTNodeType.AST_VAR_DECL {
        return exec_lower_collect_reachable_runtime_globals_node(checker, node.var_decl_init, owner_filename, globals, out_count);
    }
    if node.type == ASTNodeType.AST_EXTERN_VAR_DECL {
        return exec_lower_collect_reachable_runtime_globals_node(checker, node.extern_var_decl_init_expr, owner_filename, globals, out_count);
    }
    if node.type == ASTNodeType.AST_RETURN_STMT {
        return exec_lower_collect_reachable_runtime_globals_node(checker, node.return_stmt_expr, owner_filename, globals, out_count);
    }
    if node.type == ASTNodeType.AST_ASSIGN {
        if exec_lower_collect_reachable_runtime_globals_node(checker, node.assign_dest, owner_filename, globals, out_count) != 0 {
            return -1;
        }
        return exec_lower_collect_reachable_runtime_globals_node(checker, node.assign_src, owner_filename, globals, out_count);
    }
    if node.type == ASTNodeType.AST_DEFER_STMT {
        return exec_lower_collect_reachable_runtime_globals_node(checker, node.defer_stmt_body, owner_filename, globals, out_count);
    }
    if node.type == ASTNodeType.AST_ERRDEFER_STMT {
        return exec_lower_collect_reachable_runtime_globals_node(checker, node.errdefer_stmt_body, owner_filename, globals, out_count);
    }
    return exec_lower_collect_reachable_runtime_globals_expr(checker, node, owner_filename, globals, out_count);
}

fn exec_lower_collect_runtime_fn_decl_index(decls: & & ASTNode, decl_count: i32, target: &ASTNode) i32 {
    if decls == null || target == null {
        return -1;
    }
    var i: i32 = 0;
    while i < decl_count {
        if decls[i] == target {
            return i;
        }
        i = i + 1;
    }
    return -1;
}

fn exec_lower_collect_exec_reachable_fn_decls(checker: &TypeChecker, out_decls: & & ASTNode, out_count: &i32) i32 {
    if checker == null || out_decls == null || out_count == null {
        return -1;
    }
    out_count[0] = 0;
    const entry_decl: &ASTNode = exec_lower_find_entry_decl(checker);
    if entry_decl == null {
        return 0;
    }
    var queue: [&ASTNode: MAX_REACHABLE_FN_DECLS] = [];
    var head: i32 = 0;
    var tail: i32 = 0;
    out_decls[0] = entry_decl;
    out_count[0] = 1;
    queue[0] = entry_decl;
    tail = 1;
    while head < tail {
        const from_decl: &ASTNode = queue[head];
        head = head + 1;
        var i: i32 = 0;
        while i < checker.fn_call_edge_count {
            if checker.fn_call_edge_from[i] == from_decl {
                const to_decl: &ASTNode = checker.fn_call_edge_to[i];
                if to_decl != null &&
                    exec_lower_collect_runtime_fn_decl_index(out_decls, out_count[0], to_decl) < 0 {
                    if out_count[0] >= MAX_REACHABLE_FN_DECLS || tail >= MAX_REACHABLE_FN_DECLS {
                        exec_backend_set_error(to_decl, "exec: runtime reachable 函数集合超出上限" as *byte, 0);
                        return -1;
                    }
                    out_decls[out_count[0]] = to_decl;
                    out_count[0] = out_count[0] + 1;
                    queue[tail] = to_decl;
                    tail = tail + 1;
                }
            }
            i = i + 1;
        }
    }
    return 0;
}

fn exec_lower_collect_global_slots_from_reachable_runtime_functions(checker: &TypeChecker, globals: &HIRGlobalSlot, out_count: &i32) i32 {
    if checker == null || globals == null || out_count == null {
        return -1;
    }
    var fn_decls: [&ASTNode: MAX_REACHABLE_FN_DECLS] = [];
    var fn_decl_count: i32 = 0;
    if exec_lower_collect_exec_reachable_fn_decls(checker, &fn_decls[0] as & & ASTNode, &fn_decl_count) != 0 {
        return -1;
    }
    var i: i32 = 0;
    while i < fn_decl_count {
        const fn_decl: &ASTNode = fn_decls[i];
        if fn_decl != null &&
            fn_decl.type == ASTNodeType.AST_FN_DECL &&
            fn_decl.fn_decl_body != null &&
            fn_decl.filename != null &&
            exec_lower_decl_is_uya_root_runtime(checker, fn_decl) != 0 {
            if exec_lower_collect_reachable_runtime_globals_node(checker, fn_decl.fn_decl_body, fn_decl.filename, globals, out_count) != 0 {
                return -1;
            }
        }
        i = i + 1;
    }
    return 0;
}

fn exec_lower_find_global_slot_by_decl_in_globals(globals: &HIRGlobalSlot, global_count: i32, decl: &ASTNode) i32 {
    if globals == null || decl == null {
        return -1;
    }
    var i: i32 = 0;
    while i < global_count {
        if globals[i].decl == decl {
            return i;
        }
        i = i + 1;
    }
    return -1;
}

fn exec_lower_collect_global_slots(arena: &CompilerArena, checker: &TypeChecker, program: &ASTNode, out_count: &i32) &HIRGlobalSlot {
    if out_count != null {
        out_count[0] = 0;
    }
    if arena == null || checker == null || program == null || program.type != ASTNodeType.AST_PROGRAM {
        return null;
    }
    const globals: &HIRGlobalSlot = compiler_arena_alloc(arena, @size_of(HIRGlobalSlot) * EXEC_MAX_GLOBALS as usize) as &HIRGlobalSlot;
    if globals == null {
        exec_backend_set_error(program, "exec: global slot 表分配失败" as *byte, 0);
        return null;
    }
    var count: i32 = 0;
    if exec_lower_collect_global_slots_from_program(checker, program, globals, &count) != 0 {
        return null;
    }
    if exec_lower_collect_global_slots_from_symbols(checker, globals, &count) != 0 {
        return null;
    }
    if exec_lower_collect_global_slots_from_symbol_table(checker, globals, &count) != 0 {
        return null;
    }
    if exec_lower_collect_global_slots_from_imports(checker, globals, &count) != 0 {
        return null;
    }
    if exec_lower_collect_global_slots_from_module_imports(checker, globals, &count) != 0 {
        return null;
    }
    if exec_lower_collect_global_slots_from_use_stmts(checker, globals, &count) != 0 {
        return null;
    }
    if exec_lower_collect_global_slots_from_reachable_runtime_functions(checker, globals, &count) != 0 {
        return null;
    }
    if out_count != null {
        out_count[0] = count;
    }
    return globals;
}

fn exec_lower_collect_called_decls_from_expr(expr: &HIRExpr, out_decls: & & ASTNode, out_count: &i32) void {
    if expr == null || out_count == null {
        return;
    }
    if expr.kind == HIRExprKind.HIR_EXPR_CALL && expr.callee_decl != null &&
        expr.callee_decl.type == ASTNodeType.AST_FN_DECL &&
        expr.callee_decl.fn_decl_body != null &&
        expr.call_host_id == ExecHostCallId.EXEC_HOST_CALL_NONE &&
        exec_lower_decl_index(out_decls, out_count[0], expr.callee_decl) < 0 {
        if out_count[0] < MAX_REACHABLE_FN_DECLS {
            out_decls[out_count[0]] = expr.callee_decl;
            out_count[0] = out_count[0] + 1;
        }
    }
    if expr.kind == HIRExprKind.HIR_EXPR_INTERFACE_BOX && expr.dispatch_decls != null {
        var di: i32 = 0;
        while di < expr.dispatch_decl_count {
            const dispatch_decl: &ASTNode = expr.dispatch_decls[di];
            if dispatch_decl != null &&
                exec_lower_decl_index(out_decls, out_count[0], dispatch_decl) < 0 &&
                out_count[0] < MAX_REACHABLE_FN_DECLS {
                out_decls[out_count[0]] = dispatch_decl;
                out_count[0] = out_count[0] + 1;
            }
            di = di + 1;
        }
    }
    if expr.left != null {
        exec_lower_collect_called_decls_from_expr(expr.left, out_decls, out_count);
    }
    if expr.right != null {
        exec_lower_collect_called_decls_from_expr(expr.right, out_decls, out_count);
    }
    if expr.extra != null {
        exec_lower_collect_called_decls_from_expr(expr.extra, out_decls, out_count);
    }
    if expr.block != null {
        exec_lower_collect_called_decls_from_block(expr.block, out_decls, out_count);
    }
    var i: i32 = 0;
    while i < expr.call_arg_count {
        exec_lower_collect_called_decls_from_expr(expr.call_args[i], out_decls, out_count);
        i = i + 1;
    }
    i = 0;
    while i < expr.item_count {
        exec_lower_collect_called_decls_from_expr(expr.items[i], out_decls, out_count);
        i = i + 1;
    }
    i = 0;
    while i < expr.match_arm_count {
        exec_lower_collect_called_decls_from_expr(expr.match_arms[i].result_expr, out_decls, out_count);
        i = i + 1;
    }
}

fn exec_lower_collect_called_decls_from_stmt(stmt: &HIRStmt, out_decls: & & ASTNode, out_count: &i32) void {
    if stmt == null {
        return;
    }
    if stmt.expr != null {
        exec_lower_collect_called_decls_from_expr(stmt.expr, out_decls, out_count);
    }
    if stmt.assign_expr != null {
        exec_lower_collect_called_decls_from_expr(stmt.assign_expr, out_decls, out_count);
    }
    if stmt.assign_target != null {
        exec_lower_collect_called_decls_from_expr(stmt.assign_target, out_decls, out_count);
    }
    if stmt.then_block != null {
        exec_lower_collect_called_decls_from_block(stmt.then_block, out_decls, out_count);
    }
    if stmt.else_block != null {
        exec_lower_collect_called_decls_from_block(stmt.else_block, out_decls, out_count);
    }
    if stmt.loop_body != null {
        exec_lower_collect_called_decls_from_block(stmt.loop_body, out_decls, out_count);
    }
    if stmt.cleanup_block != null {
        exec_lower_collect_called_decls_from_block(stmt.cleanup_block, out_decls, out_count);
    }
}

fn exec_lower_collect_called_decls_from_block(block: &HIRBlock, out_decls: & & ASTNode, out_count: &i32) void {
    if block == null || out_count == null {
        return;
    }
    var i: i32 = 0;
    while i < block.stmt_count {
        exec_lower_collect_called_decls_from_stmt(block.stmts[i], out_decls, out_count);
        i = i + 1;
    }
}

fn exec_lower_collect_cleanup_decls_from_function(checker: &TypeChecker, fn_hir: &HIRFunction, out_decls: & & ASTNode, out_count: &i32) void {
    if checker == null || checker.program_node == null || fn_hir == null || fn_hir.locals == null || out_count == null {
        return;
    }
    var i: i32 = 0;
    while i < fn_hir.local_count {
        const local: &HIRLocalSlot = fn_hir.locals + i;
        var drop_decl: &ASTNode = local.drop_decl;
        if drop_decl == null && local != null && local.decl != null &&
            local.decl.type == ASTNodeType.AST_VAR_DECL &&
            local.decl.var_decl_type != null &&
            local.decl.var_decl_type.type == ASTNodeType.AST_TYPE_NAMED &&
            local.decl.var_decl_type.type_named_name != null {
            drop_decl = exec_lower_find_named_drop_decl(checker, local.decl.var_decl_type.type_named_name);
        }
        if local != null &&
            drop_decl != null &&
            drop_decl.type == ASTNodeType.AST_FN_DECL &&
            drop_decl.fn_decl_body != null &&
            exec_lower_decl_index(out_decls, out_count[0], drop_decl) < 0 &&
            out_count[0] < MAX_REACHABLE_FN_DECLS {
            out_decls[out_count[0]] = drop_decl;
            out_count[0] = out_count[0] + 1;
        }
        i = i + 1;
    }
}

fn exec_lower_lower_global_init_exprs(arena: &CompilerArena, checker: &TypeChecker, globals: &HIRGlobalSlot, global_count: i32, seed_decls: & & ASTNode, seed_count: &i32) i32 {
    if arena == null || checker == null || seed_count == null {
        return -1;
    }
    var i: i32 = 0;
    while i < global_count {
        const decl: &ASTNode = globals[i].decl;
        const init_expr_ast: &ASTNode = exec_lower_global_init_ast(decl);
        if init_expr_ast != null {
            var ctx: ExecLowerContext = ExecLowerContext {
                arena: arena,
                checker: checker,
                function_decl: decl,
                global_names: [],
                global_decls: [],
                global_types: [],
                global_is_const: [],
                global_count: 0,
                local_names: [],
                local_slots: [],
                local_types: [],
                local_is_param: [],
                slot_names: [],
                slot_decls: [],
                slot_types: [],
                slot_is_param: [],
                slot_scope_ids: [],
                slot_needs_drop: [],
                slot_drop_decls: [],
                active_local_count: 0,
                next_slot: 0,
                max_slot_count: 0,
                next_scope_id: 0,
                scope_markers: [],
                scope_ids: [],
                scope_depth: 0,
            };
            exec_lower_seed_globals(&ctx, globals, global_count);
            const lowered_init: &HIRExpr = exec_lower_coerce_expr(&ctx, init_expr_ast, &globals[i].type_ref.type);
            if lowered_init == null {
                return -1;
            }
            globals[i].init_expr = lowered_init;
            exec_lower_collect_called_decls_from_expr(lowered_init, seed_decls, seed_count);
        }
        i = i + 1;
    }
    return 0;
}

fn exec_lower_build_global_init_function(arena: &CompilerArena, globals: &HIRGlobalSlot, global_count: i32) &HIRFunction {
    if arena == null || globals == null || global_count <= 0 {
        return null;
    }
    var stmt_count: i32 = 0;
    var i: i32 = 0;
    while i < global_count {
        if globals[i].init_expr != null {
            stmt_count = stmt_count + 1;
        }
        i = i + 1;
    }
    if stmt_count == 0 {
        return null;
    }
    const body: &HIRBlock = exec_lower_alloc_scoped_block_raw(arena, globals[0].decl, 0, stmt_count);
    const fn_hir: &HIRFunction = compiler_arena_alloc(arena, @size_of(HIRFunction)) as &HIRFunction;
    if body == null || fn_hir == null {
        exec_backend_set_error(globals[0].decl, "exec: global init function 分配失败" as *byte, 0);
        return null;
    }
    _ = memset(fn_hir as *byte, 0, @size_of(HIRFunction));
    var stmt_idx: i32 = 0;
    i = 0;
    while i < global_count {
        if globals[i].init_expr != null {
            const stmt: &HIRStmt = compiler_arena_alloc(arena, @size_of(HIRStmt)) as &HIRStmt;
            const target: &HIRExpr = compiler_arena_alloc(arena, @size_of(HIRExpr)) as &HIRExpr;
            if stmt == null || target == null {
                exec_backend_set_error(globals[i].decl, "exec: global init stmt 分配失败" as *byte, 0);
                return null;
            }
            _ = memset(stmt as *byte, 0, @size_of(HIRStmt));
            _ = memset(target as *byte, 0, @size_of(HIRExpr));
            stmt.kind = HIRStmtKind.HIR_STMT_ASSIGN;
            stmt.ast_node = globals[i].decl;
            target.kind = HIRExprKind.HIR_EXPR_GLOBAL;
            target.ast_node = globals[i].decl;
            target.type_ref = exec_lower_make_type_ref(&globals[i].type_ref.type);
            target.local_slot = -1;
            target.global_slot = globals[i].slot;
            stmt.assign_target = target;
            stmt.assign_expr = globals[i].init_expr;
            body.stmts[stmt_idx + 1] = stmt;
            stmt_idx = stmt_idx + 1;
        }
        i = i + 1;
    }
    const void_type: Type = make_void_type();
    fn_hir.name = "__exec_global_init" as &byte;
    fn_hir.decl = globals[0].decl;
    fn_hir.return_type = exec_lower_make_type_ref(&void_type);
    fn_hir.locals = null;
    fn_hir.local_count = 0;
    fn_hir.param_count = 0;
    fn_hir.body = body;
    return fn_hir;
}

fn exec_lower_find_entry_decl(checker: &TypeChecker) &ASTNode {
    if checker == null {
        return null;
    }
    var fallback: &ASTNode = null;
    var i: i32 = 0;
    while i < checker.reachable_fn_decl_count {
        const decl: &ASTNode = checker.reachable_fn_decls[i];
        if decl != null &&
            decl.type == ASTNodeType.AST_FN_DECL &&
            decl.fn_decl_name != null &&
            str_equals(decl.fn_decl_name, "main" as *byte) != 0 &&
            decl.fn_decl_body != null {
            if decl.fn_decl_is_extern == 0 && decl.fn_decl_param_count == 0 {
                return decl;
            }
            if fallback == null {
                fallback = decl;
            }
        }
        i = i + 1;
    }
    return fallback;
}

fn exec_lower_decl_index(decls: & & ASTNode, decl_count: i32, target: &ASTNode) i32 {
    if decls == null || target == null {
        return -1;
    }
    var i: i32 = 0;
    while i < decl_count {
        if decls[i] == target {
            return i;
        }
        i = i + 1;
    }
    return -1;
}

fn exec_lower_expr(ctx: &ExecLowerContext, expr: &ASTNode) &HIRExpr {
    if ctx == null || expr == null {
        return null;
    }
    if expr.type == ASTNodeType.AST_TRY_EXPR {
        const operand_try_early: &HIRExpr = exec_lower_expr(ctx, expr.try_expr_operand);
        if operand_try_early == null {
            return null;
        }
        if operand_try_early.type_ref.type.kind != TypeKind.TYPE_ERROR_UNION ||
            operand_try_early.type_ref.type.error_union_payload_type == null {
            return exec_lower_fail_expr_reason(expr, "exec: try 操作数不是错误联合" as *byte, ExecUnsupportedReason.EXEC_UNSUPPORTED_TRY_EXPR);
        }
        const try_payload_type: Type = operand_try_early.type_ref.type.error_union_payload_type[0];
        const hir_try_early: &HIRExpr = exec_lower_alloc_expr(ctx, expr, HIRExprKind.HIR_EXPR_TRY, &try_payload_type);
        if hir_try_early == null {
            return null;
        }
        hir_try_early.left = operand_try_early;
        return hir_try_early;
    }
    if expr.type == ASTNodeType.AST_CATCH_EXPR {
        if expr.catch_expr_err_name != null {
            return exec_lower_fail_expr_reason(expr, "exec: 当前不支持带错误绑定的 catch" as *byte, ExecUnsupportedReason.EXEC_UNSUPPORTED_CATCH_EXPR);
        }
        const operand_catch_early: &HIRExpr = exec_lower_expr(ctx, expr.catch_expr_operand);
        if operand_catch_early == null {
            return null;
        }
        if operand_catch_early.type_ref.type.kind != TypeKind.TYPE_ERROR_UNION ||
            operand_catch_early.type_ref.type.error_union_payload_type == null {
            return exec_lower_fail_expr_reason(expr, "exec: catch 操作数不是错误联合" as *byte, ExecUnsupportedReason.EXEC_UNSUPPORTED_CATCH_EXPR);
        }
        const catch_payload_type: Type = operand_catch_early.type_ref.type.error_union_payload_type[0];
        const hir_catch_early: &HIRExpr = exec_lower_alloc_expr(ctx, expr, HIRExprKind.HIR_EXPR_CATCH, &catch_payload_type);
        if hir_catch_early == null {
            return null;
        }
        hir_catch_early.left = operand_catch_early;
        const catch_block_early: &ASTNode = expr.catch_expr_catch_block;
        const catch_last_stmt_early: &ASTNode = exec_lower_block_last_stmt(catch_block_early);
        if catch_last_stmt_early == null {
            return exec_lower_fail_expr_reason(expr, "exec: catch 分支块为空" as *byte, ExecUnsupportedReason.EXEC_UNSUPPORTED_CATCH_EXPR);
        }
        if catch_payload_type.kind == TypeKind.TYPE_VOID && catch_last_stmt_early.type != ASTNodeType.AST_RETURN_STMT {
            hir_catch_early.block = exec_lower_block(ctx, catch_block_early);
            if hir_catch_early.block == null {
                return null;
            }
            hir_catch_early.right = exec_lower_make_zero_expr(ctx, catch_block_early, &catch_payload_type);
            if hir_catch_early.right == null {
                return null;
            }
            return hir_catch_early;
        }
        hir_catch_early.block = exec_lower_make_block_prefix(ctx, catch_block_early);
        if catch_last_stmt_early.type == ASTNodeType.AST_RETURN_STMT {
            const return_stmt_early: &ASTNode = catch_last_stmt_early;
            if return_stmt_early.return_stmt_expr != null {
                if ctx.function_decl != null && ctx.function_decl.fn_decl_return_type != null {
                    const catch_return_type_early: Type = type_from_ast(ctx.checker, ctx.function_decl.fn_decl_return_type);
                    hir_catch_early.extra = exec_lower_coerce_expr(ctx, return_stmt_early.return_stmt_expr, &catch_return_type_early);
                } else {
                    hir_catch_early.extra = exec_lower_expr(ctx, return_stmt_early.return_stmt_expr);
                }
                if hir_catch_early.extra == null {
                    return null;
                }
            }
            return hir_catch_early;
        }
        const fallback_expr_early: &HIRExpr = exec_lower_expr(ctx, catch_last_stmt_early);
        if fallback_expr_early == null {
            return null;
        }
        hir_catch_early.right = fallback_expr_early;
        return hir_catch_early;
    }
    const expr_type: Type = exec_lower_expr_type(ctx, expr);
    if expr.type == ASTNodeType.AST_SIZEOF || expr.type == ASTNodeType.AST_ALIGNOF {
        const folded_value: i32 = exec_lower_eval_size_align_builtin(ctx, expr);
        if folded_value < 0 {
            const fallback_value: i32 = checker_eval_const_expr(ctx.checker, expr);
            if fallback_value < 0 {
                return exec_lower_fail_expr(expr, "exec: 编译期 builtin 折叠失败" as *byte);
            }
            return exec_lower_make_int_const_expr(ctx, expr, &expr_type, fallback_value as i64);
        }
        return exec_lower_make_int_const_expr(ctx, expr, &expr_type, folded_value as i64);
    }
    if expr.type == ASTNodeType.AST_SRC_NAME {
        return exec_lower_make_string_const_expr(ctx, expr, &expr_type, exec_lower_basename(expr.filename));
    }
    if expr.type == ASTNodeType.AST_SRC_PATH {
        var source_path: &byte = expr.filename;
        if source_path == null {
            source_path = "(unknown)" as &byte;
        }
        return exec_lower_make_string_const_expr(ctx, expr, &expr_type, source_path);
    }
    if expr.type == ASTNodeType.AST_SRC_LINE {
        return exec_lower_make_int_const_expr(ctx, expr, &expr_type, expr.line as i64);
    }
    if expr.type == ASTNodeType.AST_SRC_COL {
        return exec_lower_make_int_const_expr(ctx, expr, &expr_type, expr.column as i64);
    }
    if expr.type == ASTNodeType.AST_FUNC_NAME {
        var func_name: &byte = "(unknown)" as &byte;
        if ctx.function_decl != null && ctx.function_decl.fn_decl_name != null {
            func_name = ctx.function_decl.fn_decl_name;
        }
        return exec_lower_make_string_const_expr(ctx, expr, &expr_type, func_name);
    }
    if expr.type == ASTNodeType.AST_ASM_TARGET {
        return exec_lower_make_int_const_expr(ctx, expr, &expr_type, exec_lower_host_asm_target_value() as i64);
    }
    if expr.type == ASTNodeType.AST_INT_LIMIT {
        var int_limit_ok: i32 = 0;
        const int_limit_value: i64 = exec_lower_eval_int_limit(expr, expr_type.kind, &int_limit_ok);
        if int_limit_ok == 0 {
            return exec_lower_fail_expr(expr, "exec: @max/@min 尚未解析为可表示的整数类型" as *byte);
        }
        return exec_lower_make_int_const_expr(ctx, expr, &expr_type, int_limit_value);
    }
    if expr.type == ASTNodeType.AST_NUMBER {
        if expr_type.kind != TypeKind.TYPE_I8 &&
            expr_type.kind != TypeKind.TYPE_I16 &&
            expr_type.kind != TypeKind.TYPE_I32 &&
            expr_type.kind != TypeKind.TYPE_U32 &&
            expr_type.kind != TypeKind.TYPE_I64 &&
            expr_type.kind != TypeKind.TYPE_U64 &&
            expr_type.kind != TypeKind.TYPE_U8 &&
            expr_type.kind != TypeKind.TYPE_U16 &&
            expr_type.kind != TypeKind.TYPE_USIZE {
            return exec_lower_fail_expr(expr, "exec: 仅支持 exec VM 可表示的整数数字字面量" as *byte);
        }
        return exec_lower_make_int_const_expr(ctx, expr, &expr_type, expr.number_value_i64);
    }
    if expr.type == ASTNodeType.AST_FLOAT {
        if expr_type.kind != TypeKind.TYPE_F32 && expr_type.kind != TypeKind.TYPE_F64 {
            return exec_lower_fail_expr(expr, "exec: 当前仅支持 f32/f64 浮点字面量" as *byte);
        }
        return exec_lower_make_float_const_expr(ctx, expr, &expr_type, expr.float_literal_value);
    }
    if expr.type == ASTNodeType.AST_BOOL {
        const hir: &HIRExpr = exec_lower_alloc_expr(ctx, expr, HIRExprKind.HIR_EXPR_CONST, &expr_type);
        if hir == null {
            return null;
        }
        hir.bool_value = expr.bool_literal_value;
        return hir;
    }
    if expr.type == ASTNodeType.AST_CHAR {
        const hir: &HIRExpr = exec_lower_alloc_expr(ctx, expr, HIRExprKind.HIR_EXPR_CONST, &expr_type);
        if hir == null {
            return null;
        }
        hir.int_value = expr.char_literal_value as i64;
        return hir;
    }
    if expr.type == ASTNodeType.AST_STRING {
        return exec_lower_make_string_const_expr(ctx, expr, &expr_type, expr.string_literal_value);
    }
    if expr.type == ASTNodeType.AST_STRING_INTERP {
        return exec_lower_fail_expr_reason(expr, "exec: 当前不支持字符串插值" as *byte, ExecUnsupportedReason.EXEC_UNSUPPORTED_STRING_INTERP);
    }
    if expr.type == ASTNodeType.AST_ERROR_VALUE {
        return exec_lower_make_int_const_expr(ctx, expr, &expr_type, expr_type.error_error_id as i64);
    }
    if expr.type == ASTNodeType.AST_IDENTIFIER {
        if expr.identifier_name != null &&
            str_equals(expr.identifier_name, "null" as &byte) != 0 {
            var null_type: Type = copy_type(&expr_type);
            if null_type.kind != TypeKind.TYPE_POINTER {
                null_type = exec_lower_make_void_pointer_type();
            }
            return exec_lower_make_int_const_expr(ctx, expr, &null_type, 0);
        }
        const slot: i32 = exec_lower_find_slot(ctx, expr.identifier_name);
        if slot >= 0 {
            var local_type: Type = copy_type(&expr_type);
            if slot >= 0 && slot < EXEC_MAX_LOCALS {
                local_type = ctx.slot_types[slot];
            }
            const hir_local: &HIRExpr = exec_lower_alloc_expr(ctx, expr, HIRExprKind.HIR_EXPR_LOCAL, &local_type);
            if hir_local == null {
                return null;
            }
            hir_local.local_slot = slot;
            return hir_local;
        }
        var imported_global_decl: &ASTNode = exec_lower_resolve_global_decl(ctx.checker, expr.identifier_name);
        if imported_global_decl == null && expr.filename != null {
            imported_global_decl = exec_lower_resolve_imported_decl_from_file(ctx.checker, expr.filename, expr.identifier_name, 10);
        }
        if imported_global_decl == null && expr.filename != null {
            imported_global_decl = exec_lower_resolve_module_self_named_global_from_file(ctx.checker, expr.filename, expr.identifier_name);
        }
        if imported_global_decl != null {
            const global_slot_by_decl: i32 = exec_lower_find_global_slot_by_decl(ctx, imported_global_decl);
            var resolved_global_slot_by_decl: i32 = global_slot_by_decl;
            if resolved_global_slot_by_decl < 0 && expr.identifier_name != null {
                resolved_global_slot_by_decl = exec_lower_find_global_slot(ctx, expr.identifier_name);
            }
            if resolved_global_slot_by_decl >= 0 {
                var global_type_by_decl: Type = copy_type(&expr_type);
                if resolved_global_slot_by_decl >= 0 && resolved_global_slot_by_decl < EXEC_MAX_GLOBALS {
                    global_type_by_decl = ctx.global_types[resolved_global_slot_by_decl];
                }
                const hir_global_by_decl: &HIRExpr = exec_lower_alloc_expr(ctx, expr, HIRExprKind.HIR_EXPR_GLOBAL, &global_type_by_decl);
                if hir_global_by_decl == null {
                    return null;
                }
                hir_global_by_decl.global_slot = resolved_global_slot_by_decl;
                return hir_global_by_decl;
            }
            if exec_lower_global_is_const(imported_global_decl) != 0 {
                const const_init_expr: &ASTNode = exec_lower_global_init_ast(imported_global_decl);
                if const_init_expr != null && const_init_expr != expr {
                    return exec_lower_expr(ctx, const_init_expr);
                }
            }
            if imported_global_decl != null {
                const global_type_ast2: &ASTNode = exec_lower_global_type_ast(imported_global_decl);
                if global_type_ast2 != null {
                    const global_type2: Type = type_from_ast(ctx.checker, global_type_ast2);
                    if exec_type_is_vm_value_supported(global_type2) == 0 {
                        if exec_type_uses_simd(global_type2) != 0 {
                            return exec_lower_fail_expr_reason(expr, "exec: 当前不支持 SIMD 全局变量" as *byte, ExecUnsupportedReason.EXEC_UNSUPPORTED_SIMD);
                        }
                        return exec_lower_fail_expr(expr, "exec: 当前仅支持 exec VM 可表示的全局变量" as *byte);
                    }
                }
            }
        }
        const global_slot: i32 = exec_lower_find_global_slot(ctx, expr.identifier_name);
        if global_slot >= 0 {
            var global_type: Type = copy_type(&expr_type);
            if global_slot >= 0 && global_slot < EXEC_MAX_GLOBALS {
                global_type = ctx.global_types[global_slot];
            }
            const hir_global: &HIRExpr = exec_lower_alloc_expr(ctx, expr, HIRExprKind.HIR_EXPR_GLOBAL, &global_type);
            if hir_global == null {
                return null;
            }
            hir_global.global_slot = global_slot;
            return hir_global;
        }
        return exec_lower_fail_expr(expr, "exec: 当前仅支持局部变量/参数/全局标识符" as *byte);
    }
    if expr.type == ASTNodeType.AST_MEMBER_ACCESS {
        var enum_found: i32 = 0;
        const enum_value: i32 = exec_lower_try_enum_member_const(ctx, expr, &enum_found);
        if enum_found != 0 {
            return exec_lower_make_int_const_expr(ctx, expr, &expr_type, enum_value as i64);
        }
    }
    if expr.type == ASTNodeType.AST_CAST_EXPR {
        if expr.cast_expr_is_force_cast != 0 {
            if expr.cast_expr_expr != null &&
                expr.cast_expr_expr.type == ASTNodeType.AST_SYSCALL &&
                expr_type.kind == TypeKind.TYPE_ERROR_UNION &&
                expr_type.error_union_payload_type != null {
                const syscall_payload_type: Type = expr_type.error_union_payload_type[0];
                if exec_type_is_vm_value_supported(syscall_payload_type) == 0 {
                    return exec_lower_fail_expr(expr, "exec: @syscall as! 目标类型当前不可被 exec VM 表示" as *byte);
                }
                if expr.cast_expr_expr.syscall_number == null {
                    return exec_lower_fail_expr(expr, "exec: @syscall 缺少系统调用号" as *byte);
                }
                const syscall_nr_expr: &HIRExpr = exec_lower_expr(ctx, expr.cast_expr_expr.syscall_number);
                if syscall_nr_expr == null {
                    return null;
                }
                const syscall_args_hir: & & HIRExpr = exec_lower_alloc_items(ctx, expr.cast_expr_expr.syscall_arg_count);
                if expr.cast_expr_expr.syscall_arg_count > 0 && syscall_args_hir == null {
                    exec_backend_set_error(expr, "exec: @syscall 参数分配失败" as *byte, 0);
                    return null;
                }
                var si: i32 = 0;
                while si < expr.cast_expr_expr.syscall_arg_count {
                    const lowered_arg: &HIRExpr = exec_lower_expr(ctx, expr.cast_expr_expr.syscall_args[si]);
                    if lowered_arg == null {
                        return null;
                    }
                    syscall_args_hir[si] = lowered_arg;
                    si = si + 1;
                }
                const hir_syscall_cast: &HIRExpr = exec_lower_alloc_expr(ctx, expr, HIRExprKind.HIR_EXPR_SYSCALL, &expr_type);
                if hir_syscall_cast == null {
                    return null;
                }
                hir_syscall_cast.left = syscall_nr_expr;
                hir_syscall_cast.items = syscall_args_hir;
                hir_syscall_cast.item_count = expr.cast_expr_expr.syscall_arg_count;
                hir_syscall_cast.int_value = syscall_payload_type.kind as i64;
                hir_syscall_cast.unary_op = exec_lower_pointer_pointee_kind(&syscall_payload_type);
                return hir_syscall_cast;
            }
            if expr_type.kind != TypeKind.TYPE_ERROR_UNION || expr_type.error_union_payload_type == null {
                return exec_lower_fail_expr_reason(expr, "exec: as! 目标类型无效" as *byte, ExecUnsupportedReason.EXEC_UNSUPPORTED_GENERIC);
            }
            const force_payload_type: Type = expr_type.error_union_payload_type[0];
            if exec_type_is_vm_value_supported(force_payload_type) == 0 {
                return exec_lower_fail_expr(expr, "exec: as! 载荷类型当前不可被 exec VM 表示" as *byte);
            }
            const force_payload_expr: &HIRExpr = exec_lower_coerce_expr(ctx, expr.cast_expr_expr, &force_payload_type);
            if force_payload_expr == null {
                return null;
            }
            const hir_force_ok: &HIRExpr = exec_lower_alloc_expr(ctx, expr, HIRExprKind.HIR_EXPR_MAKE_OK, &expr_type);
            if hir_force_ok == null {
                return null;
            }
            hir_force_ok.left = force_payload_expr;
            return hir_force_ok;
        }
        if exec_type_is_vm_value_supported(expr_type) == 0 {
            return exec_lower_fail_expr(expr, "exec: cast 目标类型当前不可被 exec VM 表示" as *byte);
        }
        const cast_operand: &HIRExpr = exec_lower_expr(ctx, expr.cast_expr_expr);
        if cast_operand == null {
            return null;
        }
        const hir_cast: &HIRExpr = exec_lower_alloc_expr(ctx, expr, HIRExprKind.HIR_EXPR_CAST, &expr_type);
        if hir_cast == null {
            return null;
        }
        hir_cast.left = cast_operand;
        return hir_cast;
    }
    if expr.type == ASTNodeType.AST_PTR_FROM_USIZE {
        const ptr_operand: &HIRExpr = exec_lower_expr(ctx, expr.ptr_from_usize_value);
        if ptr_operand == null {
            return null;
        }
        const hir_ptr: &HIRExpr = exec_lower_alloc_expr(ctx, expr, HIRExprKind.HIR_EXPR_CAST, &expr_type);
        if hir_ptr == null {
            return null;
        }
        hir_ptr.left = ptr_operand;
        return hir_ptr;
    }
    if expr.type == ASTNodeType.AST_USIZE_FROM_PTR {
        const usize_operand: &HIRExpr = exec_lower_expr(ctx, expr.usize_from_ptr_ptr);
        if usize_operand == null {
            return null;
        }
        const hir_usize: &HIRExpr = exec_lower_alloc_expr(ctx, expr, HIRExprKind.HIR_EXPR_CAST, &expr_type);
        if hir_usize == null {
            return null;
        }
        hir_usize.left = usize_operand;
        return hir_usize;
    }
    if expr.type == ASTNodeType.AST_UNARY_EXPR {
        if (expr.unary_expr_op as TokenType) == TokenType.TOKEN_AMPERSAND {
            return exec_lower_make_ref_expr(ctx, expr.unary_expr_operand);
        }
        if (expr.unary_expr_op as TokenType) == TokenType.TOKEN_ASTERISK {
            const base_expr: &HIRExpr = exec_lower_expr(ctx, expr.unary_expr_operand);
            const zero_index_type: Type = make_i32_type();
            const zero_index_expr: &HIRExpr = exec_lower_make_int_const_expr(ctx, expr, &zero_index_type, 0);
            if base_expr == null || zero_index_expr == null {
                return null;
            }
            const deref_expr: &HIRExpr = exec_lower_alloc_expr(ctx, expr, HIRExprKind.HIR_EXPR_INDEX, &expr_type);
            if deref_expr == null {
                return null;
            }
            deref_expr.left = base_expr;
            deref_expr.right = zero_index_expr;
            return deref_expr;
        }
        if exec_type_is_scalar_supported(expr_type) == 0 {
            if exec_type_uses_simd(expr_type) != 0 {
                return exec_lower_fail_expr_reason(expr, "exec: 当前不支持 SIMD" as *byte, ExecUnsupportedReason.EXEC_UNSUPPORTED_SIMD);
            }
            return exec_lower_fail_expr(expr, "exec: 不支持的 unary 结果类型" as *byte);
        }
        const operand: &HIRExpr = exec_lower_expr(ctx, expr.unary_expr_operand);
        if operand == null {
            return null;
        }
        const hir: &HIRExpr = exec_lower_alloc_expr(ctx, expr, HIRExprKind.HIR_EXPR_UNARY, &expr_type);
        if hir == null {
            return null;
        }
        hir.unary_op = expr.unary_expr_op;
        hir.left = operand;
        return hir;
    }
    if expr.type == ASTNodeType.AST_BINARY_EXPR {
        if exec_type_is_scalar_supported(expr_type) == 0 &&
            expr_type.kind != TypeKind.TYPE_BOOL {
            if exec_type_uses_simd(expr_type) != 0 {
                return exec_lower_fail_expr_reason(expr, "exec: 当前不支持 SIMD" as *byte, ExecUnsupportedReason.EXEC_UNSUPPORTED_SIMD);
            }
            return exec_lower_fail_expr(expr, "exec: 不支持的 binary 结果类型" as *byte);
        }
        const left: &HIRExpr = exec_lower_expr(ctx, expr.binary_expr_left);
        if left == null {
            return null;
        }
        const right: &HIRExpr = exec_lower_expr(ctx, expr.binary_expr_right);
        if right == null {
            return null;
        }
        const hir: &HIRExpr = exec_lower_alloc_expr(ctx, expr, HIRExprKind.HIR_EXPR_BINARY, &expr_type);
        if hir == null {
            return null;
        }
        hir.binary_op = expr.binary_expr_op;
        hir.left = left;
        hir.right = right;
        return hir;
    }
    if expr.type == ASTNodeType.AST_CALL_EXPR {
        const union_ctor: &HIRExpr = exec_lower_try_union_ctor_expr(ctx, expr, &expr_type);
        if union_ctor != null {
            return union_ctor;
        }
        if expr.call_expr_type_arg_count > 0 || expr.call_expr_has_ellipsis_forward != 0 {
            return exec_lower_fail_expr(expr, "exec: 当前不支持泛型调用或 varargs 转发" as *byte);
        }
        if expr.call_expr_arg_count > EXEC_MAX_CALL_ARGS {
            return exec_lower_fail_expr(expr, "exec: 调用参数过多" as *byte);
        }
        if exec_type_is_vm_value_supported(expr_type) == 0 {
            if exec_type_uses_simd(expr_type) != 0 {
                return exec_lower_fail_expr_reason(expr, "exec: 当前不支持 SIMD" as *byte, ExecUnsupportedReason.EXEC_UNSUPPORTED_SIMD);
            }
            return exec_lower_fail_expr(expr, "exec: 当前仅支持标量/错误联合函数返回值" as *byte);
        }
        if expr.call_expr_callee != null && expr.call_expr_callee.type == ASTNodeType.AST_MEMBER_ACCESS &&
            expr.call_expr_callee.member_access_object != null &&
            expr.call_expr_callee.member_access_field_name != null {
            const object_ast: &ASTNode = expr.call_expr_callee.member_access_object;
            const method_name: &byte = expr.call_expr_callee.member_access_field_name;
            const owner_type: Type = exec_lower_member_base_type(ctx, object_ast);
            if owner_type.kind == TypeKind.TYPE_INTERFACE && owner_type.interface_name != null {
                const method_sig: &ASTNode = find_interface_method_sig(ctx.checker.program_node, owner_type.interface_name, method_name);
                const method_index: i32 = exec_lower_interface_method_index(ctx, &owner_type, method_name);
                if method_sig == null || method_index < 0 {
                    return exec_lower_fail_expr(expr, "exec: 无法解析 interface 方法调用" as *byte);
                }
                if expr.call_expr_arg_count + 1 > EXEC_MAX_CALL_ARGS {
                    return exec_lower_fail_expr(expr, "exec: interface 方法调用参数过多" as *byte);
                }
                const args_iface: & & HIRExpr = compiler_arena_alloc(ctx.arena, @size_of(&HIRExpr) * expr.call_expr_arg_count as usize) as & & HIRExpr;
                if expr.call_expr_arg_count > 0 && args_iface == null {
                    exec_backend_set_error(expr, "exec: interface 调用参数分配失败" as *byte, 0);
                    return null;
                }
                var ia: i32 = 0;
                while ia < expr.call_expr_arg_count {
                    var lowered_arg_iface: &HIRExpr = null;
                    if method_sig.fn_decl_params != null && ia + 1 < method_sig.fn_decl_param_count &&
                        method_sig.fn_decl_params[ia + 1] != null &&
                        method_sig.fn_decl_params[ia + 1].type == ASTNodeType.AST_VAR_DECL &&
                        method_sig.fn_decl_params[ia + 1].var_decl_type != null {
                        const expected_iface: Type = type_from_ast(ctx.checker, method_sig.fn_decl_params[ia + 1].var_decl_type);
                        lowered_arg_iface = exec_lower_coerce_expr(ctx, expr.call_expr_args[ia], &expected_iface);
                    } else {
                        lowered_arg_iface = exec_lower_expr(ctx, expr.call_expr_args[ia]);
                    }
                    if lowered_arg_iface == null {
                        return null;
                    }
                    args_iface[ia] = lowered_arg_iface;
                    ia = ia + 1;
                }
                const object_expr: &HIRExpr = exec_lower_expr(ctx, object_ast);
                if object_expr == null {
                    return null;
                }
                var iface_method_sigs: [&ASTNode: EXEC_MAX_INTERFACE_METHODS] = [];
                var iface_method_count: i32 = 0;
                if exec_lower_collect_interface_method_sigs(ctx, &owner_type, &iface_method_sigs[0] as & & ASTNode, &iface_method_count) != 0 {
                    return exec_lower_fail_expr(expr, "exec: interface 方法表索引计算失败" as *byte);
                }
                const iface_call: &HIRExpr = exec_lower_alloc_expr(ctx, expr, HIRExprKind.HIR_EXPR_IMETHOD_CALL, &expr_type);
                if iface_call == null {
                    return null;
                }
                iface_call.left = object_expr;
                iface_call.int_value = method_index as i64;
                iface_call.callee_name = method_name;
                iface_call.call_args = args_iface;
                iface_call.call_arg_count = expr.call_expr_arg_count;
                iface_call.callee_decl = method_sig;
                iface_call.dispatch_decl_count = iface_method_count;
                return iface_call;
            }
            var method_decl: &ASTNode = null;
            if owner_type.kind == TypeKind.TYPE_STRUCT && owner_type.struct_name != null {
                method_decl = find_instance_method_in_struct(ctx.checker.program_node, owner_type.struct_name, method_name);
            } else if owner_type.kind == TypeKind.TYPE_UNION && owner_type.union_name != null {
                method_decl = find_instance_method_in_union(ctx.checker.program_node, owner_type.union_name, method_name);
            }
            if method_decl != null {
                const total_arg_count: i32 = expr.call_expr_arg_count + 1;
                if total_arg_count > EXEC_MAX_CALL_ARGS {
                    return exec_lower_fail_expr(expr, "exec: 方法调用参数过多" as *byte);
                }
                const args_method: & & HIRExpr = compiler_arena_alloc(ctx.arena, @size_of(&HIRExpr) * total_arg_count as usize) as & & HIRExpr;
                if total_arg_count > 0 && args_method == null {
                    exec_backend_set_error(expr, "exec: 方法调用参数分配失败" as *byte, 0);
                    return null;
                }
                const receiver_arg: &HIRExpr = exec_lower_method_receiver_expr(ctx, object_ast, method_decl);
                if receiver_arg == null {
                    return exec_lower_fail_expr(expr, "exec: 当前无法为方法 receiver 构造引用" as *byte);
                }
                args_method[0] = receiver_arg;
                var ma: i32 = 0;
                while ma < expr.call_expr_arg_count {
                    var lowered_arg_method: &HIRExpr = null;
                    if method_decl.fn_decl_params != null && ma + 1 < method_decl.fn_decl_param_count &&
                        method_decl.fn_decl_params[ma + 1] != null &&
                        method_decl.fn_decl_params[ma + 1].type == ASTNodeType.AST_VAR_DECL &&
                        method_decl.fn_decl_params[ma + 1].var_decl_type != null {
                        const expected_method: Type = type_from_ast(ctx.checker, method_decl.fn_decl_params[ma + 1].var_decl_type);
                        lowered_arg_method = exec_lower_coerce_expr(ctx, expr.call_expr_args[ma], &expected_method);
                    } else {
                        lowered_arg_method = exec_lower_expr(ctx, expr.call_expr_args[ma]);
                    }
                    if lowered_arg_method == null {
                        return null;
                    }
                    args_method[ma + 1] = lowered_arg_method;
                    ma = ma + 1;
                }
                const call_method: &HIRExpr = exec_lower_alloc_expr(ctx, expr, HIRExprKind.HIR_EXPR_CALL, &expr_type);
                if call_method == null {
                    return null;
                }
                call_method.callee_name = method_decl.fn_decl_name;
                call_method.callee_decl = method_decl;
                call_method.call_host_id = ExecHostCallId.EXEC_HOST_CALL_NONE;
                call_method.call_args = args_method;
                call_method.call_arg_count = total_arg_count;
                return call_method;
            }
            var method_msg: [byte: 160] = [];
            _ = snprintf(&method_msg[0] as *byte, 160, "exec: 无法解析成员方法调用(kind=%d)" as *byte, owner_type.kind as i32);
            return exec_lower_fail_expr(expr, &method_msg[0]);
        }
        if expr.call_expr_callee == null || expr.call_expr_callee.type != ASTNodeType.AST_IDENTIFIER {
            return exec_lower_fail_expr(expr, "exec: 当前仅支持直接函数调用" as *byte);
        }
        const callee_decl: &ASTNode = exec_lower_resolve_function_decl_from_file(ctx.checker, expr.filename, expr.call_expr_callee.identifier_name);
        var host_call_id: ExecHostCallId = ExecHostCallId.EXEC_HOST_CALL_NONE;
        if callee_decl != null &&
            callee_decl.type == ASTNodeType.AST_FN_DECL &&
            callee_decl.fn_decl_is_extern != 0 {
            const extern_can_run: i32 = exec_lower_extern_can_run_in_vm(ctx.checker, callee_decl);
            const matched_host_call: ExecHostCallId = exec_lower_match_host_call(callee_decl, expr.call_expr_arg_count);
            if extern_can_run == 0 || exec_lower_host_call_overrides_body(callee_decl, matched_host_call) != 0 {
                host_call_id = matched_host_call;
            }
            if host_call_id == ExecHostCallId.EXEC_HOST_CALL_NONE &&
                extern_can_run == 0 {
                var extern_msg: [byte: 160] = [];
                if callee_decl.fn_decl_name != null {
                    _ = snprintf(&extern_msg[0] as *byte, 160, "exec: 当前不支持 extern ABI: %s/%d" as *byte,
                        callee_decl.fn_decl_name as *byte, callee_decl.fn_decl_param_count);
                    return exec_lower_fail_expr_reason(expr, &extern_msg[0], ExecUnsupportedReason.EXEC_UNSUPPORTED_EXTERN_ABI);
                }
                return exec_lower_fail_expr_reason(expr, "exec: 当前不支持 extern ABI" as *byte, ExecUnsupportedReason.EXEC_UNSUPPORTED_EXTERN_ABI);
            }
        }
        const args: & & HIRExpr = compiler_arena_alloc(ctx.arena, @size_of(&HIRExpr) * expr.call_expr_arg_count as usize) as & & HIRExpr;
        if expr.call_expr_arg_count > 0 && args == null {
            exec_backend_set_error(expr, "exec: 调用参数分配失败" as *byte, 0);
            return null;
        }
        var i: i32 = 0;
        while i < expr.call_expr_arg_count {
            var arg_expr: &HIRExpr = null;
            if callee_decl != null && callee_decl.type == ASTNodeType.AST_FN_DECL &&
                callee_decl.fn_decl_params != null && i < callee_decl.fn_decl_param_count &&
                callee_decl.fn_decl_params[i] != null &&
                callee_decl.fn_decl_params[i].type == ASTNodeType.AST_VAR_DECL &&
                callee_decl.fn_decl_params[i].var_decl_type != null {
                const expected_type: Type = type_from_ast(ctx.checker, callee_decl.fn_decl_params[i].var_decl_type);
                arg_expr = exec_lower_coerce_expr(ctx, expr.call_expr_args[i], &expected_type);
            } else {
                arg_expr = exec_lower_expr(ctx, expr.call_expr_args[i]);
            }
            if arg_expr == null {
                return null;
            }
            args[i] = arg_expr;
            i = i + 1;
        }
        const hir: &HIRExpr = exec_lower_alloc_expr(ctx, expr, HIRExprKind.HIR_EXPR_CALL, &expr_type);
        if hir == null {
            return null;
        }
        hir.callee_name = expr.call_expr_callee.identifier_name;
        hir.callee_decl = callee_decl;
        hir.call_host_id = host_call_id;
        hir.call_args = args;
        hir.call_arg_count = expr.call_expr_arg_count;
        return hir;
    }
    if expr.type == ASTNodeType.AST_SYSCALL {
        if expr.syscall_number == null {
            return exec_lower_fail_expr(expr, "exec: @syscall 缺少系统调用号" as *byte);
        }
        const nr_expr: &HIRExpr = exec_lower_expr(ctx, expr.syscall_number);
        if nr_expr == null {
            return null;
        }
        const syscall_args_exprs: & & HIRExpr = exec_lower_alloc_items(ctx, expr.syscall_arg_count);
        if expr.syscall_arg_count > 0 && syscall_args_exprs == null {
            exec_backend_set_error(expr, "exec: @syscall 参数分配失败" as *byte, 0);
            return null;
        }
        var sci: i32 = 0;
        while sci < expr.syscall_arg_count {
            const lowered_arg2: &HIRExpr = exec_lower_expr(ctx, expr.syscall_args[sci]);
            if lowered_arg2 == null {
                return null;
            }
            syscall_args_exprs[sci] = lowered_arg2;
            sci = sci + 1;
        }
        const hir_syscall: &HIRExpr = exec_lower_alloc_expr(ctx, expr, HIRExprKind.HIR_EXPR_SYSCALL, &expr_type);
        if hir_syscall == null {
            return null;
        }
        hir_syscall.left = nr_expr;
        hir_syscall.items = syscall_args_exprs;
        hir_syscall.item_count = expr.syscall_arg_count;
        hir_syscall.int_value = TypeKind.TYPE_I64 as i64;
        hir_syscall.unary_op = TypeKind.TYPE_VOID as i32;
        return hir_syscall;
    }
    if expr.type == ASTNodeType.AST_LEN {
        const known_len: i32 = exec_lower_known_len_for_expr(ctx, expr.len_expr_array);
        if known_len >= 0 {
            return exec_lower_make_int_const_expr(ctx, expr, &expr_type, known_len as i64);
        }
        const inner_len: &HIRExpr = exec_lower_expr(ctx, expr.len_expr_array);
        if inner_len == null {
            return null;
        }
        const hir_len: &HIRExpr = exec_lower_alloc_expr(ctx, expr, HIRExprKind.HIR_EXPR_LEN, &expr_type);
        if hir_len == null {
            return null;
        }
        hir_len.left = inner_len;
        return hir_len;
    }
    if expr.type == ASTNodeType.AST_STRUCT_INIT {
        if expr.struct_init_struct_name != null &&
            str_equals(expr.struct_init_struct_name, "va_list" as *byte) != 0 {
            var va_list_type: Type = copy_type(&expr_type);
            va_list_type.kind = TypeKind.TYPE_VA_LIST;
            va_list_type.struct_name = null;
            return exec_lower_make_zero_expr(ctx, expr, &va_list_type);
        }
        if expr.struct_init_struct_name == null {
            return exec_lower_fail_expr(expr, "exec: 结构体字面量不完整" as *byte);
        }
        const struct_decl: &ASTNode = find_struct_decl_from_program(ctx.checker.program_node, expr.struct_init_struct_name);
        if struct_decl == null || struct_decl.struct_decl_fields == null {
            return exec_lower_fail_expr(expr, "exec: 无法解析结构体声明" as *byte);
        }
        const items: & & HIRExpr = exec_lower_alloc_items(ctx, struct_decl.struct_decl_field_count);
        if struct_decl.struct_decl_field_count > 0 && items == null {
            exec_backend_set_error(expr, "exec: struct items 分配失败" as *byte, 0);
            return null;
        }
        var fi: i32 = 0;
        while fi < struct_decl.struct_decl_field_count {
            const field_decl: &ASTNode = struct_decl.struct_decl_fields[fi];
            if field_decl == null || field_decl.var_decl_name == null {
                return exec_lower_fail_expr(expr, "exec: 结构体字段声明异常" as *byte);
            }
            var src_idx: i32 = -1;
            var ej: i32 = 0;
            while ej < expr.struct_init_field_count {
                if expr.struct_init_field_names[ej] != null &&
                    str_equals(expr.struct_init_field_names[ej], field_decl.var_decl_name) != 0 {
                    src_idx = ej;
                    break;
                }
                ej = ej + 1;
            }
            if src_idx < 0 {
                if field_decl.var_decl_type == null {
                    return exec_lower_fail_expr(expr, "exec: 结构体字面量字段缺失且字段类型未知" as *byte);
                }
                const missing_field_type: Type = type_from_ast(ctx.checker, field_decl.var_decl_type);
                const zero_field_expr: &HIRExpr = exec_lower_make_zero_expr(ctx, field_decl, &missing_field_type);
                if zero_field_expr == null {
                    return null;
                }
                items[fi] = zero_field_expr;
                fi = fi + 1;
                continue;
            }
            var field_expr: &HIRExpr = null;
            if field_decl.var_decl_type != null {
                const expected_field_type: Type = type_from_ast(ctx.checker, field_decl.var_decl_type);
                field_expr = exec_lower_coerce_expr(ctx, expr.struct_init_field_values[src_idx], &expected_field_type);
            } else {
                field_expr = exec_lower_expr(ctx, expr.struct_init_field_values[src_idx]);
            }
            if field_expr == null {
                return null;
            }
            items[fi] = field_expr;
            fi = fi + 1;
        }
        const hir_struct: &HIRExpr = exec_lower_alloc_expr(ctx, expr, HIRExprKind.HIR_EXPR_STRUCT_INIT, &expr_type);
        if hir_struct == null {
            return null;
        }
        hir_struct.items = items;
        hir_struct.item_count = struct_decl.struct_decl_field_count;
        return hir_struct;
    }
    if expr.type == ASTNodeType.AST_ARRAY_LITERAL {
        if expr.array_literal_repeat_count_expr != null {
            return exec_lower_make_repeat_array_init_expr(ctx, expr, &expr_type);
        }
        if expr.array_literal_element_count == 0 {
            return exec_lower_make_zero_expr(ctx, expr, &expr_type);
        }
        const items2: & & HIRExpr = exec_lower_expr_list(ctx, expr.array_literal_elements, expr.array_literal_element_count);
        if expr.array_literal_element_count > 0 && items2 == null {
            return null;
        }
        const hir_array: &HIRExpr = exec_lower_alloc_expr(ctx, expr, HIRExprKind.HIR_EXPR_ARRAY_INIT, &expr_type);
        if hir_array == null {
            return null;
        }
        hir_array.items = items2;
        hir_array.item_count = expr.array_literal_element_count;
        return hir_array;
    }
    if expr.type == ASTNodeType.AST_TUPLE_LITERAL {
        const items3: & & HIRExpr = exec_lower_expr_list(ctx, expr.tuple_literal_elements, expr.tuple_literal_element_count);
        if expr.tuple_literal_element_count > 0 && items3 == null {
            return null;
        }
        const hir_tuple: &HIRExpr = exec_lower_alloc_expr(ctx, expr, HIRExprKind.HIR_EXPR_TUPLE_INIT, &expr_type);
        if hir_tuple == null {
            return null;
        }
        hir_tuple.items = items3;
        hir_tuple.item_count = expr.tuple_literal_element_count;
        return hir_tuple;
    }
    if expr.type == ASTNodeType.AST_VA_START {
        const ap_ref_start: &HIRExpr = exec_lower_make_va_storage_ref_expr(ctx, expr.va_start_ap);
        if ap_ref_start == null {
            return null;
        }
        const hir_va_start: &HIRExpr = exec_lower_alloc_expr(ctx, expr, HIRExprKind.HIR_EXPR_VA_START, &expr_type);
        if hir_va_start == null {
            return null;
        }
        hir_va_start.left = ap_ref_start;
        return hir_va_start;
    }
    if expr.type == ASTNodeType.AST_VA_END {
        const ap_ref_end: &HIRExpr = exec_lower_make_va_storage_ref_expr(ctx, expr.va_end_ap);
        if ap_ref_end == null {
            return null;
        }
        const hir_va_end: &HIRExpr = exec_lower_alloc_expr(ctx, expr, HIRExprKind.HIR_EXPR_VA_END, &expr_type);
        if hir_va_end == null {
            return null;
        }
        hir_va_end.left = ap_ref_end;
        return hir_va_end;
    }
    if expr.type == ASTNodeType.AST_VA_ARG {
        if exec_type_is_vm_value_supported(expr_type) == 0 {
            return exec_lower_fail_expr(expr, "exec: @va_arg 目标类型当前不可被 exec VM 表示" as *byte);
        }
        const ap_ref_arg: &HIRExpr = exec_lower_make_va_storage_ref_expr(ctx, expr.va_arg_ap);
        if ap_ref_arg == null {
            return null;
        }
        const hir_va_arg: &HIRExpr = exec_lower_alloc_expr(ctx, expr, HIRExprKind.HIR_EXPR_VA_ARG, &expr_type);
        if hir_va_arg == null {
            return null;
        }
        hir_va_arg.left = ap_ref_arg;
        return hir_va_arg;
    }
    if expr.type == ASTNodeType.AST_VA_COPY {
        const dest_ref_copy: &HIRExpr = exec_lower_make_va_storage_ref_expr(ctx, expr.va_copy_dest);
        const src_ref_copy: &HIRExpr = exec_lower_make_va_storage_ref_expr(ctx, expr.va_copy_src);
        if dest_ref_copy == null || src_ref_copy == null {
            return null;
        }
        const hir_va_copy: &HIRExpr = exec_lower_alloc_expr(ctx, expr, HIRExprKind.HIR_EXPR_VA_COPY, &expr_type);
        if hir_va_copy == null {
            return null;
        }
        hir_va_copy.left = dest_ref_copy;
        hir_va_copy.right = src_ref_copy;
        return hir_va_copy;
    }
    if expr.type == ASTNodeType.AST_MEMBER_ACCESS {
        var module_access_name: &byte = null;
        if expr.member_access_object != null &&
            expr.member_access_object.type == ASTNodeType.AST_IDENTIFIER &&
            expr.member_access_object.identifier_name != null {
            const shadowed_local_slot: i32 = exec_lower_find_slot(ctx, expr.member_access_object.identifier_name);
            const shadowed_global_slot: i32 = exec_lower_find_global_slot(ctx, expr.member_access_object.identifier_name);
            if shadowed_local_slot < 0 && shadowed_global_slot < 0 {
                module_access_name = exec_lower_resolve_member_access_module_name(ctx.checker, expr);
            }
        } else {
            module_access_name = exec_lower_resolve_member_access_module_name(ctx.checker, expr);
        }
        if module_access_name != null && expr.member_access_field_name != null {
            const module_global_decl: &ASTNode = exec_lower_find_module_export_decl(
                ctx.checker, module_access_name, expr.member_access_field_name, 0);
            if module_global_decl != null {
                const module_global_slot: i32 = exec_lower_find_global_slot_by_decl(ctx, module_global_decl);
                var resolved_module_global_slot: i32 = module_global_slot;
                if resolved_module_global_slot < 0 && expr.member_access_field_name != null {
                    resolved_module_global_slot = exec_lower_find_global_slot(ctx, expr.member_access_field_name);
                }
                if resolved_module_global_slot >= 0 {
                    var module_global_type: Type = copy_type(&expr_type);
                    if resolved_module_global_slot >= 0 && resolved_module_global_slot < EXEC_MAX_GLOBALS {
                        module_global_type = ctx.global_types[resolved_module_global_slot];
                    }
                    const hir_module_global: &HIRExpr = exec_lower_alloc_expr(ctx, expr, HIRExprKind.HIR_EXPR_GLOBAL, &module_global_type);
                    if hir_module_global == null {
                        return null;
                    }
                    hir_module_global.global_slot = resolved_module_global_slot;
                    return hir_module_global;
                }
                if expr.member_access_field_name != null {
                    var slot_msg: [byte: 192] = [];
                    _ = snprintf(&slot_msg[0] as *byte, 192, "exec: 模块导出全局已解析但未找到 slot: %s.%s" as *byte,
                        module_access_name as *byte, expr.member_access_field_name as *byte);
                    return exec_lower_fail_expr(expr, &slot_msg[0]);
                }
                if exec_lower_global_is_const(module_global_decl) != 0 {
                    const module_const_init: &ASTNode = exec_lower_global_init_ast(module_global_decl);
                    if module_const_init != null && module_const_init != expr {
                        return exec_lower_expr(ctx, module_const_init);
                    }
                }
                const module_global_type_ast: &ASTNode = exec_lower_global_type_ast(module_global_decl);
                if module_global_type_ast != null {
                    const module_decl_type: Type = type_from_ast(ctx.checker, module_global_type_ast);
                    if exec_type_is_vm_value_supported(module_decl_type) == 0 {
                        if exec_type_uses_simd(module_decl_type) != 0 {
                            return exec_lower_fail_expr_reason(expr, "exec: 当前不支持 SIMD 全局变量" as *byte, ExecUnsupportedReason.EXEC_UNSUPPORTED_SIMD);
                        }
                        return exec_lower_fail_expr(expr, "exec: 当前仅支持 exec VM 可表示的全局变量" as *byte);
                    }
                }
            } else {
                var missing_msg: [byte: 192] = [];
                _ = snprintf(&missing_msg[0] as *byte, 192, "exec: 无法解析模块导出全局: %s.%s" as *byte,
                    module_access_name as *byte, expr.member_access_field_name as *byte);
                return exec_lower_fail_expr(expr, &missing_msg[0]);
            }
        }
        const base_expr: &HIRExpr = exec_lower_expr(ctx, expr.member_access_object);
        var base_type: Type = exec_lower_member_base_type(ctx, expr.member_access_object);
        const base_raw_type: Type = exec_lower_expr_type(ctx, expr.member_access_object);
        if base_type.kind == TypeKind.TYPE_VOID &&
            expr.member_access_object.type == ASTNodeType.AST_ARRAY_ACCESS &&
            expr.member_access_object.array_access_array != null {
            const array_type: Type = exec_lower_resolve_exact_type(ctx, expr.member_access_object.array_access_array);
            if array_type.kind == TypeKind.TYPE_ARRAY && array_type.element_type != null {
                base_type = array_type.element_type[0];
            } else if array_type.kind == TypeKind.TYPE_SLICE && array_type.slice_element_type != null {
                base_type = array_type.slice_element_type[0];
            } else if array_type.kind == TypeKind.TYPE_POINTER && array_type.pointer_to != null {
                const pointed_type: Type = array_type.pointer_to[0];
                if pointed_type.kind == TypeKind.TYPE_ARRAY && pointed_type.element_type != null {
                    base_type = pointed_type.element_type[0];
                } else {
                    base_type = pointed_type;
                }
            }
        }
        if base_expr == null {
            return null;
        }
        if expr.member_access_field_name == null {
            return exec_lower_fail_expr(expr, "exec: 成员访问缺少字段名" as *byte);
        }
        if base_raw_type.kind != TypeKind.TYPE_POINTER &&
            (base_type.kind == TypeKind.TYPE_ERROR_UNION || base_type.kind == TypeKind.TYPE_ERROR) &&
            str_equals(expr.member_access_field_name, "error_id" as *byte) != 0 {
            const hir_error_id_field: &HIRExpr = exec_lower_alloc_expr(ctx, expr, HIRExprKind.HIR_EXPR_ERROR_ID, &expr_type);
            if hir_error_id_field == null {
                return null;
            }
            hir_error_id_field.left = base_expr;
            return hir_error_id_field;
        }
        if base_raw_type.kind != TypeKind.TYPE_POINTER &&
            base_type.kind == TypeKind.TYPE_ERROR_UNION &&
            str_equals(expr.member_access_field_name, "value" as *byte) != 0 &&
            base_type.error_union_payload_type != null {
            const hir_error_value_field: &HIRExpr = exec_lower_alloc_expr(ctx, expr, HIRExprKind.HIR_EXPR_TRY, &expr_type);
            if hir_error_value_field == null {
                return null;
            }
            hir_error_value_field.left = base_expr;
            return hir_error_value_field;
        }
        if base_type.kind == TypeKind.TYPE_SLICE {
            if expr.member_access_field_name != null && str_equals(expr.member_access_field_name, "len" as *byte) != 0 {
                const hir_slice_len: &HIRExpr = exec_lower_alloc_expr(ctx, expr, HIRExprKind.HIR_EXPR_LEN, &expr_type);
                if hir_slice_len == null {
                    return null;
                }
                hir_slice_len.left = base_expr;
                return hir_slice_len;
            }
            if expr.member_access_field_name != null && str_equals(expr.member_access_field_name, "ptr" as *byte) != 0 {
                var slice_ptr_type: Type = copy_type(&expr_type);
                if (slice_ptr_type.kind != TypeKind.TYPE_POINTER || slice_ptr_type.pointer_to == null) &&
                    base_type.slice_element_type != null {
                    slice_ptr_type = exec_lower_make_pointer_type_copy(ctx, base_type.slice_element_type[0]);
                }
                const hir_slice_ptr: &HIRExpr = exec_lower_alloc_expr(ctx, expr, HIRExprKind.HIR_EXPR_SLICE_PTR, &slice_ptr_type);
                if hir_slice_ptr == null {
                    return null;
                }
                hir_slice_ptr.left = base_expr;
                return hir_slice_ptr;
            }
            return exec_lower_fail_expr(expr, "exec: 当前不支持该 slice 成员访问" as *byte);
        }
        if base_type.kind == TypeKind.TYPE_POINTER && base_type.pointer_to != null {
            base_type = base_type.pointer_to[0];
        }
        var field_index: i32 = -1;
        if base_type.kind == TypeKind.TYPE_TUPLE {
            field_index = atoi(expr.member_access_field_name as *byte);
        } else {
            field_index = exec_lower_struct_field_index(ctx, copy_type(&base_type), expr.member_access_field_name);
        }
        if field_index < 0 {
            var member_msg: [byte: 192] = [];
            const base_kind: TypeKind = base_type.kind;
            const base_type_copy: Type = copy_type(&base_type);
            const base_struct_name: &byte = type_get_struct_name(&base_type_copy);
            if base_struct_name != null {
                _ = snprintf(&member_msg[0] as *byte, 192, "exec: 无法解析成员访问字段: %s.%s" as *byte,
                    base_struct_name as *byte, expr.member_access_field_name as *byte);
            } else {
                _ = snprintf(&member_msg[0] as *byte, 192, "exec: 无法解析成员访问字段(kind=%d): %s" as *byte,
                    base_kind as i32, expr.member_access_field_name as *byte);
            }
            return exec_lower_fail_expr(expr, &member_msg[0]);
        }
        const hir_field: &HIRExpr = exec_lower_alloc_expr(ctx, expr, HIRExprKind.HIR_EXPR_FIELD, &expr_type);
        if hir_field == null {
            return null;
        }
        hir_field.left = base_expr;
        hir_field.int_value = field_index as i64;
        return hir_field;
    }
    if expr.type == ASTNodeType.AST_ARRAY_ACCESS {
        const base_expr2: &HIRExpr = exec_lower_expr(ctx, expr.array_access_array);
        const index_expr: &HIRExpr = exec_lower_expr(ctx, expr.array_access_index);
        if base_expr2 == null || index_expr == null {
            return null;
        }
        const hir_index: &HIRExpr = exec_lower_alloc_expr(ctx, expr, HIRExprKind.HIR_EXPR_INDEX, &expr_type);
        if hir_index == null {
            return null;
        }
        hir_index.left = base_expr2;
        hir_index.right = index_expr;
        return hir_index;
    }
    if expr.type == ASTNodeType.AST_SLICE_EXPR {
        const base_expr3: &HIRExpr = exec_lower_expr(ctx, expr.slice_expr_base);
        const start_expr: &HIRExpr = exec_lower_expr(ctx, expr.slice_expr_start_expr);
        const len_expr: &HIRExpr = exec_lower_expr(ctx, expr.slice_expr_len_expr);
        if base_expr3 == null || start_expr == null || len_expr == null {
            return null;
        }
        const hir_slice: &HIRExpr = exec_lower_alloc_expr(ctx, expr, HIRExprKind.HIR_EXPR_SLICE, &expr_type);
        if hir_slice == null {
            return null;
        }
        hir_slice.left = base_expr3;
        hir_slice.right = start_expr;
        hir_slice.extra = len_expr;
        return hir_slice;
    }
    if expr.type == ASTNodeType.AST_PRINT || expr.type == ASTNodeType.AST_PRINTLN {
        const inner: &HIRExpr = exec_lower_expr(ctx, expr.print_expr);
        if inner == null {
            return null;
        }
        const hir: &HIRExpr = exec_lower_alloc_expr(ctx, expr,
            HIRExprKind.HIR_EXPR_PRINT,
            &expr_type);
        if hir == null {
            return null;
        }
        if expr.type == ASTNodeType.AST_PRINTLN {
            hir.kind = HIRExprKind.HIR_EXPR_PRINTLN;
        }
        hir.left = inner;
        return hir;
    }
    if expr.type == ASTNodeType.AST_ERROR_ID {
        const operand_literal: &ASTNode = exec_lower_named_error_literal(expr.error_id_operand);
        if operand_literal != null {
            const literal_type: Type = exec_lower_expr_type(ctx, operand_literal);
            return exec_lower_make_int_const_expr(ctx, expr, &expr_type, literal_type.error_error_id as i64);
        }
        const operand_error_id: &HIRExpr = exec_lower_expr(ctx, expr.error_id_operand);
        if operand_error_id == null {
            return null;
        }
        const hir_error_id: &HIRExpr = exec_lower_alloc_expr(ctx, expr, HIRExprKind.HIR_EXPR_ERROR_ID, &expr_type);
        if hir_error_id == null {
            return null;
        }
        hir_error_id.left = operand_error_id;
        return hir_error_id;
    }
    if expr.type == ASTNodeType.AST_ERROR_NAME {
        const operand_name_literal: &ASTNode = exec_lower_named_error_literal(expr.error_name_operand);
        if operand_name_literal != null {
            return exec_lower_make_string_const_expr(ctx, expr, &expr_type, operand_name_literal.error_value_name);
        }
        const operand_error_name: &HIRExpr = exec_lower_expr(ctx, expr.error_name_operand);
        if operand_error_name == null {
            return null;
        }
        const hir_error_name: &HIRExpr = exec_lower_alloc_expr(ctx, expr, HIRExprKind.HIR_EXPR_ERROR_NAME, &expr_type);
        if hir_error_name == null {
            return null;
        }
        hir_error_name.left = operand_error_name;
        return hir_error_name;
    }
    if expr.type == ASTNodeType.AST_TRY_EXPR {
        const operand: &HIRExpr = exec_lower_expr(ctx, expr.try_expr_operand);
        if operand == null {
            return null;
        }
        if operand.type_ref.type.kind != TypeKind.TYPE_ERROR_UNION {
            return exec_lower_fail_expr_reason(expr, "exec: try 操作数不是错误联合" as *byte, ExecUnsupportedReason.EXEC_UNSUPPORTED_TRY_EXPR);
        }
        const hir_try: &HIRExpr = exec_lower_alloc_expr(ctx, expr, HIRExprKind.HIR_EXPR_TRY, &expr_type);
        if hir_try == null {
            return null;
        }
        hir_try.left = operand;
        return hir_try;
    }
    if expr.type == ASTNodeType.AST_CATCH_EXPR {
        if expr.catch_expr_err_name != null {
            return exec_lower_fail_expr_reason(expr, "exec: 当前不支持带错误绑定的 catch" as *byte, ExecUnsupportedReason.EXEC_UNSUPPORTED_CATCH_EXPR);
        }
        const operand2: &HIRExpr = exec_lower_expr(ctx, expr.catch_expr_operand);
        if operand2 == null {
            return null;
        }
        if operand2.type_ref.type.kind != TypeKind.TYPE_ERROR_UNION {
            return exec_lower_fail_expr_reason(expr, "exec: catch 操作数不是错误联合" as *byte, ExecUnsupportedReason.EXEC_UNSUPPORTED_CATCH_EXPR);
        }
        const hir_catch: &HIRExpr = exec_lower_alloc_expr(ctx, expr, HIRExprKind.HIR_EXPR_CATCH, &expr_type);
        if hir_catch == null {
            return null;
        }
        hir_catch.left = operand2;
        const catch_block: &ASTNode = expr.catch_expr_catch_block;
        const catch_last_stmt: &ASTNode = exec_lower_block_last_stmt(catch_block);
        if catch_last_stmt == null {
            return exec_lower_fail_expr_reason(expr, "exec: catch 分支块为空" as *byte, ExecUnsupportedReason.EXEC_UNSUPPORTED_CATCH_EXPR);
        }
        if expr_type.kind == TypeKind.TYPE_VOID && catch_last_stmt.type != ASTNodeType.AST_RETURN_STMT {
            hir_catch.block = exec_lower_block(ctx, catch_block);
            if hir_catch.block == null {
                return null;
            }
            hir_catch.right = exec_lower_make_zero_expr(ctx, catch_block, &expr_type);
            if hir_catch.right == null {
                return null;
            }
            return hir_catch;
        }
        hir_catch.block = exec_lower_make_block_prefix(ctx, catch_block);
        if catch_last_stmt.type == ASTNodeType.AST_RETURN_STMT {
            const return_stmt: &ASTNode = catch_last_stmt;
            if return_stmt.return_stmt_expr != null {
                if ctx.function_decl != null && ctx.function_decl.fn_decl_return_type != null {
                    const catch_return_type: Type = type_from_ast(ctx.checker, ctx.function_decl.fn_decl_return_type);
                    hir_catch.extra = exec_lower_coerce_expr(ctx, return_stmt.return_stmt_expr, &catch_return_type);
                } else {
                    hir_catch.extra = exec_lower_expr(ctx, return_stmt.return_stmt_expr);
                }
                if hir_catch.extra == null {
                    return null;
                }
            }
            return hir_catch;
        }
        const fallback_expr: &HIRExpr = exec_lower_expr(ctx, catch_last_stmt);
        if fallback_expr == null {
            return null;
        }
        hir_catch.right = fallback_expr;
        return hir_catch;
    }
    if expr.type == ASTNodeType.AST_MATCH_EXPR {
        if expr.match_expr_expr == null || expr.match_expr_arms == null || expr.match_expr_arm_count <= 0 {
            return exec_lower_fail_expr_reason(expr, "exec: match 结构无效" as *byte, ExecUnsupportedReason.EXEC_UNSUPPORTED_MATCH_EXPR);
        }
        const subject_expr: &HIRExpr = exec_lower_expr(ctx, expr.match_expr_expr);
        if subject_expr == null {
            return null;
        }
        var subject_type: Type = exec_lower_resolve_exact_type(ctx, expr.match_expr_expr);
        if subject_type.kind == TypeKind.TYPE_VOID {
            subject_type = subject_expr.type_ref.type;
        }
        if subject_type.kind == TypeKind.TYPE_UNION {
            const arms_union: &HIRMatchArm = compiler_arena_alloc(ctx.arena, @size_of(HIRMatchArm) * expr.match_expr_arm_count as usize) as &HIRMatchArm;
            if arms_union == null {
                exec_backend_set_error(expr, "exec: union match arms 分配失败" as *byte, 0);
                return null;
            }
            var umi: i32 = 0;
            while umi < expr.match_expr_arm_count {
                const arm_union: ASTMatchArm = expr.match_expr_arms[umi];
                if arm_union.kind != MatchPatternKind.MATCH_PAT_UNION &&
                    arm_union.kind != MatchPatternKind.MATCH_PAT_ELSE &&
                    arm_union.kind != MatchPatternKind.MATCH_PAT_WILDCARD {
                    return exec_lower_fail_expr_reason(expr, "exec: 当前仅支持 union/else/wildcard match" as *byte, ExecUnsupportedReason.EXEC_UNSUPPORTED_MATCH_EXPR);
                }
                var bind_slot: i32 = -1;
                var arm_result_expr2: &HIRExpr = null;
                var variant_index2: i32 = -1;
                if arm_union.kind == MatchPatternKind.MATCH_PAT_UNION {
                    variant_index2 = exec_lower_union_variant_index(ctx, copy_type(&subject_type), arm_union.variant_name);
                    if variant_index2 < 0 {
                        return exec_lower_fail_expr_reason(expr, "exec: union match 变体无效" as *byte, ExecUnsupportedReason.EXEC_UNSUPPORTED_MATCH_EXPR);
                    }
                    exec_lower_push_scope(ctx, -1);
                    if arm_union.var_name != null && str_equals(arm_union.var_name, "_" as *byte) == 0 {
                        const bind_type: Type = exec_lower_union_variant_type(ctx, copy_type(&subject_type), arm_union.variant_name);
                        if exec_type_is_vm_value_supported(bind_type) == 0 {
                            exec_lower_pop_scope(ctx);
                            return exec_lower_fail_expr_reason(expr, "exec: union match 绑定类型当前不可表示" as *byte, ExecUnsupportedReason.EXEC_UNSUPPORTED_MATCH_EXPR);
                        }
                        bind_slot = exec_lower_append_local(ctx, null, arm_union.var_name, &bind_type, 0);
                        if bind_slot < 0 {
                            exec_lower_pop_scope(ctx);
                            exec_backend_set_error(expr, "exec: union match 绑定槽位不足" as *byte, 0);
                            return null;
                        }
                    }
                    if arm_union.result_is_block != 0 {
                        arm_result_expr2 = exec_lower_extract_block_result_expr(ctx, arm_union.result_expr);
                    } else {
                        arm_result_expr2 = exec_lower_expr(ctx, arm_union.result_expr);
                    }
                    exec_lower_pop_scope(ctx);
                } else {
                    if arm_union.result_is_block != 0 {
                        arm_result_expr2 = exec_lower_extract_block_result_expr(ctx, arm_union.result_expr);
                    } else {
                        arm_result_expr2 = exec_lower_expr(ctx, arm_union.result_expr);
                    }
                }
                if arm_result_expr2 == null {
                    return null;
                }
                arms_union[umi] = HIRMatchArm {
                    kind: arm_union.kind,
                    int_value: variant_index2 as i64,
                    bool_value: 0,
                    bind_local_slot: bind_slot,
                    result_expr: arm_result_expr2,
                };
                umi = umi + 1;
            }
            const hir_union_match: &HIRExpr = exec_lower_alloc_expr(ctx, expr, HIRExprKind.HIR_EXPR_MATCH, &expr_type);
            if hir_union_match == null {
                return null;
            }
            hir_union_match.left = subject_expr;
            hir_union_match.match_arms = arms_union;
            hir_union_match.match_arm_count = expr.match_expr_arm_count;
            return hir_union_match;
        }
        if exec_type_is_scalar_supported(subject_type) == 0 {
            return exec_lower_fail_expr_reason(expr, "exec: 当前仅支持标量 match" as *byte, ExecUnsupportedReason.EXEC_UNSUPPORTED_MATCH_EXPR);
        }
        const arms: &HIRMatchArm = compiler_arena_alloc(ctx.arena, @size_of(HIRMatchArm) * expr.match_expr_arm_count as usize) as &HIRMatchArm;
        if arms == null {
            exec_backend_set_error(expr, "exec: match arms 分配失败" as *byte, 0);
            return null;
        }
        var mi: i32 = 0;
        while mi < expr.match_expr_arm_count {
            const arm: ASTMatchArm = expr.match_expr_arms[mi];
            if arm.kind != MatchPatternKind.MATCH_PAT_LITERAL &&
                arm.kind != MatchPatternKind.MATCH_PAT_ELSE &&
                arm.kind != MatchPatternKind.MATCH_PAT_WILDCARD {
                return exec_lower_fail_expr_reason(expr, "exec: 当前仅支持 literal/else/wildcard match" as *byte, ExecUnsupportedReason.EXEC_UNSUPPORTED_MATCH_EXPR);
            }
            var arm_result_expr: &HIRExpr = null;
            if arm.result_is_block != 0 {
                arm_result_expr = exec_lower_extract_block_result_expr(ctx, arm.result_expr);
            } else {
                arm_result_expr = exec_lower_expr(ctx, arm.result_expr);
            }
            if arm_result_expr == null {
                return null;
            }
            arms[mi] = HIRMatchArm {
                kind: arm.kind,
                int_value: arm.literal_int_value as i64,
                bool_value: arm.literal_is_bool,
                bind_local_slot: -1,
                result_expr: arm_result_expr,
            };
            mi = mi + 1;
        }
        const hir_match: &HIRExpr = exec_lower_alloc_expr(ctx, expr, HIRExprKind.HIR_EXPR_MATCH, &expr_type);
        if hir_match == null {
            return null;
        }
        hir_match.left = subject_expr;
        hir_match.match_arms = arms;
        hir_match.match_arm_count = expr.match_expr_arm_count;
        return hir_match;
    }
    if expr.type == ASTNodeType.AST_ASM {
        return exec_lower_fail_expr_reason(expr, "exec: 当前不支持 inline asm" as *byte, ExecUnsupportedReason.EXEC_UNSUPPORTED_ASM);
    }
    return exec_lower_fail_expr(expr, "exec: 尚未支持的表达式节点" as *byte);
}

fn exec_lower_block(ctx: &ExecLowerContext, block: &ASTNode) &HIRBlock {
    if ctx == null || block == null || block.type != ASTNodeType.AST_BLOCK {
        exec_backend_set_error(block, "exec: block lowering 失败" as *byte, 0);
        return null;
    }
    const hir_block: &HIRBlock = exec_lower_alloc_scoped_block(ctx, block, block.block_stmt_count);
    if hir_block == null {
        return null;
    }
    exec_lower_push_scope(ctx, hir_block.scope_id);
    var i: i32 = 0;
    while i < block.block_stmt_count {
        const stmt_node: &ASTNode = block.block_stmts[i];
        var stmt: &HIRStmt = null;
        if stmt_node.type == ASTNodeType.AST_VAR_DECL {
            if stmt_node.var_decl_init == null {
                exec_lower_pop_scope(ctx);
                return exec_lower_fail_block(stmt_node, "exec: 当前不支持未初始化局部变量" as *byte);
            }
            var local_type: Type = make_void_type();
            if stmt_node.var_decl_type != null {
                local_type = type_from_ast(ctx.checker, stmt_node.var_decl_type);
            } else {
                local_type = exec_lower_expr_type(ctx, stmt_node.var_decl_init);
            }
            if exec_type_is_vm_value_supported(local_type) == 0 {
                exec_lower_pop_scope(ctx);
                if exec_type_uses_simd(local_type) != 0 {
                    return exec_lower_fail_block_reason(stmt_node, "exec: 当前不支持 SIMD" as *byte, ExecUnsupportedReason.EXEC_UNSUPPORTED_SIMD);
                }
                return exec_lower_fail_block(stmt_node, "exec: 当前仅支持 exec VM 可表示的局部变量" as *byte);
            }
            const slot: i32 = exec_lower_append_local(ctx, stmt_node, stmt_node.var_decl_name, &local_type, 0);
            if slot < 0 {
                exec_lower_pop_scope(ctx);
                exec_backend_set_error(stmt_node, "exec: 局部变量槽位不足" as *byte, 0);
                return null;
            }
            const init_expr: &HIRExpr = exec_lower_coerce_expr(ctx, stmt_node.var_decl_init, &local_type);
            if init_expr == null {
                exec_lower_pop_scope(ctx);
                return null;
            }
            stmt = exec_lower_alloc_stmt(ctx, stmt_node, HIRStmtKind.HIR_STMT_VAR_INIT);
            if stmt == null {
                exec_lower_pop_scope(ctx);
                return null;
            }
            stmt.local_slot = slot;
            stmt.expr = init_expr;
        } else if stmt_node.type == ASTNodeType.AST_ASSIGN {
            if stmt_node.assign_dest != null && stmt_node.assign_dest.type == ASTNodeType.AST_UNDERSCORE {
                // `_ = expr;` keeps RHS side effects and explicitly discards the value.
                const discard_expr: &HIRExpr = exec_lower_expr(ctx, stmt_node.assign_src);
                if discard_expr == null {
                    exec_lower_pop_scope(ctx);
                    return null;
                }
                stmt = exec_lower_alloc_stmt(ctx, stmt_node, HIRStmtKind.HIR_STMT_EXPR);
                if stmt == null {
                    exec_lower_pop_scope(ctx);
                    return null;
                }
                stmt.expr = discard_expr;
            } else {
                const assign_target: &HIRExpr = exec_lower_make_dest_expr(ctx, stmt_node.assign_dest);
                if assign_target == null {
                    exec_lower_pop_scope(ctx);
                    return null;
                }
                const value_expr: &HIRExpr = exec_lower_coerce_expr(ctx, stmt_node.assign_src, &assign_target.type_ref.type);
                if value_expr == null {
                    exec_lower_pop_scope(ctx);
                    return null;
                }
                stmt = exec_lower_alloc_stmt(ctx, stmt_node, HIRStmtKind.HIR_STMT_ASSIGN);
                if stmt == null {
                    exec_lower_pop_scope(ctx);
                    return null;
                }
                if assign_target.kind == HIRExprKind.HIR_EXPR_LOCAL {
                    stmt.local_slot = assign_target.local_slot;
                }
                stmt.assign_target = assign_target;
                stmt.assign_expr = value_expr;
            }
        } else if stmt_node.type == ASTNodeType.AST_CALL_EXPR ||
            stmt_node.type == ASTNodeType.AST_PRINT ||
            stmt_node.type == ASTNodeType.AST_PRINTLN ||
            stmt_node.type == ASTNodeType.AST_VA_START ||
            stmt_node.type == ASTNodeType.AST_VA_END ||
            stmt_node.type == ASTNodeType.AST_VA_ARG ||
            stmt_node.type == ASTNodeType.AST_VA_COPY ||
            stmt_node.type == ASTNodeType.AST_BINARY_EXPR ||
            stmt_node.type == ASTNodeType.AST_UNARY_EXPR ||
            stmt_node.type == ASTNodeType.AST_IDENTIFIER ||
            stmt_node.type == ASTNodeType.AST_MEMBER_ACCESS ||
            stmt_node.type == ASTNodeType.AST_ARRAY_ACCESS ||
            stmt_node.type == ASTNodeType.AST_SLICE_EXPR ||
            stmt_node.type == ASTNodeType.AST_STRUCT_INIT ||
            stmt_node.type == ASTNodeType.AST_ARRAY_LITERAL ||
            stmt_node.type == ASTNodeType.AST_TUPLE_LITERAL ||
            stmt_node.type == ASTNodeType.AST_SIZEOF ||
            stmt_node.type == ASTNodeType.AST_LEN ||
            stmt_node.type == ASTNodeType.AST_ALIGNOF ||
            stmt_node.type == ASTNodeType.AST_SRC_NAME ||
            stmt_node.type == ASTNodeType.AST_SRC_PATH ||
            stmt_node.type == ASTNodeType.AST_SRC_LINE ||
            stmt_node.type == ASTNodeType.AST_SRC_COL ||
            stmt_node.type == ASTNodeType.AST_FUNC_NAME ||
            stmt_node.type == ASTNodeType.AST_ERROR_ID ||
            stmt_node.type == ASTNodeType.AST_ERROR_NAME ||
            stmt_node.type == ASTNodeType.AST_TRY_EXPR ||
            stmt_node.type == ASTNodeType.AST_CATCH_EXPR {
            const expr_stmt: &HIRExpr = exec_lower_expr(ctx, stmt_node);
            if expr_stmt == null {
                exec_lower_pop_scope(ctx);
                return null;
            }
            stmt = exec_lower_alloc_stmt(ctx, stmt_node, HIRStmtKind.HIR_STMT_EXPR);
            if stmt == null {
                exec_lower_pop_scope(ctx);
                return null;
            }
            stmt.expr = expr_stmt;
        } else if stmt_node.type == ASTNodeType.AST_DEFER_STMT || stmt_node.type == ASTNodeType.AST_ERRDEFER_STMT {
            var cleanup_body: &ASTNode = stmt_node.defer_stmt_body;
            var cleanup_kind: HIRStmtKind = HIRStmtKind.HIR_STMT_DEFER;
            if stmt_node.type == ASTNodeType.AST_ERRDEFER_STMT {
                cleanup_body = stmt_node.errdefer_stmt_body;
                cleanup_kind = HIRStmtKind.HIR_STMT_ERRDEFER;
            }
            if cleanup_body == null {
                exec_lower_pop_scope(ctx);
                return exec_lower_fail_block(stmt_node, "exec: defer/errdefer body 为空" as *byte);
            }
            const cleanup_block: &HIRBlock = exec_lower_wrap_stmt_node_as_block(ctx, cleanup_body);
            if cleanup_block == null {
                exec_lower_pop_scope(ctx);
                return null;
            }
            stmt = exec_lower_alloc_stmt(ctx, stmt_node, cleanup_kind);
            if stmt == null {
                exec_lower_pop_scope(ctx);
                return null;
            }
            stmt.cleanup_block = cleanup_block;
        } else if stmt_node.type == ASTNodeType.AST_IF_STMT {
            const cond_expr: &HIRExpr = exec_lower_expr(ctx, stmt_node.if_stmt_condition);
            if cond_expr == null {
                exec_lower_pop_scope(ctx);
                return null;
            }
            const then_block: &HIRBlock = exec_lower_block(ctx, stmt_node.if_stmt_then_branch);
            if then_block == null {
                exec_lower_pop_scope(ctx);
                return null;
            }
            var else_block: &HIRBlock = null;
            if stmt_node.if_stmt_else_branch != null {
                if stmt_node.if_stmt_else_branch.type == ASTNodeType.AST_BLOCK {
                    else_block = exec_lower_block(ctx, stmt_node.if_stmt_else_branch);
                    if else_block == null {
                        exec_lower_pop_scope(ctx);
                        return null;
                    }
                } else if stmt_node.if_stmt_else_branch.type == ASTNodeType.AST_IF_STMT {
                    else_block = exec_lower_wrap_stmt_node_as_block(ctx, stmt_node.if_stmt_else_branch);
                    if else_block == null {
                        exec_lower_pop_scope(ctx);
                        return null;
                    }
                } else {
                    exec_lower_pop_scope(ctx);
                    return exec_lower_fail_block(stmt_node, "exec: 当前仅支持 block/else-if" as *byte);
                }
            }
            stmt = exec_lower_alloc_stmt(ctx, stmt_node, HIRStmtKind.HIR_STMT_IF);
            if stmt == null {
                exec_lower_pop_scope(ctx);
                return null;
            }
            stmt.expr = cond_expr;
            stmt.then_block = then_block;
            stmt.else_block = else_block;
        } else if stmt_node.type == ASTNodeType.AST_WHILE_STMT {
            const loop_body: &HIRBlock = exec_lower_alloc_scoped_block(ctx, stmt_node, 1);
            if loop_body == null {
                exec_lower_pop_scope(ctx);
                exec_backend_set_error(stmt_node, "exec: loop body 分配失败" as *byte, 0);
                return null;
            }
            const cond_stmt: &HIRStmt = exec_lower_alloc_stmt(ctx, stmt_node, HIRStmtKind.HIR_STMT_IF);
            const cond_expr: &HIRExpr = exec_lower_expr(ctx, stmt_node.while_stmt_condition);
            const body_block: &HIRBlock = exec_lower_block(ctx, stmt_node.while_stmt_body);
            if cond_stmt == null || cond_expr == null || body_block == null {
                exec_lower_pop_scope(ctx);
                return null;
            }
            const break_block: &HIRBlock = exec_lower_alloc_scoped_block(ctx, stmt_node, 1);
            const break_stmt: &HIRStmt = exec_lower_alloc_stmt(ctx, stmt_node, HIRStmtKind.HIR_STMT_BREAK);
            if break_block == null || break_stmt == null {
                exec_lower_pop_scope(ctx);
                exec_backend_set_error(stmt_node, "exec: while break block 分配失败" as *byte, 0);
                return null;
            }
            break_block.stmts[1] = break_stmt;
            cond_stmt.expr = cond_expr;
            cond_stmt.then_block = body_block;
            cond_stmt.else_block = break_block;
            loop_body.stmts[1] = cond_stmt;
            stmt = exec_lower_alloc_stmt(ctx, stmt_node, HIRStmtKind.HIR_STMT_LOOP);
            if stmt == null {
                exec_lower_pop_scope(ctx);
                return null;
            }
            stmt.loop_body = loop_body;
        } else if stmt_node.type == ASTNodeType.AST_FOR_STMT {
            stmt = exec_lower_make_for_range_stmt(ctx, stmt_node);
            if stmt == null {
                exec_lower_pop_scope(ctx);
                return null;
            }
        } else if stmt_node.type == ASTNodeType.AST_BREAK_STMT {
            stmt = exec_lower_alloc_stmt(ctx, stmt_node, HIRStmtKind.HIR_STMT_BREAK);
        } else if stmt_node.type == ASTNodeType.AST_CONTINUE_STMT {
            stmt = exec_lower_alloc_stmt(ctx, stmt_node, HIRStmtKind.HIR_STMT_CONTINUE);
        } else if stmt_node.type == ASTNodeType.AST_RETURN_STMT {
            stmt = exec_lower_alloc_stmt(ctx, stmt_node, HIRStmtKind.HIR_STMT_RETURN);
            if stmt == null {
                exec_lower_pop_scope(ctx);
                return null;
            }
            if stmt_node.return_stmt_expr != null {
                if ctx.function_decl != null && ctx.function_decl.fn_decl_return_type != null {
                    const return_type: Type = type_from_ast(ctx.checker, ctx.function_decl.fn_decl_return_type);
                    stmt.expr = exec_lower_coerce_expr(ctx, stmt_node.return_stmt_expr, &return_type);
                    if stmt.expr == null {
                        exec_lower_pop_scope(ctx);
                        return null;
                    }
                    if return_type.kind != TypeKind.TYPE_ERROR_UNION &&
                        type_equals(stmt.expr.type_ref.type, return_type) == 0 &&
                        exec_type_is_vm_value_supported(return_type) != 0 {
                        const cast_return: &HIRExpr = exec_lower_alloc_expr(ctx, stmt_node.return_stmt_expr, HIRExprKind.HIR_EXPR_CAST, &return_type);
                        if cast_return == null {
                            exec_lower_pop_scope(ctx);
                            return null;
                        }
                        cast_return.left = stmt.expr;
                        stmt.expr = cast_return;
                    }
                } else {
                    stmt.expr = exec_lower_expr(ctx, stmt_node.return_stmt_expr);
                    if stmt.expr == null {
                        exec_lower_pop_scope(ctx);
                        return null;
                    }
                }
            } else if ctx.function_decl != null && ctx.function_decl.fn_decl_return_type != null {
                const bare_return_type: Type = type_from_ast(ctx.checker, ctx.function_decl.fn_decl_return_type);
                if bare_return_type.kind == TypeKind.TYPE_ERROR_UNION &&
                    bare_return_type.error_union_payload_type != null &&
                    bare_return_type.error_union_payload_type[0].kind == TypeKind.TYPE_VOID {
                    stmt.expr = exec_lower_make_zero_expr(ctx, stmt_node, &bare_return_type.error_union_payload_type[0]);
                    if stmt.expr == null {
                        exec_lower_pop_scope(ctx);
                        return null;
                    }
                }
            }
        } else if stmt_node.type == ASTNodeType.AST_BLOCK {
            const nested_block: &HIRBlock = exec_lower_block(ctx, stmt_node);
            if nested_block == null {
                exec_lower_pop_scope(ctx);
                return null;
            }
            const nested_stmt: &HIRStmt = exec_lower_wrap_block_as_stmt(ctx, stmt_node, nested_block);
            if nested_stmt == null {
                exec_lower_pop_scope(ctx);
                return null;
            }
            stmt = nested_stmt;
        } else if stmt_node.type == ASTNodeType.AST_MATCH_EXPR {
            stmt = exec_lower_try_make_returning_match_stmt(ctx, stmt_node);
            if stmt == null {
                const expr_stmt: &HIRExpr = exec_lower_expr(ctx, stmt_node);
                if expr_stmt == null {
                    exec_lower_pop_scope(ctx);
                    return null;
                }
                stmt = exec_lower_alloc_stmt(ctx, stmt_node, HIRStmtKind.HIR_STMT_EXPR);
                if stmt == null {
                    exec_lower_pop_scope(ctx);
                    return null;
                }
                stmt.expr = expr_stmt;
            }
        } else {
            exec_lower_pop_scope(ctx);
            if stmt_node.type == ASTNodeType.AST_TEST_STMT {
                return exec_lower_fail_block(stmt_node, "exec: 当前不支持 test 语句" as *byte);
            }
            return exec_lower_fail_block(stmt_node, "exec: 尚未支持的语句节点" as *byte);
        }
        if stmt == null {
            exec_lower_pop_scope(ctx);
            return null;
        }
        hir_block.stmts[i + 1] = stmt;
        i = i + 1;
    }
    exec_lower_pop_scope(ctx);
    return hir_block;
}

fn exec_lower_function(arena: &CompilerArena, checker: &TypeChecker, fn_decl: &ASTNode, globals: &HIRGlobalSlot, global_count: i32) &HIRFunction {
    if arena == null || checker == null || fn_decl == null || fn_decl.type != ASTNodeType.AST_FN_DECL {
        return null;
    }
    if fn_decl.fn_decl_is_async != 0 {
        exec_lower_set_unsupported_reason(fn_decl, "exec: 当前不支持 async" as *byte, ExecUnsupportedReason.EXEC_UNSUPPORTED_ASYNC);
        return null;
    }
    if fn_decl.fn_decl_is_extern != 0 && exec_lower_extern_can_run_in_vm(checker, fn_decl) == 0 {
        exec_lower_set_unsupported_reason(fn_decl, "exec: 当前不支持 extern ABI" as *byte, ExecUnsupportedReason.EXEC_UNSUPPORTED_EXTERN_ABI);
        return null;
    }
    const saved_self_type_name: &byte = checker.current_self_type_name;
    const saved_self_is_union: i32 = checker.current_self_is_union;
    var owner_is_union: i32 = 0;
    const owner_type_name: &byte = checker_fn_decl_owner_type_name(checker, fn_decl, &owner_is_union);
    if owner_type_name != null {
        checker.current_self_type_name = owner_type_name;
        checker.current_self_is_union = owner_is_union;
    }
    const return_type: Type = type_from_ast(checker, fn_decl.fn_decl_return_type);
    if exec_type_is_vm_value_supported(return_type) == 0 {
        checker.current_self_type_name = saved_self_type_name;
        checker.current_self_is_union = saved_self_is_union;
        if exec_type_uses_simd(return_type) != 0 {
            exec_lower_set_unsupported_reason(fn_decl, "exec: 当前不支持 SIMD" as *byte, ExecUnsupportedReason.EXEC_UNSUPPORTED_SIMD);
            return null;
        }
        exec_lower_set_unsupported(fn_decl, "exec: 当前仅支持标量/错误联合/void 返回值" as *byte);
        return null;
    }
    var ctx: ExecLowerContext = ExecLowerContext {
        arena: arena,
        checker: checker,
        function_decl: fn_decl,
        global_names: [],
        global_decls: [],
        global_types: [],
        global_is_const: [],
        global_count: 0,
        local_names: [],
        local_slots: [],
        local_types: [],
        local_is_param: [],
        slot_names: [],
        slot_decls: [],
        slot_types: [],
        slot_is_param: [],
        slot_scope_ids: [],
        slot_needs_drop: [],
        slot_drop_decls: [],
        active_local_count: 0,
        next_slot: 0,
        max_slot_count: 0,
        next_scope_id: 0,
        scope_markers: [],
        scope_ids: [],
        scope_depth: 0,
    };
    exec_lower_seed_globals(&ctx, globals, global_count);
    var i: i32 = 0;
    while i < fn_decl.fn_decl_param_count {
        const param: &ASTNode = fn_decl.fn_decl_params[i];
        if param == null || param.type != ASTNodeType.AST_VAR_DECL {
            checker.current_self_type_name = saved_self_type_name;
            checker.current_self_is_union = saved_self_is_union;
            exec_lower_set_unsupported(fn_decl, "exec: 参数节点异常" as *byte);
            return null;
        }
        const param_type: Type = type_from_ast(checker, param.var_decl_type);
        if exec_type_is_vm_value_supported(param_type) == 0 {
            checker.current_self_type_name = saved_self_type_name;
            checker.current_self_is_union = saved_self_is_union;
            if exec_type_uses_simd(param_type) != 0 {
                exec_lower_set_unsupported_reason(param, "exec: 当前不支持 SIMD" as *byte, ExecUnsupportedReason.EXEC_UNSUPPORTED_SIMD);
                return null;
            }
            exec_lower_set_unsupported(param, "exec: 当前仅支持标量/错误联合参数" as *byte);
            return null;
        }
        if exec_lower_append_local(&ctx, param, param.var_decl_name, &param_type, 1) < 0 {
            checker.current_self_type_name = saved_self_type_name;
            checker.current_self_is_union = saved_self_is_union;
            exec_backend_set_error(param, "exec: 参数槽位不足" as *byte, 0);
            return null;
        }
        i = i + 1;
    }
    const body: &HIRBlock = exec_lower_block(&ctx, fn_decl.fn_decl_body);
    if body == null {
        checker.current_self_type_name = saved_self_type_name;
        checker.current_self_is_union = saved_self_is_union;
        return null;
    }
    const hir_fn: &HIRFunction = compiler_arena_alloc(arena, @size_of(HIRFunction)) as &HIRFunction;
    if hir_fn == null {
        checker.current_self_type_name = saved_self_type_name;
        checker.current_self_is_union = saved_self_is_union;
        exec_backend_set_error(fn_decl, "exec: HIRFunction 分配失败" as *byte, 0);
        return null;
    }
    _ = memset(hir_fn as *byte, 0, @size_of(HIRFunction));
    hir_fn.name = fn_decl.fn_decl_name;
    hir_fn.decl = fn_decl;
    hir_fn.return_type = exec_lower_make_type_ref(&return_type);
    if ctx.max_slot_count > 0 {
        const locals: &HIRLocalSlot = compiler_arena_alloc(arena, @size_of(HIRLocalSlot) * ctx.max_slot_count as usize) as &HIRLocalSlot;
        if locals == null {
            checker.current_self_type_name = saved_self_type_name;
            checker.current_self_is_union = saved_self_is_union;
            exec_backend_set_error(fn_decl, "exec: local slot 表分配失败" as *byte, 0);
            return null;
        }
        i = 0;
        while i < ctx.max_slot_count {
            locals[i].name = ctx.slot_names[i];
            locals[i].decl = ctx.slot_decls[i];
            locals[i].slot = i;
            locals[i].scope_id = ctx.slot_scope_ids[i];
            locals[i].type_ref = exec_lower_make_type_ref(&ctx.slot_types[i]);
            locals[i].is_param = ctx.slot_is_param[i];
            locals[i].needs_drop = ctx.slot_needs_drop[i];
            locals[i].drop_decl = ctx.slot_drop_decls[i];
            i = i + 1;
        }
        hir_fn.locals = locals;
        hir_fn.local_count = ctx.max_slot_count;
    }
    hir_fn.param_count = fn_decl.fn_decl_param_count;
    hir_fn.is_varargs = fn_decl.fn_decl_is_varargs;
    hir_fn.body = body;
    checker.current_self_type_name = saved_self_type_name;
    checker.current_self_is_union = saved_self_is_union;
    return hir_fn;
}

/// 将 checker 后的可达函数降级为执行友好的 HIR。
/// 参数：`arena` 为执行后端短生命周期 Arena；`checker` 提供类型与可达性；`program` 为 merged checked AST。
/// 返回值：成功时返回 `HIRModule`；遇到当前未支持特性时返回 null，并通过 exec backend 错误状态说明原因。
export fn exec_lower_module(arena: &CompilerArena, checker: &TypeChecker, program: &ASTNode) &HIRModule {
    if arena == null || checker == null || program == null {
        exec_backend_set_error(program, "exec: lowering 输入无效" as *byte, 0);
        return null;
    }
    if g_app_mode_microapp != 0 {
        exec_lower_set_unsupported_reason(program, "exec: 当前不支持 microapp exec backend" as *byte, ExecUnsupportedReason.EXEC_UNSUPPORTED_MICROAPP);
        return null;
    }
    if program.type == ASTNodeType.AST_PROGRAM {
        var decl_idx: i32 = 0;
        while decl_idx < program.program_decl_count {
            const decl: &ASTNode = program.program_decls[decl_idx];
            if decl != null && decl.type == ASTNodeType.AST_C_IMPORT_DECL {
                exec_lower_set_unsupported_reason(decl, "exec: 当前不支持 @c_import" as *byte, ExecUnsupportedReason.EXEC_UNSUPPORTED_C_IMPORT);
                return null;
            }
            decl_idx = decl_idx + 1;
        }
    }
    var global_count: i32 = 0;
    var globals: &HIRGlobalSlot = exec_lower_collect_global_slots(arena, checker, program, &global_count);
    if globals == null {
        return null;
    }
    var main_decl: &ASTNode = exec_lower_find_entry_decl(checker);
    if main_decl == null {
        exec_lower_set_unsupported(program, "exec: 当前仅支持包含显式 fn/export fn main 的程序" as *byte);
        return null;
    }
    var exec_reachable: [&ASTNode: MAX_REACHABLE_FN_DECLS] = [];
    var exec_reachable_count: i32 = 0;
    exec_reachable[0] = main_decl;
    exec_reachable_count = 1;
    if exec_lower_lower_global_init_exprs(arena, checker, globals, global_count, &exec_reachable[0] as & & ASTNode, &exec_reachable_count) != 0 {
        return null;
    }
    const global_init_function: &HIRFunction = exec_lower_build_global_init_function(arena, globals, global_count);
    const functions: & & HIRFunction = compiler_arena_alloc(arena, @size_of(&HIRFunction) * MAX_REACHABLE_FN_DECLS as usize) as & & HIRFunction;
    if functions == null {
        exec_backend_set_error(program, "exec: HIR function 列表分配失败" as *byte, 0);
        return null;
    }
    var count: i32 = 0;
    var entry_fn: &HIRFunction = null;
    var queue: [&ASTNode: MAX_REACHABLE_FN_DECLS] = [];
    var head: i32 = 0;
    var tail: i32 = 0;
    var seed_idx: i32 = 0;
    while seed_idx < exec_reachable_count {
        queue[seed_idx] = exec_reachable[seed_idx];
        seed_idx = seed_idx + 1;
    }
    tail = exec_reachable_count;
    while head < tail {
        const from_decl: &ASTNode = queue[head];
        head = head + 1;
        var edge_idx: i32 = 0;
        while edge_idx < checker.fn_call_edge_count {
            if checker.fn_call_edge_from[edge_idx] == from_decl {
                const to_decl: &ASTNode = checker.fn_call_edge_to[edge_idx];
                if to_decl != null &&
                    to_decl.type == ASTNodeType.AST_FN_DECL &&
                    exec_lower_extern_can_run_in_vm(checker, to_decl) != 0 &&
                    exec_lower_decl_index(&exec_reachable[0] as & & ASTNode, exec_reachable_count, to_decl) < 0 {
                    if exec_reachable_count >= MAX_REACHABLE_FN_DECLS || tail >= MAX_REACHABLE_FN_DECLS {
                        exec_backend_set_error(to_decl, "exec: reachable 函数集合超出上限" as *byte, 0);
                        return null;
                    }
                    exec_reachable[exec_reachable_count] = to_decl;
                    exec_reachable_count = exec_reachable_count + 1;
                    queue[tail] = to_decl;
                    tail = tail + 1;
                }
            }
            edge_idx = edge_idx + 1;
        }
    }
    var i: i32 = 0;
    while i < exec_reachable_count {
        const decl: &ASTNode = exec_reachable[i];
        if decl != null && decl.type == ASTNodeType.AST_FN_DECL && decl.fn_decl_body != null {
            const lowered: &HIRFunction = exec_lower_function(arena, checker, decl, globals, global_count);
            if lowered == null {
                return null;
            }
            functions[count] = lowered;
            if decl == main_decl {
                entry_fn = lowered;
            }
            if lowered.body != null {
                exec_lower_collect_called_decls_from_block(lowered.body, &exec_reachable[0] as & & ASTNode, &exec_reachable_count);
            }
            exec_lower_collect_cleanup_decls_from_function(checker, lowered, &exec_reachable[0] as & & ASTNode, &exec_reachable_count);
            count = count + 1;
        }
        i = i + 1;
    }
    if entry_fn == null {
        exec_lower_set_unsupported(program, "exec: 无法定位 exec 入口 main" as *byte);
        return null;
    }
    const module: &HIRModule = compiler_arena_alloc(arena, @size_of(HIRModule)) as &HIRModule;
    if module == null {
        exec_backend_set_error(program, "exec: HIRModule 分配失败" as *byte, 0);
        return null;
    }
    _ = memset(module as *byte, 0, @size_of(HIRModule));
    module.functions = functions;
    module.function_count = count;
    module.entry_function = entry_fn;
    module.globals = globals;
    module.global_count = global_count;
    module.global_init_function = global_init_function;
    return module;
}
