// exec/frame.uya - Exec VM frame definitions

// 编译器本体 staged smoke 当前已越过 4096 个临时/局部槽位。
const EXEC_MAX_FRAME_SLOTS: i32 = 8192;

struct ExecFrame {
    function: &BCFunction,
    ip: i32,
    slots: [ExecValue: EXEC_MAX_FRAME_SLOTS],
    varargs: [ExecValue: EXEC_MAX_CALL_ARGS],
    vararg_count: i32,
}
