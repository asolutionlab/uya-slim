// exec/vm.uya - Minimal bytecode VM

use libc;
use libc.puts;
use libc.atoi;
use libc.atoll;
use libc.isqrt;
use libc.strcmp;
use libc.llabs;
use libc.fprintf;
use libc.printf;
use libc.sprintf;
use libc.snprintf;
use libc.write;
use libc.strlen;

const EXEC_VM_REF_KIND_BASE: i32 = 65536;
const EXEC_VM_REF_KIND_INDEX_BASE: i32 = 131072;

fn exec_vm_slot_ref(frame: &ExecFrame, idx: i32) &ExecValue {
    if frame == null || idx < 0 || idx >= EXEC_MAX_FRAME_SLOTS {
        return null;
    }
    if idx >= 0 && idx < EXEC_MAX_FRAME_SLOTS {
        return &frame.slots[idx];
    }
    return null;
}

fn exec_vm_store_slot(slot: &ExecValue, value: ExecValue) void {
    if slot == null {
        return;
    }
    slot[0] = exec_value_clone(&value);
}

fn exec_vm_global_ref(program: &BCProgram, idx: i32) &ExecValue {
    if program == null || idx < 0 || idx >= program.global_count || program.globals == null {
        return null;
    }
    return &program.globals[idx];
}

fn exec_vm_value_kind_is_unsigned(kind: ExecValueKind) i32 {
    if kind == ExecValueKind.EXEC_VALUE_U8 ||
        kind == ExecValueKind.EXEC_VALUE_U16 ||
        kind == ExecValueKind.EXEC_VALUE_U32 ||
        kind == ExecValueKind.EXEC_VALUE_U64 ||
        kind == ExecValueKind.EXEC_VALUE_USIZE ||
        kind == ExecValueKind.EXEC_VALUE_BYTE ||
        kind == ExecValueKind.EXEC_VALUE_POINTER ||
        kind == ExecValueKind.EXEC_VALUE_STRING {
        return 1;
    }
    return 0;
}

fn exec_vm_make_integer_by_kind(kind: ExecValueKind, signed_value: i64, unsigned_value: u64) ExecValue {
    if kind == ExecValueKind.EXEC_VALUE_I8 {
        return exec_make_i8(signed_value as i8);
    }
    if kind == ExecValueKind.EXEC_VALUE_I16 {
        return exec_make_i16(signed_value as i16);
    }
    if kind == ExecValueKind.EXEC_VALUE_I64 {
        return exec_make_i64(signed_value);
    }
    if kind == ExecValueKind.EXEC_VALUE_ISIZE {
        return exec_make_isize(signed_value as isize);
    }
    if kind == ExecValueKind.EXEC_VALUE_U8 {
        return exec_make_u8(unsigned_value as u8);
    }
    if kind == ExecValueKind.EXEC_VALUE_U16 {
        return exec_make_u16(unsigned_value as u16);
    }
    if kind == ExecValueKind.EXEC_VALUE_U32 {
        return exec_make_u32(unsigned_value as u32);
    }
    if kind == ExecValueKind.EXEC_VALUE_U64 {
        return exec_make_u64(unsigned_value);
    }
    if kind == ExecValueKind.EXEC_VALUE_USIZE {
        return exec_make_usize(unsigned_value as usize);
    }
    if kind == ExecValueKind.EXEC_VALUE_F32 {
        return exec_make_f32(signed_value as f32);
    }
    if kind == ExecValueKind.EXEC_VALUE_F64 {
        return exec_make_f64(signed_value as f64);
    }
    if kind == ExecValueKind.EXEC_VALUE_BYTE {
        return exec_make_byte(unsigned_value as i32);
    }
    return exec_make_i32(signed_value as i32);
}

fn exec_vm_value_kind_from_type_code(kind_code: i32, fallback: ExecValueKind) ExecValueKind {
    if kind_code == TypeKind.TYPE_I8 as i32 {
        return ExecValueKind.EXEC_VALUE_I8;
    }
    if kind_code == TypeKind.TYPE_I16 as i32 {
        return ExecValueKind.EXEC_VALUE_I16;
    }
    if kind_code == TypeKind.TYPE_I64 as i32 {
        return ExecValueKind.EXEC_VALUE_I64;
    }
    if kind_code == TypeKind.TYPE_U8 as i32 {
        return ExecValueKind.EXEC_VALUE_U8;
    }
    if kind_code == TypeKind.TYPE_U16 as i32 {
        return ExecValueKind.EXEC_VALUE_U16;
    }
    if kind_code == TypeKind.TYPE_U32 as i32 {
        return ExecValueKind.EXEC_VALUE_U32;
    }
    if kind_code == TypeKind.TYPE_U64 as i32 {
        return ExecValueKind.EXEC_VALUE_U64;
    }
    if kind_code == TypeKind.TYPE_USIZE as i32 {
        return ExecValueKind.EXEC_VALUE_USIZE;
    }
    if kind_code == TypeKind.TYPE_F32 as i32 {
        return ExecValueKind.EXEC_VALUE_F32;
    }
    if kind_code == TypeKind.TYPE_F64 as i32 {
        return ExecValueKind.EXEC_VALUE_F64;
    }
    if kind_code == TypeKind.TYPE_BYTE as i32 {
        return ExecValueKind.EXEC_VALUE_BYTE;
    }
    if kind_code == TypeKind.TYPE_BOOL as i32 {
        return ExecValueKind.EXEC_VALUE_BOOL;
    }
    if kind_code == TypeKind.TYPE_ENUM as i32 {
        return ExecValueKind.EXEC_VALUE_I32;
    }
    if kind_code == TypeKind.TYPE_POINTER as i32 {
        return ExecValueKind.EXEC_VALUE_POINTER;
    }
    if kind_code == TypeKind.TYPE_VA_LIST as i32 {
        return ExecValueKind.EXEC_VALUE_VA_LIST;
    }
    return fallback;
}

fn exec_vm_value_kind_is_float(kind: ExecValueKind) i32 {
    return exec_value_is_float_kind(kind);
}

fn exec_vm_make_float_by_kind(kind: ExecValueKind, value: f64) ExecValue {
    if kind == ExecValueKind.EXEC_VALUE_F32 {
        return exec_make_f32(value as f32);
    }
    return exec_make_f64(value);
}

fn exec_vm_numeric_to_i64(value: ExecValue) i64 {
    if exec_vm_value_kind_is_float(value.kind) != 0 {
        return exec_value_as_f64(&value) as i64;
    }
    return value.i64_value;
}

fn exec_vm_numeric_to_u64(value: ExecValue) u64 {
    if exec_vm_value_kind_is_float(value.kind) != 0 {
        return exec_value_as_f64(&value) as u64;
    }
    return value.i64_value as u64;
}

fn exec_vm_promote_vararg_value(value: ExecValue) ExecValue {
    if value.kind == ExecValueKind.EXEC_VALUE_I8 || value.kind == ExecValueKind.EXEC_VALUE_I16 {
        return exec_make_i32(value.i64_value as i32);
    }
    if value.kind == ExecValueKind.EXEC_VALUE_U8 ||
        value.kind == ExecValueKind.EXEC_VALUE_U16 ||
        value.kind == ExecValueKind.EXEC_VALUE_BYTE ||
        value.kind == ExecValueKind.EXEC_VALUE_BOOL {
        return exec_make_i32(value.i64_value as i32);
    }
    if value.kind == ExecValueKind.EXEC_VALUE_F32 {
        return exec_make_f64(exec_value_as_f32(&value) as f64);
    }
    return exec_value_clone(&value);
}

fn exec_vm_resolve_va_target(slot: &ExecValue) &ExecValue {
    if slot == null {
        return null;
    }
    if exec_vm_pointer_is_internal_ref(slot) != 0 {
        return exec_vm_ref_target_value(slot);
    }
    return slot;
}

fn exec_vm_decode_syscall_arg_base(meta: i64) i32 {
    return (meta & 65535) as i32;
}

fn exec_vm_decode_syscall_arg_count(meta: i64) i32 {
    return ((meta >> 16) & 255) as i32;
}

fn exec_vm_decode_syscall_target_kind(meta: i64) i32 {
    return ((meta >> 24) & 65535) as i32;
}

fn exec_vm_decode_syscall_target_pointee_kind(meta: i64) i32 {
    return ((meta >> 40) & 65535) as i32;
}

fn exec_vm_syscall_arg_to_i64(value: ExecValue) i64 {
    if exec_value_is_pointer_like(value) != 0 {
        return value.i64_value;
    }
    return exec_vm_numeric_to_i64(value);
}

fn exec_vm_compare_values(left: ExecValue, right: ExecValue) i32 {
    if exec_value_is_pointer_like(left) != 0 || exec_value_is_pointer_like(right) != 0 {
        const left_u: u64 = left.i64_value as u64;
        const right_u: u64 = right.i64_value as u64;
        if left_u < right_u { return -1; }
        if left_u > right_u { return 1; }
        return 0;
    }
    if exec_vm_value_kind_is_unsigned(left.kind) != 0 {
        const left_u2: u64 = left.i64_value as u64;
        const right_u2: u64 = right.i64_value as u64;
        if left_u2 < right_u2 { return -1; }
        if left_u2 > right_u2 { return 1; }
        return 0;
    }
    if left.i64_value < right.i64_value { return -1; }
    if left.i64_value > right.i64_value { return 1; }
    return 0;
}

fn exec_vm_type_kind_size(kind_code: i32) usize {
    if kind_code == TypeKind.TYPE_BOOL as i32 ||
        kind_code == TypeKind.TYPE_BYTE as i32 ||
        kind_code == TypeKind.TYPE_I8 as i32 ||
        kind_code == TypeKind.TYPE_U8 as i32 {
        return 1 as usize;
    }
    if kind_code == TypeKind.TYPE_I16 as i32 || kind_code == TypeKind.TYPE_U16 as i32 {
        return 2 as usize;
    }
    if kind_code == TypeKind.TYPE_I32 as i32 || kind_code == TypeKind.TYPE_U32 as i32 {
        return 4 as usize;
    }
    if kind_code == TypeKind.TYPE_F32 as i32 {
        return 4 as usize;
    }
    if kind_code == TypeKind.TYPE_ENUM as i32 {
        return 4 as usize;
    }
    if kind_code == TypeKind.TYPE_I64 as i32 || kind_code == TypeKind.TYPE_U64 as i32 ||
        kind_code == TypeKind.TYPE_USIZE as i32 ||
        kind_code == TypeKind.TYPE_F64 as i32 ||
        kind_code == TypeKind.TYPE_POINTER as i32 {
        return @size_of(usize) as usize;
    }
    return 0 as usize;
}

fn exec_vm_pointer_address(value: &ExecValue) usize {
    if value == null {
        return 0 as usize;
    }
    return value.i64_value as usize;
}

fn exec_vm_encode_ref_kind(pointee_kind: i32) i32 {
    return EXEC_VM_REF_KIND_BASE + pointee_kind;
}

fn exec_vm_encode_index_ref_kind(pointee_kind: i32) i32 {
    return EXEC_VM_REF_KIND_INDEX_BASE + pointee_kind;
}

fn exec_vm_decode_ref_kind(encoded_kind: i32) i32 {
    if encoded_kind >= EXEC_VM_REF_KIND_INDEX_BASE {
        return encoded_kind - EXEC_VM_REF_KIND_INDEX_BASE;
    }
    if encoded_kind >= EXEC_VM_REF_KIND_BASE {
        return encoded_kind - EXEC_VM_REF_KIND_BASE;
    }
    return TypeKind.TYPE_VOID as i32;
}

fn exec_vm_pointer_is_internal_ref(value: &ExecValue) i32 {
    if value == null || value.kind != ExecValueKind.EXEC_VALUE_POINTER {
        return 0;
    }
    return (value.aux_i64_value as i32 >= EXEC_VM_REF_KIND_BASE) as i32;
}

fn exec_vm_pointer_is_index_base_ref(value: &ExecValue) i32 {
    if value == null || value.kind != ExecValueKind.EXEC_VALUE_POINTER {
        return 0;
    }
    return (value.aux_i64_value as i32 >= EXEC_VM_REF_KIND_INDEX_BASE) as i32;
}

fn exec_vm_make_value_ref(target: &ExecValue, pointee_kind: i32) ExecValue {
    if target == null {
        return exec_make_pointer_with_kind(0 as usize, exec_vm_encode_ref_kind(pointee_kind));
    }
    const target_addr: usize = @usize_from_ptr(target as &void);
    return exec_make_pointer_with_kind(target_addr, exec_vm_encode_ref_kind(pointee_kind));
}

fn exec_vm_make_index_ref_from_addr(addr: usize, pointee_kind: i32) ExecValue {
    return exec_make_pointer_with_kind(addr, exec_vm_encode_index_ref_kind(pointee_kind));
}

fn exec_vm_make_index_value_ref(target: &ExecValue, pointee_kind: i32) ExecValue {
    if target == null {
        return exec_make_pointer_with_kind(0 as usize, exec_vm_encode_index_ref_kind(pointee_kind));
    }
    const target_addr: usize = @usize_from_ptr(target as &void);
    return exec_make_pointer_with_kind(target_addr, exec_vm_encode_index_ref_kind(pointee_kind));
}

fn exec_vm_ref_target_value(value: &ExecValue) &ExecValue {
    if exec_vm_pointer_is_internal_ref(value) == 0 {
        return null;
    }
    const target_addr: usize = exec_vm_pointer_address(value);
    if target_addr == 0 as usize {
        return null;
    }
    return @ptr_from_usize(target_addr) as &ExecValue;
}

fn exec_vm_box_value_ref(value: ExecValue, pointee_kind: i32) ExecValue {
    const boxed: &ExecValue = exec_value_alloc_bytes(@size_of(ExecValue)) as &ExecValue;
    if boxed == null {
        return exec_make_pointer_with_kind(0 as usize, exec_vm_encode_ref_kind(pointee_kind));
    }
    boxed[0] = exec_value_clone(&value);
    return exec_vm_make_value_ref(boxed, pointee_kind);
}

fn exec_vm_aggregate_ref_from_value(value: &ExecValue) &ExecAggregate {
    if value == null {
        return null;
    }
    if value.kind == ExecValueKind.EXEC_VALUE_STRUCT ||
        value.kind == ExecValueKind.EXEC_VALUE_ARRAY ||
        value.kind == ExecValueKind.EXEC_VALUE_TUPLE {
        return exec_value_as_aggregate(value);
    }
    if exec_vm_pointer_is_internal_ref(value) != 0 {
        const target: &ExecValue = exec_vm_ref_target_value(value);
        if target == null {
            return null;
        }
        const direct_aggregate: &ExecAggregate = exec_value_as_aggregate(target);
        if direct_aggregate != null {
            return direct_aggregate;
        }
        if exec_value_is_pointer_like(target[0]) != 0 && exec_vm_pointer_is_internal_ref(target) != 0 {
            const nested_target: &ExecValue = exec_vm_ref_target_value(target);
            if nested_target != null {
                return exec_value_as_aggregate(nested_target);
            }
        }
    }
    return null;
}

fn exec_vm_field_ref(value: &ExecValue, field_idx: i32) &ExecValue {
    const aggregate: &ExecAggregate = exec_vm_aggregate_ref_from_value(value);
    if aggregate == null || field_idx < 0 || field_idx >= aggregate.count {
        return null;
    }
    return &aggregate.values[field_idx];
}

fn exec_vm_file_fd_from_value(value: &ExecValue) i32 {
    if value == null {
        return -1;
    }
    if exec_vm_pointer_is_internal_ref(value) == 0 {
        return -1;
    }
    const file_value: &ExecValue = exec_vm_ref_target_value(value);
    if file_value == null {
        return -1;
    }
    const fd_field: &ExecValue = exec_vm_field_ref(file_value, 0);
    if fd_field == null {
        return -1;
    }
    return fd_field.i64_value as i32;
}

fn exec_vm_raw_array_element_ptr(value: &ExecValue, index_value: i32) ExecValue {
    if value == null || exec_value_is_raw_array(value) == 0 || index_value < 0 {
        return exec_make_void();
    }
    const count: i32 = value.i64_value as i32;
    const elem_kind: i32 = exec_value_raw_array_element_kind(value);
    const elem_size: usize = exec_vm_type_kind_size(elem_kind);
    if index_value >= count || elem_size == 0 as usize {
        return exec_make_void();
    }
    const base_ptr: &byte = exec_value_raw_array_ptr(value);
    if base_ptr == null {
        return exec_make_void();
    }
    const addr: usize = @usize_from_ptr(base_ptr as &void) + elem_size * (index_value as usize);
    return exec_make_pointer_with_kind(addr, elem_kind);
}

fn exec_vm_raw_array_slice_ptr(value: &ExecValue, index_value: i32) ExecValue {
    if value == null || exec_value_is_raw_array(value) == 0 || index_value < 0 {
        return exec_make_void();
    }
    const count: i32 = value.i64_value as i32;
    const elem_kind: i32 = exec_value_raw_array_element_kind(value);
    const elem_size: usize = exec_vm_type_kind_size(elem_kind);
    if index_value > count || elem_size == 0 as usize {
        return exec_make_void();
    }
    const base_ptr: &byte = exec_value_raw_array_ptr(value);
    if base_ptr == null {
        if index_value == 0 && count == 0 {
            return exec_make_pointer_with_kind(0 as usize, elem_kind);
        }
        return exec_make_void();
    }
    const addr: usize = @usize_from_ptr(base_ptr as &void) + elem_size * (index_value as usize);
    return exec_make_pointer_with_kind(addr, elem_kind);
}

fn exec_vm_raw_slice_element_ptr(value: &ExecValue, index_value: i32, allow_end: i32) ExecValue {
    if value == null || exec_value_is_raw_slice(value) == 0 || index_value < 0 {
        return exec_make_void();
    }
    const count: i32 = exec_value_count(value);
    const elem_kind: i32 = exec_value_slice_element_kind(value);
    const elem_size: usize = exec_vm_type_kind_size(elem_kind);
    if elem_size == 0 as usize {
        return exec_make_void();
    }
    if index_value > count || (allow_end == 0 && index_value >= count) {
        return exec_make_void();
    }
    const base_ptr: &byte = exec_value_slice_raw_ptr(value);
    if base_ptr == null {
        if index_value == 0 && count == 0 {
            return exec_make_pointer_with_kind(0 as usize, elem_kind);
        }
        return exec_make_void();
    }
    const addr: usize = @usize_from_ptr(base_ptr as &void) + elem_size * (index_value as usize);
    return exec_make_pointer_with_kind(addr, elem_kind);
}

fn exec_vm_slice_ptr_value(value: &ExecValue, pointee_kind: i32) ExecValue {
    if value == null || value.kind != ExecValueKind.EXEC_VALUE_SLICE {
        return exec_make_void();
    }
    if exec_value_is_raw_slice(value) != 0 {
        const raw_ptr: &byte = exec_value_slice_raw_ptr(value);
        if raw_ptr == null {
            return exec_make_pointer_with_kind(0 as usize, pointee_kind);
        }
        return exec_make_pointer_with_kind(@usize_from_ptr(raw_ptr as &void), pointee_kind);
    }
    const slice_data: &ExecSliceData = exec_value_as_slice(value);
    if slice_data == null || slice_data.aggregate == null || slice_data.aggregate.values == null {
        return exec_make_pointer_with_kind(0 as usize, pointee_kind);
    }
    if slice_data.start < 0 || slice_data.start >= slice_data.aggregate.count {
        return exec_make_pointer_with_kind(0 as usize, pointee_kind);
    }
    return exec_vm_make_index_value_ref(&slice_data.aggregate.values[slice_data.start], pointee_kind);
}

fn exec_vm_pointer_element_ptr(function: &BCFunction, base: ExecValue, index_value: i64) ExecValue {
    if function == null {
        exec_backend_set_error(null, "exec: pointer addr 输入无效" as *byte, 0);
        return exec_make_void();
    }
    const base_addr: usize = exec_vm_pointer_address(&base);
    if base_addr == 0 as usize {
        exec_backend_set_error(function.decl, "exec: 空指针解引用" as *byte, 0);
        return exec_make_void();
    }
    if index_value < 0 {
        exec_backend_set_error(function.decl, "exec: 指针下标不能为负数" as *byte, 0);
        return exec_make_void();
    }
    const pointee_kind: i32 = exec_value_pointer_pointee_kind(&base);
    const elem_size: usize = exec_vm_type_kind_size(pointee_kind);
    if elem_size == 0 as usize {
        exec_backend_set_error(function.decl, "exec: 当前不支持该指针元素类型" as *byte, 0);
        return exec_make_void();
    }
    const addr: usize = base_addr + (index_value as usize) * elem_size;
    return exec_make_pointer_with_kind(addr, pointee_kind);
}

fn exec_vm_index_ref(value: &ExecValue, index_value: i32) &ExecValue {
    if value == null || index_value < 0 {
        return null;
    }
    if value.kind == ExecValueKind.EXEC_VALUE_SLICE {
        const slice_data: &ExecSliceData = exec_value_as_slice(value);
        if slice_data == null || slice_data.aggregate == null || index_value >= slice_data.len {
            return null;
        }
        return &slice_data.aggregate.values[slice_data.start + index_value];
    }
    if exec_vm_pointer_is_internal_ref(value) != 0 {
        const target: &ExecValue = exec_vm_ref_target_value(value);
        if target == null {
            return null;
        }
        if exec_vm_pointer_is_index_base_ref(value) != 0 {
            const target_addr2: usize = @usize_from_ptr(target as &void);
            return @ptr_from_usize(target_addr2 + (@size_of(ExecValue) as usize) * (index_value as usize)) as &ExecValue;
        }
        return exec_vm_index_ref(target, index_value);
    }
    const aggregate: &ExecAggregate = exec_value_as_aggregate(value);
    if aggregate == null || index_value >= aggregate.count {
        return null;
    }
    return &aggregate.values[index_value];
}

fn exec_vm_load_pointer_index(function: &BCFunction, base: ExecValue, index_value: i64, out_value: &ExecValue) i32 {
    if function == null || out_value == null {
        exec_backend_set_error(null, "exec: pointer load 输入无效" as *byte, 0);
        return -1;
    }
    const base_addr: usize = exec_vm_pointer_address(&base);
    if base_addr == 0 as usize {
        exec_backend_set_error(function.decl, "exec: 空指针解引用" as *byte, 0);
        return -1;
    }
    if index_value < 0 {
        exec_backend_set_error(function.decl, "exec: 指针下标不能为负数" as *byte, 0);
        return -1;
    }
    const pointee_kind: i32 = exec_value_pointer_pointee_kind(&base);
    const elem_size: usize = exec_vm_type_kind_size(pointee_kind);
    if elem_size == 0 as usize {
        exec_backend_set_error(function.decl, "exec: 当前不支持该指针元素类型" as *byte, 0);
        return -1;
    }
    const addr: usize = base_addr + (index_value as usize) * elem_size;
    if pointee_kind == TypeKind.TYPE_BOOL as i32 {
        const ptr_bool: &byte = @ptr_from_usize(addr) as &byte;
        out_value[0] = exec_make_bool((ptr_bool[0] != 0) as i32);
        return 0;
    }
    if pointee_kind == TypeKind.TYPE_I8 as i32 {
        const ptr_i8: &i8 = @ptr_from_usize(addr) as &i8;
        out_value[0] = exec_make_i8(ptr_i8[0]);
        return 0;
    }
    if pointee_kind == TypeKind.TYPE_BYTE as i32 || pointee_kind == TypeKind.TYPE_U8 as i32 {
        const ptr_u8: &byte = @ptr_from_usize(addr) as &byte;
        if pointee_kind == TypeKind.TYPE_U8 as i32 {
            out_value[0] = exec_make_u8(ptr_u8[0]);
        } else {
            out_value[0] = exec_make_byte(ptr_u8[0] as i32);
        }
        return 0;
    }
    if pointee_kind == TypeKind.TYPE_I16 as i32 {
        const ptr_i16: &i16 = @ptr_from_usize(addr) as &i16;
        out_value[0] = exec_make_i16(ptr_i16[0]);
        return 0;
    }
    if pointee_kind == TypeKind.TYPE_U16 as i32 {
        const ptr_u16: &u16 = @ptr_from_usize(addr) as &u16;
        out_value[0] = exec_make_u16(ptr_u16[0]);
        return 0;
    }
    if pointee_kind == TypeKind.TYPE_I32 as i32 {
        const ptr_i32: &i32 = @ptr_from_usize(addr) as &i32;
        out_value[0] = exec_make_i32(ptr_i32[0]);
        return 0;
    }
    if pointee_kind == TypeKind.TYPE_U32 as i32 {
        const ptr_u32: &u32 = @ptr_from_usize(addr) as &u32;
        out_value[0] = exec_make_u32(ptr_u32[0]);
        return 0;
    }
    if pointee_kind == TypeKind.TYPE_F32 as i32 {
        const ptr_f32: &f32 = @ptr_from_usize(addr) as &f32;
        out_value[0] = exec_make_f32(ptr_f32[0]);
        return 0;
    }
    if pointee_kind == TypeKind.TYPE_I64 as i32 {
        const ptr_i64: &i64 = @ptr_from_usize(addr) as &i64;
        out_value[0] = exec_make_i64(ptr_i64[0]);
        return 0;
    }
    if pointee_kind == TypeKind.TYPE_U64 as i32 {
        const ptr_u64: &u64 = @ptr_from_usize(addr) as &u64;
        out_value[0] = exec_make_u64(ptr_u64[0]);
        return 0;
    }
    if pointee_kind == TypeKind.TYPE_USIZE as i32 {
        const ptr_usize: &usize = @ptr_from_usize(addr) as &usize;
        out_value[0] = exec_make_usize(ptr_usize[0]);
        return 0;
    }
    if pointee_kind == TypeKind.TYPE_F64 as i32 {
        const ptr_f64: &f64 = @ptr_from_usize(addr) as &f64;
        out_value[0] = exec_make_f64(ptr_f64[0]);
        return 0;
    }
    if pointee_kind == TypeKind.TYPE_POINTER as i32 {
        const ptr_ptr: &usize = @ptr_from_usize(addr) as &usize;
        out_value[0] = exec_make_pointer_with_kind(ptr_ptr[0], TypeKind.TYPE_VOID as i32);
        return 0;
    }
    exec_backend_set_error(function.decl, "exec: 当前不支持该指针元素类型" as *byte, 0);
    return -1;
}

fn exec_vm_store_pointer_index(function: &BCFunction, base: ExecValue, index_value: i64, src_value: ExecValue) i32 {
    if function == null {
        exec_backend_set_error(null, "exec: pointer store 输入无效" as *byte, 0);
        return -1;
    }
    const base_addr: usize = exec_vm_pointer_address(&base);
    if base_addr == 0 as usize {
        exec_backend_set_error(function.decl, "exec: 空指针解引用" as *byte, 0);
        return -1;
    }
    if index_value < 0 {
        exec_backend_set_error(function.decl, "exec: 指针下标不能为负数" as *byte, 0);
        return -1;
    }
    const pointee_kind: i32 = exec_value_pointer_pointee_kind(&base);
    const elem_size: usize = exec_vm_type_kind_size(pointee_kind);
    if elem_size == 0 as usize {
        exec_backend_set_error(function.decl, "exec: 当前不支持该指针元素类型" as *byte, 0);
        return -1;
    }
    const addr: usize = base_addr + (index_value as usize) * elem_size;
    if pointee_kind == TypeKind.TYPE_BOOL as i32 {
        const ptr_bool: &byte = @ptr_from_usize(addr) as &byte;
        ptr_bool[0] = src_value.i64_value as byte;
        return 0;
    }
    if pointee_kind == TypeKind.TYPE_I8 as i32 {
        const ptr_i8: &i8 = @ptr_from_usize(addr) as &i8;
        ptr_i8[0] = src_value.i64_value as i8;
        return 0;
    }
    if pointee_kind == TypeKind.TYPE_BYTE as i32 || pointee_kind == TypeKind.TYPE_U8 as i32 {
        const ptr_u8: &byte = @ptr_from_usize(addr) as &byte;
        ptr_u8[0] = src_value.i64_value as byte;
        return 0;
    }
    if pointee_kind == TypeKind.TYPE_I16 as i32 {
        const ptr_i16: &i16 = @ptr_from_usize(addr) as &i16;
        ptr_i16[0] = src_value.i64_value as i16;
        return 0;
    }
    if pointee_kind == TypeKind.TYPE_U16 as i32 {
        const ptr_u16: &u16 = @ptr_from_usize(addr) as &u16;
        ptr_u16[0] = src_value.i64_value as u16;
        return 0;
    }
    if pointee_kind == TypeKind.TYPE_I32 as i32 {
        const ptr_i32: &i32 = @ptr_from_usize(addr) as &i32;
        ptr_i32[0] = src_value.i64_value as i32;
        return 0;
    }
    if pointee_kind == TypeKind.TYPE_U32 as i32 {
        const ptr_u32: &u32 = @ptr_from_usize(addr) as &u32;
        ptr_u32[0] = src_value.i64_value as u32;
        return 0;
    }
    if pointee_kind == TypeKind.TYPE_F32 as i32 {
        const ptr_f32: &f32 = @ptr_from_usize(addr) as &f32;
        ptr_f32[0] = exec_value_as_f32(&src_value);
        return 0;
    }
    if pointee_kind == TypeKind.TYPE_I64 as i32 {
        const ptr_i64: &i64 = @ptr_from_usize(addr) as &i64;
        ptr_i64[0] = src_value.i64_value;
        return 0;
    }
    if pointee_kind == TypeKind.TYPE_U64 as i32 {
        const ptr_u64: &u64 = @ptr_from_usize(addr) as &u64;
        ptr_u64[0] = src_value.i64_value as u64;
        return 0;
    }
    if pointee_kind == TypeKind.TYPE_USIZE as i32 {
        const ptr_usize: &usize = @ptr_from_usize(addr) as &usize;
        ptr_usize[0] = src_value.i64_value as usize;
        return 0;
    }
    if pointee_kind == TypeKind.TYPE_F64 as i32 {
        const ptr_f64: &f64 = @ptr_from_usize(addr) as &f64;
        ptr_f64[0] = exec_value_as_f64(&src_value);
        return 0;
    }
    if pointee_kind == TypeKind.TYPE_POINTER as i32 {
        const ptr_ptr: &usize = @ptr_from_usize(addr) as &usize;
        ptr_ptr[0] = src_value.i64_value as usize;
        return 0;
    }
    exec_backend_set_error(function.decl, "exec: 当前不支持该指针元素类型" as *byte, 0);
    return -1;
}

fn exec_vm_cast_value(value: ExecValue, target_kind: i32, target_pointee_kind: i32) ExecValue {
    if target_kind == TypeKind.TYPE_F32 as i32 {
        return exec_make_f32(exec_value_as_f32(&value));
    }
    if target_kind == TypeKind.TYPE_F64 as i32 {
        return exec_make_f64(exec_value_as_f64(&value));
    }
    if target_kind == TypeKind.TYPE_I8 as i32 {
        return exec_make_i8(exec_vm_numeric_to_i64(value) as i8);
    }
    if target_kind == TypeKind.TYPE_I16 as i32 {
        return exec_make_i16(exec_vm_numeric_to_i64(value) as i16);
    }
    if target_kind == TypeKind.TYPE_I32 as i32 {
        return exec_make_i32(exec_vm_numeric_to_i64(value) as i32);
    }
    if target_kind == TypeKind.TYPE_I64 as i32 {
        return exec_make_i64(exec_vm_numeric_to_i64(value));
    }
    if target_kind == TypeKind.TYPE_U8 as i32 {
        return exec_make_u8(exec_vm_numeric_to_u64(value) as u8);
    }
    if target_kind == TypeKind.TYPE_U16 as i32 {
        return exec_make_u16(exec_vm_numeric_to_u64(value) as u16);
    }
    if target_kind == TypeKind.TYPE_U32 as i32 {
        return exec_make_u32(exec_vm_numeric_to_u64(value) as u32);
    }
    if target_kind == TypeKind.TYPE_U64 as i32 {
        return exec_make_u64(exec_vm_numeric_to_u64(value));
    }
    if target_kind == TypeKind.TYPE_USIZE as i32 {
        return exec_make_usize(exec_vm_numeric_to_u64(value) as usize);
    }
    if target_kind == TypeKind.TYPE_BOOL as i32 {
        return exec_make_bool((exec_value_truthy(value) != 0) as i32);
    }
    if target_kind == TypeKind.TYPE_BYTE as i32 {
        return exec_make_byte(exec_vm_numeric_to_i64(value) as i32);
    }
    if target_kind == TypeKind.TYPE_POINTER as i32 {
        if value.kind == ExecValueKind.EXEC_VALUE_POINTER {
            return exec_make_pointer_with_kind(value.i64_value as usize, target_pointee_kind);
        }
        if value.kind == ExecValueKind.EXEC_VALUE_STRING {
            return exec_make_pointer_with_kind(value.i64_value as usize, target_pointee_kind);
        }
        return exec_make_pointer_with_kind(exec_vm_numeric_to_u64(value) as usize, target_pointee_kind);
    }
    if target_kind == TypeKind.TYPE_VA_LIST as i32 && value.kind == ExecValueKind.EXEC_VALUE_VA_LIST {
        return exec_value_clone(&value);
    }
    return value;
}

fn exec_vm_print_value(value: ExecValue, newline: i32) void {
    if value.kind == ExecValueKind.EXEC_VALUE_I8 {
        if newline != 0 {
            fprintf(libc.stdout, "%d\n" as *byte, value.i64_value as i8);
        } else {
            fprintf(libc.stdout, "%d" as *byte, value.i64_value as i8);
        }
        return;
    }
    if value.kind == ExecValueKind.EXEC_VALUE_I16 {
        if newline != 0 {
            fprintf(libc.stdout, "%d\n" as *byte, value.i64_value as i16);
        } else {
            fprintf(libc.stdout, "%d" as *byte, value.i64_value as i16);
        }
        return;
    }
    if value.kind == ExecValueKind.EXEC_VALUE_I32 {
        if newline != 0 {
            fprintf(libc.stdout, "%d\n" as *byte, value.i64_value as i32);
        } else {
            fprintf(libc.stdout, "%d" as *byte, value.i64_value as i32);
        }
        return;
    }
    if value.kind == ExecValueKind.EXEC_VALUE_I64 {
        if newline != 0 {
            fprintf(libc.stdout, "%ld\n" as *byte, value.i64_value);
        } else {
            fprintf(libc.stdout, "%ld" as *byte, value.i64_value);
        }
        return;
    }
    if value.kind == ExecValueKind.EXEC_VALUE_ISIZE {
        if newline != 0 {
            fprintf(libc.stdout, "%ld\n" as *byte, value.i64_value as isize);
        } else {
            fprintf(libc.stdout, "%ld" as *byte, value.i64_value as isize);
        }
        return;
    }
    if value.kind == ExecValueKind.EXEC_VALUE_U8 {
        if newline != 0 {
            fprintf(libc.stdout, "%u\n" as *byte, value.i64_value as u8);
        } else {
            fprintf(libc.stdout, "%u" as *byte, value.i64_value as u8);
        }
        return;
    }
    if value.kind == ExecValueKind.EXEC_VALUE_U16 {
        if newline != 0 {
            fprintf(libc.stdout, "%u\n" as *byte, value.i64_value as u16);
        } else {
            fprintf(libc.stdout, "%u" as *byte, value.i64_value as u16);
        }
        return;
    }
    if value.kind == ExecValueKind.EXEC_VALUE_U32 {
        if newline != 0 {
            fprintf(libc.stdout, "%u\n" as *byte, value.i64_value as u32);
        } else {
            fprintf(libc.stdout, "%u" as *byte, value.i64_value as u32);
        }
        return;
    }
    if value.kind == ExecValueKind.EXEC_VALUE_U64 {
        if newline != 0 {
            fprintf(libc.stdout, "%lu\n" as *byte, value.i64_value as u64);
        } else {
            fprintf(libc.stdout, "%lu" as *byte, value.i64_value as u64);
        }
        return;
    }
    if value.kind == ExecValueKind.EXEC_VALUE_USIZE {
        if newline != 0 {
            fprintf(libc.stdout, "%lu\n" as *byte, value.i64_value as usize);
        } else {
            fprintf(libc.stdout, "%lu" as *byte, value.i64_value as usize);
        }
        return;
    }
    if value.kind == ExecValueKind.EXEC_VALUE_F32 {
        if newline != 0 {
            fprintf(libc.stdout, "%g\n" as *byte, exec_f32_from_bits(value.i64_value as u32) as f64);
        } else {
            fprintf(libc.stdout, "%g" as *byte, exec_f32_from_bits(value.i64_value as u32) as f64);
        }
        return;
    }
    if value.kind == ExecValueKind.EXEC_VALUE_F64 {
        if newline != 0 {
            fprintf(libc.stdout, "%g\n" as *byte, exec_f64_from_bits(value.i64_value as u64));
        } else {
            fprintf(libc.stdout, "%g" as *byte, exec_f64_from_bits(value.i64_value as u64));
        }
        return;
    }
    if value.kind == ExecValueKind.EXEC_VALUE_BOOL {
        var bool_text: *byte = "false" as *byte;
        if value.i64_value != 0 {
            bool_text = "true" as *byte;
        }
        if newline != 0 {
            fprintf(libc.stdout, "%s\n" as *byte, bool_text);
        } else {
            fprintf(libc.stdout, "%s" as *byte, bool_text);
        }
        return;
    }
    if value.kind == ExecValueKind.EXEC_VALUE_BYTE {
        if newline != 0 {
            fprintf(libc.stdout, "%c\n" as *byte, value.i64_value as i32);
        } else {
            fprintf(libc.stdout, "%c" as *byte, value.i64_value as i32);
        }
        return;
    }
    if value.kind == ExecValueKind.EXEC_VALUE_STRING && value.ptr_value != null {
        if newline != 0 {
            fprintf(libc.stdout, "%s\n" as *byte, value.ptr_value as *byte);
        } else {
            fprintf(libc.stdout, "%s" as *byte, value.ptr_value as *byte);
        }
        return;
    }
    if value.kind == ExecValueKind.EXEC_VALUE_POINTER {
        if value.ptr_value != null && exec_value_pointer_pointee_kind(&value) == TypeKind.TYPE_BYTE as i32 {
            if newline != 0 {
                fprintf(libc.stdout, "%s\n" as *byte, value.ptr_value as *byte);
            } else {
                fprintf(libc.stdout, "%s" as *byte, value.ptr_value as *byte);
            }
        } else if newline != 0 {
            fprintf(libc.stdout, "%lu\n" as *byte, value.i64_value as usize);
        } else {
            fprintf(libc.stdout, "%lu" as *byte, value.i64_value as usize);
        }
        return;
    }
    if newline != 0 {
        fprintf(libc.stdout, "\n" as *byte);
    }
}

fn exec_vm_trace(trace_vm: i32, fn_name: &byte, ip: i32, instr: &BCInstr) void {
    if trace_vm == 0 || instr == null {
        return;
    }
    fprintf(libc.stderr, "[vm] fn=%s ip=%d op=%s(%d) a=%d b=%d c=%d imm=%ld\n" as *byte,
        fn_name as *byte, ip, exec_debug_opcode_name(instr.opcode) as *byte, instr.opcode as i32, instr.a, instr.b, instr.c, instr.imm);
}

fn exec_vm_trace_call_enter(trace_vm: i32, fn_name: &byte, arg_count: i32) void {
    if trace_vm == 0 {
        return;
    }
    fprintf(libc.stderr, "[vm] enter fn=%s args=%d\n" as *byte, fn_name as *byte, arg_count);
}

fn exec_vm_trace_jump(trace_vm: i32, fn_name: &byte, from_ip: i32, to_ip: i32, reason: &byte) void {
    if trace_vm == 0 {
        return;
    }
    fprintf(libc.stderr, "[vm] jump fn=%s from=%d to=%d reason=%s\n" as *byte,
        fn_name as *byte, from_ip, to_ip, reason as *byte);
}

fn exec_vm_load_const(program: &BCProgram, function: &BCFunction, const_idx: i32, out_value: &ExecValue) i32 {
    if program == null || function == null || out_value == null {
        exec_backend_set_error(null, "exec: LOAD_CONST 输入无效" as *byte, 0);
        return -1;
    }
    if const_idx < 0 || const_idx >= program.const_pool.count || program.const_pool.values == null {
        exec_backend_set_error(function.decl, "exec: LOAD_CONST 常量索引越界" as *byte, 0);
        return -1;
    }
    out_value[0] = program.const_pool.values[const_idx];
    return 0;
}

fn exec_vm_get_aggregate_for_slice(function: &BCFunction, value: ExecValue) &ExecAggregate {
    if value.kind == ExecValueKind.EXEC_VALUE_ARRAY {
        return exec_value_as_aggregate(&value);
    }
    if value.kind == ExecValueKind.EXEC_VALUE_SLICE {
        const slice_data: &ExecSliceData = exec_value_as_slice(&value);
        if slice_data != null {
            return slice_data.aggregate;
        }
    }
    exec_backend_set_error(function.decl, "exec: 切片基值不是 array/slice" as *byte, 0);
    return null;
}

fn exec_vm_lookup_error_name(program: &BCProgram, error_id: i32) &byte {
    if program == null || error_id == 0 || program.error_names == null || program.error_name_count <= 0 {
        return "UnknownError" as &byte;
    }
    var left: i32 = 0;
    var right: i32 = program.error_name_count - 1;
    while left <= right {
        const mid: i32 = left + (right - left) / 2;
        const entry: &BCErrorNameEntry = program.error_names + mid;
        if entry == null {
            break;
        }
        if entry.error_id == error_id {
            if entry.name != null {
                return entry.name;
            }
            break;
        }
        if entry.error_id < error_id {
            left = mid + 1;
        } else {
            right = mid - 1;
        }
    }
    return "UnknownError" as &byte;
}

fn exec_vm_wrap_syscall_result(result: !i64, target_kind: i32, target_pointee_kind: i32) ExecValue {
    const ok_value: i64 = result catch |err| {
        return exec_make_error_union_err(@error_id(err) as i32);
    };
    const raw_value: ExecValue = exec_make_i64(ok_value);
    const cast_value: ExecValue = exec_vm_cast_value(raw_value, target_kind, target_pointee_kind);
    return exec_make_error_union_ok(cast_value);
}

fn exec_vm_host_syscall0(target_kind: i32, target_pointee_kind: i32, nr: i64) ExecValue {
    return exec_vm_wrap_syscall_result(@syscall(nr), target_kind, target_pointee_kind);
}

fn exec_vm_host_syscall1(target_kind: i32, target_pointee_kind: i32, nr: i64, a1: i64) ExecValue {
    return exec_vm_wrap_syscall_result(@syscall(nr, a1), target_kind, target_pointee_kind);
}

fn exec_vm_host_syscall2(target_kind: i32, target_pointee_kind: i32, nr: i64, a1: i64, a2: i64) ExecValue {
    return exec_vm_wrap_syscall_result(@syscall(nr, a1, a2), target_kind, target_pointee_kind);
}

fn exec_vm_host_syscall3(target_kind: i32, target_pointee_kind: i32, nr: i64, a1: i64, a2: i64, a3: i64) ExecValue {
    return exec_vm_wrap_syscall_result(@syscall(nr, a1, a2, a3), target_kind, target_pointee_kind);
}

fn exec_vm_host_syscall4(target_kind: i32, target_pointee_kind: i32, nr: i64, a1: i64, a2: i64, a3: i64, a4: i64) ExecValue {
    return exec_vm_wrap_syscall_result(@syscall(nr, a1, a2, a3, a4), target_kind, target_pointee_kind);
}

fn exec_vm_host_syscall5(target_kind: i32, target_pointee_kind: i32, nr: i64, a1: i64, a2: i64, a3: i64, a4: i64, a5: i64) ExecValue {
    return exec_vm_wrap_syscall_result(@syscall(nr, a1, a2, a3, a4, a5), target_kind, target_pointee_kind);
}

fn exec_vm_host_syscall6(target_kind: i32, target_pointee_kind: i32, nr: i64, a1: i64, a2: i64, a3: i64, a4: i64, a5: i64, a6: i64) ExecValue {
    return exec_vm_wrap_syscall_result(@syscall(nr, a1, a2, a3, a4, a5, a6), target_kind, target_pointee_kind);
}

fn exec_vm_exec_syscall(function: &BCFunction, frame: &ExecFrame, nr_slot: &ExecValue, syscall_meta: i64, out_value: &ExecValue) i32 {
    if function == null || frame == null || nr_slot == null || out_value == null {
        exec_backend_set_error(null, "exec: syscall 输入无效" as *byte, 0);
        return -1;
    }
    const arg_base: i32 = exec_vm_decode_syscall_arg_base(syscall_meta);
    const arg_count: i32 = exec_vm_decode_syscall_arg_count(syscall_meta);
    const target_kind: i32 = exec_vm_decode_syscall_target_kind(syscall_meta);
    const target_pointee_kind: i32 = exec_vm_decode_syscall_target_pointee_kind(syscall_meta);
    var args: [i64: 6] = [];
    var ai: i32 = 0;
    while ai < arg_count {
        const arg_slot: &ExecValue = exec_vm_slot_ref(frame, arg_base + ai);
        if arg_slot == null {
            exec_backend_set_error(function.decl, "exec: syscall 参数槽位越界" as *byte, 0);
            return -1;
        }
        args[ai] = exec_vm_syscall_arg_to_i64(arg_slot[0]);
        ai = ai + 1;
    }
    const nr_value: i64 = exec_vm_syscall_arg_to_i64(nr_slot[0]);
    if arg_count == 0 {
        out_value[0] = exec_vm_host_syscall0(target_kind, target_pointee_kind, nr_value);
        return 0;
    }
    if arg_count == 1 {
        out_value[0] = exec_vm_host_syscall1(target_kind, target_pointee_kind, nr_value, args[0]);
        return 0;
    }
    if arg_count == 2 {
        out_value[0] = exec_vm_host_syscall2(target_kind, target_pointee_kind, nr_value, args[0], args[1]);
        return 0;
    }
    if arg_count == 3 {
        out_value[0] = exec_vm_host_syscall3(target_kind, target_pointee_kind, nr_value, args[0], args[1], args[2]);
        return 0;
    }
    if arg_count == 4 {
        out_value[0] = exec_vm_host_syscall4(target_kind, target_pointee_kind, nr_value, args[0], args[1], args[2], args[3]);
        return 0;
    }
    if arg_count == 5 {
        out_value[0] = exec_vm_host_syscall5(target_kind, target_pointee_kind, nr_value, args[0], args[1], args[2], args[3], args[4]);
        return 0;
    }
    if arg_count == 6 {
        out_value[0] = exec_vm_host_syscall6(target_kind, target_pointee_kind, nr_value, args[0], args[1], args[2], args[3], args[4], args[5]);
        return 0;
    }
    exec_backend_set_error(function.decl, "exec: syscall 参数数量非法" as *byte, 0);
    return -1;
}

fn exec_vm_va_start(function: &BCFunction, frame: &ExecFrame, ap_ref_slot: &ExecValue) i32 {
    if function == null || frame == null {
        exec_backend_set_error(null, "exec: va_start 输入无效" as *byte, 0);
        return -1;
    }
    const ap_target: &ExecValue = exec_vm_resolve_va_target(ap_ref_slot);
    if ap_target == null {
        exec_backend_set_error(function.decl, "exec: va_start 目标无效" as *byte, 0);
        return -1;
    }
    ap_target[0] = exec_make_va_list(&frame.varargs[0], frame.vararg_count, 0);
    return 0;
}

fn exec_vm_va_end(function: &BCFunction, ap_ref_slot: &ExecValue) i32 {
    if function == null {
        exec_backend_set_error(null, "exec: va_end 输入无效" as *byte, 0);
        return -1;
    }
    const ap_target: &ExecValue = exec_vm_resolve_va_target(ap_ref_slot);
    if ap_target == null {
        exec_backend_set_error(function.decl, "exec: va_end 目标无效" as *byte, 0);
        return -1;
    }
    ap_target[0] = exec_make_void();
    return 0;
}

fn exec_vm_va_copy(function: &BCFunction, dest_ref_slot: &ExecValue, src_ref_slot: &ExecValue) i32 {
    if function == null {
        exec_backend_set_error(null, "exec: va_copy 输入无效" as *byte, 0);
        return -1;
    }
    const dest_target: &ExecValue = exec_vm_resolve_va_target(dest_ref_slot);
    const src_target: &ExecValue = exec_vm_resolve_va_target(src_ref_slot);
    if dest_target == null || src_target == null {
        exec_backend_set_error(function.decl, "exec: va_copy 目标无效" as *byte, 0);
        return -1;
    }
    if src_target.kind != ExecValueKind.EXEC_VALUE_VA_LIST {
        exec_backend_set_error(function.decl, "exec: va_copy 源不是 va_list" as *byte, 0);
        return -1;
    }
    dest_target[0] = exec_value_clone(src_target);
    return 0;
}

fn exec_vm_va_arg(function: &BCFunction, ap_ref_slot: &ExecValue, target_kind: i32, target_pointee_kind: i32, out_value: &ExecValue) i32 {
    if function == null || out_value == null {
        exec_backend_set_error(null, "exec: va_arg 输入无效" as *byte, 0);
        return -1;
    }
    const ap_target: &ExecValue = exec_vm_resolve_va_target(ap_ref_slot);
    if ap_target == null {
        exec_backend_set_error(function.decl, "exec: va_arg 目标无效" as *byte, 0);
        return -1;
    }
    if ap_target.kind != ExecValueKind.EXEC_VALUE_VA_LIST {
        exec_backend_set_error(function.decl, "exec: va_arg 源不是 va_list" as *byte, 0);
        return -1;
    }
    const arg_index: i32 = ap_target.i64_value as i32;
    const arg_count: i32 = ap_target.aux_i64_value as i32;
    if arg_index < 0 || arg_index >= arg_count {
        exec_backend_set_error(function.decl, "exec: va_arg 越界" as *byte, 0);
        return -1;
    }
    const args_ptr: &ExecValue = ap_target.ptr_value as &ExecValue;
    if args_ptr == null {
        exec_backend_set_error(function.decl, "exec: va_arg 数据为空" as *byte, 0);
        return -1;
    }
    const raw_value: ExecValue = args_ptr[arg_index];
    ap_target.i64_value = (arg_index + 1) as i64;
    out_value[0] = exec_vm_cast_value(raw_value, target_kind, target_pointee_kind);
    return 0;
}

fn exec_vm_host_call_site_ref(program: &BCProgram, idx: i32) &BCHostCallSite {
    if program == null || program.host_calls == null || idx < 0 || idx >= program.host_call_count {
        return null;
    }
    return &program.host_calls[idx];
}

fn exec_vm_pointer_load_value(function: &BCFunction, ptr_value: &ExecValue, out_value: &ExecValue) i32 {
    if function == null || ptr_value == null || out_value == null {
        exec_backend_set_error(null, "exec: pointer load helper 输入无效" as *byte, 0);
        return -1;
    }
    if exec_vm_pointer_is_internal_ref(ptr_value) != 0 {
        const target: &ExecValue = exec_vm_ref_target_value(ptr_value);
        if target == null {
            exec_backend_set_error(function.decl, "exec: pointer load helper 目标为空" as *byte, 0);
            return -1;
        }
        out_value[0] = exec_value_clone(target);
        return 0;
    }
    if exec_value_is_pointer_like(ptr_value[0]) != 0 {
        return exec_vm_load_pointer_index(function, ptr_value[0], 0, out_value);
    }
    exec_backend_set_error(function.decl, "exec: pointer load helper 目标不是指针" as *byte, 0);
    return -1;
}

fn exec_vm_pointer_store_value(function: &BCFunction, ptr_value: &ExecValue, src_value: ExecValue) i32 {
    if function == null || ptr_value == null {
        exec_backend_set_error(null, "exec: pointer store helper 输入无效" as *byte, 0);
        return -1;
    }
    if exec_vm_pointer_is_internal_ref(ptr_value) != 0 {
        const target: &ExecValue = exec_vm_ref_target_value(ptr_value);
        if target == null {
            exec_backend_set_error(function.decl, "exec: pointer store helper 目标为空" as *byte, 0);
            return -1;
        }
        exec_vm_store_slot(target, src_value);
        return 0;
    }
    if exec_value_is_pointer_like(ptr_value[0]) != 0 {
        return exec_vm_store_pointer_index(function, ptr_value[0], 0, src_value);
    }
    exec_backend_set_error(function.decl, "exec: pointer store helper 目标不是指针" as *byte, 0);
    return -1;
}

fn exec_vm_call_host(function: &BCFunction, site: &BCHostCallSite, frame: &ExecFrame, arg_base: i32, arg_count: i32, out_value: &ExecValue) i32 {
    if function == null || site == null || frame == null || out_value == null {
        exec_backend_set_error(null, "exec: hostcall 输入无效" as *byte, 0);
        return -1;
    }
    if site.arg_count != arg_count {
        exec_backend_set_error(function.decl, "exec: hostcall 参数数量非法" as *byte, 0);
        return -1;
    }
    if site.id == ExecHostCallId.EXEC_HOST_CALL_PUTS {
        if arg_count != 1 {
            exec_backend_set_error(function.decl, "exec: puts 参数数量非法" as *byte, 0);
            return -1;
        }
        const arg0: &ExecValue = exec_vm_slot_ref(frame, arg_base);
        if arg0 == null {
            exec_backend_set_error(function.decl, "exec: puts 参数槽位非法" as *byte, 0);
            return -1;
        }
        out_value[0] = exec_make_i32(puts(arg0.ptr_value));
        return 0;
    }
    if site.id == ExecHostCallId.EXEC_HOST_CALL_ATOI {
        if arg_count != 1 {
            exec_backend_set_error(function.decl, "exec: atoi 参数数量非法" as *byte, 0);
            return -1;
        }
        const arg0: &ExecValue = exec_vm_slot_ref(frame, arg_base);
        if arg0 == null {
            exec_backend_set_error(function.decl, "exec: atoi 参数槽位非法" as *byte, 0);
            return -1;
        }
        out_value[0] = exec_make_i32(atoi(arg0.ptr_value));
        return 0;
    }
    if site.id == ExecHostCallId.EXEC_HOST_CALL_ATOLL {
        if arg_count != 1 {
            exec_backend_set_error(function.decl, "exec: atoll 参数数量非法" as *byte, 0);
            return -1;
        }
        const arg0: &ExecValue = exec_vm_slot_ref(frame, arg_base);
        if arg0 == null {
            exec_backend_set_error(function.decl, "exec: atoll 参数槽位非法" as *byte, 0);
            return -1;
        }
        out_value[0] = exec_make_i64(atoll(arg0.ptr_value));
        return 0;
    }
    if site.id == ExecHostCallId.EXEC_HOST_CALL_ISQRT {
        if arg_count != 1 {
            exec_backend_set_error(function.decl, "exec: isqrt 参数数量非法" as *byte, 0);
            return -1;
        }
        const arg0: &ExecValue = exec_vm_slot_ref(frame, arg_base);
        if arg0 == null {
            exec_backend_set_error(function.decl, "exec: isqrt 参数槽位非法" as *byte, 0);
            return -1;
        }
        out_value[0] = exec_make_u64(isqrt(arg0.i64_value as u64));
        return 0;
    }
    if site.id == ExecHostCallId.EXEC_HOST_CALL_STRCMP {
        if arg_count != 2 {
            exec_backend_set_error(function.decl, "exec: strcmp 参数数量非法" as *byte, 0);
            return -1;
        }
        const arg0: &ExecValue = exec_vm_slot_ref(frame, arg_base);
        const arg1: &ExecValue = exec_vm_slot_ref(frame, arg_base + 1);
        if arg0 == null || arg1 == null {
            exec_backend_set_error(function.decl, "exec: strcmp 参数槽位非法" as *byte, 0);
            return -1;
        }
        out_value[0] = exec_make_i32(strcmp(arg0.ptr_value, arg1.ptr_value));
        return 0;
    }
    if site.id == ExecHostCallId.EXEC_HOST_CALL_LLABS {
        if arg_count != 1 {
            exec_backend_set_error(function.decl, "exec: llabs 参数数量非法" as *byte, 0);
            return -1;
        }
        const arg0: &ExecValue = exec_vm_slot_ref(frame, arg_base);
        if arg0 == null {
            exec_backend_set_error(function.decl, "exec: llabs 参数槽位非法" as *byte, 0);
            return -1;
        }
        out_value[0] = exec_make_i64(llabs(arg0.i64_value));
        return 0;
    }
    if site.id == ExecHostCallId.EXEC_HOST_CALL_ATOMIC_COMPARE_EXCHANGE {
        if arg_count != 6 {
            exec_backend_set_error(function.decl, "exec: atomic compare_exchange 参数数量非法" as *byte, 0);
            return -1;
        }
        const ptr_arg: &ExecValue = exec_vm_slot_ref(frame, arg_base);
        const expected_arg: &ExecValue = exec_vm_slot_ref(frame, arg_base + 1);
        const desired_arg: &ExecValue = exec_vm_slot_ref(frame, arg_base + 2);
        if ptr_arg == null || expected_arg == null || desired_arg == null {
            exec_backend_set_error(function.decl, "exec: atomic compare_exchange 参数槽位非法" as *byte, 0);
            return -1;
        }
        var current_value: ExecValue = exec_make_void();
        var expected_value: ExecValue = exec_make_void();
        if exec_vm_pointer_load_value(function, ptr_arg, &current_value) != 0 {
            return -1;
        }
        if exec_vm_pointer_load_value(function, expected_arg, &expected_value) != 0 {
            return -1;
        }
        if exec_vm_compare_values(current_value, expected_value) == 0 {
            const pointee_kind: i32 = exec_value_pointer_pointee_kind(&ptr_arg[0]);
            const cast_desired: ExecValue = exec_vm_cast_value(desired_arg[0], pointee_kind, 0);
            if exec_vm_pointer_store_value(function, ptr_arg, cast_desired) != 0 {
                return -1;
            }
            out_value[0] = exec_make_i32(1);
            return 0;
        }
        if exec_vm_pointer_store_value(function, expected_arg, current_value) != 0 {
            return -1;
        }
        out_value[0] = exec_make_i32(0);
        return 0;
    }
    if site.id == ExecHostCallId.EXEC_HOST_CALL_FPRINTF_FIXED {
        if arg_count != 2 {
            exec_backend_set_error(function.decl, "exec: fprintf 参数数量非法" as *byte, 0);
            return -1;
        }
        const arg0: &ExecValue = exec_vm_slot_ref(frame, arg_base);
        const arg1: &ExecValue = exec_vm_slot_ref(frame, arg_base + 1);
        if arg0 == null || arg1 == null {
            exec_backend_set_error(function.decl, "exec: fprintf 参数槽位非法" as *byte, 0);
            return -1;
        }
        const vm_fd: i32 = exec_vm_file_fd_from_value(arg0);
        if vm_fd >= 0 {
            const format_len: usize = strlen(arg1.ptr_value as *const byte);
            out_value[0] = exec_make_i32(write(vm_fd, arg1.ptr_value as &const byte, format_len) as i32);
            return 0;
        }
        out_value[0] = exec_make_i32(fprintf(arg0.ptr_value as &FILE, arg1.ptr_value as &const byte));
        return 0;
    }
    if site.id == ExecHostCallId.EXEC_HOST_CALL_PRINTF_FIXED {
        if arg_count != 1 {
            exec_backend_set_error(function.decl, "exec: printf 参数数量非法" as *byte, 0);
            return -1;
        }
        const arg0: &ExecValue = exec_vm_slot_ref(frame, arg_base);
        if arg0 == null {
            exec_backend_set_error(function.decl, "exec: printf 参数槽位非法" as *byte, 0);
            return -1;
        }
        out_value[0] = exec_make_i32(printf(arg0.ptr_value as &const byte));
        return 0;
    }
    if site.id == ExecHostCallId.EXEC_HOST_CALL_SPRINTF_FIXED {
        if arg_count != 2 {
            exec_backend_set_error(function.decl, "exec: sprintf 参数数量非法" as *byte, 0);
            return -1;
        }
        const arg0: &ExecValue = exec_vm_slot_ref(frame, arg_base);
        const arg1: &ExecValue = exec_vm_slot_ref(frame, arg_base + 1);
        if arg0 == null || arg1 == null {
            exec_backend_set_error(function.decl, "exec: sprintf 参数槽位非法" as *byte, 0);
            return -1;
        }
        out_value[0] = exec_make_i32(sprintf(arg0.ptr_value, arg1.ptr_value as &const byte));
        return 0;
    }
    if site.id == ExecHostCallId.EXEC_HOST_CALL_SNPRINTF_FIXED {
        if arg_count != 3 {
            exec_backend_set_error(function.decl, "exec: snprintf 参数数量非法" as *byte, 0);
            return -1;
        }
        const arg0: &ExecValue = exec_vm_slot_ref(frame, arg_base);
        const arg1: &ExecValue = exec_vm_slot_ref(frame, arg_base + 1);
        const arg2: &ExecValue = exec_vm_slot_ref(frame, arg_base + 2);
        if arg0 == null || arg1 == null || arg2 == null {
            exec_backend_set_error(function.decl, "exec: snprintf 参数槽位非法" as *byte, 0);
            return -1;
        }
        out_value[0] = exec_make_i32(snprintf(arg0.ptr_value, arg1.i64_value as usize, arg2.ptr_value as &const byte));
        return 0;
    }
    exec_backend_set_error(function.decl, "exec: hostcall 目标非法" as *byte, 0);
    return -1;
}

fn vm_step(program: &BCProgram, frame: &ExecFrame, trace_vm: i32, out_value: &ExecValue) i32 {
    if program == null || frame == null || frame.function == null || out_value == null {
        exec_backend_set_error(null, "exec: vm_step 输入无效" as *byte, 0);
        return -1;
    }
    const function: &BCFunction = frame.function;
    if frame.ip < 0 || frame.ip >= function.instr_count {
        exec_backend_set_error(function.decl, "exec: vm_step 指令指针越界" as *byte, 0);
        return -1;
    }
    const instr: &BCInstr = function.instrs + frame.ip;
    exec_vm_trace(trace_vm, function.name, frame.ip, instr);
    const slot_a: &ExecValue = exec_vm_slot_ref(frame, instr.a);
    const slot_b: &ExecValue = exec_vm_slot_ref(frame, instr.b);
    const slot_c: &ExecValue = exec_vm_slot_ref(frame, instr.c);
    if instr.opcode == BCOpcode.BC_LOAD_CONST {
        if slot_a == null {
            exec_backend_set_error(function.decl, "exec: LOAD_CONST 槽位越界" as *byte, 0);
            return -1;
        }
        if exec_vm_load_const(program, function, instr.imm as i32, slot_a) != 0 {
            return -1;
        }
    } else if instr.opcode == BCOpcode.BC_LOAD_LOCAL {
        if slot_a == null || slot_b == null {
            exec_backend_set_error(function.decl, "exec: LOAD_LOCAL 槽位越界" as *byte, 0);
            return -1;
        }
        exec_vm_store_slot(slot_a, slot_b[0]);
    } else if instr.opcode == BCOpcode.BC_LOAD_GLOBAL {
        const global_slot: &ExecValue = exec_vm_global_ref(program, instr.b);
        if slot_a == null || global_slot == null {
            exec_backend_set_error(function.decl, "exec: LOAD_GLOBAL 槽位越界" as *byte, 0);
            return -1;
        }
        exec_vm_store_slot(slot_a, global_slot[0]);
    } else if instr.opcode == BCOpcode.BC_STORE_LOCAL {
        if slot_a == null || slot_b == null {
            exec_backend_set_error(function.decl, "exec: STORE_LOCAL 槽位越界" as *byte, 0);
            return -1;
        }
        exec_vm_store_slot(slot_a, slot_b[0]);
    } else if instr.opcode == BCOpcode.BC_STORE_GLOBAL {
        const global_slot2: &ExecValue = exec_vm_global_ref(program, instr.a);
        if global_slot2 == null || slot_b == null {
            exec_backend_set_error(function.decl, "exec: STORE_GLOBAL 槽位越界" as *byte, 0);
            return -1;
        }
        exec_vm_store_slot(global_slot2, slot_b[0]);
    } else if instr.opcode == BCOpcode.BC_MOV {
        if slot_a == null || slot_b == null {
            exec_backend_set_error(function.decl, "exec: MOV 槽位越界" as *byte, 0);
            return -1;
        }
        exec_vm_store_slot(slot_a, slot_b[0]);
    } else if instr.opcode == BCOpcode.BC_ADDR_LOCAL {
        if slot_a == null || slot_b == null {
            exec_backend_set_error(function.decl, "exec: ADDR_LOCAL 槽位越界" as *byte, 0);
            return -1;
        }
        slot_a[0] = exec_vm_make_value_ref(slot_b, instr.c);
    } else if instr.opcode == BCOpcode.BC_ADDR_GLOBAL {
        const global_slot3: &ExecValue = exec_vm_global_ref(program, instr.b);
        if slot_a == null || global_slot3 == null {
            exec_backend_set_error(function.decl, "exec: ADDR_GLOBAL 槽位越界" as *byte, 0);
            return -1;
        }
        slot_a[0] = exec_vm_make_value_ref(global_slot3, instr.c);
    } else if instr.opcode == BCOpcode.BC_ADDR_FIELD {
        if slot_a == null || slot_b == null {
            exec_backend_set_error(function.decl, "exec: ADDR_FIELD 槽位越界" as *byte, 0);
            return -1;
        }
        const field_ref: &ExecValue = exec_vm_field_ref(slot_b, instr.imm as i32);
        if field_ref == null {
            exec_backend_set_error(function.decl, "exec: ADDR_FIELD 字段越界" as *byte, 0);
            return -1;
        }
        slot_a[0] = exec_vm_make_value_ref(field_ref, instr.c);
    } else if instr.opcode == BCOpcode.BC_ADDR_INDEX {
        if slot_a == null || slot_b == null || slot_c == null {
            exec_backend_set_error(function.decl, "exec: ADDR_INDEX 槽位越界" as *byte, 0);
            return -1;
        }
        var handled_raw_addr: i32 = 0;
        if exec_value_is_raw_array(slot_b) != 0 {
            const raw_ptr_value: ExecValue = exec_vm_raw_array_element_ptr(slot_b, slot_c.i64_value as i32);
            if raw_ptr_value.kind != ExecValueKind.EXEC_VALUE_POINTER {
                exec_backend_set_error(function.decl, "exec: ADDR_INDEX 越界" as *byte, 0);
                return -1;
            }
            slot_a[0] = raw_ptr_value;
            handled_raw_addr = 1;
        } else if exec_value_is_raw_slice(slot_b) != 0 {
            const raw_slice_ptr_value: ExecValue = exec_vm_raw_slice_element_ptr(slot_b, slot_c.i64_value as i32, 0);
            if raw_slice_ptr_value.kind != ExecValueKind.EXEC_VALUE_POINTER {
                exec_backend_set_error(function.decl, "exec: ADDR_INDEX 越界" as *byte, 0);
                return -1;
            }
            slot_a[0] = raw_slice_ptr_value;
            handled_raw_addr = 1;
        } else if exec_vm_pointer_is_internal_ref(slot_b) != 0 {
            const base_target: &ExecValue = exec_vm_ref_target_value(slot_b);
            if exec_value_is_raw_array(base_target) != 0 {
                const raw_ptr_value2: ExecValue = exec_vm_raw_array_element_ptr(base_target, slot_c.i64_value as i32);
                if raw_ptr_value2.kind != ExecValueKind.EXEC_VALUE_POINTER {
                    exec_backend_set_error(function.decl, "exec: ADDR_INDEX 越界" as *byte, 0);
                    return -1;
                }
                slot_a[0] = raw_ptr_value2;
                handled_raw_addr = 1;
            } else if exec_value_is_raw_slice(base_target) != 0 {
                const raw_slice_ptr_value2: ExecValue = exec_vm_raw_slice_element_ptr(base_target, slot_c.i64_value as i32, 0);
                if raw_slice_ptr_value2.kind != ExecValueKind.EXEC_VALUE_POINTER {
                    exec_backend_set_error(function.decl, "exec: ADDR_INDEX 越界" as *byte, 0);
                    return -1;
                }
                slot_a[0] = raw_slice_ptr_value2;
                handled_raw_addr = 1;
            } else if exec_value_is_pointer_like(base_target[0]) != 0 {
                const ptr_index_value: ExecValue = exec_vm_pointer_element_ptr(function, base_target[0], slot_c.i64_value);
                if ptr_index_value.kind != ExecValueKind.EXEC_VALUE_POINTER {
                    return -1;
                }
                slot_a[0] = ptr_index_value;
                handled_raw_addr = 1;
            }
        }
        if handled_raw_addr == 0 {
            const index_ref: &ExecValue = exec_vm_index_ref(slot_b, slot_c.i64_value as i32);
            if index_ref == null {
                exec_backend_set_error(function.decl, "exec: ADDR_INDEX 越界" as *byte, 0);
                return -1;
            }
            slot_a[0] = exec_vm_make_index_value_ref(index_ref, instr.imm as i32);
        }
    } else if instr.opcode == BCOpcode.BC_BOX_VALUE {
        if slot_a == null || slot_b == null {
            exec_backend_set_error(function.decl, "exec: BOX_VALUE 槽位越界" as *byte, 0);
            return -1;
        }
        slot_a[0] = exec_vm_box_value_ref(slot_b[0], instr.c);
    } else if instr.opcode == BCOpcode.BC_ADD {
        if slot_a == null || slot_b == null || slot_c == null {
            exec_backend_set_error(function.decl, "exec: ADD 槽位越界" as *byte, 0);
            return -1;
        }
        const add_kind: ExecValueKind = exec_vm_value_kind_from_type_code(instr.imm as i32, slot_b.kind);
        if exec_vm_value_kind_is_float(add_kind) != 0 {
            slot_a[0] = exec_vm_make_float_by_kind(add_kind, exec_value_as_f64(slot_b) + exec_value_as_f64(slot_c));
        } else if exec_vm_value_kind_is_unsigned(add_kind) != 0 {
            slot_a[0] = exec_vm_make_integer_by_kind(add_kind, 0, (slot_b.i64_value as u64) + (slot_c.i64_value as u64));
        } else {
            slot_a[0] = exec_vm_make_integer_by_kind(add_kind, slot_b.i64_value + slot_c.i64_value, 0);
        }
    } else if instr.opcode == BCOpcode.BC_SUB {
        if slot_a == null || slot_b == null || slot_c == null {
            exec_backend_set_error(function.decl, "exec: SUB 槽位越界" as *byte, 0);
            return -1;
        }
        const sub_kind: ExecValueKind = exec_vm_value_kind_from_type_code(instr.imm as i32, slot_b.kind);
        if exec_vm_value_kind_is_float(sub_kind) != 0 {
            slot_a[0] = exec_vm_make_float_by_kind(sub_kind, exec_value_as_f64(slot_b) - exec_value_as_f64(slot_c));
        } else if exec_vm_value_kind_is_unsigned(sub_kind) != 0 {
            slot_a[0] = exec_vm_make_integer_by_kind(sub_kind, 0, (slot_b.i64_value as u64) - (slot_c.i64_value as u64));
        } else {
            slot_a[0] = exec_vm_make_integer_by_kind(sub_kind, slot_b.i64_value - slot_c.i64_value, 0);
        }
    } else if instr.opcode == BCOpcode.BC_MUL {
        if slot_a == null || slot_b == null || slot_c == null {
            exec_backend_set_error(function.decl, "exec: MUL 槽位越界" as *byte, 0);
            return -1;
        }
        const mul_kind: ExecValueKind = exec_vm_value_kind_from_type_code(instr.imm as i32, slot_b.kind);
        if exec_vm_value_kind_is_float(mul_kind) != 0 {
