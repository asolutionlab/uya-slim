// parser.uya - 语法分析器
// Uya 自举编译器
//
// 注意：Uya 没有 union，所有 union 字段都转换为结构体的独立字段
// 注意：Uya 不支持指针运算，ptr + i 必须转换为 &ptr[i]
// 注意：Uya 不支持函数前向声明，函数必须在使用前定义

// Lexer 函数前向声明（确保生成的 C 中在 parser_init 之前有声明，避免隐式声明）
extern fn lexer_next_token(lexer: &Lexer, arena: &CompilerArena) &Token;
extern fn lexer_init(lexer: &Lexer, source: &byte, source_len: usize, filename: &byte, arena: &CompilerArena) i32;
// 标准库函数（用于错误报告）
use libc;

// 全局常量（用于安全证明）
const MAX_INTERP_SEGMENTS: i32 = 64;
const MAX_GENERIC_NAME_BUF: i32 = 512;

// 解析上下文类型
enum ParserContext {
    PARSER_CONTEXT_NORMAL,          // 普通表达式上下文
    PARSER_CONTEXT_VAR_INIT,        // 变量初始化上下文（var/const 声明中的 = 后面的表达式）
    PARSER_CONTEXT_CONDITION        // 条件表达式上下文（if/while 后面的表达式）
}

// 语法分析器结构体
// 使用 Lexer 读取 Token，构建 AST
struct Parser {
    lexer: &Lexer,           // 词法分析器指针（由调用者提供，不分配）
    current_token: &Token,    // 当前 Token（从 Arena 分配）
    arena: &CompilerArena,            // Arena 分配器（用于分配 Token 和 AST 节点）
    context: ParserContext,  // 当前解析上下文
    pending_greater_token: &Token,  // 待处理的 > token（用于嵌套泛型 >> 拆分）
    saw_use_std: i32,        // 当前文件中是否已显式出现 use std;
    has_error: i32,          // 当前文件解析期间是否已报告语法错误
}

// 初始化 Parser
// 参数：parser - Parser 结构体指针（由调用者提供），lexer - Lexer 指针，arena - Arena 分配器
// 返回：成功返回 0，失败返回 -1
// 注意：Parser 结构体由调用者在栈上或静态分配，此函数只负责初始化
fn parser_init(parser: &Parser, lexer: &Lexer, arena: &CompilerArena) i32 {
    if parser == null || lexer == null || arena == null {
        return -1;
    }
    
    parser.lexer = lexer;
    parser.arena = arena;
    parser.context = ParserContext.PARSER_CONTEXT_NORMAL;  // 默认上下文
    parser.pending_greater_token = null;  // 初始化待处理的 > token
    parser.saw_use_std = 0;
    parser.has_error = 0;
    
    // 获取第一个 Token
    parser.current_token = lexer_next_token(lexer, arena);
    
    return 0;
}

// 辅助函数：检查当前 Token 类型是否匹配
fn parser_match(parser: &Parser, type: TokenType) i32 {
    if parser == null {
        return 0;
    }
    // 如果有待处理的 > token，优先检查它
    if parser.pending_greater_token != null {
        if parser.pending_greater_token.type == type {
            return 1;
        } else {
            return 0;
        }
    }
    if parser.current_token == null {
        return 0;
    }
    if parser.current_token.type == type {
        return 1;
    } else {
        return 0;
    }
}

// 辅助函数：消费当前 Token 并获取下一个
fn parser_consume(parser: &Parser) &Token {
    if parser == null {
        return null;
    }
    
    // 检查是否有待处理的 > token（用于嵌套泛型 >> 拆分）
    if parser.pending_greater_token != null {
        const pending: &Token = parser.pending_greater_token;
        parser.pending_greater_token = null;
        return pending;
    }
    
    if parser.current_token == null {
        return null;
    }
    
    const current: &Token = parser.current_token;
    parser.current_token = lexer_next_token(parser.lexer, parser.arena);
    return current;
}

// 辅助函数：期望特定类型的 Token
fn parser_expect(parser: &Parser, type: TokenType) &Token {
    if parser == null {
        return null;
    }

    // 如果有待处理的 > token，优先检查它
    if parser.pending_greater_token != null {
        if parser.pending_greater_token.type != type {
            return null;
        }
        return parser_consume(parser);
    }

    if parser.current_token == null {
        return null;
    }

    if parser.current_token.type != type {
        // 错误：期望的类型不匹配
        var filename: &byte = "(unknown)" as *byte;
        if parser.lexer != null && parser.lexer.filename != null {
            filename = parser.lexer.filename;
        }

        var error_msg: [byte: 200] = [];
        var len: i32 = snprintf(error_msg as *byte, 200, "意外的 token" as *byte);
        if parser.current_token.value != null && len >= 0 && len < 199 {
            snprintf((error_msg as *byte) + len, 200 - len, " '%s'" as *byte, parser.current_token.value as *byte);
        }
        parser_report_syntax_error(parser, error_msg as &byte);
        return null;
    }

    return parser_consume(parser);
}

// 辅助函数：期望变量初始化符 '='，未提供时给出友好错误
fn parser_expect_var_init(parser: &Parser, type_node: &ASTNode) &Token {
    if parser == null || parser.current_token == null {
        return null;
    }

    // 如果有待处理的 > token，优先检查它
    if parser.pending_greater_token != null {
        if parser.pending_greater_token.type != TokenType.TOKEN_ASSIGN {
            return null;
        }
        return parser_consume(parser);
    }

    if parser.current_token.type != TokenType.TOKEN_ASSIGN {
        parser_report_uninitialized_var(parser, type_node);
        return null;
    }

    return parser_consume(parser);
}

// 从 Arena 复制字符串
// 注意：需要 extern 函数 strlen 和 memcpy
// 这些函数在 extern_decls.uya 中已声明，这里不需要重复声明

fn arena_strdup(arena: &CompilerArena, src: &byte) &byte {
    if arena == null || src == null {
        return null;
    }

    const str_len: usize = strlen(src as *byte) + 1;
    const result: &byte = compiler_arena_alloc(arena, str_len) as &byte;
    if result == null {
        return null;
    }

    memcpy(result as *void, src as *void, str_len);
    return result;
}

// 统一的语法错误报告函数
fn parser_report_syntax_error(parser: &Parser, message: &byte) void {
    if parser == null {
        return;
    }
    parser.has_error = 1;

    var filename: &byte = "(unknown)" as *byte;
    if parser.lexer != null && parser.lexer.filename != null {
        filename = parser.lexer.filename;
    }

    const line: i32 = parser.current_token.line;
    const column: i32 = parser.current_token.column;

    fprintf(libc.stderr, "错误: 语法分析失败 (%s:%d:%d): %s\n" as *byte, filename, line, column, message);
}

// 报告变量未初始化错误，提供初始化示例
fn parser_report_uninitialized_var(parser: &Parser, type_node: &ASTNode) void {
    if parser == null || type_node == null {
        return;
    }

    // 检查是否是数组类型
    var is_array: i32 = 0;
    if type_node.type == ASTNodeType.AST_TYPE_ARRAY {
        is_array = 1;
    }

    if is_array != 0 {
        parser_report_syntax_error(parser, "数组必须初始化" as *byte);
        fprintf(libc.stderr, "  提示: 空数组初始化 var buf: [byte: 100] = []; 或全零初始化 var buf: [byte: 100] = [0:100];\n" as *byte);
    } else {
        parser_report_syntax_error(parser, "变量/常量必须初始化" as *byte);
        fprintf(libc.stderr, "  提示: 提供初始值，例如: var x: i32 = 0;\n" as *byte);
    }
}

// 辅助函数：检查当前 token（'{'）后面是否是结构体字段初始化列表的开始
// 结构体字段初始化列表格式：identifier: expr 或 }
// 注意：调用此函数时，parser.current_token 应该是 '{'
fn parser_peek_is_struct_init(parser: &Parser) i32 {
    if parser == null || parser.lexer == null || parser.current_token == null {
        return 0;
    }
    const lexer: &Lexer = parser.lexer;
    if lexer.string_mode != 0 || lexer.interp_depth > 0 {
        return 0;
    }
    if parser.current_token.type != TokenType.TOKEN_LEFT_BRACE {
        return 0;
    }
    
    // 保存 lexer 状态（当前 lexer 的 position 已经在 '{' 之后）
    var saved_position: usize = lexer.position;
    var saved_line: i32 = lexer.line;
    var saved_column: i32 = lexer.column;
    
    // 获取 '{' 后面的 token（lexer_next_token 会跳过空白字符和注释）
    const after_brace: &Token = lexer_next_token(lexer, parser.arena);
    
    if after_brace == null {
        // 恢复状态
        lexer.position = saved_position;
        lexer.line = saved_line;
        lexer.column = saved_column;
        return 0;
    }
    
    const token_type: TokenType = after_brace.type;
    var is_struct_init: i32 = 0;
    
    // 检查 identifier: 模式或空的 {}
    if token_type == TokenType.TOKEN_RIGHT_BRACE {
        // 空的 {}：在表达式上下文中，可能是结构体字面量，也可能是代码块
        // 采用保守策略：空的 `{}` 在表达式上下文中，优先认为是结构体字面量
        is_struct_init = 1;
    } else if token_type == TokenType.TOKEN_IDENTIFIER || token_type == TokenType.TOKEN_TYPE {
        // 检查标识符后面是否有 ':'
        // 允许 'type' 关键字作为字段名（常见字段名）
        var saved_position2: usize = lexer.position;
        var saved_line2: i32 = lexer.line;
        var saved_column2: i32 = lexer.column;
        
        const after_identifier: &Token = lexer_next_token(lexer, parser.arena);
        if after_identifier != null && after_identifier.type == TokenType.TOKEN_COLON {
            is_struct_init = 1;
        }
        
        // 恢复状态到标识符之前（after_brace 之后）
        lexer.position = saved_position2;
        lexer.line = saved_line2;
        lexer.column = saved_column2;
    }
    
    // 恢复 lexer 状态到 '{' 之后（原始位置）
    lexer.position = saved_position;
    lexer.line = saved_line;
    lexer.column = saved_column;
    
    return is_struct_init;
}

// 若当前为 '{' 且下一 token 为 '}' 则返回 1（用于将 Pending({}) 等中的 {} 解析为空块）
fn parser_peek_next_is_rbrace(parser: &Parser) i32 {
    if parser == null || parser.lexer == null || parser.current_token == null {
        return 0;
    }
    if parser.current_token.type != TokenType.TOKEN_LEFT_BRACE {
        return 0;
    }
    const lexer: &Lexer = parser.lexer;
    var saved_position: usize = lexer.position;
    var saved_line: i32 = lexer.line;
    var saved_column: i32 = lexer.column;
    const next: &Token = lexer_next_token(lexer, parser.arena);
    lexer.position = saved_position;
    lexer.line = saved_line;
    lexer.column = saved_column;
    if next != null && next.type == TokenType.TOKEN_RIGHT_BRACE {
        return 1;
    }
    return 0;
}

// 前向声明（Uya 不支持，需要重新组织函数顺序）
// 注意：这些函数会在后面定义，但需要先声明以便递归调用
// 由于 Uya 不支持前向声明，我们需要重新组织函数顺序
// 这里先定义基础表达式解析函数，然后定义更复杂的表达式解析函数

// 辅助函数：获取文件名（用于 ast_new_node）
fn parser_get_filename(parser: &Parser) &byte {
    if parser != null && parser.lexer != null {
        return parser.lexer.filename;
    }
    return null;
}

fn parser_make_empty_cfg_decl_result(parser: &Parser) &ASTNode {
    var line: i32 = 0;
    var column: i32 = 0;
    if parser != null && parser.current_token != null {
        line = parser.current_token.line;
        column = parser.current_token.column;
    }
    return ast_new_node(ASTNodeType.AST_PROGRAM, line, column, parser.arena, parser_get_filename(parser));
}

fn parser_make_empty_cfg_stmt_result(parser: &Parser) &ASTNode {
    var line: i32 = 0;
    var column: i32 = 0;
    if parser != null && parser.current_token != null {
        line = parser.current_token.line;
        column = parser.current_token.column;
    }
    return ast_new_node(ASTNodeType.AST_BLOCK, line, column, parser.arena, parser_get_filename(parser));
}

fn parser_note_use_std_import(parser: &Parser, node: &ASTNode) void {
    if parser == null || node == null || node.type != ASTNodeType.AST_USE_STMT {
        return;
    }
    if node.use_stmt_alias != null || node.use_stmt_item_name != null {
        return;
    }
    if node.use_stmt_path_segment_count != 1 || node.use_stmt_path_segments == null {
        return;
    }
    const seg0: &byte = node.use_stmt_path_segments[0];
    if seg0 != null && strcmp(seg0 as *byte, "std" as *byte) == 0 {
        parser.saw_use_std = 1;
    }
}

fn parser_peek_is_std_cfg_call(parser: &Parser) i32 {
    if parser == null || parser.lexer == null || parser.current_token == null {
        return 0;
    }
    if parser.current_token.type != TokenType.TOKEN_IDENTIFIER || parser.current_token.value == null {
        return 0;
    }
    if strcmp(parser.current_token.value as *byte, "std" as *byte) != 0 {
        return 0;
    }
    const lexer: &Lexer = parser.lexer;
    var saved_position: usize = lexer.position;
    var saved_line: i32 = lexer.line;
    var saved_column: i32 = lexer.column;
    const dot_tok: &Token = lexer_next_token(lexer, parser.arena);
    const name_tok: &Token = lexer_next_token(lexer, parser.arena);
    const lparen_tok: &Token = lexer_next_token(lexer, parser.arena);
    lexer.position = saved_position;
    lexer.line = saved_line;
    lexer.column = saved_column;
    if dot_tok == null || name_tok == null || lparen_tok == null {
        return 0;
    }
    if dot_tok.type != TokenType.TOKEN_DOT || lparen_tok.type != TokenType.TOKEN_LEFT_PAREN {
        return 0;
    }
    if name_tok.type != TokenType.TOKEN_IDENTIFIER || name_tok.value == null {
        return 0;
    }
    if strcmp(name_tok.value as *byte, "cfg" as *byte) != 0 {
        return 0;
    }
    return 1;
}

fn parser_require_std_for_cfg(parser: &Parser) i32 {
    if parser == null {
        return 0;
    }
    if parser.saw_use_std != 0 {
        return 1;
    }
    parser_report_syntax_error(parser, "使用 std.cfg 前必须先写 use std;" as *byte);
    return 0;
}

fn parser_parse_std_cfg_predicate(parser: &Parser) i32 {
    if parser == null || parser.current_token == null {
        return -1;
    }
    if parser.current_token.type != TokenType.TOKEN_IDENTIFIER || parser.current_token.value == null ||
        strcmp(parser.current_token.value as *byte, "std" as *byte) != 0 {
        parser_report_syntax_error(parser, "std.cfg 的条件当前仅支持 std.host_os/std.host_arch/std.target_os/std.target_arch" as *byte);
        return -1;
    }
    parser_consume(parser);  // std
    if parser_expect(parser, TokenType.TOKEN_DOT) == null {
        return -1;
    }
    if parser.current_token == null || parser.current_token.type != TokenType.TOKEN_IDENTIFIER || parser.current_token.value == null {
        parser_report_syntax_error(parser, "std.cfg 条件缺少平台选择器" as *byte);
        return -1;
    }
    const selector: &byte = parser.current_token.value;
    parser_consume(parser);

    var is_equal: i32 = 1;
    if parser_match(parser, TokenType.TOKEN_EQUAL) != 0 {
        parser_consume(parser);
        is_equal = 1;
    } else if parser_match(parser, TokenType.TOKEN_NOT_EQUAL) != 0 {
        parser_consume(parser);
        is_equal = 0;
    } else {
        parser_report_syntax_error(parser, "std.cfg 条件当前仅支持 == 或 !=" as *byte);
        return -1;
    }

    if parser_expect(parser, TokenType.TOKEN_DOT) == null {
        return -1;
    }
    if parser.current_token == null || parser.current_token.type != TokenType.TOKEN_IDENTIFIER || parser.current_token.value == null {
        parser_report_syntax_error(parser, "std.cfg 条件缺少平台枚举变体名" as *byte);
        return -1;
    }
    const variant: &byte = parser.current_token.value;
    parser_consume(parser);

    const matched: i32 = std_cfg_selector_matches(selector, variant);
    if matched < 0 {
        parser_report_syntax_error(parser, "std.cfg 条件包含未知的平台选择器或变体" as *byte);
        return -1;
    }
    if is_equal != 0 {
        return matched;
    }
    if matched != 0 {
        return 0;
    }
    return 1;
}

fn parser_parse_cfg_decl_block(parser: &Parser) &ASTNode {
    if parser == null || parser.current_token == null || parser_match(parser, TokenType.TOKEN_LEFT_BRACE) == 0 {
        return null;
    }
    const line: i32 = parser.current_token.line;
    const column: i32 = parser.current_token.column;
    const block_program: &ASTNode = ast_new_node(ASTNodeType.AST_PROGRAM, line, column, parser.arena, parser_get_filename(parser));
    if block_program == null {
        return null;
    }
    var decls: & & ASTNode = null;
    var decl_count: i32 = 0;
    var decl_capacity: i32 = 0;
    parser_consume(parser);  // 消费 '{'
    while parser.current_token != null &&
          parser_match(parser, TokenType.TOKEN_RIGHT_BRACE) == 0 &&
          parser_match(parser, TokenType.TOKEN_EOF) == 0 {
        const decl: &ASTNode = parser_parse_declaration(parser);
        if decl == null {
            return null;
        }
        if decl.type == ASTNodeType.AST_PROGRAM {
            var inner_i: i32 = 0;
            while inner_i < decl.program_decl_count {
                const inner_decl: &ASTNode = decl.program_decls[inner_i];
                if inner_decl != null {
                    if decl_count >= decl_capacity {
                        var new_capacity: i32 = 4;
                        if decl_capacity != 0 {
                            new_capacity = decl_capacity * 2;
                        }
                        const new_decls: & & ASTNode = compiler_arena_alloc(parser.arena, @size_of(&ASTNode) * new_capacity) as & & ASTNode;
                        if new_decls == null {
                            return null;
                        }
                        var copy_i: i32 = 0;
                        while copy_i < decl_count {
                            if decls != null {
                                new_decls[copy_i] = decls[copy_i];
                            }
                            copy_i = copy_i + 1;
                        }
                        decls = new_decls;
                        decl_capacity = new_capacity;
                    }
                    if decls == null {
                        return null;
                    }
                    decls[decl_count] = inner_decl;
                    decl_count = decl_count + 1;
                }
                inner_i = inner_i + 1;
            }
        } else {
            if decl_count >= decl_capacity {
                var new_capacity2: i32 = 4;
                if decl_capacity != 0 {
                    new_capacity2 = decl_capacity * 2;
                }
                const new_decls2: & & ASTNode = compiler_arena_alloc(parser.arena, @size_of(&ASTNode) * new_capacity2) as & & ASTNode;
                if new_decls2 == null {
                    return null;
                }
                var copy_i2: i32 = 0;
                while copy_i2 < decl_count {
                    if decls != null {
                        new_decls2[copy_i2] = decls[copy_i2];
                    }
                    copy_i2 = copy_i2 + 1;
                }
                decls = new_decls2;
                decl_capacity = new_capacity2;
            }
            if decls == null {
                return null;
            }
            decls[decl_count] = decl;
            decl_count = decl_count + 1;
        }
    }
    if parser_expect(parser, TokenType.TOKEN_RIGHT_BRACE) == null {
        return null;
    }
    block_program.program_decls = decls;
    block_program.program_decl_count = decl_count;
    return block_program;
}

fn parser_parse_std_cfg_decl_arg(parser: &Parser) &ASTNode {
    if parser == null || parser.current_token == null {
        return null;
    }
    if parser_match(parser, TokenType.TOKEN_LEFT_BRACE) != 0 {
        return parser_parse_cfg_decl_block(parser);
    }
    return parser_parse_declaration(parser);
}

fn parser_parse_std_cfg_decl(parser: &Parser) &ASTNode {
    if parser == null || parser_peek_is_std_cfg_call(parser) == 0 {
        return null;
    }
    if parser_require_std_for_cfg(parser) == 0 {
        return null;
    }
    parser_consume(parser);  // std
    if parser_expect(parser, TokenType.TOKEN_DOT) == null {
        return null;
    }
    if parser.current_token == null || parser.current_token.type != TokenType.TOKEN_IDENTIFIER || parser.current_token.value == null ||
        strcmp(parser.current_token.value as *byte, "cfg" as *byte) != 0 {
        parser_report_syntax_error(parser, "顶层当前仅支持 std.cfg(...)" as *byte);
        return null;
    }
    parser_consume(parser);  // cfg
    if parser_expect(parser, TokenType.TOKEN_LEFT_PAREN) == null {
        return null;
    }
    const take_then: i32 = parser_parse_std_cfg_predicate(parser);
    if take_then < 0 {
        return null;
    }
    if parser_expect(parser, TokenType.TOKEN_COMMA) == null {
        return null;
    }

    var result: &ASTNode = null;
    if take_then != 0 {
        result = parser_parse_std_cfg_decl_arg(parser);
        if result == null {
            return null;
        }
        if parser_match(parser, TokenType.TOKEN_COMMA) != 0 {
            parser_consume(parser);
            const saved_use_std: i32 = parser.saw_use_std;
            const discarded: &ASTNode = parser_parse_std_cfg_decl_arg(parser);
            if discarded == null {
                return null;
            }
            parser.saw_use_std = saved_use_std;
        }
    } else {
        const saved_use_std: i32 = parser.saw_use_std;
        const discarded: &ASTNode = parser_parse_std_cfg_decl_arg(parser);
        if discarded == null {
            return null;
        }
        parser.saw_use_std = saved_use_std;
        if parser_match(parser, TokenType.TOKEN_COMMA) != 0 {
            parser_consume(parser);
            result = parser_parse_std_cfg_decl_arg(parser);
            if result == null {
                return null;
            }
        } else {
            result = parser_make_empty_cfg_decl_result(parser);
            if result == null {
                return null;
            }
        }
    }

    if parser_expect(parser, TokenType.TOKEN_RIGHT_PAREN) == null {
        return null;
    }
    return result;
}

fn parser_parse_std_cfg_stmt_arg(parser: &Parser) &ASTNode {
    if parser == null || parser.current_token == null {
        return null;
    }
    if parser_match(parser, TokenType.TOKEN_LEFT_BRACE) != 0 {
        return parser_parse_block(parser);
    }
    return parser_parse_statement(parser);
}

fn parser_parse_std_cfg_stmt(parser: &Parser) &ASTNode {
    if parser == null || parser_peek_is_std_cfg_call(parser) == 0 {
        return null;
    }
    if parser_require_std_for_cfg(parser) == 0 {
        return null;
    }
    parser_consume(parser);  // std
    if parser_expect(parser, TokenType.TOKEN_DOT) == null {
        return null;
    }
    if parser.current_token == null || parser.current_token.type != TokenType.TOKEN_IDENTIFIER || parser.current_token.value == null ||
        strcmp(parser.current_token.value as *byte, "cfg" as *byte) != 0 {
        parser_report_syntax_error(parser, "语句位置当前仅支持 std.cfg(...)" as *byte);
        return null;
    }
    parser_consume(parser);  // cfg
    if parser_expect(parser, TokenType.TOKEN_LEFT_PAREN) == null {
        return null;
    }
    const take_then: i32 = parser_parse_std_cfg_predicate(parser);
    if take_then < 0 {
        return null;
    }
    if parser_expect(parser, TokenType.TOKEN_COMMA) == null {
        return null;
    }

    var result: &ASTNode = null;
    if take_then != 0 {
        result = parser_parse_std_cfg_stmt_arg(parser);
        if result == null {
            return null;
        }
        if parser_match(parser, TokenType.TOKEN_COMMA) != 0 {
            parser_consume(parser);
            const saved_use_std: i32 = parser.saw_use_std;
            const discarded: &ASTNode = parser_parse_std_cfg_stmt_arg(parser);
            if discarded == null {
                return null;
            }
            parser.saw_use_std = saved_use_std;
        }
    } else {
        const saved_use_std: i32 = parser.saw_use_std;
        const discarded: &ASTNode = parser_parse_std_cfg_stmt_arg(parser);
        if discarded == null {
            return null;
        }
        parser.saw_use_std = saved_use_std;
        if parser_match(parser, TokenType.TOKEN_COMMA) != 0 {
            parser_consume(parser);
            result = parser_parse_std_cfg_stmt_arg(parser);
            if result == null {
                return null;
            }
        } else {
            result = parser_make_empty_cfg_stmt_result(parser);
            if result == null {
                return null;
            }
        }
    }

    if parser_expect(parser, TokenType.TOKEN_RIGHT_PAREN) == null {
        return null;
    }
    return result;
}

// 解析类型（支持命名类型、指针类型和数组类型）

// 解析声明（函数、结构体或变量声明）
fn parser_parse_declaration(parser: &Parser) &ASTNode {
    if parser == null || parser.current_token == null {
        return null;
    }
    
    // 检查 use 语句
    if parser_match(parser, TokenType.TOKEN_USE) != 0 {
        const use_stmt: &ASTNode = parser_parse_use_stmt(parser);
        parser_note_use_std_import(parser, use_stmt);
        return use_stmt;
    }
    
    // 检查 test 语句（可以在顶层声明）
    if parser_match(parser, TokenType.TOKEN_TEST) != 0 {
        return parser_parse_statement(parser);
    }

    if parser_peek_is_std_cfg_call(parser) != 0 {
        return parser_parse_std_cfg_decl(parser);
    }

    if parser.current_token.type == TokenType.TOKEN_AT_IDENTIFIER &&
        parser.current_token.value != null &&
        str_equals_lexer(parser.current_token.value, "c_import" as &byte) != 0 {
        return parser_parse_c_import_decl(parser);
    }
    
    // 检查 export 关键字
    var is_export: i32 = 0;
    if parser_match(parser, TokenType.TOKEN_EXPORT) != 0 {
        is_export = 1;
        parser_consume(parser);
    }
    
    // 检查 @align(N) 函数属性
    var align_val: i32 = 0;
    if parser.current_token != null && parser.current_token.type == TokenType.TOKEN_AT_IDENTIFIER &&
        parser.current_token.value != null {
        if str_equals_lexer(parser.current_token.value, "align" as &byte) != 0 {
            parser_consume(parser);  // 消费 @align
            if parser_expect(parser, TokenType.TOKEN_LEFT_PAREN) == null {
                return null;
            }
            if parser.current_token == null || parser.current_token.type != TokenType.TOKEN_NUMBER {
                fprintf(libc.stderr, "错误: @align(N) 需要整数常量参数\n" as *byte);
                return null;
            }
            align_val = atoi(parser.current_token.value as *byte);
            parser_consume(parser);
            if parser_expect(parser, TokenType.TOKEN_RIGHT_PAREN) == null {
                return null;
            }
        }
    }

    // 检查 @async_fn / @naked_fn 函数属性
    var is_async: i32 = 0;
    var is_naked: i32 = 0;
    if parser.current_token != null && parser.current_token.type == TokenType.TOKEN_AT_IDENTIFIER &&
        parser.current_token.value != null {
        if str_equals_lexer(parser.current_token.value, "async_fn" as &byte) != 0 {
            is_async = 1;
            parser_consume(parser);  // 消费 @async_fn
            // @async_fn 后必须跟着 fn
            if parser_match(parser, TokenType.TOKEN_FN) == 0 {
                fprintf(libc.stderr, "错误: @async_fn 后必须跟着 fn 关键字\n" as *byte);
                return null;
            }
        } else if str_equals_lexer(parser.current_token.value, "naked_fn" as &byte) != 0 {
            is_naked = 1;
            parser_consume(parser);  // 消费 @naked_fn
        }
    }
    
    // 根据第一个 Token 判断声明类型
    if parser_match(parser, TokenType.TOKEN_EXTERN) != 0 {
        if is_async != 0 {
            fprintf(libc.stderr, "错误: extern 函数不能使用 @async_fn 属性\n" as *byte);
            return null;
        }
        if is_naked != 0 {
            fprintf(libc.stderr, "错误: extern 函数不能使用 @naked_fn 属性\n" as *byte);
            return null;
        }
        parser_consume(parser);
        // 检查是否有字符串字面量（extern "libc" fn）
        var extern_lib_name: &byte = null;
        if parser_match(parser, TokenType.TOKEN_STRING) != 0 {
            extern_lib_name = arena_strdup(parser.arena, parser.current_token.value);
            if extern_lib_name == null {
                return null;
            }
            parser_consume(parser);
        }
        const decl: &ASTNode = parser_parse_extern_decl(parser, extern_lib_name, is_export);
        if decl != null && is_export != 0 {
            // 设置 export 标记（extern 函数/结构体）
            if decl.type == ASTNodeType.AST_FN_DECL {
                decl.fn_decl_is_export = 1;
            } else if decl.type == ASTNodeType.AST_STRUCT_DECL {
                decl.struct_decl_is_export = 1;
            } else if decl.type == ASTNodeType.AST_UNION_DECL {
                decl.union_decl_is_export = 1;
            }
            // AST_EXTERN_VAR_DECL 的标记在 parser_parse_extern_decl 中已设置
        }
        return decl;
    } else if parser_match(parser, TokenType.TOKEN_FN) != 0 {
        const decl: &ASTNode = parser_parse_function(parser);
        if decl != null {
            if is_export != 0 {
                decl.fn_decl_is_export = 1;
            }
            if is_async != 0 {
                decl.fn_decl_is_async = 1;
            }
            if is_naked != 0 {
                decl.fn_decl_is_naked = 1;
            }
            if align_val > 0 {
                decl.fn_decl_align = align_val;
            }
        }
        return decl;
    } else if parser_match(parser, TokenType.TOKEN_ERROR) != 0 {
        const decl: &ASTNode = parser_parse_error_decl(parser);
        if decl != null && is_export != 0 {
            decl.error_decl_is_export = 1;
        }
        return decl;
    } else if parser_match(parser, TokenType.TOKEN_ENUM) != 0 {
        const decl: &ASTNode = parser_parse_enum(parser);
        if decl != null && is_export != 0 {
            decl.enum_decl_is_export = 1;
        }
        return decl;
    } else if parser_match(parser, TokenType.TOKEN_INTERFACE) != 0 {
        const decl: &ASTNode = parser_parse_interface(parser);
        if decl != null && is_export != 0 {
            decl.interface_decl_is_export = 1;
        }
        return decl;
    } else if parser_match(parser, TokenType.TOKEN_STRUCT) != 0 {
        const decl: &ASTNode = parser_parse_struct(parser);
        if decl != null && is_export != 0 {
            decl.struct_decl_is_export = 1;
        }
        return decl;
    } else if parser_match(parser, TokenType.TOKEN_UNION) != 0 {
        const decl: &ASTNode = parser_parse_union(parser);
        if decl != null && is_export != 0 {
            decl.union_decl_is_export = 1;
        }
                return decl;
    } else if parser_match(parser, TokenType.TOKEN_MC) != 0 {
        const decl: &ASTNode = parser_parse_macro(parser);
        if decl != null && is_export != 0 {
            decl.macro_decl_is_export = 1;
        }
        return decl;
    } else if parser_match(parser, TokenType.TOKEN_TYPE) != 0 {
        const decl: &ASTNode = parser_parse_type_alias(parser);
        if decl != null && is_export != 0 {
            decl.type_alias_is_export = 1;
        }
        return decl;
    } else if parser_match(parser, TokenType.TOKEN_IDENTIFIER) != 0 {
const name: &byte = arena_strdup(parser.arena, parser.current_token.value);
        if name == null {
            return null;
        }
        parser_consume(parser);
        if parser.current_token != null && parser_match(parser, TokenType.TOKEN_LEFT_BRACE) != 0 {
            parser_consume(parser);
            return parser_parse_method_block(parser, name);
        }
        var filename: &byte = "(unknown)" as *byte;
        if parser.lexer != null && parser.lexer.filename != null {
            filename = parser.lexer.filename;
        }
        fprintf(libc.stderr, "错误: 语法分析失败 (%s:%d:%d): 顶层标识符 '%s' 后期望 '{'（方法块）\n" as *byte,
                filename, parser.current_token.line, parser.current_token.column, name);
        return null;
    } else if parser_match(parser, TokenType.TOKEN_CONST) != 0 || parser_match(parser, TokenType.TOKEN_VAR) != 0 {
        // 变量声明
        // 注意：export const/var 使用 AST_EXTERN_VAR_DECL，普通 const/var 使用 AST_VAR_DECL
        if is_export != 0 {
            // export const/var name: type = value;
            var is_const: i32 = 0;
            if parser_match(parser, TokenType.TOKEN_CONST) != 0 {
                is_const = 1;
            }
            parser_consume(parser);
            const decl: &ASTNode = parser_parse_export_var_decl(parser, is_const, is_export);
            return decl;
        } else {
            // 普通 const/var
            const decl: &ASTNode = parser_parse_statement(parser);
            return decl;
        }
    } else {
        // 无法识别的声明类型
        return null;
    }
}

// 解析程序（顶层声明列表）
fn parser_parse(parser: &Parser) &ASTNode {
    if parser == null || parser.current_token == null {
        return null;
    }
    
    // 创建程序节点
    const line: i32 = parser.current_token.line;
    const column: i32 = parser.current_token.column;
    
    const program: &ASTNode = ast_new_node(ASTNodeType.AST_PROGRAM, line, column, parser.arena, parser_get_filename(parser));
    if program == null {
        return null;
    }
    
    // 初始化声明列表
    program.program_decls = null;
    program.program_decl_count = 0;
    
    // 解析顶层声明列表
    var decls: & & ASTNode = null;
    var decl_count: i32 = 0;
    var decl_capacity: i32 = 0;
    
    while parser.current_token != null && parser_match(parser, TokenType.TOKEN_EOF) == 0 {
        const decl: &ASTNode = parser_parse_declaration(parser);
        if decl == null {
            // 解析失败：检查是否因为到达文件末尾（EOF）还是真正的错误
            // 如果当前 token 不是 EOF，说明遇到了真正的解析错误
            if parser.current_token != null && parser_match(parser, TokenType.TOKEN_EOF) == 0 {
                // 真正的解析错误：输出错误信息并返回 null（与 C 版一致）
                var filename: &byte = "(unknown)" as *byte;
                if parser.lexer != null && parser.lexer.filename != null {
                    filename = parser.lexer.filename;
                }
                fprintf(libc.stderr, "错误: 语法分析失败 (%s:%d:%d): 意外的 token" as *byte, filename, parser.current_token.line, parser.current_token.column);
                if parser.current_token.value != null {
                    fprintf(libc.stderr, " '%s'" as *byte, parser.current_token.value);
                }
                fprintf(libc.stderr, "\n" as *byte);
                return null;
            }
            if parser.current_token == null {
                // current_token 为 null 时也报告，便于排查自举失败
                var filename: &byte = "(unknown)" as *byte;
                if parser.lexer != null && parser.lexer.filename != null {
                    filename = parser.lexer.filename;
                }
                fprintf(libc.stderr, "错误: 语法分析失败 (%s): 当前 token 为 null\n" as *byte, filename);
                return null;
            }
            // 到达文件末尾，正常退出循环
            break;
        }
        
        // 扩展声明数组（使用 Arena 分配）
        if decl_count >= decl_capacity {
            var new_capacity: i32 = 0;
                        if decl_capacity == 0 {
                            new_capacity = 4;
                        } else {
                            new_capacity = decl_capacity * 2;
                        }
            const new_decls: & & ASTNode = compiler_arena_alloc(parser.arena, @size_of(&ASTNode) * new_capacity) as & & ASTNode;
            if new_decls == null {
                return null;
            }
            
            // 复制旧声明
            if decls != null {
                var i: i32 = 0;
                while i < decl_count {
                    new_decls[i] = decls[i];
                    i = i + 1;
                }
            }
            
            decls = new_decls;
            decl_capacity = new_capacity;
        }
        
        if decl.type == ASTNodeType.AST_PROGRAM {
            var inner_i2: i32 = 0;
            while inner_i2 < decl.program_decl_count {
                const inner_decl2: &ASTNode = decl.program_decls[inner_i2];
                if inner_decl2 != null {
                    if decl_count >= decl_capacity {
                        var new_capacity3: i32 = 0;
                        if decl_capacity == 0 {
                            new_capacity3 = 4;
                        } else {
                            new_capacity3 = decl_capacity * 2;
                        }
                        const new_decls3: & & ASTNode = compiler_arena_alloc(parser.arena, @size_of(&ASTNode) * new_capacity3) as & & ASTNode;
                        if new_decls3 == null {
                            return null;
                        }
                        var copy_i3: i32 = 0;
                        while copy_i3 < decl_count {
                            new_decls3[copy_i3] = decls[copy_i3];
                            copy_i3 = copy_i3 + 1;
                        }
                        decls = new_decls3;
                        decl_capacity = new_capacity3;
                    }
                    decls[decl_count] = inner_decl2;
                    decl_count = decl_count + 1;
                }
                inner_i2 = inner_i2 + 1;
            }
        } else {
            decls[decl_count] = decl;
            decl_count = decl_count + 1;
        }
    }
    
    program.program_decls = decls;
    program.program_decl_count = decl_count;
    
    return program;
}

// parser_parse_program 是 parser_parse 的别名（为了兼容性）
fn parser_parse_program(parser: &Parser) &ASTNode {
    return parser_parse(parser);
}
