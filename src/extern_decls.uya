// extern_decls.uya - C 标准库与 bridge 外部函数声明
// 供 codegen/c99、main 等模块使用
// 注意：*T 为 FFI 指针类型，仅用于 extern 函数参数/返回值
// 
// 注意：此文件正在迁移到 std.* 标准库
// 已迁移的函数使用 use 语句导入，未迁移的仍使用 extern 声明

// ===== libc 模块（系统调用封装）=====
// 导入 libc 模块以解析所有 lib/libc/ 下的文件
use libc;

// ===== 运行时支持（std.runtime）=====
use std.runtime.get_argc;
use std.runtime.get_argv;
use std.runtime.get_stderr;
use std.runtime.ptr_diff;

// ===== 文件 I/O（std.io）=====
use std.io.fopen;
use std.io.fclose;
use std.io.fread;
use std.io.fwrite;
use std.io.fgetc;
use std.io.fputs;
use std.io.fprintf;
use std.io.fflush;

// ===== 字符串操作（std.string）=====
use std.string.strlen;
use std.string.strcmp;
use std.string.strncmp;
use std.string.strcpy;
use std.string.strchr;
use std.string.strrchr;
use std.string.strstr;

// ===== 数值转换（libc）=====
use libc.strtod;
use libc.strtol;

// ===== 格式化（libc）=====
use libc.sprintf;
use libc.snprintf;

// ===== 内存操作（std.mem）=====
use std.mem.memcpy;
use std.mem.memset;

// ===== 进程控制（libc）=====
use libc.exit;
use libc.getenv;

// ===== 文件系统（std.c，暂时保留，后续迁移到 std.fs）=====
// 使用 libc 的 Stat 结构体
use libc.Stat;
use libc.stat;
// S_ISDIR 和 S_ISREG 是宏，在 Uya 中需要手动实现
// S_ISDIR(mode) = ((mode) & S_IFMT) == S_IFDIR
// S_ISREG(mode) = ((mode) & S_IFMT) == S_IFREG
const S_IFMT: u32 = 61440;  // 0xF000
const S_IFDIR: u32 = 16384;  // 0x4000
const S_IFREG: u32 = 32768;  // 0x8000

// ===== 目录操作（libc）=====
struct Dirent {
    d_name: *byte,
    d_type: u8,  // DT_REG = 8, DT_DIR = 4
}
struct DIR {
    // 不透明类型
}
use libc.opendir;
use libc.readdir;
use libc.closedir;
const DT_REG: u8 = 8;  // 普通文件
const DT_DIR: u8 = 4;  // 目录

// ===== 符号链接（libc）=====
use libc.readlink;
