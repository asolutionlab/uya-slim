// microapp/main.uya - microapp 镜像/打包/校验子系统
// 从 src/main.uya 拆分

use std;

const MACHO_ARM64_RELOC_BRANCH26_RAW: u32 = 2u32;
const MACHO_ARM64_RELOC_PAGE21_RAW: u32 = 3u32;
const MACHO_ARM64_RELOC_PAGEOFF12_RAW: u32 = 4u32;
const ELF64_SECTION_KIND_SKIP_RAW: u32 = 0u32;
const ELF64_SECTION_KIND_CODE_RAW: u32 = 1u32;
const ELF64_SECTION_KIND_RODATA_RAW: u32 = 2u32;
const ELF64_SECTION_KIND_DATA_RAW: u32 = 3u32;
const ELF64_SECTION_KIND_BSS_RAW: u32 = 4u32;
const ELF64_MAX_SECTIONS: usize = 256usize;
var microapp_elf64_section_kind_map: [u32: 256] = [];
var microapp_elf64_section_off_map: [u32: 256] = [];
var microapp_elf64_section_va_map: [u32: 256] = [];
var microapp_elf64_section_addr_map: [u32: 256] = [];

fn microapp_elf64_section_kind_at(idx: usize) !u32 {
    if idx >= @len(microapp_elf64_section_kind_map) {
        return error.BufRange;
    }
    return microapp_elf64_section_kind_map[idx];
}

fn microapp_elf64_section_off_at(idx: usize) !u32 {
    if idx >= @len(microapp_elf64_section_off_map) {
        return error.BufRange;
    }
    return microapp_elf64_section_off_map[idx];
}

fn microapp_elf64_section_va_at(idx: usize) !u32 {
    if idx >= @len(microapp_elf64_section_va_map) {
        return error.BufRange;
    }
    return microapp_elf64_section_va_map[idx];
}

fn microapp_elf64_section_addr_at(idx: usize) !u32 {
    if idx >= @len(microapp_elf64_section_addr_map) {
        return error.BufRange;
    }
    return microapp_elf64_section_addr_map[idx];
}

struct MicroAppTargetProfile {
    profile_id: u32,
    arch_raw: u32,
    bridge_kind_raw: u32,
    name: &byte,
    triple: &byte,
    default_gcc: &byte,
}

fn read_u16_le_at(buf: &byte, off: usize) u16 {
    const b0: u16 = buf[off] as u16;
    const b1: u16 = buf[off + 1] as u16;
    return b0 | (b1 << 8);
}

fn read_u32_le_at(buf: &byte, off: usize) u32 {
    const b0: u32 = buf[off] as u32;
    const b1: u32 = buf[off + 1] as u32;
    const b2: u32 = buf[off + 2] as u32;
    const b3: u32 = buf[off + 3] as u32;
    return b0 | (b1 << 8) | (b2 << 16) | (b3 << 24);
}

fn read_u64_le_at(buf: &byte, off: usize) u64 {
    const lo: u64 = read_u32_le_at(buf, off) as u64;
    const hi: u64 = read_u32_le_at(buf, off + 4usize) as u64;
    return lo | (hi << 32);
}

fn write_u16_le_at(buf: &byte, off: usize, val: u16) void {
    buf[off] = (val & 255u16) as byte;
    buf[off + 1] = ((val >> 8) & 255u16) as byte;
}

fn write_u32_le_at(buf: &byte, off: usize, val: u32) void {
    buf[off] = (val & 255u32) as byte;
    buf[off + 1] = ((val >> 8) & 255u32) as byte;
    buf[off + 2] = ((val >> 16) & 255u32) as byte;
    buf[off + 3] = ((val >> 24) & 255u32) as byte;
}

fn hex_nibble(c: byte) i32 {
    if c >= 48 as byte && c <= 57 as byte {
        return (c - 48 as byte) as i32;
    }
    if c >= 97 as byte && c <= 102 as byte {
        return 10 + (c - 97 as byte) as i32;
    }
    if c >= 65 as byte && c <= 70 as byte {
        return 10 + (c - 65 as byte) as i32;
    }
    return -1;
}

fn w16_file(fp: &FILE, val: u16) void {
    const b0_tmp: !byte = (val & 255u16) as! byte;
    const b1_tmp: !byte = ((val >> 8) & 255u16) as! byte;
    var b0: byte = b0_tmp catch { 0 as byte; };
    var b1: byte = b1_tmp catch { 0 as byte; };
    fwrite(&b0 as *void, 1 as usize, 1 as usize, fp);
    fwrite(&b1 as *void, 1 as usize, 1 as usize, fp);
}

fn w32_file(fp: &FILE, val: u32) void {
    const b0_tmp: !byte = (val & 255u32) as! byte;
    const b1_tmp: !byte = ((val >> 8) & 255u32) as! byte;
    const b2_tmp: !byte = ((val >> 16) & 255u32) as! byte;
    const b3_tmp: !byte = ((val >> 24) & 255u32) as! byte;
    var b0: byte = b0_tmp catch { 0 as byte; };
    var b1: byte = b1_tmp catch { 0 as byte; };
    var b2: byte = b2_tmp catch { 0 as byte; };
    var b3: byte = b3_tmp catch { 0 as byte; };
    fwrite(&b0 as *void, 1 as usize, 1 as usize, fp);
    fwrite(&b1 as *void, 1 as usize, 1 as usize, fp);
    fwrite(&b2 as *void, 1 as usize, 1 as usize, fp);
    fwrite(&b3 as *void, 1 as usize, 1 as usize, fp);
}

fn resolve_microapp_target_arch_raw() u32 {
    const arch_name: &byte = resolve_microapp_target_platform_arch_name();
    return microapp_target_arch_raw_from_name(arch_name);
}

fn microapp_target_arch_raw_from_name(arch_name: &byte) u32 {
    if arch_name == null || arch_name[0] == 0 as byte {
        return MICROAPP_TARGET_ARCH_X86_64_RAW;
    }
    if strcmp(arch_name, "rv32" as *byte) == 0 {
        return MICROAPP_TARGET_ARCH_RV32_RAW;
    }
    if strcmp(arch_name, "x86_64" as *byte) == 0 {
        return MICROAPP_TARGET_ARCH_X86_64_RAW;
    }
    if strcmp(arch_name, "aarch64" as *byte) == 0 || strcmp(arch_name, "arm64" as *byte) == 0 {
        return MICROAPP_TARGET_ARCH_AARCH64_RAW;
    }
    if strcmp(arch_name, "xtensa" as *byte) == 0 {
        return MICROAPP_TARGET_ARCH_XTENSA_RAW;
    }
    return MICROAPP_TARGET_ARCH_X86_64_RAW;
}

fn resolve_microapp_target_platform_os_name() &byte {
    var os_name: &byte = get_env_or_default("TARGET_OS" as *byte, "" as *byte);
    if os_name == null || os_name[0] == 0 as byte {
        os_name = get_env_or_default("HOST_OS" as *byte, "linux" as *byte);
    }
    if strcmp(os_name, "darwin" as *byte) == 0 {
        return "macos" as &byte;
    }
    return os_name;
}

fn resolve_microapp_target_platform_arch_name() &byte {
    var arch_name: &byte = get_env_or_default("MICROAPP_TARGET_ARCH" as *byte, "" as *byte);
    if arch_name == null || arch_name[0] == 0 as byte {
        arch_name = get_env_or_default("TARGET_ARCH" as *byte, "" as *byte);
    }
    if arch_name == null || arch_name[0] == 0 as byte {
        arch_name = get_env_or_default("HOST_ARCH" as *byte, "x86_64" as *byte);
    }
    return arch_name;
}

fn microapp_target_arch_name(target_arch_raw: u32) &byte {
    if target_arch_raw == MICROAPP_TARGET_ARCH_RV32_RAW {
        return "rv32" as &byte;
    }
    if target_arch_raw == MICROAPP_TARGET_ARCH_X86_64_RAW {
        return "x86_64" as &byte;
    }
    if target_arch_raw == MICROAPP_TARGET_ARCH_AARCH64_RAW {
        return "aarch64" as &byte;
    }
    if target_arch_raw == MICROAPP_TARGET_ARCH_XTENSA_RAW {
        return "xtensa" as &byte;
    }
    return "unknown" as &byte;
}

fn microapp_target_default_triple(target_arch_raw: u32) &byte {
    if target_arch_raw == MICROAPP_TARGET_ARCH_RV32_RAW {
        return "riscv32-unknown-elf" as &byte;
    }
    if target_arch_raw == MICROAPP_TARGET_ARCH_X86_64_RAW {
        return "x86_64-linux-gnu" as &byte;
    }
    if target_arch_raw == MICROAPP_TARGET_ARCH_AARCH64_RAW {
        return "aarch64-linux-gnu" as &byte;
    }
    if target_arch_raw == MICROAPP_TARGET_ARCH_XTENSA_RAW {
        return "xtensa-unknown-elf" as &byte;
    }
    return "x86_64-linux-gnu" as &byte;
}

fn microapp_target_default_gcc(target_arch_raw: u32) &byte {
    if target_arch_raw == MICROAPP_TARGET_ARCH_RV32_RAW {
        return "riscv32-unknown-elf-gcc" as &byte;
    }
    if target_arch_raw == MICROAPP_TARGET_ARCH_X86_64_RAW {
        return "x86_64-linux-gnu-gcc" as &byte;
    }
    if target_arch_raw == MICROAPP_TARGET_ARCH_AARCH64_RAW {
        return "aarch64-linux-gnu-gcc" as &byte;
    }
    if target_arch_raw == MICROAPP_TARGET_ARCH_XTENSA_RAW {
        return "xtensa-unknown-elf-gcc" as &byte;
    }
    return "x86_64-linux-gnu-gcc" as &byte;
}

fn microapp_target_default_profile_id(target_arch_raw: u32) u32 {
    if target_arch_raw == MICROAPP_TARGET_ARCH_RV32_RAW {
        return MICROAPP_PROFILE_RV32_BAREMETAL_SOFTVM_RAW;
    }
    if target_arch_raw == MICROAPP_TARGET_ARCH_X86_64_RAW {
        return MICROAPP_PROFILE_LINUX_X86_64_HARDVM_RAW;
    }
    if target_arch_raw == MICROAPP_TARGET_ARCH_AARCH64_RAW {
        return MICROAPP_PROFILE_LINUX_AARCH64_HARDVM_RAW;
    }
    if target_arch_raw == MICROAPP_TARGET_ARCH_XTENSA_RAW {
        return MICROAPP_PROFILE_XTENSA_BAREMETAL_SOFTVM_RAW;
    }
    return MICROAPP_PROFILE_UNKNOWN_RAW;
}

fn microapp_target_default_bridge_kind_raw(target_arch_raw: u32) u32 {
    if target_arch_raw == MICROAPP_TARGET_ARCH_RV32_RAW {
        return MICROAPP_BRIDGE_TRAP_RAW;
    }
    if target_arch_raw == MICROAPP_TARGET_ARCH_X86_64_RAW {
        return MICROAPP_BRIDGE_CALL_GATE_RAW;
    }
    if target_arch_raw == MICROAPP_TARGET_ARCH_AARCH64_RAW {
        return MICROAPP_BRIDGE_CALL_GATE_RAW;
    }
    if target_arch_raw == MICROAPP_TARGET_ARCH_XTENSA_RAW {
        return MICROAPP_BRIDGE_TRAP_RAW;
    }
    return MICROAPP_BRIDGE_UNKNOWN_RAW;
}

fn microapp_profile_default_stack_hint(profile: &MicroAppTargetProfile) u32 {
    if profile != null && profile.bridge_kind_raw == MICROAPP_BRIDGE_CALL_GATE_RAW {
        return MICROAPP_DEFAULT_STACK_HINT_BYTES;
    }
    return 0u32;
}

fn microapp_profile_name(profile_id: u32) &byte {
    if profile_id == MICROAPP_PROFILE_LINUX_X86_64_HARDVM_RAW {
        return "linux_x86_64_hardvm" as &byte;
    }
    if profile_id == MICROAPP_PROFILE_LINUX_AARCH64_HARDVM_RAW {
        return "linux_aarch64_hardvm" as &byte;
    }
    if profile_id == MICROAPP_PROFILE_MACOS_ARM64_HARDVM_RAW {
        return "macos_arm64_hardvm" as &byte;
    }
    if profile_id == MICROAPP_PROFILE_RV32_BAREMETAL_SOFTVM_RAW {
        return "rv32_baremetal_softvm" as &byte;
    }
    if profile_id == MICROAPP_PROFILE_XTENSA_BAREMETAL_SOFTVM_RAW {
        return "xtensa_baremetal_softvm" as &byte;
    }
    return "unknown" as &byte;
}

fn microapp_bridge_kind_name(bridge_kind_raw: u32) &byte {
    if bridge_kind_raw == MICROAPP_BRIDGE_TRAP_RAW {
        return "trap" as &byte;
    }
    if bridge_kind_raw == MICROAPP_BRIDGE_CALL_GATE_RAW {
        return "call_gate" as &byte;
    }
    return "unknown" as &byte;
}

fn microapp_target_profile_from_arch_raw(target_arch_raw: u32) MicroAppTargetProfile {
    if target_arch_raw == MICROAPP_TARGET_ARCH_RV32_RAW {
        return MicroAppTargetProfile{
            profile_id: MICROAPP_PROFILE_RV32_BAREMETAL_SOFTVM_RAW,
            arch_raw: MICROAPP_TARGET_ARCH_RV32_RAW,
            bridge_kind_raw: MICROAPP_BRIDGE_TRAP_RAW,
            name: "rv32_baremetal_softvm" as &byte,
            triple: "riscv32-unknown-elf" as &byte,
            default_gcc: "riscv32-unknown-elf-gcc" as &byte,
        };
    }
    if target_arch_raw == MICROAPP_TARGET_ARCH_AARCH64_RAW {
        return MicroAppTargetProfile{
            profile_id: MICROAPP_PROFILE_LINUX_AARCH64_HARDVM_RAW,
            arch_raw: MICROAPP_TARGET_ARCH_AARCH64_RAW,
            bridge_kind_raw: MICROAPP_BRIDGE_CALL_GATE_RAW,
            name: "linux_aarch64_hardvm" as &byte,
            triple: "aarch64-linux-gnu" as &byte,
            default_gcc: "aarch64-linux-gnu-gcc" as &byte,
        };
    }
    if target_arch_raw == MICROAPP_TARGET_ARCH_XTENSA_RAW {
        return MicroAppTargetProfile{
            profile_id: MICROAPP_PROFILE_XTENSA_BAREMETAL_SOFTVM_RAW,
            arch_raw: MICROAPP_TARGET_ARCH_XTENSA_RAW,
            bridge_kind_raw: MICROAPP_BRIDGE_TRAP_RAW,
            name: "xtensa_baremetal_softvm" as &byte,
            triple: "xtensa-unknown-elf" as &byte,
            default_gcc: "xtensa-unknown-elf-gcc" as &byte,
        };
    }
    return MicroAppTargetProfile{
        profile_id: MICROAPP_PROFILE_LINUX_X86_64_HARDVM_RAW,
        arch_raw: MICROAPP_TARGET_ARCH_X86_64_RAW,
        bridge_kind_raw: MICROAPP_BRIDGE_CALL_GATE_RAW,
        name: "linux_x86_64_hardvm" as &byte,
        triple: "x86_64-linux-gnu" as &byte,
        default_gcc: "x86_64-linux-gnu-gcc" as &byte,
    };
}

fn microapp_target_profile_from_name(name: &byte) MicroAppTargetProfile {
    if name != null {
        if strcmp(name, "linux_x86_64_hardvm" as *byte) == 0 {
            return microapp_target_profile_from_arch_raw(MICROAPP_TARGET_ARCH_X86_64_RAW);
        }
        if strcmp(name, "linux_aarch64_hardvm" as *byte) == 0 {
            return microapp_target_profile_from_arch_raw(MICROAPP_TARGET_ARCH_AARCH64_RAW);
        }
        if strcmp(name, "macos_arm64_hardvm" as *byte) == 0 {
            return MicroAppTargetProfile{
                profile_id: MICROAPP_PROFILE_MACOS_ARM64_HARDVM_RAW,
                arch_raw: MICROAPP_TARGET_ARCH_AARCH64_RAW,
                bridge_kind_raw: MICROAPP_BRIDGE_CALL_GATE_RAW,
                name: "macos_arm64_hardvm" as &byte,
                triple: "arm64-apple-darwin" as &byte,
                default_gcc: "cc" as &byte,
            };
        }
        if strcmp(name, "rv32_baremetal_softvm" as *byte) == 0 {
            return microapp_target_profile_from_arch_raw(MICROAPP_TARGET_ARCH_RV32_RAW);
        }
        if strcmp(name, "xtensa_baremetal_softvm" as *byte) == 0 {
            return microapp_target_profile_from_arch_raw(MICROAPP_TARGET_ARCH_XTENSA_RAW);
        }
    }
    return microapp_target_profile_from_arch_raw(resolve_microapp_target_arch_raw());
}

fn microapp_target_profile_from_platform(os_name: &byte, arch_name: &byte) MicroAppTargetProfile {
    const arch_raw: u32 = microapp_target_arch_raw_from_name(arch_name);
    if arch_raw == MICROAPP_TARGET_ARCH_AARCH64_RAW {
        if os_name != null {
            if strcmp(os_name, "macos" as *byte) == 0 || strcmp(os_name, "darwin" as *byte) == 0 {
                return microapp_target_profile_from_name("macos_arm64_hardvm" as &byte);
            }
        }
        return microapp_target_profile_from_arch_raw(MICROAPP_TARGET_ARCH_AARCH64_RAW);
    }
    return microapp_target_profile_from_arch_raw(arch_raw);
}

fn microapp_profile_uses_macho_object_extraction(profile: &MicroAppTargetProfile) i32 {
    if profile == null {
        return 0;
    }
    return (profile.profile_id == MICROAPP_PROFILE_MACOS_ARM64_HARDVM_RAW) as i32;
}

fn microapp_profile_supports_runtime_execution(profile: &MicroAppTargetProfile) i32 {
    if profile == null {
        return 0;
    }
    if profile.profile_id == MICROAPP_PROFILE_MACOS_ARM64_HARDVM_RAW {
        std.cfg(std.host_os == .hos_macos, {
            std.cfg(std.target_arch == .ta_arm64, {
                return 1;
            }, {
                return 0;
            })
        }, {
            return 0;
        })
    }
    return 1;
}

fn resolve_microapp_target_profile() MicroAppTargetProfile {
    if g_microapp_target_profile_override_active != 0 && g_microapp_target_profile_override[0] != 0 as byte {
        return microapp_target_profile_from_name(&g_microapp_target_profile_override[0] as &byte);
    }
    const explicit_profile: *byte = getenv("MICROAPP_TARGET_PROFILE" as *byte);
    if explicit_profile != null && explicit_profile[0] != 0 {
        return microapp_target_profile_from_name(explicit_profile as &byte);
    }
    const target_os: &byte = resolve_microapp_target_platform_os_name();
    const target_arch_name: &byte = resolve_microapp_target_platform_arch_name();
    return microapp_target_profile_from_platform(target_os, target_arch_name);
}

fn resolve_microapp_target_gcc(profile: &MicroAppTargetProfile, buffer: &byte, buffer_size: i32) &byte {
    const explicit_microapp_target_gcc: *byte = getenv("MICROAPP_TARGET_GCC" as *byte);
    if explicit_microapp_target_gcc != null && explicit_microapp_target_gcc[0] != 0 {
        return explicit_microapp_target_gcc as &byte;
    }
    const explicit_target_gcc: *byte = getenv("TARGET_GCC" as *byte);
    if explicit_target_gcc != null && explicit_target_gcc[0] != 0 {
        return explicit_target_gcc as &byte;
    }
    var fallback_gcc: &byte = microapp_target_default_gcc(MICROAPP_TARGET_ARCH_X86_64_RAW);
    if profile != null && profile.default_gcc != null && profile.default_gcc[0] != 0 as byte {
        fallback_gcc = profile.default_gcc;
    }
    const written: i32 = snprintf(buffer as *byte, buffer_size, "%s" as *byte, fallback_gcc);
    if written > 0 && written < buffer_size {
        return buffer;
    }
    return get_env_or_default("CC" as *byte, "cc" as *byte);
}

fn microapp_profile_default_cflags(profile: &MicroAppTargetProfile) &byte {
    if profile != null && profile.profile_id == MICROAPP_PROFILE_LINUX_X86_64_HARDVM_RAW {
        return "-std=c99 -Os -fomit-frame-pointer -fno-builtin -fno-stack-protector -fpie -ffunction-sections -fdata-sections" as &byte;
    }
    if profile != null && profile.bridge_kind_raw == MICROAPP_BRIDGE_CALL_GATE_RAW {
        return "-std=c99 -Os -fomit-frame-pointer -fno-builtin -fno-stack-protector -fpie -ffunction-sections -fdata-sections -flto=auto" as &byte;
    }
    return "-std=c99 -Os -fomit-frame-pointer -fno-builtin -fno-stack-protector -fno-pie -ffunction-sections -fdata-sections -flto=auto" as &byte;
}

fn microapp_profile_default_ldflags(profile: &MicroAppTargetProfile) &byte {
    if profile != null && profile.profile_id == MICROAPP_PROFILE_LINUX_X86_64_HARDVM_RAW {
        return "-pie -Wl,--gc-sections -Wl,--emit-relocs -flto=auto" as &byte;
    }
    if profile != null && profile.bridge_kind_raw == MICROAPP_BRIDGE_CALL_GATE_RAW {
        return "-pie -Wl,--gc-sections -flto=auto" as &byte;
    }
    return "-no-pie -Wl,--gc-sections -flto=auto" as &byte;
}

fn microapp_ascii_is_space(c: byte) i32 {
    if c == 32 as byte || c == 9 as byte || c == 10 as byte || c == 13 as byte {
        return 1;
    }
    return 0;
}

fn microapp_hex_to_u32_span(buf: &byte, start: usize, end: usize) !u32 {
    var value: u32 = 0u32;
    var i: usize = start;
    if start >= end {
        return error.InvalidSize;
    }
    while i < end {
        const nib: i32 = hex_nibble(buf[i]);
        if nib < 0 {
            return error.InvalidSize;
        }
        value = (value << 4) | (nib as u32);
        i = i + 1;
    }
    return value;
}

fn microapp_parse_signed_u32_token(line: &byte, token_start: usize, token_end: usize, sign: i32) !u32 {
    if line == null || token_end <= token_start {
        return error.InvalidState;
    }
    const raw: u32 = try microapp_hex_to_u32_span(line, token_start, token_end);
    if sign >= 0 {
        return raw;
    }
    if raw == 0u32 {
        return 0u32;
    }
    return error.InvalidState;
}

fn microapp_align_u32(value: u32, align: u32) u32 {
    if align <= 1u32 {
        return value;
    }
    return (value + align - 1u32) & ~(align - 1u32);
}

fn microapp_target_uses_internal_elf_extraction(target_arch_raw: u32) i32 {
    if target_arch_raw == MICROAPP_TARGET_ARCH_X86_64_RAW {
        return 1;
    }
    if target_arch_raw == MICROAPP_TARGET_ARCH_AARCH64_RAW {
        return 1;
    }
    return 0;
}

fn microapp_target_uses_object_elf_extraction(target_arch_raw: u32) i32 {
    if target_arch_raw == MICROAPP_TARGET_ARCH_X86_64_RAW {
        return 1;
    }
    if target_arch_raw == MICROAPP_TARGET_ARCH_AARCH64_RAW {
        return 1;
    }
    return 0;
}

fn microapp_elf_machine_matches_target_arch(target_arch_raw: u32, machine_raw: u16) i32 {
    if target_arch_raw == MICROAPP_TARGET_ARCH_X86_64_RAW {
        return (machine_raw == ELF_MACHINE_X86_64_RAW) as i32;
    }
    if target_arch_raw == MICROAPP_TARGET_ARCH_AARCH64_RAW {
        // aarch64 hosted/unwired 回归在缺少交叉工具链时会用 x86_64 gcc 生成占位镜像，
        // 这里保持兼容，允许 64-bit hosted ELF 继续进入 .uapp 打包链路。
        if machine_raw == ELF_MACHINE_AARCH64_RAW || machine_raw == ELF_MACHINE_X86_64_RAW {
            return 1;
        }
        return 0;
    }
    return 0;
}

fn microapp_elf_range_valid(file_len: usize, off: u64, size: u64) i32 {
    const file_len_u64: u64 = file_len as u64;
    if off > file_len_u64 || size > file_len_u64 {
        return 0;
    }
    if off + size > file_len_u64 {
        return 0;
    }
    return 1;
}

fn microapp_elf_cstring_equals_at(buf: &byte, buf_len: usize, table_off: usize, table_len: usize, str_off: u32, expected: &byte) i32 {
    if buf == null || expected == null {
        return 0;
    }
    const name_off: usize = str_off as usize;
    if name_off >= table_len {
        return 0;
    }
    var i: usize = 0;
    while expected[i] != 0 as byte {
        if name_off + i >= table_len {
            return 0;
        }
        const abs_off: usize = table_off + name_off + i;
        if abs_off >= buf_len {
            return 0;
        }
        if buf[abs_off] != expected[i] {
            return 0;
        }
        i = i + 1usize;
    }
    if name_off + i >= table_len {
        return 0;
    }
    const term_off: usize = table_off + name_off + i;
    if term_off >= buf_len {
        return 0;
    }
    return (buf[term_off] == 0 as byte) as i32;
}

fn microapp_elf_cstring_has_prefix_at(buf: &byte, buf_len: usize, table_off: usize, table_len: usize, str_off: u32, prefix: &byte) i32 {
    if buf == null || prefix == null {
        return 0;
    }
    const name_off: usize = str_off as usize;
    if name_off >= table_len {
        return 0;
    }
    var i: usize = 0usize;
    while prefix[i] != 0 as byte {
        if name_off + i >= table_len {
            return 0;
        }
        const abs_off: usize = table_off + name_off + i;
        if abs_off >= buf_len {
            return 0;
        }
        if buf[abs_off] != prefix[i] {
            return 0;
        }
        i = i + 1usize;
    }
    return 1;
}

fn microapp_elf64_symbol_value_by_index(elf: &byte, elf_len: usize, shoff: usize, shentsize: usize, shnum: usize, sym_section_index: u32, sym_index: u32, value_out: &u64) i32 {
    if elf == null || value_out == null {
        return 1;
    }
    if sym_section_index as usize >= shnum {
        return 1;
    }
    const sh_base: usize = shoff + sym_section_index as usize * shentsize;
    if sh_base + ELF64_SECTION_HEADER_SIZE > elf_len {
        return 1;
    }
    const sh_type: u32 = read_u32_le_at(elf, sh_base + 4usize);
    if sh_type != ELF64_SECTION_TYPE_SYMTAB_RAW && sh_type != ELF64_SECTION_TYPE_DYNSYM_RAW {
        return 1;
    }
    const sym_off: u64 = read_u64_le_at(elf, sh_base + 24usize);
    const sym_size: u64 = read_u64_le_at(elf, sh_base + 32usize);
    const sym_entsize: u64 = read_u64_le_at(elf, sh_base + 56usize);
    if sym_entsize < ELF64_SYMBOL_SIZE as u64 {
        return 1;
    }
    const record_off: u64 = sym_off + sym_entsize * sym_index as u64;
    if record_off < sym_off || record_off + ELF64_SYMBOL_SIZE as u64 > sym_off + sym_size {
        return 1;
    }
    if microapp_elf_range_valid(elf_len, record_off, ELF64_SYMBOL_SIZE as u64) == 0 {
        return 1;
    }
    value_out[0] = read_u64_le_at(elf, record_off as usize + 8usize);
    return 0;
}

fn microapp_elf64_find_symbol_value(elf: &byte, elf_len: usize, shoff: usize, shentsize: usize, shnum: usize, symbol_name: &byte, value_out: &u64) i32 {
    if elf == null || symbol_name == null || value_out == null {
        return 1;
    }
    var i: usize = 0usize;
    while i < shnum {
        const sh_base: usize = shoff + i * shentsize;
        if sh_base + ELF64_SECTION_HEADER_SIZE > elf_len {
            return 1;
        }
        const sh_type: u32 = read_u32_le_at(elf, sh_base + 4usize);
        if sh_type == ELF64_SECTION_TYPE_SYMTAB_RAW || sh_type == ELF64_SECTION_TYPE_DYNSYM_RAW {
            const sym_off: u64 = read_u64_le_at(elf, sh_base + 24usize);
            const sym_size: u64 = read_u64_le_at(elf, sh_base + 32usize);
            const str_index: u32 = read_u32_le_at(elf, sh_base + 40usize);
            const sym_entsize: u64 = read_u64_le_at(elf, sh_base + 56usize);
            if str_index as usize >= shnum || sym_entsize < ELF64_SYMBOL_SIZE as u64 || microapp_elf_range_valid(elf_len, sym_off, sym_size) == 0 {
                i = i + 1usize;
                continue;
            }
            const str_sh_base: usize = shoff + str_index as usize * shentsize;
            if str_sh_base + ELF64_SECTION_HEADER_SIZE > elf_len {
                i = i + 1usize;
                continue;
            }
            const str_off: u64 = read_u64_le_at(elf, str_sh_base + 24usize);
            const str_size: u64 = read_u64_le_at(elf, str_sh_base + 32usize);
            if microapp_elf_range_valid(elf_len, str_off, str_size) == 0 {
                i = i + 1usize;
                continue;
            }
            var sym_pos: u64 = 0u64;
            while sym_pos + ELF64_SYMBOL_SIZE as u64 <= sym_size {
                const rec_off: u64 = sym_off + sym_pos;
                const st_name: u32 = read_u32_le_at(elf, rec_off as usize);
                if microapp_elf_cstring_equals_at(elf, elf_len, str_off as usize, str_size as usize, st_name, symbol_name) != 0 {
                    value_out[0] = read_u64_le_at(elf, rec_off as usize + 8usize);
                    return 0;
                }
                sym_pos = sym_pos + sym_entsize;
            }
        }
        i = i + 1usize;
    }
    return 1;
}

fn microapp_extract_internal_elf64(exe_path: &byte, target_arch_raw: u32, code_len: &u32, rodata_len: &u32, data_len: &u32, text_va: &u32, rodata_va: &u32, data_va: &u32, bss_va: &u32, bss_len: &u32, entry_va: &u32, base_raw_out: &u32, text_raw_out: &u32, rodata_raw_out: &u32, data_raw_out: &u32, bss_raw_out: &u32, reloc_count: &u32, reloc_len: &u32) i32 {
    if exe_path == null || code_len == null || rodata_len == null || data_len == null ||
       text_va == null || rodata_va == null || data_va == null || bss_va == null ||
       bss_len == null || entry_va == null || reloc_count == null || reloc_len == null {
        return 1;
    }
    const elf_size: i32 = read_file_content(exe_path, &microapp_pack_output_buffer[0] as &byte, @len(microapp_pack_output_buffer));
    if elf_size < 0 {
        return 1;
    }
    const elf_size_usize: usize = elf_size as usize;
    const elf_size_u64: u64 = elf_size as u64;
    if elf_size_usize < ELF64_HEADER_SIZE {
        return 1;
    }
    const elf: &byte = &microapp_pack_output_buffer[0] as &byte;
    if elf[0] != 127 as byte || elf[1] != 69 as byte || elf[2] != 76 as byte || elf[3] != 70 as byte {
        return 1;
    }
    if elf[4] != ELFCLASS64_RAW || elf[5] != ELFDATA2LSB_RAW {
        return 1;
    }
    const machine_raw: u16 = read_u16_le_at(elf, 18usize);
    if microapp_elf_machine_matches_target_arch(target_arch_raw, machine_raw) == 0 {
        return 1;
    }
    const shoff_u64: u64 = read_u64_le_at(elf, 40usize);
    const shentsize: usize = read_u16_le_at(elf, 58usize) as usize;
    const shnum: usize = read_u16_le_at(elf, 60usize) as usize;
    const shstrndx: usize = read_u16_le_at(elf, 62usize) as usize;
    if shoff_u64 > elf_size_u64 || shentsize < ELF64_SECTION_HEADER_SIZE || shnum == 0usize || shstrndx >= shnum {
        return 1;
    }
    const shoff: usize = shoff_u64 as usize;
    if shoff + shentsize * shnum > elf_size_usize {
        return 1;
    }
    const shstr_base: usize = shoff + shstrndx * shentsize;
    if shstr_base + ELF64_SECTION_HEADER_SIZE > elf_size_usize {
        return 1;
    }
    const shstr_off_u64: u64 = read_u64_le_at(elf, shstr_base + 24usize);
    const shstr_size_u64: u64 = read_u64_le_at(elf, shstr_base + 32usize);
    if microapp_elf_range_valid(elf_size_usize, shstr_off_u64, shstr_size_u64) == 0 {
        return 1;
    }
    const shstr_off: usize = shstr_off_u64 as usize;
    const shstr_size: usize = shstr_size_u64 as usize;

    code_len[0] = 0u32;
    rodata_len[0] = 0u32;
    data_len[0] = 0u32;
    bss_len[0] = 0u32;
    bss_va[0] = 0u32;
    reloc_count[0] = 0u32;
    reloc_len[0] = 0u32;

    var text_raw_u64: u64 = 0u64;
    var rodata_raw_u64: u64 = 0u64;
    var data_raw_u64: u64 = 0u64;
    var bss_raw_u64: u64 = 0u64;
    var bss_size_u64: u64 = 0u64;
    var base_raw_u64: u64 = 0u64;
    var saw_base: i32 = 0;
    var i: usize = 0usize;
    while i < shnum {
        const sh_base: usize = shoff + i * shentsize;
        const sh_name: u32 = read_u32_le_at(elf, sh_base);
        const sh_addr: u64 = read_u64_le_at(elf, sh_base + 16usize);
        const sh_offset: u64 = read_u64_le_at(elf, sh_base + 24usize);
        const sh_size: u64 = read_u64_le_at(elf, sh_base + 32usize);
        if microapp_elf_cstring_equals_at(elf, elf_size_usize, shstr_off, shstr_size, sh_name, ".text" as &byte) != 0 {
            if microapp_elf_range_valid(elf_size_usize, sh_offset, sh_size) == 0 || sh_size > FILE_BUFFER_SIZE as u64 {
                return 1;
            }
            memcpy(&file_buffer[0] as *void, (elf + sh_offset as usize) as *void, sh_size as usize);
            code_len[0] = sh_size as u32;
            text_raw_u64 = sh_addr;
            if saw_base == 0 || sh_addr < base_raw_u64 {
                base_raw_u64 = sh_addr;
                saw_base = 1;
            }
        } else if microapp_elf_cstring_equals_at(elf, elf_size_usize, shstr_off, shstr_size, sh_name, ".rodata" as &byte) != 0 {
            if microapp_elf_range_valid(elf_size_usize, sh_offset, sh_size) == 0 || sh_size > FILE_BUFFER_SIZE as u64 {
                return 1;
            }
            memcpy(&microapp_rodata_buffer[0] as *void, (elf + sh_offset as usize) as *void, sh_size as usize);
            rodata_len[0] = sh_size as u32;
            rodata_raw_u64 = sh_addr;
            if saw_base == 0 || sh_addr < base_raw_u64 {
                base_raw_u64 = sh_addr;
                saw_base = 1;
            }
        } else if microapp_elf_cstring_equals_at(elf, elf_size_usize, shstr_off, shstr_size, sh_name, ".data" as &byte) != 0 {
            if microapp_elf_range_valid(elf_size_usize, sh_offset, sh_size) == 0 || sh_size > FILE_BUFFER_SIZE as u64 {
                return 1;
            }
            memcpy(&microapp_data_buffer[0] as *void, (elf + sh_offset as usize) as *void, sh_size as usize);
            data_len[0] = sh_size as u32;
            data_raw_u64 = sh_addr;
            if saw_base == 0 || sh_addr < base_raw_u64 {
                base_raw_u64 = sh_addr;
                saw_base = 1;
            }
        } else if microapp_elf_cstring_equals_at(elf, elf_size_usize, shstr_off, shstr_size, sh_name, ".bss" as &byte) != 0 {
            bss_raw_u64 = sh_addr;
            bss_size_u64 = sh_size;
            if sh_size > 0u64 && (saw_base == 0 || sh_addr < base_raw_u64) {
                base_raw_u64 = sh_addr;
                saw_base = 1;
            }
        }
        i = i + 1usize;
    }
    if code_len[0] == 0u32 || saw_base == 0 {
        return 1;
    }
    if rodata_len[0] == 0u32 {
        rodata_raw_u64 = text_raw_u64;
    }
    if data_len[0] == 0u32 {
        data_raw_u64 = rodata_raw_u64;
    }
    var entry_raw_u64: u64 = 0u64;
    if microapp_elf64_find_symbol_value(elf, elf_size_usize, shoff, shentsize, shnum, "main_main" as &byte, &entry_raw_u64) != 0 {
        if microapp_elf64_find_symbol_value(elf, elf_size_usize, shoff, shentsize, shnum, "main" as &byte, &entry_raw_u64) != 0 {
            return 1;
        }
    }
    if entry_raw_u64 < base_raw_u64 || text_raw_u64 < base_raw_u64 || rodata_raw_u64 < base_raw_u64 || data_raw_u64 < base_raw_u64 {
        return 1;
    }
    if entry_raw_u64 > 4294967295u64 || text_raw_u64 > 4294967295u64 || rodata_raw_u64 > 4294967295u64 ||
       data_raw_u64 > 4294967295u64 || base_raw_u64 > 4294967295u64 || bss_raw_u64 > 4294967295u64 ||
       bss_size_u64 > 4294967295u64 {
        return 1;
    }
    const base_raw: u32 = base_raw_u64 as u32;
    const text_raw: u32 = text_raw_u64 as u32;
    const rodata_raw: u32 = rodata_raw_u64 as u32;
    const data_raw: u32 = data_raw_u64 as u32;
    const bss_raw: u32 = bss_raw_u64 as u32;
    const entry_raw: u32 = entry_raw_u64 as u32;
    const bss_raw_len: u32 = bss_size_u64 as u32;
    text_va[0] = MICROAPP_VADDR_BASE + (text_raw - base_raw);
    rodata_va[0] = MICROAPP_VADDR_BASE + (rodata_raw - base_raw);
    data_va[0] = MICROAPP_VADDR_BASE + (data_raw - base_raw);
    if bss_raw_len > 0u32 {
        bss_va[0] = MICROAPP_VADDR_BASE + (bss_raw - base_raw);
    }
    bss_len[0] = bss_raw_len;
    entry_va[0] = MICROAPP_VADDR_BASE + (entry_raw - base_raw);
    if base_raw_out != null { base_raw_out[0] = base_raw; }
    if text_raw_out != null { text_raw_out[0] = text_raw; }
    if rodata_raw_out != null { rodata_raw_out[0] = rodata_raw; }
    if data_raw_out != null { data_raw_out[0] = data_raw; }
    if bss_raw_out != null { bss_raw_out[0] = bss_raw; }

    var out_count: u32 = 0u32;
    i = 0usize;
    while i < shnum {
        const sh_base: usize = shoff + i * shentsize;
        const sh_type: u32 = read_u32_le_at(elf, sh_base + 4usize);
        if sh_type == ELF64_SECTION_TYPE_RELA_RAW {
            const rela_off: u64 = read_u64_le_at(elf, sh_base + 24usize);
            const rela_size: u64 = read_u64_le_at(elf, sh_base + 32usize);
            const sym_section_index: u32 = read_u32_le_at(elf, sh_base + 40usize);
            const rela_entsize: u64 = read_u64_le_at(elf, sh_base + 56usize);
            if microapp_elf_range_valid(elf_size_usize, rela_off, rela_size) == 0 || rela_entsize < ELF64_RELA_SIZE as u64 {
                return 1;
            }
            var rela_pos: u64 = 0u64;
            while rela_pos + ELF64_RELA_SIZE as u64 <= rela_size {
                const rec_off: u64 = rela_off + rela_pos;
                const target_raw_u64: u64 = read_u64_le_at(elf, rec_off as usize);
                const info_u64: u64 = read_u64_le_at(elf, rec_off as usize + 8usize);
                const addend_u64: u64 = read_u64_le_at(elf, rec_off as usize + 16usize);
                const reloc_type: u32 = (info_u64 & 4294967295u64) as u32;
                const sym_index: u32 = ((info_u64 >> 32) & 4294967295u64) as u32;
                var supported_type: i32 = 0;
                var value_raw_u64: u64 = 0u64;
                if target_arch_raw == MICROAPP_TARGET_ARCH_X86_64_RAW {
                    if reloc_type == ELF_RELOC_X86_64_RELATIVE_RAW {
                        value_raw_u64 = addend_u64;
                        supported_type = 1;
                    } else if reloc_type == ELF_RELOC_X86_64_64_RAW || reloc_type == ELF_RELOC_X86_64_GLOB_DAT_RAW {
                        var sym_value_u64: u64 = 0u64;
                        if microapp_elf64_symbol_value_by_index(elf, elf_size_usize, shoff, shentsize, shnum, sym_section_index, sym_index, &sym_value_u64) == 0 {
                            if addend_u64 > 9223372036854775807u64 {
                                return 1;
                            }
                            value_raw_u64 = sym_value_u64 + addend_u64;
                            supported_type = 1;
                        }
                    }
                } else if target_arch_raw == MICROAPP_TARGET_ARCH_AARCH64_RAW {
                    if reloc_type == ELF_RELOC_AARCH64_RELATIVE_RAW {
                        value_raw_u64 = addend_u64;
                        supported_type = 1;
                    } else if reloc_type == ELF_RELOC_AARCH64_ABS64_RAW || reloc_type == ELF_RELOC_AARCH64_GLOB_DAT_RAW {
                        var sym_value_u64: u64 = 0u64;
                        if microapp_elf64_symbol_value_by_index(elf, elf_size_usize, shoff, shentsize, shnum, sym_section_index, sym_index, &sym_value_u64) == 0 {
                            if addend_u64 > 9223372036854775807u64 {
                                return 1;
                            }
                            value_raw_u64 = sym_value_u64 + addend_u64;
                            supported_type = 1;
                        }
                    }
                }
                if supported_type != 0 &&
                   target_raw_u64 <= 4294967295u64 && value_raw_u64 <= 4294967295u64 {
                    const target_raw: u32 = target_raw_u64 as u32;
                    const value_raw: u32 = value_raw_u64 as u32;
                    if microapp_raw_va_in_writable_image_range(target_raw, data_raw, data_len[0], bss_raw, bss_len[0]) != 0 &&
                       microapp_raw_va_maps_into_image(value_raw, text_raw, code_len[0], rodata_raw, rodata_len[0], data_raw, data_len[0], bss_raw, bss_len[0]) != 0 {
                        const out_off: usize = out_count as usize * 8usize;
                        if out_off + 8usize > FILE_BUFFER_SIZE as usize {
                            return 1;
                        }
                        write_u32_le_at(&microapp_reloc_buffer[0] as &byte, out_off, MICROAPP_VADDR_BASE + (target_raw - base_raw));
                        write_u32_le_at(&microapp_reloc_buffer[0] as &byte, out_off + 4usize, MICROAPP_VADDR_BASE + (value_raw - base_raw));
                        out_count = out_count + 1u32;
                    }
                }
                rela_pos = rela_pos + rela_entsize;
            }
        }
        i = i + 1usize;
    }
    reloc_count[0] = out_count;
    reloc_len[0] = out_count * 8u32;
    return 0;
}

fn microapp_zero_byte_range(buf: &byte, len: u32) void {
    if buf == null {
        return;
    }
    var i: u32 = 0u32;
    while i < len {
        buf[i as usize] = 0 as byte;
        i = i + 1u32;
    }
}

fn microapp_object_elf64_section_kind(elf: &byte, elf_len: usize, shstr_off: usize, shstr_size: usize, sh_name: u32, sh_type: u32, sh_flags: u64) u32 {
    if (sh_flags & ELF64_SECTION_FLAG_ALLOC_RAW) == 0u64 {
        return ELF64_SECTION_KIND_SKIP_RAW;
    }
    if microapp_elf_cstring_has_prefix_at(elf, elf_len, shstr_off, shstr_size, sh_name, ".text" as &byte) != 0 &&
       sh_type == ELF64_SECTION_TYPE_PROGBITS_RAW &&
       (sh_flags & ELF64_SECTION_FLAG_EXEC_RAW) != 0u64 {
        return ELF64_SECTION_KIND_CODE_RAW;
    }
    if microapp_elf_cstring_has_prefix_at(elf, elf_len, shstr_off, shstr_size, sh_name, ".rodata" as &byte) != 0 &&
       sh_type == ELF64_SECTION_TYPE_PROGBITS_RAW &&
       (sh_flags & ELF64_SECTION_FLAG_WRITE_RAW) == 0u64 {
        return ELF64_SECTION_KIND_RODATA_RAW;
    }
    if microapp_elf_cstring_has_prefix_at(elf, elf_len, shstr_off, shstr_size, sh_name, ".data" as &byte) != 0 &&
       sh_type == ELF64_SECTION_TYPE_PROGBITS_RAW &&
       (sh_flags & ELF64_SECTION_FLAG_WRITE_RAW) != 0u64 {
        return ELF64_SECTION_KIND_DATA_RAW;
    }
    if microapp_elf_cstring_has_prefix_at(elf, elf_len, shstr_off, shstr_size, sh_name, ".bss" as &byte) != 0 &&
       sh_type == ELF64_SECTION_TYPE_NOBITS_RAW &&
       (sh_flags & ELF64_SECTION_FLAG_WRITE_RAW) != 0u64 {
        return ELF64_SECTION_KIND_BSS_RAW;
    }
    return ELF64_SECTION_KIND_SKIP_RAW;
}

fn microapp_object_elf64_symbol_value_by_index(elf: &byte, elf_len: usize, shoff: usize, shentsize: usize, shnum: usize, symtab_index: u32, sym_index: u32, value_out: &u32) i32 {
    if elf == null || value_out == null {
        return 1;
    }
    if symtab_index as usize >= shnum || symtab_index as usize >= ELF64_MAX_SECTIONS {
        return 1;
    }
    const sh_base: usize = shoff + symtab_index as usize * shentsize;
    if sh_base + ELF64_SECTION_HEADER_SIZE > elf_len {
        return 1;
    }
    const sh_type: u32 = read_u32_le_at(elf, sh_base + 4usize);
    if sh_type != ELF64_SECTION_TYPE_SYMTAB_RAW && sh_type != ELF64_SECTION_TYPE_DYNSYM_RAW {
        return 1;
    }
    const sym_off: u64 = read_u64_le_at(elf, sh_base + 24usize);
    const sym_size: u64 = read_u64_le_at(elf, sh_base + 32usize);
    const sym_entsize: u64 = read_u64_le_at(elf, sh_base + 56usize);
    if sym_entsize < ELF64_SYMBOL_SIZE as u64 {
        return 1;
    }
    const rec_off: u64 = sym_off + sym_entsize * sym_index as u64;
    if rec_off < sym_off || rec_off + ELF64_SYMBOL_SIZE as u64 > sym_off + sym_size {
        return 1;
    }
    if microapp_elf_range_valid(elf_len, rec_off, ELF64_SYMBOL_SIZE as u64) == 0 {
        return 1;
    }
    const st_shndx: u16 = read_u16_le_at(elf, rec_off as usize + 6usize);
    const st_value_u64: u64 = read_u64_le_at(elf, rec_off as usize + 8usize);
    if st_shndx == 0u16 {
        return 1;
    }
    if st_shndx == 65521u16 {
        if st_value_u64 > 4294967295u64 {
            return 1;
        }
        value_out[0] = st_value_u64 as u32;
        return 0;
    }
    if st_shndx as usize >= shnum || st_shndx as usize >= ELF64_MAX_SECTIONS {
        return 1;
    }
    const section_index: usize = st_shndx as usize;
    if section_index >= @len(microapp_elf64_section_kind_map) {
        return 1;
    }
    var section_kind: u32 = ELF64_SECTION_KIND_SKIP_RAW;
    var section_va: u32 = 0u32;
    if section_index < @len(microapp_elf64_section_kind_map) {
        section_kind = microapp_elf64_section_kind_at(section_index) catch { return 1; };
        section_va = microapp_elf64_section_va_at(section_index) catch { return 1; };
    } else {
        return 1;
    }
    if section_kind == ELF64_SECTION_KIND_SKIP_RAW {
        return 1;
    }
    if st_value_u64 > 4294967295u64 {
        return 1;
    }
    value_out[0] = section_va + st_value_u64 as u32;
    return 0;
}

fn microapp_object_elf64_find_symbol_value(elf: &byte, elf_len: usize, shoff: usize, shentsize: usize, shnum: usize, symbol_name: &byte, value_out: &u32) i32 {
    if elf == null || symbol_name == null || value_out == null {
        return 1;
    }
    var i: usize = 0usize;
    while i < shnum && i < ELF64_MAX_SECTIONS {
        const sh_base: usize = shoff + i * shentsize;
        if sh_base + ELF64_SECTION_HEADER_SIZE > elf_len {
            return 1;
        }
        const sh_type: u32 = read_u32_le_at(elf, sh_base + 4usize);
        if sh_type == ELF64_SECTION_TYPE_SYMTAB_RAW || sh_type == ELF64_SECTION_TYPE_DYNSYM_RAW {
            const sym_off: u64 = read_u64_le_at(elf, sh_base + 24usize);
            const sym_size: u64 = read_u64_le_at(elf, sh_base + 32usize);
            const str_index: u32 = read_u32_le_at(elf, sh_base + 40usize);
            const sym_entsize: u64 = read_u64_le_at(elf, sh_base + 56usize);
            if str_index as usize >= shnum || sym_entsize < ELF64_SYMBOL_SIZE as u64 || microapp_elf_range_valid(elf_len, sym_off, sym_size) == 0 {
                i = i + 1usize;
                continue;
            }
            const str_sh_base: usize = shoff + str_index as usize * shentsize;
            if str_sh_base + ELF64_SECTION_HEADER_SIZE > elf_len {
                i = i + 1usize;
                continue;
            }
            const str_off: u64 = read_u64_le_at(elf, str_sh_base + 24usize);
            const str_size: u64 = read_u64_le_at(elf, str_sh_base + 32usize);
            if microapp_elf_range_valid(elf_len, str_off, str_size) == 0 {
                i = i + 1usize;
                continue;
            }
            var sym_pos: u64 = 0u64;
            var sym_index: u32 = 0u32;
            while sym_pos + ELF64_SYMBOL_SIZE as u64 <= sym_size {
                const rec_off: u64 = sym_off + sym_pos;
                const st_name: u32 = read_u32_le_at(elf, rec_off as usize);
                if microapp_elf_cstring_equals_at(elf, elf_len, str_off as usize, str_size as usize, st_name, symbol_name) != 0 {
                    return microapp_object_elf64_symbol_value_by_index(elf, elf_len, shoff, shentsize, shnum, i as u32, sym_index, value_out);
                }
                sym_pos = sym_pos + sym_entsize;
                sym_index = sym_index + 1u32;
            }
        }
        i = i + 1usize;
    }
    return 1;
}

fn microapp_aarch64_encode_signed_field(value: i64, bits: u32) !u32 {
    if bits == 26u32 {
        if value < (0 - 33554432) || value > 33554431 {
            return error.InvalidState;
        }
        var encoded26: i64 = value;
        if encoded26 < 0 {
            encoded26 = encoded26 + 67108864;
        }
        const out26: !u32 = encoded26 as! u32;
        return out26 catch { return 0u32; };
    }
    if bits == 21u32 {
        if value < (0 - 1048576) || value > 1048575 {
            return error.InvalidState;
        }
        var encoded21: i64 = value;
        if encoded21 < 0 {
            encoded21 = encoded21 + 2097152;
        }
        const out21: !u32 = encoded21 as! u32;
        return out21 catch { return 0u32; };
    }
    if bits == 19u32 {
        if value < (0 - 262144) || value > 262143 {
            return error.InvalidState;
        }
        var encoded19: i64 = value;
        if encoded19 < 0 {
            encoded19 = encoded19 + 524288;
        }
        const out19: !u32 = encoded19 as! u32;
        return out19 catch { return 0u32; };
    }
    return error.InvalidState;
}

fn microapp_aarch64_patch_branch26(insn: u32, place_va: u32, target_va: u32) !u32 {
    if (place_va & 3u32) != 0u32 || (target_va & 3u32) != 0u32 {
        return error.InvalidState;
    }
    const place_i64: !i64 = place_va as! i64;
    const target_i64: !i64 = target_va as! i64;
    const disp: i64 = (target_i64 catch { return 0u32; }) - (place_i64 catch { return 0u32; });
    if (disp % (4 as i64)) != 0 {
        return error.InvalidState;
    }
    const imm26: i64 = disp / (4 as i64);
    const field: u32 = try microapp_aarch64_encode_signed_field(imm26, 26u32);
    return (insn & 4227858432u32) | (field & 67108863u32);
}

fn microapp_aarch64_patch_adr_lo21(insn: u32, place_va: u32, target_va: u32) !u32 {
    const place_i64: !i64 = place_va as! i64;
    const target_i64: !i64 = target_va as! i64;
    const disp: i64 = (target_i64 catch { return 0u32; }) - (place_i64 catch { return 0u32; });
    const field: u32 = try microapp_aarch64_encode_signed_field(disp, 21u32);
    return (insn & 2667577375u32) |
        ((field & 3u32) << 29) |
        (((field >> 2) & 524287u32) << 5);
}

fn microapp_aarch64_patch_adrp_hi21(insn: u32, place_va: u32, target_va: u32) !u32 {
    const place_page: u32 = place_va & 4294963200u32;
    const target_page: u32 = target_va & 4294963200u32;
    const place_i64: !i64 = place_page as! i64;
    const target_i64: !i64 = target_page as! i64;
    const disp_pages: i64 = (target_i64.value - place_i64.value) / 4096;
    const field: u32 = try microapp_aarch64_encode_signed_field(disp_pages, 21u32);
    return (insn & 2667577375u32) |
        ((field & 3u32) << 29) |
        (((field >> 2) & 524287u32) << 5);
}

fn microapp_aarch64_patch_ld_prel_lo19(insn: u32, place_va: u32, target_va: u32) !u32 {
    if (place_va & 3u32) != 0u32 || (target_va & 3u32) != 0u32 {
        return error.InvalidState;
    }
    const place_i64: !i64 = place_va as! i64;
    const target_i64: !i64 = target_va as! i64;
    const disp: i64 = (target_i64 catch { return 0u32; }) - (place_i64 catch { return 0u32; });
    if (disp % (4 as i64)) != 0 {
        return error.InvalidState;
    }
    const imm19: i64 = disp / (4 as i64);
    const field: u32 = try microapp_aarch64_encode_signed_field(imm19, 19u32);
    return (insn & 4278190111u32) | ((field & 524287u32) << 5);
}

fn microapp_aarch64_patch_add_lo12(insn: u32, target_va: u32) u32 {
    const imm12: u32 = target_va & 4095u32;
    return (insn & 4290772991u32) | ((imm12 & 4095u32) << 10);
}

fn microapp_aarch64_patch_ldst_lo12(insn: u32, target_va: u32, scale: u32) !u32 {
    const low12: u32 = target_va & 4095u32;
    const scale_i32: !i32 = scale as! i32;
    if scale > 0u32 {
        const align_mask: u32 = (1u32 << scale_i32.value) - 1u32;
        if (low12 & align_mask) != 0u32 {
            return error.InvalidState;
        }
    }
    const imm12: u32 = low12 >> (scale_i32 catch { return 0u32; });
    return (insn & 4290772991u32) | ((imm12 & 4095u32) << 10);
}

fn microapp_macho_fixed_name_equals(buf: &byte, buf_len: usize, off: usize, expected: &byte) i32 {
    if buf == null || expected == null || off + 16usize > buf_len {
        return 0;
    }
    var i: usize = 0usize;
    while i < 16usize {
        const actual_ch: byte = buf[off + i];
        const expected_ch: byte = expected[i];
        if expected_ch == 0 as byte {
            return (actual_ch == 0 as byte) as i32;
        }
        if actual_ch != expected_ch {
            return 0;
        }
        i = i + 1usize;
    }
    return (expected[16] == 0 as byte) as i32;
}

fn microapp_macho_fixed_name_has_prefix(buf: &byte, buf_len: usize, off: usize, prefix: &byte) i32 {
    if buf == null || prefix == null || off + 16usize > buf_len {
        return 0;
    }
    var i: usize = 0usize;
    while i < 16usize {
        const prefix_ch: byte = prefix[i];
        if prefix_ch == 0 as byte {
            return 1;
        }
        if buf[off + i] != prefix_ch {
            return 0;
        }
        i = i + 1usize;
    }
    return 1;
}

fn microapp_macho_arm64_section_kind(obj: &byte, obj_len: usize, sect_base: usize) u32 {
    if obj == null || sect_base + MACHO_SECTION_64_SIZE > obj_len {
        return ELF64_SECTION_KIND_SKIP_RAW;
    }
    const sect_name_off: usize = sect_base;
    const seg_name_off: usize = sect_base + 16usize;
    if microapp_macho_fixed_name_equals(obj, obj_len, seg_name_off, "__TEXT" as &byte) != 0 {
        if microapp_macho_fixed_name_has_prefix(obj, obj_len, sect_name_off, "__text" as &byte) != 0 {
            return ELF64_SECTION_KIND_CODE_RAW;
        }
        if microapp_macho_fixed_name_equals(obj, obj_len, sect_name_off, "__cstring" as &byte) != 0 ||
           microapp_macho_fixed_name_equals(obj, obj_len, sect_name_off, "__const" as &byte) != 0 ||
           microapp_macho_fixed_name_equals(obj, obj_len, sect_name_off, "__literal4" as &byte) != 0 ||
           microapp_macho_fixed_name_equals(obj, obj_len, sect_name_off, "__literal8" as &byte) != 0 ||
           microapp_macho_fixed_name_equals(obj, obj_len, sect_name_off, "__literal16" as &byte) != 0 {
            return ELF64_SECTION_KIND_RODATA_RAW;
        }
    }
    if microapp_macho_fixed_name_equals(obj, obj_len, seg_name_off, "__DATA" as &byte) != 0 {
        if microapp_macho_fixed_name_equals(obj, obj_len, sect_name_off, "__data" as &byte) != 0 {
            return ELF64_SECTION_KIND_DATA_RAW;
        }
        if microapp_macho_fixed_name_equals(obj, obj_len, sect_name_off, "__bss" as &byte) != 0 ||
           microapp_macho_fixed_name_equals(obj, obj_len, sect_name_off, "__common" as &byte) != 0 {
            return ELF64_SECTION_KIND_BSS_RAW;
        }
    }
    return ELF64_SECTION_KIND_SKIP_RAW;
}

fn microapp_macho_align_from_exponent(exp: u32) !u32 {
    if exp >= 31u32 {
        return error.InvalidState;
    }
    if exp == 0u32 {
        return 1u32;
    }
    const exp_i32: !i32 = exp as! i32;
    return 1u32 << (exp_i32 catch { return 0u32; });
}

fn microapp_macho_arm64_patch_pageoff12(insn: u32, target_va: u32) !u32 {
    if (insn & 2130706432u32) == 285212672u32 {
        return microapp_aarch64_patch_add_lo12(insn, target_va);
    }
    if (insn & 4290772992u32) == 960495616u32 {
        return try microapp_aarch64_patch_ldst_lo12(insn, target_va, 0u32);
    }
    if (insn & 4290772992u32) == 2034237440u32 {
        return try microapp_aarch64_patch_ldst_lo12(insn, target_va, 1u32);
    }
    if (insn & 4290772992u32) == 3107979264u32 {
        return try microapp_aarch64_patch_ldst_lo12(insn, target_va, 2u32);
    }
    if (insn & 4290772992u32) == 4181721088u32 {
        return try microapp_aarch64_patch_ldst_lo12(insn, target_va, 3u32);
    }
    if (insn & 4290772992u32) == 1035993088u32 {
        return try microapp_aarch64_patch_ldst_lo12(insn, target_va, 4u32);
    }
    return error.InvalidState;
}

fn microapp_macho_arm64_symbol_value_by_index(obj: &byte, obj_len: usize, symoff: usize, nsyms: u32, stroff: usize, strsize: usize, sym_index: u32, value_out: &u32) i32 {
    if obj == null || value_out == null {
        return 1;
    }
    if sym_index >= nsyms {
        return 1;
    }
    const rec_off: usize = symoff + sym_index as usize * MACHO_NLIST_64_SIZE;
    if microapp_elf_range_valid(obj_len, rec_off as u64, MACHO_NLIST_64_SIZE as u64) == 0 {
        return 1;
    }
    const sect_index: u32 = obj[rec_off + 5usize] as u32;
    if sect_index == 0u32 || sect_index as usize >= ELF64_MAX_SECTIONS {
        return 1;
    }
    const section_kind: u32 = microapp_elf64_section_kind_at(sect_index as usize) catch { return 1; };
    if section_kind == ELF64_SECTION_KIND_SKIP_RAW {
        return 1;
    }
    const section_addr: u32 = microapp_elf64_section_addr_at(sect_index as usize) catch { return 1; };
    const section_va: u32 = microapp_elf64_section_va_at(sect_index as usize) catch { return 1; };
    const value_u64: u64 = read_u64_le_at(obj, rec_off + 8usize);
    if value_u64 > 4294967295u64 {
        return 1;
    }
    const value_raw: u32 = value_u64 as u32;
    if value_raw < section_addr {
        return 1;
    }
    value_out[0] = section_va + (value_raw - section_addr);
    return 0;
}

fn microapp_macho_arm64_find_symbol_value(obj: &byte, obj_len: usize, symoff: usize, nsyms: u32, stroff: usize, strsize: usize, symbol_name: &byte, value_out: &u32) i32 {
    if obj == null || symbol_name == null || value_out == null {
        return 1;
    }
    var sym_index: u32 = 0u32;
    while sym_index < nsyms {
        const rec_off: usize = symoff + sym_index as usize * MACHO_NLIST_64_SIZE;
        if microapp_elf_range_valid(obj_len, rec_off as u64, MACHO_NLIST_64_SIZE as u64) == 0 {
            return 1;
        }
        const strx: u32 = read_u32_le_at(obj, rec_off);
        if microapp_elf_cstring_equals_at(obj, obj_len, stroff, strsize, strx, symbol_name) != 0 {
            return microapp_macho_arm64_symbol_value_by_index(obj, obj_len, symoff, nsyms, stroff, strsize, sym_index, value_out);
        }
        sym_index = sym_index + 1u32;
    }
    return 1;
}

fn microapp_probe_macho_arm64_object_extract(obj_path: &byte) i32 {
    var code_len: u32 = 0u32;
    var rodata_len: u32 = 0u32;
    var data_len: u32 = 0u32;
    var text_va: u32 = 0u32;
    var rodata_va: u32 = 0u32;
    var data_va: u32 = 0u32;
    var bss_va: u32 = 0u32;
    var bss_len: u32 = 0u32;
    var entry_va: u32 = 0u32;
    var base_raw: u32 = 0u32;
    var text_raw: u32 = 0u32;
    var rodata_raw: u32 = 0u32;
    var data_raw: u32 = 0u32;
    var bss_raw: u32 = 0u32;
    var reloc_count: u32 = 0u32;
    var reloc_len: u32 = 0u32;
    if microapp_extract_macho_arm64_object(obj_path, &code_len, &rodata_len, &data_len,
        &text_va, &rodata_va, &data_va, &bss_va, &bss_len, &entry_va,
        &base_raw, &text_raw, &rodata_raw, &data_raw, &bss_raw,
        &reloc_count, &reloc_len) != 0 {
        return 0;
    }
    return 1;
}

fn microapp_extract_macho_arm64_object(obj_path: &byte, code_len: &u32, rodata_len: &u32, data_len: &u32, text_va: &u32, rodata_va: &u32, data_va: &u32, bss_va: &u32, bss_len: &u32, entry_va: &u32, base_raw_out: &u32, text_raw_out: &u32, rodata_raw_out: &u32, data_raw_out: &u32, bss_raw_out: &u32, reloc_count: &u32, reloc_len: &u32) i32 {
    if obj_path == null || code_len == null || rodata_len == null || data_len == null ||
       text_va == null || rodata_va == null || data_va == null || bss_va == null ||
       bss_len == null || entry_va == null || reloc_count == null || reloc_len == null {
        return 1;
    }
    const obj_size: i32 = read_file_content(obj_path, &microapp_pack_output_buffer[0] as &byte, @len(microapp_pack_output_buffer));
    if obj_size < 0 {
        return 1;
    }
    const obj_size_usize: usize = obj_size as usize;
    const obj: &byte = &microapp_pack_output_buffer[0] as &byte;
    if obj_size_usize < 32usize {
        return 1;
    }
    if read_u32_le_at(obj, 0usize) != MACHO_MAGIC_64_RAW {
        return 1;
    }
    if read_u32_le_at(obj, 4usize) != MACHO_CPU_TYPE_ARM64_RAW {
        return 1;
    }
    if read_u32_le_at(obj, 12usize) != MACHO_FILETYPE_OBJECT_RAW {
        return 1;
    }
    const ncmds: u32 = read_u32_le_at(obj, 16usize);
    const sizeofcmds: u32 = read_u32_le_at(obj, 20usize);
    if 32usize + sizeofcmds as usize > obj_size_usize {
        return 1;
    }

    var symoff: usize = 0usize;
    var nsyms: u32 = 0u32;
    var stroff: usize = 0usize;
    var strsize: usize = 0usize;
    var section_count: u32 = 0u32;
    var code_total: u32 = 0u32;
    var rodata_total: u32 = 0u32;
    var data_total: u32 = 0u32;
    var bss_total: u32 = 0u32;
    var code_seg_align: u32 = 1u32;
    var rodata_seg_align: u32 = 1u32;
    var data_seg_align: u32 = 1u32;
    var bss_seg_align: u32 = 1u32;
    var i: usize = 0usize;
    while i < ELF64_MAX_SECTIONS {
        microapp_elf64_section_kind_map[i] = ELF64_SECTION_KIND_SKIP_RAW;
        microapp_elf64_section_off_map[i] = 0u32;
        microapp_elf64_section_va_map[i] = 0u32;
        microapp_elf64_section_addr_map[i] = 0u32;
        i = i + 1usize;
    }

    var cmd_off: usize = 32usize;
    var cmd_idx: u32 = 0u32;
    while cmd_idx < ncmds {
        if cmd_off + 8usize > obj_size_usize {
            return 1;
        }
        const cmd: u32 = read_u32_le_at(obj, cmd_off);
        const cmdsize: u32 = read_u32_le_at(obj, cmd_off + 4usize);
        if cmdsize < 8u32 || cmd_off + cmdsize as usize > obj_size_usize {
            return 1;
        }
        if cmd == MACHO_LOAD_COMMAND_SYMTAB_RAW {
            if cmdsize < 24u32 {
                return 1;
            }
            symoff = read_u32_le_at(obj, cmd_off + 8usize) as usize;
            nsyms = read_u32_le_at(obj, cmd_off + 12usize);
            stroff = read_u32_le_at(obj, cmd_off + 16usize) as usize;
            strsize = read_u32_le_at(obj, cmd_off + 20usize) as usize;
        } else if cmd == MACHO_LOAD_COMMAND_SEGMENT_64_RAW {
            if cmdsize < MACHO_SEGMENT_COMMAND_64_SIZE as u32 {
                return 1;
            }
            const nsects: u32 = read_u32_le_at(obj, cmd_off + 64usize);
            var sect_base: usize = cmd_off + MACHO_SEGMENT_COMMAND_64_SIZE;
            var sect_idx: u32 = 0u32;
            while sect_idx < nsects {
                if section_count + 1u32 >= ELF64_MAX_SECTIONS as u32 || sect_base + MACHO_SECTION_64_SIZE > obj_size_usize {
                    return 1;
                }
                section_count = section_count + 1u32;
                const slot: usize = section_count as usize;
                const kind: u32 = microapp_macho_arm64_section_kind(obj, obj_size_usize, sect_base);
                microapp_elf64_section_kind_map[slot] = kind;
                const sec_addr_u64: u64 = read_u64_le_at(obj, sect_base + 32usize);
                const sec_size_u64: u64 = read_u64_le_at(obj, sect_base + 40usize);
                const sec_align_exp: u32 = read_u32_le_at(obj, sect_base + 52usize);
                if sec_addr_u64 > 4294967295u64 || sec_size_u64 > 4294967295u64 {
                    return 1;
                }
                microapp_elf64_section_addr_map[slot] = sec_addr_u64 as u32;
                if kind != ELF64_SECTION_KIND_SKIP_RAW {
                    var align_u32: u32 = microapp_macho_align_from_exponent(sec_align_exp) catch { return 1; };
                    if align_u32 < 4u32 {
                        align_u32 = 4u32;
                    }
                    const sec_size: u32 = sec_size_u64 as u32;
                    if kind == ELF64_SECTION_KIND_CODE_RAW {
                        const sec_off: u32 = microapp_align_u32(code_total, align_u32);
                        microapp_elf64_section_off_map[slot] = sec_off;
                        code_total = sec_off + sec_size;
                        if align_u32 > code_seg_align { code_seg_align = align_u32; }
                    } else if kind == ELF64_SECTION_KIND_RODATA_RAW {
                        const sec_off: u32 = microapp_align_u32(rodata_total, align_u32);
                        microapp_elf64_section_off_map[slot] = sec_off;
                        rodata_total = sec_off + sec_size;
                        if align_u32 > rodata_seg_align { rodata_seg_align = align_u32; }
                    } else if kind == ELF64_SECTION_KIND_DATA_RAW {
                        const sec_off: u32 = microapp_align_u32(data_total, align_u32);
                        microapp_elf64_section_off_map[slot] = sec_off;
                        data_total = sec_off + sec_size;
                        if align_u32 > data_seg_align { data_seg_align = align_u32; }
                    } else if kind == ELF64_SECTION_KIND_BSS_RAW {
                        const sec_off: u32 = microapp_align_u32(bss_total, align_u32);
                        microapp_elf64_section_off_map[slot] = sec_off;
                        bss_total = sec_off + sec_size;
                        if align_u32 > bss_seg_align { bss_seg_align = align_u32; }
                    }
                }
                sect_base = sect_base + MACHO_SECTION_64_SIZE;
                sect_idx = sect_idx + 1u32;
            }
        }
        cmd_off = cmd_off + cmdsize as usize;
        cmd_idx = cmd_idx + 1u32;
    }

    if symoff == 0usize || nsyms == 0u32 || stroff == 0usize || code_total == 0u32 {
        return 1;
    }
    if microapp_elf_range_valid(obj_size_usize, symoff as u64, nsyms as u64 * MACHO_NLIST_64_SIZE as u64) == 0 {
        return 1;
    }
    if microapp_elf_range_valid(obj_size_usize, stroff as u64, strsize as u64) == 0 {
        return 1;
    }

    const code_base_va: u32 = microapp_align_u32(MICROAPP_VADDR_BASE, code_seg_align);
    const rodata_base_va: u32 = microapp_align_u32(code_base_va + code_total, rodata_seg_align);
    const data_base_va: u32 = microapp_align_u32(rodata_base_va + rodata_total, data_seg_align);
    const bss_base_va: u32 = microapp_align_u32(data_base_va + data_total, bss_seg_align);
    microapp_zero_byte_range(&file_buffer[0] as &byte, code_total);
    microapp_zero_byte_range(&microapp_rodata_buffer[0] as &byte, rodata_total);
    microapp_zero_byte_range(&microapp_data_buffer[0] as &byte, data_total);

    cmd_off = 32usize;
    cmd_idx = 0u32;
    var fill_section: u32 = 0u32;
    while cmd_idx < ncmds {
        const cmd: u32 = read_u32_le_at(obj, cmd_off);
        const cmdsize: u32 = read_u32_le_at(obj, cmd_off + 4usize);
        if cmd == MACHO_LOAD_COMMAND_SEGMENT_64_RAW {
            const nsects: u32 = read_u32_le_at(obj, cmd_off + 64usize);
            var sect_base: usize = cmd_off + MACHO_SEGMENT_COMMAND_64_SIZE;
            var sect_idx: u32 = 0u32;
            while sect_idx < nsects {
                fill_section = fill_section + 1u32;
                if fill_section as usize >= ELF64_MAX_SECTIONS {
                    return 1;
                }
                const slot: usize = fill_section as usize;
                const kind: u32 = microapp_elf64_section_kind_at(slot) catch { return 1; };
                const sec_off: u32 = microapp_elf64_section_off_at(slot) catch { return 1; };
                const sec_addr_u64: u64 = read_u64_le_at(obj, sect_base + 32usize);
                const sec_size_u64: u64 = read_u64_le_at(obj, sect_base + 40usize);
                const sec_file_off: u32 = read_u32_le_at(obj, sect_base + 48usize);
                const sec_size: u32 = sec_size_u64 as u32;
                if kind == ELF64_SECTION_KIND_CODE_RAW {
                    microapp_elf64_section_va_map[slot] = code_base_va + sec_off;
                    if sec_size > 0u32 {
                        if microapp_elf_range_valid(obj_size_usize, sec_file_off as u64, sec_size as u64) == 0 {
                            return 1;
                        }
                        memcpy((&file_buffer[sec_off as usize]) as *void, (obj + sec_file_off as usize) as *void, sec_size as usize);
                    }
                } else if kind == ELF64_SECTION_KIND_RODATA_RAW {
                    microapp_elf64_section_va_map[slot] = rodata_base_va + sec_off;
                    if sec_size > 0u32 {
                        if microapp_elf_range_valid(obj_size_usize, sec_file_off as u64, sec_size as u64) == 0 {
                            return 1;
                        }
                        memcpy((&microapp_rodata_buffer[sec_off as usize]) as *void, (obj + sec_file_off as usize) as *void, sec_size as usize);
                    }
                } else if kind == ELF64_SECTION_KIND_DATA_RAW {
                    microapp_elf64_section_va_map[slot] = data_base_va + sec_off;
                    if sec_size > 0u32 {
                        if microapp_elf_range_valid(obj_size_usize, sec_file_off as u64, sec_size as u64) == 0 {
                            return 1;
                        }
                        memcpy((&microapp_data_buffer[sec_off as usize]) as *void, (obj + sec_file_off as usize) as *void, sec_size as usize);
                    }
                } else if kind == ELF64_SECTION_KIND_BSS_RAW {
                    microapp_elf64_section_va_map[slot] = bss_base_va + sec_off;
                }
                sect_base = sect_base + MACHO_SECTION_64_SIZE;
                sect_idx = sect_idx + 1u32;
            }
        }
        cmd_off = cmd_off + cmdsize as usize;
        cmd_idx = cmd_idx + 1u32;
    }

    var entry_value: u32 = 0u32;
    if microapp_macho_arm64_find_symbol_value(obj, obj_size_usize, symoff, nsyms, stroff, strsize, "_main_main" as &byte, &entry_value) != 0 {
        if microapp_macho_arm64_find_symbol_value(obj, obj_size_usize, symoff, nsyms, stroff, strsize, "_main" as &byte, &entry_value) != 0 {
            if microapp_macho_arm64_find_symbol_value(obj, obj_size_usize, symoff, nsyms, stroff, strsize, "main_main" as &byte, &entry_value) != 0 {
                if microapp_macho_arm64_find_symbol_value(obj, obj_size_usize, symoff, nsyms, stroff, strsize, "main" as &byte, &entry_value) != 0 {
                    return 1;
                }
            }
        }
    }

    var out_count: u32 = 0u32;
    cmd_off = 32usize;
    cmd_idx = 0u32;
    var reloc_section: u32 = 0u32;
    while cmd_idx < ncmds {
        const cmd: u32 = read_u32_le_at(obj, cmd_off);
        const cmdsize: u32 = read_u32_le_at(obj, cmd_off + 4usize);
        if cmd == MACHO_LOAD_COMMAND_SEGMENT_64_RAW {
            const nsects: u32 = read_u32_le_at(obj, cmd_off + 64usize);
            var sect_base: usize = cmd_off + MACHO_SEGMENT_COMMAND_64_SIZE;
            var sect_idx: u32 = 0u32;
            while sect_idx < nsects {
                reloc_section = reloc_section + 1u32;
                if reloc_section as usize >= ELF64_MAX_SECTIONS {
                    return 1;
                }
                const slot: usize = reloc_section as usize;
                const target_kind: u32 = microapp_elf64_section_kind_at(slot) catch { return 1; };
                const target_section_va: u32 = microapp_elf64_section_va_at(slot) catch { return 1; };
                const target_section_off: u32 = microapp_elf64_section_off_at(slot) catch { return 1; };
                const reloff: u32 = read_u32_le_at(obj, sect_base + 56usize);
                const nreloc: u32 = read_u32_le_at(obj, sect_base + 60usize);
                var reloc_idx: u32 = 0u32;
                while reloc_idx < nreloc {
                    const rec_off: usize = reloff as usize + reloc_idx as usize * 8usize;
                    if microapp_elf_range_valid(obj_size_usize, rec_off as u64, 8u64) == 0 {
                        return 1;
                    }
                    const r_address: u32 = read_u32_le_at(obj, rec_off);
                    const raw: u32 = read_u32_le_at(obj, rec_off + 4usize);
                    const r_symbolnum: u32 = raw & 16777215u32;
                    const r_length: u32 = (raw >> 25) & 3u32;
                    const r_extern: u32 = (raw >> 27) & 1u32;
                    const r_type: u32 = (raw >> 28) & 15u32;
                    var sym_value_u32: u32 = 0u32;
                    if r_extern != 0u32 {
                        if microapp_macho_arm64_symbol_value_by_index(obj, obj_size_usize, symoff, nsyms, stroff, strsize, r_symbolnum, &sym_value_u32) != 0 {
                            return 1;
                        }
                    } else {
                        if r_symbolnum == 0u32 || r_symbolnum as usize >= ELF64_MAX_SECTIONS {
                            return 1;
                        }
                        sym_value_u32 = microapp_elf64_section_va_at(r_symbolnum as usize) catch { return 1; };
                    }
                    const target_va_abs: u32 = target_section_va + r_address;
                    if target_kind == ELF64_SECTION_KIND_CODE_RAW {
                        if r_length != 2u32 {
                            return 1;
                        }
                        const patch_off: usize = target_section_off as usize + r_address as usize;
                        if patch_off + 4usize > code_total as usize {
                            return 1;
                        }
                        const insn: u32 = read_u32_le_at(&file_buffer[0] as &byte, patch_off);
                        var patched: u32 = 0u32;
                        if r_type == MACHO_ARM64_RELOC_BRANCH26_RAW {
                            patched = microapp_aarch64_patch_branch26(insn, target_va_abs, sym_value_u32) catch { return 1; };
                        } else if r_type == MACHO_ARM64_RELOC_PAGE21_RAW {
                            patched = microapp_aarch64_patch_adrp_hi21(insn, target_va_abs, sym_value_u32) catch { return 1; };
                        } else if r_type == MACHO_ARM64_RELOC_PAGEOFF12_RAW {
                            patched = microapp_macho_arm64_patch_pageoff12(insn, sym_value_u32) catch { return 1; };
                        } else {
                            return 1;
                        }
                        write_u32_le_at(&file_buffer[0] as &byte, patch_off, patched);
                    } else if (target_kind == ELF64_SECTION_KIND_DATA_RAW || target_kind == ELF64_SECTION_KIND_BSS_RAW) &&
                              r_type == MACHO_ARM64_RELOC_UNSIGNED_RAW {
                        if r_length != 3u32 {
                            return 1;
                        }
                        const out_off: usize = out_count as usize * 8usize;
                        if out_off + 8usize > FILE_BUFFER_SIZE as usize {
                            return 1;
                        }
                        write_u32_le_at(&microapp_reloc_buffer[0] as &byte, out_off, target_va_abs);
                        write_u32_le_at(&microapp_reloc_buffer[0] as &byte, out_off + 4usize, sym_value_u32);
                        out_count = out_count + 1u32;
                    } else {
                        return 1;
                    }
                    reloc_idx = reloc_idx + 1u32;
                }
                sect_base = sect_base + MACHO_SECTION_64_SIZE;
                sect_idx = sect_idx + 1u32;
            }
        }
        cmd_off = cmd_off + cmdsize as usize;
        cmd_idx = cmd_idx + 1u32;
    }

    code_len[0] = code_total;
    rodata_len[0] = rodata_total;
    data_len[0] = data_total;
    text_va[0] = code_base_va;
    rodata_va[0] = rodata_base_va;
    data_va[0] = data_base_va;
    if bss_total > 0u32 {
        bss_va[0] = bss_base_va;
    } else {
        bss_va[0] = 0u32;
    }
    bss_len[0] = bss_total;
    entry_va[0] = entry_value;
    if base_raw_out != null { base_raw_out[0] = MICROAPP_VADDR_BASE; }
    if text_raw_out != null { text_raw_out[0] = code_base_va; }
    if rodata_raw_out != null { rodata_raw_out[0] = rodata_base_va; }
    if data_raw_out != null { data_raw_out[0] = data_base_va; }
    if bss_raw_out != null { bss_raw_out[0] = bss_va[0]; }
    reloc_count[0] = out_count;
    reloc_len[0] = out_count * 8u32;
    return 0;
}

fn microapp_probe_object_elf64_extract(obj_path: &byte, target_arch_raw: u32) i32 {
    var code_len: u32 = 0u32;
    var rodata_len: u32 = 0u32;
    var data_len: u32 = 0u32;
    var text_va: u32 = 0u32;
    var rodata_va: u32 = 0u32;
    var data_va: u32 = 0u32;
    var bss_va: u32 = 0u32;
    var bss_len: u32 = 0u32;
    var entry_va: u32 = 0u32;
    var base_raw: u32 = 0u32;
    var text_raw: u32 = 0u32;
    var rodata_raw: u32 = 0u32;
    var data_raw: u32 = 0u32;
    var bss_raw: u32 = 0u32;
    var reloc_count: u32 = 0u32;
    var reloc_len: u32 = 0u32;
    if microapp_extract_object_elf64(obj_path, target_arch_raw, &code_len, &rodata_len, &data_len,
        &text_va, &rodata_va, &data_va, &bss_va, &bss_len, &entry_va,
        &base_raw, &text_raw, &rodata_raw, &data_raw, &bss_raw,
        &reloc_count, &reloc_len) != 0 {
        return 0;
    }
    return 1;
}

fn microapp_extract_object_elf64(obj_path: &byte, target_arch_raw: u32, code_len: &u32, rodata_len: &u32, data_len: &u32, text_va: &u32, rodata_va: &u32, data_va: &u32, bss_va: &u32, bss_len: &u32, entry_va: &u32, base_raw_out: &u32, text_raw_out: &u32, rodata_raw_out: &u32, data_raw_out: &u32, bss_raw_out: &u32, reloc_count: &u32, reloc_len: &u32) i32 {
    if obj_path == null || code_len == null || rodata_len == null || data_len == null ||
       text_va == null || rodata_va == null || data_va == null || bss_va == null ||
       bss_len == null || entry_va == null || reloc_count == null || reloc_len == null {
        return 1;
    }
    if target_arch_raw != MICROAPP_TARGET_ARCH_X86_64_RAW &&
       target_arch_raw != MICROAPP_TARGET_ARCH_AARCH64_RAW {
        return 1;
    }
    const elf_size: i32 = read_file_content(obj_path, &microapp_pack_output_buffer[0] as &byte, @len(microapp_pack_output_buffer));
    if elf_size < 0 {
        return 1;
    }
    const elf_size_usize: usize = elf_size as usize;
    if elf_size_usize < ELF64_HEADER_SIZE {
        return 1;
    }
    const elf: &byte = &microapp_pack_output_buffer[0] as &byte;
    if elf[0] != 127 as byte || elf[1] != 69 as byte || elf[2] != 76 as byte || elf[3] != 70 as byte {
        return 1;
    }
    if elf[4] != ELFCLASS64_RAW || elf[5] != ELFDATA2LSB_RAW {
        return 1;
    }
    if read_u16_le_at(elf, 16usize) != 1u16 {
        return 1;
    }
    var expected_machine: u16 = ELF_MACHINE_X86_64_RAW;
    if target_arch_raw == MICROAPP_TARGET_ARCH_AARCH64_RAW {
        expected_machine = ELF_MACHINE_AARCH64_RAW;
    }
    if read_u16_le_at(elf, 18usize) != expected_machine {
        return 1;
    }
    const shoff_u64: u64 = read_u64_le_at(elf, 40usize);
    const shentsize: usize = read_u16_le_at(elf, 58usize) as usize;
    const shnum: usize = read_u16_le_at(elf, 60usize) as usize;
    const shstrndx: usize = read_u16_le_at(elf, 62usize) as usize;
    if shnum == 0usize || shnum > ELF64_MAX_SECTIONS || shstrndx >= shnum || shentsize < ELF64_SECTION_HEADER_SIZE {
        return 1;
    }
    const shoff: usize = shoff_u64 as usize;
    if shoff + shentsize * shnum > elf_size_usize {
        return 1;
    }
    const shstr_base: usize = shoff + shstrndx * shentsize;
    if shstr_base + ELF64_SECTION_HEADER_SIZE > elf_size_usize {
        return 1;
    }
    const shstr_off_u64: u64 = read_u64_le_at(elf, shstr_base + 24usize);
    const shstr_size_u64: u64 = read_u64_le_at(elf, shstr_base + 32usize);
    if microapp_elf_range_valid(elf_size_usize, shstr_off_u64, shstr_size_u64) == 0 {
        return 1;
    }
    const shstr_off: usize = shstr_off_u64 as usize;
    const shstr_size: usize = shstr_size_u64 as usize;

    var code_total: u32 = 0u32;
    var rodata_total: u32 = 0u32;
    var data_total: u32 = 0u32;
    var bss_total: u32 = 0u32;
    var code_seg_align: u32 = 1u32;
    var rodata_seg_align: u32 = 1u32;
    var data_seg_align: u32 = 1u32;
    var bss_seg_align: u32 = 1u32;
    var i: usize = 0usize;
    while i < shnum {
        microapp_elf64_section_kind_map[i] = ELF64_SECTION_KIND_SKIP_RAW;
        microapp_elf64_section_off_map[i] = 0u32;
        microapp_elf64_section_va_map[i] = 0u32;
        i = i + 1usize;
    }
    i = 0usize;
    while i < shnum {
        const sh_base: usize = shoff + i * shentsize;
        const sh_name: u32 = read_u32_le_at(elf, sh_base);
        const sh_type: u32 = read_u32_le_at(elf, sh_base + 4usize);
        const sh_flags: u64 = read_u64_le_at(elf, sh_base + 8usize);
        const sh_size_u64: u64 = read_u64_le_at(elf, sh_base + 32usize);
        const sh_align_u64: u64 = read_u64_le_at(elf, sh_base + 48usize);
        if sh_size_u64 > 4294967295u64 || sh_align_u64 > 4294967295u64 {
            return 1;
        }
        const kind: u32 = microapp_object_elf64_section_kind(elf, elf_size_usize, shstr_off, shstr_size, sh_name, sh_type, sh_flags);
        microapp_elf64_section_kind_map[i] = kind;
        if kind != ELF64_SECTION_KIND_SKIP_RAW {
            var align_u32: u32 = sh_align_u64 as u32;
            if align_u32 == 0u32 {
                align_u32 = 1u32;
            }
            if align_u32 < 4u32 {
                align_u32 = 4u32;
            }
            const sec_size: u32 = sh_size_u64 as u32;
            if kind == ELF64_SECTION_KIND_CODE_RAW {
                const sec_off: u32 = microapp_align_u32(code_total, align_u32);
                microapp_elf64_section_off_map[i] = sec_off;
                code_total = sec_off + sec_size;
                if align_u32 > code_seg_align {
                    code_seg_align = align_u32;
                }
            } else if kind == ELF64_SECTION_KIND_RODATA_RAW {
                const sec_off: u32 = microapp_align_u32(rodata_total, align_u32);
                microapp_elf64_section_off_map[i] = sec_off;
                rodata_total = sec_off + sec_size;
                if align_u32 > rodata_seg_align {
                    rodata_seg_align = align_u32;
                }
            } else if kind == ELF64_SECTION_KIND_DATA_RAW {
                const sec_off: u32 = microapp_align_u32(data_total, align_u32);
                microapp_elf64_section_off_map[i] = sec_off;
                data_total = sec_off + sec_size;
                if align_u32 > data_seg_align {
                    data_seg_align = align_u32;
                }
            } else if kind == ELF64_SECTION_KIND_BSS_RAW {
                const sec_off: u32 = microapp_align_u32(bss_total, align_u32);
                microapp_elf64_section_off_map[i] = sec_off;
                bss_total = sec_off + sec_size;
                if align_u32 > bss_seg_align {
                    bss_seg_align = align_u32;
                }
            }
        }
        i = i + 1usize;
    }
    if code_total == 0u32 {
        return 1;
    }
    const code_base_va: u32 = microapp_align_u32(MICROAPP_VADDR_BASE, code_seg_align);
    const rodata_base_va: u32 = microapp_align_u32(code_base_va + code_total, rodata_seg_align);
    const data_base_va: u32 = microapp_align_u32(rodata_base_va + rodata_total, data_seg_align);
    const bss_base_va: u32 = microapp_align_u32(data_base_va + data_total, bss_seg_align);
    microapp_zero_byte_range(&file_buffer[0] as &byte, code_total);
    microapp_zero_byte_range(&microapp_rodata_buffer[0] as &byte, rodata_total);
    microapp_zero_byte_range(&microapp_data_buffer[0] as &byte, data_total);
    i = 0usize;
    while i < shnum {
        const kind: u32 = microapp_elf64_section_kind_map[i];
        const sec_off: u32 = microapp_elf64_section_off_map[i];
        const sh_base: usize = shoff + i * shentsize;
        const sh_type: u32 = read_u32_le_at(elf, sh_base + 4usize);
        const sh_offset_u64: u64 = read_u64_le_at(elf, sh_base + 24usize);
        const sh_size_u64: u64 = read_u64_le_at(elf, sh_base + 32usize);
        if kind == ELF64_SECTION_KIND_CODE_RAW {
            microapp_elf64_section_va_map[i] = code_base_va + sec_off;
            if sh_type == ELF64_SECTION_TYPE_PROGBITS_RAW && sh_size_u64 > 0u64 {
                if microapp_elf_range_valid(elf_size_usize, sh_offset_u64, sh_size_u64) == 0 {
                    return 1;
                }
                memcpy((&file_buffer[sec_off as usize]) as *void, (elf + sh_offset_u64 as usize) as *void, sh_size_u64 as usize);
            }
        } else if kind == ELF64_SECTION_KIND_RODATA_RAW {
            microapp_elf64_section_va_map[i] = rodata_base_va + sec_off;
            if sh_type == ELF64_SECTION_TYPE_PROGBITS_RAW && sh_size_u64 > 0u64 {
                if microapp_elf_range_valid(elf_size_usize, sh_offset_u64, sh_size_u64) == 0 {
                    return 1;
                }
                memcpy((&microapp_rodata_buffer[sec_off as usize]) as *void, (elf + sh_offset_u64 as usize) as *void, sh_size_u64 as usize);
            }
        } else if kind == ELF64_SECTION_KIND_DATA_RAW {
            microapp_elf64_section_va_map[i] = data_base_va + sec_off;
            if sh_type == ELF64_SECTION_TYPE_PROGBITS_RAW && sh_size_u64 > 0u64 {
                if microapp_elf_range_valid(elf_size_usize, sh_offset_u64, sh_size_u64) == 0 {
                    return 1;
                }
                memcpy((&microapp_data_buffer[sec_off as usize]) as *void, (elf + sh_offset_u64 as usize) as *void, sh_size_u64 as usize);
            }
        } else if kind == ELF64_SECTION_KIND_BSS_RAW {
            microapp_elf64_section_va_map[i] = bss_base_va + sec_off;
        }
        i = i + 1usize;
    }

    var entry_value: u32 = 0u32;
    if microapp_object_elf64_find_symbol_value(elf, elf_size_usize, shoff, shentsize, shnum, "main_main" as &byte, &entry_value) != 0 {
        if microapp_object_elf64_find_symbol_value(elf, elf_size_usize, shoff, shentsize, shnum, "main" as &byte, &entry_value) != 0 {
            return 1;
        }
    }

    var out_count: u32 = 0u32;
    i = 0usize;
    while i < shnum {
        const sh_base: usize = shoff + i * shentsize;
        const sh_type: u32 = read_u32_le_at(elf, sh_base + 4usize);
        if sh_type == ELF64_SECTION_TYPE_RELA_RAW {
            const target_section_index: u32 = read_u32_le_at(elf, sh_base + 44usize);
            if target_section_index as usize >= shnum || target_section_index as usize >= ELF64_MAX_SECTIONS {
                return 1;
            }
            const target_section_slot: usize = target_section_index as usize;
            if target_section_slot >= @len(microapp_elf64_section_kind_map) {
                return 1;
            }
            var target_kind: u32 = ELF64_SECTION_KIND_SKIP_RAW;
            if target_section_slot < @len(microapp_elf64_section_kind_map) {
                target_kind = microapp_elf64_section_kind_at(target_section_slot) catch { return 1; };
            } else {
                return 1;
            }
            if target_kind == ELF64_SECTION_KIND_SKIP_RAW {
                i = i + 1usize;
                continue;
            }
            const symtab_index: u32 = read_u32_le_at(elf, sh_base + 40usize);
            const rela_off_u64: u64 = read_u64_le_at(elf, sh_base + 24usize);
            const rela_size_u64: u64 = read_u64_le_at(elf, sh_base + 32usize);
            const rela_entsize_u64: u64 = read_u64_le_at(elf, sh_base + 56usize);
            if microapp_elf_range_valid(elf_size_usize, rela_off_u64, rela_size_u64) == 0 || rela_entsize_u64 < ELF64_RELA_SIZE as u64 {
                return 1;
            }
            var rela_pos: u64 = 0u64;
            while rela_pos + ELF64_RELA_SIZE as u64 <= rela_size_u64 {
                const rec_off: u64 = rela_off_u64 + rela_pos;
                const target_sec_off_u32: u32 = read_u64_le_at(elf, rec_off as usize) as u32;
                const info_u64: u64 = read_u64_le_at(elf, rec_off as usize + 8usize);
                const addend_u64: u64 = read_u64_le_at(elf, rec_off as usize + 16usize);
                const reloc_type: u32 = (info_u64 & 4294967295u64) as u32;
                const sym_index: u32 = ((info_u64 >> 32) & 4294967295u64) as u32;
                const target_section_va: u32 = microapp_elf64_section_va_at(target_section_slot) catch { return 1; };
                const target_va_abs: u32 = target_section_va + target_sec_off_u32;
                var sym_value_u32: u32 = 0u32;
                if microapp_object_elf64_symbol_value_by_index(elf, elf_size_usize, shoff, shentsize, shnum, symtab_index, sym_index, &sym_value_u32) != 0 {
                    return 1;
                }
                if target_arch_raw == MICROAPP_TARGET_ARCH_X86_64_RAW &&
                   target_kind == ELF64_SECTION_KIND_CODE_RAW &&
                   (reloc_type == ELF_RELOC_X86_64_PC32_RAW || reloc_type == ELF_RELOC_X86_64_PLT32_RAW) {
                    const target_section_off: u32 = microapp_elf64_section_off_at(target_section_slot) catch { return 1; };
                    const patch_off: usize = target_section_off as usize + target_sec_off_u32 as usize;
                    if patch_off + 4usize > code_total as usize {
                        return 1;
                    }
                    const disp_u64: u64 = sym_value_u32 as u64 + addend_u64 - target_va_abs as u64;
                    write_u32_le_at(&file_buffer[0] as &byte, patch_off, disp_u64 as u32);
                } else if target_arch_raw == MICROAPP_TARGET_ARCH_X86_64_RAW &&
                          (target_kind == ELF64_SECTION_KIND_DATA_RAW || target_kind == ELF64_SECTION_KIND_BSS_RAW) &&
                          (reloc_type == ELF_RELOC_X86_64_64_RAW || reloc_type == ELF_RELOC_X86_64_GLOB_DAT_RAW) {
                    const value_u64: u64 = sym_value_u32 as u64 + addend_u64;
                    if value_u64 > 4294967295u64 {
                        return 1;
                    }
                    const out_off: usize = out_count as usize * 8usize;
                    if out_off + 8usize > FILE_BUFFER_SIZE as usize {
                        return 1;
                    }
                    write_u32_le_at(&microapp_reloc_buffer[0] as &byte, out_off, target_va_abs);
                    write_u32_le_at(&microapp_reloc_buffer[0] as &byte, out_off + 4usize, value_u64 as u32);
                    out_count = out_count + 1u32;
                } else if target_arch_raw == MICROAPP_TARGET_ARCH_AARCH64_RAW &&
                          target_kind == ELF64_SECTION_KIND_CODE_RAW {
                    if addend_u64 > 4294967295u64 {
                        return 1;
                    }
                    const value_u64: u64 = sym_value_u32 as u64 + addend_u64;
                    if value_u64 > 4294967295u64 {
                        return 1;
                    }
                    const value_u32: u32 = value_u64 as u32;
                    const target_section_off: u32 = microapp_elf64_section_off_at(target_section_slot) catch { return 1; };
                    const patch_off: usize = target_section_off as usize + target_sec_off_u32 as usize;
                    if patch_off + 4usize > code_total as usize {
                        return 1;
                    }
                    const insn: u32 = read_u32_le_at(&file_buffer[0] as &byte, patch_off);
                    var patched: u32 = 0u32;
                    if reloc_type == ELF_RELOC_AARCH64_CALL26_RAW || reloc_type == ELF_RELOC_AARCH64_JUMP26_RAW {
                        patched = microapp_aarch64_patch_branch26(insn, target_va_abs, value_u32) catch { return 1; };
                    } else if reloc_type == ELF_RELOC_AARCH64_ADR_PREL_LO21_RAW {
                        patched = microapp_aarch64_patch_adr_lo21(insn, target_va_abs, value_u32) catch { return 1; };
                    } else if reloc_type == ELF_RELOC_AARCH64_ADR_PREL_PG_HI21_RAW ||
                              reloc_type == ELF_RELOC_AARCH64_ADR_PREL_PG_HI21_NC_RAW {
                        patched = microapp_aarch64_patch_adrp_hi21(insn, target_va_abs, value_u32) catch { return 1; };
                    } else if reloc_type == ELF_RELOC_AARCH64_ADD_ABS_LO12_NC_RAW {
                        patched = microapp_aarch64_patch_add_lo12(insn, value_u32);
                    } else if reloc_type == ELF_RELOC_AARCH64_LD_PREL_LO19_RAW {
                        patched = microapp_aarch64_patch_ld_prel_lo19(insn, target_va_abs, value_u32) catch { return 1; };
                    } else if reloc_type == ELF_RELOC_AARCH64_LDST8_ABS_LO12_NC_RAW {
                        patched = microapp_aarch64_patch_ldst_lo12(insn, value_u32, 0u32) catch { return 1; };
                    } else if reloc_type == ELF_RELOC_AARCH64_LDST16_ABS_LO12_NC_RAW {
                        patched = microapp_aarch64_patch_ldst_lo12(insn, value_u32, 1u32) catch { return 1; };
                    } else if reloc_type == ELF_RELOC_AARCH64_LDST32_ABS_LO12_NC_RAW {
                        patched = microapp_aarch64_patch_ldst_lo12(insn, value_u32, 2u32) catch { return 1; };
                    } else if reloc_type == ELF_RELOC_AARCH64_LDST64_ABS_LO12_NC_RAW {
                        patched = microapp_aarch64_patch_ldst_lo12(insn, value_u32, 3u32) catch { return 1; };
                    } else if reloc_type == ELF_RELOC_AARCH64_LDST128_ABS_LO12_NC_RAW {
                        patched = microapp_aarch64_patch_ldst_lo12(insn, value_u32, 4u32) catch { return 1; };
                    } else {
                        return 1;
                    }
                    write_u32_le_at(&file_buffer[0] as &byte, patch_off, patched);
                } else if target_arch_raw == MICROAPP_TARGET_ARCH_AARCH64_RAW &&
                          (target_kind == ELF64_SECTION_KIND_DATA_RAW || target_kind == ELF64_SECTION_KIND_BSS_RAW) &&
                          (reloc_type == ELF_RELOC_AARCH64_ABS64_RAW || reloc_type == ELF_RELOC_AARCH64_GLOB_DAT_RAW) {
                    const value_u64: u64 = sym_value_u32 as u64 + addend_u64;
                    if value_u64 > 4294967295u64 {
                        return 1;
                    }
                    const out_off: usize = out_count as usize * 8usize;
                    if out_off + 8usize > FILE_BUFFER_SIZE as usize {
                        return 1;
                    }
                    write_u32_le_at(&microapp_reloc_buffer[0] as &byte, out_off, target_va_abs);
                    write_u32_le_at(&microapp_reloc_buffer[0] as &byte, out_off + 4usize, value_u64 as u32);
                    out_count = out_count + 1u32;
                } else {
                    return 1;
                }
                rela_pos = rela_pos + rela_entsize_u64;
            }
        }
        i = i + 1usize;
    }

    code_len[0] = code_total;
    rodata_len[0] = rodata_total;
    data_len[0] = data_total;
    text_va[0] = code_base_va;
    rodata_va[0] = rodata_base_va;
    data_va[0] = data_base_va;
    if bss_total > 0u32 {
        bss_va[0] = bss_base_va;
    } else {
        bss_va[0] = 0u32;
    }
    bss_len[0] = bss_total;
    entry_va[0] = entry_value;
    if base_raw_out != null { base_raw_out[0] = MICROAPP_VADDR_BASE; }
    if text_raw_out != null { text_raw_out[0] = code_base_va; }
    if rodata_raw_out != null { rodata_raw_out[0] = rodata_base_va; }
    if data_raw_out != null { data_raw_out[0] = data_base_va; }
    if bss_raw_out != null { bss_raw_out[0] = bss_va[0]; }
    reloc_count[0] = out_count;
    reloc_len[0] = out_count * 8u32;
    return 0;
}

fn microapp_token_bounds(line: &byte, line_len: usize, token_index: i32, token_start: &usize, token_end: &usize) i32 {
    var idx: i32 = 0;
    var pos: usize = 0;
    while pos < line_len {
        while pos < line_len && microapp_ascii_is_space(line[pos]) != 0 {
            pos = pos + 1;
        }
        if pos >= line_len {
            break;
        }
        const start: usize = pos;
        while pos < line_len && microapp_ascii_is_space(line[pos]) == 0 {
            pos = pos + 1;
        }
        if idx == token_index {
            token_start[0] = start;
            token_end[0] = pos;
            return 1;
        }
        idx = idx + 1;
    }
    return 0;
}

fn microapp_token_equals(line: &byte, token_start: usize, token_end: usize, expected: &byte) i32 {
    const expected_len: usize = strlen(expected as *byte);
    if token_end - token_start != expected_len {
        return 0;
    }
    var i: usize = 0;
    while i < expected_len {
        if line[token_start + i] != expected[i] {
            return 0;
        }
        i = i + 1;
    }
    return 1;
}

fn microapp_section_field_from_report(report: &byte, report_len: usize, section_name: &byte, field_token_index: i32) !u32 {
    var line_start: usize = 0;
    while line_start < report_len {
        var line_end: usize = line_start;
        while line_end < report_len && report[line_end] != 10 as byte {
            line_end = line_end + 1;
        }
        var tok0_s: usize = 0;
        var tok0_e: usize = 0;
        var tok1_s: usize = 0;
        var tok1_e: usize = 0;
        var field_s: usize = 0;
        var field_e: usize = 0;
        if microapp_token_bounds(report + line_start, line_end - line_start, 0, &tok0_s, &tok0_e) != 0 &&
           microapp_token_bounds(report + line_start, line_end - line_start, 1, &tok1_s, &tok1_e) != 0 &&
           microapp_token_bounds(report + line_start, line_end - line_start, field_token_index, &field_s, &field_e) != 0 {
            if microapp_token_equals(report + line_start, tok1_s, tok1_e, section_name) != 0 {
                return try microapp_hex_to_u32_span(report + line_start, field_s, field_e);
            }
        }
        if line_end >= report_len {
            break;
        }
        line_start = line_end + 1;
    }
    return error.InvalidState;
}

fn microapp_section_vma_from_report(report: &byte, report_len: usize, section_name: &byte) !u32 {
    return try microapp_section_field_from_report(report, report_len, section_name, 3);
}

fn microapp_section_size_from_report(report: &byte, report_len: usize, section_name: &byte) !u32 {
    return try microapp_section_field_from_report(report, report_len, section_name, 2);
}

fn microapp_symbol_vma_from_report(report: &byte, report_len: usize, symbol_name: &byte) !u32 {
    var line_start: usize = 0;
    while line_start < report_len {
        var line_end: usize = line_start;
        while line_end < report_len && report[line_end] != 10 as byte {
            line_end = line_end + 1;
        }
        var tok0_s: usize = 0;
        var tok0_e: usize = 0;
        var tok2_s: usize = 0;
        var tok2_e: usize = 0;
        if microapp_token_bounds(report + line_start, line_end - line_start, 0, &tok0_s, &tok0_e) != 0 &&
           microapp_token_bounds(report + line_start, line_end - line_start, 2, &tok2_s, &tok2_e) != 0 {
            if microapp_token_equals(report + line_start, tok2_s, tok2_e, symbol_name) != 0 {
                return try microapp_hex_to_u32_span(report + line_start, tok0_s, tok0_e);
            }
        }
        if line_end >= report_len {
            break;
        }
        line_start = line_end + 1;
    }
    return error.InvalidState;
}

fn microapp_reloc_count_from_report(report: &byte, report_len: usize) u32 {
    var total: u32 = 0u32;
    var i: usize = 0;
    while i + 10usize < report_len {
        if report[i] == 32 as byte && report[i + 1usize] == 99 as byte &&
           report[i + 2usize] == 111 as byte && report[i + 3usize] == 110 as byte &&
           report[i + 4usize] == 116 as byte && report[i + 5usize] == 97 as byte &&
           report[i + 6usize] == 105 as byte && report[i + 7usize] == 110 as byte &&
           report[i + 8usize] == 115 as byte && report[i + 9usize] == 32 as byte {
            var j: usize = i + 10usize;
            var value: u32 = 0u32;
            var saw_digit: i32 = 0;
            while j < report_len && report[j] >= 48 as byte && report[j] <= 57 as byte {
                saw_digit = 1;
                value = value * 10u32 + (report[j] - 48 as byte) as u32;
                j = j + 1usize;
            }
            if saw_digit != 0 {
                total = total + value;
            }
        }
        i = i + 1usize;
    }
    return total;
}

fn microapp_append_shell_token(cmd: &byte, cmd_cap: i32, cmd_len: &i32, token: &byte) i32 {
    if cmd == null || cmd_len == null || token == null {
        return -1;
    }
    const token_len: usize = strlen(token as *byte);
    if cmd_len[0] + token_len as i32 + 1 >= cmd_cap {
        return -1;
    }
    cmd[cmd_len[0] as usize] = 32 as byte;
    cmd_len[0] = cmd_len[0] + 1;
    memcpy(cmd + cmd_len[0] as usize, token as *void, token_len);
    cmd_len[0] = cmd_len[0] + token_len as i32;
    cmd[cmd_len[0] as usize] = 0 as byte;
    return 0;
}

fn microapp_append_reloc_sections_from_report(report: &byte, report_len: usize, cmd: &byte, cmd_cap: i32, cmd_len: &i32) i32 {
    if report == null || cmd == null || cmd_len == null {
        return 0;
    }
    var count: i32 = 0;
    var line_start: usize = 0;
    while line_start < report_len {
        var line_end: usize = line_start;
        while line_end < report_len && report[line_end] != 10 as byte {
            line_end = line_end + 1usize;
        }
        var line_pos: usize = line_start;
        var matched: i32 = 0;
        const prefix: &byte = "Relocation section '" as &byte;
        const prefix_len: usize = strlen(prefix as *byte);
        if line_end - line_start > prefix_len {
            matched = 1;
            var k: usize = 0;
            while k < prefix_len {
                if report[line_pos + k] != prefix[k] {
                    matched = 0;
                    break;
                }
                k = k + 1usize;
            }
        }
        if matched != 0 {
            var sec_start: usize = line_start + prefix_len;
            var sec_end: usize = sec_start;
            while sec_end < line_end && report[sec_end] != 39 as byte {
                sec_end = sec_end + 1usize;
            }
            if sec_end > sec_start {
                var token: [byte: 160] = [];
                const prefix2: &byte = "--only-section=" as &byte;
                const prefix2_len: usize = strlen(prefix2 as *byte);
                if prefix2_len + (sec_end - sec_start) < @len(token) {
                    const sec_ptr: &byte = report + sec_start;
                    memcpy(&token[0] as *void, prefix2 as *void, prefix2_len);
                    memcpy(&token[prefix2_len] as *void, sec_ptr as *void, sec_end - sec_start);
                    token[prefix2_len + (sec_end - sec_start)] = 0 as byte;
                    if microapp_append_shell_token(cmd, cmd_cap, cmd_len, &token[0] as &byte) != 0 {
                        return -1;
                    }
                    count = count + 1;
                }
            }
        }
        if line_end >= report_len {
            break;
        }
        line_start = line_end + 1usize;
    }
    return count;
}

fn microapp_raw_va_maps_into_image(raw_va: u32, text_raw: u32, code_len: u32, rodata_raw: u32, rodata_len: u32, data_raw: u32, data_len: u32, bss_raw: u32, bss_len: u32) i32 {
    if raw_va >= text_raw && raw_va < text_raw + code_len {
        return 1;
    }
    if rodata_len > 0u32 && raw_va >= rodata_raw && raw_va < rodata_raw + rodata_len {
        return 1;
    }
    if data_len > 0u32 && raw_va >= data_raw && raw_va < data_raw + data_len {
        return 1;
    }
    if bss_len > 0u32 && raw_va >= bss_raw && raw_va < bss_raw + bss_len {
        return 1;
    }
    return 0;
}

fn microapp_raw_va_in_writable_image_range(raw_va: u32, data_raw: u32, data_len: u32, bss_raw: u32, bss_len: u32) i32 {
    if data_len > 0u32 && raw_va >= data_raw && raw_va < data_raw + data_len {
        return 1;
    }
    if bss_len > 0u32 && raw_va >= bss_raw && raw_va < bss_raw + bss_len {
        return 1;
    }
    return 0;
}

fn microapp_extract_elf_relocations(exe_path: &byte, target_arch_raw: u32, base_raw: u32, text_raw: u32, code_len: u32, rodata_raw: u32, rodata_len: u32, data_raw: u32, data_len: u32, bss_raw: u32, bss_len: u32, reloc_count: &u32, reloc_len: &u32) i32 {
    if reloc_count == null || reloc_len == null {
        return 1;
    }
    reloc_count[0] = 0u32;
    reloc_len[0] = 0u32;
    if target_arch_raw != MICROAPP_TARGET_ARCH_X86_64_RAW {
        return 0;
    }

    var report_path: [byte: PATH_MAX] = [];
    var cmd: [byte: 8192] = [];
    const report_len: i32 = snprintf(&report_path[0] as *byte, PATH_MAX, "%s.relocs.txt" as *byte, exe_path as *byte);
    if report_len <= 0 || report_len >= PATH_MAX {
        return 1;
    }

    const readelf_env: &byte = get_env_or_default("READELF" as *byte, "readelf" as *byte);
    var cmd_len: i32 = snprintf(&cmd[0] as *byte, 8192, "%s -r %s > %s" as *byte, readelf_env as *byte, exe_path as *byte, &report_path[0] as *byte);
    if cmd_len <= 0 || cmd_len >= 8192 {
        return 1;
    }
    if system(&cmd[0] as *byte) != 0 {
        return 1;
    }

    var report_buf: [byte: FILE_BUFFER_SIZE] = [];
    const report_size: i32 = read_file_content(&report_path[0] as &byte, &report_buf[0], FILE_BUFFER_SIZE as usize);
    if report_size < 0 {
        return 1;
    }
    var line_start: usize = 0;
    var out_count: u32 = 0u32;
    while line_start < report_size as usize {
        var line_end: usize = line_start;
        while line_end < report_size as usize && report_buf[line_end] != 10 as byte {
            line_end = line_end + 1usize;
        }
        const line_ptr: &byte = &report_buf[line_start] as &byte;
        var tok0_s: usize = 0;
        var tok0_e: usize = 0;
        var tok2_s: usize = 0;
        var tok2_e: usize = 0;
        var tok3_s: usize = 0;
        var tok3_e: usize = 0;
        if microapp_token_bounds(line_ptr, line_end - line_start, 0, &tok0_s, &tok0_e) != 0 &&
           microapp_token_bounds(line_ptr, line_end - line_start, 2, &tok2_s, &tok2_e) != 0 &&
           microapp_token_bounds(line_ptr, line_end - line_start, 3, &tok3_s, &tok3_e) != 0 {
            const target_raw: u32 = microapp_hex_to_u32_span(line_ptr, tok0_s, tok0_e) catch { 0u32; };
            var value_raw: u32 = 0u32;
            var supported_type: i32 = 0;
            if microapp_token_equals(line_ptr, tok2_s, tok2_e, "R_X86_64_RELATIVE" as &byte) != 0 {
                value_raw = microapp_hex_to_u32_span(line_ptr, tok3_s, tok3_e) catch { 0u32; };
                supported_type = 1;
            } else if microapp_token_equals(line_ptr, tok2_s, tok2_e, "R_X86_64_64" as &byte) != 0 ||
                      microapp_token_equals(line_ptr, tok2_s, tok2_e, "R_X86_64_GLOB_DAT" as &byte) != 0 {
                var tok5_s: usize = 0;
                var tok5_e: usize = 0;
                var tok6_s: usize = 0;
                var tok6_e: usize = 0;
                const sym_raw: u32 = microapp_hex_to_u32_span(line_ptr, tok3_s, tok3_e) catch { 0u32; };
                value_raw = sym_raw;
                if microapp_token_bounds(line_ptr, line_end - line_start, 5, &tok5_s, &tok5_e) != 0 &&
                   microapp_token_bounds(line_ptr, line_end - line_start, 6, &tok6_s, &tok6_e) != 0 {
                    var addend_sign: i32 = 0;
                    if microapp_token_equals(line_ptr, tok5_s, tok5_e, "+" as &byte) != 0 {
                        addend_sign = 1;
                    } else if microapp_token_equals(line_ptr, tok5_s, tok5_e, "-" as &byte) != 0 {
                        addend_sign = -1;
                    }
                    if addend_sign != 0 {
                        const addend_raw: u32 = microapp_parse_signed_u32_token(line_ptr, tok6_s, tok6_e, addend_sign) catch { 0u32; };
                        if addend_sign > 0 {
                            value_raw = sym_raw + addend_raw;
                        }
                    }
                }
                supported_type = 1;
            }
            if supported_type != 0 &&
               microapp_raw_va_in_writable_image_range(target_raw, data_raw, data_len, bss_raw, bss_len) != 0 &&
               microapp_raw_va_maps_into_image(value_raw, text_raw, code_len, rodata_raw, rodata_len, data_raw, data_len, bss_raw, bss_len) != 0 {
                const target_va: u32 = MICROAPP_VADDR_BASE + (target_raw - base_raw);
                const value_va: u32 = MICROAPP_VADDR_BASE + (value_raw - base_raw);
                const out_off: usize = out_count as usize * 8usize;
                if out_off + 8usize > FILE_BUFFER_SIZE as usize {
                    return 1;
                }
                write_u32_le_at(&microapp_reloc_buffer[0] as &byte, out_off, target_va);
                write_u32_le_at(&microapp_reloc_buffer[0] as &byte, out_off + 4usize, value_va);
                out_count = out_count + 1u32;
            }
        }
        if line_end >= report_size as usize {
            break;
        }
        line_start = line_end + 1usize;
    }
    reloc_count[0] = out_count;
    reloc_len[0] = out_count * 8u32;
    return 0;
}

fn microapp_extract_elf_vaddrs(exe_path: &byte, text_va: &u32, rodata_va: &u32, data_va: &u32, bss_va: &u32, bss_len: &u32, entry_va: &u32, base_raw_out: &u32, text_raw_out: &u32, rodata_raw_out: &u32, data_raw_out: &u32, bss_raw_out: &u32) i32 {
    var report_path: [byte: PATH_MAX] = [];
    var sym_path: [byte: PATH_MAX] = [];
    var cmd: [byte: 8192] = [];
    const report_len: i32 = snprintf(&report_path[0] as *byte, PATH_MAX, "%s.sections.txt" as *byte, exe_path as *byte);
    const sym_len: i32 = snprintf(&sym_path[0] as *byte, PATH_MAX, "%s.symbols.txt" as *byte, exe_path as *byte);
    if report_len <= 0 || report_len >= PATH_MAX || sym_len <= 0 || sym_len >= PATH_MAX {
        return 1;
    }
    const objdump_env: &byte = get_env_or_default("OBJDUMP" as *byte, "objdump" as *byte);
    const nm_env: &byte = get_env_or_default("NM" as *byte, "nm" as *byte);
    var cmd_len: i32 = snprintf(&cmd[0] as *byte, 8192, "%s -h %s > %s" as *byte, objdump_env as *byte, exe_path as *byte, &report_path[0] as *byte);
    if cmd_len <= 0 || cmd_len >= 8192 {
        return 1;
    }
    if system(&cmd[0] as *byte) != 0 {
        return 1;
    }
    cmd_len = snprintf(&cmd[0] as *byte, 8192, "%s -n %s > %s" as *byte, nm_env as *byte, exe_path as *byte, &sym_path[0] as *byte);
    if cmd_len <= 0 || cmd_len >= 8192 {
        return 1;
    }
    if system(&cmd[0] as *byte) != 0 {
        return 1;
    }
    var report_buf: [byte: FILE_BUFFER_SIZE] = [];
    const report_size: i32 = read_file_content(&report_path[0] as &byte, &report_buf[0], FILE_BUFFER_SIZE as usize);
    if report_size < 0 {
        return 1;
    }
    var sym_buf: [byte: FILE_BUFFER_SIZE] = [];
    const sym_size: i32 = read_file_content(&sym_path[0] as &byte, &sym_buf[0], FILE_BUFFER_SIZE as usize);
    if sym_size < 0 {
        return 1;
    }
    const text_raw: u32 = microapp_section_vma_from_report(&report_buf[0] as &byte, report_size as usize, ".text" as &byte) catch { return 1; };
    var rodata_raw: u32 = microapp_section_vma_from_report(&report_buf[0] as &byte, report_size as usize, ".rodata" as &byte) catch { text_raw; };
    var data_raw: u32 = microapp_section_vma_from_report(&report_buf[0] as &byte, report_size as usize, ".data" as &byte) catch { rodata_raw; };
    var bss_raw: u32 = microapp_section_vma_from_report(&report_buf[0] as &byte, report_size as usize, ".bss" as &byte) catch { 0u32; };
    var bss_raw_len: u32 = microapp_section_size_from_report(&report_buf[0] as &byte, report_size as usize, ".bss" as &byte) catch { 0u32; };
    var entry_raw: u32 = microapp_symbol_vma_from_report(&sym_buf[0] as &byte, sym_size as usize, "main_main" as &byte) catch { 0u32; };
    if entry_raw == 0u32 {
        entry_raw = microapp_symbol_vma_from_report(&sym_buf[0] as &byte, sym_size as usize, "main" as &byte) catch { 0u32; };
    }
    if entry_raw == 0u32 {
        return 1;
    }
    var base_raw: u32 = text_raw;
    if rodata_raw != 0u32 && rodata_raw < base_raw {
        base_raw = rodata_raw;
    }
    if data_raw != 0u32 && data_raw < base_raw {
        base_raw = data_raw;
    }
    if bss_raw_len > 0u32 && bss_raw < base_raw {
        base_raw = bss_raw;
    }
    text_va[0] = MICROAPP_VADDR_BASE + (text_raw - base_raw);
    rodata_va[0] = MICROAPP_VADDR_BASE + (rodata_raw - base_raw);
    data_va[0] = MICROAPP_VADDR_BASE + (data_raw - base_raw);
    if bss_raw_len > 0u32 {
        bss_va[0] = MICROAPP_VADDR_BASE + (bss_raw - base_raw);
    } else {
        bss_va[0] = 0u32;
    }
    bss_len[0] = bss_raw_len;
    entry_va[0] = MICROAPP_VADDR_BASE + (entry_raw - base_raw);
    if base_raw_out != null { base_raw_out[0] = base_raw; }
    if text_raw_out != null { text_raw_out[0] = text_raw; }
    if rodata_raw_out != null { rodata_raw_out[0] = rodata_raw; }
    if data_raw_out != null { data_raw_out[0] = data_raw; }
    if bss_raw_out != null { bss_raw_out[0] = bss_raw; }
    return 0;
}

fn microapp_source_is_ident_start(ch: byte) i32 {
    if (ch >= 65 && ch <= 90) || (ch >= 97 && ch <= 122) || ch == 95 {
        return 1;
    }
    return 0;
}

fn microapp_source_is_ident_continue(ch: byte) i32 {
    if microapp_source_is_ident_start(ch) != 0 || (ch >= 48 && ch <= 57) {
        return 1;
    }
    return 0;
}

fn microapp_source_skip_string(buf: &byte, file_size: usize, pos: &usize, quote: byte) void {
    if buf == null || pos == null || pos[0] >= file_size {
        return;
    }
    pos[0] = pos[0] + 1;
    while pos[0] < file_size {
        const ch: byte = buf[pos[0]];
        if ch == 92 && pos[0] + 1 < file_size {
            pos[0] = pos[0] + 2;
            continue;
        }
        pos[0] = pos[0] + 1;
        if ch == quote {
            return;
        }
    }
}

fn microapp_source_skip_comment(buf: &byte, file_size: usize, pos: &usize) i32 {
    if buf == null || pos == null || pos[0] + 1 >= file_size {
        return 0;
    }
    if buf[pos[0]] != 47 {
        return 0;
    }
    const next: byte = buf[pos[0] + 1];
    if next == 47 {
        pos[0] = pos[0] + 2;
        while pos[0] < file_size && buf[pos[0]] != 10 {
            pos[0] = pos[0] + 1;
        }
        return 1;
    }
    if next == 42 {
        pos[0] = pos[0] + 2;
        while pos[0] + 1 < file_size {
            if buf[pos[0]] == 42 && buf[pos[0] + 1] == 47 {
                pos[0] = pos[0] + 2;
                return 1;
            }
            pos[0] = pos[0] + 1;
        }
        pos[0] = file_size;
        return 1;
    }
    return 0;
}

fn microapp_source_token_eq(buf: &byte, start: usize, end: usize, text: &byte) i32 {
    if buf == null || text == null || end < start {
        return 0;
    }
    const len: usize = end - start;
    if strlen(text as *byte) != len {
        return 0;
    }
    if len == 0 {
        return 0;
    }
    if strncmp(&buf[start], text as *byte, len) == 0 {
        return 1;
    }
    return 0;
}

fn microapp_source_has_ident(buf: &byte, file_size: usize, ident: &byte) i32 {
    if buf == null || ident == null {
        return 0;
    }
    var i: usize = 0;
    while i < file_size {
        const ch: byte = buf[i];
        if ch == 34 || ch == 39 {
            microapp_source_skip_string(buf, file_size, &i, ch);
            continue;
        }
        if microapp_source_skip_comment(buf, file_size, &i) != 0 {
            continue;
        }
        if microapp_source_is_ident_start(ch) == 0 {
            i = i + 1;
            continue;
        }
        const start: usize = i;
        i = i + 1;
        while i < file_size && microapp_source_is_ident_continue(buf[i]) != 0 {
            i = i + 1;
        }
        if microapp_source_token_eq(buf, start, i, ident) != 0 {
            return 1;
        }
    }
    return 0;
}

fn microapp_infer_required_caps_from_source(source_path: &byte) u32 {
    if source_path == null {
        return 0u32;
    }
    const file_size: i32 = read_file_content(source_path, &file_buffer[0], FILE_BUFFER_SIZE as usize);
    if file_size < 0 {
        return 0u32;
    }
    const buf: &byte = &file_buffer[0];
    const size: usize = file_size as usize;
    var caps: u32 = 0u32;
    if microapp_source_has_ident(buf, size, "read_uart" as &byte) != 0 ||
        microapp_source_has_ident(buf, size, "write_uart" as &byte) != 0 {
        caps = caps | MICROAPP_REQUIRED_CAP_IO_UART;
    }
    if microapp_source_has_ident(buf, size, "read_gpio" as &byte) != 0 ||
        microapp_source_has_ident(buf, size, "write_gpio" as &byte) != 0 {
        caps = caps | MICROAPP_REQUIRED_CAP_IO_GPIO;
    }
    if microapp_source_has_ident(buf, size, "read_timer" as &byte) != 0 ||
        microapp_source_has_ident(buf, size, "write_timer" as &byte) != 0 {
        caps = caps | MICROAPP_REQUIRED_CAP_IO_TIMER;
    }
    return caps;
}

fn build_microapp_text_from_c(c_file: &byte, text_bin_path: &byte, rodata_bin_path: &byte, data_bin_path: &byte, target_arch_raw: u32) i32 {
    const profile: MicroAppTargetProfile = resolve_microapp_target_profile();
    var gcc_buf: [byte: PATH_MAX] = [];
    const gcc: &byte = resolve_microapp_target_gcc(&profile, &gcc_buf[0] as &byte, PATH_MAX);
    const target_triple: &byte = profile.triple;
    var obj_path: [byte: PATH_MAX] = [];
    var exe_path: [byte: PATH_MAX] = [];
    var cmd: [byte: 8192] = [];
    const obj_len: i32 = snprintf(&obj_path[0] as *byte, PATH_MAX, "%s.obj" as *byte, text_bin_path as *byte);
    if obj_len <= 0 || obj_len >= PATH_MAX {
        fprintf(libc.stderr, "错误: 无法生成 microapp 中间目标文件路径\n" as *byte);
        return 1;
    }
    const exe_len: i32 = snprintf(&exe_path[0] as *byte, PATH_MAX, "%s.elf" as *byte, text_bin_path as *byte);
    if exe_len <= 0 || exe_len >= PATH_MAX {
        fprintf(libc.stderr, "错误: 无法生成 microapp 链接输出路径\n" as *byte);
        return 1;
    }

    const compile_flags: &byte = get_env_or_default("MICROAPP_TARGET_CFLAGS" as *byte, microapp_profile_default_cflags(&profile) as *byte);
    const compile_len: i32 = snprintf(&cmd[0] as *byte, 8192, "%s %s -c %s -o %s" as *byte, gcc as *byte, compile_flags as *byte, c_file as *byte, &obj_path[0] as *byte);
    if compile_len <= 0 || compile_len >= 8192 {
        fprintf(libc.stderr, "错误: 无法生成 microapp 目标 gcc 编译命令\n" as *byte);
        return 1;
    }
    fprintf(libc.stderr, "信息：microapp profile=%s, bridge=%s, 目标架构=%s, 默认三元组=%s\n" as *byte,
        profile.name as *byte,
        microapp_bridge_kind_name(profile.bridge_kind_raw) as *byte,
        microapp_target_arch_name(target_arch_raw) as *byte,
        target_triple as *byte);
    fprintf(libc.stderr, "信息：microapp 目标 gcc 编译：%s\n" as *byte, &cmd[0] as *byte);
    var result: i32 = system(&cmd[0] as *byte);
    if result != 0 {
        fprintf(libc.stderr, "错误: microapp 目标 gcc 编译失败，返回码：%d\n" as *byte, result);
        return 1;
    }

    if microapp_profile_uses_macho_object_extraction(&profile) != 0 {
        if microapp_probe_macho_arm64_object_extract(&obj_path[0] as &byte) == 0 {
            fprintf(libc.stderr, "错误: microapp macos arm64 目标 gcc 未产出可识别的 Mach-O 对象文件\n" as *byte);
            return 1;
        }
        fprintf(libc.stderr, "信息：microapp 目标 gcc Mach-O 对象产物：%s\n" as *byte, &obj_path[0] as *byte);
        return 0;
    }

    if microapp_target_uses_object_elf_extraction(target_arch_raw) != 0 {
        if target_arch_raw == MICROAPP_TARGET_ARCH_AARCH64_RAW &&
           microapp_probe_object_elf64_extract(&obj_path[0] as &byte, target_arch_raw) == 0 {
            fprintf(libc.stderr, "信息：microapp aarch64 对象提取预检失败，回退到内部 ELF 提取\n" as *byte);
        } else {
            fprintf(libc.stderr, "信息：microapp 目标 gcc 对象产物：%s\n" as *byte, &obj_path[0] as *byte);
            return 0;
        }
    }

    const link_flags: &byte = get_env_or_default("MICROAPP_TARGET_LDFLAGS" as *byte, microapp_profile_default_ldflags(&profile) as *byte);
    const link_len: i32 = snprintf(&cmd[0] as *byte, 8192, "%s %s %s -o %s" as *byte, gcc as *byte, link_flags as *byte, &obj_path[0] as *byte, &exe_path[0] as *byte);
    if link_len <= 0 || link_len >= 8192 {
        fprintf(libc.stderr, "错误: 无法生成 microapp 目标 gcc 链接命令\n" as *byte);
        return 1;
    }
    fprintf(libc.stderr, "信息：microapp 目标 gcc 链接：%s\n" as *byte, &cmd[0] as *byte);
    result = system(&cmd[0] as *byte);
    if result != 0 {
        fprintf(libc.stderr, "错误: microapp 目标 gcc 链接失败，返回码：%d\n" as *byte, result);
        return 1;
    }

    if microapp_target_uses_internal_elf_extraction(target_arch_raw) != 0 {
        fprintf(libc.stderr, "信息：microapp 内部 ELF 提取：%s\n" as *byte, &exe_path[0] as *byte);
        return 0;
    }

    const objcopy_env: &byte = get_env_or_default("OBJCOPY" as *byte, "objcopy" as *byte);
    const dump_len: i32 = snprintf(&cmd[0] as *byte, 8192, "%s -O binary --only-section=.text %s %s" as *byte, objcopy_env as *byte, &exe_path[0] as *byte, text_bin_path as *byte);
    if dump_len <= 0 || dump_len >= 8192 {
        fprintf(libc.stderr, "错误: 无法生成 microapp 代码段导出命令\n" as *byte);
        return 1;
    }
    fprintf(libc.stderr, "信息：microapp 目标 gcc 导出 .text：%s\n" as *byte, &cmd[0] as *byte);
    result = system(&cmd[0] as *byte);
    if result != 0 {
        fprintf(libc.stderr, "错误: microapp 目标 gcc .text 导出失败，返回码：%d\n" as *byte, result);
        return 1;
    }

    const rodata_len: i32 = snprintf(&cmd[0] as *byte, 8192, "%s -O binary --only-section=.rodata %s %s" as *byte, objcopy_env as *byte, &exe_path[0] as *byte, rodata_bin_path as *byte);
    if rodata_len <= 0 || rodata_len >= 8192 {
        fprintf(libc.stderr, "错误: 无法生成 microapp 只读段导出命令\n" as *byte);
        return 1;
    }
    fprintf(libc.stderr, "信息：microapp 目标 gcc 导出 .rodata：%s\n" as *byte, &cmd[0] as *byte);
    result = system(&cmd[0] as *byte);
    if result != 0 {
        fprintf(libc.stderr, "错误: microapp 目标 gcc .rodata 导出失败，返回码：%d\n" as *byte, result);
        return 1;
    }

    const data_len: i32 = snprintf(&cmd[0] as *byte, 8192, "%s -O binary --only-section=.data %s %s" as *byte, objcopy_env as *byte, &exe_path[0] as *byte, data_bin_path as *byte);
    if data_len > 0 && data_len < 8192 {
        system(&cmd[0] as *byte);
    }
    return 0;
}

fn write_microapp_payload_obj(
    output_path: &byte,
    source_path: &byte,
    c_file: &byte
) i32 {
    const source_len_tmp: !u32 = strlen(source_path as *byte) as! u32;
    const source_len: u32 = source_len_tmp catch { return 1; };
    const profile: MicroAppTargetProfile = resolve_microapp_target_profile();
    const target_arch_raw: u32 = profile.arch_raw;
    const profile_id: u32 = profile.profile_id;
    const image_flags: u32 = 0u32;
    const bridge_kind_raw: u32 = profile.bridge_kind_raw;
    const stack_size_hint: u32 = microapp_profile_default_stack_hint(&profile);
    const required_caps: u32 = microapp_infer_required_caps_from_source(source_path);
    if required_caps != 0u32 {
        fprintf(libc.stderr, "信息：microapp inferred required_caps=%u\n" as *byte, required_caps);
    }
    var entry_va: u32 = 0u32;
    var code_va: u32 = 0u32;
    var rodata_va: u32 = 0u32;
    var data_va: u32 = 0u32;
    var bss_va: u32 = 0u32;
    var bss_len: u32 = 0u32;
    var bss_size: u32 = 0u32;
    var base_raw: u32 = 0u32;
    var text_raw: u32 = 0u32;
    var rodata_raw: u32 = 0u32;
    var data_raw: u32 = 0u32;
    var bss_raw: u32 = 0u32;
    var reloc_count: u32 = 0u32;
    var reloc_len: u32 = 0u32;
    var text_bin_path: [byte: PATH_MAX] = [];
    var rodata_bin_path: [byte: PATH_MAX] = [];
    var data_bin_path: [byte: PATH_MAX] = [];
    const text_len_path: i32 = snprintf(&text_bin_path[0] as *byte, PATH_MAX, "%s.text.bin" as *byte, output_path as *byte);
    if text_len_path <= 0 || text_len_path >= PATH_MAX {
        fprintf(libc.stderr, "错误: 无法生成 microapp 代码段路径\n" as *byte);
        return 1;
    }
    const rodata_len_path: i32 = snprintf(&rodata_bin_path[0] as *byte, PATH_MAX, "%s.rodata.bin" as *byte, output_path as *byte);
    if rodata_len_path <= 0 || rodata_len_path >= PATH_MAX {
        fprintf(libc.stderr, "错误: 无法生成 microapp 只读段路径\n" as *byte);
        return 1;
    }
    const data_len_path: i32 = snprintf(&data_bin_path[0] as *byte, PATH_MAX, "%s.data.bin" as *byte, output_path as *byte);
    if data_len_path <= 0 || data_len_path >= PATH_MAX {
        fprintf(libc.stderr, "错误: 无法生成 microapp 数据段路径\n" as *byte);
        return 1;
    }
    if build_microapp_text_from_c(c_file, &text_bin_path[0] as &byte, &rodata_bin_path[0] as &byte, &data_bin_path[0] as &byte, target_arch_raw) != 0 {
        return 1;
    }
    var obj_path: [byte: PATH_MAX] = [];
    const obj_len_path: i32 = snprintf(&obj_path[0] as *byte, PATH_MAX, "%s.obj" as *byte, &text_bin_path[0] as *byte);
    if obj_len_path <= 0 || obj_len_path >= PATH_MAX {
        fprintf(libc.stderr, "错误: 无法生成 microapp 对象文件路径\n" as *byte);
        return 1;
    }
    var exe_path: [byte: PATH_MAX] = [];
    const exe_len_path: i32 = snprintf(&exe_path[0] as *byte, PATH_MAX, "%s.text.bin.elf" as *byte, output_path as *byte);
    if exe_len_path <= 0 || exe_len_path >= PATH_MAX {
        fprintf(libc.stderr, "错误: 无法生成 microapp ELF 路径\n" as *byte);
        return 1;
    }
    var code_len: u32 = 0u32;
    var rodata_len: u32 = 0u32;
    var data_len: u32 = 0u32;
    var object_extracted: i32 = 0;
    if microapp_profile_uses_macho_object_extraction(&profile) != 0 {
        if microapp_extract_macho_arm64_object(&obj_path[0] as &byte, &code_len, &rodata_len, &data_len, &code_va, &rodata_va, &data_va, &bss_va, &bss_len, &entry_va, &base_raw, &text_raw, &rodata_raw, &data_raw, &bss_raw, &reloc_count, &reloc_len) != 0 {
            fprintf(libc.stderr, "错误: 无法从 microapp Mach-O 对象文件提取段与 relocation 信息\n" as *byte);
            return 1;
        }
        object_extracted = 1;
        fprintf(libc.stderr, "信息：microapp Mach-O 对象提取 code=%u rodata=%u data=%u bss=%u entry_va=0x%x reloc_count=%u\n" as *byte,
            code_len, rodata_len, data_len, bss_len, entry_va, reloc_count);
    } else if microapp_target_uses_object_elf_extraction(target_arch_raw) != 0 {
        if microapp_extract_object_elf64(&obj_path[0] as &byte, target_arch_raw, &code_len, &rodata_len, &data_len, &code_va, &rodata_va, &data_va, &bss_va, &bss_len, &entry_va, &base_raw, &text_raw, &rodata_raw, &data_raw, &bss_raw, &reloc_count, &reloc_len) == 0 {
            object_extracted = 1;
            fprintf(libc.stderr, "信息：microapp 对象提取 code=%u rodata=%u data=%u bss=%u entry_va=0x%x reloc_count=%u\n" as *byte,
                code_len, rodata_len, data_len, bss_len, entry_va, reloc_count);
        } else if target_arch_raw != MICROAPP_TARGET_ARCH_AARCH64_RAW {
            fprintf(libc.stderr, "错误: 无法从 microapp 对象文件提取段与 relocation 信息\n" as *byte);
            return 1;
        } else {
            fprintf(libc.stderr, "信息：microapp aarch64 对象提取失败，回退到内部 ELF 提取\n" as *byte);
        }
    }
    if object_extracted == 0 && microapp_target_uses_internal_elf_extraction(target_arch_raw) != 0 {
        if microapp_extract_internal_elf64(&exe_path[0] as &byte, target_arch_raw, &code_len, &rodata_len, &data_len, &code_va, &rodata_va, &data_va, &bss_va, &bss_len, &entry_va, &base_raw, &text_raw, &rodata_raw, &data_raw, &bss_raw, &reloc_count, &reloc_len) != 0 {
            fprintf(libc.stderr, "错误: 无法内部提取 microapp ELF 段与 relocation 信息\n" as *byte);
            return 1;
        }
    } else if object_extracted == 0 {
        if microapp_extract_elf_vaddrs(&exe_path[0] as &byte, &code_va, &rodata_va, &data_va, &bss_va, &bss_len, &entry_va, &base_raw, &text_raw, &rodata_raw, &data_raw, &bss_raw) != 0 {
            fprintf(libc.stderr, "错误: 无法提取 microapp ELF 虚拟地址信息\n" as *byte);
            return 1;
        }
        const code_len_raw: i32 = read_file_content(&text_bin_path[0] as &byte, &file_buffer[0], FILE_BUFFER_SIZE as usize);
        if code_len_raw < 0 {
            fprintf(libc.stderr, "错误: 无法读取 microapp 目标 gcc 代码段 '%s'\n" as *byte, &text_bin_path[0] as *byte);
            return 1;
        }
        const code_len_tmp: !u32 = code_len_raw as! u32;
        code_len = code_len_tmp catch { return 1; };
        const rodata_len_raw: i32 = read_file_content(&rodata_bin_path[0] as &byte, &microapp_rodata_buffer[0], FILE_BUFFER_SIZE as usize);
        if rodata_len_raw < 0 {
            fprintf(libc.stderr, "错误: 无法读取 microapp 目标 gcc 只读段 '%s'\n" as *byte, &rodata_bin_path[0] as *byte);
            return 1;
        }
        const rodata_len_tmp: !u32 = rodata_len_raw as! u32;
        rodata_len = rodata_len_tmp catch { return 1; };
        const data_len_raw: i32 = read_file_content(&data_bin_path[0] as &byte, &microapp_data_buffer[0], FILE_BUFFER_SIZE as usize);
        if data_len_raw >= 0 {
            const data_len_tmp: !u32 = data_len_raw as! u32;
            data_len = data_len_tmp catch { return 1; };
        }
        if microapp_extract_elf_relocations(&exe_path[0] as &byte, target_arch_raw, base_raw, text_raw, code_len, rodata_raw, rodata_len, data_raw, data_len, bss_raw, bss_len, &reloc_count, &reloc_len) != 0 {
            fprintf(libc.stderr, "错误: 无法提取 microapp ELF relocation 信息\n" as *byte);
            return 1;
        }
    }
    if bss_len > 0u32 {
        if data_len == 0u32 {
            data_va = bss_va;
            bss_size = bss_len;
        } else {
            const data_end_va: u32 = data_va + data_len;
            if bss_va < data_end_va {
                fprintf(libc.stderr, "错误: microapp ELF .bss 起始地址早于 .data 结束地址\n" as *byte);
                return 1;
            }
            bss_size = (bss_va - data_end_va) + bss_len;
        }
    }
    const fp: &FILE = fopen(output_path as *byte, "wb" as *byte);
    if fp == null {
        fprintf(libc.stderr, "错误: 无法打开输出文件 '%s'\n" as *byte, output_path as *byte);
        return 1;
    }

    const magic: u32 = 0x4A424F50;  // "POBJ"
    const version: u16 = POBJ_VERSION;
    const flags: u16 = 0;
    const entry_offset: u32 = 0u32;
    const build_mode_raw: u32 = POBJ_BUILD_MODE_MICROAPP;

    fwrite(&magic as *void, 1 as usize, 4 as usize, fp);
    w16_file(fp, version);
    w16_file(fp, flags);
    w32_file(fp, target_arch_raw);
    w32_file(fp, build_mode_raw);
    w32_file(fp, required_caps);
    w32_file(fp, entry_offset);
    w32_file(fp, source_len);
    w32_file(fp, code_len);
    w32_file(fp, rodata_len);
    w32_file(fp, reloc_count);
    w32_file(fp, profile_id);
    w32_file(fp, image_flags);
    w32_file(fp, bridge_kind_raw);
    w32_file(fp, bss_size);
    w32_file(fp, stack_size_hint);
    w32_file(fp, data_len);
    w32_file(fp, reloc_len);
    w32_file(fp, entry_va);
    w32_file(fp, code_va);
    w32_file(fp, rodata_va);
    w32_file(fp, data_va);
    fwrite(source_path as *void, 1 as usize, source_len as usize, fp);
    fwrite(&file_buffer[0] as *void, 1 as usize, code_len as usize, fp);
    fwrite(&microapp_rodata_buffer[0] as *void, 1 as usize, rodata_len as usize, fp);
    if data_len > 0u32 {
        fwrite(&microapp_data_buffer[0] as *void, 1 as usize, data_len as usize, fp);
    }
    if reloc_len > 0u32 {
        fwrite(&microapp_reloc_buffer[0] as *void, 1 as usize, reloc_len as usize, fp);
    }
    fclose(fp);
    return 0;
}

fn pack_microapp_pobj_to_uapp(pobj_path: &byte, out_path: &byte) i32 {
    const pobj_len: i32 = read_file_content(pobj_path, &file_buffer[0], FILE_BUFFER_SIZE as usize);
    if pobj_len < 0 {
        fprintf(libc.stderr, "错误: 无法读取 microapp payload 对象 '%s'\n" as *byte, pobj_path as *byte);
        return 1;
    }
    if pobj_len < POBJ_HEADER_SIZE_V1 as i32 {
        fprintf(libc.stderr, "错误: microapp payload 对象太小: %s\n" as *byte, pobj_path as *byte);
        return 1;
    }
    const magic: u32 = read_u32_le_at(&file_buffer[0] as &byte, 0usize);
    if magic != POBJ_MAGIC {
        fprintf(libc.stderr, "错误: 不是有效的 .pobj 文件: %s\n" as *byte, pobj_path as *byte);
        return 1;
    }
    const version: u16 = read_u16_le_at(&file_buffer[0] as &byte, 4usize);
    if version != 5u16 && version != 6u16 && version != POBJ_VERSION {
        fprintf(libc.stderr, "错误: 不支持的 .pobj 版本 %u\n" as *byte, version as u32);
        return 1;
    }
    if version >= POBJ_VERSION && pobj_len < POBJ_HEADER_SIZE_V2 as i32 {
        fprintf(libc.stderr, "错误: microapp payload 对象太小: %s\n" as *byte, pobj_path as *byte);
        return 1;
    }

    const file_ptr: &byte = &file_buffer[0] as &byte;

    const target_arch_raw: u32 = read_u32_le_at(file_ptr, 8usize);
    const build_mode_raw: u32 = read_u32_le_at(file_ptr, 12usize);
    const required_caps: u32 = read_u32_le_at(file_ptr, 16usize);
    const entry_offset: u32 = read_u32_le_at(file_ptr, 20usize);
    const source_path_len: u32 = read_u32_le_at(file_ptr, 24usize);
    const code_len: u32 = read_u32_le_at(file_ptr, 28usize);
    const rodata_len: u32 = read_u32_le_at(file_ptr, 32usize);
    const reloc_count: u32 = read_u32_le_at(file_ptr, 36usize);
    var profile_id: u32 = microapp_target_profile_from_arch_raw(target_arch_raw).profile_id;
    var image_flags: u32 = 0u32;
    var bridge_kind_raw: u32 = microapp_target_profile_from_arch_raw(target_arch_raw).bridge_kind_raw;
    var bss_size: u32 = 0u32;
    var stack_size_hint: u32 = 0u32;
    var data_len: u32 = 0u32;
    var reloc_len: u32 = 0u32;
    var pobj_header_size: u32 = POBJ_HEADER_SIZE_V1;
    var entry_va: u32 = IMAGE_HEADER_SIZE + entry_offset;
    var code_va: u32 = IMAGE_HEADER_SIZE;
    var rodata_va: u32 = code_va + code_len;
    var data_va: u32 = rodata_va + rodata_len;
    if version >= 6u16 {
        pobj_header_size = POBJ_HEADER_SIZE;
        profile_id = read_u32_le_at(file_ptr, 40usize);
        image_flags = read_u32_le_at(file_ptr, 44usize);
        bridge_kind_raw = read_u32_le_at(file_ptr, 48usize);
        bss_size = read_u32_le_at(file_ptr, 52usize);
        stack_size_hint = read_u32_le_at(file_ptr, 56usize);
        data_len = read_u32_le_at(file_ptr, 60usize);
        reloc_len = read_u32_le_at(file_ptr, 64usize);
    }
    if version >= POBJ_VERSION {
        pobj_header_size = POBJ_HEADER_SIZE_V2;
        entry_va = read_u32_le_at(file_ptr, 68usize);
        code_va = read_u32_le_at(file_ptr, 72usize);
        rodata_va = read_u32_le_at(file_ptr, 76usize);
        data_va = read_u32_le_at(file_ptr, 80usize);
    }

    if build_mode_raw != POBJ_BUILD_MODE_MICROAPP {
        fprintf(libc.stderr, "错误: 仅支持 microapp payload_obj\n" as *byte);
        return 1;
    }
    if code_len == 0 {
        fprintf(libc.stderr, "错误: payload_obj 缺少 code 段\n" as *byte);
        return 1;
    }

    const source_path_off: usize = pobj_header_size as usize;
    const code_off: usize = source_path_off + source_path_len as usize;
    const rodata_off: usize = code_off + code_len as usize;
    const data_off: usize = rodata_off + rodata_len as usize;
    const reloc_off: usize = data_off + data_len as usize;
    if reloc_off + reloc_len as usize > pobj_len as usize {
        fprintf(libc.stderr, "错误: .pobj 内容长度不一致\n" as *byte);
        return 1;
    }

    if target_arch_raw < MICROAPP_TARGET_ARCH_RV32_RAW || target_arch_raw > MICROAPP_TARGET_ARCH_XTENSA_RAW {
        fprintf(libc.stderr, "错误: 当前 packer 不支持未知目标架构\n" as *byte);
        return 1;
    }
    if source_path_off + source_path_len as usize > pobj_len as usize {
        fprintf(libc.stderr, "错误: .pobj 源路径长度不一致\n" as *byte);
        return 1;
    }
    if rodata_off > pobj_len as usize {
        fprintf(libc.stderr, "错误: .pobj rodata 偏移越界\n" as *byte);
        return 1;
    }
    const rodata_idx: usize = rodata_off;
    if rodata_len > 0u32 && rodata_idx >= @len(file_buffer) {
        fprintf(libc.stderr, "错误: .pobj rodata 索引越界\n" as *byte);
        return 1;
    }
    const source_path_ptr: &byte = main_file_buffer_ptr_at(source_path_off);
    const code_ptr: &byte = main_file_buffer_ptr_at(code_off);
    if source_path_ptr == null || code_ptr == null {
        fprintf(libc.stderr, "错误: .pobj 路径或代码指针为空\n" as *byte);
        return 1;
    }
    var rodata_ptr: &byte = &file_buffer[0] as &byte;
    if rodata_len > 0u32 {
        rodata_ptr = main_file_buffer_ptr_at(rodata_idx);
    }
    if rodata_len > 0u32 && rodata_ptr == null {
        fprintf(libc.stderr, "错误: .pobj rodata 指针为空\n" as *byte);
        return 1;
    }
    var data_ptr: &byte = &file_buffer[0] as &byte;
    if data_len > 0u32 {
        data_ptr = main_file_buffer_ptr_at(data_off);
        if data_ptr == null {
            fprintf(libc.stderr, "错误: .pobj data 指针为空\n" as *byte);
            return 1;
        }
    }
    var reloc_ptr: &byte = &file_buffer[0] as &byte;
    if reloc_len > 0u32 {
        reloc_ptr = main_file_buffer_ptr_at(reloc_off);
        if reloc_ptr == null {
            fprintf(libc.stderr, "错误: .pobj reloc 指针为空\n" as *byte);
            return 1;
        }
    }
    const source_path_bytes: &[byte] = source_path_ptr[0: source_path_len as usize];
    const code_bytes: &[byte] = code_ptr[0: code_len as usize];
    const rodata_bytes: &[byte] = rodata_ptr[0: rodata_len as usize];
    const data_bytes: &[byte] = data_ptr[0: data_len as usize];
    const reloc_bytes: &[byte] = reloc_ptr[0: reloc_len as usize];
    const payload: PayloadObj = PayloadObj{
        target_arch: image_target_arch_from_byte(target_arch_raw as byte),
        bridge_kind: image_bridge_kind_from_byte(bridge_kind_raw as byte),
        build_mode: BUILD_MODE_CONTAINER,
        profile_id: profile_id,
        required_caps: required_caps,
        flags: image_flags,
        entry_offset: entry_offset,
        entry_va: entry_va,
        code_va: code_va,
        rodata_va: rodata_va,
        data_va: data_va,
        code: code_bytes,
        rodata: rodata_bytes,
        data: data_bytes,
        bss_size: bss_size,
        stack_size_hint: stack_size_hint,
        relocs: reloc_bytes,
        reloc_count: reloc_count,
    };
    const out_ptr: &byte = &microapp_pack_output_buffer[0] as &byte;
    const out_bytes: &[byte] = out_ptr[0: @len(microapp_pack_output_buffer)];
    const image_len_result: !u32 = payload_pack_to_uapp(
        &payload,
        out_bytes
    );
    const image_len: u32 = image_len_result catch { return 1; };

    const image_bytes: &[byte] = out_ptr[0: image_len as usize];
    const validated_header_result: !ImageHeader = image_validate(image_bytes);
    const validated_header: ImageHeader = validated_header_result catch { return 1; };
    const fp: &FILE = fopen(out_path as *byte, "wb" as *byte);
    if fp == null {
        fprintf(libc.stderr, "错误: 无法打开输出文件 '%s'\n" as *byte, out_path as *byte);
        return 1;
    }
    fwrite(&microapp_pack_output_buffer[0] as *void, 1 as usize, image_len as usize, fp);
    fclose(fp);
    return 0;
}

fn inspect_microapp_pobj(path: &byte) i32 {
    const pobj_len: i32 = read_file_content(path, &file_buffer[0], FILE_BUFFER_SIZE as usize);
    if pobj_len < POBJ_HEADER_SIZE_V1 as i32 {
        fprintf(libc.stderr, "错误: .pobj 太小或无法读取: %s\n" as *byte, path as *byte);
        return 1;
    }
    const file_ptr: &byte = &file_buffer[0] as &byte;
    if read_u32_le_at(file_ptr, 0usize) != POBJ_MAGIC {
        fprintf(libc.stderr, "错误: 不是有效的 .pobj 文件: %s\n" as *byte, path as *byte);
        return 1;
    }
    const version: u16 = read_u16_le_at(file_ptr, 4usize);
    if version != 5u16 && version != 6u16 && version != POBJ_VERSION {
        fprintf(libc.stderr, "错误: 不支持的 .pobj 版本 %u\n" as *byte, version as u32);
        return 1;
    }
    const target_arch_raw: u32 = read_u32_le_at(file_ptr, 8usize);
    const build_mode_raw: u32 = read_u32_le_at(file_ptr, 12usize);
    const required_caps: u32 = read_u32_le_at(file_ptr, 16usize);
    const entry_offset: u32 = read_u32_le_at(file_ptr, 20usize);
    const source_path_len: u32 = read_u32_le_at(file_ptr, 24usize);
    const code_len: u32 = read_u32_le_at(file_ptr, 28usize);
    const rodata_len: u32 = read_u32_le_at(file_ptr, 32usize);
    const reloc_count: u32 = read_u32_le_at(file_ptr, 36usize);
    var profile_id: u32 = microapp_target_profile_from_arch_raw(target_arch_raw).profile_id;
    var image_flags: u32 = 0u32;
    var bridge_kind_raw: u32 = microapp_target_profile_from_arch_raw(target_arch_raw).bridge_kind_raw;
    var bss_size: u32 = 0u32;
    var stack_size_hint: u32 = 0u32;
    var data_len: u32 = 0u32;
    var reloc_len: u32 = 0u32;
    var entry_va: u32 = IMAGE_HEADER_SIZE + entry_offset;
    var code_va: u32 = IMAGE_HEADER_SIZE;
    var rodata_va: u32 = code_va + code_len;
    var data_va: u32 = rodata_va + rodata_len;
    if version >= 6u16 {
        profile_id = read_u32_le_at(file_ptr, 40usize);
        image_flags = read_u32_le_at(file_ptr, 44usize);
        bridge_kind_raw = read_u32_le_at(file_ptr, 48usize);
        bss_size = read_u32_le_at(file_ptr, 52usize);
        stack_size_hint = read_u32_le_at(file_ptr, 56usize);
        data_len = read_u32_le_at(file_ptr, 60usize);
        reloc_len = read_u32_le_at(file_ptr, 64usize);
    }
    if version >= POBJ_VERSION {
        entry_va = read_u32_le_at(file_ptr, 68usize);
        code_va = read_u32_le_at(file_ptr, 72usize);
        rodata_va = read_u32_le_at(file_ptr, 76usize);
        data_va = read_u32_le_at(file_ptr, 80usize);
    }
    fprintf(libc.stdout, "kind=pobj\n" as *byte);
    fprintf(libc.stdout, "path=%s\n" as *byte, path as *byte);
    fprintf(libc.stdout, "version=%u\n" as *byte, version as u32);
    fprintf(libc.stdout, "target_arch=%s\n" as *byte, microapp_target_arch_name(target_arch_raw) as *byte);
    fprintf(libc.stdout, "profile=%s\n" as *byte, microapp_profile_name(profile_id) as *byte);
    fprintf(libc.stdout, "bridge=%s\n" as *byte, microapp_bridge_kind_name(bridge_kind_raw) as *byte);
    fprintf(libc.stdout, "build_mode=%u\n" as *byte, build_mode_raw);
    fprintf(libc.stdout, "required_caps=%u\n" as *byte, required_caps);
    fprintf(libc.stdout, "flags=%u\n" as *byte, image_flags);
    fprintf(libc.stdout, "source_path_len=%u\n" as *byte, source_path_len);
    fprintf(libc.stdout, "code_size=%u\n" as *byte, code_len);
    fprintf(libc.stdout, "rodata_size=%u\n" as *byte, rodata_len);
    fprintf(libc.stdout, "data_size=%u\n" as *byte, data_len);
    fprintf(libc.stdout, "bss_size=%u\n" as *byte, bss_size);
    fprintf(libc.stdout, "stack_size_hint=%u\n" as *byte, stack_size_hint);
    fprintf(libc.stdout, "reloc_count=%u\n" as *byte, reloc_count);
    fprintf(libc.stdout, "reloc_size=%u\n" as *byte, reloc_len);
    fprintf(libc.stdout, "entry_offset=%u\n" as *byte, entry_offset);
    fprintf(libc.stdout, "entry_va=%u\n" as *byte, entry_va);
    fprintf(libc.stdout, "code_va=%u\n" as *byte, code_va);
    fprintf(libc.stdout, "rodata_va=%u\n" as *byte, rodata_va);
    fprintf(libc.stdout, "data_va=%u\n" as *byte, data_va);
    return 0;
}

fn microapp_image_arch_name(arch: ImageTargetArch) &byte {
    return microapp_target_arch_name(image_target_arch_to_byte(arch) as u32);
}

fn microapp_image_bridge_name(kind: ImageBridgeKind) &byte {
    return microapp_bridge_kind_name(image_bridge_kind_to_byte(kind) as u32);
}

fn inspect_microapp_uapp(path: &byte) i32 {
    const image_len: i32 = read_file_content(path, &file_buffer[0], FILE_BUFFER_SIZE as usize);
    if image_len < IMAGE_HEADER_SIZE_V1 as i32 {
        fprintf(libc.stderr, "错误: .uapp 太小或无法读取: %s\n" as *byte, path as *byte);
        return 1;
    }
    const image_ptr: &byte = &file_buffer[0] as &byte;
    const image_bytes: &[byte] = image_ptr[0: image_len as usize];
    const hdr_result: !ImageHeader = image_validate(image_bytes);
    const hdr: ImageHeader = hdr_result catch {
        fprintf(libc.stderr, "错误: .uapp 校验失败: %s\n" as *byte, path as *byte);
        return 1;
    };
    fprintf(libc.stdout, "kind=uapp\n" as *byte);
    fprintf(libc.stdout, "path=%s\n" as *byte, path as *byte);
    fprintf(libc.stdout, "validated=yes\n" as *byte);
    fprintf(libc.stdout, "format_version=%u\n" as *byte, hdr.format_version as u32);
    fprintf(libc.stdout, "target_arch=%s\n" as *byte, microapp_image_arch_name(hdr.target_arch) as *byte);
    fprintf(libc.stdout, "profile=%s\n" as *byte, microapp_profile_name(hdr.profile_id) as *byte);
    fprintf(libc.stdout, "bridge=%s\n" as *byte, microapp_image_bridge_name(hdr.bridge_kind) as *byte);
    fprintf(libc.stdout, "image_size=%u\n" as *byte, hdr.image_size);
    fprintf(libc.stdout, "code_size=%u\n" as *byte, hdr.code_size);
    fprintf(libc.stdout, "rodata_size=%u\n" as *byte, hdr.rodata_size);
    fprintf(libc.stdout, "data_size=%u\n" as *byte, hdr.data_size);
    fprintf(libc.stdout, "bss_size=%u\n" as *byte, hdr.bss_size);
    fprintf(libc.stdout, "stack_size_hint=%u\n" as *byte, hdr.stack_size_hint);
    fprintf(libc.stdout, "reloc_count=%u\n" as *byte, hdr.reloc_count);
    fprintf(libc.stdout, "entry_offset=%u\n" as *byte, hdr.entry_offset);
    fprintf(libc.stdout, "entry_va=%u\n" as *byte, hdr.entry_va);
    fprintf(libc.stdout, "code_offset=%u\n" as *byte, hdr.code_offset);
    fprintf(libc.stdout, "rodata_offset=%u\n" as *byte, hdr.rodata_offset);
    fprintf(libc.stdout, "data_offset=%u\n" as *byte, hdr.data_offset);
    fprintf(libc.stdout, "code_va=%u\n" as *byte, hdr.code_va);
    fprintf(libc.stdout, "rodata_va=%u\n" as *byte, hdr.rodata_va);
    fprintf(libc.stdout, "data_va=%u\n" as *byte, hdr.data_va);
    return 0;
}

fn inspect_microapp_image(path: &byte) i32 {
    if is_pobj_output(path) != 0 {
        return inspect_microapp_pobj(path);
    }
    if is_uapp_output(path) != 0 {
        return inspect_microapp_uapp(path);
    }
    fprintf(libc.stderr, "错误: inspect-image 仅支持 .pobj 或 .uapp: %s\n" as *byte, path as *byte);
    return 1;
}

fn verify_microapp_uapp(path: &byte) i32 {
    const image_len: i32 = read_file_content(path, &file_buffer[0], FILE_BUFFER_SIZE as usize);
    if image_len < IMAGE_HEADER_SIZE_V1 as i32 {
        fprintf(libc.stderr, "错误: .uapp 太小或无法读取: %s\n" as *byte, path as *byte);
        return 1;
    }
    const image_ptr: &byte = &file_buffer[0] as &byte;
    const image_bytes: &[byte] = image_ptr[0: image_len as usize];
    const hdr_result: !ImageHeader = image_validate(image_bytes);
    const hdr: ImageHeader = hdr_result catch {
        fprintf(libc.stderr, "错误: .uapp 校验失败: %s\n" as *byte, path as *byte);
        return 1;
    };
    fprintf(libc.stdout, "kind=uapp\n" as *byte);
    fprintf(libc.stdout, "verified=yes\n" as *byte);
    fprintf(libc.stdout, "format_version=%u\n" as *byte, hdr.format_version as u32);
    fprintf(libc.stdout, "target_arch=%s\n" as *byte, microapp_image_arch_name(hdr.target_arch) as *byte);
    fprintf(libc.stdout, "profile=%s\n" as *byte, microapp_profile_name(hdr.profile_id) as *byte);
    fprintf(libc.stdout, "bridge=%s\n" as *byte, microapp_image_bridge_name(hdr.bridge_kind) as *byte);
    fprintf(libc.stdout, "reloc_count=%u\n" as *byte, hdr.reloc_count);
    return 0;
}

fn verify_microapp_pobj(path: &byte) i32 {
    const pobj_len: i32 = read_file_content(path, &file_buffer[0], FILE_BUFFER_SIZE as usize);
    if pobj_len < POBJ_HEADER_SIZE_V1 as i32 {
        fprintf(libc.stderr, "错误: .pobj 太小或无法读取: %s\n" as *byte, path as *byte);
        return 1;
    }
    const file_ptr: &byte = &file_buffer[0] as &byte;
    const magic: u32 = read_u32_le_at(file_ptr, 0usize);
    if magic != POBJ_MAGIC {
        fprintf(libc.stderr, "错误: 不是有效的 .pobj 文件: %s\n" as *byte, path as *byte);
        return 1;
    }
    const version: u16 = read_u16_le_at(file_ptr, 4usize);
    if version != 5u16 && version != 6u16 && version != POBJ_VERSION {
        fprintf(libc.stderr, "错误: 不支持的 .pobj 版本 %u\n" as *byte, version as u32);
        return 1;
    }
    if version >= POBJ_VERSION && pobj_len < POBJ_HEADER_SIZE_V2 as i32 {
        fprintf(libc.stderr, "错误: .pobj 头部不完整: %s\n" as *byte, path as *byte);
        return 1;
    }

    const target_arch_raw: u32 = read_u32_le_at(file_ptr, 8usize);
    const build_mode_raw: u32 = read_u32_le_at(file_ptr, 12usize);
    const required_caps: u32 = read_u32_le_at(file_ptr, 16usize);
    const entry_offset: u32 = read_u32_le_at(file_ptr, 20usize);
    const source_path_len: u32 = read_u32_le_at(file_ptr, 24usize);
    const code_len: u32 = read_u32_le_at(file_ptr, 28usize);
    const rodata_len: u32 = read_u32_le_at(file_ptr, 32usize);
    const reloc_count: u32 = read_u32_le_at(file_ptr, 36usize);
    var profile_id: u32 = microapp_target_profile_from_arch_raw(target_arch_raw).profile_id;
    var image_flags: u32 = 0u32;
    var bridge_kind_raw: u32 = microapp_target_profile_from_arch_raw(target_arch_raw).bridge_kind_raw;
    var bss_size: u32 = 0u32;
    var stack_size_hint: u32 = 0u32;
    var data_len: u32 = 0u32;
    var reloc_len: u32 = 0u32;
    var pobj_header_size: u32 = POBJ_HEADER_SIZE_V1;
    var entry_va: u32 = IMAGE_HEADER_SIZE + entry_offset;
    var code_va: u32 = IMAGE_HEADER_SIZE;
    var rodata_va: u32 = code_va + code_len;
    var data_va: u32 = rodata_va + rodata_len;
    if version >= 6u16 {
        pobj_header_size = POBJ_HEADER_SIZE;
        profile_id = read_u32_le_at(file_ptr, 40usize);
        image_flags = read_u32_le_at(file_ptr, 44usize);
        bridge_kind_raw = read_u32_le_at(file_ptr, 48usize);
        bss_size = read_u32_le_at(file_ptr, 52usize);
        stack_size_hint = read_u32_le_at(file_ptr, 56usize);
        data_len = read_u32_le_at(file_ptr, 60usize);
        reloc_len = read_u32_le_at(file_ptr, 64usize);
    }
    if version >= POBJ_VERSION {
        pobj_header_size = POBJ_HEADER_SIZE_V2;
        entry_va = read_u32_le_at(file_ptr, 68usize);
        code_va = read_u32_le_at(file_ptr, 72usize);
        rodata_va = read_u32_le_at(file_ptr, 76usize);
        data_va = read_u32_le_at(file_ptr, 80usize);
    }

    const source_path_off: usize = pobj_header_size as usize;
    const code_off: usize = source_path_off + source_path_len as usize;
    const rodata_off: usize = code_off + code_len as usize;
    const data_off: usize = rodata_off + rodata_len as usize;
    const reloc_off: usize = data_off + data_len as usize;
    if reloc_off + reloc_len as usize > pobj_len as usize {
        fprintf(libc.stderr, "错误: .pobj 内容长度不一致: %s\n" as *byte, path as *byte);
        return 1;
    }
    if build_mode_raw != POBJ_BUILD_MODE_MICROAPP {
        fprintf(libc.stderr, "错误: 仅支持 microapp .pobj: %s\n" as *byte, path as *byte);
        return 1;
    }
    if target_arch_raw < MICROAPP_TARGET_ARCH_RV32_RAW || target_arch_raw > MICROAPP_TARGET_ARCH_XTENSA_RAW {
        fprintf(libc.stderr, "错误: 未知 .pobj 目标架构: %s\n" as *byte, path as *byte);
        return 1;
    }

    const code_ptr: &byte = &file_buffer[code_off] as &byte;
    var rodata_ptr: &byte = &file_buffer[0] as &byte;
    if rodata_len > 0u32 {
        rodata_ptr = main_file_buffer_ptr_at(rodata_off);
        if rodata_ptr == null {
            fprintf(libc.stderr, "错误: .pobj rodata 指针为空: %s\n" as *byte, path as *byte);
            return 1;
        }
    }
    var data_ptr: &byte = &file_buffer[0] as &byte;
    if data_len > 0u32 {
        data_ptr = main_file_buffer_ptr_at(data_off);
        if data_ptr == null {
            fprintf(libc.stderr, "错误: .pobj data 指针为空: %s\n" as *byte, path as *byte);
            return 1;
        }
    }
    var reloc_ptr: &byte = &file_buffer[0] as &byte;
    if reloc_len > 0u32 {
        reloc_ptr = main_file_buffer_ptr_at(reloc_off);
        if reloc_ptr == null {
            fprintf(libc.stderr, "错误: .pobj reloc 指针为空: %s\n" as *byte, path as *byte);
            return 1;
        }
    }

    const payload: PayloadObj = PayloadObj{
        target_arch: image_target_arch_from_byte(target_arch_raw as byte),
        bridge_kind: image_bridge_kind_from_byte(bridge_kind_raw as byte),
        build_mode: BUILD_MODE_CONTAINER,
        profile_id: profile_id,
        required_caps: required_caps,
        flags: image_flags,
        entry_offset: entry_offset,
        entry_va: entry_va,
        code_va: code_va,
        rodata_va: rodata_va,
        data_va: data_va,
        code: code_ptr[0: code_len as usize],
        rodata: rodata_ptr[0: rodata_len as usize],
        data: data_ptr[0: data_len as usize],
        bss_size: bss_size,
        stack_size_hint: stack_size_hint,
        relocs: reloc_ptr[0: reloc_len as usize],
        reloc_count: reloc_count,
    };
    payload_validate_layout(&payload) catch {
        fprintf(libc.stderr, "错误: .pobj payload 布局非法: %s\n" as *byte, path as *byte);
        return 1;
    };

    const out_ptr: &byte = &microapp_pack_output_buffer[0] as &byte;
    const out_bytes: &[byte] = out_ptr[0: @len(microapp_pack_output_buffer)];
    const image_len_result: !u32 = payload_pack_to_uapp(&payload, out_bytes);
    const image_len: u32 = image_len_result catch {
        fprintf(libc.stderr, "错误: .pobj 无法重打包为 .uapp: %s\n" as *byte, path as *byte);
        return 1;
    };
    const rebuilt_bytes: &[byte] = out_ptr[0: image_len as usize];
    image_validate(rebuilt_bytes) catch {
        fprintf(libc.stderr, "错误: .pobj 重打包后的 .uapp 校验失败: %s\n" as *byte, path as *byte);
        return 1;
    };
    fprintf(libc.stdout, "kind=pobj\n" as *byte);
    fprintf(libc.stdout, "verified=yes\n" as *byte);
    fprintf(libc.stdout, "version=%u\n" as *byte, version as u32);
    fprintf(libc.stdout, "target_arch=%s\n" as *byte, microapp_target_arch_name(target_arch_raw) as *byte);
    fprintf(libc.stdout, "profile=%s\n" as *byte, microapp_profile_name(profile_id) as *byte);
    fprintf(libc.stdout, "bridge=%s\n" as *byte, microapp_bridge_kind_name(bridge_kind_raw) as *byte);
    fprintf(libc.stdout, "reloc_count=%u\n" as *byte, reloc_count);
    fprintf(libc.stdout, "reloc_size=%u\n" as *byte, reloc_len);
    return 0;
}

fn verify_microapp_image(path: &byte) i32 {
    if is_pobj_output(path) != 0 {
        return verify_microapp_pobj(path);
    }
    if is_uapp_output(path) != 0 {
        return verify_microapp_uapp(path);
    }
    fprintf(libc.stderr, "错误: verify-image 仅支持 .pobj 或 .uapp: %s\n" as *byte, path as *byte);
    return 1;
}

// microapp 工作缓冲区（替代 C 的 static 数组，零初始化）
var microapp_rodata_buffer: [byte: FILE_BUFFER_SIZE] = [];
var microapp_data_buffer: [byte: FILE_BUFFER_SIZE] = [];
var microapp_reloc_buffer: [byte: FILE_BUFFER_SIZE] = [];
var microapp_pack_output_buffer: [byte: FILE_BUFFER_SIZE + 512] = [];
