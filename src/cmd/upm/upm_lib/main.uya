use libc;
use libc.FILE;
use libc.Stat;
use libc.fopen;
use libc.fclose;
use libc.fgets;
use libc.fputs;
use libc.fprintf;
use libc.getcwd;
use libc.getpid;
use libc.getenv;
use libc.fork;
use libc.waitpid;
use libc.execve;
use libc.read;
use libc.dup2;
use libc._exit;
use libc.sys_close;
use libc.sys_pipe2;
use libc.stat;
use libc.system;
use libc.snprintf;
use std.mem.memcpy;
use std.mem.memset;
use std.runtime.get_argc;
use std.runtime.get_argv;
use std.runtime.saved_envp;
use std.string.strlen;
use std.string.strcmp;
use std.string.strncmp;
use std.string.strcpy;
use std.string.strcat;
use std.string.strrchr;

const UPM_PATH_MAX: usize = 4096;
const UPM_LINE_MAX: i32 = 2048;
const UPM_CMD_MAX: i32 = 16384;
const UPM_MAX_DEPS: i32 = 64;
const UPM_MAX_ALIAS_LEN: usize = 128;
const UPM_MAX_NAME_LEN: usize = 128;
const UPM_MAX_VERSION_LEN: usize = 64;
const UPM_MAX_META_LEN: usize = 256;
const UPM_MAX_REF_LEN: usize = 256;
const UPM_MAX_LOCK_ITEMS: i32 = 128;
const UPM_MAX_VISITED: i32 = 64;

const UPM_S_IFMT: u32 = 61440u32;
const UPM_S_IFDIR: u32 = 16384u32;
const UPM_S_IFREG: u32 = 32768u32;

enum UPMManifestSection {
    UPM_SECTION_NONE,
    UPM_SECTION_PACKAGE,
    UPM_SECTION_DEPENDENCIES,
    UPM_SECTION_DEV_DEPENDENCIES,
}

enum UPMDependencyKind {
    UPM_DEP_NONE,
    UPM_DEP_PATH,
    UPM_DEP_GIT,
}

enum UPMGitRefKind {
    UPM_GIT_REF_NONE,
    UPM_GIT_REF_TAG,
    UPM_GIT_REF_BRANCH,
    UPM_GIT_REF_COMMIT,
}

enum UPMBuildArgValueMode {
    UPM_BUILD_ARG_VALUE_NONE,
    UPM_BUILD_ARG_VALUE_REQUIRED,
    UPM_BUILD_ARG_VALUE_OPTIONAL,
}

/// 表示单个依赖声明。
/// 参数说明：无。
/// 返回值说明：无；字段用于保存 alias、来源类型与 path/git 细节。
export struct UPMDependency {
    alias: [byte: UPM_MAX_ALIAS_LEN],
    kind: UPMDependencyKind,
    path_value: [byte: UPM_PATH_MAX],
    git_url: [byte: UPM_PATH_MAX],
    ref_kind: UPMGitRefKind,
    ref_value: [byte: UPM_MAX_REF_LEN],
}

/// 表示单个依赖声明。
/// 参数说明：无。
/// 返回值说明：无；字段用于保存 alias、来源类型与 path/git 细节。
export struct UPMManifest {
    manifest_path: [byte: UPM_PATH_MAX],
    package_root: [byte: UPM_PATH_MAX],
    source_root: [byte: UPM_PATH_MAX],
    source_dir: [byte: UPM_PATH_MAX],
    package_name: [byte: UPM_MAX_NAME_LEN],
    version: [byte: UPM_MAX_VERSION_LEN],
    description: [byte: UPM_MAX_META_LEN],
    license: [byte: UPM_MAX_META_LEN],
    repository: [byte: UPM_MAX_META_LEN],
    dep_count: i32,
    deps: [UPMDependency: UPM_MAX_DEPS],
    dev_dep_count: i32,
    dev_deps: [UPMDependency: UPM_MAX_DEPS],
}

struct UPMLockItem {
    alias: [byte: UPM_MAX_ALIAS_LEN],
    package_name: [byte: UPM_MAX_NAME_LEN],
    kind: UPMDependencyKind,
    path_raw: [byte: UPM_PATH_MAX],
    package_root: [byte: UPM_PATH_MAX],
    source_root: [byte: UPM_PATH_MAX],
    git_url: [byte: UPM_PATH_MAX],
    ref_kind: UPMGitRefKind,
    ref_value: [byte: UPM_MAX_REF_LEN],
}

/// 表示一次包模式构建前的准备结果。
/// 参数说明：无。
/// 返回值说明：无；字段用于保存 package/source/module root 与 lock 记录。
export struct UPMPackageBuildPlan {
    active: i32,
    manifest_path: [byte: UPM_PATH_MAX],
    package_root: [byte: UPM_PATH_MAX],
    source_root: [byte: UPM_PATH_MAX],
    build_root: [byte: UPM_PATH_MAX],
    compile_input: [byte: UPM_PATH_MAX],
    module_root: [byte: UPM_PATH_MAX],
    lock_item_count: i32,
    lock_items: [UPMLockItem: UPM_MAX_LOCK_ITEMS],
}

/// 创建带默认值的 manifest 结构。
/// 参数说明：无。
/// 返回值说明：返回一个 `source_dir` 默认值为 `"."` 的 `UPMManifest`。
export fn upm_manifest_init() UPMManifest {
    var manifest: UPMManifest = UPMManifest{};
    manifest.source_dir[0] = '.' as byte;
    manifest.source_dir[1] = 0 as byte;
    return manifest;
}

/// 创建空的包构建计划结构。
/// 参数说明：无。
/// 返回值说明：返回一个所有字段清零的 `UPMPackageBuildPlan`。
export fn upm_build_plan_init() UPMPackageBuildPlan {
    return UPMPackageBuildPlan{};
}

fn upm_ascii_is_space(ch: byte) i32 {
    if ch == 32 as byte || ch == 9 as byte || ch == 10 as byte || ch == 13 as byte {
        return 1;
    }
    return 0;
}

fn upm_is_path_sep(ch: byte) i32 {
    if ch == 47 as byte || ch == 92 as byte {
        return 1;
    }
    return 0;
}

fn upm_normalize_path(input: &byte, out: &byte, out_cap: usize) i32 {
    if input == null || out == null || out_cap <= 1usize {
        return 1;
    }
    var seg_starts: [i32: 256] = [];
    var seg_lens: [i32: 256] = [];
    var seg_count: i32 = 0;
    var prefix_len: i32 = 0;
    var has_root: i32 = 0;
    var start_idx: i32 = 0;
    if upm_is_path_sep(input[0]) != 0 {
        has_root = 1;
        start_idx = 1;
    } else {
        const c0: i32 = input[0] as i32;
        if ((c0 >= 65 && c0 <= 90) || (c0 >= 97 && c0 <= 122)) && input[1] == 58 as byte {
            prefix_len = 2;
            start_idx = 2;
            if upm_is_path_sep(input[2]) != 0 {
                has_root = 1;
                start_idx = 3;
            }
        }
    }

    var i: i32 = start_idx;
    while input[i] != 0 as byte {
        while input[i] != 0 as byte && upm_is_path_sep(input[i]) != 0 {
            i = i + 1;
        }
        if input[i] == 0 as byte {
            break;
        }
        const seg_start: i32 = i;
        while input[i] != 0 as byte && upm_is_path_sep(input[i]) == 0 {
            i = i + 1;
        }
        const seg_len: i32 = i - seg_start;
        if seg_len == 1 && input[seg_start] == 46 as byte {
            continue;
        }
        if seg_len == 2 && input[seg_start] == 46 as byte && input[seg_start + 1] == 46 as byte {
            if seg_count > 0 && seg_count - 1 >= 0 && seg_count - 1 < 256 {
                const prev_start: i32 = seg_starts[seg_count - 1];
                const prev_len: i32 = seg_lens[seg_count - 1];
                if !(prev_len == 2 && input[prev_start] == 46 as byte && input[prev_start + 1] == 46 as byte) {
                    seg_count = seg_count - 1;
                    continue;
                }
            }
            if has_root == 0 && seg_count < 256 {
                seg_starts[seg_count] = seg_start;
                seg_lens[seg_count] = seg_len;
                seg_count = seg_count + 1;
            }
            continue;
        }
        if seg_count >= 256 {
            return 1;
        }
        seg_starts[seg_count] = seg_start;
        seg_lens[seg_count] = seg_len;
        seg_count = seg_count + 1;
    }

    var out_pos: i32 = 0;
    if prefix_len == 2 {
        if out_pos + 2 >= out_cap as i32 {
            return 1;
        }
        out[out_pos as usize] = input[0];
        out[(out_pos + 1) as usize] = 58 as byte;
        out_pos = out_pos + 2;
    }
    if has_root != 0 {
        if out_pos + 1 >= out_cap as i32 {
            return 1;
        }
        out[out_pos as usize] = 47 as byte;
        out_pos = out_pos + 1;
    }

    var si: i32 = 0;
    while si < seg_count {
        if out_pos > 0 && out[(out_pos - 1) as usize] != 47 as byte {
            if out_pos + 1 >= out_cap as i32 {
                return 1;
            }
            out[out_pos as usize] = 47 as byte;
            out_pos = out_pos + 1;
        }
        var sj: i32 = 0;
        while sj < seg_lens[si] {
            if out_pos + 1 >= out_cap as i32 {
                return 1;
            }
            out[out_pos as usize] = input[(seg_starts[si] + sj) as usize];
            out_pos = out_pos + 1;
            sj = sj + 1;
        }
        si = si + 1;
    }

    if out_pos == 0 {
        out[0] = 46 as byte;
        out[1] = 0 as byte;
        return 0;
    }
    if out_pos == 2 && prefix_len == 2 && has_root == 0 {
        out[out_pos as usize] = 0 as byte;
        return 0;
    }
    if out_pos < out_cap as i32 {
        out[out_pos as usize] = 0 as byte;
        return 0;
    }
    return 1;
}

fn upm_exit_code_from_system_status(wstatus: i32) i32 {
    if wstatus < 0 {
        return 1;
    }
    const low: i32 = wstatus & 0x7f;
    const code: i32 = (wstatus >> 8) & 0xff;
    if low == 0 {
        return code;
    }
    const sig: i32 = low & 0x7f;
    if sig == 0 {
        return 1;
    }
    return 128 + sig;
}

fn upm_string_copy(dst: &byte, cap: usize, src: &byte) i32 {
    if dst == null || cap == 0usize || src == null {
        return 1;
    }
    const len: usize = strlen(src as *byte);
    if len >= cap {
        return 1;
    }
    strcpy(dst as *byte, src as *byte);
    return 0;
}

fn upm_bytes_copy(dst: &byte, cap: usize, src: &byte, src_len: usize) i32 {
    if dst == null || src == null || cap == 0usize {
        return 1;
    }
    if src_len >= cap {
        return 1;
    }
    memcpy(dst as *void, src as *void, src_len);
    dst[src_len] = 0 as byte;
    return 0;
}

fn upm_trim_copy(src: &byte, dst: &byte, cap: usize) i32 {
    if src == null || dst == null || cap == 0usize {
        return 1;
    }
    var start: usize = 0;
    const src_len: usize = strlen(src as *byte);
    while start < src_len && upm_ascii_is_space(src[start]) != 0 {
        start = start + 1;
    }
    var end: usize = src_len;
    while end > start && upm_ascii_is_space(src[end - 1usize]) != 0 {
        end = end - 1usize;
    }
    return upm_bytes_copy(dst, cap, (&src[start]) as &byte, end - start);
}

fn upm_strip_inline_comment(buf: &byte) void {
    if buf == null {
        return;
    }
    var in_quote: i32 = 0;
    var escaped: i32 = 0;
    var i: usize = 0;
    while buf[i] != 0 as byte {
        const ch: byte = buf[i];
        if escaped != 0 {
            escaped = 0;
        } else if ch == 92 as byte {
            escaped = 1;
        } else if ch == 34 as byte {
            if in_quote == 0 {
                in_quote = 1;
            } else {
                in_quote = 0;
            }
        } else if ch == 35 as byte && in_quote == 0 {
            buf[i] = 0 as byte;
            return;
        }
        i = i + 1;
    }
}

fn upm_is_absolute_path(path: &byte) i32 {
    if path == null || path[0] == 0 as byte {
        return 0;
    }
    if upm_is_path_sep(path[0]) != 0 {
        return 1;
    }
    if path[0] != 0 as byte && path[1] == 58 as byte &&
        (path[2] == 0 as byte || upm_is_path_sep(path[2]) != 0) {
        return 1;
    }
    return 0;
}

fn upm_path_dirname(path: &byte, out: &byte, cap: usize) i32 {
    if path == null || out == null || cap < 4usize {
        return 1;
    }
    const len: usize = strlen(path as *byte);
    if len == 0 || len >= UPM_PATH_MAX {
        return 1;
    }
    var tmp: [byte: UPM_PATH_MAX] = [];
    strcpy(&tmp[0] as *byte, path as *byte);
    var last: *byte = strrchr(&tmp[0] as *byte, 47);
    if last == null {
        return upm_string_copy(out, cap, "./" as &byte);
    }
    if last == &tmp[0] as *byte {
        out[0] = 47 as byte;
        out[1] = 0 as byte;
        return 0;
    }
    const prefix_len: usize = ptr_diff(last, &tmp[0] as *byte);
    if prefix_len + 2usize >= cap {
        return 1;
    }
    memcpy(out as *void, &tmp[0] as *void, prefix_len);
    out[prefix_len] = 47 as byte;
    out[prefix_len + 1usize] = 0 as byte;
    return 0;
}

fn upm_path_parent_dir(dir_path: &byte, out: &byte, cap: usize) i32 {
    if dir_path == null || out == null || cap < 4usize {
        return 1;
    }
    var tmp: [byte: UPM_PATH_MAX] = [];
    if upm_string_copy(&tmp[0] as &byte, UPM_PATH_MAX, dir_path) != 0 {
        return 1;
    }
    var len: usize = strlen(&tmp[0] as *byte);
    while len > 1usize {
        const tail_idx: usize = len - 1usize;
        if tail_idx >= UPM_PATH_MAX {
            return 1;
        }
        if tmp[tail_idx] != 47 as byte {
            break;
        }
        tmp[tail_idx] = 0 as byte;
        len = tail_idx;
    }
    var last: *byte = strrchr(&tmp[0] as *byte, 47);
    if last == null {
        return 1;
    }
    if last == &tmp[0] as *byte {
        out[0] = 47 as byte;
        out[1] = 0 as byte;
        return 0;
    }
    const prefix_len: usize = ptr_diff(last, &tmp[0] as *byte);
    if prefix_len + 2usize >= cap {
        return 1;
    }
    memcpy(out as *void, &tmp[0] as *void, prefix_len);
    out[prefix_len] = 47 as byte;
    out[prefix_len + 1usize] = 0 as byte;
    return 0;
}

fn upm_ensure_trailing_slash(path: &byte, cap: usize) i32 {
    if path == null || cap < 2usize {
        return 1;
    }
    const len: usize = strlen(path as *byte);
    if len == 0 {
        return 1;
    }
    if path[len - 1usize] == 47 as byte {
        return 0;
    }
    if len + 1usize >= cap {
        return 1;
    }
    path[len] = 47 as byte;
    path[len + 1usize] = 0 as byte;
    return 0;
}

fn upm_join_path(base_dir: &byte, rel: &byte, out: &byte, cap: usize) i32 {
    if rel == null || out == null || cap == 0usize {
        return 1;
    }
    if upm_is_absolute_path(rel) != 0 {
        return upm_string_copy(out, cap, rel);
    }
    if base_dir == null {
        return 1;
    }
    if strcmp(rel as *byte, "." as *byte) == 0 {
        return upm_string_copy(out, cap, base_dir);
    }
    const base_len: usize = strlen(base_dir as *byte);
    var with_sep: i32 = 0;
    if base_len > 0 && base_dir[base_len - 1usize] == 47 as byte {
        with_sep = 1;
    }
    var written: i32 = 0;
    if with_sep != 0 {
        written = snprintf(out as *byte, cap, "%s%s" as *byte, base_dir as *byte, rel as *byte);
    } else {
        written = snprintf(out as *byte, cap, "%s/%s" as *byte, base_dir as *byte, rel as *byte);
    }
    if written <= 0 || written >= cap as i32 {
        return 1;
    }
    return 0;
}

fn upm_make_absolute_path(path: &byte, out: &byte, cap: usize) i32 {
    if path == null || out == null || cap == 0usize {
        return 1;
    }
    if upm_is_absolute_path(path) != 0 {
        return upm_string_copy(out, cap, path);
    }
    var cwd: [byte: UPM_PATH_MAX] = [];
    if getcwd(&cwd[0] as &byte, UPM_PATH_MAX) == null {
        return 1;
    }
    if upm_ensure_trailing_slash(&cwd[0] as &byte, UPM_PATH_MAX) != 0 {
        return 1;
    }
    return upm_join_path(&cwd[0] as &byte, path, out, cap);
}

fn upm_realpath_or_copy(path: &byte, out: &byte, cap: usize) i32 {
    if path == null || out == null || cap == 0usize {
        return 1;
    }
    var absolute: [byte: UPM_PATH_MAX] = [];
    if upm_make_absolute_path(path, &absolute[0] as &byte, UPM_PATH_MAX) != 0 {
        return 1;
    }
    return upm_normalize_path(&absolute[0] as &byte, out, cap);
}

fn upm_path_exists(path: &byte) i32 {
    if path == null || path[0] == 0 as byte {
        return 0;
    }
    var st: Stat = Stat{};
    if stat(path as *byte, &st) == 0 {
        return 1;
    }
    return 0;
}

fn upm_is_directory(path: &byte) i32 {
    if path == null || path[0] == 0 as byte {
        return 0;
    }
    var st: Stat = Stat{};
    if stat(path as *byte, &st) != 0 {
        return 0;
    }
    if ((st.st_mode as u32) & UPM_S_IFMT) == UPM_S_IFDIR {
        return 1;
    }
    return 0;
}

fn upm_is_file(path: &byte) i32 {
    if path == null || path[0] == 0 as byte {
        return 0;
    }
    var st: Stat = Stat{};
    if stat(path as *byte, &st) != 0 {
        return 0;
    }
    if ((st.st_mode as u32) & UPM_S_IFMT) == UPM_S_IFREG {
        return 1;
    }
    return 0;
}

fn upm_source_dir_is_safe(source_dir: &byte) i32 {
    if source_dir == null || source_dir[0] == 0 as byte {
        return 0;
    }
    if upm_is_absolute_path(source_dir) != 0 {
        return 0;
    }
    var i: usize = 0;
    var segment_start: usize = 0;
    while true {
        const ch: byte = source_dir[i];
        if ch == 47 as byte || ch == 0 as byte {
            const seg_len: usize = i - segment_start;
            if seg_len == 2usize &&
                source_dir[segment_start] == 46 as byte &&
                source_dir[segment_start + 1usize] == 46 as byte {
                return 0;
            }
            if ch == 0 as byte {
                break;
            }
            segment_start = i + 1usize;
        }
        i = i + 1usize;
    }
    return 1;
}

fn upm_shell_quote(src: &byte, out: &byte, cap: usize) i32 {
    if src == null || out == null || cap < 3usize {
        return 1;
    }
    var i: usize = 0;
    var o: usize = 0;
    out[o] = 39 as byte;
    o = o + 1usize;
    while src[i] != 0 as byte {
        if src[i] == 39 as byte {
            if o + 4usize >= cap {
                return 1;
            }
            out[o] = 39 as byte;
            out[o + 1usize] = 92 as byte;
            out[o + 2usize] = 39 as byte;
            out[o + 3usize] = 39 as byte;
            o = o + 4usize;
        } else {
            if o + 1usize >= cap {
                return 1;
            }
            out[o] = src[i];
            o = o + 1usize;
        }
        i = i + 1usize;
    }
    if o + 1usize >= cap {
        return 1;
    }
    out[o] = 39 as byte;
    out[o + 1usize] = 0 as byte;
    return 0;
}

fn upm_shell_run(cmd: &byte, failure_label: &byte) i32 {
    const status: i32 = system(cmd as *byte);
    const exit_code: i32 = upm_exit_code_from_system_status(status);
    if exit_code != 0 {
        if failure_label != null {
            fprintf(libc.stderr, "错误: %s 失败 (exit=%d)\n" as *byte, failure_label as *byte, exit_code);
        }
        return 1;
    }
    return 0;
}

fn upm_shell_remove_tree(path: &byte) i32 {
    var quoted: [byte: UPM_PATH_MAX * 2] = [];
    if upm_shell_quote(path, &quoted[0] as &byte, UPM_PATH_MAX * 2usize) != 0 {
        return 1;
    }
    var cmd: [byte: UPM_CMD_MAX] = [];
    const written: i32 = snprintf(&cmd[0] as *byte, UPM_CMD_MAX as usize, "rm -rf %s" as *byte, &quoted[0] as *byte);
    if written <= 0 || written >= UPM_CMD_MAX {
        return 1;
    }
    return upm_shell_run(&cmd[0] as &byte, "删除目录树" as &byte);
}

fn upm_shell_mkdir_p(path: &byte) i32 {
    var quoted: [byte: UPM_PATH_MAX * 2] = [];
    if upm_shell_quote(path, &quoted[0] as &byte, UPM_PATH_MAX * 2usize) != 0 {
        return 1;
    }
    var cmd: [byte: UPM_CMD_MAX] = [];
    const written: i32 = snprintf(&cmd[0] as *byte, UPM_CMD_MAX as usize, "mkdir -p %s" as *byte, &quoted[0] as *byte);
    if written <= 0 || written >= UPM_CMD_MAX {
        return 1;
    }
    return upm_shell_run(&cmd[0] as &byte, "创建目录" as &byte);
}

fn upm_shell_copy_tree(src_dir: &byte, dst_dir: &byte) i32 {
    var src_q: [byte: UPM_PATH_MAX * 2] = [];
    var dst_q: [byte: UPM_PATH_MAX * 2] = [];
    var src_with_dot: [byte: UPM_PATH_MAX] = [];
    const src_len: usize = strlen(src_dir as *byte);
    if src_len + 3usize >= UPM_PATH_MAX {
        return 1;
    }
    strcpy(&src_with_dot[0] as *byte, src_dir as *byte);
    if src_len > 0 && src_dir[src_len - 1usize] == 47 as byte {
        strcat(&src_with_dot[0] as *byte, "." as *byte);
    } else {
        strcat(&src_with_dot[0] as *byte, "/." as *byte);
    }
    if upm_shell_quote(&src_with_dot[0] as &byte, &src_q[0] as &byte, UPM_PATH_MAX * 2usize) != 0 {
        return 1;
    }
    if upm_shell_quote(dst_dir, &dst_q[0] as &byte, UPM_PATH_MAX * 2usize) != 0 {
        return 1;
    }
    var cmd: [byte: UPM_CMD_MAX] = [];
    const written: i32 = snprintf(
        &cmd[0] as *byte,
        UPM_CMD_MAX as usize,
        "mkdir -p %s && cp -R %s %s" as *byte,
        &dst_q[0] as *byte,
        &src_q[0] as *byte,
        &dst_q[0] as *byte
    );
    if written <= 0 || written >= UPM_CMD_MAX {
        return 1;
    }
    return upm_shell_run(&cmd[0] as &byte, "复制目录树" as &byte);
}

/// 清理一次 package build plan 产生的临时 staging 目录。
/// 参数说明：`plan` 为待清理的构建计划。
/// 返回值说明：成功返回 `0`，失败返回非 `0`。
export fn upm_build_plan_cleanup(plan: &UPMPackageBuildPlan) i32 {
    if plan == null || plan.build_root[0] == 0 as byte {
        return 0;
    }
    var cleanup_root: [byte: UPM_PATH_MAX] = [];
    if upm_path_parent_dir(&plan.build_root[0] as &byte, &cleanup_root[0] as &byte, UPM_PATH_MAX) != 0 {
        if upm_string_copy(&cleanup_root[0] as &byte, UPM_PATH_MAX, &plan.build_root[0] as &byte) != 0 {
            return 1;
        }
    }
    if upm_shell_remove_tree(&cleanup_root[0] as &byte) != 0 {
        return 1;
    }
    plan.active = 0;
    plan.build_root[0] = 0 as byte;
    plan.compile_input[0] = 0 as byte;
    plan.module_root[0] = 0 as byte;
    return 0;
}

fn upm_dep_init(alias: &byte) UPMDependency {
    var dep: UPMDependency = UPMDependency{};
    _ = upm_string_copy(&dep.alias[0] as &byte, UPM_MAX_ALIAS_LEN, alias);
    dep.kind = UPMDependencyKind.UPM_DEP_NONE;
    dep.ref_kind = UPMGitRefKind.UPM_GIT_REF_NONE;
    return dep;
}

fn upm_parse_manifest_string_value(line: &byte, key_out: &byte, key_cap: usize, value_out: &byte, value_cap: usize) i32 {
    if line == null || key_out == null || value_out == null {
        return 1;
    }
    var eq_idx: usize = 0;
    while line[eq_idx] != 0 as byte && line[eq_idx] != 61 as byte {
        eq_idx = eq_idx + 1usize;
    }
    if line[eq_idx] != 61 as byte {
        return 1;
    }
    var key_buf: [byte: 256] = [];
    if upm_bytes_copy(&key_buf[0] as &byte, 256usize, line, eq_idx) != 0 {
        return 1;
    }
    if upm_trim_copy(&key_buf[0] as &byte, key_out, key_cap) != 0 {
        return 1;
    }
    var i: usize = eq_idx + 1usize;
    while line[i] != 0 as byte && upm_ascii_is_space(line[i]) != 0 {
        i = i + 1usize;
    }
    if line[i] != 34 as byte {
        return 1;
    }
    i = i + 1usize;
    const start: usize = i;
    while line[i] != 0 as byte && line[i] != 34 as byte {
        if line[i] == 92 as byte && line[i + 1usize] != 0 as byte {
            i = i + 1usize;
        }
        i = i + 1usize;
    }
    if line[i] != 34 as byte {
        return 1;
    }
    return upm_bytes_copy(value_out, value_cap, (&line[start]) as &byte, i - start);
}

fn upm_parse_dependency_inline_table(line: &byte, dep_out: &UPMDependency) i32 {
    if line == null || dep_out == null {
        return 1;
    }
    var eq_idx: usize = 0;
    while line[eq_idx] != 0 as byte && line[eq_idx] != 61 as byte {
        eq_idx = eq_idx + 1usize;
    }
    if line[eq_idx] != 61 as byte {
        return 1;
    }
    var alias_buf: [byte: UPM_MAX_ALIAS_LEN] = [];
    if upm_bytes_copy(&alias_buf[0] as &byte, UPM_MAX_ALIAS_LEN, line, eq_idx) != 0 {
        return 1;
    }
    if upm_trim_copy(&alias_buf[0] as &byte, &dep_out.alias[0] as &byte, UPM_MAX_ALIAS_LEN) != 0 {
        return 1;
    }

    var i: usize = eq_idx + 1usize;
    while line[i] != 0 as byte && upm_ascii_is_space(line[i]) != 0 {
        i = i + 1usize;
    }
    if line[i] != 123 as byte {
        return 1;
    }
    i = i + 1usize;
    dep_out.kind = UPMDependencyKind.UPM_DEP_NONE;
    dep_out.ref_kind = UPMGitRefKind.UPM_GIT_REF_NONE;
    dep_out.path_value[0] = 0 as byte;
    dep_out.git_url[0] = 0 as byte;
    dep_out.ref_value[0] = 0 as byte;

    while line[i] != 0 as byte {
        while line[i] != 0 as byte &&
            (upm_ascii_is_space(line[i]) != 0 || line[i] == 44 as byte) {
            i = i + 1usize;
        }
        if line[i] == 125 as byte {
            break;
        }
        const key_start: usize = i;
        while line[i] != 0 as byte && line[i] != 61 as byte && upm_ascii_is_space(line[i]) == 0 {
            i = i + 1usize;
        }
        var key_tmp: [byte: 64] = [];
        if upm_bytes_copy(&key_tmp[0] as &byte, 64usize, (&line[key_start]) as &byte, i - key_start) != 0 {
            return 1;
        }
        while line[i] != 0 as byte && upm_ascii_is_space(line[i]) != 0 {
            i = i + 1usize;
        }
        if line[i] != 61 as byte {
            return 1;
        }
        i = i + 1usize;
        while line[i] != 0 as byte && upm_ascii_is_space(line[i]) != 0 {
            i = i + 1usize;
        }
        if line[i] != 34 as byte {
            return 1;
        }
        i = i + 1usize;
        const value_start: usize = i;
        while line[i] != 0 as byte && line[i] != 34 as byte {
            i = i + 1usize;
        }
        if line[i] != 34 as byte {
            return 1;
        }
        var value_tmp: [byte: UPM_PATH_MAX] = [];
        if upm_bytes_copy(&value_tmp[0] as &byte, UPM_PATH_MAX, (&line[value_start]) as &byte, i - value_start) != 0 {
            return 1;
        }
        if strcmp(&key_tmp[0] as *byte, "path" as *byte) == 0 {
            dep_out.kind = UPMDependencyKind.UPM_DEP_PATH;
            if upm_string_copy(&dep_out.path_value[0] as &byte, UPM_PATH_MAX, &value_tmp[0] as &byte) != 0 {
                return 1;
            }
        } else if strcmp(&key_tmp[0] as *byte, "git" as *byte) == 0 {
            dep_out.kind = UPMDependencyKind.UPM_DEP_GIT;
            if upm_string_copy(&dep_out.git_url[0] as &byte, UPM_PATH_MAX, &value_tmp[0] as &byte) != 0 {
                return 1;
            }
        } else if strcmp(&key_tmp[0] as *byte, "tag" as *byte) == 0 {
            dep_out.ref_kind = UPMGitRefKind.UPM_GIT_REF_TAG;
            if upm_string_copy(&dep_out.ref_value[0] as &byte, UPM_MAX_REF_LEN, &value_tmp[0] as &byte) != 0 {
                return 1;
            }
        } else if strcmp(&key_tmp[0] as *byte, "branch" as *byte) == 0 {
            dep_out.ref_kind = UPMGitRefKind.UPM_GIT_REF_BRANCH;
            if upm_string_copy(&dep_out.ref_value[0] as &byte, UPM_MAX_REF_LEN, &value_tmp[0] as &byte) != 0 {
                return 1;
            }
        } else if strcmp(&key_tmp[0] as *byte, "commit" as *byte) == 0 {
            dep_out.ref_kind = UPMGitRefKind.UPM_GIT_REF_COMMIT;
            if upm_string_copy(&dep_out.ref_value[0] as &byte, UPM_MAX_REF_LEN, &value_tmp[0] as &byte) != 0 {
                return 1;
            }
        } else {
            return 1;
        }
        i = i + 1usize;
    }

    if dep_out.kind == UPMDependencyKind.UPM_DEP_PATH {
        if dep_out.path_value[0] == 0 as byte {
            return 1;
        }
        if dep_out.ref_kind != UPMGitRefKind.UPM_GIT_REF_NONE {
            return 1;
        }
    } else if dep_out.kind == UPMDependencyKind.UPM_DEP_GIT {
        if dep_out.git_url[0] == 0 as byte {
            return 1;
        }
        if dep_out.ref_kind == UPMGitRefKind.UPM_GIT_REF_NONE {
            return 1;
        }
    } else {
        return 1;
    }
    return 0;
}

/// 解析 `uya.toml` 的 MVP 子集并填充 manifest 结构。
/// 参数说明：`manifest_path` 为 manifest 文件路径；`manifest_out` 为输出结构。
/// 返回值说明：成功返回 `0`，失败返回非 `0`。
export fn upm_parse_manifest(manifest_path: &byte, manifest_out: &UPMManifest) i32 {
    if manifest_path == null || manifest_out == null {
        return 1;
    }
    manifest_out[0] = upm_manifest_init();
    if upm_realpath_or_copy(manifest_path, &manifest_out.manifest_path[0] as &byte, UPM_PATH_MAX) != 0 {
        fprintf(libc.stderr, "错误: 无法规范化 manifest 路径: %s\n" as *byte, manifest_path as *byte);
        return 1;
    }
    if upm_path_dirname(&manifest_out.manifest_path[0] as &byte, &manifest_out.package_root[0] as &byte, UPM_PATH_MAX) != 0 {
        fprintf(libc.stderr, "错误: 无法获取 package root: %s\n" as *byte, manifest_path as *byte);
        return 1;
    }
    const file: &FILE = fopen(&manifest_out.manifest_path[0] as *byte, "r" as *byte);
    if file == null {
        fprintf(libc.stderr, "错误: 无法打开 manifest: %s\n" as *byte, manifest_path as *byte);
        return 1;
    }
    var section: UPMManifestSection = UPMManifestSection.UPM_SECTION_NONE;
    var line_buf: [byte: UPM_LINE_MAX] = [];
    while fgets(&line_buf[0] as &byte, UPM_LINE_MAX, file) != null {
        upm_strip_inline_comment(&line_buf[0] as &byte);
        var trimmed: [byte: UPM_LINE_MAX] = [];
        if upm_trim_copy(&line_buf[0] as &byte, &trimmed[0] as &byte, UPM_LINE_MAX as usize) != 0 {
            fclose(file);
            return 1;
        }
        if trimmed[0] == 0 as byte {
            continue;
        }
        if strcmp(&trimmed[0] as *byte, "[package]" as *byte) == 0 {
            section = UPMManifestSection.UPM_SECTION_PACKAGE;
            continue;
        }
        if strcmp(&trimmed[0] as *byte, "[dependencies]" as *byte) == 0 {
            section = UPMManifestSection.UPM_SECTION_DEPENDENCIES;
            continue;
        }
        if strcmp(&trimmed[0] as *byte, "[dev-dependencies]" as *byte) == 0 {
            section = UPMManifestSection.UPM_SECTION_DEV_DEPENDENCIES;
            continue;
        }
        if section == UPMManifestSection.UPM_SECTION_PACKAGE {
            var key_buf: [byte: 64] = [];
            var value_buf: [byte: UPM_PATH_MAX] = [];
            if upm_parse_manifest_string_value(&trimmed[0] as &byte, &key_buf[0] as &byte, 64usize, &value_buf[0] as &byte, UPM_PATH_MAX) != 0 {
                fclose(file);
                fprintf(libc.stderr, "错误: 无法解析 package 字段: %s\n" as *byte, &trimmed[0] as *byte);
                return 1;
            }
            if strcmp(&key_buf[0] as *byte, "name" as *byte) == 0 {
                _ = upm_string_copy(&manifest_out.package_name[0] as &byte, UPM_MAX_NAME_LEN, &value_buf[0] as &byte);
            } else if strcmp(&key_buf[0] as *byte, "version" as *byte) == 0 {
                _ = upm_string_copy(&manifest_out.version[0] as &byte, UPM_MAX_VERSION_LEN, &value_buf[0] as &byte);
            } else if strcmp(&key_buf[0] as *byte, "source-dir" as *byte) == 0 {
                _ = upm_string_copy(&manifest_out.source_dir[0] as &byte, UPM_PATH_MAX, &value_buf[0] as &byte);
            } else if strcmp(&key_buf[0] as *byte, "description" as *byte) == 0 {
                _ = upm_string_copy(&manifest_out.description[0] as &byte, UPM_MAX_META_LEN, &value_buf[0] as &byte);
            } else if strcmp(&key_buf[0] as *byte, "license" as *byte) == 0 {
                _ = upm_string_copy(&manifest_out.license[0] as &byte, UPM_MAX_META_LEN, &value_buf[0] as &byte);
            } else if strcmp(&key_buf[0] as *byte, "repository" as *byte) == 0 {
                _ = upm_string_copy(&manifest_out.repository[0] as &byte, UPM_MAX_META_LEN, &value_buf[0] as &byte);
            } else {
                fclose(file);
                fprintf(libc.stderr, "错误: 未支持的 package 字段: %s\n" as *byte, &key_buf[0] as *byte);
                return 1;
            }
        } else if section == UPMManifestSection.UPM_SECTION_DEPENDENCIES ||
            section == UPMManifestSection.UPM_SECTION_DEV_DEPENDENCIES {
            if section == UPMManifestSection.UPM_SECTION_DEPENDENCIES {
                if manifest_out.dep_count >= UPM_MAX_DEPS {
                    fclose(file);
                    fprintf(libc.stderr, "错误: dependencies 超出上限 %d\n" as *byte, UPM_MAX_DEPS);
                    return 1;
                }
                const dep_idx: i32 = manifest_out.dep_count;
                if dep_idx < 0 || dep_idx >= UPM_MAX_DEPS {
                    fclose(file);
                    return 1;
                }
                const dep_idx_checked: !usize = dep_idx as! usize;
                const dep_idx_usize: usize = dep_idx_checked catch {
                    fclose(file);
                    return 1;
                };
                if dep_idx_usize >= UPM_MAX_DEPS as usize {
                    fclose(file);
                    return 1;
                }
                manifest_out.deps[dep_idx_usize] = upm_dep_init("" as &byte);
                if upm_parse_dependency_inline_table(&trimmed[0] as &byte, &manifest_out.deps[dep_idx_usize]) != 0 {
                    fclose(file);
                    fprintf(libc.stderr, "错误: 无法解析依赖声明: %s\n" as *byte, &trimmed[0] as *byte);
                    return 1;
                }
                manifest_out.dep_count = dep_idx + 1;
            } else {
                if manifest_out.dev_dep_count >= UPM_MAX_DEPS {
                    fclose(file);
                    fprintf(libc.stderr, "错误: dev-dependencies 超出上限 %d\n" as *byte, UPM_MAX_DEPS);
                    return 1;
                }
                const dep_idx: i32 = manifest_out.dev_dep_count;
                if dep_idx < 0 || dep_idx >= UPM_MAX_DEPS {
                    fclose(file);
                    return 1;
                }
                const dep_idx_checked: !usize = dep_idx as! usize;
                const dep_idx_usize: usize = dep_idx_checked catch {
                    fclose(file);
                    return 1;
                };
                if dep_idx_usize >= UPM_MAX_DEPS as usize {
                    fclose(file);
                    return 1;
                }
                manifest_out.dev_deps[dep_idx_usize] = upm_dep_init("" as &byte);
                if upm_parse_dependency_inline_table(&trimmed[0] as &byte, &manifest_out.dev_deps[dep_idx_usize]) != 0 {
                    fclose(file);
                    fprintf(libc.stderr, "错误: 无法解析依赖声明: %s\n" as *byte, &trimmed[0] as *byte);
                    return 1;
                }
                manifest_out.dev_dep_count = dep_idx + 1;
            }
        }
    }
    fclose(file);
    if manifest_out.package_name[0] == 0 as byte || manifest_out.version[0] == 0 as byte {
        fprintf(libc.stderr, "错误: manifest 缺少 package.name 或 package.version: %s\n" as *byte, &manifest_out.manifest_path[0] as *byte);
        return 1;
    }
    if upm_source_dir_is_safe(&manifest_out.source_dir[0] as &byte) == 0 {
        fprintf(libc.stderr, "错误: source-dir 必须是 package root 内部路径: %s\n" as *byte, &manifest_out.source_dir[0] as *byte);
        return 1;
    }
    if upm_join_path(&manifest_out.package_root[0] as &byte, &manifest_out.source_dir[0] as &byte, &manifest_out.source_root[0] as &byte, UPM_PATH_MAX) != 0 {
        fprintf(libc.stderr, "错误: 无法计算 source root: %s\n" as *byte, &manifest_out.source_dir[0] as *byte);
        return 1;
    }
    if upm_realpath_or_copy(&manifest_out.source_root[0] as &byte, &manifest_out.source_root[0] as &byte, UPM_PATH_MAX) != 0 {
        fprintf(libc.stderr, "错误: 无法规范化 source root: %s\n" as *byte, &manifest_out.source_root[0] as *byte);
        return 1;
    }
    if upm_ensure_trailing_slash(&manifest_out.package_root[0] as &byte, UPM_PATH_MAX) != 0 {
        return 1;
    }
    if upm_ensure_trailing_slash(&manifest_out.source_root[0] as &byte, UPM_PATH_MAX) != 0 {
        return 1;
    }
    if upm_is_directory(&manifest_out.source_root[0] as &byte) == 0 {
        fprintf(libc.stderr, "错误: source root 不存在或不是目录: %s\n" as *byte, &manifest_out.source_root[0] as *byte);
        return 1;
    }
    return 0;
}

fn upm_find_manifest_upwards(start_path: &byte, out_manifest_path: &byte) i32 {
    var current: [byte: UPM_PATH_MAX] = [];
    if upm_realpath_or_copy(start_path, &current[0] as &byte, UPM_PATH_MAX) != 0 {
        return 1;
    }
    if upm_is_directory(&current[0] as &byte) == 0 {
        if upm_path_dirname(&current[0] as &byte, &current[0] as &byte, UPM_PATH_MAX) != 0 {
            return 1;
        }
    } else if upm_ensure_trailing_slash(&current[0] as &byte, UPM_PATH_MAX) != 0 {
        return 1;
    }
    while true {
        var candidate: [byte: UPM_PATH_MAX] = [];
        if upm_join_path(&current[0] as &byte, "uya.toml" as &byte, &candidate[0] as &byte, UPM_PATH_MAX) != 0 {
            return 1;
        }
        if upm_is_file(&candidate[0] as &byte) != 0 {
            return upm_realpath_or_copy(&candidate[0] as &byte, out_manifest_path, UPM_PATH_MAX);
        }
        if strcmp(&current[0] as *byte, "/" as *byte) == 0 {
            break;
        }
        var parent: [byte: UPM_PATH_MAX] = [];
        if upm_path_parent_dir(&current[0] as &byte, &parent[0] as &byte, UPM_PATH_MAX) != 0 {
            break;
        }
        if strcmp(&parent[0] as *byte, &current[0] as *byte) == 0 {
            break;
        }
        strcpy(&current[0] as *byte, &parent[0] as *byte);
    }
    return 1;
}

fn upm_resolve_manifest_path(input_path: &byte, manifest_override: &byte, out_manifest_path: &byte) i32 {
    if manifest_override != null && manifest_override[0] != 0 as byte {
        var override_abs: [byte: UPM_PATH_MAX] = [];
        if upm_make_absolute_path(manifest_override, &override_abs[0] as &byte, UPM_PATH_MAX) != 0 {
            return 1;
        }
        if upm_is_directory(&override_abs[0] as &byte) != 0 {
            return upm_join_path(&override_abs[0] as &byte, "uya.toml" as &byte, out_manifest_path, UPM_PATH_MAX);
        }
        return upm_realpath_or_copy(&override_abs[0] as &byte, out_manifest_path, UPM_PATH_MAX);
    }
    return upm_find_manifest_upwards(input_path, out_manifest_path);
}

fn upm_lock_item_record(plan: &UPMPackageBuildPlan, alias: &byte, manifest: &UPMManifest, dep: &UPMDependency) void {
    if plan == null || manifest == null || dep == null {
        return;
    }
    if plan.lock_item_count >= UPM_MAX_LOCK_ITEMS {
        return;
    }
    const idx: i32 = plan.lock_item_count;
    if idx < 0 || idx >= UPM_MAX_LOCK_ITEMS {
        return;
    }
    const idx_checked: !usize = idx as! usize;
    const idx_usize: usize = idx_checked catch {
        return;
    };
    if idx_usize >= UPM_MAX_LOCK_ITEMS as usize {
        return;
    }
    _ = upm_string_copy(&plan.lock_items[idx_usize].alias[0] as &byte, UPM_MAX_ALIAS_LEN, alias);
    _ = upm_string_copy(&plan.lock_items[idx_usize].package_name[0] as &byte, UPM_MAX_NAME_LEN, &manifest.package_name[0] as &byte);
    plan.lock_items[idx_usize].kind = dep.kind;
    _ = upm_string_copy(&plan.lock_items[idx_usize].package_root[0] as &byte, UPM_PATH_MAX, &manifest.package_root[0] as &byte);
    _ = upm_string_copy(&plan.lock_items[idx_usize].source_root[0] as &byte, UPM_PATH_MAX, &manifest.source_root[0] as &byte);
    _ = upm_string_copy(&plan.lock_items[idx_usize].path_raw[0] as &byte, UPM_PATH_MAX, &dep.path_value[0] as &byte);
    _ = upm_string_copy(&plan.lock_items[idx_usize].git_url[0] as &byte, UPM_PATH_MAX, &dep.git_url[0] as &byte);
    plan.lock_items[idx_usize].ref_kind = dep.ref_kind;
    _ = upm_string_copy(&plan.lock_items[idx_usize].ref_value[0] as &byte, UPM_MAX_REF_LEN, &dep.ref_value[0] as &byte);
    plan.lock_item_count = plan.lock_item_count + 1;
}

fn upm_dependency_exact_ref(dep: &UPMDependency, resolved_commit: &byte, out: &byte, cap: usize) i32 {
    if dep == null || out == null || cap == 0usize {
        return 1;
    }
    out[0] = 0 as byte;
    if dep.kind != UPMDependencyKind.UPM_DEP_GIT {
        return 0;
    }
    if resolved_commit != null && resolved_commit[0] != 0 as byte {
        return upm_string_copy(out, cap, resolved_commit);
    }
    return upm_string_copy(out, cap, &dep.ref_value[0] as &byte);
}

fn upm_lock_item_matches_source(item: &UPMLockItem, manifest: &UPMManifest, dep: &UPMDependency, resolved_commit: &byte) i32 {
    if item == null || manifest == null || dep == null {
        return 0;
    }
    if item.kind != dep.kind {
        return 0;
    }
    if dep.kind == UPMDependencyKind.UPM_DEP_PATH {
        if strcmp(&item.package_root[0] as *byte, &manifest.package_root[0] as *byte) == 0 {
            return 1;
        }
        return 0;
    }
    if dep.kind == UPMDependencyKind.UPM_DEP_GIT {
        var exact_ref: [byte: UPM_MAX_REF_LEN] = [];
        if upm_dependency_exact_ref(dep, resolved_commit, &exact_ref[0] as &byte, UPM_MAX_REF_LEN) != 0 {
            return 0;
        }
        if strcmp(&item.git_url[0] as *byte, &dep.git_url[0] as *byte) != 0 {
            return 0;
        }
        if strcmp(&item.ref_value[0] as *byte, &exact_ref[0] as *byte) != 0 {
            return 0;
        }
        return 1;
    }
    return 0;
}

fn upm_check_dependency_conflicts(plan: &UPMPackageBuildPlan, manifest: &UPMManifest, dep: &UPMDependency, resolved_commit: &byte) i32 {
    if plan == null || manifest == null || dep == null {
        return -1;
    }
    var i: i32 = 0;
    while i < plan.lock_item_count {
        const item: &UPMLockItem = &plan.lock_items[i];
        const same_source: i32 = upm_lock_item_matches_source(item, manifest, dep, resolved_commit);
        if strcmp(&item.alias[0] as *byte, &dep.alias[0] as *byte) == 0 {
            if same_source != 0 {
                return 1;
            }
            fprintf(libc.stderr, "错误: 依赖 alias 冲突（alias=%s, existing_package=%s, new_package=%s）\n" as *byte,
                &dep.alias[0] as *byte,
                &item.package_name[0] as *byte,
                &manifest.package_name[0] as *byte);
            return -1;
        }
        if strcmp(&item.package_name[0] as *byte, &manifest.package_name[0] as *byte) == 0 && same_source == 0 {
            if dep.kind == UPMDependencyKind.UPM_DEP_GIT {
                fprintf(libc.stderr, "错误: 同一包要求不同 ref（package=%s, existing_alias=%s, new_alias=%s）\n" as *byte,
                    &manifest.package_name[0] as *byte,
                    &item.alias[0] as *byte,
                    &dep.alias[0] as *byte);
            } else {
                fprintf(libc.stderr, "错误: 同一包要求不同来源（package=%s, existing_alias=%s, new_alias=%s）\n" as *byte,
                    &manifest.package_name[0] as *byte,
                    &item.alias[0] as *byte,
                    &dep.alias[0] as *byte);
            }
            return -1;
        }
        i = i + 1;
    }
    return 0;
}

fn upm_build_root_contains_alias(build_root: &byte, alias: &byte) i32 {
    var alias_dir: [byte: UPM_PATH_MAX] = [];
    if upm_join_path(build_root, alias, &alias_dir[0] as &byte, UPM_PATH_MAX) == 0 {
        if upm_path_exists(&alias_dir[0] as &byte) != 0 {
            return 1;
        }
    }
    var alias_file: [byte: UPM_PATH_MAX] = [];
    const written: i32 = snprintf(&alias_file[0] as *byte, UPM_PATH_MAX, "%s%s.uya" as *byte, build_root as *byte, alias as *byte);
    if written > 0 && written < UPM_PATH_MAX {
        if upm_path_exists(&alias_file[0] as &byte) != 0 {
            return 1;
        }
    }
    return 0;
}

fn upm_stage_dependency_recursive(
    owner_manifest: &UPMManifest,
    dep: &UPMDependency,
    plan: &UPMPackageBuildPlan,
    visited: &(&byte),
    visited_count: &i32,
    force_git_refresh: i32
) i32 {
    if owner_manifest == null || dep == null || plan == null || visited == null || visited_count == null {
        return 1;
    }
    if dep.kind != UPMDependencyKind.UPM_DEP_PATH && dep.kind != UPMDependencyKind.UPM_DEP_GIT {
        fprintf(libc.stderr, "错误: 未知依赖类型（alias=%s）\n" as *byte, &dep.alias[0] as *byte);
        return 1;
    }

    var dep_package_root: [byte: UPM_PATH_MAX] = [];
    var manifest_path: [byte: UPM_PATH_MAX] = [];
    var resolved_commit: [byte: UPM_MAX_REF_LEN] = [];
    if dep.kind == UPMDependencyKind.UPM_DEP_PATH {
        if upm_join_path(&owner_manifest.package_root[0] as &byte, &dep.path_value[0] as &byte, &dep_package_root[0] as &byte, UPM_PATH_MAX) != 0 {
            fprintf(libc.stderr, "错误: path 依赖路径无效（alias=%s, path=%s）\n" as *byte, &dep.alias[0] as *byte, &dep.path_value[0] as *byte);
            return 1;
        }
        if upm_realpath_or_copy(&dep_package_root[0] as &byte, &dep_package_root[0] as &byte, UPM_PATH_MAX) != 0 ||
            upm_is_directory(&dep_package_root[0] as &byte) == 0 {
            fprintf(libc.stderr, "错误: path 依赖路径不存在（alias=%s, path=%s）\n" as *byte, &dep.alias[0] as *byte, &dep.path_value[0] as *byte);
            return 1;
        }
        if upm_join_path(&dep_package_root[0] as &byte, "uya.toml" as &byte, &manifest_path[0] as &byte, UPM_PATH_MAX) != 0 ||
            upm_is_file(&manifest_path[0] as &byte) == 0 {
            fprintf(libc.stderr, "错误: 依赖包缺少 uya.toml（alias=%s, package_root=%s）\n" as *byte, &dep.alias[0] as *byte, &dep_package_root[0] as *byte);
            return 1;
        }
    } else {
        if upm_git_prepare_checkout(owner_manifest, dep, force_git_refresh, &dep_package_root[0] as &byte, &resolved_commit[0] as &byte) != 0 {
            fprintf(libc.stderr, "错误: git 依赖准备失败（alias=%s, git=%s）\n" as *byte, &dep.alias[0] as *byte, &dep.git_url[0] as *byte);
            return 1;
        }
        if upm_join_path(&dep_package_root[0] as &byte, "uya.toml" as &byte, &manifest_path[0] as &byte, UPM_PATH_MAX) != 0 ||
            upm_is_file(&manifest_path[0] as &byte) == 0 {
            fprintf(libc.stderr, "错误: git 依赖缺少 uya.toml（alias=%s, git=%s）\n" as *byte, &dep.alias[0] as *byte, &dep.git_url[0] as *byte);
            return 1;
        }
    }

    var vi: i32 = 0;
    while vi < visited_count[0] {
        if visited[vi] != null && strcmp(visited[vi] as *byte, &dep_package_root[0] as *byte) == 0 {
            fprintf(libc.stderr, "错误: 检测到 path 依赖循环（alias=%s, package_root=%s）\n" as *byte, &dep.alias[0] as *byte, &dep_package_root[0] as *byte);
            return 1;
        }
        vi = vi + 1;
    }

    var dep_manifest: UPMManifest = upm_manifest_init();
    if upm_parse_manifest(&manifest_path[0] as &byte, &dep_manifest) != 0 {
        return 1;
    }

    const conflict_check: i32 = upm_check_dependency_conflicts(plan, &dep_manifest, dep, &resolved_commit[0] as &byte);
    if conflict_check < 0 {
        return 1;
    }
    if conflict_check > 0 {
        return 0;
    }

    if upm_build_root_contains_alias(&plan.build_root[0] as &byte, &dep.alias[0] as &byte) != 0 {
        fprintf(libc.stderr, "错误: 依赖 alias 冲突（alias=%s, package_root=%s）\n" as *byte, &dep.alias[0] as *byte, &dep_package_root[0] as *byte);
        return 1;
    }

    var install_root: [byte: UPM_PATH_MAX] = [];
    if upm_join_path(&owner_manifest.package_root[0] as &byte, ".uya/deps" as &byte, &install_root[0] as &byte, UPM_PATH_MAX) != 0 {
        return 1;
    }
    var install_alias_dir: [byte: UPM_PATH_MAX] = [];
    if upm_join_path(&install_root[0] as &byte, &dep.alias[0] as &byte, &install_alias_dir[0] as &byte, UPM_PATH_MAX) != 0 {
        return 1;
    }
    var build_alias_dir: [byte: UPM_PATH_MAX] = [];
    if upm_join_path(&plan.build_root[0] as &byte, &dep.alias[0] as &byte, &build_alias_dir[0] as &byte, UPM_PATH_MAX) != 0 {
        return 1;
    }

    _ = upm_shell_remove_tree(&install_alias_dir[0] as &byte);
    _ = upm_shell_remove_tree(&build_alias_dir[0] as &byte);
    if upm_shell_copy_tree(&dep_manifest.source_root[0] as &byte, &install_alias_dir[0] as &byte) != 0 {
        return 1;
    }
    if upm_shell_copy_tree(&dep_manifest.source_root[0] as &byte, &build_alias_dir[0] as &byte) != 0 {
        return 1;
    }

    if dep.kind == UPMDependencyKind.UPM_DEP_GIT && resolved_commit[0] != 0 as byte {
        var locked_dep: UPMDependency = dep[0];
        locked_dep.ref_kind = UPMGitRefKind.UPM_GIT_REF_COMMIT;
        _ = upm_string_copy(&locked_dep.ref_value[0] as &byte, UPM_MAX_REF_LEN, &resolved_commit[0] as &byte);
        upm_lock_item_record(plan, &dep.alias[0] as &byte, &dep_manifest, &locked_dep);
    } else {
        upm_lock_item_record(plan, &dep.alias[0] as &byte, &dep_manifest, dep);
    }

    if visited_count[0] >= UPM_MAX_VISITED {
        fprintf(libc.stderr, "错误: 依赖深度超过上限 %d\n" as *byte, UPM_MAX_VISITED);
        return 1;
    }
    visited[visited_count[0]] = &dep_manifest.package_root[0] as &byte;
    visited_count[0] = visited_count[0] + 1;
    var i: i32 = 0;
    while i < dep_manifest.dep_count {
        if upm_stage_dependency_recursive(&dep_manifest, &dep_manifest.deps[i], plan, visited, visited_count, force_git_refresh) != 0 {
            return 1;
        }
        i = i + 1;
    }
    visited_count[0] = visited_count[0] - 1;
    return 0;
}

fn upm_write_lockfile(root_manifest: &UPMManifest, plan: &UPMPackageBuildPlan) i32 {
    var lock_path: [byte: UPM_PATH_MAX] = [];
    if upm_join_path(&root_manifest.package_root[0] as &byte, "uya.lock" as &byte, &lock_path[0] as &byte, UPM_PATH_MAX) != 0 {
        return 1;
    }
    const file: &FILE = fopen(&lock_path[0] as *byte, "w" as *byte);
    if file == null {
        fprintf(libc.stderr, "错误: 无法写入 lockfile: %s\n" as *byte, &lock_path[0] as *byte);
        return 1;
    }
    fprintf(file as *void, "version = 1\n\n" as *byte);
    fprintf(file as *void, "root_name = \"%s\"\n" as *byte, &root_manifest.package_name[0] as *byte);
    fprintf(file as *void, "root_source_dir = \"%s\"\n\n" as *byte, &root_manifest.source_dir[0] as *byte);
    var i: i32 = 0;
    while i < plan.lock_item_count {
        const item: UPMLockItem = plan.lock_items[i];
        fprintf(file as *void, "[[package]]\n" as *byte);
        fprintf(file as *void, "alias = \"%s\"\n" as *byte, &item.alias[0] as *byte);
        fprintf(file as *void, "name = \"%s\"\n" as *byte, &item.package_name[0] as *byte);
        if item.kind == UPMDependencyKind.UPM_DEP_PATH {
            fprintf(file as *void, "source_kind = \"path\"\n" as *byte);
            fprintf(file as *void, "path = \"%s\"\n" as *byte, &item.path_raw[0] as *byte);
            fprintf(file as *void, "package_root = \"%s\"\n" as *byte, &item.package_root[0] as *byte);
        } else if item.kind == UPMDependencyKind.UPM_DEP_GIT {
            fprintf(file as *void, "source_kind = \"git\"\n" as *byte);
            fprintf(file as *void, "git = \"%s\"\n" as *byte, &item.git_url[0] as *byte);
            fprintf(file as *void, "commit = \"%s\"\n" as *byte, &item.ref_value[0] as *byte);
        }
        fprintf(file as *void, "source_root = \"%s\"\n\n" as *byte, &item.source_root[0] as *byte);
        i = i + 1;
    }
    fclose(file);
    return 0;
}

/// 基于输入路径和可选 manifest 覆盖生成默认构建计划。
/// 参数说明：`input_path` 为用户输入的文件或目录；`manifest_override` 为可选 manifest 路径；`plan_out` 为输出计划。
/// 返回值说明：成功返回 `0`，失败返回非 `0`。
export fn upm_prepare_build_plan(input_path: &byte, manifest_override: &byte, plan_out: &UPMPackageBuildPlan) i32 {
    return upm_prepare_build_plan_ex(input_path, manifest_override, plan_out, 0);
}

fn upm_print_usage() void {
    fprintf(libc.stdout, "Uya Package Manager (upm)\n" as *byte);
    fprintf(libc.stdout, "用法:\n" as *byte);
    fprintf(libc.stdout, "  upm --help\n" as *byte);
    fprintf(libc.stdout, "  upm --version\n" as *byte);
    fprintf(libc.stdout, "  upm init [--src-layout] [<dir>]\n" as *byte);
    fprintf(libc.stdout, "  upm install [--manifest-path <path>] [<dir>]\n" as *byte);
    fprintf(libc.stdout, "  upm update [--manifest-path <path>] [<dir>]\n" as *byte);
    fprintf(libc.stdout, "  upm build [<uya build args>...]\n" as *byte);
    fprintf(libc.stdout, "\n说明:\n" as *byte);
    fprintf(libc.stdout, "  - canonical public UX 为 `uya upm <subcommand>`\n" as *byte);
    fprintf(libc.stdout, "  - `upm build` 当前是对 `uya build` 的 wrapper\n" as *byte);
    fprintf(libc.stdout, "  - `add` / `remove` 仍保留为下一阶段命令\n" as *byte);
}

fn upm_print_version() void {
    fprintf(libc.stdout, "upm draft (uya v0.9.8)\n" as *byte);
}

fn upm_guess_package_name_from_dir(dir_path: &byte, out: &byte, cap: usize) i32 {
    if dir_path == null || out == null || cap == 0usize {
        return 1;
    }
    var tmp: [byte: UPM_PATH_MAX] = [];
    if upm_string_copy(&tmp[0] as &byte, UPM_PATH_MAX, dir_path) != 0 {
        return 1;
    }
    var len: usize = strlen(&tmp[0] as *byte);
    while len > 1usize {
        const tail_idx: usize = len - 1usize;
        if tail_idx >= UPM_PATH_MAX {
            return 1;
        }
        if tmp[tail_idx] != 47 as byte {
            break;
        }
        tmp[tail_idx] = 0 as byte;
        len = tail_idx;
    }
    var last: *byte = strrchr(&tmp[0] as *byte, 47);
    if last == null {
        return upm_string_copy(out, cap, &tmp[0] as &byte);
    }
    return upm_string_copy(out, cap, (last + 1) as &byte);
}

fn upm_write_text_file(path: &byte, text: &byte) i32 {
    if path == null || text == null {
        return 1;
    }
    const file: &FILE = fopen(path as *byte, "w" as *byte);
    if file == null {
        return 1;
    }
    fputs(text as *byte, file as *void);
    fclose(file);
    return 0;
}

fn upm_init_package(target_dir: &byte, src_layout: i32) i32 {
    if target_dir == null {
        return 1;
    }
    var target_abs: [byte: UPM_PATH_MAX] = [];
    if upm_make_absolute_path(target_dir, &target_abs[0] as &byte, UPM_PATH_MAX) != 0 {
        return 1;
    }
    if upm_shell_mkdir_p(&target_abs[0] as &byte) != 0 {
        return 1;
    }
    var manifest_path: [byte: UPM_PATH_MAX] = [];
    if upm_join_path(&target_abs[0] as &byte, "uya.toml" as &byte, &manifest_path[0] as &byte, UPM_PATH_MAX) != 0 {
        return 1;
    }
    if upm_is_file(&manifest_path[0] as &byte) != 0 {
        fprintf(libc.stderr, "错误: uya.toml 已存在: %s\n" as *byte, &manifest_path[0] as *byte);
        return 1;
    }
    var package_name: [byte: UPM_MAX_NAME_LEN] = [];
    if upm_guess_package_name_from_dir(&target_abs[0] as &byte, &package_name[0] as &byte, UPM_MAX_NAME_LEN) != 0 {
        return 1;
    }
    if package_name[0] == 0 as byte {
        _ = upm_string_copy(&package_name[0] as &byte, UPM_MAX_NAME_LEN, "uya-package" as &byte);
    }
    var source_dir_value: &byte = "." as &byte;
    var file_name: &byte = "main.uya" as &byte;
    if src_layout != 0 {
        source_dir_value = "src" as &byte;
        file_name = "src/main.uya" as &byte;
    }
    var source_file_path: [byte: UPM_PATH_MAX] = [];
    if upm_join_path(&target_abs[0] as &byte, file_name, &source_file_path[0] as &byte, UPM_PATH_MAX) != 0 {
        return 1;
    }
    if src_layout != 0 {
        var src_dir_path: [byte: UPM_PATH_MAX] = [];
        if upm_join_path(&target_abs[0] as &byte, "src" as &byte, &src_dir_path[0] as &byte, UPM_PATH_MAX) != 0 {
            return 1;
        }
        if upm_shell_mkdir_p(&src_dir_path[0] as &byte) != 0 {
            return 1;
        }
    }
    var manifest_text: [byte: UPM_LINE_MAX] = [];
    const manifest_written: i32 = snprintf(
        &manifest_text[0] as *byte,
        UPM_LINE_MAX as usize,
        "[package]\nname = \"%s\"\nversion = \"0.1.0\"\nsource-dir = \"%s\"\n" as *byte,
        &package_name[0] as *byte,
        source_dir_value as *byte
    );
    if manifest_written <= 0 || manifest_written >= UPM_LINE_MAX {
        return 1;
    }
    if upm_write_text_file(&manifest_path[0] as &byte, &manifest_text[0] as &byte) != 0 {
        return 1;
    }
    if upm_write_text_file(&source_file_path[0] as &byte, "export fn main() i32 {\n    @println(\"Hello from upm init!\");\n    return 0;\n}\n" as &byte) != 0 {
        return 1;
    }
    fprintf(libc.stdout, "已初始化: %s\n" as *byte, &manifest_path[0] as *byte);
    return 0;
}

fn upm_parse_manifest_flag_and_input(start_index: i32, manifest_out: &byte, input_out: &byte, input_cap: usize) i32 {
    if input_out == null || input_cap == 0usize {
        return 1;
    }
    input_out[0] = 0 as byte;
    if manifest_out != null {
        manifest_out[0] = 0 as byte;
    }
    var i: i32 = start_index;
    while i < get_argc() {
        const arg: &byte = get_argv(i);
        if arg == null {
            return 1;
        }
        if strcmp(arg as *byte, "--manifest-path" as *byte) == 0 {
            if manifest_out == null || i + 1 >= get_argc() {
                return 1;
            }
            i = i + 1;
            const value: &byte = get_argv(i);
            if value == null || upm_string_copy(manifest_out, UPM_PATH_MAX, value) != 0 {
                return 1;
            }
        } else if input_out[0] == 0 as byte {
            if upm_string_copy(input_out, input_cap, arg) != 0 {
                return 1;
            }
        } else {
            return 1;
        }
        i = i + 1;
    }
    if input_out[0] == 0 as byte {
        return upm_string_copy(input_out, input_cap, "." as &byte);
    }
    return 0;
}

fn upm_sync_dependencies(input_path: &byte, manifest_override: &byte, force_git_refresh: i32) i32 {
    var plan: UPMPackageBuildPlan = upm_build_plan_init();
    if upm_prepare_build_plan_ex(input_path, manifest_override, &plan, force_git_refresh) != 0 {
        return 1;
    }
    if plan.active == 0 {
        fprintf(libc.stderr, "错误: 未找到 uya.toml，请在包目录中运行或显式传入 --manifest-path\n" as *byte);
        return 1;
    }
    return upm_build_plan_cleanup(&plan);
}

fn upm_compiler_path_from_argv0(argv0: &byte, out: &byte) i32 {
    if argv0 == null || out == null {
        return 1;
    }
    var cmd_dir: [byte: UPM_PATH_MAX] = [];
    if upm_path_dirname(argv0, &cmd_dir[0] as &byte, UPM_PATH_MAX) != 0 {
        return upm_string_copy(out, UPM_PATH_MAX, "./bin/uya" as &byte);
    }
    var bin_dir: [byte: UPM_PATH_MAX] = [];
    if upm_path_parent_dir(&cmd_dir[0] as &byte, &bin_dir[0] as &byte, UPM_PATH_MAX) != 0 {
        return upm_string_copy(out, UPM_PATH_MAX, "./bin/uya" as &byte);
    }
    return upm_join_path(&bin_dir[0] as &byte, "uya" as &byte, out, UPM_PATH_MAX);
}

fn upm_shell_append_quoted(cmd: &byte, cap: usize, len: &i32, token: &byte) i32 {
    if cmd == null || len == null || token == null {
        return 1;
    }
    var quoted: [byte: UPM_PATH_MAX * 2] = [];
    if upm_shell_quote(token, &quoted[0] as &byte, UPM_PATH_MAX * 2usize) != 0 {
        return 1;
    }
    const written: i32 = snprintf((cmd as *byte) + len[0], cap - len[0] as usize, " %s" as *byte, &quoted[0] as *byte);
    if written <= 0 || len[0] + written >= cap as i32 {
        return 1;
    }
    len[0] = len[0] + written;
    return 0;
}

fn upm_build_arg_value_mode(arg: &byte) UPMBuildArgValueMode {
    if arg == null {
        return UPMBuildArgValueMode.UPM_BUILD_ARG_VALUE_NONE;
    }
    if strcmp(arg as *byte, "-o" as *byte) == 0 ||
        strcmp(arg as *byte, "--manifest-path" as *byte) == 0 ||
        strcmp(arg as *byte, "--project-root" as *byte) == 0 ||
        strcmp(arg as *byte, "--app" as *byte) == 0 ||
        strcmp(arg as *byte, "--microapp-profile" as *byte) == 0 ||
        strcmp(arg as *byte, "--outlibc" as *byte) == 0 ||
        strcmp(arg as *byte, "--stack-size" as *byte) == 0 {
        return UPMBuildArgValueMode.UPM_BUILD_ARG_VALUE_REQUIRED;
    }
    if strcmp(arg as *byte, "--split-c-dir" as *byte) == 0 {
        return UPMBuildArgValueMode.UPM_BUILD_ARG_VALUE_OPTIONAL;
    }
    return UPMBuildArgValueMode.UPM_BUILD_ARG_VALUE_NONE;
}

fn upm_build_extract_input_and_manifest(start_index: i32, manifest_out: &byte, input_out: &byte, input_cap: usize) i32 {
    if manifest_out == null || input_out == null || input_cap == 0usize {
        return 1;
    }
    manifest_out[0] = 0 as byte;
    input_out[0] = 0 as byte;
    var i: i32 = start_index;
    while i < get_argc() {
        const arg: &byte = get_argv(i);
        if arg == null {
            return 1;
        }
        if strcmp(arg as *byte, "--manifest-path" as *byte) == 0 {
            if i + 1 >= get_argc() {
                return 1;
            }
            i = i + 1;
            const value: &byte = get_argv(i);
            if value == null || upm_string_copy(manifest_out, UPM_PATH_MAX, value) != 0 {
                return 1;
            }
        } else {
            const value_mode: UPMBuildArgValueMode = upm_build_arg_value_mode(arg);
            if value_mode == UPMBuildArgValueMode.UPM_BUILD_ARG_VALUE_REQUIRED {
                if i + 1 >= get_argc() {
                    return 1;
                }
                i = i + 1;
            } else if value_mode == UPMBuildArgValueMode.UPM_BUILD_ARG_VALUE_OPTIONAL {
                if i + 1 < get_argc() {
                    i = i + 1;
                }
            } else if arg[0] != 45 as byte && input_out[0] == 0 as byte {
                if upm_string_copy(input_out, input_cap, arg) != 0 {
                    return 1;
                }
            }
        }
        i = i + 1;
    }
    if input_out[0] == 0 as byte {
        return upm_string_copy(input_out, input_cap, "." as &byte);
    }
    return 0;
}

fn upm_forward_build(start_index: i32) i32 {
    var compiler_path: [byte: UPM_PATH_MAX] = [];
    const argv0: &byte = get_argv(0);
    if upm_compiler_path_from_argv0(argv0, &compiler_path[0] as &byte) != 0 {
        return 1;
    }

    var manifest_path: [byte: UPM_PATH_MAX] = [];
    var input_path: [byte: UPM_PATH_MAX] = [];
    if upm_build_extract_input_and_manifest(start_index, &manifest_path[0] as &byte, &input_path[0] as &byte, UPM_PATH_MAX) != 0 {
        fprintf(libc.stderr, "错误: upm build 参数无效\n" as *byte);
        return 1;
    }

    var manifest_override: &byte = null;
    if manifest_path[0] != 0 as byte {
        manifest_override = &manifest_path[0] as &byte;
    }
    var plan: UPMPackageBuildPlan = upm_build_plan_init();
    if upm_prepare_build_plan(&input_path[0] as &byte, manifest_override, &plan) != 0 {
        return 1;
    }

    var cmd: [byte: UPM_CMD_MAX] = [];
    var compiler_q: [byte: UPM_PATH_MAX * 2] = [];
    if upm_shell_quote(&compiler_path[0] as &byte, &compiler_q[0] as &byte, UPM_PATH_MAX * 2usize) != 0 {
        return 1;
    }
    var cmd_len: i32 = snprintf(&cmd[0] as *byte, UPM_CMD_MAX as usize, "%s build" as *byte, &compiler_q[0] as *byte);
    if cmd_len <= 0 || cmd_len >= UPM_CMD_MAX {
        return 1;
    }

    if plan.active != 0 {
        var arg_index: i32 = start_index;
        while arg_index < get_argc() {
            const arg: &byte = get_argv(arg_index);
            if arg == null {
                return 1;
            }
            if strcmp(arg as *byte, "--manifest-path" as *byte) == 0 ||
                strcmp(arg as *byte, "--project-root" as *byte) == 0 {
                arg_index = arg_index + 2;
                continue;
            }
            const value_mode: UPMBuildArgValueMode = upm_build_arg_value_mode(arg);
            if value_mode == UPMBuildArgValueMode.UPM_BUILD_ARG_VALUE_REQUIRED {
                if upm_shell_append_quoted(&cmd[0] as &byte, UPM_CMD_MAX as usize, &cmd_len, arg) != 0 {
                    return 1;
                }
                if arg_index + 1 >= get_argc() {
                    return 1;
                }
                const value: &byte = get_argv(arg_index + 1);
                if value == null || upm_shell_append_quoted(&cmd[0] as &byte, UPM_CMD_MAX as usize, &cmd_len, value) != 0 {
                    return 1;
                }
                arg_index = arg_index + 2;
                continue;
            }
            if value_mode == UPMBuildArgValueMode.UPM_BUILD_ARG_VALUE_OPTIONAL {
                if upm_shell_append_quoted(&cmd[0] as &byte, UPM_CMD_MAX as usize, &cmd_len, arg) != 0 {
                    return 1;
                }
                if arg_index + 1 < get_argc() {
                    const value: &byte = get_argv(arg_index + 1);
                    if value == null || upm_shell_append_quoted(&cmd[0] as &byte, UPM_CMD_MAX as usize, &cmd_len, value) != 0 {
                        return 1;
                    }
                    arg_index = arg_index + 2;
                } else {
                    arg_index = arg_index + 1;
                }
                continue;
            }
            if arg[0] != 45 as byte && strcmp(arg as *byte, &input_path[0] as *byte) == 0 {
                arg_index = arg_index + 1;
                continue;
            }
            if upm_shell_append_quoted(&cmd[0] as &byte, UPM_CMD_MAX as usize, &cmd_len, arg) != 0 {
                return 1;
            }
            arg_index = arg_index + 1;
        }
        if upm_shell_append_quoted(&cmd[0] as &byte, UPM_CMD_MAX as usize, &cmd_len, &plan.compile_input[0] as &byte) != 0 {
            return 1;
        }
        if upm_shell_append_quoted(&cmd[0] as &byte, UPM_CMD_MAX as usize, &cmd_len, "--project-root" as &byte) != 0 {
            return 1;
        }
        if upm_shell_append_quoted(&cmd[0] as &byte, UPM_CMD_MAX as usize, &cmd_len, &plan.module_root[0] as &byte) != 0 {
            return 1;
        }
    } else {
        var arg_index: i32 = start_index;
        if arg_index >= get_argc() || get_argv(arg_index) == null || get_argv(arg_index)[0] == 0 as byte ||
            get_argv(arg_index)[0] == 45 as byte {
            if upm_shell_append_quoted(&cmd[0] as &byte, UPM_CMD_MAX as usize, &cmd_len, "." as &byte) != 0 {
                return 1;
            }
        }
        while arg_index < get_argc() {
            const arg: &byte = get_argv(arg_index);
            if arg == null {
                return 1;
            }
            if upm_shell_append_quoted(&cmd[0] as &byte, UPM_CMD_MAX as usize, &cmd_len, arg) != 0 {
                return 1;
            }
            arg_index = arg_index + 1;
        }
    }
    const status: i32 = system(&cmd[0] as *byte);
    const exit_code: i32 = upm_exit_code_from_system_status(status);
    if plan.active != 0 {
        if upm_build_plan_cleanup(&plan) != 0 {
            return 1;
        }
    }
    return exit_code;
}

/// 处理 `upm` 子命令入口。
/// 参数说明：`start_index` 为子命令在 `argv` 中的起始位置。
/// 返回值说明：成功返回 `0`，失败返回非 `0`。
export fn upm_cli_main(start_index: i32) i32 {
    if get_argc() <= start_index {
        upm_print_usage();
        return 0;
    }
    const cmd: &byte = get_argv(start_index);
    if cmd == null {
        return 1;
    }
    if strcmp(cmd as *byte, "--help" as *byte) == 0 || strcmp(cmd as *byte, "-h" as *byte) == 0 {
        upm_print_usage();
        return 0;
    }
    if strcmp(cmd as *byte, "--version" as *byte) == 0 || strcmp(cmd as *byte, "-v" as *byte) == 0 {
        upm_print_version();
        return 0;
    }
    if strcmp(cmd as *byte, "init" as *byte) == 0 {
        var target_dir: [byte: UPM_PATH_MAX] = [];
        _ = upm_string_copy(&target_dir[0] as &byte, UPM_PATH_MAX, "." as &byte);
        var src_layout: i32 = 0;
        var i: i32 = start_index + 1;
        while i < get_argc() {
            const arg: &byte = get_argv(i);
            if arg == null {
                return 1;
            }
            if strcmp(arg as *byte, "--src-layout" as *byte) == 0 {
                src_layout = 1;
            } else if target_dir[0] == '.' as byte && target_dir[1] == 0 as byte {
                if upm_string_copy(&target_dir[0] as &byte, UPM_PATH_MAX, arg) != 0 {
                    return 1;
                }
            } else {
                fprintf(libc.stderr, "错误: upm init 不支持的参数: %s\n" as *byte, arg as *byte);
                return 1;
            }
            i = i + 1;
        }
        return upm_init_package(&target_dir[0] as &byte, src_layout);
    }
    if strcmp(cmd as *byte, "install" as *byte) == 0 || strcmp(cmd as *byte, "update" as *byte) == 0 {
        var manifest_path: [byte: UPM_PATH_MAX] = [];
        var input_path: [byte: UPM_PATH_MAX] = [];
        if upm_parse_manifest_flag_and_input(start_index + 1, &manifest_path[0] as &byte, &input_path[0] as &byte, UPM_PATH_MAX) != 0 {
            fprintf(libc.stderr, "错误: %s 参数无效\n" as *byte, cmd as *byte);
            return 1;
        }
        var manifest_override: &byte = null;
        if manifest_path[0] != 0 as byte {
            manifest_override = &manifest_path[0] as &byte;
        }
        var force_refresh: i32 = 0;
        if strcmp(cmd as *byte, "update" as *byte) == 0 {
            force_refresh = 1;
        }
        return upm_sync_dependencies(&input_path[0] as &byte, manifest_override, force_refresh);
    }
    if strcmp(cmd as *byte, "build" as *byte) == 0 {
        return upm_forward_build(start_index + 1);
    }
    if strcmp(cmd as *byte, "add" as *byte) == 0 || strcmp(cmd as *byte, "remove" as *byte) == 0 {
        fprintf(libc.stderr, "错误: `%s` 尚未实现，请先手工修改 uya.toml 并运行 upm install/update\n" as *byte, cmd as *byte);
        return 1;
    }
    fprintf(libc.stderr, "错误: 未知 upm 子命令: %s\n" as *byte, cmd as *byte);
    fprintf(libc.stderr, "提示: 运行 `upm --help` 查看可用命令\n" as *byte);
    return 1;
}

fn upm_lock_item_reset(
    alias: &byte,
    kind: &byte,
    git_url: &byte,
    commit: &byte
) void {
    if alias != null {
        alias[0] = 0 as byte;
    }
    if kind != null {
        kind[0] = 0 as byte;
    }
    if git_url != null {
        git_url[0] = 0 as byte;
    }
    if commit != null {
        commit[0] = 0 as byte;
    }
}

fn upm_trim_newline_in_place(buf: &byte) void {
    if buf == null {
        return;
    }
    var len: usize = strlen(buf as *byte);
    while len > 0usize {
        const idx: usize = len - 1usize;
        if buf[idx] == 10 as byte || buf[idx] == 13 as byte {
            buf[idx] = 0 as byte;
            len = idx;
            continue;
        }
        break;
    }
}

fn upm_lock_item_matches_git(alias: &byte, source_kind: &byte, git_url: &byte, commit: &byte, want_alias: &byte, want_git_url: &byte) i32 {
    if alias == null || source_kind == null || git_url == null || commit == null || want_alias == null || want_git_url == null {
        return 0;
    }
    if alias[0] == 0 as byte || git_url[0] == 0 as byte || commit[0] == 0 as byte {
        return 0;
    }
    if strcmp(source_kind as *byte, "git" as *byte) != 0 {
        return 0;
    }
    if strcmp(alias as *byte, want_alias as *byte) != 0 {
        return 0;
    }
    if strcmp(git_url as *byte, want_git_url as *byte) != 0 {
        return 0;
    }
    return 1;
}

fn upm_load_locked_git_commit(package_root: &byte, alias: &byte, git_url: &byte, commit_out: &byte) i32 {
    if package_root == null || alias == null || git_url == null || commit_out == null {
        return 1;
    }
    var lock_path: [byte: UPM_PATH_MAX] = [];
    if upm_join_path(package_root, "uya.lock" as &byte, &lock_path[0] as &byte, UPM_PATH_MAX) != 0 {
        return 1;
    }
    if upm_is_file(&lock_path[0] as &byte) == 0 {
        return 1;
    }
    const file: &FILE = fopen(&lock_path[0] as *byte, "r" as *byte);
    if file == null {
        return 1;
    }
    var current_alias: [byte: UPM_MAX_ALIAS_LEN] = [];
    var current_kind: [byte: 32] = [];
    var current_git_url: [byte: UPM_PATH_MAX] = [];
    var current_commit: [byte: UPM_MAX_REF_LEN] = [];
    upm_lock_item_reset(&current_alias[0] as &byte, &current_kind[0] as &byte, &current_git_url[0] as &byte, &current_commit[0] as &byte);

    var line_buf: [byte: UPM_LINE_MAX] = [];
    while fgets(&line_buf[0] as &byte, UPM_LINE_MAX, file) != null {
        upm_strip_inline_comment(&line_buf[0] as &byte);
        var trimmed: [byte: UPM_LINE_MAX] = [];
        if upm_trim_copy(&line_buf[0] as &byte, &trimmed[0] as &byte, UPM_LINE_MAX as usize) != 0 {
            fclose(file);
            return 1;
        }
        if trimmed[0] == 0 as byte {
            continue;
        }
        if strcmp(&trimmed[0] as *byte, "[[package]]" as *byte) == 0 {
            if upm_lock_item_matches_git(&current_alias[0] as &byte, &current_kind[0] as &byte, &current_git_url[0] as &byte, &current_commit[0] as &byte, alias, git_url) != 0 {
                fclose(file);
                return upm_string_copy(commit_out, UPM_MAX_REF_LEN, &current_commit[0] as &byte);
            }
            upm_lock_item_reset(&current_alias[0] as &byte, &current_kind[0] as &byte, &current_git_url[0] as &byte, &current_commit[0] as &byte);
            continue;
        }
        var key_buf: [byte: 64] = [];
        var value_buf: [byte: UPM_PATH_MAX] = [];
        if upm_parse_manifest_string_value(&trimmed[0] as &byte, &key_buf[0] as &byte, 64usize, &value_buf[0] as &byte, UPM_PATH_MAX) != 0 {
            continue;
        }
        if strcmp(&key_buf[0] as *byte, "alias" as *byte) == 0 {
            _ = upm_string_copy(&current_alias[0] as &byte, UPM_MAX_ALIAS_LEN, &value_buf[0] as &byte);
        } else if strcmp(&key_buf[0] as *byte, "source_kind" as *byte) == 0 {
            _ = upm_string_copy(&current_kind[0] as &byte, 32usize, &value_buf[0] as &byte);
        } else if strcmp(&key_buf[0] as *byte, "git" as *byte) == 0 {
            _ = upm_string_copy(&current_git_url[0] as &byte, UPM_PATH_MAX, &value_buf[0] as &byte);
        } else if strcmp(&key_buf[0] as *byte, "commit" as *byte) == 0 {
            _ = upm_string_copy(&current_commit[0] as &byte, UPM_MAX_REF_LEN, &value_buf[0] as &byte);
        }
    }
    fclose(file);
    if upm_lock_item_matches_git(&current_alias[0] as &byte, &current_kind[0] as &byte, &current_git_url[0] as &byte, &current_commit[0] as &byte, alias, git_url) != 0 {
        return upm_string_copy(commit_out, UPM_MAX_REF_LEN, &current_commit[0] as &byte);
    }
    return 1;
}

fn upm_find_git_binary(out: &byte, cap: usize) i32 {
    if out == null || cap == 0usize {
        return 1;
    }
    var path_env: &byte = getenv("PATH" as *byte);
    if path_env != null && path_env[0] != 0 as byte {
        var start: usize = 0;
        var i: usize = 0;
        while true {
            const ch: byte = path_env[i];
            if ch == 58 as byte || ch == 0 as byte {
                var dir_buf: [byte: UPM_PATH_MAX] = [];
                if i == start {
                    _ = upm_string_copy(&dir_buf[0] as &byte, UPM_PATH_MAX, "." as &byte);
                } else if upm_bytes_copy(&dir_buf[0] as &byte, UPM_PATH_MAX, (&path_env[start]) as &byte, i - start) != 0 {
                    return 1;
                }
                var candidate: [byte: UPM_PATH_MAX] = [];
                if upm_join_path(&dir_buf[0] as &byte, "git" as &byte, &candidate[0] as &byte, UPM_PATH_MAX) == 0 &&
                    upm_is_file(&candidate[0] as &byte) != 0 {
                    return upm_string_copy(out, cap, &candidate[0] as &byte);
                }
                if ch == 0 as byte {
                    break;
                }
                start = i + 1usize;
            }
            i = i + 1usize;
        }
    }
    if upm_is_file("/usr/bin/git" as &byte) != 0 {
        return upm_string_copy(out, cap, "/usr/bin/git" as &byte);
    }
    if upm_is_file("/bin/git" as &byte) != 0 {
        return upm_string_copy(out, cap, "/bin/git" as &byte);
    }
    fprintf(libc.stderr, "错误: 未找到 git 可执行文件\n" as *byte);
    return 1;
}

fn upm_exec_argv_wait(argv: &(&byte), failure_label: &byte) i32 {
    if argv == null || argv[0] == null {
        return 1;
    }
    const pid: i32 = fork();
    if pid == 0 {
        var empty_env: [&byte: 1] = [null];
        var envp: &(&byte) = &empty_env[0] as &(&byte);
        if saved_envp != null {
            envp = saved_envp as &(&byte);
        }
        execve(argv[0], argv as &(&byte), envp as & &byte);
        _exit(127);
    }
    if pid < 0 {
        fprintf(libc.stderr, "错误: 无法创建子进程\n" as *byte);
        return 1;
    }
    var status: i32 = 0;
    if waitpid(pid, &status, 0) < 0 {
        fprintf(libc.stderr, "错误: waitpid 失败\n" as *byte);
        return 1;
    }
    const exit_code: i32 = upm_exit_code_from_system_status(status);
    if exit_code != 0 {
        if failure_label != null {
            fprintf(libc.stderr, "错误: %s 失败 (exit=%d)\n" as *byte, failure_label as *byte, exit_code);
        }
        return 1;
    }
    return 0;
}

fn upm_exec_argv_capture_first_line(argv: &(&byte), out: &byte, cap: usize, failure_label: &byte) i32 {
    if argv == null || argv[0] == null || out == null || cap == 0usize {
        return 1;
    }
    var pipe_fds: [i32: 2] = [];
    const pipe_result: !i32 = sys_pipe2(&pipe_fds[0], 0);
    pipe_result catch {
        fprintf(libc.stderr, "错误: 无法创建管道\n" as *byte);
        return 1;
    };
    const pid: i32 = fork();
    if pid == 0 {
        _ = sys_close(pipe_fds[0]) catch {};
        if dup2(pipe_fds[1], 1) < 0 {
            _exit(127);
        }
        _ = sys_close(pipe_fds[1]) catch {};
        var empty_env: [&byte: 1] = [null];
        var envp: &(&byte) = &empty_env[0] as &(&byte);
        if saved_envp != null {
            envp = saved_envp as &(&byte);
        }
        execve(argv[0], argv as &(&byte), envp as & &byte);
        _exit(127);
    }
    _ = sys_close(pipe_fds[1]) catch {};
    if pid < 0 {
        _ = sys_close(pipe_fds[0]) catch {};
        fprintf(libc.stderr, "错误: 无法创建子进程\n" as *byte);
        return 1;
    }

    var filled: usize = 0;
    while filled + 1usize < cap {
        const read_result: i64 = read(pipe_fds[0], (&out[filled]) as &byte, cap - 1usize - filled);
        if read_result <= 0 {
            break;
        }
        const rn_checked: !usize = read_result as! usize;
        const rn: usize = rn_checked catch {
            _ = sys_close(pipe_fds[0]) catch {};
            return 1;
        };
        var scan: usize = 0;
        while scan < rn {
            if out[filled + scan] == 10 as byte || out[filled + scan] == 13 as byte {
                out[filled + scan] = 0 as byte;
                filled = filled + scan;
                _ = sys_close(pipe_fds[0]) catch {};
                var status: i32 = 0;
                if waitpid(pid, &status, 0) < 0 {
                    return 1;
                }
                const exit_code: i32 = upm_exit_code_from_system_status(status);
                if exit_code != 0 {
                    if failure_label != null {
                        fprintf(libc.stderr, "错误: %s 失败 (exit=%d)\n" as *byte, failure_label as *byte, exit_code);
                    }
                    return 1;
                }
                return 0;
            }
            scan = scan + 1usize;
        }
        filled = filled + rn;
    }
    _ = sys_close(pipe_fds[0]) catch {};
    out[filled] = 0 as byte;
    var status: i32 = 0;
    if waitpid(pid, &status, 0) < 0 {
        return 1;
    }
    const exit_code: i32 = upm_exit_code_from_system_status(status);
    if exit_code != 0 {
        if failure_label != null {
            fprintf(libc.stderr, "错误: %s 失败 (exit=%d)\n" as *byte, failure_label as *byte, exit_code);
        }
        return 1;
    }
    upm_trim_newline_in_place(out);
    if out[0] == 0 as byte {
        return 1;
    }
    return 0;
}

fn upm_git_checkout_ref(repo_dir: &byte, ref_name: &byte) i32 {
    var git_path: [byte: UPM_PATH_MAX] = [];
    if upm_find_git_binary(&git_path[0] as &byte, UPM_PATH_MAX) != 0 {
        return 1;
    }
    var args: [&byte: 6] = [
        &git_path[0] as &byte,
        "-C" as &byte,
        repo_dir,
        "checkout" as &byte,
        ref_name,
        null,
    ];
    return upm_exec_argv_wait(&args[0] as &(&byte), "git checkout" as &byte);
}

fn upm_git_rev_parse_head(repo_dir: &byte, commit_out: &byte) i32 {
    var git_path: [byte: UPM_PATH_MAX] = [];
    if upm_find_git_binary(&git_path[0] as &byte, UPM_PATH_MAX) != 0 {
        return 1;
    }
    var args: [&byte: 6] = [
        &git_path[0] as &byte,
        "-C" as &byte,
        repo_dir,
        "rev-parse" as &byte,
        "HEAD" as &byte,
        null,
    ];
    return upm_exec_argv_capture_first_line(&args[0] as &(&byte), commit_out, UPM_MAX_REF_LEN, "git rev-parse" as &byte);
}

fn upm_git_clone_into(url: &byte, dst_dir: &byte) i32 {
    var git_path: [byte: UPM_PATH_MAX] = [];
    if upm_find_git_binary(&git_path[0] as &byte, UPM_PATH_MAX) != 0 {
        return 1;
    }
    var args: [&byte: 5] = [
        &git_path[0] as &byte,
        "clone" as &byte,
        url,
        dst_dir,
        null,
    ];
    return upm_exec_argv_wait(&args[0] as &(&byte), "git clone" as &byte);
}

fn upm_git_prepare_checkout(
    owner_manifest: &UPMManifest,
    dep: &UPMDependency,
    force_git_refresh: i32,
    checkout_dir_out: &byte,
    commit_out: &byte
) i32 {
    if owner_manifest == null || dep == null || checkout_dir_out == null || commit_out == null {
        return 1;
    }
    var git_cache_root: [byte: UPM_PATH_MAX] = [];
    if upm_join_path(&owner_manifest.package_root[0] as &byte, ".uya/git-cache" as &byte, &git_cache_root[0] as &byte, UPM_PATH_MAX) != 0 {
        return 1;
    }
    var repo_dir: [byte: UPM_PATH_MAX] = [];
    if upm_join_path(&git_cache_root[0] as &byte, &dep.alias[0] as &byte, &repo_dir[0] as &byte, UPM_PATH_MAX) != 0 {
        return 1;
    }
    _ = upm_shell_remove_tree(&repo_dir[0] as &byte);
    if upm_git_clone_into(&dep.git_url[0] as &byte, &repo_dir[0] as &byte) != 0 {
        return 1;
    }

    var ref_to_use: [byte: UPM_MAX_REF_LEN] = [];
    ref_to_use[0] = 0 as byte;
    if dep.ref_kind == UPMGitRefKind.UPM_GIT_REF_COMMIT {
        _ = upm_string_copy(&ref_to_use[0] as &byte, UPM_MAX_REF_LEN, &dep.ref_value[0] as &byte);
    } else if force_git_refresh == 0 {
        if upm_load_locked_git_commit(&owner_manifest.package_root[0] as &byte, &dep.alias[0] as &byte, &dep.git_url[0] as &byte, &ref_to_use[0] as &byte) != 0 {
            _ = upm_string_copy(&ref_to_use[0] as &byte, UPM_MAX_REF_LEN, &dep.ref_value[0] as &byte);
        }
    } else {
        _ = upm_string_copy(&ref_to_use[0] as &byte, UPM_MAX_REF_LEN, &dep.ref_value[0] as &byte);
    }
    if ref_to_use[0] == 0 as byte {
        return 1;
    }
    if upm_git_checkout_ref(&repo_dir[0] as &byte, &ref_to_use[0] as &byte) != 0 {
        return 1;
    }
    if upm_git_rev_parse_head(&repo_dir[0] as &byte, commit_out) != 0 {
        return 1;
    }
    return upm_string_copy(checkout_dir_out, UPM_PATH_MAX, &repo_dir[0] as &byte);
}

/// 生成可选带强制 Git 刷新的构建计划。
/// 参数说明：`input_path` 为用户输入；`manifest_override` 为可选 manifest 路径；`plan_out` 为输出计划；`force_git_refresh` 控制是否刷新可变 Git ref。
/// 返回值说明：成功返回 `0`，失败返回非 `0`。
export fn upm_prepare_build_plan_ex(input_path: &byte, manifest_override: &byte, plan_out: &UPMPackageBuildPlan, force_git_refresh: i32) i32 {
    if input_path == null || plan_out == null {
        return 1;
    }
    plan_out[0] = upm_build_plan_init();
    var cleanup_on_fail: i32 = 0;
    defer {
        if cleanup_on_fail != 0 {
            _ = upm_build_plan_cleanup(plan_out);
        }
    }
    var manifest_path: [byte: UPM_PATH_MAX] = [];
    if upm_resolve_manifest_path(input_path, manifest_override, &manifest_path[0] as &byte) != 0 {
        return 0;
    }

    var root_manifest: UPMManifest = upm_manifest_init();
    if upm_parse_manifest(&manifest_path[0] as &byte, &root_manifest) != 0 {
        return 1;
    }

    plan_out.active = 1;
    cleanup_on_fail = 1;
    _ = upm_string_copy(&plan_out.manifest_path[0] as &byte, UPM_PATH_MAX, &root_manifest.manifest_path[0] as &byte);
    _ = upm_string_copy(&plan_out.package_root[0] as &byte, UPM_PATH_MAX, &root_manifest.package_root[0] as &byte);
    _ = upm_string_copy(&plan_out.source_root[0] as &byte, UPM_PATH_MAX, &root_manifest.source_root[0] as &byte);

    var tmpdir: &byte = getenv("TMPDIR" as *byte);
    if tmpdir == null || tmpdir[0] == 0 as byte {
        tmpdir = "/tmp" as &byte;
    }
    var tmpdir_slash: [byte: UPM_PATH_MAX] = [];
    if upm_string_copy(&tmpdir_slash[0] as &byte, UPM_PATH_MAX, tmpdir) != 0 {
        return 1;
    }
    if upm_ensure_trailing_slash(&tmpdir_slash[0] as &byte, UPM_PATH_MAX) != 0 {
        return 1;
    }
    const written: i32 = snprintf(
        &plan_out.build_root[0] as *byte,
        UPM_PATH_MAX,
        "%suya-upm-build-%d/root" as *byte,
        &tmpdir_slash[0] as *byte,
        getpid()
    );
    if written <= 0 || written >= UPM_PATH_MAX {
        return 1;
    }
    if upm_shell_remove_tree(&plan_out.build_root[0] as &byte) != 0 {
        return 1;
    }
    if upm_shell_copy_tree(&root_manifest.source_root[0] as &byte, &plan_out.build_root[0] as &byte) != 0 {
        return 1;
    }
    if upm_ensure_trailing_slash(&plan_out.build_root[0] as &byte, UPM_PATH_MAX) != 0 {
        return 1;
    }
    _ = upm_string_copy(&plan_out.module_root[0] as &byte, UPM_PATH_MAX, &plan_out.build_root[0] as &byte);

    var input_abs: [byte: UPM_PATH_MAX] = [];
    if upm_realpath_or_copy(input_path, &input_abs[0] as &byte, UPM_PATH_MAX) != 0 {
        return 1;
    }
    if upm_is_directory(&input_abs[0] as &byte) != 0 {
        _ = upm_string_copy(&plan_out.compile_input[0] as &byte, UPM_PATH_MAX, &plan_out.build_root[0] as &byte);
    } else {
        const root_len: usize = strlen(&root_manifest.source_root[0] as *byte);
        if root_len > 0usize && strncmp(&input_abs[0] as *byte, &root_manifest.source_root[0] as *byte, root_len) == 0 {
            if upm_join_path(&plan_out.build_root[0] as &byte, (&input_abs[root_len]) as &byte, &plan_out.compile_input[0] as &byte, UPM_PATH_MAX) != 0 {
                return 1;
            }
        } else {
            _ = upm_string_copy(&plan_out.compile_input[0] as &byte, UPM_PATH_MAX, &plan_out.build_root[0] as &byte);
        }
    }

    var visited: [&byte: UPM_MAX_VISITED] = [];
    var visited_count: i32 = 1;
    visited[0] = &root_manifest.package_root[0] as &byte;
    var i: i32 = 0;
    while i < root_manifest.dep_count {
        if upm_stage_dependency_recursive(&root_manifest, &root_manifest.deps[i], plan_out, &visited[0] as &(&byte), &visited_count, force_git_refresh) != 0 {
            return 1;
        }
        i = i + 1;
    }
    if upm_write_lockfile(&root_manifest, plan_out) != 0 {
        return 1;
    }
    cleanup_on_fail = 0;
    return 0;
}
