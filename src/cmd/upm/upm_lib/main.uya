fn upm_print_usage() void {
    fprintf(libc.stdout, "Uya Package Manager (upm)\n" as *byte);
    fprintf(libc.stdout, "用法:\n" as *byte);
    fprintf(libc.stdout, "  upm --help\n" as *byte);
    fprintf(libc.stdout, "  upm --version\n" as *byte);
    fprintf(libc.stdout, "  upm init [--src-layout] [<dir>]\n" as *byte);
    fprintf(libc.stdout, "  upm install [--manifest-path <path>] [<dir>]\n" as *byte);
    fprintf(libc.stdout, "  upm update [--manifest-path <path>] [<dir>]\n" as *byte);
    fprintf(libc.stdout, "  upm add <alias> --path <dir> [--manifest-path <path>] [<dir>]\n" as *byte);
    fprintf(libc.stdout, "  upm add <alias> --git <url> (--branch <name> | --tag <name> | --commit <sha>) [--manifest-path <path>] [<dir>]\n" as *byte);
    fprintf(libc.stdout, "  upm add <alias> --dev --path <dir> [--manifest-path <path>] [<dir>]\n" as *byte);
    fprintf(libc.stdout, "  upm add <alias> --dev --git <url> (--branch <name> | --tag <name> | --commit <sha>) [--manifest-path <path>] [<dir>]\n" as *byte);
    fprintf(libc.stdout, "  upm remove <alias> [--manifest-path <path>] [<dir>]\n" as *byte);
    fprintf(libc.stdout, "  upm remove <alias> --dep [--manifest-path <path>] [<dir>]\n" as *byte);
    fprintf(libc.stdout, "  upm remove <alias> --dev [--manifest-path <path>] [<dir>]\n" as *byte);
    fprintf(libc.stdout, "  upm graph [--manifest-path <path>] [<dir>]\n" as *byte);
    fprintf(libc.stdout, "  upm why <alias> [--manifest-path <path>] [<dir>]\n" as *byte);
    fprintf(libc.stdout, "  upm doctor [--manifest-path <path>] [<dir>]\n" as *byte);
    fprintf(libc.stdout, "  upm cache dir\n" as *byte);
    fprintf(libc.stdout, "  upm vendor [--manifest-path <path>] [<dir>]\n" as *byte);
    fprintf(libc.stdout, "  upm publish [--manifest-path <path>] [<dir>]\n" as *byte);
    fprintf(libc.stdout, "  upm build [<uya build args>...]\n" as *byte);
    fprintf(libc.stdout, "\n示例:\n" as *byte);
    fprintf(libc.stdout, "  upm add gui_uya --git https://github.com/uya-lang/gui-uya.git --branch main\n" as *byte);
    fprintf(libc.stdout, "  upm add gui_uya --dev --path ../gui_uya\n" as *byte);
    fprintf(libc.stdout, "  upm remove gui_uya --dep\n" as *byte);
    fprintf(libc.stdout, "  upm remove gui_uya --dev\n" as *byte);
    fprintf(libc.stdout, "\n说明:\n" as *byte);
    fprintf(libc.stdout, "  - canonical public UX 为 `uya upm <subcommand>`\n" as *byte);
    fprintf(libc.stdout, "  - `upm build` 当前是对 `uya build` 的 wrapper\n" as *byte);
    fprintf(libc.stdout, "  - `upm add` 会改写 uya.toml 并自动执行 install\n" as *byte);
    fprintf(libc.stdout, "  - `upm remove` 会从 manifest 删除依赖并自动执行 install\n" as *byte);
}

fn upm_print_version() void {
    fprintf(libc.stdout, "upm draft (uya v%s)\n" as *byte, UYA_UPM_RUNTIME_VERSION as *byte);
}

fn upm_package_name_is_valid(name: &byte) i32 {
    if name == null {
        return 0;
    }
    const len: usize = strlen(name as *byte);
    if len == 0usize || len >= UPM_MAX_NAME_LEN {
        return 0;
    }
    var i: usize = 0usize;
    while i < len {
        const ch: i32 = name[i] as i32;
        var is_lower: i32 = 0;
        var is_digit: i32 = 0;
        if ch >= 97 && ch <= 122 {
            is_lower = 1;
        }
        if ch >= 48 && ch <= 57 {
            is_digit = 1;
        }
        if i == 0usize && ch == 45 {
            return 0;
        }
        if is_lower == 0 && is_digit == 0 && ch != 45 && ch != 95 {
            return 0;
        }
        i = i + 1usize;
    }
    return 1;
}

fn upm_init_target_dir_arg_is_valid(target_dir: &byte) i32 {
    if target_dir == null || target_dir[0] == 0 as byte {
        return 0;
    }
    if target_dir[0] == 45 as byte {
        return 0;
    }
    var i: usize = 0usize;
    var segment_start: usize = 0usize;
    var last_segment_start: usize = 0usize;
    var last_segment_len: usize = 0usize;
    while true {
        const ch: byte = target_dir[i];
        const ch_i: i32 = ch as i32;
        if ch == 0 as byte {
            if i > segment_start {
                last_segment_start = segment_start;
                last_segment_len = i - segment_start;
            }
            break;
        }
        if ch_i == 9 || ch_i == 10 || ch_i == 13 {
            return 0;
        }
        if ch == 47 as byte || ch == 92 as byte {
            if i > segment_start {
                last_segment_start = segment_start;
                last_segment_len = i - segment_start;
            }
            segment_start = i + 1usize;
        }
        i = i + 1usize;
    }
    if last_segment_len == 0usize {
        return 0;
    }
    if last_segment_len == 2usize &&
        target_dir[last_segment_start] == 46 as byte &&
        target_dir[last_segment_start + 1usize] == 46 as byte {
        return 0;
    }
    return 1;
}

fn upm_guess_package_name_from_dir(dir_path: &byte, out: &byte, cap: usize) i32 {
    if dir_path == null || out == null || cap == 0usize {
        return 1;
    }
    var tmp: [byte: UPM_PATH_MAX] = [];
    if upm_string_copy(&tmp[0] as &byte, UPM_PATH_MAX, dir_path) != 0 {
        return 1;
    }
    var len: usize = strlen(&tmp[0] as *byte);
    while len > 1usize {
        const tail_idx: usize = len - 1usize;
        if tail_idx >= UPM_PATH_MAX {
            return 1;
        }
        if tmp[tail_idx] != 47 as byte {
            break;
        }
        tmp[tail_idx] = 0 as byte;
        len = tail_idx;
    }
    var last: *byte = strrchr(&tmp[0] as *byte, 47);
    if last == null {
        return upm_string_copy(out, cap, &tmp[0] as &byte);
    }
    return upm_string_copy(out, cap, (last + 1) as &byte);
}

fn upm_write_text_file(path: &byte, text: &byte) i32 {
    if path == null || text == null {
        return 1;
    }
    const file: &FILE = fopen(path as *byte, "w" as *byte);
    if file == null {
        return 1;
    }
    fputs(text as *byte, file as *void);
    fclose(file);
    return 0;
}

fn upm_init_package(target_dir: &byte, src_layout: i32) i32 {
    if target_dir == null {
        return 1;
    }
    if upm_init_target_dir_arg_is_valid(target_dir) == 0 {
        fprintf(libc.stderr, "错误: upm init 项目文件夹无效: %s\n" as *byte, target_dir as *byte);
        return 1;
    }
    var target_abs: [byte: UPM_PATH_MAX] = [];
    if upm_make_absolute_path(target_dir, &target_abs[0] as &byte, UPM_PATH_MAX) != 0 {
        return 1;
    }
    var package_name: [byte: UPM_MAX_NAME_LEN] = [];
    if upm_guess_package_name_from_dir(&target_abs[0] as &byte, &package_name[0] as &byte, UPM_MAX_NAME_LEN) != 0 {
        return 1;
    }
    if upm_package_name_is_valid(&package_name[0] as &byte) == 0 {
        fprintf(libc.stderr, "错误: upm init 项目名无效: %s\n" as *byte, &package_name[0] as *byte);
        fprintf(libc.stderr, "提示: 项目名只能使用 ASCII 小写字母、数字、`-`、`_`，且不能以 `-` 开头\n" as *byte);
        return 1;
    }
    if upm_is_file(&target_abs[0] as &byte) != 0 {
        fprintf(libc.stderr, "错误: upm init 项目文件夹不是目录: %s\n" as *byte, &target_abs[0] as *byte);
        return 1;
    }
    var manifest_path: [byte: UPM_PATH_MAX] = [];
    if upm_join_path(&target_abs[0] as &byte, "uya.toml" as &byte, &manifest_path[0] as &byte, UPM_PATH_MAX) != 0 {
        return 1;
    }
    if upm_is_file(&manifest_path[0] as &byte) != 0 || upm_is_directory(&manifest_path[0] as &byte) != 0 {
        fprintf(libc.stderr, "错误: uya.toml 已存在: %s\n" as *byte, &manifest_path[0] as *byte);
        return 1;
    }
    if upm_shell_mkdir_p(&target_abs[0] as &byte) != 0 {
        return 1;
    }
    if upm_is_directory(&target_abs[0] as &byte) == 0 {
        fprintf(libc.stderr, "错误: upm init 项目文件夹不是目录: %s\n" as *byte, &target_abs[0] as *byte);
        return 1;
    }
    var source_dir_value: &byte = "." as &byte;
    var file_name: &byte = "main.uya" as &byte;
    if src_layout != 0 {
        source_dir_value = "src" as &byte;
        file_name = "src/main.uya" as &byte;
    }
    var source_file_path: [byte: UPM_PATH_MAX] = [];
    if upm_join_path(&target_abs[0] as &byte, file_name, &source_file_path[0] as &byte, UPM_PATH_MAX) != 0 {
        return 1;
    }
    if upm_is_file(&source_file_path[0] as &byte) != 0 || upm_is_directory(&source_file_path[0] as &byte) != 0 {
        fprintf(libc.stderr, "错误: upm init 源码文件已存在: %s\n" as *byte, &source_file_path[0] as *byte);
        return 1;
    }
    if src_layout != 0 {
        var src_dir_path: [byte: UPM_PATH_MAX] = [];
        if upm_join_path(&target_abs[0] as &byte, "src" as &byte, &src_dir_path[0] as &byte, UPM_PATH_MAX) != 0 {
            return 1;
        }
        if upm_is_file(&src_dir_path[0] as &byte) != 0 {
            fprintf(libc.stderr, "错误: upm init src 目录路径不是目录: %s\n" as *byte, &src_dir_path[0] as *byte);
            return 1;
        }
        if upm_shell_mkdir_p(&src_dir_path[0] as &byte) != 0 {
            return 1;
        }
    }
    var manifest_text: [byte: UPM_LINE_MAX] = [];
    const manifest_written: i32 = snprintf(
        &manifest_text[0] as *byte,
        UPM_LINE_MAX as usize,
        "[package]\nname = \"%s\"\nversion = \"0.1.0\"\nsource-dir = \"%s\"\n" as *byte,
        &package_name[0] as *byte,
        source_dir_value as *byte
    );
    if manifest_written <= 0 || manifest_written >= UPM_LINE_MAX {
        return 1;
    }
    if upm_write_text_file(&manifest_path[0] as &byte, &manifest_text[0] as &byte) != 0 {
        return 1;
    }
    if upm_write_text_file(&source_file_path[0] as &byte, "export fn main() i32 {\n    @println(\"Hello from upm init!\");\n    return 0;\n}\n" as &byte) != 0 {
        return 1;
    }
    fprintf(libc.stdout, "已初始化: %s\n" as *byte, &manifest_path[0] as *byte);
    return 0;
}

fn upm_parse_manifest_flag_and_input(start_index: i32, manifest_out: &byte, input_out: &byte, input_cap: usize) i32 {
    if input_out == null || input_cap == 0usize {
        return 1;
    }
    input_out[0] = 0 as byte;
    if manifest_out != null {
        manifest_out[0] = 0 as byte;
    }
    var i: i32 = start_index;
    while i < get_argc() {
        const arg: &byte = get_argv(i);
        if arg == null {
            return 1;
        }
        if strcmp(arg as *byte, "--manifest-path" as *byte) == 0 {
            if manifest_out == null || i + 1 >= get_argc() {
                return 1;
            }
            i = i + 1;
            const value: &byte = get_argv(i);
            if value == null || upm_string_copy(manifest_out, UPM_PATH_MAX, value) != 0 {
                return 1;
            }
        } else if input_out[0] == 0 as byte {
            if upm_string_copy(input_out, input_cap, arg) != 0 {
                return 1;
            }
        } else {
            return 1;
        }
        i = i + 1;
    }
    if input_out[0] == 0 as byte {
        return upm_string_copy(input_out, input_cap, "." as &byte);
    }
    return 0;
}

fn upm_sync_dependencies(input_path: &byte, manifest_override: &byte, force_git_refresh: i32) i32 {
    var plan: UPMPackageBuildPlan = upm_build_plan_init();
    if upm_prepare_build_plan_ex(input_path, manifest_override, &plan, force_git_refresh) != 0 {
        return 1;
    }
    if plan.active == 0 {
        fprintf(libc.stderr, "错误: 未找到 uya.toml，请在包目录中运行或显式传入 --manifest-path\n" as *byte);
        return 1;
    }
    return upm_build_plan_cleanup(&plan);
}

fn upm_manifest_has_dependency_alias(manifest: &UPMManifest, alias: &byte) i32 {
    if manifest == null || alias == null {
        return 0;
    }
    var i: i32 = 0;
    while i < manifest.dep_count {
        if strcmp(&manifest.deps[i].alias[0] as *byte, alias as *byte) == 0 {
            return 1;
        }
        i = i + 1;
    }
    if manifest.dev_dep_count > 0 {
        i = 0;
        while i < manifest.dev_dep_count {
            if strcmp(&manifest.dev_deps[i].alias[0] as *byte, alias as *byte) == 0 {
                return 1;
            }
            i = i + 1;
        }
    }
    return 0;
}

fn upm_parse_add_args(start_index: i32, args_out: &UPMAddArgs) i32 {
    if args_out == null {
        return 1;
    }
    memset(args_out as *void, 0, @size_of(UPMAddArgs));
    args_out.input_path[0] = '.' as byte;
    args_out.input_path[1] = 0 as byte;
    args_out.dep = upm_dep_init("" as &byte);

    var saw_source: i32 = 0;
    var saw_ref: i32 = 0;
    var i: i32 = start_index;
    while i < get_argc() {
        const arg: &byte = get_argv(i);
        if arg == null {
            return 1;
        }
        if strcmp(arg as *byte, "--manifest-path" as *byte) == 0 {
            if i + 1 >= get_argc() {
                return 1;
            }
            i = i + 1;
            const value: &byte = get_argv(i);
            if value == null || upm_string_copy(&args_out.manifest_path[0] as &byte, UPM_PATH_MAX, value) != 0 {
                return 1;
            }
        } else if strcmp(arg as *byte, "--git" as *byte) == 0 {
            if saw_source != 0 || i + 1 >= get_argc() {
                return 1;
            }
            i = i + 1;
            const value: &byte = get_argv(i);
            if value == null || upm_string_copy(&args_out.dep.git_url[0] as &byte, UPM_PATH_MAX, value) != 0 {
                return 1;
            }
            args_out.dep.kind = UPMDependencyKind.UPM_DEP_GIT;
            saw_source = 1;
        } else if strcmp(arg as *byte, "--path" as *byte) == 0 {
            if saw_source != 0 || i + 1 >= get_argc() {
                return 1;
            }
            i = i + 1;
            const value: &byte = get_argv(i);
            if value == null || upm_string_copy(&args_out.dep.path_value[0] as &byte, UPM_PATH_MAX, value) != 0 {
                return 1;
            }
            args_out.dep.kind = UPMDependencyKind.UPM_DEP_PATH;
            saw_source = 1;
        } else if strcmp(arg as *byte, "--branch" as *byte) == 0 {
            if saw_ref != 0 || i + 1 >= get_argc() {
                return 1;
            }
            i = i + 1;
            const value: &byte = get_argv(i);
            if value == null || upm_string_copy(&args_out.dep.ref_value[0] as &byte, UPM_MAX_REF_LEN, value) != 0 {
                return 1;
            }
            args_out.dep.ref_kind = UPMGitRefKind.UPM_GIT_REF_BRANCH;
            saw_ref = 1;
        } else if strcmp(arg as *byte, "--tag" as *byte) == 0 {
            if saw_ref != 0 || i + 1 >= get_argc() {
                return 1;
            }
            i = i + 1;
            const value: &byte = get_argv(i);
            if value == null || upm_string_copy(&args_out.dep.ref_value[0] as &byte, UPM_MAX_REF_LEN, value) != 0 {
                return 1;
            }
            args_out.dep.ref_kind = UPMGitRefKind.UPM_GIT_REF_TAG;
            saw_ref = 1;
        } else if strcmp(arg as *byte, "--commit" as *byte) == 0 {
            if saw_ref != 0 || i + 1 >= get_argc() {
                return 1;
            }
            i = i + 1;
            const value: &byte = get_argv(i);
            if value == null || upm_string_copy(&args_out.dep.ref_value[0] as &byte, UPM_MAX_REF_LEN, value) != 0 {
                return 1;
            }
            args_out.dep.ref_kind = UPMGitRefKind.UPM_GIT_REF_COMMIT;
            saw_ref = 1;
        } else if strcmp(arg as *byte, "--dev" as *byte) == 0 {
            if args_out.dev_only != 0 {
                return 1;
            }
            args_out.dev_only = 1;
        } else if arg[0] == 45 as byte {
            return 1;
        } else if args_out.alias[0] == 0 as byte {
            if upm_string_copy(&args_out.alias[0] as &byte, UPM_MAX_ALIAS_LEN, arg) != 0 {
                return 1;
            }
            if upm_string_copy(&args_out.dep.alias[0] as &byte, UPM_MAX_ALIAS_LEN, arg) != 0 {
                return 1;
            }
        } else if strcmp(&args_out.input_path[0] as *byte, "." as *byte) == 0 {
            if upm_string_copy(&args_out.input_path[0] as &byte, UPM_PATH_MAX, arg) != 0 {
                return 1;
            }
        } else {
            return 1;
        }
        i = i + 1;
    }

    if args_out.alias[0] == 0 as byte {
        return 1;
    }
    if args_out.dep.kind == UPMDependencyKind.UPM_DEP_NONE {
        return 1;
    }
    if args_out.dep.kind == UPMDependencyKind.UPM_DEP_GIT {
        if args_out.dep.ref_kind == UPMGitRefKind.UPM_GIT_REF_NONE {
            return 1;
        }
    } else {
        if args_out.dep.ref_kind != UPMGitRefKind.UPM_GIT_REF_NONE {
            return 1;
        }
    }
    return 0;
}

fn upm_append_dependency_to_manifest(manifest_path: &byte, dep: &UPMDependency, dev_only: i32) i32 {
    if manifest_path == null || dep == null {
        return 1;
    }
    const in_file: &FILE = fopen(manifest_path as *byte, "r" as *byte);
    if in_file == null {
        return 1;
    }

    var out_path: [byte: UPM_PATH_MAX] = [];
    const out_written: i32 = snprintf(&out_path[0] as *byte, UPM_PATH_MAX, "%s.tmp" as *byte, manifest_path as *byte);
    if out_written <= 0 || out_written >= UPM_PATH_MAX {
        fclose(in_file);
        return 1;
    }
    const out_file: &FILE = fopen(&out_path[0] as *byte, "w" as *byte);
    if out_file == null {
        fclose(in_file);
        return 1;
    }

    var dep_line: [byte: UPM_LINE_MAX] = [];
    var dep_written: i32 = 0;
    if dep.kind == UPMDependencyKind.UPM_DEP_PATH {
        dep_written = snprintf(
            &dep_line[0] as *byte,
            UPM_LINE_MAX as usize,
            "%s = { path = \"%s\" }\n" as *byte,
            &dep.alias[0] as *byte,
            &dep.path_value[0] as *byte
        );
    } else {
        var ref_key: &byte = "branch" as &byte;
        if dep.ref_kind == UPMGitRefKind.UPM_GIT_REF_TAG {
            ref_key = "tag" as &byte;
        } else if dep.ref_kind == UPMGitRefKind.UPM_GIT_REF_COMMIT {
            ref_key = "commit" as &byte;
        }
        dep_written = snprintf(
            &dep_line[0] as *byte,
            UPM_LINE_MAX as usize,
            "%s = { git = \"%s\", %s = \"%s\" }\n" as *byte,
            &dep.alias[0] as *byte,
            &dep.git_url[0] as *byte,
            ref_key as *byte,
            &dep.ref_value[0] as *byte
        );
    }
    if dep_written <= 0 || dep_written >= UPM_LINE_MAX {
        fclose(in_file);
        fclose(out_file);
        return 1;
    }

    var target_section: &byte = "[dependencies]" as &byte;
    if dev_only != 0 {
        target_section = "[dev-dependencies]" as &byte;
    }

    var line_buf: [byte: UPM_LINE_MAX] = [];
    var trimmed: [byte: UPM_LINE_MAX] = [];
    var in_target_section: i32 = 0;
    var saw_target_section: i32 = 0;
    var inserted: i32 = 0;
    while fgets(&line_buf[0] as &byte, UPM_LINE_MAX, in_file) != null {
        if upm_trim_copy(&line_buf[0] as &byte, &trimmed[0] as &byte, UPM_LINE_MAX as usize) != 0 {
            fclose(in_file);
            fclose(out_file);
            return 1;
        }
        if strcmp(&trimmed[0] as *byte, target_section as *byte) == 0 {
            saw_target_section = 1;
            in_target_section = 1;
            fputs(&line_buf[0] as *byte, out_file as *void);
            continue;
        }
        if in_target_section != 0 && trimmed[0] == 91 as byte {
            fputs(&dep_line[0] as *byte, out_file as *void);
            inserted = 1;
            in_target_section = 0;
        }
        fputs(&line_buf[0] as *byte, out_file as *void);
    }
    if in_target_section != 0 && inserted == 0 {
        fputs(&dep_line[0] as *byte, out_file as *void);
        inserted = 1;
    }
    if saw_target_section == 0 {
        fprintf(out_file as *void, "\n%s\n" as *byte, target_section as *byte);
        fputs(&dep_line[0] as *byte, out_file as *void);
    }
    fclose(in_file);
    fclose(out_file);

    const final_in: &FILE = fopen(&out_path[0] as *byte, "r" as *byte);
    if final_in == null {
        return 1;
    }
    const final_out: &FILE = fopen(manifest_path as *byte, "w" as *byte);
    if final_out == null {
        fclose(final_in);
        return 1;
    }
    while fgets(&line_buf[0] as &byte, UPM_LINE_MAX, final_in) != null {
        fputs(&line_buf[0] as *byte, final_out as *void);
    }
    fclose(final_in);
    fclose(final_out);
    var rm_cmd: [byte: UPM_PATH_MAX * 2] = [];
    const rm_written: i32 = snprintf(&rm_cmd[0] as *byte, UPM_PATH_MAX * 2usize, "rm -f \"%s\"" as *byte, &out_path[0] as *byte);
    if rm_written > 0 && rm_written < UPM_PATH_MAX * 2 {
        _ = system(&rm_cmd[0] as *byte);
    }
    return 0;
}

fn upm_parse_remove_args(start_index: i32, args_out: &UPMRemoveArgs) i32 {
    if args_out == null {
        return 1;
    }
    memset(args_out as *void, 0, @size_of(UPMRemoveArgs));
    args_out.input_path[0] = '.' as byte;
    args_out.input_path[1] = 0 as byte;

    var i: i32 = start_index;
    while i < get_argc() {
        const arg: &byte = get_argv(i);
        if arg == null {
            return 1;
        }
        if strcmp(arg as *byte, "--manifest-path" as *byte) == 0 {
            if i + 1 >= get_argc() {
                return 1;
            }
            i = i + 1;
            const value: &byte = get_argv(i);
            if value == null || upm_string_copy(&args_out.manifest_path[0] as &byte, UPM_PATH_MAX, value) != 0 {
                return 1;
            }
        } else if strcmp(arg as *byte, "--dev" as *byte) == 0 {
            if args_out.dep_only != 0 || args_out.dev_only != 0 {
                return 1;
            }
            args_out.dev_only = 1;
        } else if strcmp(arg as *byte, "--dep" as *byte) == 0 {
            if args_out.dev_only != 0 || args_out.dep_only != 0 {
                return 1;
            }
            args_out.dep_only = 1;
        } else if arg[0] == 45 as byte {
            return 1;
        } else if args_out.alias[0] == 0 as byte {
            if upm_string_copy(&args_out.alias[0] as &byte, UPM_MAX_ALIAS_LEN, arg) != 0 {
                return 1;
            }
        } else if strcmp(&args_out.input_path[0] as *byte, "." as *byte) == 0 {
            if upm_string_copy(&args_out.input_path[0] as &byte, UPM_PATH_MAX, arg) != 0 {
                return 1;
            }
        } else {
            return 1;
        }
        i = i + 1;
    }
    if args_out.alias[0] == 0 as byte {
        return 1;
    }
    return 0;
}

fn upm_remove_dependency_line(line: &byte, alias: &byte) i32 {
    if line == null || alias == null {
        return 0;
    }
    var trimmed: [byte: UPM_LINE_MAX] = [];
    if upm_trim_copy(line, &trimmed[0] as &byte, UPM_LINE_MAX as usize) != 0 {
        return 0;
    }
    var prefix: [byte: UPM_MAX_ALIAS_LEN + 4] = [];
    const written: i32 = snprintf(&prefix[0] as *byte, (UPM_MAX_ALIAS_LEN + 4usize), "%s =" as *byte, alias as *byte);
    if written <= 0 || written >= (UPM_MAX_ALIAS_LEN + 4) {
        return 0;
    }
    if strncmp(&trimmed[0] as *byte, &prefix[0] as *byte, written as usize) == 0 {
        return 1;
    }
    return 0;
}

fn upm_remove_dependency_from_manifest(manifest_path: &byte, alias: &byte, target_mode: i32) i32 {
    if manifest_path == null || alias == null {
        return 1;
    }
    const in_file: &FILE = fopen(manifest_path as *byte, "r" as *byte);
    if in_file == null {
        return 1;
    }

    var out_path: [byte: UPM_PATH_MAX] = [];
    const out_written: i32 = snprintf(&out_path[0] as *byte, UPM_PATH_MAX, "%s.tmp" as *byte, manifest_path as *byte);
    if out_written <= 0 || out_written >= UPM_PATH_MAX {
        fclose(in_file);
        return 1;
    }
    const out_file: &FILE = fopen(&out_path[0] as *byte, "w" as *byte);
    if out_file == null {
        fclose(in_file);
        return 1;
    }

    var line_buf: [byte: UPM_LINE_MAX] = [];
    var trimmed: [byte: UPM_LINE_MAX] = [];
    var current_section: i32 = 0;
    var removed: i32 = 0;
    while fgets(&line_buf[0] as &byte, UPM_LINE_MAX, in_file) != null {
        if upm_trim_copy(&line_buf[0] as &byte, &trimmed[0] as &byte, UPM_LINE_MAX as usize) != 0 {
            fclose(in_file);
            fclose(out_file);
            return 1;
        }
        if strcmp(&trimmed[0] as *byte, "[dependencies]" as *byte) == 0 {
            current_section = 1;
            fputs(&line_buf[0] as *byte, out_file as *void);
            continue;
        }
        if strcmp(&trimmed[0] as *byte, "[dev-dependencies]" as *byte) == 0 {
            current_section = 2;
            fputs(&line_buf[0] as *byte, out_file as *void);
            continue;
        }
        if trimmed[0] == 91 as byte {
            current_section = 0;
        }
        var can_remove: i32 = 0;
        if target_mode == 0 {
            can_remove = current_section != 0;
        } else if target_mode == 1 {
            can_remove = current_section == 1;
        } else if target_mode == 2 {
            can_remove = current_section == 2;
        }
        if can_remove != 0 && upm_remove_dependency_line(&line_buf[0] as &byte, alias) != 0 {
            removed = 1;
            continue;
        }
        fputs(&line_buf[0] as *byte, out_file as *void);
    }
    fclose(in_file);
    fclose(out_file);

    if removed == 0 {
        var rm_tmp_cmd: [byte: UPM_PATH_MAX * 2] = [];
        const rm_tmp_written: i32 = snprintf(&rm_tmp_cmd[0] as *byte, UPM_PATH_MAX * 2usize, "rm -f \"%s\"" as *byte, &out_path[0] as *byte);
        if rm_tmp_written > 0 && rm_tmp_written < UPM_PATH_MAX * 2 {
            _ = system(&rm_tmp_cmd[0] as *byte);
        }
        return 1;
    }

    const final_in: &FILE = fopen(&out_path[0] as *byte, "r" as *byte);
    if final_in == null {
        return 1;
    }
    const final_out: &FILE = fopen(manifest_path as *byte, "w" as *byte);
    if final_out == null {
        fclose(final_in);
        return 1;
    }
    while fgets(&line_buf[0] as &byte, UPM_LINE_MAX, final_in) != null {
        fputs(&line_buf[0] as *byte, final_out as *void);
    }
    fclose(final_in);
    fclose(final_out);

    var rm_cmd: [byte: UPM_PATH_MAX * 2] = [];
    const rm_written: i32 = snprintf(&rm_cmd[0] as *byte, UPM_PATH_MAX * 2usize, "rm -f \"%s\"" as *byte, &out_path[0] as *byte);
    if rm_written > 0 && rm_written < UPM_PATH_MAX * 2 {
        _ = system(&rm_cmd[0] as *byte);
    }
    return 0;
}

fn upm_remove_dependency(start_index: i32) i32 {
    var args: UPMRemoveArgs = UPMRemoveArgs{};
    if upm_parse_remove_args(start_index, &args) != 0 {
        fprintf(libc.stderr, "错误: upm remove 参数无效\n" as *byte);
        return 1;
    }

    var manifest_override: &byte = null;
    if args.manifest_path[0] != 0 as byte {
        manifest_override = &args.manifest_path[0] as &byte;
    }
    var resolved_manifest: [byte: UPM_PATH_MAX] = [];
    if upm_resolve_manifest_path(&args.input_path[0] as &byte, manifest_override, &resolved_manifest[0] as &byte) != 0 {
        fprintf(libc.stderr, "错误: 未找到 uya.toml，请在包目录中运行或显式传入 --manifest-path\n" as *byte);
        return 1;
    }
    var target_mode: i32 = 0;
    if args.dep_only != 0 {
        target_mode = 1;
    } else if args.dev_only != 0 {
        target_mode = 2;
    }
    if upm_remove_dependency_from_manifest(&resolved_manifest[0] as &byte, &args.alias[0] as &byte, target_mode) != 0 {
        fprintf(libc.stderr, "错误: 未找到依赖 alias: %s\n" as *byte, &args.alias[0] as *byte);
        return 1;
    }
    return upm_sync_dependencies(&args.input_path[0] as &byte, manifest_override, 0);
}

fn upm_add_dependency(start_index: i32) i32 {
    var args: UPMAddArgs = UPMAddArgs{};
    if upm_parse_add_args(start_index, &args) != 0 {
        fprintf(libc.stderr, "错误: upm add 参数无效\n" as *byte);
        return 1;
    }

    var manifest_path: [byte: UPM_PATH_MAX] = [];
    var manifest_override: &byte = null;
    if args.manifest_path[0] != 0 as byte {
        manifest_override = &args.manifest_path[0] as &byte;
    }
    if upm_resolve_manifest_path(&args.input_path[0] as &byte, manifest_override, &manifest_path[0] as &byte) != 0 {
        fprintf(libc.stderr, "错误: 未找到 uya.toml，请在包目录中运行或显式传入 --manifest-path\n" as *byte);
        return 1;
    }

    var manifest: UPMManifest = upm_manifest_init();
    if upm_parse_manifest(&manifest_path[0] as &byte, &manifest) != 0 {
        return 1;
    }
    if upm_manifest_has_dependency_alias(&manifest, &args.alias[0] as &byte) != 0 {
        fprintf(libc.stderr, "错误: 依赖 alias 已存在: %s\n" as *byte, &args.alias[0] as *byte);
        return 1;
    }
    if upm_append_dependency_to_manifest(&manifest_path[0] as &byte, &args.dep, args.dev_only) != 0 {
        fprintf(libc.stderr, "错误: 写入 uya.toml 失败: %s\n" as *byte, &manifest_path[0] as *byte);
        return 1;
    }
    return upm_sync_dependencies(&args.input_path[0] as &byte, manifest_override, 0);
}

fn upm_compiler_path_from_argv0(argv0: &byte, out: &byte) i32 {
    if argv0 == null || out == null {
        return 1;
    }
    var cmd_dir: [byte: UPM_PATH_MAX] = [];
    if upm_path_dirname(argv0, &cmd_dir[0] as &byte, UPM_PATH_MAX) != 0 {
        return upm_string_copy(out, UPM_PATH_MAX, "./bin/uya" as &byte);
    }
    var bin_dir: [byte: UPM_PATH_MAX] = [];
    if upm_path_parent_dir(&cmd_dir[0] as &byte, &bin_dir[0] as &byte, UPM_PATH_MAX) != 0 {
        return upm_string_copy(out, UPM_PATH_MAX, "./bin/uya" as &byte);
    }
    return upm_join_path(&bin_dir[0] as &byte, "uya" as &byte, out, UPM_PATH_MAX);
}

fn upm_shell_append_quoted(cmd: &byte, cap: usize, len: &i32, token: &byte) i32 {
    if cmd == null || len == null || token == null {
        return 1;
    }
    var quoted: [byte: UPM_PATH_MAX * 2] = [];
    if upm_shell_quote(token, &quoted[0] as &byte, UPM_PATH_MAX * 2usize) != 0 {
        return 1;
    }
    const written: i32 = snprintf((cmd as *byte) + len[0], cap - len[0] as usize, " %s" as *byte, &quoted[0] as *byte);
    if written <= 0 || len[0] + written >= cap as i32 {
        return 1;
    }
    len[0] = len[0] + written;
    return 0;
}

fn upm_build_arg_value_mode(arg: &byte) UPMBuildArgValueMode {
    if arg == null {
        return UPMBuildArgValueMode.UPM_BUILD_ARG_VALUE_NONE;
    }
    if strcmp(arg as *byte, "-o" as *byte) == 0 ||
        strcmp(arg as *byte, "--manifest-path" as *byte) == 0 ||
        strcmp(arg as *byte, "--project-root" as *byte) == 0 ||
        strcmp(arg as *byte, "--app" as *byte) == 0 ||
        strcmp(arg as *byte, "--outlibc" as *byte) == 0 ||
        strcmp(arg as *byte, "--stack-size" as *byte) == 0 {
        return UPMBuildArgValueMode.UPM_BUILD_ARG_VALUE_REQUIRED;
    }
    if strcmp(arg as *byte, "--split-c-dir" as *byte) == 0 {
        return UPMBuildArgValueMode.UPM_BUILD_ARG_VALUE_OPTIONAL;
    }
    return UPMBuildArgValueMode.UPM_BUILD_ARG_VALUE_NONE;
}

fn upm_build_extract_input_and_manifest(start_index: i32, manifest_out: &byte, input_out: &byte, input_cap: usize) i32 {
    if manifest_out == null || input_out == null || input_cap == 0usize {
        return 1;
    }
    manifest_out[0] = 0 as byte;
    input_out[0] = 0 as byte;
    var i: i32 = start_index;
    while i < get_argc() {
        const arg: &byte = get_argv(i);
        if arg == null {
            return 1;
        }
        if strcmp(arg as *byte, "--manifest-path" as *byte) == 0 {
            if i + 1 >= get_argc() {
                return 1;
            }
            i = i + 1;
            const value: &byte = get_argv(i);
            if value == null || upm_string_copy(manifest_out, UPM_PATH_MAX, value) != 0 {
                return 1;
            }
        } else {
            const value_mode: UPMBuildArgValueMode = upm_build_arg_value_mode(arg);
            if value_mode == UPMBuildArgValueMode.UPM_BUILD_ARG_VALUE_REQUIRED {
                if i + 1 >= get_argc() {
                    return 1;
                }
                i = i + 1;
            } else if value_mode == UPMBuildArgValueMode.UPM_BUILD_ARG_VALUE_OPTIONAL {
                if i + 1 < get_argc() {
                    i = i + 1;
                }
            } else if arg[0] != 45 as byte && input_out[0] == 0 as byte {
                if upm_string_copy(input_out, input_cap, arg) != 0 {
                    return 1;
                }
            }
        }
        i = i + 1;
    }
    if input_out[0] == 0 as byte {
        return upm_string_copy(input_out, input_cap, "." as &byte);
    }
    return 0;
}

fn upm_forward_build(start_index: i32) i32 {
    var compiler_path: [byte: UPM_PATH_MAX] = [];
    const argv0: &byte = get_argv(0);
    if upm_compiler_path_from_argv0(argv0, &compiler_path[0] as &byte) != 0 {
        return 1;
    }

    var manifest_path: [byte: UPM_PATH_MAX] = [];
    var input_path: [byte: UPM_PATH_MAX] = [];
    if upm_build_extract_input_and_manifest(start_index, &manifest_path[0] as &byte, &input_path[0] as &byte, UPM_PATH_MAX) != 0 {
        fprintf(libc.stderr, "错误: upm build 参数无效\n" as *byte);
        return 1;
    }

    var manifest_override: &byte = null;
    if manifest_path[0] != 0 as byte {
        manifest_override = &manifest_path[0] as &byte;
    }
    var plan: UPMPackageBuildPlan = upm_build_plan_init();
    if upm_prepare_build_plan(&input_path[0] as &byte, manifest_override, &plan) != 0 {
        return 1;
    }

    var cmd: [byte: UPM_CMD_MAX] = [];
    var compiler_q: [byte: UPM_PATH_MAX * 2] = [];
    if upm_shell_quote(&compiler_path[0] as &byte, &compiler_q[0] as &byte, UPM_PATH_MAX * 2usize) != 0 {
        return 1;
    }
    var cmd_len: i32 = snprintf(&cmd[0] as *byte, UPM_CMD_MAX as usize, "%s build" as *byte, &compiler_q[0] as *byte);
    if cmd_len <= 0 || cmd_len >= UPM_CMD_MAX {
        return 1;
    }

    if plan.active != 0 {
        var arg_index: i32 = start_index;
        while arg_index < get_argc() {
            const arg: &byte = get_argv(arg_index);
            if arg == null {
                return 1;
            }
            if strcmp(arg as *byte, "--manifest-path" as *byte) == 0 ||
                strcmp(arg as *byte, "--project-root" as *byte) == 0 {
                arg_index = arg_index + 2;
                continue;
            }
            const value_mode: UPMBuildArgValueMode = upm_build_arg_value_mode(arg);
            if value_mode == UPMBuildArgValueMode.UPM_BUILD_ARG_VALUE_REQUIRED {
                if upm_shell_append_quoted(&cmd[0] as &byte, UPM_CMD_MAX as usize, &cmd_len, arg) != 0 {
                    return 1;
                }
                if arg_index + 1 >= get_argc() {
                    return 1;
                }
                const value: &byte = get_argv(arg_index + 1);
                if value == null || upm_shell_append_quoted(&cmd[0] as &byte, UPM_CMD_MAX as usize, &cmd_len, value) != 0 {
                    return 1;
                }
                arg_index = arg_index + 2;
                continue;
            }
            if value_mode == UPMBuildArgValueMode.UPM_BUILD_ARG_VALUE_OPTIONAL {
                if upm_shell_append_quoted(&cmd[0] as &byte, UPM_CMD_MAX as usize, &cmd_len, arg) != 0 {
                    return 1;
                }
                if arg_index + 1 < get_argc() {
                    const value: &byte = get_argv(arg_index + 1);
                    if value == null || upm_shell_append_quoted(&cmd[0] as &byte, UPM_CMD_MAX as usize, &cmd_len, value) != 0 {
                        return 1;
                    }
                    arg_index = arg_index + 2;
                } else {
                    arg_index = arg_index + 1;
                }
                continue;
            }
            if arg[0] != 45 as byte && strcmp(arg as *byte, &input_path[0] as *byte) == 0 {
                arg_index = arg_index + 1;
                continue;
            }
            if upm_shell_append_quoted(&cmd[0] as &byte, UPM_CMD_MAX as usize, &cmd_len, arg) != 0 {
                return 1;
            }
            arg_index = arg_index + 1;
        }
        if upm_shell_append_quoted(&cmd[0] as &byte, UPM_CMD_MAX as usize, &cmd_len, &plan.compile_input[0] as &byte) != 0 {
            return 1;
        }
        if upm_shell_append_quoted(&cmd[0] as &byte, UPM_CMD_MAX as usize, &cmd_len, "--project-root" as &byte) != 0 {
            return 1;
        }
        if upm_shell_append_quoted(&cmd[0] as &byte, UPM_CMD_MAX as usize, &cmd_len, &plan.module_root[0] as &byte) != 0 {
            return 1;
        }
    } else {
        var arg_index: i32 = start_index;
        if arg_index >= get_argc() || get_argv(arg_index) == null || get_argv(arg_index)[0] == 0 as byte ||
            get_argv(arg_index)[0] == 45 as byte {
            if upm_shell_append_quoted(&cmd[0] as &byte, UPM_CMD_MAX as usize, &cmd_len, "." as &byte) != 0 {
                return 1;
            }
        }
        while arg_index < get_argc() {
            const arg: &byte = get_argv(arg_index);
            if arg == null {
                return 1;
            }
            if upm_shell_append_quoted(&cmd[0] as &byte, UPM_CMD_MAX as usize, &cmd_len, arg) != 0 {
                return 1;
            }
            arg_index = arg_index + 1;
        }
    }
    const status: i32 = system(&cmd[0] as *byte);
    const exit_code: i32 = upm_exit_code_from_system_status(status);
    if plan.active != 0 {
        if upm_build_plan_cleanup(&plan) != 0 {
            return 1;
        }
    }
    return exit_code;
}

fn upm_resolve_manifest_for_diagnostics(input_path: &byte, manifest_path: &byte, out: &byte) i32 {
    var manifest_override: &byte = null;
    if manifest_path != null && manifest_path[0] != 0 as byte {
        manifest_override = manifest_path;
    }
    if upm_resolve_manifest_path(input_path, manifest_override, out) != 0 {
        fprintf(libc.stderr, "错误: 未找到 uya.toml，请在包目录中运行或显式传入 --manifest-path\n" as *byte);
        return 1;
    }
    return 0;
}

fn upm_diagnostics_graph_command(start_index: i32) i32 {
    var manifest_path: [byte: UPM_PATH_MAX] = [];
    var input_path: [byte: UPM_PATH_MAX] = [];
    if upm_parse_manifest_flag_and_input(start_index, &manifest_path[0] as &byte, &input_path[0] as &byte, UPM_PATH_MAX) != 0 {
        return 1;
    }
    var resolved_manifest: [byte: UPM_PATH_MAX] = [];
    if upm_resolve_manifest_for_diagnostics(&input_path[0] as &byte, &manifest_path[0] as &byte, &resolved_manifest[0] as &byte) != 0 {
        return 1;
    }
    return upm_diagnostics_print_graph(&resolved_manifest[0] as &byte);
}

fn upm_diagnostics_why_command(start_index: i32) i32 {
    if start_index >= get_argc() {
        fprintf(libc.stderr, "错误: upm why 需要依赖 alias\n" as *byte);
        return 1;
    }
    const alias: &byte = get_argv(start_index);
    if alias == null || alias[0] == 0 as byte || alias[0] == 45 as byte {
        fprintf(libc.stderr, "错误: upm why 需要依赖 alias\n" as *byte);
        return 1;
    }
    var manifest_path: [byte: UPM_PATH_MAX] = [];
    var input_path: [byte: UPM_PATH_MAX] = [];
    if upm_parse_manifest_flag_and_input(start_index + 1, &manifest_path[0] as &byte, &input_path[0] as &byte, UPM_PATH_MAX) != 0 {
        return 1;
    }
    var resolved_manifest: [byte: UPM_PATH_MAX] = [];
    if upm_resolve_manifest_for_diagnostics(&input_path[0] as &byte, &manifest_path[0] as &byte, &resolved_manifest[0] as &byte) != 0 {
        return 1;
    }
    return upm_diagnostics_print_why(&resolved_manifest[0] as &byte, alias);
}

fn upm_diagnostics_doctor_command(start_index: i32) i32 {
    var manifest_path: [byte: UPM_PATH_MAX] = [];
    var input_path: [byte: UPM_PATH_MAX] = [];
    if upm_parse_manifest_flag_and_input(start_index, &manifest_path[0] as &byte, &input_path[0] as &byte, UPM_PATH_MAX) != 0 {
        return 1;
    }
    var resolved_manifest: [byte: UPM_PATH_MAX] = [];
    if upm_resolve_manifest_for_diagnostics(&input_path[0] as &byte, &manifest_path[0] as &byte, &resolved_manifest[0] as &byte) != 0 {
        return 1;
    }
    return upm_diagnostics_doctor(&resolved_manifest[0] as &byte);
}

fn upm_diagnostics_vendor_command(start_index: i32) i32 {
    var manifest_path: [byte: UPM_PATH_MAX] = [];
    var input_path: [byte: UPM_PATH_MAX] = [];
    if upm_parse_manifest_flag_and_input(start_index, &manifest_path[0] as &byte, &input_path[0] as &byte, UPM_PATH_MAX) != 0 {
        return 1;
    }
    var manifest_override: &byte = null;
    if manifest_path[0] != 0 as byte {
        manifest_override = &manifest_path[0] as &byte;
    }
    return upm_diagnostics_vendor(&input_path[0] as &byte, manifest_override);
}

fn upm_diagnostics_cache_command(start_index: i32) i32 {
    if start_index >= get_argc() {
        fprintf(libc.stderr, "错误: upm cache 需要子命令\n" as *byte);
        return 1;
    }
    const subcmd: &byte = get_argv(start_index);
    if subcmd != null && strcmp(subcmd as *byte, "dir" as *byte) == 0 {
        return upm_diagnostics_print_cache_dir();
    }
    fprintf(libc.stderr, "错误: 未知 upm cache 子命令\n" as *byte);
    return 1;
}

fn upm_publish_command(start_index: i32) i32 {
    var manifest_path: [byte: UPM_PATH_MAX] = [];
    var input_path: [byte: UPM_PATH_MAX] = [];
    if upm_parse_manifest_flag_and_input(start_index, &manifest_path[0] as &byte, &input_path[0] as &byte, UPM_PATH_MAX) != 0 {
        return 1;
    }
    var resolved_manifest: [byte: UPM_PATH_MAX] = [];
    if upm_resolve_manifest_for_diagnostics(&input_path[0] as &byte, &manifest_path[0] as &byte, &resolved_manifest[0] as &byte) != 0 {
        return 1;
    }
    var plan: UPMPublishPlan = upm_publish_plan_init();
    if upm_publish_prepare_plan(&resolved_manifest[0] as &byte, &plan) != 0 {
        return 1;
    }
    var uya_dir: [byte: UPM_PATH_MAX] = [];
    if upm_join_path(&plan.package_root[0] as &byte, ".uya" as &byte, &uya_dir[0] as &byte, UPM_PATH_MAX) != 0 {
        return 1;
    }
    if upm_shell_mkdir_p(&uya_dir[0] as &byte) != 0 {
        return 1;
    }
    var receipt_path: [byte: UPM_PATH_MAX] = [];
    if upm_join_path(&uya_dir[0] as &byte, "publish.receipt" as &byte, &receipt_path[0] as &byte, UPM_PATH_MAX) != 0 {
        return 1;
    }
    if upm_publish_write_metadata(&plan, &receipt_path[0] as &byte) != 0 {
        return 1;
    }
    fprintf(libc.stdout, "publish metadata: %s\n" as *byte, &receipt_path[0] as *byte);
    return 0;
}

/// 处理 `upm` 子命令入口。
/// 参数说明：`start_index` 为子命令在 `argv` 中的起始位置。
/// 返回值说明：成功返回 `0`，失败返回非 `0`。
export fn upm_cli_main(start_index: i32) i32 {
    if get_argc() <= start_index {
        upm_print_usage();
        return 0;
    }
    const cmd: &byte = get_argv(start_index);
    if cmd == null {
        return 1;
    }
    if strcmp(cmd as *byte, "--help" as *byte) == 0 || strcmp(cmd as *byte, "-h" as *byte) == 0 {
        upm_print_usage();
        return 0;
    }
    if strcmp(cmd as *byte, "--version" as *byte) == 0 || strcmp(cmd as *byte, "-v" as *byte) == 0 {
        upm_print_version();
        return 0;
    }
    if strcmp(cmd as *byte, "init" as *byte) == 0 {
        var target_dir: [byte: UPM_PATH_MAX] = [];
        _ = upm_string_copy(&target_dir[0] as &byte, UPM_PATH_MAX, "." as &byte);
        var src_layout: i32 = 0;
        var i: i32 = start_index + 1;
        while i < get_argc() {
            const arg: &byte = get_argv(i);
            if arg == null {
                return 1;
            }
            if strcmp(arg as *byte, "--src-layout" as *byte) == 0 {
                src_layout = 1;
            } else if arg[0] == 45 as byte {
                fprintf(libc.stderr, "错误: upm init 不支持的参数: %s\n" as *byte, arg as *byte);
                return 1;
            } else if target_dir[0] == '.' as byte && target_dir[1] == 0 as byte {
                if upm_string_copy(&target_dir[0] as &byte, UPM_PATH_MAX, arg) != 0 {
                    return 1;
                }
            } else {
                fprintf(libc.stderr, "错误: upm init 不支持的参数: %s\n" as *byte, arg as *byte);
                return 1;
            }
            i = i + 1;
        }
        return upm_init_package(&target_dir[0] as &byte, src_layout);
    }
    if strcmp(cmd as *byte, "install" as *byte) == 0 || strcmp(cmd as *byte, "update" as *byte) == 0 {
        var manifest_path: [byte: UPM_PATH_MAX] = [];
        var input_path: [byte: UPM_PATH_MAX] = [];
        if upm_parse_manifest_flag_and_input(start_index + 1, &manifest_path[0] as &byte, &input_path[0] as &byte, UPM_PATH_MAX) != 0 {
            fprintf(libc.stderr, "错误: %s 参数无效\n" as *byte, cmd as *byte);
            return 1;
        }
        var manifest_override: &byte = null;
        if manifest_path[0] != 0 as byte {
            manifest_override = &manifest_path[0] as &byte;
        }
        var force_refresh: i32 = 0;
        if strcmp(cmd as *byte, "update" as *byte) == 0 {
            force_refresh = 1;
        }
        return upm_sync_dependencies(&input_path[0] as &byte, manifest_override, force_refresh);
    }
    if strcmp(cmd as *byte, "build" as *byte) == 0 {
        return upm_forward_build(start_index + 1);
    }
    if strcmp(cmd as *byte, "add" as *byte) == 0 {
        return upm_add_dependency(start_index + 1);
    }
    if strcmp(cmd as *byte, "remove" as *byte) == 0 {
        return upm_remove_dependency(start_index + 1);
    }
    if strcmp(cmd as *byte, "graph" as *byte) == 0 {
        return upm_diagnostics_graph_command(start_index + 1);
    }
    if strcmp(cmd as *byte, "why" as *byte) == 0 {
        return upm_diagnostics_why_command(start_index + 1);
    }
    if strcmp(cmd as *byte, "doctor" as *byte) == 0 {
        return upm_diagnostics_doctor_command(start_index + 1);
    }
    if strcmp(cmd as *byte, "cache" as *byte) == 0 {
        return upm_diagnostics_cache_command(start_index + 1);
    }
    if strcmp(cmd as *byte, "vendor" as *byte) == 0 {
        return upm_diagnostics_vendor_command(start_index + 1);
    }
    if strcmp(cmd as *byte, "publish" as *byte) == 0 {
        return upm_publish_command(start_index + 1);
    }
    fprintf(libc.stderr, "错误: 未知 upm 子命令: %s\n" as *byte, cmd as *byte);
    fprintf(libc.stderr, "提示: 运行 `upm --help` 查看可用命令\n" as *byte);
    return 1;
}
