// arena.uya - Arena 分配器
// v2.0: 支持按需增长
// - 初始使用静态缓冲区
// - 当缓冲区不足时，动态分配新 chunk
// - 编译结束时释放所有动态分配的内存

// 使用 libc 模块
use libc;

// Arena chunk 结构（用于动态增长的内存块）
struct ArenaChunk {
    buffer: &byte,       // 内存缓冲区
    size: usize,         // 缓冲区大小
    used: usize,         // 已使用大小
    next: &ArenaChunk,   // 下一个 chunk
}

// Arena 分配器结构体
// v2.0: 扩展支持动态增长
struct CompilerArena {
    buffer: &byte,           // 静态缓冲区指针
    size: usize,             // 静态缓冲区大小（字节）
    offset: usize,           // 当前分配位置（bump pointer）
    // 动态增长支持（新增字段）
    first_chunk: &ArenaChunk, // 第一个动态 chunk
    current_chunk: &ArenaChunk, // 当前活跃 chunk
    total_allocated: usize,   // 总分配量（统计用）
}

// 内存对齐边界（字节）
const ARENA_ALIGNMENT: usize = 8;

// 默认动态 chunk 大小（1MB）
const ARENA_CHUNK_SIZE: usize = 1024 * 1024;

// 对齐到指定边界
fn align_size(size: usize, align: usize) usize {
    return ((size + align - 1) / align) * align;
}

// 初始化 Arena 分配器
fn compiler_arena_init(arena: &CompilerArena, buffer: &byte, size: usize) void {
    if arena == null || buffer == null {
        return;
    }
    arena.buffer = buffer;
    arena.size = size;
    arena.offset = 0;
    arena.first_chunk = null;
    arena.current_chunk = null;
    arena.total_allocated = 0;
}

// 从 Arena 分配内存（支持动态增长）
fn compiler_arena_alloc(arena: &CompilerArena, size: usize) &byte {
    if arena == null {
        fprintf(libc.stderr, "错误: CompilerArena 分配失败（arena 为 null）\n" as *byte);
        exit(1);
    }
    
    const aligned_size: usize = align_size(size, ARENA_ALIGNMENT);
    
    // 1. 尝试从静态缓冲区分配
    if arena.buffer != null {
        const aligned_offset: usize = align_size(arena.offset, ARENA_ALIGNMENT);
        if aligned_offset + aligned_size <= arena.size {
            const result: &byte = &arena.buffer[aligned_offset];
            arena.offset = aligned_offset + aligned_size;
            arena.total_allocated = arena.total_allocated + aligned_size;
            return result;
        }
    }
    
    // 2. 尝试从当前动态 chunk 分配
    if arena.current_chunk != null {
        const chunk: &ArenaChunk = arena.current_chunk;
        const chunk_offset: usize = align_size(chunk.used, ARENA_ALIGNMENT);
        if chunk_offset + aligned_size <= chunk.size {
            const result: &byte = &chunk.buffer[chunk_offset];
            chunk.used = chunk_offset + aligned_size;
            arena.total_allocated = arena.total_allocated + aligned_size;
            return result;
        }
    }
    
    // 3. 分配新的动态 chunk
    var chunk_size: usize = ARENA_CHUNK_SIZE;
    if aligned_size > ARENA_CHUNK_SIZE {
        chunk_size = aligned_size;
    }
    
    // 分配 chunk 结构
    const chunk_mem: &byte = malloc(@size_of(ArenaChunk)) as &byte;
    if chunk_mem == null {
        fprintf(libc.stderr, "错误: CompilerArena 无法分配 chunk 结构\n" as *byte);
        exit(1);
    }
    const new_chunk: &ArenaChunk = chunk_mem as &ArenaChunk;
    
    // 分配 chunk 缓冲区
    const buffer_mem: &byte = malloc(chunk_size) as &byte;
    if buffer_mem == null {
        fprintf(libc.stderr, "错误: CompilerArena 无法分配 chunk 缓冲区 (%zu 字节)\n" as *byte, chunk_size);
        exit(1);
    }
    
    // 初始化 chunk
    new_chunk.buffer = buffer_mem;
    new_chunk.size = chunk_size;
    new_chunk.used = 0;
    new_chunk.next = null;
    
    // 链接到链表
    if arena.first_chunk == null {
        arena.first_chunk = new_chunk;
    } else {
        var last: &ArenaChunk = arena.first_chunk;
        while last.next != null {
            last = last.next;
        }
        last.next = new_chunk;
    }
    arena.current_chunk = new_chunk;
    
    // 从新 chunk 分配
    const result_offset: usize = align_size(new_chunk.used, ARENA_ALIGNMENT);
    const result: &byte = &new_chunk.buffer[result_offset];
    new_chunk.used = result_offset + aligned_size;
    arena.total_allocated = arena.total_allocated + aligned_size;
    
    return result;
}

// 重置 Arena（不释放内存，可复用）
fn compiler_arena_reset(arena: &CompilerArena) void {
    if arena == null {
        return;
    }
    arena.offset = 0;
    arena.total_allocated = 0;
    
    // 重置所有动态 chunk
    var chunk: &ArenaChunk = arena.first_chunk;
    while chunk != null {
        chunk.used = 0;
        chunk = chunk.next;
    }
    arena.current_chunk = arena.first_chunk;
}

// 释放 Arena 的所有动态内存
fn compiler_arena_free_all(arena: &CompilerArena) void {
    if arena == null {
        return;
    }
    
    var chunk: &ArenaChunk = arena.first_chunk;
    while chunk != null {
        const next: &ArenaChunk = chunk.next;
        if chunk.buffer != null {
            free(chunk.buffer as &void);
        }
        free(chunk as &void);
        chunk = next;
    }
    
    arena.first_chunk = null;
    arena.current_chunk = null;
    arena.buffer = null;
    arena.size = 0;
    arena.offset = 0;
}

// 保存 Arena 状态
fn compiler_arena_save(arena: &CompilerArena) usize {
    if arena == null {
        return 0;
    }
    return arena.offset;
}

// 恢复 Arena 状态
fn compiler_arena_restore(arena: &CompilerArena, offset: usize) void {
    if arena == null {
        return;
    }
    if offset <= arena.size {
        arena.offset = offset;
    }
}

// 获取总分配量
fn compiler_arena_total_allocated(arena: &CompilerArena) usize {
    if arena == null {
        return 0;
    }
    return arena.total_allocated;
}
