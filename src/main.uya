// main.uya - 编译器主程序
// Uya 自举编译器
// 架构：export fn main 编译为 main_main，由 std.runtime.entry 的 C main 调用
// 命令行参数通过 get_argc/get_argv 获取

// ===== 模块导入（按依赖顺序）=====
// use main：收集主文件所在目录下所有 .uya（arena, extern_decls, ast, lexer, parser, checker, str_utils）
// 否则单文件依赖收集不会自动包含同目录文件，生成的 C 会缺少 ASTNode/CompilerArena 等类型定义导致链接失败。
use main;
use parser;
use checker;  // 包含 checker 目录下所有文件（包括 optimizer.uya）
// C99 代码生成（子目录，整体导入该目录模块）
use codegen.c99;
use kernel.image;
use kernel.payload;
use std;
// C 程序入口由编译器自动注入 std.runtime.entry；此处仅导入堆栈上限设置（避免与局部名 entry 冲突）
use std.runtime.entry.set_process_stack_limit_bytes;
use libc;
use libc.stdlib;  // clock, CLOCKS_PER_SEC
use libc.unistd;  // system
use fmt;

// ===== 计时函数 =====
// 暂时禁用精确计时，使用简单计数器

// 编译统计结构体
struct CompileStats {
    parse_time_ms: i64,      // 解析阶段耗时（毫秒）
    merge_time_ms: i64,      // AST 合并耗时
    check_time_ms: i64,      // 类型检查耗时
    opt_time_ms: i64,        // 优化阶段耗时（v0.7.3 新增）
    codegen_time_ms: i64,    // 代码生成耗时
    total_time_ms: i64,      // 总耗时
    file_count: i32,         // 编译文件数
    ast_nodes: i32,          // AST 节点数（近似）
}

// 后端类型
enum BackendType {
    BACKEND_LLVM,
    BACKEND_C99
}

// 命令类型
enum CommandType {
    COMMAND_BUILD,   // uya build - 编译为可执行文件
    COMMAND_RUN,     // uya run - 编译并运行
    COMMAND_TEST,    // uya test - 编译测试并运行
    COMMAND_PACK_IMAGE, // uya pack-image - 将 .pobj 打包为 .uapp
    COMMAND_OUTLIBC,  // uya --outlibc - 生成独立 libc
    COMMAND_FMT       // uya fmt - 格式化代码
}

// 文件读取缓冲区大小（与 Lexer 一致）
const FILE_BUFFER_SIZE: i32 = 1024 * 1024;

// Arena 缓冲区大小（v2.0: 动态增长 Arena）
// 初始缓冲区 64MB，不足时自动分配新 chunk
const ARENA_BUFFER_SIZE: i32 = 64 * 1024 * 1024;  // 64MB 初始

// 最大输入文件数
const MAX_INPUT_FILES: i32 = 128;

// --split-c-dir / UYA_SPLIT_C_DIR：多文件 C 输出目录；非空时链接阶段走 make -j
// C99 且非「显式 -o xxx.c」时默认目录 .uyacache（与显式 --split-c-dir 省略路径一致）；UYA_SPLIT_C=0 或 --no-split-c 可关闭
var g_split_c_dir: [byte: PATH_MAX] = [];
var g_split_c_dir_active: i32 = 0;
// 命令行 --no-split-c：强制单文件 C，忽略默认多文件、UYA_SPLIT_C_DIR 与 --split-c-dir
var g_split_c_disabled_cli: i32 = 0;

// --async-frame-heap=on：async frame pool 满时回退到调试 heap
var g_async_frame_heap_fallback: i32 = 0;

// 微应用模式：在 app 基础上额外收紧限制
// 说明：当前默认行为就是 app；microapp 只是在此基础上启用更严格检查
var g_container_mode: i32 = 0;
// --app microapp: 微应用模式
var g_app_mode_microapp: i32 = 0;

fn split_c_set_default_dir() void {
    const def: &byte = ".uyacache" as &byte;
    const sl: usize = strlen(def);
    if sl > 0 && sl < PATH_MAX - 1 {
        strcpy(&g_split_c_dir[0] as *byte, def);
        g_split_c_dir[sl] = 0 as byte;
        g_split_c_dir_active = 1;
    }
}

fn is_pobj_output(path: &byte) i32 {
    if path == null {
        return 0;
    }
    const len: usize = strlen(path);
    if len < 5 {
        return 0;
    }
    if strcmp(path + (len - 5), ".pobj" as *byte) == 0 {
        return 1;
    }
    return 0;
}

fn is_uapp_output(path: &byte) i32 {
    if path == null {
        return 0;
    }
    const len: usize = strlen(path);
    if len < 5 {
        return 0;
    }
    if strcmp(path + (len - 5), ".uapp" as *byte) == 0 {
        return 1;
    }
    return 0;
}

const POBJ_MAGIC: u32 = 0x4A424F50;  // "POBJ"
const POBJ_HEADER_SIZE: u32 = 40;
const POBJ_VERSION: u16 = 5;
const POBJ_BUILD_MODE_MICROAPP: u32 = 1;
const MICROAPP_TARGET_ARCH_RV32_RAW: u32 = 1u32;
const MICROAPP_TARGET_ARCH_X86_64_RAW: u32 = 2u32;
const MICROAPP_TARGET_ARCH_AARCH64_RAW: u32 = 3u32;
const MICROAPP_TARGET_ARCH_XTENSA_RAW: u32 = 4u32;

fn read_u16_le_at(buf: &byte, off: usize) u16 {
    const b0: u16 = buf[off] as u16;
    const b1: u16 = buf[off + 1] as u16;
    return b0 | (b1 << 8);
}

fn read_u32_le_at(buf: &byte, off: usize) u32 {
    const b0: u32 = buf[off] as u32;
    const b1: u32 = buf[off + 1] as u32;
    const b2: u32 = buf[off + 2] as u32;
    const b3: u32 = buf[off + 3] as u32;
    return b0 | (b1 << 8) | (b2 << 16) | (b3 << 24);
}

fn write_u16_le_at(buf: &byte, off: usize, val: u16) void {
    buf[off] = (val & 255u16) as byte;
    buf[off + 1] = ((val >> 8) & 255u16) as byte;
}

fn write_u32_le_at(buf: &byte, off: usize, val: u32) void {
    buf[off] = (val & 255u32) as byte;
    buf[off + 1] = ((val >> 8) & 255u32) as byte;
    buf[off + 2] = ((val >> 16) & 255u32) as byte;
    buf[off + 3] = ((val >> 24) & 255u32) as byte;
}

fn hex_nibble(c: byte) i32 {
    if c >= 48 as byte && c <= 57 as byte {
        return (c - 48 as byte) as i32;
    }
    if c >= 97 as byte && c <= 102 as byte {
        return 10 + (c - 97 as byte) as i32;
    }
    if c >= 65 as byte && c <= 70 as byte {
        return 10 + (c - 65 as byte) as i32;
    }
    return -1;
}

fn w16_file(fp: &FILE, val: u16) void {
    const b0_tmp: !byte = (val & 255u16) as! byte;
    const b1_tmp: !byte = ((val >> 8) & 255u16) as! byte;
    var b0: byte = b0_tmp.value;
    var b1: byte = b1_tmp.value;
    _ = fwrite(&b0 as *void, 1 as usize, 1 as usize, fp);
    _ = fwrite(&b1 as *void, 1 as usize, 1 as usize, fp);
}

fn w32_file(fp: &FILE, val: u32) void {
    const b0_tmp: !byte = (val & 255u32) as! byte;
    const b1_tmp: !byte = ((val >> 8) & 255u32) as! byte;
    const b2_tmp: !byte = ((val >> 16) & 255u32) as! byte;
    const b3_tmp: !byte = ((val >> 24) & 255u32) as! byte;
    var b0: byte = b0_tmp.value;
    var b1: byte = b1_tmp.value;
    var b2: byte = b2_tmp.value;
    var b3: byte = b3_tmp.value;
    _ = fwrite(&b0 as *void, 1 as usize, 1 as usize, fp);
    _ = fwrite(&b1 as *void, 1 as usize, 1 as usize, fp);
    _ = fwrite(&b2 as *void, 1 as usize, 1 as usize, fp);
    _ = fwrite(&b3 as *void, 1 as usize, 1 as usize, fp);
}

fn resolve_microapp_target_arch_raw() u32 {
    var arch_name: &byte = get_env_or_default("MICROAPP_TARGET_ARCH" as *byte, "" as *byte);
    if arch_name == null || arch_name[0] == 0 as byte {
        arch_name = get_env_or_default("TARGET_ARCH" as *byte, "x86_64" as *byte);
    }
    if strcmp(arch_name, "rv32" as *byte) == 0 {
        return MICROAPP_TARGET_ARCH_RV32_RAW;
    }
    if strcmp(arch_name, "x86_64" as *byte) == 0 {
        return MICROAPP_TARGET_ARCH_X86_64_RAW;
    }
    if strcmp(arch_name, "aarch64" as *byte) == 0 || strcmp(arch_name, "arm64" as *byte) == 0 {
        return MICROAPP_TARGET_ARCH_AARCH64_RAW;
    }
    if strcmp(arch_name, "xtensa" as *byte) == 0 {
        return MICROAPP_TARGET_ARCH_XTENSA_RAW;
    }
    return MICROAPP_TARGET_ARCH_X86_64_RAW;
}

fn microapp_target_arch_name(target_arch_raw: u32) &byte {
    if target_arch_raw == MICROAPP_TARGET_ARCH_RV32_RAW {
        return "rv32" as &byte;
    }
    if target_arch_raw == MICROAPP_TARGET_ARCH_X86_64_RAW {
        return "x86_64" as &byte;
    }
    if target_arch_raw == MICROAPP_TARGET_ARCH_AARCH64_RAW {
        return "aarch64" as &byte;
    }
    if target_arch_raw == MICROAPP_TARGET_ARCH_XTENSA_RAW {
        return "xtensa" as &byte;
    }
    return "unknown" as &byte;
}

fn microapp_target_default_triple(target_arch_raw: u32) &byte {
    if target_arch_raw == MICROAPP_TARGET_ARCH_RV32_RAW {
        return "riscv32-unknown-elf" as &byte;
    }
    if target_arch_raw == MICROAPP_TARGET_ARCH_X86_64_RAW {
        return "x86_64-linux-gnu" as &byte;
    }
    if target_arch_raw == MICROAPP_TARGET_ARCH_AARCH64_RAW {
        return "aarch64-linux-gnu" as &byte;
    }
    if target_arch_raw == MICROAPP_TARGET_ARCH_XTENSA_RAW {
        return "xtensa-unknown-elf" as &byte;
    }
    return "x86_64-linux-gnu" as &byte;
}

fn microapp_target_default_gcc(target_arch_raw: u32) &byte {
    if target_arch_raw == MICROAPP_TARGET_ARCH_RV32_RAW {
        return "riscv32-unknown-elf-gcc" as &byte;
    }
    if target_arch_raw == MICROAPP_TARGET_ARCH_X86_64_RAW {
        return "x86_64-linux-gnu-gcc" as &byte;
    }
    if target_arch_raw == MICROAPP_TARGET_ARCH_AARCH64_RAW {
        return "aarch64-linux-gnu-gcc" as &byte;
    }
    if target_arch_raw == MICROAPP_TARGET_ARCH_XTENSA_RAW {
        return "xtensa-unknown-elf-gcc" as &byte;
    }
    return "x86_64-linux-gnu-gcc" as &byte;
}

fn resolve_microapp_target_gcc(target_arch_raw: u32, buffer: &byte, buffer_size: i32) &byte {
    const explicit_microapp_target_gcc: *byte = getenv("MICROAPP_TARGET_GCC" as *byte);
    if explicit_microapp_target_gcc != null && explicit_microapp_target_gcc[0] != 0 {
        return explicit_microapp_target_gcc as &byte;
    }
    const explicit_target_gcc: *byte = getenv("TARGET_GCC" as *byte);
    if explicit_target_gcc != null && explicit_target_gcc[0] != 0 {
        return explicit_target_gcc as &byte;
    }
    const fallback_gcc: &byte = microapp_target_default_gcc(target_arch_raw);
    const written: i32 = snprintf(buffer as *byte, buffer_size, "%s" as *byte, fallback_gcc);
    if written > 0 && written < buffer_size {
        return buffer;
    }
    return get_env_or_default("CC" as *byte, "cc" as *byte);
}

fn build_microapp_text_from_c(c_file: &byte, text_bin_path: &byte, rodata_bin_path: &byte, target_arch_raw: u32) i32 {
    var gcc_buf: [byte: PATH_MAX] = [];
    const gcc: &byte = resolve_microapp_target_gcc(target_arch_raw, &gcc_buf[0] as &byte, PATH_MAX);
    const target_triple: &byte = microapp_target_default_triple(target_arch_raw);
    var obj_path: [byte: PATH_MAX] = [];
    var exe_path: [byte: PATH_MAX] = [];
    var cmd: [byte: 8192] = [];
    const obj_len: i32 = snprintf(&obj_path[0] as *byte, PATH_MAX, "%s.obj" as *byte, text_bin_path as *byte);
    if obj_len <= 0 || obj_len >= PATH_MAX {
        fprintf(libc.stderr, "错误: 无法生成 microapp 中间目标文件路径\n" as *byte);
        return 1;
    }
    const exe_len: i32 = snprintf(&exe_path[0] as *byte, PATH_MAX, "%s.elf" as *byte, text_bin_path as *byte);
    if exe_len <= 0 || exe_len >= PATH_MAX {
        fprintf(libc.stderr, "错误: 无法生成 microapp 链接输出路径\n" as *byte);
        return 1;
    }

    const compile_flags: &byte = get_env_or_default("MICROAPP_TARGET_CFLAGS" as *byte, "-std=c99 -Os -fomit-frame-pointer -fno-builtin -fno-stack-protector -fno-pie -ffunction-sections -fdata-sections -flto" as *byte);
    const compile_len: i32 = snprintf(&cmd[0] as *byte, 8192, "%s %s -c %s -o %s" as *byte, gcc as *byte, compile_flags as *byte, c_file as *byte, &obj_path[0] as *byte);
    if compile_len <= 0 || compile_len >= 8192 {
        fprintf(libc.stderr, "错误: 无法生成 microapp 目标 gcc 编译命令\n" as *byte);
        return 1;
    }
    fprintf(libc.stderr, "信息：microapp 目标架构=%s, 默认三元组=%s\n" as *byte, microapp_target_arch_name(target_arch_raw), target_triple as *byte);
    fprintf(libc.stderr, "信息：microapp 目标 gcc 编译：%s\n" as *byte, &cmd[0] as *byte);
    var result: i32 = system(&cmd[0] as *byte);
    if result != 0 {
        fprintf(libc.stderr, "错误: microapp 目标 gcc 编译失败，返回码：%d\n" as *byte, result);
        return 1;
    }

    const link_flags: &byte = get_env_or_default("MICROAPP_TARGET_LDFLAGS" as *byte, "-no-pie -Wl,--gc-sections -flto" as *byte);
    const link_len: i32 = snprintf(&cmd[0] as *byte, 8192, "%s %s %s -o %s" as *byte, gcc as *byte, link_flags as *byte, &obj_path[0] as *byte, &exe_path[0] as *byte);
    if link_len <= 0 || link_len >= 8192 {
        fprintf(libc.stderr, "错误: 无法生成 microapp 目标 gcc 链接命令\n" as *byte);
        return 1;
    }
    fprintf(libc.stderr, "信息：microapp 目标 gcc 链接：%s\n" as *byte, &cmd[0] as *byte);
    result = system(&cmd[0] as *byte);
    if result != 0 {
        fprintf(libc.stderr, "错误: microapp 目标 gcc 链接失败，返回码：%d\n" as *byte, result);
        return 1;
    }

    const objcopy_env: &byte = get_env_or_default("OBJCOPY" as *byte, "objcopy" as *byte);
    const dump_len: i32 = snprintf(&cmd[0] as *byte, 8192, "%s -O binary --only-section=.text %s %s" as *byte, objcopy_env as *byte, &exe_path[0] as *byte, text_bin_path as *byte);
    if dump_len <= 0 || dump_len >= 8192 {
        fprintf(libc.stderr, "错误: 无法生成 microapp 代码段导出命令\n" as *byte);
        return 1;
    }
    fprintf(libc.stderr, "信息：microapp 目标 gcc 导出 .text：%s\n" as *byte, &cmd[0] as *byte);
    result = system(&cmd[0] as *byte);
    if result != 0 {
        fprintf(libc.stderr, "错误: microapp 目标 gcc .text 导出失败，返回码：%d\n" as *byte, result);
        return 1;
    }

    const rodata_len: i32 = snprintf(&cmd[0] as *byte, 8192, "%s -O binary --only-section=.rodata %s %s" as *byte, objcopy_env as *byte, &exe_path[0] as *byte, rodata_bin_path as *byte);
    if rodata_len <= 0 || rodata_len >= 8192 {
        fprintf(libc.stderr, "错误: 无法生成 microapp 只读段导出命令\n" as *byte);
        return 1;
    }
    fprintf(libc.stderr, "信息：microapp 目标 gcc 导出 .rodata：%s\n" as *byte, &cmd[0] as *byte);
    result = system(&cmd[0] as *byte);
    if result != 0 {
        fprintf(libc.stderr, "错误: microapp 目标 gcc .rodata 导出失败，返回码：%d\n" as *byte, result);
        return 1;
    }
    return 0;
}

fn write_microapp_payload_obj(
    output_path: &byte,
    source_path: &byte,
    c_file: &byte
) i32 {
    const source_len_tmp: !u32 = strlen(source_path as *byte) as! u32;
    const source_len: u32 = source_len_tmp.value;
    const target_arch_raw: u32 = resolve_microapp_target_arch_raw();
    var text_bin_path: [byte: PATH_MAX] = [];
    var rodata_bin_path: [byte: PATH_MAX] = [];
    const text_len_path: i32 = snprintf(&text_bin_path[0] as *byte, PATH_MAX, "%s.text.bin" as *byte, output_path as *byte);
    if text_len_path <= 0 || text_len_path >= PATH_MAX {
        fprintf(libc.stderr, "错误: 无法生成 microapp 代码段路径\n" as *byte);
        return 1;
    }
    const rodata_len_path: i32 = snprintf(&rodata_bin_path[0] as *byte, PATH_MAX, "%s.rodata.bin" as *byte, output_path as *byte);
    if rodata_len_path <= 0 || rodata_len_path >= PATH_MAX {
        fprintf(libc.stderr, "错误: 无法生成 microapp 只读段路径\n" as *byte);
        return 1;
    }
    if build_microapp_text_from_c(c_file, &text_bin_path[0] as &byte, &rodata_bin_path[0] as &byte, target_arch_raw) != 0 {
        return 1;
    }
    const code_len_raw: i32 = read_file_content(&text_bin_path[0] as &byte, &file_buffer[0], FILE_BUFFER_SIZE as usize);
    if code_len_raw < 0 {
        fprintf(libc.stderr, "错误: 无法读取 microapp 目标 gcc 代码段 '%s'\n" as *byte, &text_bin_path[0] as *byte);
        return 1;
    }
    const code_len_tmp: !u32 = code_len_raw as! u32;
    const code_len: u32 = code_len_tmp.value;
    const rodata_len_raw: i32 = read_file_content(&rodata_bin_path[0] as &byte, &microapp_rodata_buffer[0], FILE_BUFFER_SIZE as usize);
    if rodata_len_raw < 0 {
        fprintf(libc.stderr, "错误: 无法读取 microapp 目标 gcc 只读段 '%s'\n" as *byte, &rodata_bin_path[0] as *byte);
        return 1;
    }
    const rodata_len_tmp: !u32 = rodata_len_raw as! u32;
    const rodata_len: u32 = rodata_len_tmp.value;
    const fp: &FILE = fopen(output_path as *byte, "wb" as *byte);
    if fp == null {
        fprintf(libc.stderr, "错误: 无法打开输出文件 '%s'\n" as *byte, output_path as *byte);
        return 1;
    }

    const magic: u32 = 0x4A424F50;  // "POBJ"
    const version: u16 = POBJ_VERSION;
    const flags: u16 = 0;
    const reloc_count: u32 = 0u32;
    const required_caps: u32 = 0u32;
    const entry_offset: u32 = 0u32;
    const build_mode_raw: u32 = POBJ_BUILD_MODE_MICROAPP;

    _ = fwrite(&magic as *void, 1 as usize, 4 as usize, fp);
    w16_file(fp, version);
    w16_file(fp, flags);
    w32_file(fp, target_arch_raw);
    w32_file(fp, build_mode_raw);
    w32_file(fp, required_caps);
    w32_file(fp, entry_offset);
    w32_file(fp, source_len);
    w32_file(fp, code_len);
    w32_file(fp, rodata_len);
    w32_file(fp, reloc_count);
    _ = fwrite(source_path as *void, 1 as usize, source_len as usize, fp);
    _ = fwrite(&file_buffer[0] as *void, 1 as usize, code_len as usize, fp);
    _ = fwrite(&microapp_rodata_buffer[0] as *void, 1 as usize, rodata_len as usize, fp);
    fclose(fp);
    return 0;
}

fn pack_microapp_pobj_to_uapp(pobj_path: &byte, out_path: &byte) i32 {
    const pobj_len: i32 = read_file_content(pobj_path, &file_buffer[0], FILE_BUFFER_SIZE as usize);
    if pobj_len < 0 {
        fprintf(libc.stderr, "错误: 无法读取 microapp payload 对象 '%s'\n" as *byte, pobj_path as *byte);
        return 1;
    }
    if pobj_len < POBJ_HEADER_SIZE as i32 {
        fprintf(libc.stderr, "错误: microapp payload 对象太小: %s\n" as *byte, pobj_path as *byte);
        return 1;
    }
    const magic: u32 = read_u32_le_at(&file_buffer[0] as &byte, 0usize);
    if magic != POBJ_MAGIC {
        fprintf(libc.stderr, "错误: 不是有效的 .pobj 文件: %s\n" as *byte, pobj_path as *byte);
        return 1;
    }
    const version: u16 = read_u16_le_at(&file_buffer[0] as &byte, 4usize);
    if version != POBJ_VERSION {
        fprintf(libc.stderr, "错误: 不支持的 .pobj 版本 %u\n" as *byte, version as u32);
        return 1;
    }

    const file_ptr: &byte = &file_buffer[0] as &byte;

    const target_arch_raw: u32 = read_u32_le_at(file_ptr, 8usize);
    const build_mode_raw: u32 = read_u32_le_at(file_ptr, 12usize);
    const required_caps: u32 = read_u32_le_at(file_ptr, 16usize);
    const entry_offset: u32 = read_u32_le_at(file_ptr, 20usize);
    const source_path_len: u32 = read_u32_le_at(file_ptr, 24usize);
    const code_len: u32 = read_u32_le_at(file_ptr, 28usize);
    const rodata_len: u32 = read_u32_le_at(file_ptr, 32usize);
    const reloc_count: u32 = read_u32_le_at(file_ptr, 36usize);

    if build_mode_raw != POBJ_BUILD_MODE_MICROAPP {
        fprintf(libc.stderr, "错误: 仅支持 microapp payload_obj\n" as *byte);
        return 1;
    }
    if code_len == 0 {
        fprintf(libc.stderr, "错误: payload_obj 缺少 code 段\n" as *byte);
        return 1;
    }

    const source_path_off: usize = POBJ_HEADER_SIZE as usize;
    const code_off: usize = source_path_off + source_path_len as usize;
    const rodata_off: usize = code_off + code_len as usize;
    if rodata_off + rodata_len as usize > pobj_len as usize {
        fprintf(libc.stderr, "错误: .pobj 内容长度不一致\n" as *byte);
        return 1;
    }

    if target_arch_raw < MICROAPP_TARGET_ARCH_RV32_RAW || target_arch_raw > MICROAPP_TARGET_ARCH_XTENSA_RAW {
        fprintf(libc.stderr, "错误: 当前 packer 不支持未知目标架构\n" as *byte);
        return 1;
    }
    if source_path_off + source_path_len as usize > pobj_len as usize {
        fprintf(libc.stderr, "错误: .pobj 源路径长度不一致\n" as *byte);
        return 1;
    }
    const source_path_ptr: &byte = &file_buffer[source_path_off] as &byte;
    const code_ptr: &byte = &file_buffer[code_off] as &byte;
    const rodata_ptr: &byte = &file_buffer[rodata_off] as &byte;
    const source_path_bytes: &[byte] = source_path_ptr[0: source_path_len as usize];
    const code_bytes: &[byte] = code_ptr[0: code_len as usize];
    const rodata_bytes: &[byte] = rodata_ptr[0: rodata_len as usize];
    const payload: PayloadObj = PayloadObj{
        target_arch: image_target_arch_from_byte(target_arch_raw as byte),
        build_mode: BUILD_MODE_CONTAINER,
        required_caps: required_caps,
        entry_offset: entry_offset,
        code: code_bytes,
        rodata: rodata_bytes,
        reloc_count: reloc_count,
    };
    _ = source_path_bytes;
    const out_ptr: &byte = &microapp_pack_output_buffer[0] as &byte;
    const out_bytes: &[byte] = out_ptr[0: @len(microapp_pack_output_buffer)];
    const image_len: u32 = payload_pack_to_uapp(
        &payload,
        out_bytes
    ) catch {
        fprintf(libc.stderr, "错误: payload_pack_to_uapp 失败\n" as *byte);
        return 1;
    };

    const image_bytes: &[byte] = out_ptr[0: image_len as usize];
    const validated_header: ImageHeader = image_validate(image_bytes) catch {
        fprintf(libc.stderr, "错误: 生成的 .uapp 未通过自验证\n" as *byte);
        return 1;
    };
    _ = validated_header;

    const fp: &FILE = fopen(out_path as *byte, "wb" as *byte);
    if fp == null {
        fprintf(libc.stderr, "错误: 无法打开输出文件 '%s'\n" as *byte, out_path as *byte);
        return 1;
    }
    _ = fwrite(&microapp_pack_output_buffer[0] as *void, 1 as usize, image_len as usize, fp);
    fclose(fp);
    return 0;
}

// 全局缓冲区（替代 C 的 static 数组，零初始化）
var arena_buffer: [byte: ARENA_BUFFER_SIZE] = [];
var file_buffer: [byte: FILE_BUFFER_SIZE] = [];
var microapp_rodata_buffer: [byte: FILE_BUFFER_SIZE] = [];
var microapp_pack_output_buffer: [byte: FILE_BUFFER_SIZE + 512] = [];
// 临时 Arena 缓冲区（用于依赖收集，全局变量避免栈溢出）
// v2.0: 动态增长，初始 16MB
var temp_arena_buffer: [byte: 16 * 1024 * 1024] = [];
// 大数组移到全局变量避免栈溢出（main_file_paths 是 64 * 4096 = 262KB）
var main_file_paths_global: [[byte: PATH_MAX]: MAX_INPUT_FILES] = [];
// 将 resolved_files 也移到全局变量，避免栈溢出
var resolved_files_global: [&byte: MAX_INPUT_FILES] = [];

// 读取文件内容到缓冲区
// 成功返回读取字节数，失败返回 -1
// 注意：filename 用 &byte，调用 fopen 时转为 *byte
fn read_file_content(filename: &byte, buffer: &byte, buffer_size: usize) i32 {
    const file: &FILE = fopen(filename as *byte, "rb" as *byte);
    if file == null {
        return -1;
    }
    const bytes_read: usize = fread(buffer as *byte, 1, buffer_size - 1, file);
    const c: i32 = fgetc(file);
    if bytes_read >= buffer_size - 1 {
        fclose(file);
        if c != -1 {
            return -1;
        }
    } else {
        fclose(file);
    }
    buffer[bytes_read] = 0 as byte;
    return bytes_read as i32;
}

// system(3) 返回值为 wait 状态字；转为与 shell 类似的退出码（段错误等为 128+信号，便于压测与 if 判断）
fn exit_code_from_system_status(wstatus: i32) i32 {
    if wstatus < 0 {
        return 1;
    }
    const low: i32 = wstatus & 0x7f;
    const code: i32 = (wstatus >> 8) & 0xff;
    if low == 0 {
        return code;
    }
    const sig: i32 = low & 0x7f;
    if sig == 0 {
        return 1;
    }
    return 128 + sig;
}

// 常量定义
const PATH_MAX: usize = 4096;

// 比较两个路径是否指向同一个文件（考虑路径格式差异）
// 参数：path1 - 第一个路径
//       path2 - 第二个路径
// 返回：相同返回1，不同返回0
fn paths_equal(path1: &byte, path2: &byte) i32 {
    if path1 == null || path2 == null {
        return 0;
    }
    
    // 首先尝试直接比较（最常见的情况）
    if strcmp(path1 as *byte, path2 as *byte) == 0 {
        return 1;
    }
    
    // 如果直接比较失败，提取文件名进行比较
    // 如果文件名相同，使用 stat 检查是否是同一个文件（相同的 inode）
    var name1: &byte = strrchr(path1 as *byte, 47);  // '/'
    var name2: &byte = strrchr(path2 as *byte, 47);  // '/'
    if name1 == null {
        name1 = path1;
    } else {
        name1 = name1 + 1;
    }
    if name2 == null {
        name2 = path2;
    } else {
        name2 = name2 + 1;
    }
    
    // 如果文件名不同，肯定不是同一个文件
    if strcmp(name1 as *byte, name2 as *byte) != 0 {
        return 0;
    }
    
    // 文件名相同，使用 stat 检查是否是同一个文件
    var st1: Stat = Stat { st_dev: 0, st_ino: 0, st_nlink: 0, st_mode: 0, st_uid: 0, st_gid: 0, _pad0: 0, st_rdev: 0, st_size: 0, st_blksize: 0, st_blocks: 0, st_atime: 0, st_atime_nsec: 0, st_mtime: 0, st_mtime_nsec: 0, st_ctime: 0, st_ctime_nsec: 0, _unused0: 0, _unused1: 0, _unused2: 0 };
    var st2: Stat = Stat { st_dev: 0, st_ino: 0, st_nlink: 0, st_mode: 0, st_uid: 0, st_gid: 0, _pad0: 0, st_rdev: 0, st_size: 0, st_blksize: 0, st_blocks: 0, st_atime: 0, st_atime_nsec: 0, st_mtime: 0, st_mtime_nsec: 0, st_ctime: 0, st_ctime_nsec: 0, _unused0: 0, _unused1: 0, _unused2: 0 };
    if stat(path1 as *byte, &st1) == 0 && stat(path2 as *byte, &st2) == 0 {
        // 检查是否是同一个文件（相同的设备和 inode）
        if st1.st_dev == st2.st_dev && st1.st_ino == st2.st_ino {
            return 1;
        }
    }
    
    // stat 失败或不是同一个文件，返回0
    return 0;
}

// 注意：arena_strdup 函数在 parser.uya 中定义，这里不再重复定义

// 检查路径是否为目录
fn is_directory(path: &byte) i32 {
    if path == null {
        return 0;
    }
    var st: Stat = Stat { st_dev: 0, st_ino: 0, st_nlink: 0, st_mode: 0, st_uid: 0, st_gid: 0, _pad0: 0, st_rdev: 0, st_size: 0, st_blksize: 0, st_blocks: 0, st_atime: 0, st_atime_nsec: 0, st_mtime: 0, st_mtime_nsec: 0, st_ctime: 0, st_ctime_nsec: 0, _unused0: 0, _unused1: 0, _unused2: 0 };
    if stat(path as *byte, &st) == 0 {
        if ((st.st_mode as u32) & S_IFMT) == S_IFDIR {
            return 1;
        }
    }
    return 0;
}

// 检查路径是否为文件
fn is_file(path: &byte) i32 {
    if path == null {
        return 0;
    }
    var st: Stat = Stat { st_dev: 0, st_ino: 0, st_nlink: 0, st_mode: 0, st_uid: 0, st_gid: 0, _pad0: 0, st_rdev: 0, st_size: 0, st_blksize: 0, st_blocks: 0, st_atime: 0, st_atime_nsec: 0, st_mtime: 0, st_mtime_nsec: 0, st_ctime: 0, st_ctime_nsec: 0, _unused0: 0, _unused1: 0, _unused2: 0 };
    if stat(path as *byte, &st) == 0 {
        if ((st.st_mode as u32) & S_IFMT) == S_IFREG {
            return 1;
        }
    }
    return 0;
}

// 仅 Darwin 宿主进 AST；Linux 自举时整段裁剪，不链接 _NSGetExecutablePath
std.cfg(std.host_os == .hos_macos, {
extern fn _NSGetExecutablePath(buf: *byte, bufsize: *u32) i32;
extern fn realpath(path: *byte, resolved_path: *byte) *byte;
fn main_darwin_get_compiler_dir(buffer: &byte, buffer_size: usize) i32 {
    if buffer == null || buffer_size < 3 {
        return -1;
    }
    var raw: [byte: PATH_MAX] = [];
    var sz: u32 = (PATH_MAX - 1) as u32;
    if _NSGetExecutablePath(&raw[0] as *byte, &sz) != 0 {
        return -1;
    }
    raw[(PATH_MAX - 1) as usize] = 0 as byte;
    var full: [byte: PATH_MAX] = [];
    const rp: *byte = realpath(&raw[0] as *byte, &full[0] as *byte);
    if rp == null {
        return -1;
    }
    const last_slash: *byte = strrchr(&full[0] as *byte, 47);
    if last_slash == null {
        return -1;
    }
    const dir_len: usize = ptr_diff(last_slash, &full[0] as *byte);
    if dir_len + 1 >= buffer_size {
        return -1;
    }
    memcpy(buffer as *void, &full[0] as *void, dir_len);
    buffer[dir_len] = 47 as byte;
    buffer[dir_len + 1] = 0 as byte;
    return 0;
}
}, {})

// 获取编译器程序所在目录
fn get_compiler_dir(argv0: &byte, buffer: &byte, buffer_size: usize) i32 {
    if argv0 == null || buffer == null || buffer_size == 0 {
        return -1;
    }
    
    // 如果是绝对路径，直接提取目录
    if argv0[0] == 47 {
        const last_slash: *byte = strrchr(argv0 as *byte, 47);
        if last_slash != null {
            const dir_len: usize = ptr_diff(last_slash, argv0);
            if dir_len + 1 < buffer_size {
                memcpy(buffer as *void, argv0 as *void, dir_len);
                buffer[dir_len] = 47 as byte;
                buffer[dir_len + 1] = 0 as byte;
                return 0;
            }
        }
    }
    
    std.cfg(std.host_os == .hos_linux, {
        var resolved_path: [byte: PATH_MAX] = [];
        const len: i32 = readlink("/proc/self/exe" as *byte, &resolved_path[0], PATH_MAX - 1);
        if len != -1 {
            resolved_path[len as usize] = 0 as byte;
            const last_slash: *byte = strrchr(&resolved_path[0], 47);
            if last_slash != null {
                const dir_len: usize = ptr_diff(last_slash, &resolved_path[0] as *byte);
                if dir_len + 1 < buffer_size {
                    memcpy(buffer as *void, &resolved_path[0] as *void, dir_len);
                    buffer[dir_len] = 47 as byte;
                    buffer[dir_len + 1] = 0 as byte;
                    return 0;
                }
            }
        }
    }, std.cfg(std.host_os == .hos_macos, {
        if main_darwin_get_compiler_dir(buffer, buffer_size) == 0 {
            return 0;
        }
    }, {}))

    // 回退：使用当前目录
    if buffer_size > 1 {
        buffer[0] = 46 as byte;  // '.'
        buffer[1] = 47 as byte;   // '/'
        buffer[2] = 0 as byte;
        return 0;
    }
    
    return -1;
}

// 从「含末尾 / 的绝对或相对目录路径」得到父目录，写入 dst（带尾 /）。用于 bin/ → 源码树根。
fn path_get_parent_dir(src: &byte, dst: &byte, dst_cap: usize) i32 {
    if src == null || dst == null || dst_cap < 4 {
        return -1;
    }
    var work: [byte: PATH_MAX] = [];
    const sl: usize = strlen(src as *byte);
    if sl >= PATH_MAX {
        return -1;
    }
    memcpy(&work[0] as *void, src as *void, sl + 1 as usize);
    var len: usize = sl;
    while len > 0 && work[len - 1] == 47 as byte {
        len = len - 1;
        work[len] = 0 as byte;
    }
    if len == 0 {
        return -1;
    }
    var last: *byte = strrchr(&work[0] as *byte, 47);
    if last == null {
        if strcmp(&work[0] as *byte, "." as *byte) == 0 {
            strcpy(dst as *byte, "../" as *byte);
            return 0;
        }
        return -1;
    }
    if last == &work[0] as *byte {
        dst[0] = 47 as byte;
        dst[1] = 0 as byte;
        return 0;
    }
    last[0] = 0 as byte;
    const plen: usize = strlen(&work[0] as *byte);
    if plen + 2 >= dst_cap {
        return -1;
    }
    memcpy(dst as *void, &work[0] as *void, plen);
    dst[plen] = 47 as byte;
    dst[plen + 1] = 0 as byte;
    return 0;
}

// 获取 UYA_ROOT 环境变量或默认目录
fn get_uya_root(argv0: &byte, buffer: &byte, buffer_size: usize) i32 {
    if buffer == null || buffer_size == 0 {
        return -1;
    }
    
    // 首先尝试从环境变量获取
    const env_root: *byte = getenv("UYA_ROOT" as *byte);
    if env_root != null && env_root[0] != 0 {
        const len: usize = strlen(env_root);
        if len < buffer_size {
            strcpy(buffer as *byte, env_root);
            // 确保以 '/' 结尾
            if len > 0 && buffer[len - 1] != 47 {
                if len + 1 < buffer_size {
                    buffer[len] = 47 as byte;
                    buffer[len + 1] = 0 as byte;
                }
            }
            return 0;
        }
    }
    
    // 未设置 UYA_ROOT：默认可执行文件所在目录的上一级（如 …/bin/uya → …/…/lib/）
    var comp_dir: [byte: PATH_MAX] = [];
    if get_compiler_dir(argv0, &comp_dir[0] as &byte, PATH_MAX) != 0 {
        return -1;
    }
    return path_get_parent_dir(&comp_dir[0] as &byte, buffer, buffer_size);
}

// 打印使用说明（program_name 用 &byte，传给 fprintf 时转为 *byte；若为 null 则用默认名避免 %s 段错误）
fn print_usage(program_name: &byte) void {
    var name: &byte = program_name;
    if name == null { name = "uya" as *byte; }
    fprintf(libc.stderr, "Uya 编译器 - 零GC系统编程语言\n" as *byte);
    fprintf(libc.stderr, "版本：v0.9.3\n" as *byte);
    fprintf(libc.stderr, "\n用法:\n" as *byte);
    fprintf(libc.stderr, "  %s build <文件> [-o <输出>] [选项]  编译为可执行文件或中间产物\n" as *byte, name as *byte);
    fprintf(libc.stderr, "  %s build --app microapp <文件> -o <xxx.pobj|xxx.uapp>  输出 microapp 载荷对象或镜像\n" as *byte, name as *byte);
    fprintf(libc.stderr, "  %s pack-image <xxx.pobj> -o <xxx.uapp>  将 microapp 载荷对象打包为 .uapp\n" as *byte, name as *byte);
    fprintf(libc.stderr, "  %s run <文件> [选项] [-- <参数>...]  编译并运行\n" as *byte, name as *byte);
    fprintf(libc.stderr, "  %s test <文件> [选项]               编译测试并运行（子进程栈：--stack-size 或默认 65536 KB）\n" as *byte, name as *byte);
    fprintf(libc.stderr, "  %s --outlibc <目录>                 生成独立 libc\n" as *byte, name as *byte);
    fprintf(libc.stderr, "\n示例:\n" as *byte);
    fprintf(libc.stderr, "  %s build main.uya -o myapp\n" as *byte, name as *byte);
    fprintf(libc.stderr, "  %s pack-image hello.pobj -o hello.uapp\n" as *byte, name as *byte);
    fprintf(libc.stderr, "  %s run main.uya\n" as *byte, name as *byte);
    fprintf(libc.stderr, "  %s test tests.uya\n" as *byte, name as *byte);
    fprintf(libc.stderr, "  %s build main.uya -o main.c --c99   # 生成 C99 代码\n" as *byte, name as *byte);
    fprintf(libc.stderr, "  %s build --app microapp main.uya -o microapp.uapp  # 微应用模式\n" as *byte, name as *byte);
    fprintf(libc.stderr, "  MICROAPP_TARGET_ARCH=x86_64 %s build --app microapp main.uya -o microapp.uapp\n" as *byte, name as *byte);
    fprintf(libc.stderr, "\n选项:\n" as *byte);
    fprintf(libc.stderr, "  --c99                使用 C99 后端生成 C 代码\n" as *byte);
    fprintf(libc.stderr, "  --app <app|microapp>  选择应用类型；app 为默认行为，microapp 会启用更严格检查\n" as *byte);
    fprintf(libc.stderr, "  --line-directives    启用 #line 指令生成（C99 后端）\n" as *byte);
    fprintf(libc.stderr, "  --no-line-directives 禁用 #line 指令生成\n" as *byte);
    fprintf(libc.stderr, "  --opt=<0-3>          优化级别（0=禁用, 1=默认, 2=+证明优化, 3=+内联）\n" as *byte);
    fprintf(libc.stderr, "  -O0, -O1, -O2, -O3   优化级别（简写形式）\n" as *byte);
    fprintf(libc.stderr, "  --safety-proof       启用内存安全证明（默认已启用；自举脚本对编译器源码会传 --no-safety-proof）\n" as *byte);
    fprintf(libc.stderr, "  --no-safety-proof    禁用内存安全证明\n" as *byte);
    fprintf(libc.stderr, "  --nostdlib           完全独立模式：无标准库依赖，使用 syscall\n" as *byte);
    fprintf(libc.stderr, "  --async-frame-heap=on  async frame pool 满时回退到调试 heap（默认关闭）\n" as *byte);
    fprintf(libc.stderr, "  MICROAPP_TARGET_CFLAGS  microapp 目标 gcc 编译旗标；默认 -std=c99 -Os -fomit-frame-pointer -fno-builtin -fno-stack-protector -fno-pie -ffunction-sections -fdata-sections -flto（不含 -g）\n" as *byte);
    fprintf(libc.stderr, "  MICROAPP_TARGET_LDFLAGS microapp 目标 gcc 链接旗标；默认 -no-pie -Wl,--gc-sections -flto\n" as *byte);
    fprintf(libc.stderr, "  -o <文件>            指定输出文件名\n" as *byte);
    fprintf(libc.stderr, "  --stack-size <KB>    设置堆栈大小（KB），默认 65536 (64MB)\n" as *byte);
    fprintf(libc.stderr, "  --split-c-dir [<dir>]  多文件 C 输出；省略或 --split-c-dir= 时目录默认为 .uyacache\n" as *byte);
    fprintf(libc.stderr, "  --split-c-dir=<dir>  同上（合并写法；空路径等价于默认 .uyacache）\n" as *byte);
    fprintf(libc.stderr, "  --no-split-c         关闭多文件 C（单文件/临时 .c；忽略 UYA_SPLIT_C_DIR 与 --split-c-dir）\n" as *byte);
    fprintf(libc.stderr, "  C99 默认多文件输出到 .uyacache（显式 -o xxx.c 或 UYA_SPLIT_C=0|false|no|off 时为单文件）\n" as *byte);
    fprintf(libc.stderr, "  多文件布局：默认镜像分 TU（一源一 .c，便于 make -j）；UYA_SPLIT_C_MIRROR=0|false|no|off 时用 uya_part1+part2\n" as *byte);
    fprintf(libc.stderr, "  -h, --help           显示此帮助信息\n" as *byte);
    fprintf(libc.stderr, "\n微应用环境变量:\n" as *byte);
    fprintf(libc.stderr, "  MICROAPP_TARGET_ARCH  microapp 目标架构；默认 x86_64\n" as *byte);
    fprintf(libc.stderr, "  MICROAPP_TARGET_GCC   microapp 专用 gcc；优先于 TARGET_GCC\n" as *byte);
    fprintf(libc.stderr, "  TARGET_GCC            通用 gcc；仅在未设 MICROAPP_TARGET_GCC 时生效\n" as *byte);
    fprintf(libc.stderr, "  默认三元组：rv32=riscv32-unknown-elf, x86_64=x86_64-linux-gnu, aarch64=aarch64-linux-gnu, xtensa=xtensa-unknown-elf\n" as *byte);
    fprintf(libc.stderr, "\n说明:\n" as *byte);
    fprintf(libc.stderr, "  - 可以指定单个文件或目录，编译器会自动解析模块依赖\n" as *byte);
    fprintf(libc.stderr, "  - 如果指定目录，目录中必须只有一个文件包含 main 函数\n" as *byte);
    fprintf(libc.stderr, "  - 使用 UYA_ROOT 环境变量指定标准库位置（未设置时默认为编译器所在目录的上一级，即 …/bin → …/lib）\n" as *byte);
    fprintf(libc.stderr, "\n语言特性:\n" as *byte);
    fprintf(libc.stderr, "  - 零 GC，手动内存管理\n" as *byte);
    fprintf(libc.stderr, "  - 编译期内存安全证明\n" as *byte);
    fprintf(libc.stderr, "  - 泛型支持 <T: Constraint>\n" as *byte);
    fprintf(libc.stderr, "  - 接口鸭子类型\n" as *byte);
    fprintf(libc.stderr, "  - 错误处理 !T 联合类型\n" as *byte);
    fprintf(libc.stderr, "  - defer/errdefer 资源清理\n" as *byte);
    fprintf(libc.stderr, "  - 原子类型 atomic T\n" as *byte);
    fprintf(libc.stderr, "  - 内联汇编 @asm { }\n" as *byte);
}

fn detect_main_is_space(ch: byte) i32 {
    if ch == 32 || ch == 10 || ch == 9 || ch == 13 {
        return 1;
    }
    return 0;
}

fn detect_main_is_ident_start(ch: byte) i32 {
    if (ch >= 65 && ch <= 90) || (ch >= 97 && ch <= 122) || ch == 95 {
        return 1;
    }
    return 0;
}

fn detect_main_is_ident_continue(ch: byte) i32 {
    if detect_main_is_ident_start(ch) != 0 || (ch >= 48 && ch <= 57) {
        return 1;
    }
    return 0;
}

fn detect_main_skip_string(buf: &byte, file_size: usize, pos: &usize, quote: byte) void {
    if buf == null || pos == null || pos[0] >= file_size {
        return;
    }
    pos[0] = pos[0] + 1;
    while pos[0] < file_size {
        const ch: byte = buf[pos[0]];
        if ch == 92 && pos[0] + 1 < file_size {
            pos[0] = pos[0] + 2;
            continue;
        }
        pos[0] = pos[0] + 1;
        if ch == quote {
            return;
        }
    }
}

fn detect_main_skip_ws_and_comments(buf: &byte, file_size: usize, pos: &usize) void {
    if buf == null || pos == null {
        return;
    }
    while pos[0] < file_size {
        const ch: byte = buf[pos[0]];
        if detect_main_is_space(ch) != 0 {
            pos[0] = pos[0] + 1;
            continue;
        }
        if ch == 47 && pos[0] + 1 < file_size {
            const next: byte = buf[pos[0] + 1];
            if next == 47 {
                pos[0] = pos[0] + 2;
                while pos[0] < file_size && buf[pos[0]] != 10 {
                    pos[0] = pos[0] + 1;
                }
                continue;
            }
            if next == 42 {
                pos[0] = pos[0] + 2;
                while pos[0] + 1 < file_size {
                    if buf[pos[0]] == 42 && buf[pos[0] + 1] == 47 {
                        pos[0] = pos[0] + 2;
                        break;
                    }
                    pos[0] = pos[0] + 1;
                }
                continue;
            }
        }
        return;
    }
}

fn detect_main_token_eq(buf: &byte, start: usize, end: usize, text: &byte) i32 {
    if buf == null || text == null || end < start {
        return 0;
    }
    const len: usize = end - start;
    if strlen(text as *byte) != len {
        return 0;
    }
    if len == 0 {
        return 0;
    }
    if strncmp(&buf[start], text as *byte, len) == 0 {
        return 1;
    }
    return 0;
}

fn detect_main_match_ident_after(buf: &byte, file_size: usize, pos: usize, text: &byte, next_pos: &usize) i32 {
    var cursor: usize = pos;
    detect_main_skip_ws_and_comments(buf, file_size, &cursor);
    if cursor >= file_size || detect_main_is_ident_start(buf[cursor]) == 0 {
        return 0;
    }
    const start: usize = cursor;
    cursor = cursor + 1;
    while cursor < file_size && detect_main_is_ident_continue(buf[cursor]) != 0 {
        cursor = cursor + 1;
    }
    if detect_main_token_eq(buf, start, cursor, text) == 0 {
        return 0;
    }
    if next_pos != null {
        next_pos[0] = cursor;
    }
    return 1;
}

// 检测文件是否包含 main 函数
// 返回值：0=无main，1=fn main / test，2=export fn main，3=export extern fn main
fn detect_main_function(filename: &byte) i32 {
    if filename == null {
        return 0;
    }
    const file_size: i32 = read_file_content(filename, &file_buffer[0], FILE_BUFFER_SIZE as usize);
    if file_size < 0 {
        return 0;
    }
    const buf: &byte = &file_buffer[0];
    const size: usize = file_size as usize;
    var i: usize = 0;
    while i < size {
        detect_main_skip_ws_and_comments(buf, size, &i);
        if i >= size {
            break;
        }
        const ch: byte = buf[i];
        if ch == 34 || ch == 39 {
            detect_main_skip_string(buf, size, &i, ch);
            continue;
        }
        if detect_main_is_ident_start(ch) == 0 {
            i = i + 1;
            continue;
        }
        const token_start: usize = i;
        i = i + 1;
        while i < size && detect_main_is_ident_continue(buf[i]) != 0 {
            i = i + 1;
        }
        if detect_main_token_eq(buf, token_start, i, "export" as &byte) != 0 {
            var after_export: usize = i;
            if detect_main_match_ident_after(buf, size, after_export, "extern" as &byte, &after_export) != 0 {
                if detect_main_match_ident_after(buf, size, after_export, "fn" as &byte, &after_export) != 0 &&
                    detect_main_match_ident_after(buf, size, after_export, "main" as &byte, null) != 0 {
                    return 3;
                }
            }
            after_export = i;
            if detect_main_match_ident_after(buf, size, after_export, "fn" as &byte, &after_export) != 0 &&
                detect_main_match_ident_after(buf, size, after_export, "main" as &byte, null) != 0 {
                return 2;
            }
            continue;
        }
        if detect_main_token_eq(buf, token_start, i, "fn" as &byte) != 0 {
            if detect_main_match_ident_after(buf, size, i, "main" as &byte, null) != 0 {
                return 1;
            }
            continue;
        }
        if detect_main_token_eq(buf, token_start, i, "test" as &byte) != 0 {
            var after_test: usize = i;
            detect_main_skip_ws_and_comments(buf, size, &after_test);
            if after_test < size && buf[after_test] == 34 {
                return 1;
            }
        }
    }
    return 0;
}

fn node_has_tests(node: &ASTNode) i32 {
    if node == null {
        return 0;
    }
    if node.type == ASTNodeType.AST_TEST_STMT {
        return 1;
    }
    if node.type == ASTNodeType.AST_BLOCK && node.block_stmts != null {
        var i: i32 = 0;
        while i < node.block_stmt_count {
            if node_has_tests(node.block_stmts[i]) != 0 {
                return 1;
            }
            i = i + 1;
        }
        return 0;
    }
    if node.type == ASTNodeType.AST_IF_STMT {
        if node_has_tests(node.if_stmt_then_branch) != 0 {
            return 1;
        }
        if node.if_stmt_else_branch != null && node_has_tests(node.if_stmt_else_branch) != 0 {
            return 1;
        }
        return 0;
    }
    if node.type == ASTNodeType.AST_WHILE_STMT {
        return node_has_tests(node.while_stmt_body);
    }
    if node.type == ASTNodeType.AST_FOR_STMT {
        return node_has_tests(node.for_stmt_body);
    }
    if node.type == ASTNodeType.AST_FN_DECL {
        return node_has_tests(node.fn_decl_body);
    }
    if node.type == ASTNodeType.AST_VAR_DECL {
        return node_has_tests(node.var_decl_init);
    }
    if node.type == ASTNodeType.AST_EXTERN_VAR_DECL {
        return node_has_tests(node.extern_var_decl_init_expr);
    }
    if node.type == ASTNodeType.AST_RETURN_STMT {
        return node_has_tests(node.return_stmt_expr);
    }
    if node.type == ASTNodeType.AST_ASSIGN {
        if node_has_tests(node.assign_dest) != 0 {
            return 1;
        }
        return node_has_tests(node.assign_src);
    }
    if node.type == ASTNodeType.AST_CALL_EXPR {
        if node_has_tests(node.call_expr_callee) != 0 {
            return 1;
        }
        if node.call_expr_args != null {
            var j: i32 = 0;
            while j < node.call_expr_arg_count {
                if node_has_tests(node.call_expr_args[j]) != 0 {
                    return 1;
                }
                j = j + 1;
            }
        }
        return 0;
    }
    if node.type == ASTNodeType.AST_MEMBER_ACCESS {
        return node_has_tests(node.member_access_object);
    }
    if node.type == ASTNodeType.AST_BINARY_EXPR {
        if node_has_tests(node.binary_expr_left) != 0 {
            return 1;
        }
        return node_has_tests(node.binary_expr_right);
    }
    if node.type == ASTNodeType.AST_UNARY_EXPR {
        return node_has_tests(node.unary_expr_operand);
    }
    if node.type == ASTNodeType.AST_CAST_EXPR {
        if node_has_tests(node.cast_expr_expr) != 0 {
            return 1;
        }
        return node_has_tests(node.cast_expr_target_type);
    }
    if node.type == ASTNodeType.AST_TRY_EXPR {
        return node_has_tests(node.try_expr_operand);
    }
    if node.type == ASTNodeType.AST_MATCH_EXPR && node.match_expr_arms != null {
        if node_has_tests(node.match_expr_expr) != 0 {
            return 1;
        }
        var k: i32 = 0;
        while k < node.match_expr_arm_count {
            if node_has_tests(node.match_expr_arms[k].result_expr) != 0 {
                return 1;
            }
            k = k + 1;
        }
        return 0;
    }
    return 0;
}

fn program_has_tests(program: &ASTNode) i32 {
    if program == null || program.type != ASTNodeType.AST_PROGRAM {
        return 0;
    }
    var i: i32 = 0;
    while i < program.program_decl_count {
        if node_has_tests(program.program_decls[i]) != 0 {
            return 1;
        }
        i = i + 1;
    }
    return 0;
}

fn seed_function_reachability_from_owned_method(checker: &TypeChecker, method: &ASTNode) void {
    if checker == null || method == null || method.type != ASTNodeType.AST_FN_DECL || method.fn_decl_body == null {
        return;
    }
    const saved_owner: &ASTNode = checker.current_function_decl;
    checker.current_function_decl = method;
    // Owned-method fallback runs after checking, so keep it independent from the
    // per-pass visited cache used to speed up ordinary reachability walks.
    checker_walk_reachability_node_uncached(checker, method.fn_decl_body);
    checker.current_function_decl = saved_owner;
}

fn seed_function_reachability_roots(checker: &TypeChecker, program: &ASTNode) void {
    if checker == null || program == null || program.type != ASTNodeType.AST_PROGRAM {
        return;
    }
    var i: i32 = 0;
    while i < program.program_decl_count {
        const decl: &ASTNode = program.program_decls[i];
        if decl != null {
            if decl.type == ASTNodeType.AST_FN_DECL && decl.fn_decl_name != null {
                if decl.fn_decl_is_export != 0 || str_equals(decl.fn_decl_name, "main" as *byte) != 0 {
                    _ = checker_add_function_root_decl(checker, decl);
                }
            } else if decl.type == ASTNodeType.AST_STRUCT_DECL && decl.struct_decl_methods != null {
                var mj: i32 = 0;
                while mj < decl.struct_decl_method_count {
                    const method: &ASTNode = decl.struct_decl_methods[mj];
                    seed_function_reachability_from_owned_method(checker, method);
                    mj = mj + 1;
                }
            } else if decl.type == ASTNodeType.AST_UNION_DECL && decl.union_decl_methods != null {
                var uj: i32 = 0;
                while uj < decl.union_decl_method_count {
                    const method: &ASTNode = decl.union_decl_methods[uj];
                    seed_function_reachability_from_owned_method(checker, method);
                    uj = uj + 1;
                }
            } else if decl.type == ASTNodeType.AST_METHOD_BLOCK && decl.method_block_methods != null {
                var mj2: i32 = 0;
                while mj2 < decl.method_block_method_count {
                    const method2: &ASTNode = decl.method_block_methods[mj2];
                    seed_function_reachability_from_owned_method(checker, method2);
                    mj2 = mj2 + 1;
                }
            }
        }
        i = i + 1;
    }
}

std.cfg(std.host_os == .hos_linux, {
    const DIRENT_OFF_D_TYPE: usize = 18;
    const DIRENT_OFF_D_NAME: usize = 19;
}, std.cfg(std.host_os == .hos_macos, {
    const DIRENT_OFF_D_TYPE: usize = 20;
    const DIRENT_OFF_D_NAME: usize = 21;
}, {
    const DIRENT_OFF_D_TYPE: usize = 18;
    const DIRENT_OFF_D_NAME: usize = 19;
}))

fn dirent_get_type(entry_ptr: &byte) byte {
    return entry_ptr[DIRENT_OFF_D_TYPE];
}

fn dirent_get_name(entry_ptr: &byte) &byte {
    var p: &byte = entry_ptr;
    p = p + DIRENT_OFF_D_NAME;
    return p;
}

// 是否为「普通文件」语义（.uya 扫描等，仅 DT_REG）
fn dirent_is_regular_file(entry_ptr: &byte) i32 {
    if dirent_get_type(entry_ptr) == DT_REG as byte {
        return 1;
    }
    return 0;
}

// DT_REG 或 DT_UNKNOWN（NFS 等可能未知类型，需后续 stat）
fn dirent_may_be_regular_file(entry_ptr: &byte) i32 {
    const t: byte = dirent_get_type(entry_ptr);
    if t == DT_REG as byte || t == DT_UNKNOWN as byte {
        return 1;
    }
    return 0;
}

// 默认中间 C 路径：$TMPDIR/uya_output.c，否则 /tmp/uya_output.c（Darwin/Linux 通用）
fn host_fill_temp_c_compile_path(buf: &byte, cap: usize) i32 {
    if buf == null || cap < 24 {
        return -1;
    }
    const tmpdir: *byte = getenv("TMPDIR" as *byte);
    if tmpdir != null && tmpdir[0] != 0 {
        const w: i32 = snprintf(buf as *byte, cap, "%s/uya_output.c" as *byte, tmpdir);
        if w > 0 && (w as usize) < cap {
            return 0;
        }
        return -1;
    }
    const w2: i32 = snprintf(buf as *byte, cap, "/tmp/uya_output.c" as *byte);
    if w2 > 0 && (w2 as usize) < cap {
        return 0;
    }
    return -1;
}

// run/test 临时可执行路径：$TMPDIR/uya_out<suffix> 或 /tmp/uya_out<suffix>
fn host_fill_temp_run_exe_path(buf: &byte, cap: usize, exe_suffix: &byte) i32 {
    if buf == null || cap < 32 {
        return -1;
    }
    var suf: &byte = exe_suffix;
    if suf == null {
        suf = "" as *byte;
    }
    const tmpdir: *byte = getenv("TMPDIR" as *byte);
    if tmpdir != null && tmpdir[0] != 0 {
        const w: i32 = snprintf(buf as *byte, cap, "%s/uya_out%s" as *byte, tmpdir, suf as *byte);
        if w > 0 && (w as usize) < cap {
            return 0;
        }
        return -1;
    }
    const w2: i32 = snprintf(buf as *byte, cap, "/tmp/uya_out%s" as *byte, suf as *byte);
    if w2 > 0 && (w2 as usize) < cap {
        return 0;
    }
    return -1;
}

fn host_fill_temp_microapp_loader_path(buf: &byte, cap: usize, exe_suffix: &byte) i32 {
    if buf == null || cap < 48 {
        return -1;
    }
    var suf: &byte = exe_suffix;
    if suf == null {
        suf = "" as *byte;
    }
    const pid: i32 = getpid();
    const tmpdir: *byte = getenv("TMPDIR" as *byte);
    if tmpdir != null && tmpdir[0] != 0 {
        const w: i32 = snprintf(buf as *byte, cap, "%s/uya_microapp_loader_%d%s" as *byte, tmpdir, pid, suf as *byte);
        if w > 0 && (w as usize) < cap {
            return 0;
        }
        return -1;
    }
    const w2: i32 = snprintf(buf as *byte, cap, "/tmp/uya_microapp_loader_%d%s" as *byte, pid, suf as *byte);
    if w2 > 0 && (w2 as usize) < cap {
        return 0;
    }
    return -1;
}

fn host_run_microapp_loader(loader_exe: &byte, uapp_path: &byte, payload_exe_path: &byte) i32 {
    if loader_exe == null || uapp_path == null {
        return 1;
    }
    var cmd: [byte: 4096] = [];
    var cmd_len: i32 = 0;
    if payload_exe_path != null && payload_exe_path[0] != 0 as byte {
        cmd_len = snprintf(&cmd[0] as *byte, 4096,
            "\"%s\" \"%s\" \"%s\"" as *byte,
            loader_exe as *byte,
            uapp_path as *byte,
            payload_exe_path as *byte,
            );
    } else {
        cmd_len = snprintf(&cmd[0] as *byte, 4096, "\"%s\" \"%s\"" as *byte, loader_exe as *byte, uapp_path as *byte);
    }
    if cmd_len <= 0 || cmd_len >= 4096 {
        fprintf(libc.stderr, "错误：无法生成微容器运行命令\n" as *byte);
        return 1;
    }
    return system(&cmd[0] as *byte);
}

// 在目录中查找包含 main 函数的文件
fn find_main_files_in_dir(
    dir_path: &byte,
    main_files: &(&byte),
    file_paths_buffer: &([byte: PATH_MAX]),
    max_files: i32,
    file_count: &i32
) i32 {
    if dir_path == null || main_files == null || file_count == null {
        return -1;
    }
    file_count[0] = 0;
    const dir: *DIR = opendir(dir_path as *byte);
    if dir == null {
        return -1;
    }
    var entry: *Dirent = readdir(dir);
    while entry != null && file_count[0] < max_files {
        if dirent_is_regular_file(entry as &byte) != 0 {
            const name: *byte = dirent_get_name(entry as &byte) as *byte;
            const name_len: usize = strlen(name);
            if name_len > 4 {
                const ext: *byte = name + (name_len - 4);
                if strcmp(ext, ".uya" as *byte) == 0 {
                    const len: i32 = snprintf(&file_paths_buffer[file_count[0]][0], PATH_MAX, "%s/%s" as *byte, dir_path as *byte, name);
                    if len > 0 && len < PATH_MAX as i32 {
                        if detect_main_function(&file_paths_buffer[file_count[0]][0] as &byte) != 0 {
                            main_files[file_count[0]] = &file_paths_buffer[file_count[0]][0] as &byte;
                            file_count[0] = file_count[0] + 1;
                        }
                    }
                }
            }
        }
        entry = readdir(dir);
    }
    closedir(dir);
    return 0;
}

// 根据模块路径查找文件
fn find_module_file(
    module_path: &byte,
    project_root: &byte,
    uya_root: &byte,
    buffer: &byte,
    buffer_size: usize
) i32 {
    if module_path == null || buffer == null || buffer_size == 0 {
        return -1;
    }

    // `use std;` 仅用于引入平台选择器与 `std.cfg` 语义，应该稳定映射到
    // lib/std/platform.uya，而不是从 lib/std/ 目录里任意挑一个 `.uya` 文件。
    if uya_root != null && strcmp(module_path as *byte, "std" as *byte) == 0 {
        var std_platform_path: [byte: PATH_MAX] = [];
        const std_platform_len: i32 = snprintf(&std_platform_path[0], PATH_MAX, "%sstd/platform.uya" as *byte, uya_root as *byte);
        if std_platform_len > 0 && std_platform_len < PATH_MAX as i32 {
            const std_platform_file: *void = fopen(&std_platform_path[0], "r" as *byte);
            if std_platform_file != null {
                fclose(std_platform_file);
                if (std_platform_len as usize) < buffer_size {
                    strcpy(buffer as *byte, &std_platform_path[0]);
                    return 0;
                }
            }
        }
    }
    
    // 将模块路径转换为文件路径（std.io -> std/io/）
    var file_path: [byte: PATH_MAX] = [];
    const path_len: usize = strlen(module_path as *byte);
    if path_len >= PATH_MAX {
        return -1;
    }
    strcpy(&file_path[0], module_path as *byte);
    // 将 '.' 替换为 '/'
    var i: usize = 0;
    while i < path_len {
        if file_path[i] == 46 {
            file_path[i] = 47;
        }
        i = i + 1;
    }
    
    // 在给定根目录下查找模块文件
    // 策略1：path/ 目录中的 .uya 文件（如 std/c/syscall/ → syscall.uya）
    // 策略2：path.uya 直接文件（如 std/c/string.uya）
    var ri: i32 = 0;
    while ri < 2 {
        var root: &byte = null;
        if ri == 0 { root = project_root; }
        if ri == 1 { root = uya_root; }
        ri = ri + 1;
        if root == null { continue; }
        const root_nonnull: &byte = root;  // 为安全证明建立非空引用
        if root_nonnull[0] == 0 { continue; }
        
        var full_path: [byte: PATH_MAX] = [];
        const len: i32 = snprintf(&full_path[0], PATH_MAX, "%s%s" as *byte, root as *byte, &file_path[0]);
        if len <= 0 || len >= PATH_MAX as i32 { continue; }
        
        // 策略1：目录中查找 .uya 文件
        if is_directory(&full_path[0] as &byte) != 0 {
            const dir: *DIR = opendir(&full_path[0]);
            if dir != null {
                var entry: *Dirent = readdir(dir);
                while entry != null {
                    if dirent_is_regular_file(entry as &byte) != 0 {
                        const name: *byte = dirent_get_name(entry as &byte) as *byte;
                        const name_len: usize = strlen(name);
                        if name_len > 4 {
                            const ext: *byte = name + (name_len - 4);
                            if strcmp(ext, ".uya" as *byte) == 0 {
                                closedir(dir);
                                const result_len: i32 = snprintf(buffer as *byte, buffer_size, "%s%s/%s" as *byte, root as *byte, &file_path[0], name);
                                if result_len > 0 && result_len < buffer_size as i32 {
                                    return 0;
                                }
                            }
                        }
                    }
                    entry = readdir(dir);
                }
                closedir(dir);
            }
        }
        
        // 策略2：直接文件 path.uya
        var uya_path: [byte: PATH_MAX] = [];
        const ulen: i32 = snprintf(&uya_path[0], PATH_MAX, "%s%s.uya" as *byte, root as *byte, &file_path[0]);
        if ulen > 0 && ulen < PATH_MAX as i32 {
            const f: *void = fopen(&uya_path[0], "r" as *byte);
            if f != null {
                fclose(f);
                const ulen_sz_tmp: !usize = ulen as! usize;
                const ulen_sz: usize = ulen_sz_tmp.value;
                if ulen_sz < buffer_size {
                    strcpy(buffer as *byte, &uya_path[0]);
                    return 0;
                }
            }
        }
    }
    
    return -1;
}

// 从 AST 中提取 use 语句的模块路径
// 辅助函数：将 segments[0..count) 连接为 "a.b.c" 形式
fn join_segments_alloc(segs: &(&byte), count: i32, arena: &CompilerArena) &byte {
    var total_len: usize = 0;
    var j: i32 = 0;
    while j < count {
        if segs[j] != null {
            total_len = total_len + strlen(segs[j] as *byte);
            if j > 0 { total_len = total_len + 1; }
        }
        j = j + 1;
    }
    if total_len == 0 { return null; }
    const buf: &byte = compiler_arena_alloc(arena, total_len + 1) as &byte;
    if buf == null { return null; }
    var dst: &byte = buf;
    j = 0;
    while j < count {
        if segs[j] != null {
            if j > 0 { dst[0] = 46 as byte; dst = dst + 1; }
            const sl: usize = strlen(segs[j] as *byte);
            memcpy(dst as *void, segs[j] as *void, sl);
            dst = dst + sl;
        }
        j = j + 1;
    }
    dst[0] = 0 as byte;
    return buf;
}

fn extract_use_modules(
    ast: &ASTNode,
    modules: &(&byte),
    max_modules: i32,
    module_count: &i32,
    project_root: &byte,
    uya_root: &byte,
    arena: &CompilerArena
) i32 {
    if ast == null || ast.type != ASTNodeType.AST_PROGRAM || modules == null || module_count == null || arena == null {
        return -1;
    }
    module_count[0] = 0;
    var i: i32 = 0;
    while i < ast.program_decl_count && module_count[0] < max_modules {
        const decl: &ASTNode = ast.program_decls[i];
        if decl != null && decl.type == ASTNodeType.AST_USE_STMT {
            const seg_count: i32 = decl.use_stmt_path_segment_count;
            if seg_count > 0 {
                var module_name: &byte = null;
                
                if decl.use_stmt_item_name != null {
                    // item_name 已设置，所有 segments 都是模块路径
                    module_name = join_segments_alloc(decl.use_stmt_path_segments, seg_count, arena);
                } else if seg_count > 1 {
                    // 先尝试全路径作为模块名
                    const full_path: &byte = join_segments_alloc(decl.use_stmt_path_segments, seg_count, arena);
                    if full_path != null {
                        var module_file: [byte: PATH_MAX] = [];
                        if find_module_file(full_path, project_root, uya_root, &module_file[0] as &byte, PATH_MAX) == 0 {
                            module_name = full_path;
                        } else {
                            module_name = join_segments_alloc(decl.use_stmt_path_segments, seg_count - 1, arena);
                        }
                    }
                } else {
                    module_name = join_segments_alloc(decl.use_stmt_path_segments, seg_count, arena);
                }
                
                if module_name != null {
                    // 去重
                    var duplicate: i32 = 0;
                    var k: i32 = 0;
                    while k < module_count[0] {
                        if modules[k] != null && strcmp(modules[k] as *byte, module_name as *byte) == 0 {
                            duplicate = 1;
                            break;
                        }
                        k = k + 1;
                    }
                    if duplicate == 0 {
                        modules[module_count[0]] = module_name;
                        module_count[0] = module_count[0] + 1;
                    }
                }
            }
        }
        i = i + 1;
    }
    return 0;
}

// 对路径指针数组按字符串排序（与 C 编译器 qsort 一致，保证自举比对顺序）
fn sort_paths(paths: &(&byte), count: i32) void {
    var i: i32 = 0;
    while i < count - 1 {
        var j: i32 = i + 1;
        while j < count {
            if strcmp(paths[i] as *byte, paths[j] as *byte) > 0 {
                const tmp: &byte = paths[i];
                paths[i] = paths[j];
                paths[j] = tmp;
            }
            j = j + 1;
        }
        i = i + 1;
    }
}

// 递归收集模块依赖
// 返回：成功返回新的文件列表大小，失败返回-1
fn collect_module_dependencies(
    filename: &byte,
    file_list: &(&byte),
    file_list_size: i32,
    max_files: i32,
    processed_files: &(&byte),
    processed_count: &i32,
    max_processed: i32,
    project_root: &byte,
    uya_root: &byte,
    arena: &CompilerArena
) i32 {
    if filename == null || file_list == null || processed_files == null || processed_count == null || arena == null {
        return -1;
    }
    
    // 使用局部变量存储可修改的 file_list_size（函数参数在 Uya 中不可修改）
    var current_size: i32 = file_list_size;
    
    // 检查是否已处理过（避免循环依赖）
    // 使用路径比较函数，考虑路径格式差异
    var i: i32 = 0;
    while i < processed_count[0] {
        if processed_files[i] != null && paths_equal(processed_files[i], filename) != 0 {
            return current_size;  // 已处理，直接返回
        }
        i = i + 1;
    }
    
    // 标记为已处理
    if processed_count[0] >= max_processed {
        return -1;
    }
    processed_files[processed_count[0]] = filename;
    processed_count[0] = processed_count[0] + 1;

    // 保存 arena 偏移量，用于解析后回滚释放 AST 内存
    const arena_save_offset: usize = compiler_arena_save(arena);

    // 读取文件并解析 AST
    const file_size: i32 = read_file_content(filename, &file_buffer[0], FILE_BUFFER_SIZE as usize);
    if file_size < 0 {
        compiler_arena_restore(arena, arena_save_offset);
        return -1;
    }

    var lexer: Lexer = Lexer {
        buffer: [],
        buffer_size: 0 as usize,
        position: 0 as usize,
        line: 1,
        column: 1,
        filename: null,
        has_error: 0,
        string_mode: 0,
        raw_string_mode: 0,
        interp_depth: 0,
        pending_interp_open: 0,
        reading_spec: 0,
        has_seen_interp_in_string: 0,
        string_text_buffer: [],
        string_text_len: 0,
    };
    if lexer_init(&lexer, &file_buffer[0], file_size as usize, filename, arena) != 0 {
        compiler_arena_restore(arena, arena_save_offset);
        return -1;
    }

    var parser: Parser = Parser {
        lexer: null,
        current_token: null,
        arena: null,
        context: ParserContext.PARSER_CONTEXT_NORMAL,
        pending_greater_token: null,
        saw_use_std: 0,
    };
    if parser_init(&parser, &lexer, arena) != 0 {
        compiler_arena_restore(arena, arena_save_offset);
        return -1;
    }

    const ast: &ASTNode = parser_parse(&parser);
    if ast == null || ast.type != ASTNodeType.AST_PROGRAM {
        compiler_arena_restore(arena, arena_save_offset);
        return -1;
    }

    // 提取 use 语句中的模块路径
    var modules: [&byte: MAX_INPUT_FILES] = [];
    var module_count: i32 = 0;
    if extract_use_modules(ast, &modules[0], MAX_INPUT_FILES, &module_count, project_root, uya_root, arena) != 0 {
        compiler_arena_restore(arena, arena_save_offset);
        return -1;
    }

    // 将模块名复制到栈上（arena 回滚后 modules 指针会失效）
    var module_names_stack: [[byte: 256]: MAX_INPUT_FILES] = [];
    var mi: i32 = 0;
    while mi < module_count {
        if modules[mi] != null {
            var si: usize = 0;
            while si < 255 && modules[mi][si] != 0 {
                module_names_stack[mi][si] = modules[mi][si];
                si = si + 1;
            }
            module_names_stack[mi][si] = 0 as byte;
        }
        mi = mi + 1;
    }

    // 回滚 arena，释放 AST 内存（依赖收集阶段不需要保留 AST）
    compiler_arena_restore(arena, arena_save_offset);

    // 对于每个模块，查找文件并递归处理
    i = 0;
    while i < module_count {
        if module_names_stack[i][0] == 0 {
            i = i + 1;
            continue;
        }
        // std 模块：收集 lib/std/ 目录下所有 .uya 文件（与 C 编译器一致）
        if (strcmp(&module_names_stack[i][0] as *byte, "std" as *byte) == 0 || strncmp(&module_names_stack[i][0] as *byte, "std." as *byte, 4) == 0) && uya_root != null && uya_root[0] != 0 {
            // 先尝试按单文件解析（如 std.async -> lib/std/async.uya），避免依赖 lib/std/async/ 目录存在
            var single_file: [byte: PATH_MAX] = [];
            if find_module_file(&module_names_stack[i][0] as *byte, project_root, uya_root, &single_file[0], PATH_MAX) == 0 {
                var in_list: i32 = 0;
                var j: i32 = 0;
                while j < current_size {
                    if file_list[j] != null && paths_equal(file_list[j], &single_file[0] as &byte) != 0 {
                        in_list = 1;
                        break;
                    }
                    j = j + 1;
                }
                if in_list == 0 && current_size < max_files {
                    const path_copy: &byte = compiler_arena_alloc(arena, strlen(&single_file[0]) + 1) as &byte;
                    if path_copy != null {
                        strcpy(path_copy as *byte, &single_file[0]);
                        file_list[current_size] = path_copy;
                        current_size = current_size + 1;
                        current_size = collect_module_dependencies(path_copy, file_list, current_size, max_files, processed_files, processed_count, max_processed, project_root, uya_root, arena);
                        if current_size < 0 { return -1; }
                    }
                }
                i = i + 1;
                continue;
            }
            var std_dir: [byte: PATH_MAX] = [];
            var dlen: i32 = 0;
            if strcmp(&module_names_stack[i][0] as *byte, "std" as *byte) == 0 {
                dlen = snprintf(&std_dir[0], PATH_MAX, "%sstd/" as *byte, uya_root as *byte);
            } else {
                // std.xxx.yyy 模块 -> lib/std/xxx/yyy/
                // 需要将点号替换为斜杠
                var path_suffix: [byte: PATH_MAX] = [];
                const suffix: &byte = &module_names_stack[i][0] as *byte + 4;  // 跳过 "std."
                var k: usize = 0;
                while suffix[k] != 0 && k < PATH_MAX - 2 {
                    if suffix[k] == 46 {  // '.'
                        path_suffix[k] = 47;  // '/'
                    } else {
                        path_suffix[k] = suffix[k];
                    }
                    k = k + 1;
                }
                path_suffix[k] = 47;  // 添加末尾斜杠
                path_suffix[k + 1] = 0;
                dlen = snprintf(&std_dir[0], PATH_MAX, "%sstd/%s" as *byte, uya_root as *byte, &path_suffix[0]);
            }
            // 如果目录不存在，尝试去掉最后一段（可能是 item_name 被错误地当作模块路径）
            if dlen <= 0 || dlen >= PATH_MAX || is_directory(&std_dir[0] as &byte) == 0 {
                // 查找最后一个斜杠，截断路径
                var last_slash: i32 = dlen - 1;
                while last_slash > 0 {
                    if std_dir[last_slash] == 47 {  // '/'
                        break;
                    }
                    last_slash = last_slash - 1;
                }
                if last_slash > 0 {
                    std_dir[last_slash + 1] = 0;  // 截断到最后一个斜杠后
                    dlen = last_slash + 1;
                }
            }
            if dlen > 0 && dlen < PATH_MAX && is_directory(&std_dir[0] as &byte) != 0 {
                const dir: *DIR = opendir(&std_dir[0]);
                if dir != null {
                    var pending: [&byte: MAX_INPUT_FILES] = [];
                    var pending_count: i32 = 0;
                    var entry: *Dirent = readdir(dir);
                    while entry != null && pending_count < max_files {
                        if dirent_may_be_regular_file(entry as &byte) != 0 {
                            const name: *byte = dirent_get_name(entry as &byte) as *byte;
                            const nlen: usize = strlen(name);
                            if nlen > 4 && strcmp(name + (nlen - 4), ".uya" as *byte) == 0 {
                                var fp: [byte: PATH_MAX] = [];
                                const flen: i32 = snprintf(&fp[0], PATH_MAX, "%s%s" as *byte, &std_dir[0], name);
                                if flen > 0 && flen < PATH_MAX {
                                    var in_list: i32 = 0;
                                    var j: i32 = 0;
                                    while j < current_size {
                                        if file_list[j] != null && paths_equal(file_list[j], &fp[0] as &byte) != 0 {
                                            in_list = 1;
                                            break;
                                        }
                                        j = j + 1;
                                    }
                                    // 同时检查 pending 数组中是否已存在（防止重复添加）
                                    if in_list == 0 {
                                        var pk: i32 = 0;
                                        while pk < pending_count {
                                            if pending[pk] != null && paths_equal(pending[pk], &fp[0] as &byte) != 0 {
                                                in_list = 1;
                                                break;
                                            }
                                            pk = pk + 1;
                                        }
                                    }
                                    if in_list == 0 {
                                        const path_copy: &byte = compiler_arena_alloc(arena, strlen(&fp[0]) + 1) as &byte;
                                        if path_copy != null {
                                            strcpy(path_copy as *byte, &fp[0]);
                                            pending[pending_count] = path_copy;
                                            pending_count = pending_count + 1;
                                        }
                                    }
                                }
                            }
                        }
                        entry = readdir(dir);
                    }
                    closedir(dir);
                    if pending_count > 0 {
                        sort_paths(&pending[0] as &(&byte), pending_count);
                        // 先把所有文件添加到 file_list（防止递归时重复添加）
                        var idx: i32 = 0;
                        while idx < pending_count {
                            file_list[current_size] = pending[idx];
                            current_size = current_size + 1;
                            idx = idx + 1;
                        }
                        // 然后递归处理每个文件的依赖
                        idx = 0;
                        while idx < pending_count {
                            const pc: &byte = pending[idx];
                            current_size = collect_module_dependencies(pc, file_list, current_size, max_files, processed_files, processed_count, max_processed, project_root, uya_root, arena);
                            if current_size < 0 { return -1; }
                            idx = idx + 1;
                        }
                    }
                }
            }
            i = i + 1;
            continue;
        }
        // libc 模块：收集 lib/libc/ 目录下所有 .uya 文件（与 C 编译器一致）
        if strcmp(&module_names_stack[i][0] as *byte, "libc" as *byte) == 0 && uya_root != null && uya_root[0] != 0 {
            var libc_dir: [byte: PATH_MAX] = [];
            const dlen: i32 = snprintf(&libc_dir[0], PATH_MAX, "%slibc/" as *byte, uya_root as *byte);
            if dlen > 0 && dlen < PATH_MAX && is_directory(&libc_dir[0] as &byte) != 0 {
                const dir: *DIR = opendir(&libc_dir[0]);
                if dir != null {
                    var pending: [&byte: MAX_INPUT_FILES] = [];
                    var pending_count: i32 = 0;
                    var entry: *Dirent = readdir(dir);
                    while entry != null && pending_count < max_files {
                        if dirent_may_be_regular_file(entry as &byte) != 0 {
                            const name: *byte = dirent_get_name(entry as &byte) as *byte;
                            const nlen: usize = strlen(name);
                            if nlen > 4 && strcmp(name + (nlen - 4), ".uya" as *byte) == 0 {
                                var fp: [byte: PATH_MAX] = [];
                                const flen: i32 = snprintf(&fp[0], PATH_MAX, "%s%s" as *byte, &libc_dir[0], name);
                                if flen > 0 && flen < PATH_MAX {
                                    var in_list: i32 = 0;
                                    var j: i32 = 0;
                                    while j < current_size {
                                        if file_list[j] != null && paths_equal(file_list[j], &fp[0] as &byte) != 0 {
                                            in_list = 1;
                                            break;
                                        }
                                        j = j + 1;
                                    }
                                    if in_list == 0 {
                                        var in_proc: i32 = 0;
                                        j = 0;
                                        while j < processed_count[0] {
                                            if processed_files[j] != null && paths_equal(processed_files[j], &fp[0] as &byte) != 0 {
                                                in_proc = 1;
                                                break;
                                            }
                                            j = j + 1;
                                        }
                                        // 同时检查 pending 数组中是否已存在（防止重复添加）
                                        if in_proc == 0 {
                                            var k: i32 = 0;
                                            while k < pending_count {
                                                if pending[k] != null && paths_equal(pending[k], &fp[0] as &byte) != 0 {
                                                    in_proc = 1;
                                                    break;
                                                }
                                                k = k + 1;
                                            }
                                        }
                                        if in_proc == 0 {
                                            const path_copy: &byte = compiler_arena_alloc(arena, strlen(&fp[0]) + 1) as &byte;
                                            if path_copy != null {
                                                strcpy(path_copy as *byte, &fp[0]);
                                                pending[pending_count] = path_copy;
                                                pending_count = pending_count + 1;
                                            }
                                        }
                                    }
                                }
                            }
                        }
                        entry = readdir(dir);
                    }
                    closedir(dir);
                    if pending_count > 0 {
                        sort_paths(&pending[0] as &(&byte), pending_count);
                        // 先把所有文件添加到 file_list（防止递归时重复添加）
                        var idx: i32 = 0;
                        while idx < pending_count {
                            file_list[current_size] = pending[idx];
                            current_size = current_size + 1;
                            idx = idx + 1;
                        }
                        // 然后递归处理每个文件的依赖
                        idx = 0;
                        while idx < pending_count {
                            const pc: &byte = pending[idx];
                            current_size = collect_module_dependencies(pc, file_list, current_size, max_files, processed_files, processed_count, max_processed, project_root, uya_root, arena);
                            if current_size < 0 { return -1; }
                            idx = idx + 1;
                        }
                    }
                }
            }
            i = i + 1;
            continue;
        }
        // syscall 模块：收集 lib/syscall/ 目录下所有 .uya 文件（标准库重构 syscall 层）
        if strcmp(&module_names_stack[i][0] as *byte, "syscall" as *byte) == 0 && uya_root != null && uya_root[0] != 0 {
            var syscall_dir: [byte: PATH_MAX] = [];
            const dlen: i32 = snprintf(&syscall_dir[0], PATH_MAX, "%ssyscall/" as *byte, uya_root as *byte);
            if dlen > 0 && dlen < PATH_MAX && is_directory(&syscall_dir[0] as &byte) != 0 {
                const dir: *DIR = opendir(&syscall_dir[0]);
                if dir != null {
                    var pending: [&byte: MAX_INPUT_FILES] = [];
                    var pending_count: i32 = 0;
                    var entry: *Dirent = readdir(dir);
                    while entry != null && pending_count < max_files {
                        if dirent_may_be_regular_file(entry as &byte) != 0 {
                            const name: *byte = dirent_get_name(entry as &byte) as *byte;
                            const nlen: usize = strlen(name);
                            if nlen > 4 && strcmp(name + (nlen - 4), ".uya" as *byte) == 0 {
                                var fp: [byte: PATH_MAX] = [];
                                const flen: i32 = snprintf(&fp[0], PATH_MAX, "%s%s" as *byte, &syscall_dir[0], name);
                                if flen > 0 && flen < PATH_MAX {
                                    var in_list: i32 = 0;
                                    var j: i32 = 0;
                                    while j < current_size {
                                        if file_list[j] != null && paths_equal(file_list[j], &fp[0] as &byte) != 0 {
                                            in_list = 1;
                                            break;
                                        }
                                        j = j + 1;
                                    }
                                    if in_list == 0 {
                                        var k: i32 = 0;
                                        while k < pending_count {
                                            if pending[k] != null && paths_equal(pending[k], &fp[0] as &byte) != 0 {
                                                in_list = 1;
                                                break;
                                            }
                                            k = k + 1;
                                        }
                                    }
                                    if in_list == 0 {
                                        const path_copy: &byte = compiler_arena_alloc(arena, strlen(&fp[0]) + 1) as &byte;
                                        if path_copy != null {
                                            strcpy(path_copy as *byte, &fp[0]);
                                            pending[pending_count] = path_copy;
                                            pending_count = pending_count + 1;
                                        }
                                    }
                                }
                            }
                        }
                        entry = readdir(dir);
                    }
                    closedir(dir);
                    if pending_count > 0 {
                        sort_paths(&pending[0] as &(&byte), pending_count);
                        var idx: i32 = 0;
                        while idx < pending_count {
                            file_list[current_size] = pending[idx];
                            current_size = current_size + 1;
                            idx = idx + 1;
                        }
                        idx = 0;
                        while idx < pending_count {
                            const pc: &byte = pending[idx];
                            current_size = collect_module_dependencies(pc, file_list, current_size, max_files, processed_files, processed_count, max_processed, project_root, uya_root, arena);
                            if current_size < 0 { return -1; }
                            idx = idx + 1;
                        }
                    }
                }
            }
            i = i + 1;
            continue;
        }
        // use main：收集主工程目录下所有 .uya，排序后加入（与 C 编译器一致）
        if strcmp(&module_names_stack[i][0] as *byte, "main" as *byte) == 0 {
            var main_dir: [byte: PATH_MAX] = [];
            var dir_src: &byte = null;
            // 优先 project_root（主文件所在目录，一般为 src/），避免双输入时 processed_files[0] 为 entry 路径而误扫子目录
            if project_root != null && strlen(project_root) > 0 {
                dir_src = project_root;
            } else if processed_count[0] > 0 && processed_files[0] != null {
                const entry_file: &byte = processed_files[0];
                const slash: *byte = strrchr(entry_file as *byte, 47);
                if slash != null {
                    const dlen_tmp: !usize = (slash as i64 - entry_file as i64 + 1) as! usize;
                    const dlen: usize = dlen_tmp.value;
                    if dlen < PATH_MAX as usize {
                        memcpy(&main_dir[0] as *void, entry_file as *void, dlen);
                        main_dir[dlen] = 0 as byte;
                    } else {
                        strcpy(&main_dir[0], "." as *byte);
                    }
                } else {
                    strcpy(&main_dir[0], "." as *byte);
                }
                dir_src = &main_dir[0] as &byte;
            }
            if dir_src != null {
                const dir: *DIR = opendir(dir_src as *byte);
                if dir != null {
                    var pending: [&byte: MAX_INPUT_FILES] = [];
                    var pending_count: i32 = 0;
                    var entry: *Dirent = readdir(dir);
                    while entry != null && pending_count < max_files {
                        const name: *byte = dirent_get_name(entry as &byte) as *byte;
                        if dirent_may_be_regular_file(entry as &byte) != 0 && strlen(name) > 4 {
                            if strcmp(name + (strlen(name) - 4), ".uya" as *byte) == 0 {
                                var fp: [byte: PATH_MAX] = [];
                                const flen: i32 = snprintf(&fp[0], PATH_MAX, "%s%s" as *byte, dir_src, name);
                                if flen > 0 && flen < PATH_MAX as i32 {
                                    var in_list: i32 = 0;
                                    var j: i32 = 0;
                                    while j < current_size {
                                        if file_list[j] != null && paths_equal(file_list[j], &fp[0] as &byte) != 0 {
                                            in_list = 1;
                                            break;
                                        }
                                        j = j + 1;
                                    }
                                    if in_list == 0 {
                                        var in_proc: i32 = 0;
                                        j = 0;
                                        while j < processed_count[0] {
                                            if processed_files[j] != null && paths_equal(processed_files[j], &fp[0] as &byte) != 0 {
                                                in_proc = 1;
                                                break;
                                            }
                                            j = j + 1;
                                        }
                                        if in_proc == 0 {
                                            const path_copy: &byte = compiler_arena_alloc(arena, strlen(&fp[0]) + 1) as &byte;
                                            if path_copy != null {
                                                strcpy(path_copy as *byte, &fp[0]);
                                                pending[pending_count] = path_copy;
                                                pending_count = pending_count + 1;
                                            }
                                        }
                                    }
                                }
                            }
                        }
                        entry = readdir(dir);
                    }
                    closedir(dir);
                    if pending_count > 0 {
                        sort_paths(&pending[0] as &(&byte), pending_count);
                        // 先把所有文件添加到 file_list（防止递归时重复添加）
                        var idx: i32 = 0;
                        while idx < pending_count {
                            file_list[current_size] = pending[idx];
                            current_size = current_size + 1;
                            idx = idx + 1;
                        }
                        // 然后递归处理每个文件的依赖
                        idx = 0;
                        while idx < pending_count {
                            const pc: &byte = pending[idx];
                            current_size = collect_module_dependencies(pc, file_list, current_size, max_files, processed_files, processed_count, max_processed, project_root, uya_root, arena);
                            if current_size < 0 { return -1; }
                            idx = idx + 1;
                        }
                    }
                }
            }
            i = i + 1;
            continue;
        }
        // 目录模块：将模块路径转为目录路径，若存在则收集该目录下所有 .uya（与 C 一致）
        var file_path: [byte: PATH_MAX] = [];
        const path_len: usize = strlen(&module_names_stack[i][0] as *byte);
        if path_len >= PATH_MAX as usize {
            i = i + 1;
            continue;
        }
        strcpy(&file_path[0], &module_names_stack[i][0] as *byte);
        var k: usize = 0;
        while k < path_len {
            if file_path[k] == 46 as byte { file_path[k] = 47 as byte; }
            k = k + 1;
        }
        var found_dir: i32 = 0;
        var module_dir_path: [byte: PATH_MAX] = [];
        var ri: i32 = 0;
        while ri < 2 {
            var root: &byte = null;
            if ri == 0 { root = project_root; }
            if ri == 1 { root = uya_root; }
            ri = ri + 1;
            if root == null { continue; }
            const root_nonnull: &byte = root;  // 为安全证明建立非空引用
            if root_nonnull[0] == 0 { continue; }
            const len: i32 = snprintf(&module_dir_path[0], PATH_MAX, "%s%s" as *byte, root as *byte, &file_path[0]);
            if len > 0 && len < PATH_MAX as i32 && is_directory(&module_dir_path[0] as &byte) != 0 {
                found_dir = 1;
                break;
            }
        }
        if found_dir != 0 {
            const dir_path: &byte = &module_dir_path[0] as &byte;
            const dir: *DIR = opendir(&module_dir_path[0]);
            if dir != null {
                var pending: [&byte: MAX_INPUT_FILES] = [];
                var pending_count: i32 = 0;
                var entry: *Dirent = readdir(dir);
                while entry != null && pending_count < max_files {
                    if dirent_is_regular_file(entry as &byte) != 0 {
                        const name: *byte = dirent_get_name(entry as &byte) as *byte;
                        const name_len: usize = strlen(name);
                        if name_len > 4 && strcmp(name + (name_len - 4), ".uya" as *byte) == 0 {
                            var full_path: [byte: PATH_MAX] = [];
                            const flen: i32 = snprintf(&full_path[0], PATH_MAX, "%s/%s" as *byte, dir_path as *byte, name);
                            if flen > 0 && flen < PATH_MAX as i32 {
                                var already_added: i32 = 0;
                                var j: i32 = 0;
                                while j < current_size {
                                    if file_list[j] != null && paths_equal(file_list[j], &full_path[0] as &byte) != 0 {
                                        already_added = 1;
                                        break;
                                    }
                                    j = j + 1;
                                }
                                // 同时检查 pending 数组中是否已存在（防止重复添加）
                                if already_added == 0 {
                                    var pk: i32 = 0;
                                    while pk < pending_count {
                                        if pending[pk] != null && paths_equal(pending[pk], &full_path[0] as &byte) != 0 {
                                            already_added = 1;
                                            break;
                                        }
                                        pk = pk + 1;
                                    }
                                }
                                if already_added == 0 {
                                    const path_copy: &byte = compiler_arena_alloc(arena, strlen(&full_path[0]) + 1) as &byte;
                                    if path_copy != null {
                                        strcpy(path_copy as *byte, &full_path[0]);
                                        pending[pending_count] = path_copy;
                                        pending_count = pending_count + 1;
                                    }
                                }
                            }
                        }
                    }
                    entry = readdir(dir);
                }
                closedir(dir);
                if pending_count > 0 {
                    sort_paths(&pending[0] as &(&byte), pending_count);
                    var idx: i32 = 0;
                    while idx < pending_count {
                        const path_copy: &byte = pending[idx];
                        file_list[current_size] = path_copy;
                        current_size = current_size + 1;
                        current_size = collect_module_dependencies(path_copy, file_list, current_size, max_files, processed_files, processed_count, max_processed, project_root, uya_root, arena);
                        if current_size < 0 { return -1; }
                        idx = idx + 1;
                    }
                }
            }
            i = i + 1;
            continue;
        }
        // 单文件模块：find_module_file
        var module_file: [byte: PATH_MAX] = [];
        if find_module_file(&module_names_stack[i][0] as &byte, project_root, uya_root, &module_file[0] as &byte, PATH_MAX) == 0 {
            var already_added: i32 = 0;
            var j: i32 = 0;
            while j < current_size {
                if file_list[j] != null && paths_equal(file_list[j], &module_file[0] as &byte) != 0 {
                    already_added = 1;
                    break;
                }
                j = j + 1;
            }
            if already_added == 0 && current_size < max_files {
                const path_copy: &byte = compiler_arena_alloc(arena, strlen(&module_file[0]) + 1) as &byte;
                if path_copy != null {
                    strcpy(path_copy as *byte, &module_file[0]);
                    file_list[current_size] = path_copy;
                    current_size = current_size + 1;
                    current_size = collect_module_dependencies(path_copy, file_list, current_size, max_files, processed_files, processed_count, max_processed, project_root, uya_root, arena);
                    if current_size < 0 { return -1; }
                }
            }
        }
        i = i + 1;
    }
    
    return current_size;
}

// 解析命令行参数
// command: 输出命令类型
// input_file_indices: 填充前 *input_file_count 个为输入文件在 argv 中的下标
// outlibc_index: --outlibc 选项的参数索引（-1 表示未指定）
// run_arg_start: run 命令的运行时参数起始索引（-1 表示无运行时参数）
// is_nostdlib: --nostdlib 选项（生成 _start 入口）
// stack_size: 堆栈大小（KB），0 表示自动设置
// 返回：0 成功，-1 失败
fn parse_args(
    command: &CommandType,
    input_file_indices: &i32,
    input_file_count: &i32,
    output_file_index: &i32,
    backend_type: &BackendType,
    emit_line_directives: &i32,
    enable_safety_proof: &i32,
    opt_level: &i32,
    outlibc_index: &i32,
    run_arg_start: &i32,
    is_nostdlib: &i32,
    stack_size: &i32,
    async_frame_heap_fallback: &i32
) i32 {
    const argc: i32 = get_argc();
    if argc < 2 {
        const program_name: *byte = get_argv(0);
        if program_name != null {
            print_usage(program_name as &byte);
        }
        return -1;
    }

    // 初始化输出参数
    command[0] = CommandType.COMMAND_BUILD;  // 默认为 build
    input_file_count[0] = 0;
    output_file_index[0] = -1;
    backend_type[0] = BackendType.BACKEND_LLVM;
    emit_line_directives[0] = 0;
    enable_safety_proof[0] = 1;  // 默认启用（compile.sh 自举编译编译器时传 --no-safety-proof）
    opt_level[0] = 1;  // 默认优化级别 1
    outlibc_index[0] = -1;
    run_arg_start[0] = -1;
    is_nostdlib[0] = 0;  // 默认不启用 nostdlib
    stack_size[0] = 0;  // 默认自动设置堆栈大小
    g_split_c_dir_active = 0;
    g_split_c_dir[0] = 0 as byte;
    g_split_c_disabled_cli = 0;
    g_app_mode_microapp = 0;
    async_frame_heap_fallback[0] = 0;

    // 检测子命令
    const first_arg: *byte = get_argv(1);
    var start_idx: i32 = 1;  // 参数解析起始位置
    
    if first_arg != null {
        if strcmp(first_arg, "build" as *byte) == 0 {
            command[0] = CommandType.COMMAND_BUILD;
            start_idx = 2;
        } else if strcmp(first_arg, "run" as *byte) == 0 {
            command[0] = CommandType.COMMAND_RUN;
            start_idx = 2;
        } else if strcmp(first_arg, "test" as *byte) == 0 {
            command[0] = CommandType.COMMAND_TEST;
            start_idx = 2;
        } else if strcmp(first_arg, "pack-image" as *byte) == 0 {
            command[0] = CommandType.COMMAND_PACK_IMAGE;
            start_idx = 2;
        } else if strcmp(first_arg, "fmt" as *byte) == 0 {
            command[0] = CommandType.COMMAND_FMT;
            start_idx = 2;
        }
        // 如果不是子命令，保持默认 COMMAND_BUILD，start_idx = 1
    }

    var i: i32 = start_idx;
    while i < argc {
        const arg: *byte = get_argv(i);
        if arg == null {
            fprintf(libc.stderr, "错误: 无法获取命令行参数（索引 %d）\n" as *byte, i);
            return -1;
        }
        
        // run 命令：检测 -- 之后的参数作为运行时参数
        if command[0] == CommandType.COMMAND_RUN && strcmp(arg, "--" as *byte) == 0 {
            run_arg_start[0] = i + 1;
            break;  // -- 之后的参数不再解析
        }
        
        if strcmp(arg, "-o" as *byte) == 0 {
            if i + 1 < argc {
                output_file_index[0] = i + 1;
                i = i + 1;
            } else {
                fprintf(libc.stderr, "错误: -o 选项需要指定输出文件名\n" as *byte);
                return -1;
            }
        } else if strcmp(arg, "--c99" as *byte) == 0 {
            backend_type[0] = BackendType.BACKEND_C99;
        } else if strcmp(arg, "--no-line-directives" as *byte) == 0 {
            emit_line_directives[0] = 0;
        } else if strcmp(arg, "--line-directives" as *byte) == 0 {
            emit_line_directives[0] = 1;
        } else if strcmp(arg, "--safety-proof" as *byte) == 0 {
            enable_safety_proof[0] = 1;
        } else if strcmp(arg, "--no-safety-proof" as *byte) == 0 {
            enable_safety_proof[0] = 0;
        } else if strcmp(arg, "--opt=0" as *byte) == 0 {
            opt_level[0] = 0;
        } else if strcmp(arg, "--opt=1" as *byte) == 0 {
            opt_level[0] = 1;
        } else if strcmp(arg, "--opt=2" as *byte) == 0 {
            opt_level[0] = 2;
        } else if strcmp(arg, "--opt=3" as *byte) == 0 {
            opt_level[0] = 3;
        } else if strcmp(arg, "-O0" as *byte) == 0 {
            opt_level[0] = 0;
        } else if strcmp(arg, "-O1" as *byte) == 0 {
            opt_level[0] = 1;
        } else if strcmp(arg, "-O2" as *byte) == 0 {
            opt_level[0] = 2;
        } else if strcmp(arg, "-O3" as *byte) == 0 {
            opt_level[0] = 3;
        } else if strcmp(arg, "--nostdlib" as *byte) == 0 {
            is_nostdlib[0] = 1;
        } else if strcmp(arg, "--app" as *byte) == 0 {
            if i + 1 < argc {
                i = i + 1;
                const app_arg: *byte = get_argv(i);
                if app_arg != null && strcmp(app_arg, "microapp" as *byte) == 0 {
                    g_app_mode_microapp = 1;
                    g_container_mode = 1;
                } else if app_arg != null && strcmp(app_arg, "app" as *byte) == 0 {
                    g_app_mode_microapp = 0;
                    g_container_mode = 0;
                } else {
                    fprintf(libc.stderr, "错误: --app 仅支持 app 或 microapp\n" as *byte);
                    return -1;
                }
            } else {
                fprintf(libc.stderr, "错误: --app 选项需要指定 app 或 microapp\n" as *byte);
                return -1;
            }
        } else if strcmp(arg, "--outlibc" as *byte) == 0 {
            if i + 1 < argc {
                outlibc_index[0] = i + 1;
                command[0] = CommandType.COMMAND_OUTLIBC;
                backend_type[0] = BackendType.BACKEND_C99;
                i = i + 1;
            } else {
                fprintf(libc.stderr, "错误: --outlibc 选项需要指定输出目录\n" as *byte);
                return -1;
            }
        } else if strcmp(arg, "--stack-size" as *byte) == 0 {
            if i + 1 < argc {
                const size_str: *byte = get_argv(i + 1);
                if size_str != null {
                    var j: i32 = 0;
                    var size_val: i32 = 0;
                    while size_str[j] >= 48 && size_str[j] <= 57 {
                        size_val = size_val * 10 + (size_str[j] - 48);
                        j = j + 1;
                    }
                    if size_val > 0 {
                        stack_size[0] = size_val;
                    } else {
                        fprintf(libc.stderr, "警告：无效的堆栈大小值\n" as *byte);
                    }
                }
                i = i + 1;
            } else {
                fprintf(libc.stderr, "错误：--stack-size 选项需要指定堆栈大小（KB）\n" as *byte);
                return -1;
            }
        } else if strcmp(arg, "--async-frame-heap=on" as *byte) == 0 {
            async_frame_heap_fallback[0] = 1;
        } else if strcmp(arg, "--no-split-c" as *byte) == 0 {
            g_split_c_disabled_cli = 1;
            g_split_c_dir_active = 0;
            g_split_c_dir[0] = 0 as byte;
        } else if strncmp(arg as &const byte, "--split-c-dir=" as &const byte, 14) == 0 {
            if g_split_c_disabled_cli != 0 {
                fprintf(libc.stderr, "警告: 已指定 --no-split-c，忽略 --split-c-dir\n" as *byte);
            } else {
                // --split-c-dir=<path>：单 argv，避免被误判为未知选项后仅靠 UYA_SPLIT_C_DIR 生效
                var k: i32 = 14;
                var sl: usize = 0;
                while arg[k] != 0 as byte && sl < PATH_MAX - 2 {
                    g_split_c_dir[sl] = arg[k];
                    sl = sl + 1;
                    k = k + 1;
                }
                g_split_c_dir[sl] = 0 as byte;
                if sl > 0 {
                    g_split_c_dir_active = 1;
                } else {
                    split_c_set_default_dir();
                }
            }
        } else if strcmp(arg, "--split-c-dir" as *byte) == 0 {
            if g_split_c_disabled_cli != 0 {
                fprintf(libc.stderr, "警告: 已指定 --no-split-c，忽略 --split-c-dir\n" as *byte);
                if i + 1 < argc {
                    const sd_skip: *byte = get_argv(i + 1);
                    if sd_skip != null && sd_skip[0] != 45 as byte {
                        i = i + 1;
                    }
                }
            } else {
                if i + 1 < argc {
                    const sd: *byte = get_argv(i + 1);
                    if sd != null {
                        const sl: usize = strlen(sd);
                        if sl > 0 && sl < PATH_MAX - 1 {
                            strcpy(&g_split_c_dir[0] as *byte, sd);
                            g_split_c_dir[sl] = 0 as byte;
                            g_split_c_dir_active = 1;
                        } else {
                            split_c_set_default_dir();
                        }
                    } else {
                        split_c_set_default_dir();
                    }
                    i = i + 1;
                } else {
                    split_c_set_default_dir();
                }
            }
        } else {
            const c: byte = arg[0];
            if c != 45 {  // 不是 '-' 开头
                if input_file_count[0] >= MAX_INPUT_FILES {
                    fprintf(libc.stderr, "错误: 输入文件数量超过最大限制 (%d)\n" as *byte, MAX_INPUT_FILES);
                    return -1;
                }
                const idx: i32 = input_file_count[0];
                input_file_indices[idx] = i;
                input_file_count[0] = idx + 1;
            }
        }
        i = i + 1;
    }

    // --outlibc 模式：不需要输入文件和 -o 参数
    if command[0] == CommandType.COMMAND_OUTLIBC {
        return 0;
    }

    if input_file_count[0] == 0 {
        fprintf(libc.stderr, "错误: 未指定输入文件\n" as *byte);
        const program_name: *byte = get_argv(0);
        if program_name != null {
            print_usage(program_name as &byte);
        }
        return -1;
    }
    
    // run 和 test 命令：如果没有指定 -o，自动生成输出路径
    // 输出路径将在主函数中根据输入文件名生成
    
    const out_idx: i32 = output_file_index[0];
    if out_idx >= 0 {
        const out_path: *byte = get_argv(out_idx);
        if out_path == null {
            fprintf(libc.stderr, "错误: 无法获取输出文件路径（索引 %d）\n" as *byte, out_idx);
            return -1;
        }
        if backend_type[0] == BackendType.BACKEND_LLVM {
            const ext: *byte = strrchr(out_path, 46);
            if ext != null && strcmp(ext, ".c" as *byte) == 0 {
                backend_type[0] = BackendType.BACKEND_C99;
            }
        }
    }
    return 0;
}

// 检测输出路径是否为 C 文件（以 .c 结尾）
// 返回：1 表示 C 文件，0 表示其他
fn is_c_output(output_path: &byte) i32 {
    if output_path == null { return 0; }
    const len: usize = strlen(output_path as *byte);
    if len < 2 { return 0; }
    if output_path[len - 2] == 46 as byte && output_path[len - 1] == 99 as byte {
        return 1;
    }
    return 0;
}

// UYA_SPLIT_C=0|false|no|off 或 UYA_SINGLE_FILE_C=1|true|yes 时关闭 C99 默认多文件输出（Makefile 自举等）
fn env_disables_auto_split_c() i32 {
    const ns: *byte = getenv("UYA_SPLIT_C" as *byte);
    if ns != null && ns[0] != 0 as byte {
        if strcmp(ns, "0" as *byte) == 0 ||
            strcmp(ns, "false" as *byte) == 0 ||
            strcmp(ns, "no" as *byte) == 0 ||
            strcmp(ns, "off" as *byte) == 0 {
            return 1;
        }
    }
    const sf: *byte = getenv("UYA_SINGLE_FILE_C" as *byte);
    if sf != null && sf[0] != 0 as byte {
        if strcmp(sf, "1" as *byte) == 0 ||
            strcmp(sf, "true" as *byte) == 0 ||
            strcmp(sf, "yes" as *byte) == 0 {
            return 1;
        }
    }
    return 0;
}

fn get_env_or_default(name: &byte, fallback: &byte) &byte {
    const value: *byte = getenv(name as *byte);
    if value != null && value[0] != 0 {
        return value as &byte;
    }
    return fallback;
}

fn sync_test_network_skip_marker() void {
    const allow: *byte = getenv("ALLOW_SKIP_NETWORK" as *byte);
    if allow != null && allow[0] == '1' as byte && allow[1] == 0 {
        _ = system("/bin/sh -c ': > /tmp/uya_allow_skip_network'" as *byte);
    } else {
        _ = system("/bin/sh -c 'rm -f /tmp/uya_allow_skip_network'" as *byte);
    }
}

fn resolve_cc_driver(buffer: &byte, buffer_size: i32) &byte {
    const explicit_cc_driver: *byte = getenv("CC_DRIVER" as *byte);
    if explicit_cc_driver != null && explicit_cc_driver[0] != 0 {
        return explicit_cc_driver as &byte;
    }

    const toolchain: &byte = get_env_or_default("TOOLCHAIN" as *byte, "system" as *byte);
    if strcmp(toolchain as *byte, "zig" as *byte) == 0 {
        const zig: &byte = get_env_or_default("ZIG" as *byte, "/home/winger/zig/zig" as *byte);
        const written: i32 = snprintf(buffer as *byte, buffer_size, "%s cc" as *byte, zig as *byte);
        if written > 0 && written < buffer_size {
            return buffer;
        }
    }

    return get_env_or_default("CC" as *byte, "cc" as *byte);
}

fn target_matches_host_platform() i32 {
    const target_os: &byte = get_env_or_default("TARGET_OS" as *byte, "linux" as *byte);
    const target_arch: &byte = get_env_or_default("TARGET_ARCH" as *byte, "x86_64" as *byte);
    const host_os: &byte = get_env_or_default("HOST_OS" as *byte, target_os);
    const host_arch: &byte = get_env_or_default("HOST_ARCH" as *byte, target_arch);
    if strcmp(target_os as *byte, host_os as *byte) != 0 {
        return 0;
    }
    if strcmp(target_arch as *byte, host_arch as *byte) != 0 {
        return 0;
    }
    return 1;
}

fn get_target_exe_suffix() &byte {
    const target_os: &byte = get_env_or_default("TARGET_OS" as *byte, "linux" as *byte);
    if strcmp(target_os as *byte, "windows" as *byte) == 0 {
        const suffix: &byte = ".exe" as *byte;
        return suffix;
    }
    const empty: &byte = "" as *byte;
    return empty;
}

// 宿主 CFLAGS 是否处于 -O2/-O3/-Os（GCC 对部分 Uya 生成 C 的错误小函数内联可导致 SIGSEGV，见 std.thread 等测例）
fn hosted_cflags_need_no_small_inline(cflags: &byte) i32 {
    if cflags == null {
        return 0;
    }
    if strstr(cflags as *byte, "-O2" as *byte) != null {
        return 1;
    }
    if strstr(cflags as *byte, "-O3" as *byte) != null {
        return 1;
    }
    if strstr(cflags as *byte, "-Os" as *byte) != null {
        return 1;
    }
    return 0;
}

fn hosted_cflags_has_no_small_inline(cflags: &byte) i32 {
    if cflags == null {
        return 0;
    }
    if strstr(cflags as *byte, "fno-inline-small-functions" as *byte) != null {
        return 1;
    }
    return 0;
}

// 多文件 C：在 split 目录下执行 make -j（UYA_GCC_JOBS）链接 UYA_OUT
fn link_split_with_make(split_dir: &byte, output_exe: &byte, is_nostdlib: i32) i32 {
    if split_dir == null || split_dir[0] == 0 as byte || output_exe == null {
        return 1;
    }
    if is_nostdlib != 0 {
        const target_os: &byte = get_env_or_default("TARGET_OS" as *byte, "linux" as *byte);
        if strcmp(target_os as *byte, "linux" as *byte) != 0 {
            fprintf(libc.stderr, "错误：--nostdlib 多文件链接仅支持 Linux 目标，当前 TARGET_OS=%s\n" as *byte, target_os as *byte);
            return 1;
        }
    }
    var cc_driver_buffer: [byte: PATH_MAX] = [];
    const cc_driver: &byte = resolve_cc_driver(&cc_driver_buffer[0] as &byte, PATH_MAX);
    const cflags_env: &byte = get_env_or_default("CFLAGS" as *byte, "-std=c99 -O0 -g -fno-builtin" as *byte);
    var cflags_buf: [byte: 2048] = [];
    var cflags: &byte = cflags_env;
    if hosted_cflags_need_no_small_inline(cflags_env) != 0 && hosted_cflags_has_no_small_inline(cflags_env) == 0 {
        const wcf: i32 = snprintf(&cflags_buf[0] as *byte, 2048, "%s -fno-inline-small-functions" as *byte, cflags_env as *byte);
        if wcf > 0 && wcf < 2048 {
            cflags = &cflags_buf[0];
        }
    }
    // -nostdlib 无 libc：禁用栈保护，避免未定义的 __stack_chk_fail
    var cflags_nsd_buf: [byte: 2048] = [];
    if is_nostdlib != 0 {
        const wns: i32 = snprintf(&cflags_nsd_buf[0] as *byte, 2048, "%s -fno-stack-protector" as *byte, cflags as *byte);
        if wns > 0 && wns < 2048 {
            cflags = &cflags_nsd_buf[0];
        }
    }
    var ld_buf: [byte: 2048] = [];
    const ld_env: &byte = get_env_or_default("LDFLAGS" as *byte, "" as *byte);
    var ld_use: &byte = ld_env;
    if is_nostdlib != 0 {
        const wld: i32 = snprintf(&ld_buf[0] as *byte, 2048, "%s -nostdlib -static -lgcc" as *byte, ld_env as *byte);
        if wld > 0 && wld < 2048 {
            ld_use = &ld_buf[0];
        }
    }
    const jobs_env: &byte = get_env_or_default("UYA_GCC_JOBS" as *byte, "4" as *byte);
    _ = setenv("UYA_OUT" as *byte, output_exe, 1);
    _ = setenv("CC" as *byte, cc_driver, 1);
    _ = setenv("CFLAGS" as *byte, cflags, 1);
    _ = setenv("LDFLAGS" as *byte, ld_use, 1);
    // 嵌套 make 时清除 GNU make jobserver 变量，避免在「外层 make -j」下子 make 与父 make 争用令牌而卡死
    var cmd: [byte: 8192] = [];
    const cmd_len: i32 = snprintf(&cmd[0] as *byte, 8192,
        "env -u MAKEFLAGS -u MFLAGS -u GNUMAKEFLAGS make -C \"%s\" -j%s" as *byte,
        split_dir as *byte, jobs_env as *byte);
    if cmd_len <= 0 || cmd_len >= 8192 {
        fprintf(libc.stderr, "错误：构建 make 链接命令失败\n" as *byte);
        return 1;
    }
    fprintf(libc.stderr, "信息：多文件 C 链接：%s\n" as *byte, &cmd[0] as *byte);
    const result: i32 = system(&cmd[0] as *byte);
    if result != 0 {
        fprintf(libc.stderr, "错误：make 链接失败，返回码：%d\n" as *byte, result);
        return 1;
    }
    return 0;
}

// 调用宿主工具链链接生成可执行文件
// c_file: C 源代码文件路径
// output: 输出可执行文件路径
// is_nostdlib: 是否使用 --nostdlib 模式
// 返回：0 成功，非 0 失败
fn link_with_toolchain(c_file: &byte, output: &byte, is_nostdlib: i32) i32 {
    if g_split_c_dir_active != 0 {
        return link_split_with_make(&g_split_c_dir[0] as &byte, output, is_nostdlib);
    }
    var cmd: [byte: 4096] = [];
    var cmd_len: i32 = 0;
    var cc_driver_buffer: [byte: PATH_MAX] = [];
    const cc_driver: &byte = resolve_cc_driver(&cc_driver_buffer[0] as &byte, PATH_MAX);
    // 默认对齐仓库 Makefile 的 hosted CFLAGS，避免 uya build/run/test 与 make check 走出不同的宿主代码路径。
    const cflags_env: &byte = get_env_or_default("CFLAGS" as *byte, "-std=c99 -O0 -g -fno-builtin" as *byte);
    var cflags_buf: [byte: 2048] = [];
    var cflags: &byte = cflags_env;
    if hosted_cflags_need_no_small_inline(cflags_env) != 0 && hosted_cflags_has_no_small_inline(cflags_env) == 0 {
        const wcf: i32 = snprintf(&cflags_buf[0] as *byte, 2048, "%s -fno-inline-small-functions" as *byte, cflags_env as *byte);
        if wcf > 0 && wcf < 2048 {
            cflags = &cflags_buf[0];
            fprintf(libc.stderr, "信息：CFLAGS 含 -O2/-O3/-Os，已自动追加 -fno-inline-small-functions（规避宿主 GCC 对部分生成代码的错误小函数内联）\n" as *byte);
        }
    }
    // -nostdlib 无 libc：禁用栈保护，避免未定义的 __stack_chk_fail
    var cflags_nsd2_buf: [byte: 2048] = [];
    if is_nostdlib != 0 {
        const wns2: i32 = snprintf(&cflags_nsd2_buf[0] as *byte, 2048, "%s -fno-stack-protector" as *byte, cflags as *byte);
        if wns2 > 0 && wns2 < 2048 {
            cflags = &cflags_nsd2_buf[0];
        }
    }
    const ldflags: &byte = get_env_or_default("LDFLAGS" as *byte, "" as *byte);
    const target_os: &byte = get_env_or_default("TARGET_OS" as *byte, "linux" as *byte);
    const target_triple: &byte = get_env_or_default("TARGET_TRIPLE" as *byte, "" as *byte);
    var target_flags: &byte = get_env_or_default("CC_TARGET_FLAGS" as *byte, "" as *byte);
    var target_flags_buffer: [byte: 256] = [];

    if target_flags[0] == 0 && target_triple[0] != 0 {
        const target_flags_len: i32 = snprintf(&target_flags_buffer[0], 256, "-target %s" as *byte, target_triple as *byte);
        if target_flags_len > 0 && target_flags_len < 256 {
            target_flags = &target_flags_buffer[0];
        }
    }

    if is_nostdlib != 0 {
        if strcmp(target_os as *byte, "linux" as *byte) != 0 {
            fprintf(libc.stderr, "错误：当前 build/run/test 的 --nostdlib 路径仅支持 Linux 目标，当前 TARGET_OS=%s\n" as *byte, target_os as *byte);
            return 1;
        }
        if target_flags[0] != 0 {
            cmd_len = snprintf(&cmd[0], 4096, "%s %s %s -nostdlib -static %s -o %s -lgcc %s" as *byte, cc_driver as *byte, target_flags as *byte, cflags as *byte, c_file as *byte, output as *byte, ldflags as *byte);
        } else {
            cmd_len = snprintf(&cmd[0], 4096, "%s %s -nostdlib -static %s -o %s -lgcc %s" as *byte, cc_driver as *byte, cflags as *byte, c_file as *byte, output as *byte, ldflags as *byte);
        }
    } else {
        if target_flags[0] != 0 {
            cmd_len = snprintf(&cmd[0], 4096, "%s %s %s %s -o %s %s" as *byte, cc_driver as *byte, target_flags as *byte, cflags as *byte, c_file as *byte, output as *byte, ldflags as *byte);
        } else {
            cmd_len = snprintf(&cmd[0], 4096, "%s %s %s -o %s %s" as *byte, cc_driver as *byte, cflags as *byte, c_file as *byte, output as *byte, ldflags as *byte);
        }
    }

    if cmd_len <= 0 || cmd_len >= 4096 {
        fprintf(libc.stderr, "错误：构建宿主链接命令失败\n" as *byte);
        return 1;
    }

    fprintf(libc.stderr, "信息：调用宿主工具链链接：%s\n" as *byte, &cmd[0] as *byte);
    const result: i32 = system(&cmd[0] as *byte);
    if result != 0 {
        fprintf(libc.stderr, "错误：宿主工具链链接失败，返回码：%d\n" as *byte, result);
        return 1;
    }
    return 0;
}

// 主编译函数：词法 → 语法 → AST 合并 → 类型检查 → 代码生成
// 支持目录输入和自动依赖收集
// output_path_override: 如果非 null，使用此路径替代 get_argv(output_file_index)
// is_nostdlib: 生成 _start 入口（无 C 标准库链接）
// stack_size: 堆栈大小（KB），0 表示默认
fn compile_files(
    input_file_indices: &i32,
    input_file_count: i32,
    output_file_index: i32,
    backend: BackendType,
    emit_line_directives: i32,
    enable_safety_proof: i32,
    opt_level: i32,
    output_path_override: &byte,
    is_nostdlib: i32,
    stack_size: i32,
    split_c_dir: &byte,
    async_frame_heap_fallback: i32
) i32 {
    
    // 初始化临时 Arena（用于依赖收集，使用全局缓冲区避免栈溢出）
    var temp_arena: CompilerArena = CompilerArena {
        buffer: null,
        size: 0 as usize,
        offset: 0 as usize,
        first_chunk: null,
        current_chunk: null,
        total_allocated: 0 as usize,
    };
    compiler_arena_init(&temp_arena, &temp_arena_buffer[0], 16 * 1024 * 1024);
    
    // 获取 UYA_ROOT 和编译器目录
    var uya_root_base: [byte: PATH_MAX] = [];
    const argv0: *byte = get_argv(0);
    if argv0 == null {
        fprintf(libc.stderr, "错误: 无法获取程序路径\n" as *byte);
        return 1;
    }
    if get_uya_root(argv0 as &byte, &uya_root_base[0] as &byte, PATH_MAX) != 0 {
        fprintf(libc.stderr, "错误: 无法获取 UYA_ROOT 目录\n" as *byte);
        return 1;
    }
    
    // 标准库在编译器所在目录的上一级目录的 lib/ 下
    // 例如：编译器在 /path/bin/uya，标准库在 /path/lib/
    // 与 C 编译器一致：若 UYA_ROOT 已指向 lib 目录则直接使用，否则追加 /lib/
    var base_len: usize = strlen(&uya_root_base[0]);
    if base_len > 1 && uya_root_base[base_len - 1] == 47 {  // '/'
        uya_root_base[base_len - 1] = 0;
        base_len = base_len - 1;
    }
    const last_slash: *byte = strrchr(&uya_root_base[0], 47);
    var already_lib: i32 = 0;
    if last_slash != null && strcmp(last_slash, "/lib" as *byte) == 0 {
        already_lib = 1;
    }
    if already_lib == 0 && last_slash != null && strcmp(last_slash, "/bin" as *byte) == 0 {
        const slash_idx_tmp: !usize = (last_slash as i64 - &uya_root_base[0] as i64) as! usize;
        var slash_idx: usize = slash_idx_tmp.value;
        uya_root_base[slash_idx] = 0;
    }
    var uya_root_buffer: [byte: PATH_MAX] = [];
    var lib_len: i32 = 0;
    if already_lib != 0 {
        lib_len = snprintf(&uya_root_buffer[0] as &byte, PATH_MAX, "%s/" as *byte, &uya_root_base[0] as &byte);
    } else {
        lib_len = snprintf(&uya_root_buffer[0] as &byte, PATH_MAX, "%s/lib/" as *byte, &uya_root_base[0] as &byte);
    }
    if lib_len <= 0 || lib_len >= PATH_MAX {
        fprintf(libc.stderr, "错误: UYA_ROOT 路径过长\n" as *byte);
        return 1;
    }
    
    // 处理输入：如果是目录，查找包含 main 的文件；如果是文件，检查是否包含 main
    // 使用全局变量避免栈溢出
    var resolved_files: [&byte: MAX_INPUT_FILES] = resolved_files_global;
    var resolved_count: i32 = 0;
    var project_root_buffer: [byte: PATH_MAX] = [];
    var project_root: &byte = null;
    // 使用全局变量避免栈溢出（262KB 太大），直接使用全局数组
    // var main_file_paths: [[byte: PATH_MAX]: MAX_INPUT_FILES] = [];
    
    var i: i32 = 0;
    while i < input_file_count {
        const idx_i: i32 = input_file_indices[i];
        const input_path: *byte = get_argv(idx_i);
        if input_path == null {
            fprintf(libc.stderr, "错误: 无法获取输入文件路径（索引 %d）\n" as *byte, idx_i);
            return 1;
        }
        const input: &byte = input_path as &byte;
        
        const is_dir_result: i32 = is_directory(input);
        if is_dir_result != 0 {
            // 是目录，查找包含 main 的文件
            var main_files: [&byte: MAX_INPUT_FILES] = [];
            var main_count: i32 = 0;
            if find_main_files_in_dir(input, &main_files[0], &main_file_paths_global[0], MAX_INPUT_FILES, &main_count) != 0 {
                fprintf(libc.stderr, "错误: 无法读取目录 '%s'\n" as *byte, input_path);
                return 1;
            }
            if main_count == 0 {
                fprintf(libc.stderr, "错误: 目录 '%s' 中未找到包含 main 函数的文件\n" as *byte, input_path);
                return 1;
            }
            if main_count > 1 {
                fprintf(libc.stderr, "错误: 目录 '%s' 中有多个文件包含 main 函数:\n" as *byte, input_path);
                var j: i32 = 0;
                while j < main_count {
                    fprintf(libc.stderr, "  %s\n" as *byte, main_files[j] as *byte);
                    j = j + 1;
                }
                return 1;
            }
            resolved_files[resolved_count] = main_files[0];
            resolved_count = resolved_count + 1;
            // 设置项目根目录
            if project_root == null {
                const input_len: usize = strlen(input_path);
                if input_len < PATH_MAX - 1 {
                    strcpy(&project_root_buffer[0], input_path);
                    if project_root_buffer[input_len - 1] != 47 {
                        project_root_buffer[input_len] = 47 as byte;
                        project_root_buffer[input_len + 1] = 0 as byte;
                    }
                    project_root = &project_root_buffer[0] as &byte;
                } else {
                    project_root = input;
                }
            }
        } else if is_file(input) != 0 {
            // 检查是否已在 resolved_files 中（避免重复添加）
            var already_resolved: i32 = 0;
            var j: i32 = 0;
            while j < resolved_count {
                if resolved_files[j] != null && paths_equal(resolved_files[j], input) != 0 {
                    already_resolved = 1;
                    break;
                }
                j = j + 1;
            }
            if already_resolved != 0 {
                i = i + 1;
                continue;
            }
            
            // 是文件，检查是否包含 main
            if detect_main_function(input) != 0 {
                resolved_files[resolved_count] = input;
                resolved_count = resolved_count + 1;
                // 设置项目根目录（文件所在目录）
                if project_root == null {
                    const input_last_slash: *byte = strrchr(input_path, 47);
                    if input_last_slash != null {
                        const dir_len: usize = ptr_diff(input_last_slash, input) + 1;
                        if dir_len < PATH_MAX {
                            memcpy(&project_root_buffer[0], input_path, dir_len);
                            project_root_buffer[dir_len] = 0 as byte;
                            project_root = &project_root_buffer[0] as &byte;
                        } else {
                            strcpy(&project_root_buffer[0], "./" as *byte);
                            project_root = &project_root_buffer[0] as &byte;
                        }
                    } else {
                        strcpy(&project_root_buffer[0], "./" as *byte);
                        project_root = &project_root_buffer[0] as &byte;
                    }
                }
            } else {
                // 多文件模式下，允许某些文件不包含 main（它们是库文件）
                // 但如果这是唯一输入文件�����则必须包含 main
                if input_file_count == 1 {
                    fprintf(libc.stderr, "错误: 文件 '%s' 不包含 main 函数\n" as *byte, input_path);
                    return 1;
                }
                // 多文件模式：将不包含 main 的文件也加入列表（作为���文件）
                resolved_files[resolved_count] = input;
                resolved_count = resolved_count + 1;
            }
        } else {
            fprintf(libc.stderr, "错误: '%s' 既不是文件也不是目录\n" as *byte, input_path);
            return 1;
        }
        i = i + 1;
    }
    
    if resolved_count == 0 {
        fprintf(libc.stderr, "错误: 未找到包含 main 函数的文件\n" as *byte);
        return 1;
    }
    
    // 检测是否有 export fn main 或 test 语句，如果有则自动添加 entry.uya
    // 返回值：0=无main/test，1=fn main 或 test，2=export fn main，3=export extern fn main
    var has_export_main: i32 = 0;
    var has_test_stmt: i32 = 0;
    var has_export_extern_main: i32 = 0;
    i = 0;
    while i < resolved_count {
        const main_type: i32 = detect_main_function(resolved_files[i]);
        if main_type == 3 {
            has_export_extern_main = 1;
        } else if main_type == 2 {
            has_export_main = 1;
        } else if main_type == 1 {
            has_test_stmt = 1;
        }
        i = i + 1;
    }
    
    // 如果有 export fn main 或 test 语句（但没有 export fn main），自动添加 std.runtime.entry
    // test 模式下需要 entry.uya 来提供 C main 入口
    if has_export_extern_main == 0 && (has_export_main != 0 || has_test_stmt != 0) {
        var entry_path: [byte: PATH_MAX] = [];
        const entry_len: i32 = snprintf(&entry_path[0], PATH_MAX, "%sstd/runtime/entry/entry.uya" as *byte, &uya_root_buffer[0] as *byte);
        if entry_len > 0 && entry_len < PATH_MAX {
            if is_file(&entry_path[0] as &byte) != 0 {
                var already_in_list: i32 = 0;
                var j: i32 = 0;
                while j < resolved_count {
                    if resolved_files[j] != null && paths_equal(resolved_files[j], &entry_path[0] as &byte) != 0 {
                        already_in_list = 1;
                        break;
                    }
                    j = j + 1;
                }
                if already_in_list == 0 && resolved_count < MAX_INPUT_FILES {
                    const entry_copy: &byte = compiler_arena_alloc(&temp_arena, entry_len + 1) as &byte;
                    if entry_copy != null {
                        var entry_insert_idx: i32 = 0;
                        while entry_insert_idx < resolved_count {
                            if detect_main_function(resolved_files[entry_insert_idx]) == 0 {
                                break;
                            }
                            entry_insert_idx = entry_insert_idx + 1;
                        }
                        var move_idx: i32 = resolved_count;
                        while move_idx > entry_insert_idx {
                            resolved_files[move_idx] = resolved_files[move_idx - 1];
                            move_idx = move_idx - 1;
                        }
                        strcpy(entry_copy as *byte, &entry_path[0]);
                        resolved_files[entry_insert_idx] = entry_copy;
                        resolved_count = resolved_count + 1;
                    }
                }
            }
        }
    }
    
    // 自动收集模块依赖
    // 只对包含 main 的文件进行依赖收集，库文件已经在列表中，不需要进行依赖收集
    var all_files: [&byte: MAX_INPUT_FILES] = [];
    var all_file_count: i32 = resolved_count;
    i = 0;
    while i < resolved_count {
        all_files[i] = resolved_files[i];
        i = i + 1;
    }
    
    // 收集依赖（只对包含 main 的文件进行依赖收集）
    var processed_files: [&byte: MAX_INPUT_FILES] = [];
    var processed_count: i32 = 0;
    
    // 找出包含 main 的文件（入口文件）
    var main_files: [&byte: MAX_INPUT_FILES] = [];
    var main_file_count: i32 = 0;
    i = 0;
    while i < resolved_count {
        if detect_main_function(resolved_files[i]) != 0 {
            main_files[main_file_count] = resolved_files[i];
            main_file_count = main_file_count + 1;
        }
        i = i + 1;
    }
    
    // 依赖收集策略：对所有输入文件进行依赖收集（与 C 版一致）
    i = 0;
    while i < all_file_count {
        const new_count: i32 = collect_module_dependencies(
            all_files[i],
            &all_files[0],
            all_file_count,
            MAX_INPUT_FILES,
            &processed_files[0],
            &processed_count,
            MAX_INPUT_FILES,
            project_root,
            &uya_root_buffer[0] as &byte,
            &temp_arena
        );
        if new_count < 0 {
            fprintf(libc.stderr, "错误: 收集模块依赖失败: %s\n" as *byte, all_files[i] as *byte);
            return 1;
        }
        all_file_count = new_count;
        i = i + 1;
    }
    
    fprintf(libc.stderr, "=== 开始编译 ===\n" as *byte);
    fprintf(libc.stderr, "输入文件数量: %d (包含依赖)\n" as *byte, all_file_count);
    i = 0;
    while i < all_file_count {
        fprintf(libc.stderr, "  %d: %s\n" as *byte, i, all_files[i] as *byte);
        i = i + 1;
    }
    const output_file: *byte = get_argv(output_file_index);
    // 如果有覆盖路径，使用覆盖路径
    var actual_output: *byte = output_file;
    if output_path_override != null {
        actual_output = output_path_override as *byte;
    }
    fprintf(libc.stderr, "输出文件: %s\n" as *byte, actual_output);
    if project_root != null {
        fprintf(libc.stderr, "项目根目录: %s\n" as *byte, project_root as *byte);
    }
    fprintf(libc.stderr, "UYA_ROOT: %s\n" as *byte, &uya_root_buffer[0]);
    var module_name: *byte = "(unknown)" as *byte;
    if all_file_count > 0 {
        module_name = all_files[0] as *byte;
    }
    fprintf(libc.stderr, "=== 词法/语法分析 ===\n" as *byte);
    var backend_str: *byte = "LLVM" as *byte;
    if backend == BackendType.BACKEND_C99 {
        backend_str = "C99" as *byte;
    }
    fprintf(libc.stderr, "后端类型: %s\n" as *byte, backend_str);

    // 初始化编译统计
    var stats: CompileStats = CompileStats { parse_time_ms: 0, merge_time_ms: 0, check_time_ms: 0, opt_time_ms: 0, codegen_time_ms: 0, total_time_ms: 0, file_count: 0, ast_nodes: 0 };
    stats.file_count = all_file_count;  // 记录文件数

    // 计时变量
    const start_time: i64 = clock();
    var parse_end_time: i64 = 0;
    var merge_end_time: i64 = 0;
    var check_end_time: i64 = 0;
    var codegen_end_time: i64 = 0;

    var arena: CompilerArena = CompilerArena { buffer: null, size: 0 as usize, offset: 0 as usize, first_chunk: null, current_chunk: null, total_allocated: 0 as usize };
    compiler_arena_init(&arena, &arena_buffer[0], ARENA_BUFFER_SIZE as usize);

    var programs: [&ASTNode: MAX_INPUT_FILES] = [];

    i = 0;
    while i < all_file_count {
        const input_path: *byte = all_files[i] as *byte;
        const file_size: i32 = read_file_content(input_path as &byte, &file_buffer[0], FILE_BUFFER_SIZE as usize);
        if file_size < 0 {
            fprintf(libc.stderr, "错误: 无法读取文件 '%s' (可能文件太大或不存在)\n" as *byte, input_path);
            return 1;
        }
        var lexer: Lexer = Lexer {
            buffer: [],
            buffer_size: 0 as usize,
            position: 0 as usize,
            line: 0,
            column: 0,
            filename: null,
            has_error: 0,
            string_mode: 0,
            raw_string_mode: 0,
            interp_depth: 0,
            pending_interp_open: 0,
            reading_spec: 0,
            has_seen_interp_in_string: 0,
            string_text_buffer: [],
            string_text_len: 0,
        };
        const input_path_ref: &byte = input_path as &byte;
        if lexer_init(&lexer, &file_buffer[0], file_size as usize, input_path_ref, &arena) != 0 {
            fprintf(libc.stderr, "错误: Lexer 初始化失败: %s\n" as *byte, input_path);
            return 1;
        }
        var parser: Parser = Parser {
            lexer: null,
            current_token: null,
            arena: null,
            context: ParserContext.PARSER_CONTEXT_NORMAL,
            pending_greater_token: null,
            saw_use_std: 0,
        };
        if parser_init(&parser, &lexer, &arena) != 0 {
            fprintf(libc.stderr, "错误: Parser 初始化失败: %s\n" as *byte, input_path);
            return 1;
        }
        const ast: &ASTNode = parser_parse(&parser);
        if ast == null {
            fprintf(libc.stderr, "错误: 语法分析失败: %s\n" as *byte, input_path);
            return 1;
        }
        if ast.type != ASTNodeType.AST_PROGRAM {
            fprintf(libc.stderr, "错误: 解析结果不是程序节点: %s\n" as *byte, input_path);
            return 1;
        }
        // 检查词法分析错误（如未闭合块注释）
        if lexer.has_error != 0 {
            fprintf(libc.stderr, "错误: 语法分析失败: %s\n" as *byte, input_path);
            return 1;
        }
        programs[i] = ast;
        fprintf(libc.stderr, "  解析完成: %s\n" as *byte, input_path);
        i = i + 1;
    }
    parse_end_time = clock();
    fprintf(libc.stderr, "=== 词法/语法分析完成，共 %d 个文件 ===\n" as *byte, all_file_count);

    fprintf(libc.stderr, "=== AST 合并阶段 ===\n" as *byte);
    var merged_ast: &ASTNode = ast_merge_programs(programs, all_file_count, &arena);
    if merged_ast == null {
        fprintf(libc.stderr, "错误: AST 合并失败\n" as *byte);
        return 1;
    }
    merged_ast = ast_flatten_nested_program_decls(merged_ast, &arena);
    if merged_ast == null {
        fprintf(libc.stderr, "错误: AST 展平失败\n" as *byte);
        return 1;
    }
    merge_end_time = clock();
    fprintf(libc.stderr, "AST 合并完成，共 %d 个声明\n" as *byte, merged_ast.program_decl_count);

    fprintf(libc.stderr, "=== 类型检查阶段 ===\n" as *byte);
    const void_type: Type = Type {
        kind: TypeKind.TYPE_VOID,
        data: TypeData.named(null as &byte),
        enum_name: null,
        interface_name: null,
        interface_type_args: null,
        interface_type_arg_count: 0,
        struct_name: null,
        union_name: null,
        pointer_to: null,
        is_ffi_pointer: 0,
        element_type: null,
        array_size: 0,
        slice_element_type: null,
        slice_len: 0,
        slice_element_is_const: 0,
        tuple_element_types: null,
        tuple_count: 0,
        error_union_payload_type: null,
        error_error_id: 0,
        atomic_inner_type: null,
        generic_param_name: null,
        struct_type_args: null,
        struct_type_arg_count: 0,
        union_type_args: null,
        union_type_arg_count: 0,
    };
    var checker: TypeChecker = TypeChecker {
        arena: null,
        symbol_table: SymbolTable { slots: [], count: 0 },
        function_table: FunctionTable { slots: [], count: 0 },
        module_table: ModuleTable { slots: [], count: 0 },
        import_table: ImportTable { slots: [], count: 0 },
        string_pool: StringPool { buckets: [], count: 0 },
        scope_level: 0,
        loop_depth: 0,
        program_node: null,
        error_count: 0,
        default_filename: null,
        current_return_type: void_type,
        in_function: 0,
        in_defer_or_errdefer: 0,
        current_function_decl: null,
        error_names: [],
        error_hashes: [],
        error_name_count: 0,
        moved_names: [],
        moved_count: 0,
        project_root_dir: null,
        uya_root_dir: null,
        current_type_params: null,
        current_type_param_count: 0,
        mono_instances: [],
        mono_instance_count: 0,
        constraint_var_names: [],
        constraint_ops: [],
        constraint_values: [],
        constraint_count: 0,
        pointer_nonnull_names: [],
        pointer_nonnull_count: 0,
        pointer_nullable_names: [],
        pointer_nullable_count: 0,
        enable_safety_proof: 0,
        container_mode: 0,
        proof_step_limit: 0,
        proof_step_count: 0,
        scope_heads: [],
        async_call_edge_from: [],
        async_call_edge_to: [],
        async_call_edge_count: 0,
        fn_call_edge_from: [],
        fn_call_edge_to: [],
        fn_call_edge_count: 0,
        fn_root_decls: [],
        fn_root_count: 0,
        reachable_fn_decls: [],
        reachable_fn_decl_count: 0,
        reachability_visit_count: 0,
        reachability_visit_cache: [],
        async_frame_metas: [],
        async_frame_meta_count: 0,
    };
    var default_filename: *byte = "(unknown)" as *byte;
    if all_file_count > 0 {
        default_filename = all_files[0] as *byte;
    }
    if checker_init(&checker, &arena, default_filename as &byte) != 0 {
        fprintf(libc.stderr, "错误: TypeChecker 初始化失败\n" as *byte);
        return 1;
    }
    // 设置 UYA_ROOT 目录，供 checker 识别标准库模块
    checker.uya_root_dir = &uya_root_buffer[0] as &byte;
    // 用 CLI 推导的项目根（与依赖收集一致）初始化 module 路径前缀，避免仅靠「首个 main 文件名」
    // 得到空字符串或标准库 entry 目录，进而误判 extract_module_path / use 导出解析。
    if project_root != null {
        const pr_len: usize = strlen(project_root as *byte);
        if pr_len > 0 {
            var need_slash: i32 = 0;
            if project_root[pr_len - 1] != 47 as byte && project_root[pr_len - 1] != 92 as byte {
                need_slash = 1;
            }
            const alloc_len: usize = pr_len + (need_slash as usize) + 1 as usize;
            const pr_copy: &u8 = compiler_arena_alloc(&arena, alloc_len) as &u8;
            if pr_copy != null {
                memcpy(pr_copy as *void, project_root as *void, pr_len);
                if need_slash != 0 {
                    pr_copy[pr_len] = 47 as u8;
                    pr_copy[pr_len + 1] = 0 as u8;
                } else {
                    pr_copy[pr_len] = 0 as u8;
                }
                checker.project_root_dir = pr_copy as &byte;
            }
        }
    }
    // 设置内存安全证明开关
    checker.enable_safety_proof = enable_safety_proof;
    checker.container_mode = g_container_mode;

    if checker_check(&checker, merged_ast) != 0 {
        fprintf(libc.stderr, "错误: 类型检查失败（错误数量: %d）\n" as *byte, checker_get_error_count(&checker));
        const err_msg: &byte = get_last_checker_error();
        if err_msg != null {
            fprintf(libc.stderr, "最后错误: %s\n" as *byte, err_msg as *byte);
        }
        return 1;
    }
    if checker_get_error_count(&checker) > 0 {
        fprintf(libc.stderr, "错误: 类型检查失败（错误数量: %d）\n" as *byte, checker_get_error_count(&checker));
        const err_msg: &byte = get_last_checker_error();
        if err_msg != null {
            fprintf(libc.stderr, "最后错误: %s\n" as *byte, err_msg as *byte);
        }
        return 1;
    }
    check_end_time = clock();
    fprintf(libc.stderr, "类型检查通过\n" as *byte);
    if checker.program_node != null && checker.program_node.type == ASTNodeType.AST_PROGRAM {
        merged_ast = checker.program_node;
    }
    checker_reset_reachability_visit_cache(&checker);
    seed_function_reachability_roots(&checker, merged_ast);
    checker_compute_function_reachability(&checker);
    const debug_reach_env: *byte = getenv("UYA_DEBUG_REACHABILITY" as *byte);
    if debug_reach_env != null && debug_reach_env[0] != 0 as byte {
        fprintf(libc.stderr, "可达性调试: roots=%d, reachable=%d, edges=%d\n" as *byte,
            checker.fn_root_count, checker.reachable_fn_decl_count, checker.fn_call_edge_count);
        var dbg_i: i32 = 0;
        while dbg_i < checker.reachable_fn_decl_count && dbg_i < 20 {
            const dbg_decl: &ASTNode = checker.reachable_fn_decls[dbg_i];
            if dbg_decl != null && dbg_decl.fn_decl_name != null {
                fprintf(libc.stderr, "  reachable[%d]=%s (body=%d export=%d extern=%d)\n" as *byte,
                    dbg_i, dbg_decl.fn_decl_name as *byte, dbg_decl.fn_decl_body != null, dbg_decl.fn_decl_is_export, dbg_decl.fn_decl_is_extern);
            }
            dbg_i = dbg_i + 1;
        }
        const dbg_parse_args: &ASTNode = checker_find_reachable_fn_decl_by_name(&checker, "parse_args" as *byte);
        const dbg_generate_libc: &ASTNode = checker_find_reachable_fn_decl_by_name(&checker, "generate_libc" as *byte);
        const dbg_align_size: &ASTNode = checker_find_reachable_fn_decl_by_name(&checker, "align_size" as *byte);
        const dbg_next_macro_hygiene_expansion_id: &ASTNode = checker_find_reachable_fn_decl_by_name(&checker, "next_macro_hygiene_expansion_id" as *byte);
        const dbg_c99_utils_cache_ensure: &ASTNode = checker_find_reachable_fn_decl_by_name(&checker, "c99_utils_cache_ensure" as *byte);
        fprintf(libc.stderr, "  query parse_args reachable=%d\n" as *byte, checker_is_function_reachable(&checker, dbg_parse_args));
        fprintf(libc.stderr, "  query generate_libc reachable=%d\n" as *byte, checker_is_function_reachable(&checker, dbg_generate_libc));
        fprintf(libc.stderr, "  query align_size reachable=%d\n" as *byte, checker_is_function_reachable(&checker, dbg_align_size));
        fprintf(libc.stderr, "  query next_macro_hygiene_expansion_id reachable=%d\n" as *byte,
            checker_is_function_reachable(&checker, dbg_next_macro_hygiene_expansion_id));
        fprintf(libc.stderr, "  query c99_utils_cache_ensure reachable=%d\n" as *byte,
            checker_is_function_reachable(&checker, dbg_c99_utils_cache_ensure));
    }

    // ===== 优化阶段（v0.7.3 新增）=====
    var opt_end_time: i64 = 0;

    // 创建优化配置
    var opt_config: OptimizationConfig = create_optimization_config(opt_level);
    opt_config.verbose = 1;  // 启用详细输出
    
    if opt_level > 0 {
        fprintf(libc.stderr, "\n=== 优化阶段 (级别: %d) ===\n" as *byte, opt_level);
        
        // 执行优化
        const optimized_ast: &ASTNode = optimize_program(&checker, merged_ast, opt_config);
        opt_end_time = clock();
        
        // 打印优化统计
        const opt_stats: OptimizationStats = get_optimization_stats();
        fprintf(libc.stderr, "常量折叠: %d\n" as *byte, opt_stats.constant_folded);
        fprintf(libc.stderr, "死代码消除: %d\n" as *byte, opt_stats.dead_code_eliminated);
        fprintf(libc.stderr, "证明优化: %d\n" as *byte, opt_stats.proof_optimized);
        fprintf(libc.stderr, "函数内联: %d\n" as *byte, opt_stats.inlined_functions);
        fprintf(libc.stderr, "循环展开: %d\n" as *byte, opt_stats.loops_unrolled);
    } else {
        opt_end_time = clock();
    }

    fprintf(libc.stderr, "\n=== 代码生成阶段 ===\n" as *byte);
    fprintf(libc.stderr, "模块名: %s\n" as *byte, module_name);

    // C99 后端：生成 C 源代码（与 C 版本保持一致，直接使用 C99 后端）
    var out_file: *void = null;
    if split_c_dir == null || split_c_dir[0] == 0 as byte {
        out_file = fopen(actual_output, "w" as *byte);
        if out_file == null {
            fprintf(libc.stderr, "错误: 无法打开输出文件 '%s'\n" as *byte, actual_output);
            return 1;
        }
    }
    var c99_codegen: C99CodeGenerator = C99CodeGenerator { };
    var split_mirror_flag: i32 = 0;
    if split_c_dir != null && split_c_dir[0] != 0 as byte {
        split_mirror_flag = 1;
        const smg: *byte = getenv("UYA_SPLIT_C_MIRROR" as *byte);
        if smg != null && smg[0] != 0 as byte {
            if strcmp(smg as *byte, "0" as *byte) == 0 ||
               strcmp(smg as *byte, "false" as *byte) == 0 ||
               strcmp(smg as *byte, "no" as *byte) == 0 ||
               strcmp(smg as *byte, "off" as *byte) == 0 {
                split_mirror_flag = 0;
            }
        }
    }
    if c99_codegen_new(&c99_codegen, &arena, out_file as &void, module_name as &byte, emit_line_directives, is_nostdlib, stack_size, split_c_dir, split_mirror_flag, async_frame_heap_fallback) != 0 {
        fprintf(libc.stderr, "错误: C99CodeGenerator 初始化失败\n" as *byte);
        if out_file != null {
            fclose(out_file);
        }
        return 1;
    }
    // 设置单态化实例（从 TypeChecker 传入）
    c99_codegen_set_mono_instances(&c99_codegen, &checker);
    c99_codegen_set_reachable_functions(&c99_codegen, &checker);
    c99_codegen.container_mode = g_container_mode;
    if c99_codegen_generate(&c99_codegen, merged_ast, actual_output as &byte) != 0 {
        fprintf(libc.stderr, "错误: C99 代码生成失败\n" as *byte);
        c99_codegen_free(&c99_codegen);
        if out_file != null {
            fclose(out_file);
        }
        return 1;
    }
    c99_codegen_free(&c99_codegen);
    if out_file != null {
        fclose(out_file);
    }
    codegen_end_time = clock();

    // 计算各阶段耗时（毫秒）
    stats.parse_time_ms = (parse_end_time - start_time) * 1000 / CLOCKS_PER_SEC;
    stats.merge_time_ms = (merge_end_time - parse_end_time) * 1000 / CLOCKS_PER_SEC;
    stats.check_time_ms = (check_end_time - merge_end_time) * 1000 / CLOCKS_PER_SEC;
    stats.codegen_time_ms = (codegen_end_time - opt_end_time) * 1000 / CLOCKS_PER_SEC;
    stats.total_time_ms = (codegen_end_time - start_time) * 1000 / CLOCKS_PER_SEC;
    
    // 输出编译统计
    fprintf(libc.stderr, "\n=== 编译统计 ===\n" as *byte);
    fprintf(libc.stderr, "文件数: %d\n" as *byte, stats.file_count);
    fprintf(libc.stderr, "解析耗时: %ld ms\n" as *byte, stats.parse_time_ms);
    fprintf(libc.stderr, "合并耗时: %ld ms\n" as *byte, stats.merge_time_ms);
    fprintf(libc.stderr, "检查耗时: %ld ms\n" as *byte, stats.check_time_ms);
    if opt_level > 0 {
        const opt_time_ms: i64 = (opt_end_time - check_end_time) * 1000 / CLOCKS_PER_SEC;
        fprintf(libc.stderr, "优化耗时: %ld ms\n" as *byte, opt_time_ms);
    }
    fprintf(libc.stderr, "生成耗时: %ld ms\n" as *byte, stats.codegen_time_ms);
    fprintf(libc.stderr, "总耗时: %ld ms\n" as *byte, stats.total_time_ms);
    
    fprintf(libc.stderr, "\n代码生成完成: %s\n" as *byte, actual_output);

    return 0;
}

// 程序入口（export fn main 编译为 main_main，由 std.runtime.entry 的 C main 调用）
export fn main() i32 {

    var input_file_indices: [i32: 64] = [];
    var input_file_count: i32 = 0;
    var output_file_index: i32 = -1;
    var backend: BackendType = BackendType.BACKEND_LLVM;
    var emit_line_directives: i32 = 0;
    var enable_safety_proof: i32 = 1;
    var opt_level: i32 = 1;
    var outlibc_index: i32 = -1;
    var command: CommandType = CommandType.COMMAND_BUILD;
    var run_arg_start: i32 = -1;
    var is_nostdlib: i32 = 0;
    var stack_size: i32 = 65536;  // 默认 64MB 堆栈
    var async_frame_heap_fallback: i32 = 0;

    // 临时缓冲区用于自动生成输出路径
    var auto_output_path: [byte: PATH_MAX] = [];

    if parse_args(&command, &input_file_indices[0], &input_file_count, &output_file_index, &backend, &emit_line_directives, &enable_safety_proof, &opt_level, &outlibc_index, &run_arg_start, &is_nostdlib, &stack_size, &async_frame_heap_fallback) != 0 {
        return 1;
    }
    // parse_args 中 stack_size=0 表示未传 --stack-size。编译器进程须尽快抬高主线程栈（与默认 65536 KB 一致），否则大依赖编译易栈溢出（段错误）。
    // 传给 compile_files 的 stack_size 仍保留 0：不在生成 C 里注入 setrlimit/resource.h（曾与生成类型、系统头冲突）；run/test 子进程由 sh ulimit；显式 --stack-size 仅保留文件头提示注释。
    var eff_compiler_stack_kb: i32 = stack_size;
    if eff_compiler_stack_kb <= 0 {
        eff_compiler_stack_kb = 65536;
    }
    set_process_stack_limit_bytes(eff_compiler_stack_kb as u64 * 1024);
    if g_split_c_dir_active == 0 && g_split_c_disabled_cli == 0 {
        const env_split: *byte = getenv("UYA_SPLIT_C_DIR" as *byte);
        if env_split != null && env_split[0] != 0 {
            const el: usize = strlen(env_split);
            if el > 0 && el < PATH_MAX - 1 {
                strcpy(&g_split_c_dir[0] as *byte, env_split);
                g_split_c_dir[el] = 0 as byte;
                g_split_c_dir_active = 1;
            }
        }
    }

    // --outlibc 模式
    if command == CommandType.COMMAND_OUTLIBC {
        const outlibc_path: *byte = get_argv(outlibc_index);
        if outlibc_path == null {
            fprintf(libc.stderr, "错误: 无法获取 --outlibc 参数\n" as *byte);
            return 1;
        }
        const result: i32 = generate_libc(outlibc_path as &byte);
        return result;
    }

    if command == CommandType.COMMAND_PACK_IMAGE {
        if input_file_count != 1 {
            fprintf(libc.stderr, "错误: pack-image 只接受一个 .pobj 输入文件\n" as *byte);
            return 1;
        }
        if output_file_index < 0 {
            fprintf(libc.stderr, "错误: pack-image 需要 -o 指定输出 .uapp 路径\n" as *byte);
            return 1;
        }
        const pobj_path: *byte = get_argv(input_file_indices[0]);
        const uapp_path: *byte = get_argv(output_file_index);
        if pobj_path == null || uapp_path == null {
            fprintf(libc.stderr, "错误: 无法获取 pack-image 输入或输出路径\n" as *byte);
            return 1;
        }
        const pack_result: i32 = pack_microapp_pobj_to_uapp(pobj_path as &byte, uapp_path as &byte);
        if pack_result != 0 {
            return pack_result;
        }
        fprintf(libc.stderr, "pack-image 完成: %s -> %s\n" as *byte, pobj_path, uapp_path);
        return 0;
    }

    // fmt 命令：格式化代码文件
    if command == CommandType.COMMAND_FMT {
        const fmt_result: i32 = fmt_main();
        return fmt_result;
    }

    // build 命令：如果没有指定 -o，使用默认输出 a.out
    if command == CommandType.COMMAND_BUILD && output_file_index < 0 {
        if host_fill_temp_c_compile_path(&auto_output_path[0], PATH_MAX) != 0 {
            fprintf(libc.stderr, "错误：无法生成临时输出路径\n" as *byte);
            return 1;
        }
        output_file_index = -2;  // 标记为自动生成的路径
        backend = BackendType.BACKEND_C99;  // build 模式默认使用 C99 后端
    }

    // run 和 test 命令：自动生成输出路径
    if (command == CommandType.COMMAND_RUN || command == CommandType.COMMAND_TEST) && output_file_index < 0 {
        // 从输入文件名生成输出路径
        const input_path: *byte = get_argv(input_file_indices[0]);
        if input_path == null {
            fprintf(libc.stderr, "错误: 无法获取输入文件路径\n" as *byte);
            return 1;
        }
        
        if host_fill_temp_c_compile_path(&auto_output_path[0], PATH_MAX) != 0 {
            fprintf(libc.stderr, "错误: 无法生成临时输出路径\n" as *byte);
            return 1;
        }
        output_file_index = -2;  // 标记为自动生成的路径
        backend = BackendType.BACKEND_C99;  // run/test 模式默认使用 C99 后端
    }

    // run/test 紧接着就要调用宿主工具链并执行产物，需要稳定的单文件 C 路径。
    // 默认 split-C 会让 auto_output_path 只成为一个占位路径，并让后续 link/run 依赖额外的
    // 子 make 环境；microapp loader 的递归 `run` 也会因此拿不到真正生成的可执行文件。
    // split-C 仍可通过 build 路径使用，run/test 统一固定为单文件 C。
    if command == CommandType.COMMAND_RUN || command == CommandType.COMMAND_TEST {
        g_split_c_dir_active = 0;
        g_split_c_disabled_cli = 1;
        g_split_c_dir[0] = 0 as byte;
    }
    
    // build 命令：如果指定了非 .c 输出，需要生成临时 C 文件
    var user_output_path: *byte = null;  // 用户指定的输出路径（用于宿主工具链链接）
    if command == CommandType.COMMAND_BUILD && output_file_index >= 0 {
        const out_path: *byte = get_argv(output_file_index);
        if out_path != null {
            // microapp 模式需要保留用户显式输出路径，哪怕是 .c
            if g_app_mode_microapp != 0 {
                user_output_path = out_path;
            }
            if is_c_output(out_path as &byte) == 0 {
                // 输出不是 .c 文件，保存用户指定的路径，生成临时 C 文件路径
                user_output_path = out_path;
                if host_fill_temp_c_compile_path(&auto_output_path[0], PATH_MAX) != 0 {
                    fprintf(libc.stderr, "错误: 无法生成临时输出路径\n" as *byte);
                    return 1;
                }
                output_file_index = -2;  // 标记为自动生成的路径
                backend = BackendType.BACKEND_C99;
            }
        }
    }

    // microapp 模式下，build 仍然先完成宿主编译检查，
    // 但现在可以在后处理阶段直接产出 .pobj / .uapp。
    if command == CommandType.COMMAND_BUILD && g_app_mode_microapp != 0 {
        if user_output_path == null {
            fprintf(libc.stderr, "错误: --app microapp 的 build 需要显式输出 .c / .pobj / .uapp\n" as *byte);
            return 1;
        }
        if is_c_output(user_output_path as &byte) == 0 &&
           is_pobj_output(user_output_path as &byte) == 0 &&
           is_uapp_output(user_output_path as &byte) == 0 {
            fprintf(libc.stderr, "错误: --app microapp 的 build 目前只支持输出 .c / .pobj / .uapp\n" as *byte);
            return 1;
        }
        if is_pobj_output(user_output_path as &byte) != 0 || is_uapp_output(user_output_path as &byte) != 0 {
            // 目标 gcc 需要单文件 C 输入；microapp 的后处理阶段不走 split-C。
            g_split_c_disabled_cli = 1;
        }
    }

    // C99 且非显式 -o xxx.c 时默认多文件输出到 .uyacache（与省略路径的 --split-c-dir 一致；UYA_SPLIT_C=0 / --no-split-c 等可关闭）
    if g_split_c_dir_active == 0 && g_split_c_disabled_cli == 0 && backend == BackendType.BACKEND_C99 {
        var explicit_single_c: i32 = 0;
        if output_file_index >= 0 {
            const outp: *byte = get_argv(output_file_index);
            if outp != null && is_c_output(outp as &byte) != 0 {
                explicit_single_c = 1;
            }
        }
        if explicit_single_c == 0 && env_disables_auto_split_c() == 0 {
            split_c_set_default_dir();
        }
    }
    
    // 确定输出路径覆盖参数
    var output_path_for_compile: &byte = null;
    if output_file_index == -2 {
        output_path_for_compile = &auto_output_path[0];
    }

    var split_c_arg: &byte = null;
    if g_split_c_dir_active != 0 {
        split_c_arg = &g_split_c_dir[0] as &byte;
    }
    const result: i32 = compile_files(&input_file_indices[0], input_file_count, output_file_index, backend, emit_line_directives, enable_safety_proof, opt_level, output_path_for_compile, is_nostdlib, stack_size, split_c_arg, async_frame_heap_fallback);
    if result != 0 {
        return result;
    }

    if command == CommandType.COMMAND_RUN && g_app_mode_microapp != 0 {
        const source_path: *byte = get_argv(input_file_indices[0]);
        if source_path == null {
            fprintf(libc.stderr, "错误：无法获取 microapp 源文件路径\n" as *byte);
            return 1;
        }
        fprintf(libc.stderr, "\n=== microapp run: 编译 payload ===\n" as *byte);
        var microapp_uapp_path: [byte: PATH_MAX] = [];
        if host_fill_temp_microapp_loader_path(&microapp_uapp_path[0], PATH_MAX, ".uapp" as *byte) != 0 {
            fprintf(libc.stderr, "错误：无法生成 microapp 临时输出路径\n" as *byte);
            return 1;
        }
        var microapp_pobj_path: [byte: PATH_MAX] = [];
        if host_fill_temp_microapp_loader_path(&microapp_pobj_path[0], PATH_MAX, ".pobj" as *byte) != 0 {
            fprintf(libc.stderr, "错误：无法生成 microapp 临时 payload_obj 路径\n" as *byte);
            return 1;
        }
        const manifest_result: i32 = write_microapp_payload_obj(&microapp_pobj_path[0] as &byte, source_path as &byte, &auto_output_path[0] as &byte);
        if manifest_result != 0 {
            return manifest_result;
        }
        const pack_result: i32 = pack_microapp_pobj_to_uapp(&microapp_pobj_path[0] as &byte, &microapp_uapp_path[0] as &byte);
        if pack_result != 0 {
            return pack_result;
        }
        const loader_source_path: &byte = "examples/microapp/microcontainer_hello_load.uya" as *byte;
        var microapp_exe_path: [byte: PATH_MAX] = [];
        const microapp_exe_len: i32 = snprintf(&microapp_exe_path[0] as *byte, PATH_MAX, "%s.text.bin.elf" as *byte, &microapp_pobj_path[0] as *byte);
        if microapp_exe_len <= 0 || microapp_exe_len >= PATH_MAX {
            fprintf(libc.stderr, "错误：无法生成 microapp payload 可执行文件路径\n" as *byte);
            return 1;
        }
        fprintf(libc.stderr, "=== microapp run: 编译并运行 loader ===\n" as *byte);
        var loader_cmd: [byte: 4096] = [];
        const loader_cmd_len: i32 = snprintf(&loader_cmd[0] as *byte, 4096,
            "\"%s\" run \"%s\" -- \"%s\" \"%s\"" as *byte,
            get_argv(0),
            loader_source_path as *byte,
            &microapp_uapp_path[0] as *byte,
            &microapp_exe_path[0] as *byte);
        if loader_cmd_len <= 0 || loader_cmd_len >= 4096 {
            fprintf(libc.stderr, "错误：无法生成 microapp loader 运行命令\n" as *byte);
            return 1;
        }
        // 复用普通 `run` 路径，避免在 seed 编译器上走单独的 `build loader` 分支。
        const run_result: i32 = system(&loader_cmd[0] as *byte);
        const child_exit: i32 = exit_code_from_system_status(run_result);
        if child_exit != 0 {
            fprintf(libc.stderr, "程序运行返回码：%d\n" as *byte, child_exit);
        }
        return child_exit;
    }

    if command == CommandType.COMMAND_BUILD && g_app_mode_microapp != 0 && user_output_path != null && is_pobj_output(user_output_path as &byte) != 0 {
        const source_path: *byte = get_argv(input_file_indices[0]);
        if source_path == null {
            fprintf(libc.stderr, "错误: 无法获取 microapp 源文件路径\n" as *byte);
            return 1;
        }
        const manifest_result: i32 = write_microapp_payload_obj(user_output_path as &byte, source_path as &byte, &auto_output_path[0] as &byte);
        if manifest_result != 0 {
            return manifest_result;
        }
        fprintf(libc.stderr, "\n=== microapp payload_obj 已输出 ===\n" as *byte);
        fprintf(libc.stderr, "输出文件: %s\n" as *byte, user_output_path);
        fprintf(libc.stderr, "注意: 代码段来自 target gcc 的 .text 输出\n" as *byte);
        return 0;
    }

    if command == CommandType.COMMAND_BUILD && g_app_mode_microapp != 0 && user_output_path != null && is_uapp_output(user_output_path as &byte) != 0 {
        const source_path: *byte = get_argv(input_file_indices[0]);
        if source_path == null {
            fprintf(libc.stderr, "错误: 无法获取 microapp 源文件路径\n" as *byte);
            return 1;
        }
        var temp_pobj_path: [byte: PATH_MAX] = [];
        const temp_pobj_len: i32 = snprintf(&temp_pobj_path[0] as *byte, PATH_MAX, "%s.pobj" as *byte, user_output_path as *byte);
        if temp_pobj_len <= 0 || temp_pobj_len >= PATH_MAX {
            fprintf(libc.stderr, "错误: 无法生成 microapp 临时 payload_obj 路径\n" as *byte);
            return 1;
        }
        const manifest_result: i32 = write_microapp_payload_obj(&temp_pobj_path[0] as &byte, source_path as &byte, &auto_output_path[0] as &byte);
        if manifest_result != 0 {
            return manifest_result;
        }
        const pack_result: i32 = pack_microapp_pobj_to_uapp(&temp_pobj_path[0] as &byte, user_output_path as &byte);
        if pack_result != 0 {
            return pack_result;
        }
        fprintf(libc.stderr, "\n=== microapp .uapp 已输出 ===\n" as *byte);
        fprintf(libc.stderr, "输出文件: %s\n" as *byte, user_output_path);
        return 0;
    }

    // build 命令：检测输出类型（C 文件或可执行文件）
    // 注意：output_file_index 可能是 -2（自动生成路径），此时用户指定了非 .c 输出
    var is_output_c_file: i32 = 0;
    if command == CommandType.COMMAND_BUILD && output_file_index >= 0 {
        const out_path: *byte = get_argv(output_file_index);
        if out_path != null && is_c_output(out_path as &byte) != 0 {
            is_output_c_file = 1;
        }
    }

    // build 命令：如果输出不是 C 文件，调用宿主工具链链接
    // 条件：output_file_index == -2（自动生成 C 文件）或用户指定了非 .c 输出
    if command == CommandType.COMMAND_BUILD && is_output_c_file == 0 {
        // C 文件路径（auto_output_path 已设置）
        const c_file: &byte = &auto_output_path[0];
        
        var output: &byte = "a.out" as *byte;

        // 如果用户指定了输出路径，使用它
        if user_output_path != null {
            output = user_output_path as &byte;
        } else if output_file_index >= 0 {
            output = get_argv(output_file_index) as &byte;
        }

        // 调用宿主工具链链接
        const link_result: i32 = link_with_toolchain(c_file, output, is_nostdlib);
        if link_result != 0 {
            fprintf(libc.stderr, "错误：链接失败\n" as *byte);
            return 1;
        }

        fprintf(libc.stderr, "\n编译完成：%s\n" as *byte, output as *byte);
        return 0;
    }

    // run 和 test 命令：自动编译并运行
    if command == CommandType.COMMAND_RUN || command == CommandType.COMMAND_TEST {
        // 获取输出路径
        var actual_output: &byte = &auto_output_path[0];
        if output_file_index >= 0 {
            actual_output = get_argv(output_file_index) as &byte;
        }

        if target_matches_host_platform() == 0 {
            fprintf(libc.stderr, "错误：run/test 仅支持在宿主平台上运行当前目标；请改用 build 或调整 HOST_*/TARGET_*\n" as *byte);
            return 1;
        }

        // 生成临时可执行文件路径
        var run_output: [byte: PATH_MAX] = [];
        const run_suffix: &byte = get_target_exe_suffix();
        if host_fill_temp_run_exe_path(&run_output[0], PATH_MAX, run_suffix) != 0 {
            fprintf(libc.stderr, "错误：无法生成运行时输出路径\n" as *byte);
            return 1;
        }

        // 调用宿主工具链链接生成可执行文件
        fprintf(libc.stderr, "\n编译完成：%s\n" as *byte, actual_output as *byte);

        const link_result: i32 = link_with_toolchain(actual_output, &run_output[0] as &byte, is_nostdlib);
        if link_result != 0 {
            fprintf(libc.stderr, "错误：宿主工具链链接失败\n" as *byte);
            return 1;
        }

        // 运行程序（test：经 sh 设置 ulimit -s，避免大栈编译出的测试体在默认栈下段错误）
        var eff_run_stack_kb: i32 = stack_size;
        if eff_run_stack_kb <= 0 {
            eff_run_stack_kb = 65536;
        }
        var run_cmd: [byte: 4096] = [];
        var run_cmd_len: i32 = 0;
        if command == CommandType.COMMAND_TEST {
            sync_test_network_skip_marker();
            run_cmd_len = snprintf(&run_cmd[0], 4096,
                "/bin/sh -c 'ulimit -s %d && exec \"$1\"' sh \"%s\"" as *byte,
                eff_run_stack_kb,
                &run_output[0] as *byte);
        } else {
            run_cmd_len = snprintf(&run_cmd[0], 4096, "%s" as *byte, &run_output[0] as *byte);
            if run_cmd_len > 0 && run_cmd_len < 4096 && command == CommandType.COMMAND_RUN && run_arg_start >= 0 {
                var run_arg_i: i32 = run_arg_start;
                while run_arg_i < get_argc() {
                    const run_arg: *byte = get_argv(run_arg_i);
                    if run_arg != null {
                        const appended: i32 = snprintf((&run_cmd[0] as *byte) + run_cmd_len, 4096 - run_cmd_len, " \"%s\"" as *byte, run_arg);
                        if appended <= 0 || run_cmd_len + appended >= 4096 {
                            fprintf(libc.stderr, "错误：运行时参数过长\n" as *byte);
                            return 1;
                        }
                        run_cmd_len = run_cmd_len + appended;
                    }
                    run_arg_i = run_arg_i + 1;
                }
            }
        }
        const run_result: i32 = system(&run_cmd[0] as *byte);
        const child_exit: i32 = exit_code_from_system_status(run_result);
        if command == CommandType.COMMAND_TEST {
            _ = system("/bin/sh -c 'rm -f /tmp/uya_allow_skip_network'" as *byte);
        }
        if command == CommandType.COMMAND_TEST {
            var passed: i32 = 0;
            var failed: i32 = 1;
            if child_exit == 0 {
                passed = 1;
                failed = 0;
            }
            fprintf(libc.stderr, "================================\n" as *byte);
            fprintf(libc.stderr, "总计: 1 个测试\n" as *byte);
            fprintf(libc.stderr, "通过: %d\n" as *byte, passed);
            fprintf(libc.stderr, "失败: %d\n" as *byte, failed);
            fprintf(libc.stderr, "================================\n" as *byte);
            if child_exit != 0 {
                fprintf(libc.stderr, "程序运行返回码：%d\n" as *byte, child_exit);
            }
        } else {
            if child_exit != 0 {
                fprintf(libc.stderr, "程序运行返回码：%d\n" as *byte, child_exit);
            }
        }
        return child_exit;
    }
    
    return 0;
}

// ===== --outlibc 功能实现 =====

// libc 源文件列表（相对于 lib/ 目录）
const LIBC_SOURCES: i32 = 8;
const LIBC_SOURCE_NAMES: [&byte: 8] = [
    "libc/syscall.uya" as *byte,
    "libc/errno.uya" as *byte,
    "libc/ctype.uya" as *byte,
    "libc/string.uya" as *byte,
    "libc/mem.uya" as *byte,
    "libc/stdio.uya" as *byte,
    "libc/stdlib.uya" as *byte,
    "libc/unistd.uya" as *byte
];

// 生成 libuya.c 和 libuya.h
// output_dir: 输出目录
// 返回：0 成功，非 0 失败
fn generate_libc(output_dir: &byte) i32 {
    fprintf(libc.stderr, "信息: 开始生成 libuya 库到 %s/\n" as *byte, output_dir as *byte);

    // 获取 UYA_ROOT
    var uya_root_buffer: [byte: PATH_MAX] = [];
    const argv0: *byte = get_argv(0);
    if argv0 == null {
        fprintf(libc.stderr, "错误: 无法获取程序路径\n" as *byte);
        return 1;
    }
    if get_uya_root(argv0 as &byte, &uya_root_buffer[0] as &byte, PATH_MAX) != 0 {
        fprintf(libc.stderr, "错误: 无法获取 UYA_ROOT 目录\n" as *byte);
        return 1;
    }

    // 标准库在编译器所在目录的上一级目录的 lib/ 下
    var base_len: usize = strlen(&uya_root_buffer[0]);
    if base_len > 1 && uya_root_buffer[base_len - 1] == 47 {
        uya_root_buffer[base_len - 1] = 0;
        base_len = base_len - 1;
    }
    const last_slash: *byte = strrchr(&uya_root_buffer[0], 47);
    if last_slash != null && strcmp(last_slash, "/bin" as *byte) == 0 {
        const slash_idx_tmp: !usize = (last_slash as i64 - &uya_root_buffer[0] as i64) as! usize;
        var slash_idx: usize = slash_idx_tmp.value;
        uya_root_buffer[slash_idx] = 0;
    }
    var lib_dir: [byte: PATH_MAX] = [];
    snprintf(&lib_dir[0], PATH_MAX, "%s/lib/" as *byte, &uya_root_buffer[0] as *byte);

    // 创建输出目录（如果不存在）
    mkdir(output_dir as *byte, 493);  // 0755 = 493

    // 构建输出文件路径
    var header_path: [byte: PATH_MAX] = [];
    var source_path: [byte: PATH_MAX] = [];
    snprintf(&header_path[0], PATH_MAX, "%s/libuya.h" as *byte, output_dir as *byte);
    snprintf(&source_path[0], PATH_MAX, "%s/libuya.c" as *byte, output_dir as *byte);

    // 打开输出文件
    const header_file: *void = fopen(&header_path[0] as *byte, "w" as *byte);
    const source_file: *void = fopen(&source_path[0] as *byte, "w" as *byte);
    if header_file == null || source_file == null {
        fprintf(libc.stderr, "错误: 无法创建输出文件\n" as *byte);
        if header_file != null { fclose(header_file); }
        if source_file != null { fclose(source_file); }
        return 1;
    }

    // 写入头文件
    fprintf(header_file, "/* libuya.h - Uya 标准库头文件 */\n" as *byte);
    fprintf(header_file, "/* 自动生成，请勿手动修改 */\n" as *byte);
    fprintf(header_file, "#ifndef LIBUYA_H\n" as *byte);
    fprintf(header_file, "#define LIBUYA_H\n\n" as *byte);

    // 类型定义（零依赖）
    fprintf(header_file, "/* 类型定义 */\n" as *byte);
    fprintf(header_file, "typedef signed char int8_t;\n" as *byte);
    fprintf(header_file, "typedef unsigned char uint8_t;\n" as *byte);
    fprintf(header_file, "typedef signed short int16_t;\n" as *byte);
    fprintf(header_file, "typedef unsigned short uint16_t;\n" as *byte);
    fprintf(header_file, "typedef signed int int32_t;\n" as *byte);
    fprintf(header_file, "typedef unsigned int uint32_t;\n" as *byte);
    fprintf(header_file, "typedef signed long long int64_t;\n" as *byte);
    fprintf(header_file, "typedef unsigned long long uint64_t;\n" as *byte);
    fprintf(header_file, "typedef unsigned long size_t;\n" as *byte);
    fprintf(header_file, "typedef long ssize_t;\n" as *byte);
    fprintf(header_file, "\n" as *byte);

    // NULL 定义
    fprintf(header_file, "#ifndef NULL\n" as *byte);
    fprintf(header_file, "#define NULL ((void*)0)\n" as *byte);
    fprintf(header_file, "#endif\n\n" as *byte);

    // syscall 内联函数（放在头文件中因为是 static inline）
    fprintf(header_file, "/* syscall 内联函数（x86-64） */\n" as *byte);
    fprintf(header_file, "#ifdef __x86_64__\n" as *byte);
    fprintf(header_file, "static inline int64_t uya_syscall0(int64_t n) {\n" as *byte);
    fprintf(header_file, "    long ret;\n" as *byte);
    fprintf(header_file, "    __asm__ volatile(\"syscall\" : \"=a\"(ret) : \"a\"(n) : \"rcx\", \"r11\", \"cc\", \"memory\");\n" as *byte);
    fprintf(header_file, "    return ret;\n" as *byte);
    fprintf(header_file, "}\n" as *byte);
    fprintf(header_file, "static inline int64_t uya_syscall1(int64_t n, int64_t a1) {\n" as *byte);
    fprintf(header_file, "    long ret;\n" as *byte);
    fprintf(header_file, "    __asm__ volatile(\"syscall\" : \"=a\"(ret) : \"a\"(n), \"D\"(a1) : \"rcx\", \"r11\", \"cc\", \"memory\");\n" as *byte);
    fprintf(header_file, "    return ret;\n" as *byte);
    fprintf(header_file, "}\n" as *byte);
    fprintf(header_file, "static inline int64_t uya_syscall2(int64_t n, int64_t a1, int64_t a2) {\n" as *byte);
    fprintf(header_file, "    long ret;\n" as *byte);
    fprintf(header_file, "    __asm__ volatile(\"syscall\" : \"=a\"(ret) : \"a\"(n), \"D\"(a1), \"S\"(a2) : \"rcx\", \"r11\", \"cc\", \"memory\");\n" as *byte);
    fprintf(header_file, "    return ret;\n" as *byte);
    fprintf(header_file, "}\n" as *byte);
    fprintf(header_file, "static inline int64_t uya_syscall3(int64_t n, int64_t a1, int64_t a2, int64_t a3) {\n" as *byte);
    fprintf(header_file, "    long ret;\n" as *byte);
    fprintf(header_file, "    __asm__ volatile(\"syscall\" : \"=a\"(ret) : \"a\"(n), \"D\"(a1), \"S\"(a2), \"d\"(a3) : \"rcx\", \"r11\", \"cc\", \"memory\");\n" as *byte);
    fprintf(header_file, "    return ret;\n" as *byte);
    fprintf(header_file, "}\n" as *byte);
    fprintf(header_file, "#endif\n\n" as *byte);

    fprintf(header_file, "/* std.thread：单参函数指针间接调用（与 codegen 前导一致；勿用 inline 以免 -O2 内联退化） */\n" as *byte);
    fprintf(header_file, "static int32_t uya_thread_call_i32(void *fn, int32_t arg) {\n" as *byte);
    fprintf(header_file, "    typedef int32_t (*uya_thrd_fn_i32)(int32_t);\n" as *byte);
    fprintf(header_file, "    return ((uya_thrd_fn_i32)fn)(arg);\n" as *byte);
    fprintf(header_file, "}\n" as *byte);
    fprintf(header_file, "static uint32_t uya_thread_call_u32(void *fn, uint32_t arg) {\n" as *byte);
    fprintf(header_file, "    typedef uint32_t (*uya_thrd_fn_u32)(uint32_t);\n" as *byte);
    fprintf(header_file, "    return ((uya_thrd_fn_u32)fn)(arg);\n" as *byte);
    fprintf(header_file, "}\n" as *byte);
    fprintf(header_file, "static size_t uya_thread_call_usize(void *fn, size_t arg) {\n" as *byte);
    fprintf(header_file, "    typedef size_t (*uya_thrd_fn_usz)(size_t);\n" as *byte);
    fprintf(header_file, "    return ((uya_thrd_fn_usz)fn)(arg);\n" as *byte);
    fprintf(header_file, "}\n\n" as *byte);

    // 函数声明（从各模块收集）
    fprintf(header_file, "/* 函数声明 */\n" as *byte);
    fprintf(header_file, "\n/* string 模块 */\n" as *byte);
    fprintf(header_file, "size_t uya_strlen(const char *s);\n" as *byte);
    fprintf(header_file, "int uya_strcmp(const char *s1, const char *s2);\n" as *byte);
    fprintf(header_file, "int uya_strncmp(const char *s1, const char *s2, size_t n);\n" as *byte);
    fprintf(header_file, "char *uya_strcpy(char *dest, const char *src);\n" as *byte);
    fprintf(header_file, "char *uya_strncpy(char *dest, const char *src, size_t n);\n" as *byte);
    fprintf(header_file, "char *uya_strcat(char *dest, const char *src);\n" as *byte);
    fprintf(header_file, "char *uya_strchr(const char *s, int c);\n" as *byte);
    fprintf(header_file, "char *uya_strrchr(const char *s, int c);\n" as *byte);

    fprintf(header_file, "\n/* mem 模块 */\n" as *byte);
    fprintf(header_file, "void *uya_memcpy(void *dest, const void *src, size_t n);\n" as *byte);
    fprintf(header_file, "void *uya_memmove(void *dest, const void *src, size_t n);\n" as *byte);
    fprintf(header_file, "void *uya_memset(void *s, int c, size_t n);\n" as *byte);
    fprintf(header_file, "int uya_memcmp(const void *s1, const void *s2, size_t n);\n" as *byte);
    fprintf(header_file, "void *uya_memchr(const void *s, int c, size_t n);\n" as *byte);

    fprintf(header_file, "\n/* stdio 模块 */\n" as *byte);
    fprintf(header_file, "int uya_putchar(int c);\n" as *byte);
    fprintf(header_file, "int uya_puts(const char *s);\n" as *byte);
    fprintf(header_file, "size_t uya_strlen(const char *s);\n" as *byte);
    fprintf(header_file, "int uya_printf(const char *fmt, ...);\n" as *byte);

    fprintf(header_file, "\n/* stdlib 模块 */\n" as *byte);
    fprintf(header_file, "void uya_exit(int status);\n" as *byte);
    fprintf(header_file, "void *uya_malloc(size_t size);\n" as *byte);
    fprintf(header_file, "void uya_free(void *ptr);\n" as *byte);
    fprintf(header_file, "void *uya_calloc(size_t nmemb, size_t size);\n" as *byte);
    fprintf(header_file, "int uya_atoi(const char *s);\n" as *byte);
    fprintf(header_file, "long uya_atol(const char *s);\n" as *byte);

    fprintf(header_file, "\n/* unistd 模块 */\n" as *byte);
    fprintf(header_file, "int uya_write(int fd, const void *buf, size_t count);\n" as *byte);
    fprintf(header_file, "int uya_read(int fd, void *buf, size_t count);\n" as *byte);
    fprintf(header_file, "int uya_close(int fd);\n" as *byte);

    fprintf(header_file, "\n#endif /* LIBUYA_H */\n" as *byte);
    fclose(header_file);

    // 写入源文件
    fprintf(source_file, "/* libuya.c - Uya 标准库实现 */\n" as *byte);
    fprintf(source_file, "/* 自动生成，请勿手动修改 */\n" as *byte);
    fprintf(source_file, "#include \"libuya.h\"\n\n" as *byte);

    // 简化实现（使用 syscall）
    fprintf(source_file, "/* ===== stdlib 模块 ===== */\n" as *byte);
    fprintf(source_file, "void uya_exit(int status) {\n" as *byte);
    fprintf(source_file, "    uya_syscall1(60, status);\n" as *byte);
    fprintf(source_file, "    __builtin_unreachable();\n" as *byte);
    fprintf(source_file, "}\n\n" as *byte);

    fprintf(source_file, "/* ===== unistd 模块 ===== */\n" as *byte);
    fprintf(source_file, "int uya_write(int fd, const void *buf, size_t count) {\n" as *byte);
    fprintf(source_file, "    return (int)uya_syscall3(1, fd, (int64_t)buf, (int64_t)count);\n" as *byte);
    fprintf(source_file, "}\n\n" as *byte);

    fprintf(source_file, "int uya_read(int fd, void *buf, size_t count) {\n" as *byte);
    fprintf(source_file, "    return (int)uya_syscall3(0, fd, (int64_t)buf, (int64_t)count);\n" as *byte);
    fprintf(source_file, "}\n\n" as *byte);

    fprintf(source_file, "int uya_close(int fd) {\n" as *byte);
    fprintf(source_file, "    return (int)uya_syscall1(3, fd);\n" as *byte);
    fprintf(source_file, "}\n\n" as *byte);

    fprintf(source_file, "/* ===== stdio 模块 ===== */\n" as *byte);
    fprintf(source_file, "int uya_putchar(int c) {\n" as *byte);
    fprintf(source_file, "    char ch = (char)c;\n" as *byte);
    fprintf(source_file, "    return uya_write(1, &ch, 1) == 1 ? c : -1;\n" as *byte);
    fprintf(source_file, "}\n\n" as *byte);

    fprintf(source_file, "int uya_puts(const char *s) {\n" as *byte);
    fprintf(source_file, "    size_t len = 0;\n" as *byte);
    fprintf(source_file, "    while (s[len]) len++;\n" as *byte);
    fprintf(source_file, "    uya_write(1, s, len);\n" as *byte);
    fprintf(source_file, "    uya_write(1, \"\\n\", 1);\n" as *byte);
    fprintf(source_file, "    return 0;\n" as *byte);
    fprintf(source_file, "}\n\n" as *byte);

    fprintf(source_file, "/* ===== string 模块 ===== */\n" as *byte);
    fprintf(source_file, "size_t uya_strlen(const char *s) {\n" as *byte);
    fprintf(source_file, "    size_t len = 0;\n" as *byte);
    fprintf(source_file, "    while (s[len]) len++;\n" as *byte);
    fprintf(source_file, "    return len;\n" as *byte);
    fprintf(source_file, "}\n\n" as *byte);

    fprintf(source_file, "int uya_strcmp(const char *s1, const char *s2) {\n" as *byte);
    fprintf(source_file, "    while (*s1 && (*s1 == *s2)) { s1++; s2++; }\n" as *byte);
    fprintf(source_file, "    return *(unsigned char*)s1 - *(unsigned char*)s2;\n" as *byte);
    fprintf(source_file, "}\n\n" as *byte);

    fprintf(source_file, "int uya_strncmp(const char *s1, const char *s2, size_t n) {\n" as *byte);
    fprintf(source_file, "    while (n && *s1 && (*s1 == *s2)) { s1++; s2++; n--; }\n" as *byte);
    fprintf(source_file, "    return n ? *(unsigned char*)s1 - *(unsigned char*)s2 : 0;\n" as *byte);
    fprintf(source_file, "}\n\n" as *byte);

    fprintf(source_file, "char *uya_strcpy(char *dest, const char *src) {\n" as *byte);
    fprintf(source_file, "    char *d = dest;\n" as *byte);
    fprintf(source_file, "    while ((*d++ = *src++));\n" as *byte);
    fprintf(source_file, "    return dest;\n" as *byte);
    fprintf(source_file, "}\n\n" as *byte);

    fprintf(source_file, "char *uya_strncpy(char *dest, const char *src, size_t n) {\n" as *byte);
    fprintf(source_file, "    char *d = dest;\n" as *byte);
    fprintf(source_file, "    while (n && (*d++ = *src++)) n--;\n" as *byte);
    fprintf(source_file, "    while (n--) *d++ = 0;\n" as *byte);
    fprintf(source_file, "    return dest;\n" as *byte);
    fprintf(source_file, "}\n\n" as *byte);

    fprintf(source_file, "char *uya_strcat(char *dest, const char *src) {\n" as *byte);
    fprintf(source_file, "    char *d = dest;\n" as *byte);
    fprintf(source_file, "    while (*d) d++;\n" as *byte);
    fprintf(source_file, "    while ((*d++ = *src++));\n" as *byte);
    fprintf(source_file, "    return dest;\n" as *byte);
    fprintf(source_file, "}\n\n" as *byte);

    fprintf(source_file, "char *uya_strchr(const char *s, int c) {\n" as *byte);
    fprintf(source_file, "    while (*s && *s != (char)c) s++;\n" as *byte);
    fprintf(source_file, "    return (*s == (char)c) ? (char*)s : NULL;\n" as *byte);
    fprintf(source_file, "}\n\n" as *byte);

    fprintf(source_file, "char *uya_strrchr(const char *s, int c) {\n" as *byte);
    fprintf(source_file, "    const char *last = NULL;\n" as *byte);
    fprintf(source_file, "    while (*s) { if (*s == (char)c) last = s; s++; }\n" as *byte);
    fprintf(source_file, "    return (char*)last;\n" as *byte);
    fprintf(source_file, "}\n\n" as *byte);

    fprintf(source_file, "/* ===== mem 模块 ===== */\n" as *byte);
    fprintf(source_file, "void *uya_memcpy(void *dest, const void *src, size_t n) {\n" as *byte);
    fprintf(source_file, "    char *d = (char*)dest;\n" as *byte);
    fprintf(source_file, "    const char *s = (const char*)src;\n" as *byte);
    fprintf(source_file, "    while (n--) *d++ = *s++;\n" as *byte);
    fprintf(source_file, "    return dest;\n" as *byte);
    fprintf(source_file, "}\n\n" as *byte);

    fprintf(source_file, "void *uya_memmove(void *dest, const void *src, size_t n) {\n" as *byte);
    fprintf(source_file, "    char *d = (char*)dest;\n" as *byte);
    fprintf(source_file, "    const char *s = (const char*)src;\n" as *byte);
    fprintf(source_file, "    if (d < s) while (n--) *d++ = *s++;\n" as *byte);
    fprintf(source_file, "    else { d += n; s += n; while (n--) *--d = *--s; }\n" as *byte);
    fprintf(source_file, "    return dest;\n" as *byte);
    fprintf(source_file, "}\n\n" as *byte);

    fprintf(source_file, "void *uya_memset(void *s, int c, size_t n) {\n" as *byte);
    fprintf(source_file, "    char *p = (char*)s;\n" as *byte);
    fprintf(source_file, "    while (n--) *p++ = (char)c;\n" as *byte);
    fprintf(source_file, "    return s;\n" as *byte);
    fprintf(source_file, "}\n\n" as *byte);

    fprintf(source_file, "int uya_memcmp(const void *s1, const void *s2, size_t n) {\n" as *byte);
    fprintf(source_file, "    const unsigned char *p1 = (const unsigned char*)s1;\n" as *byte);
    fprintf(source_file, "    const unsigned char *p2 = (const unsigned char*)s2;\n" as *byte);
    fprintf(source_file, "    while (n--) { if (*p1 != *p2) return *p1 - *p2; p1++; p2++; }\n" as *byte);
    fprintf(source_file, "    return 0;\n" as *byte);
    fprintf(source_file, "}\n\n" as *byte);

    fprintf(source_file, "void *uya_memchr(const void *s, int c, size_t n) {\n" as *byte);
    fprintf(source_file, "    const unsigned char *p = (const unsigned char*)s;\n" as *byte);
    fprintf(source_file, "    while (n--) { if (*p == (unsigned char)c) return (void*)p; p++; }\n" as *byte);
    fprintf(source_file, "    return NULL;\n" as *byte);
    fprintf(source_file, "}\n\n" as *byte);

    fprintf(source_file, "/* ===== stdlib 模块 ===== */\n" as *byte);
    fprintf(source_file, "int uya_atoi(const char *s) {\n" as *byte);
    fprintf(source_file, "    int n = 0, neg = 0;\n" as *byte);
    fprintf(source_file, "    while (*s == ' ' || *s == '\\t') s++;\n" as *byte);
    fprintf(source_file, "    if (*s == '-') { neg = 1; s++; }\n" as *byte);
    fprintf(source_file, "    else if (*s == '+') s++;\n" as *byte);
    fprintf(source_file, "    while (*s >= '0' && *s <= '9') n = n * 10 + (*s++ - '0');\n" as *byte);
    fprintf(source_file, "    return neg ? -n : n;\n" as *byte);
    fprintf(source_file, "}\n\n" as *byte);

    fprintf(source_file, "long uya_atol(const char *s) {\n" as *byte);
    fprintf(source_file, "    long n = 0;\n" as *byte);
    fprintf(source_file, "    int neg = 0;\n" as *byte);
    fprintf(source_file, "    while (*s == ' ' || *s == '\\t') s++;\n" as *byte);
    fprintf(source_file, "    if (*s == '-') { neg = 1; s++; }\n" as *byte);
    fprintf(source_file, "    else if (*s == '+') s++;\n" as *byte);
    fprintf(source_file, "    while (*s >= '0' && *s <= '9') n = n * 10 + (*s++ - '0');\n" as *byte);
    fprintf(source_file, "    return neg ? -n : n;\n" as *byte);
    fprintf(source_file, "}\n\n" as *byte);

    fclose(source_file);

    fprintf(libc.stderr, "信息: 已生成 %s 和 %s\n" as *byte, &header_path[0] as *byte, &source_path[0] as *byte);
    fprintf(libc.stderr, "信息: 使用方法:\n" as *byte);
    fprintf(libc.stderr, "  ${CC:-cc} -c libuya.c -o libuya.o\n" as *byte);
    fprintf(libc.stderr, "  ${CC:-cc} -nostdlib your_program.c libuya.o -o your_program -lgcc\n" as *byte);

    return 0;
}
