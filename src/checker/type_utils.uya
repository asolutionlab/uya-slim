        struct_type_args: null,
        struct_type_arg_count: 0,
        union_type_args: null,
        union_type_arg_count: 0,
    };
}

// 创建命名类型（enum/struct/union/interface）
// kind: TYPE_ENUM, TYPE_STRUCT, TYPE_UNION, TYPE_INTERFACE
// name: 类型名称
fn make_named_type(kind: TypeKind, name: &byte) Type {
    var t: Type = Type {
        kind: kind,
        data: TypeData.named(name),
        enum_name: null,
        interface_name: null,
        struct_name: null,
        union_name: null,
        pointer_to: null,
        is_ffi_pointer: 0,
        element_type: null,
        array_size: 0,
        slice_element_type: null,
        slice_len: 0,
        tuple_element_types: null,
        tuple_count: 0,
        error_union_payload_type: null,
        error_error_id: 0,
        atomic_inner_type: null,
        generic_param_name: null,
        struct_type_args: null,
        struct_type_arg_count: 0,
        union_type_args: null,
        union_type_arg_count: 0,
    };
    if kind == TypeKind.TYPE_ENUM {
        t.enum_name = name;
    } else if kind == TypeKind.TYPE_STRUCT {
        t.struct_name = name;
    } else if kind == TypeKind.TYPE_UNION {
        t.union_name = name;
    } else if kind == TypeKind.TYPE_INTERFACE {
        t.interface_name = name;
    }
    return t;
}

// 创建错误联合类型
// payload: 负载类型（需从 arena 分配）；codegen 用其从 match 成功臂推导 try 的 !T
export fn make_error_union_type(arena: &Arena, payload: &Type) Type {
    if arena == null || payload == null {
        return make_void_type();
    }
    var eud: ErrorUnionData = ErrorUnionData { payload: payload, error_id: 0 };
    return Type {
        kind: TypeKind.TYPE_ERROR_UNION,
        data: TypeData.error_union(eud),
        enum_name: null,
        interface_name: null,
        struct_name: null,
        union_name: null,
        pointer_to: null,
        is_ffi_pointer: 0,
        element_type: null,
        array_size: 0,
        slice_element_type: null,
        slice_len: 0,
        tuple_element_types: null,
        tuple_count: 0,
        error_union_payload_type: payload,
        error_error_id: 0,
        atomic_inner_type: null,
        generic_param_name: null,
        struct_type_args: null,
        struct_type_arg_count: 0,
        union_type_args: null,
        union_type_arg_count: 0,
    };
}

// 创建原子类型
// inner: 内部类型（需从 arena 分配）
fn make_atomic_type(arena: &Arena, inner: &Type) Type {
    if arena == null || inner == null {
        return make_void_type();
    }
    var ad: AtomicData = AtomicData { inner: inner };
    return Type {
        kind: TypeKind.TYPE_ATOMIC,
        data: TypeData.atomic_data(ad),
        enum_name: null,
        interface_name: null,
        struct_name: null,
        union_name: null,
        pointer_to: null,
        is_ffi_pointer: 0,
        element_type: null,
        array_size: 0,
        slice_element_type: null,
        slice_len: 0,
        tuple_element_types: null,
        tuple_count: 0,
        error_union_payload_type: null,
        error_error_id: 0,
        atomic_inner_type: inner,
        generic_param_name: null,
        struct_type_args: null,
        struct_type_arg_count: 0,
        union_type_args: null,
        union_type_arg_count: 0,
    };
}

fn make_vector_type(arena: &Arena, element: &Type, lanes: i32) Type {
    if arena == null || element == null || lanes <= 0 {
        return make_void_type();
    }
    const elem_ptr: &Type = arena_alloc(arena, @size_of(Type)) as &Type;
    if elem_ptr == null {
        return make_void_type();
    }
    elem_ptr[0] = copy_type(element);
    return Type {
        kind: TypeKind.TYPE_VECTOR,
        data: make_empty_type_data(),
        enum_name: null,
        interface_name: null,
        struct_name: null,
        union_name: null,
        pointer_to: null,
        is_ffi_pointer: 0,
        element_type: elem_ptr,
        array_size: lanes,
        slice_element_type: null,
        slice_len: 0,
        tuple_element_types: null,
        tuple_count: 0,
        error_union_payload_type: null,
        error_error_id: 0,
        atomic_inner_type: null,
        generic_param_name: null,
        struct_type_args: null,
        struct_type_arg_count: 0,
        union_type_args: null,
        union_type_arg_count: 0,
    };
}

fn make_mask_type(lanes: i32) Type {
    if lanes <= 0 {
        return make_void_type();
    }
    return Type {
        kind: TypeKind.TYPE_MASK,
        data: make_empty_type_data(),
        enum_name: null,
        interface_name: null,
        struct_name: null,
        union_name: null,
        pointer_to: null,
        is_ffi_pointer: 0,
        element_type: null,
        array_size: lanes,
        slice_element_type: null,
        slice_len: 0,
        tuple_element_types: null,
        tuple_count: 0,
        error_union_payload_type: null,
        error_error_id: 0,
        atomic_inner_type: null,
        generic_param_name: null,
        struct_type_args: null,
        struct_type_arg_count: 0,
        union_type_args: null,
        union_type_arg_count: 0,
    };
}

// 检查是否为 void 类型（通常表示错误）
fn is_void_type(t: Type) i32 {
    if t.kind == TypeKind.TYPE_VOID {
        return 1;
    }
    return 0;
}

// 检查是否为指针类型
fn is_pointer_type(t: Type) i32 {
    if t.kind == TypeKind.TYPE_POINTER {
        return 1;
    }
