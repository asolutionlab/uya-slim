fn ensure_program_lookup_caches(program_node: &ASTNode) void {
    if program_node == null || program_node.type != ASTNodeType.AST_PROGRAM {
        return;
    }
    if g_lookup_cache_initialized != 0 &&
        g_lookup_cached_program == program_node &&
        g_lookup_cached_decl_count == program_node.program_decl_count {
        return;
    }
    reset_program_lookup_caches();
    var i: i32 = 0;
    while i < program_node.program_decl_count {
        const decl: &ASTNode = program_node.program_decls[i];
        if decl == null {
            i = i + 1;
            continue;
        }
        if decl.type == ASTNodeType.AST_ENUM_DECL && decl.enum_decl_name != null {
            const enum_slot: i32 = lookup_decl_cache_slot(decl.enum_decl_name);
            if enum_slot >= 0 && enum_slot < CHECKER_LOOKUP_CACHE_SIZE {
                g_lookup_enum_decl_cache[enum_slot] = decl;
            }
        } else if decl.type == ASTNodeType.AST_STRUCT_DECL && decl.struct_decl_name != null {
            const struct_slot: i32 = lookup_decl_cache_slot(decl.struct_decl_name);
            if struct_slot >= 0 && struct_slot < CHECKER_LOOKUP_CACHE_SIZE {
                g_lookup_struct_decl_cache[struct_slot] = decl;
            }
        } else if decl.type == ASTNodeType.AST_TYPE_ALIAS && decl.type_alias_name != null {
            const type_alias_slot: i32 = lookup_decl_cache_slot(decl.type_alias_name);
            if type_alias_slot >= 0 && type_alias_slot < CHECKER_LOOKUP_CACHE_SIZE {
                g_lookup_type_alias_cache[type_alias_slot] = decl;
            }
        } else if decl.type == ASTNodeType.AST_UNION_DECL && decl.union_decl_name != null {
            const union_slot: i32 = lookup_decl_cache_slot(decl.union_decl_name);
            if union_slot >= 0 && union_slot < CHECKER_LOOKUP_CACHE_SIZE {
                g_lookup_union_decl_cache[union_slot] = decl;
            }
        } else if decl.type == ASTNodeType.AST_INTERFACE_DECL && decl.interface_decl_name != null {
            const interface_slot: i32 = lookup_decl_cache_slot(decl.interface_decl_name);
            if interface_slot >= 0 && interface_slot < CHECKER_LOOKUP_CACHE_SIZE {
                g_lookup_interface_decl_cache[interface_slot] = decl;
            }
        } else if decl.type == ASTNodeType.AST_FN_DECL && decl.fn_decl_name != null {
            const fn_slot: i32 = lookup_decl_cache_slot(decl.fn_decl_name);
            if fn_slot >= 0 && fn_slot < CHECKER_LOOKUP_CACHE_SIZE {
                g_lookup_fn_decl_cache[fn_slot] = decl;
            }
        } else if decl.type == ASTNodeType.AST_METHOD_BLOCK {
            if decl.method_block_struct_name != null {
                const method_block_struct_slot: i32 = lookup_decl_cache_slot(decl.method_block_struct_name);
                if method_block_struct_slot >= 0 && method_block_struct_slot < CHECKER_LOOKUP_CACHE_SIZE {
                    g_lookup_method_block_struct_cache[method_block_struct_slot] = decl;
                }
            }
            if decl.method_block_union_name != null {
                const method_block_union_slot: i32 = lookup_decl_cache_slot(decl.method_block_union_name);
                if method_block_union_slot >= 0 && method_block_union_slot < CHECKER_LOOKUP_CACHE_SIZE {
                    g_lookup_method_block_union_cache[method_block_union_slot] = decl;
                }
            }
        }
        i = i + 1;
    }
    g_lookup_cached_program = program_node;
    g_lookup_cached_decl_count = program_node.program_decl_count;
    g_lookup_cache_initialized = 1;
}

// ===== 枚举查找 =====

// 从程序节点中查找枚举声明
fn find_enum_decl_from_program(program_node: &ASTNode, enum_name: &byte) &ASTNode {
    if program_node == null || program_node.type != ASTNodeType.AST_PROGRAM || enum_name == null {
        return null;
    }
    ensure_program_lookup_caches(program_node);
    const enum_result_slot: i32 = lookup_result_cache_slot(enum_name);
    if enum_result_slot >= 0 && enum_result_slot < CHECKER_LOOKUP_RESULT_CACHE_SIZE &&
        lookup_result_cache_key_matches(g_lookup_enum_result_valid[enum_result_slot],
            g_lookup_enum_result_keys[enum_result_slot], enum_name) != 0 {
        return g_lookup_enum_result_values[enum_result_slot];
    }
    var cached: &ASTNode = null;
    const enum_slot: i32 = lookup_decl_cache_slot(enum_name);
    if enum_slot >= 0 && enum_slot < CHECKER_LOOKUP_CACHE_SIZE {
        cached = g_lookup_enum_decl_cache[enum_slot];
    }
    if cached != null && cached.type == ASTNodeType.AST_ENUM_DECL &&
        cached.enum_decl_name != null && str_equals(cached.enum_decl_name, enum_name) != 0 {
        if enum_result_slot >= 0 && enum_result_slot < CHECKER_LOOKUP_RESULT_CACHE_SIZE {
            g_lookup_enum_result_keys[enum_result_slot] = enum_name;
            g_lookup_enum_result_values[enum_result_slot] = cached;
            g_lookup_enum_result_valid[enum_result_slot] = 1;
        }
        return cached;
    }
    const scanned: &ASTNode = scan_enum_decl_from_program(program_node, enum_name);
    if enum_result_slot >= 0 && enum_result_slot < CHECKER_LOOKUP_RESULT_CACHE_SIZE {
        g_lookup_enum_result_keys[enum_result_slot] = enum_name;
        g_lookup_enum_result_values[enum_result_slot] = scanned;
        g_lookup_enum_result_valid[enum_result_slot] = 1;
    }
    return scanned;
}

// 检查 name 是否是程序中任意枚举的变体名
fn is_enum_variant_name_in_program(program_node: &ASTNode, name: &byte) i32 {
    if program_node == null || program_node.type != ASTNodeType.AST_PROGRAM || name == null {
        return 0;
    }
    ensure_program_lookup_caches(program_node);
    const enum_variant_result_slot: i32 = lookup_result_cache_slot(name);
    if enum_variant_result_slot >= 0 && enum_variant_result_slot < CHECKER_LOOKUP_RESULT_CACHE_SIZE &&
        lookup_result_cache_key_matches(g_lookup_enum_variant_result_valid[enum_variant_result_slot],
            g_lookup_enum_variant_result_keys[enum_variant_result_slot], name) != 0 {
        return g_lookup_enum_variant_result_values[enum_variant_result_slot];
    }
    const indexed_variant_result: i32 = progdecl_index_has_enum_variant(program_node, name);
    if indexed_variant_result >= 0 {
        if enum_variant_result_slot >= 0 && enum_variant_result_slot < CHECKER_LOOKUP_RESULT_CACHE_SIZE {
            g_lookup_enum_variant_result_keys[enum_variant_result_slot] = name;
            g_lookup_enum_variant_result_values[enum_variant_result_slot] = indexed_variant_result;
            g_lookup_enum_variant_result_valid[enum_variant_result_slot] = 1;
        }
        return indexed_variant_result;
    }
    var i: i32 = 0;
    while i < program_node.program_decl_count {
        const decl: &ASTNode = program_node.program_decls[i];
        if decl != null && decl.type == ASTNodeType.AST_ENUM_DECL && decl.enum_decl_variants != null {
            var j: i32 = 0;
            while j < decl.enum_decl_variant_count {
                if decl.enum_decl_variants[j].name != null &&
                    str_equals(decl.enum_decl_variants[j].name, name) != 0 {
                    if enum_variant_result_slot >= 0 && enum_variant_result_slot < CHECKER_LOOKUP_RESULT_CACHE_SIZE {
                        g_lookup_enum_variant_result_keys[enum_variant_result_slot] = name;
                        g_lookup_enum_variant_result_values[enum_variant_result_slot] = 1;
                        g_lookup_enum_variant_result_valid[enum_variant_result_slot] = 1;
                    }
                    return 1;
                }
                j = j + 1;
            }
        }
        i = i + 1;
    }
    if enum_variant_result_slot >= 0 && enum_variant_result_slot < CHECKER_LOOKUP_RESULT_CACHE_SIZE {
        g_lookup_enum_variant_result_keys[enum_variant_result_slot] = name;
        g_lookup_enum_variant_result_values[enum_variant_result_slot] = 0;
        g_lookup_enum_variant_result_valid[enum_variant_result_slot] = 1;
    }
    return 0;
}

// ===== 结构体查找 =====

// 从程序节点中查找结构体声明（精确匹配 "Future" 或基名匹配 "Future<T>"）；codegen 用其预注册 from_json 内层 err_union
export fn find_struct_decl_from_program(program_node: &ASTNode, struct_name: &byte) &ASTNode {
    if program_node == null || program_node.type != ASTNodeType.AST_PROGRAM || struct_name == null {
        return null;
    }
    ensure_program_lookup_caches(program_node);
    const struct_result_slot: i32 = lookup_result_cache_slot(struct_name);
    if struct_result_slot >= 0 && struct_result_slot < CHECKER_LOOKUP_RESULT_CACHE_SIZE &&
        lookup_result_cache_key_matches(g_lookup_struct_result_valid[struct_result_slot],
            g_lookup_struct_result_keys[struct_result_slot], struct_name) != 0 {
        return g_lookup_struct_result_values[struct_result_slot];
    }
    var cached: &ASTNode = null;
    const struct_slot: i32 = lookup_decl_cache_slot(struct_name);
    if struct_slot >= 0 && struct_slot < CHECKER_LOOKUP_CACHE_SIZE {
        cached = g_lookup_struct_decl_cache[struct_slot];
    }
    if cached != null && cached.type == ASTNodeType.AST_STRUCT_DECL &&
        lookup_name_matches_exact_or_generic_base(cached.struct_decl_name, struct_name) != 0 {
        if struct_result_slot >= 0 && struct_result_slot < CHECKER_LOOKUP_RESULT_CACHE_SIZE {
            g_lookup_struct_result_keys[struct_result_slot] = struct_name;
            g_lookup_struct_result_values[struct_result_slot] = cached;
            g_lookup_struct_result_valid[struct_result_slot] = 1;
        }
        return cached;
    }
    const scanned: &ASTNode = scan_struct_decl_from_program(program_node, struct_name);
    if struct_result_slot >= 0 && struct_result_slot < CHECKER_LOOKUP_RESULT_CACHE_SIZE {
        g_lookup_struct_result_keys[struct_result_slot] = struct_name;
        g_lookup_struct_result_values[struct_result_slot] = scanned;
        g_lookup_struct_result_valid[struct_result_slot] = 1;
    }
    return scanned;
}

