// 从程序节点中查找类型别名声明
fn find_type_alias_from_program(program_node: &ASTNode, alias_name: &byte) &ASTNode {
    if program_node == null || program_node.type != ASTNodeType.AST_PROGRAM || alias_name == null {
        return null;
    }
    ensure_program_lookup_caches(program_node);
    const type_alias_result_slot: i32 = lookup_result_cache_slot(alias_name);
    if type_alias_result_slot >= 0 && type_alias_result_slot < CHECKER_LOOKUP_RESULT_CACHE_SIZE &&
        lookup_result_cache_key_matches(g_lookup_type_alias_result_valid[type_alias_result_slot],
            g_lookup_type_alias_result_keys[type_alias_result_slot], alias_name) != 0 {
        return g_lookup_type_alias_result_values[type_alias_result_slot];
    }
    var cached: &ASTNode = null;
    const type_alias_slot: i32 = lookup_decl_cache_slot(alias_name);
    if type_alias_slot >= 0 && type_alias_slot < CHECKER_LOOKUP_CACHE_SIZE {
        cached = g_lookup_type_alias_cache[type_alias_slot];
    }
    if cached != null && cached.type == ASTNodeType.AST_TYPE_ALIAS &&
        cached.type_alias_name != null && str_equals(cached.type_alias_name, alias_name) != 0 {
        if type_alias_result_slot >= 0 && type_alias_result_slot < CHECKER_LOOKUP_RESULT_CACHE_SIZE {
            g_lookup_type_alias_result_keys[type_alias_result_slot] = alias_name;
            g_lookup_type_alias_result_values[type_alias_result_slot] = cached;
            g_lookup_type_alias_result_valid[type_alias_result_slot] = 1;
        }
        return cached;
    }
    var scanned: &ASTNode = null;
    progdecl_index_ensure(program_node);
    if progdecl_index_ready(program_node) != 0 {
        scanned = progdecl_index_find_typed(program_node, alias_name, ASTNodeType.AST_TYPE_ALIAS);
    } else {
        scanned = scan_type_alias_from_program(program_node, alias_name);
    }
    if type_alias_result_slot >= 0 && type_alias_result_slot < CHECKER_LOOKUP_RESULT_CACHE_SIZE {
        g_lookup_type_alias_result_keys[type_alias_result_slot] = alias_name;
        g_lookup_type_alias_result_values[type_alias_result_slot] = scanned;
        g_lookup_type_alias_result_valid[type_alias_result_slot] = 1;
    }
    return scanned;
}

