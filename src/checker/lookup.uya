        g_lookup_method_block_union_result_keys[method_block_union_result_slot] = union_name;
        g_lookup_method_block_union_result_values[method_block_union_result_slot] = scanned;
        g_lookup_method_block_union_result_valid[method_block_union_result_slot] = 1;
