// 在接口及其组合接口中递归查找方法签名
fn find_interface_method_sig(program_node: &ASTNode, interface_name: &byte, method_name: &byte) &ASTNode {
    if program_node == null || interface_name == null || method_name == null {
        return null;
    }
    
    const iface: &ASTNode = find_interface_decl_from_program(program_node, interface_name);
    if iface == null {
        return null;
    }
    
    // 先在本接口中查找
    if iface.interface_decl_method_sigs != null {
        var i: i32 = 0;
        while i < iface.interface_decl_method_sig_count {
            const msig: &ASTNode = iface.interface_decl_method_sigs[i];
            if msig != null && msig.type == ASTNodeType.AST_FN_DECL && msig.fn_decl_name != null {
                if str_equals(msig.fn_decl_name, method_name) != 0 {
                    return msig;
                }
            }
            i = i + 1;
        }
    }
    
    // 再在组合接口中递归查找
    if iface.interface_decl_composed_interfaces != null {
        var j: i32 = 0;
        while j < iface.interface_decl_composed_count {
            const composed_name: &byte = iface.interface_decl_composed_interfaces[j];
            if composed_name != null {
                const found: &ASTNode = find_interface_method_sig(program_node, composed_name, method_name);
                if found != null {
                    return found;
                }
            }
            j = j + 1;
        }
    }
    
    return null;
}

// 检查接口组合是否存在循环依赖
fn check_interface_compose_cycle(program_node: &ASTNode, interface_name: &byte, visited: & & byte, visited_count: i32) i32 {
    if program_node == null || interface_name == null {
        return 0;
    }
    
    // 检查是否已访问过（存在循环）
    var i: i32 = 0;
    while i < visited_count {
        if visited[i] != null && str_equals(visited[i], interface_name) != 0 {
            return 1;  // 发现循环
        }
        i = i + 1;
    }
    
    const iface: &ASTNode = find_interface_decl_from_program(program_node, interface_name);
    if iface == null || iface.interface_decl_composed_interfaces == null {
        return 0;
    }
    
    // 递归检查组合接口
    var j: i32 = 0;
    while j < iface.interface_decl_composed_count {
        const composed_name: &byte = iface.interface_decl_composed_interfaces[j];
        if composed_name != null {
            visited[visited_count] = interface_name;
            if check_interface_compose_cycle(program_node, composed_name, visited, visited_count + 1) != 0 {
                return 1;
            }
        }
        j = j + 1;
    }
    
    return 0;
}

// ===== 函数查找 =====

// 从程序节点查找函数声明
fn find_fn_decl_from_program(program_node: &ASTNode, fn_name: &byte) &ASTNode {
    if program_node == null || program_node.type != ASTNodeType.AST_PROGRAM || fn_name == null {
        return null;
    }
    ensure_program_lookup_caches(program_node);
    const fn_result_slot: i32 = lookup_result_cache_slot(fn_name);
    if fn_result_slot >= 0 && fn_result_slot < CHECKER_LOOKUP_RESULT_CACHE_SIZE &&
        lookup_result_cache_key_matches(g_lookup_fn_result_valid[fn_result_slot],
            g_lookup_fn_result_keys[fn_result_slot], fn_name) != 0 {
        return g_lookup_fn_result_values[fn_result_slot];
    }
    var cached: &ASTNode = null;
    const fn_slot: i32 = lookup_decl_cache_slot(fn_name);
    if fn_slot >= 0 && fn_slot < CHECKER_LOOKUP_CACHE_SIZE {
        cached = g_lookup_fn_decl_cache[fn_slot];
    }
    if cached != null && cached.type == ASTNodeType.AST_FN_DECL &&
        cached.fn_decl_name != null && str_equals(cached.fn_decl_name, fn_name) != 0 {
        if fn_result_slot >= 0 && fn_result_slot < CHECKER_LOOKUP_RESULT_CACHE_SIZE {
            g_lookup_fn_result_keys[fn_result_slot] = fn_name;
            g_lookup_fn_result_values[fn_result_slot] = cached;
            g_lookup_fn_result_valid[fn_result_slot] = 1;
        }
        return cached;
    }
    const scanned: &ASTNode = scan_fn_decl_from_program(program_node, fn_name);
    if fn_result_slot >= 0 && fn_result_slot < CHECKER_LOOKUP_RESULT_CACHE_SIZE {
        g_lookup_fn_result_keys[fn_result_slot] = fn_name;
        g_lookup_fn_result_values[fn_result_slot] = scanned;
        g_lookup_fn_result_valid[fn_result_slot] = 1;
    }
    return scanned;
}

// ===== 方法查找 =====

fn fn_decl_has_interface_receiver(fn_decl: &ASTNode) i32 {
    if fn_decl == null || fn_decl.type != ASTNodeType.AST_FN_DECL ||
        fn_decl.fn_decl_param_count < 1 || fn_decl.fn_decl_params == null {
        return 0;
    }
    const param: &ASTNode = fn_decl.fn_decl_params[0];
    if param == null || param.type != ASTNodeType.AST_VAR_DECL || param.var_decl_type == null {
        return 0;
    }
    const param_type: &ASTNode = param.var_decl_type;
    if param_type.type != ASTNodeType.AST_TYPE_POINTER || param_type.type_pointer_is_ffi_pointer != 0 ||
        param_type.type_pointer_pointed_type == null {
        return 0;
    }
    const pointed: &ASTNode = param_type.type_pointer_pointed_type;
    if pointed.type == ASTNodeType.AST_TYPE_NAMED && pointed.type_named_name != null &&
        str_equals(pointed.type_named_name, "Self" as *byte) != 0 {
        return 1;
    }
    return 0;
}

fn fn_decl_has_receiver_for_owner(fn_decl: &ASTNode, owner_name: &byte) i32 {
    if fn_decl == null || fn_decl.type != ASTNodeType.AST_FN_DECL || owner_name == null ||
        fn_decl.fn_decl_param_count < 1 || fn_decl.fn_decl_params == null {
        return 0;
    }
    const param: &ASTNode = fn_decl.fn_decl_params[0];
    if param == null || param.type != ASTNodeType.AST_VAR_DECL || param.var_decl_type == null {
        return 0;
    }
    const param_type: &ASTNode = param.var_decl_type;
    if param_type.type != ASTNodeType.AST_TYPE_POINTER || param_type.type_pointer_is_ffi_pointer != 0 ||
        param_type.type_pointer_pointed_type == null {
        return 0;
    }
    const pointed: &ASTNode = param_type.type_pointer_pointed_type;
    if pointed.type != ASTNodeType.AST_TYPE_NAMED || pointed.type_named_name == null {
        return 0;
    }
    if str_equals(pointed.type_named_name, "Self" as *byte) != 0 ||
        str_equals(pointed.type_named_name, owner_name) != 0 {
        return 1;
    }
    return 0;
}

fn find_method_in_block_with_receiver_kind(method_block: &ASTNode, owner_name: &byte, method_name: &byte, want_self_receiver: i32) &ASTNode {
    if method_block == null || method_block.type != ASTNodeType.AST_METHOD_BLOCK || method_name == null {
        return null;
    }
    var i: i32 = 0;
    while i < method_block.method_block_method_count {
        const m: &ASTNode = method_block.method_block_methods[i];
        if m != null && m.type == ASTNodeType.AST_FN_DECL && m.fn_decl_name != null &&
            str_equals(m.fn_decl_name, method_name) != 0 {
            if want_self_receiver < 0 || fn_decl_has_receiver_for_owner(m, owner_name) == want_self_receiver {
                return m;
            }
        }
        i = i + 1;
    }
    return null;
}

// 查找结构体对应的方法块
fn find_method_block_for_struct(program_node: &ASTNode, struct_name: &byte) &ASTNode {
    if program_node == null || program_node.type != ASTNodeType.AST_PROGRAM || struct_name == null {
        return null;
    }
    ensure_program_lookup_caches(program_node);
    const method_block_struct_result_slot: i32 = lookup_result_cache_slot(struct_name);
    if method_block_struct_result_slot >= 0 && method_block_struct_result_slot < CHECKER_LOOKUP_RESULT_CACHE_SIZE &&
        lookup_result_cache_key_matches(g_lookup_method_block_struct_result_valid[method_block_struct_result_slot],
            g_lookup_method_block_struct_result_keys[method_block_struct_result_slot], struct_name) != 0 {
        return g_lookup_method_block_struct_result_values[method_block_struct_result_slot];
    }
    var cached: &ASTNode = null;
    const method_block_struct_slot: i32 = lookup_decl_cache_slot(struct_name);
    if method_block_struct_slot >= 0 && method_block_struct_slot < CHECKER_LOOKUP_CACHE_SIZE {
        cached = g_lookup_method_block_struct_cache[method_block_struct_slot];
    }
    if cached != null && cached.type == ASTNodeType.AST_METHOD_BLOCK &&
        cached.method_block_struct_name != null &&
        str_equals(cached.method_block_struct_name, struct_name) != 0 {
        if method_block_struct_result_slot >= 0 && method_block_struct_result_slot < CHECKER_LOOKUP_RESULT_CACHE_SIZE {
            g_lookup_method_block_struct_result_keys[method_block_struct_result_slot] = struct_name;
            g_lookup_method_block_struct_result_values[method_block_struct_result_slot] = cached;
            g_lookup_method_block_struct_result_valid[method_block_struct_result_slot] = 1;
        }
        return cached;
    }
    const scanned: &ASTNode = scan_method_block_for_struct(program_node, struct_name);
    if method_block_struct_result_slot >= 0 && method_block_struct_result_slot < CHECKER_LOOKUP_RESULT_CACHE_SIZE {
        g_lookup_method_block_struct_result_keys[method_block_struct_result_slot] = struct_name;
        g_lookup_method_block_struct_result_values[method_block_struct_result_slot] = scanned;
        g_lookup_method_block_struct_result_valid[method_block_struct_result_slot] = 1;
    }
    return scanned;
}

// 查找结构体方法
fn find_method_in_struct(program_node: &ASTNode, struct_name: &byte, method_name: &byte) &ASTNode {
    if program_node == null || program_node.type != ASTNodeType.AST_PROGRAM || struct_name == null || method_name == null {
        return null;
    }
    // 1. 先检查外部方法块
    const method_block: &ASTNode = find_method_block_for_struct(program_node, struct_name);
    if method_block != null && method_block.method_block_methods != null {
        var i: i32 = 0;
        while i < method_block.method_block_method_count {
            const m: &ASTNode = method_block.method_block_methods[i];
            if m != null && m.type == ASTNodeType.AST_FN_DECL && m.fn_decl_name != null &&
                str_equals(m.fn_decl_name, method_name) != 0 {
                return m;
            }
            i = i + 1;
        }
    }
    // 2. 再检查结构体内部定义的方法
    const struct_decl: &ASTNode = find_struct_decl_from_program(program_node, struct_name);
    if struct_decl != null && struct_decl.struct_decl_methods != null {
        var i: i32 = 0;
        while i < struct_decl.struct_decl_method_count {
            const m: &ASTNode = struct_decl.struct_decl_methods[i];
            if m != null && m.type == ASTNodeType.AST_FN_DECL && m.fn_decl_name != null &&
                str_equals(m.fn_decl_name, method_name) != 0 {
                return m;
            }
            i = i + 1;
        }
    }
    return null;
}

fn find_instance_method_in_struct(program_node: &ASTNode, struct_name: &byte, method_name: &byte) &ASTNode {
    if program_node == null || program_node.type != ASTNodeType.AST_PROGRAM || struct_name == null || method_name == null {
        return null;
    }
    const method_block: &ASTNode = find_method_block_for_struct(program_node, struct_name);
    if method_block != null {
        const m_block: &ASTNode = find_method_in_block_with_receiver_kind(method_block, struct_name, method_name, 1);
        if m_block != null {
            return m_block;
        }
    }
    const struct_decl: &ASTNode = find_struct_decl_from_program(program_node, struct_name);
    if struct_decl != null && struct_decl.struct_decl_methods != null {
        var i: i32 = 0;
        while i < struct_decl.struct_decl_method_count {
            const m: &ASTNode = struct_decl.struct_decl_methods[i];
            if m != null && m.type == ASTNodeType.AST_FN_DECL && m.fn_decl_name != null &&
                str_equals(m.fn_decl_name, method_name) != 0 &&
                fn_decl_has_receiver_for_owner(m, struct_name) != 0 {
                return m;
            }
            i = i + 1;
        }
    }
    return null;
}

fn find_static_method_in_struct(program_node: &ASTNode, struct_name: &byte, method_name: &byte) &ASTNode {
    if program_node == null || program_node.type != ASTNodeType.AST_PROGRAM || struct_name == null || method_name == null {
        return null;
    }
    const method_block: &ASTNode = find_method_block_for_struct(program_node, struct_name);
    if method_block != null {
        const m_block: &ASTNode = find_method_in_block_with_receiver_kind(method_block, struct_name, method_name, 0);
        if m_block != null {
            return m_block;
        }
    }
    const struct_decl: &ASTNode = find_struct_decl_from_program(program_node, struct_name);
    if struct_decl != null && struct_decl.struct_decl_methods != null {
        var i: i32 = 0;
        while i < struct_decl.struct_decl_method_count {
            const m: &ASTNode = struct_decl.struct_decl_methods[i];
            if m != null && m.type == ASTNodeType.AST_FN_DECL && m.fn_decl_name != null &&
                str_equals(m.fn_decl_name, method_name) != 0 &&
                fn_decl_has_receiver_for_owner(m, struct_name) == 0 {
                return m;
            }
            i = i + 1;
        }
    }
    return null;
}

// 查找联合体对应的方法块
