fn checker_fn_decl_is_owned_method(checker: &TypeChecker, fn_decl: &ASTNode) i32 {
    if checker == null || fn_decl == null || fn_decl.type != ASTNodeType.AST_FN_DECL ||
        checker.program_node == null || checker.program_node.type != ASTNodeType.AST_PROGRAM {
        return 0;
    }
    ensure_program_lookup_caches(checker.program_node);
    const owned_slot: i32 = lookup_node_result_cache_slot(fn_decl);
    if owned_slot >= 0 && owned_slot < CHECKER_LOOKUP_RESULT_CACHE_SIZE &&
        g_lookup_owned_method_result_valid[owned_slot] != 0 &&
        g_lookup_owned_method_result_keys[owned_slot] == fn_decl {
        return g_lookup_owned_method_result_values[owned_slot];
    }
    var i: i32 = 0;
    while i < checker.program_node.program_decl_count {
        const decl: &ASTNode = checker.program_node.program_decls[i];
        if decl != null {
            if decl.type == ASTNodeType.AST_STRUCT_DECL && decl.struct_decl_methods != null {
                var j: i32 = 0;
                while j < decl.struct_decl_method_count {
                    if decl.struct_decl_methods[j] == fn_decl {
                        if owned_slot >= 0 && owned_slot < CHECKER_LOOKUP_RESULT_CACHE_SIZE {
                            g_lookup_owned_method_result_keys[owned_slot] = fn_decl;
                            g_lookup_owned_method_result_values[owned_slot] = 1;
                            g_lookup_owned_method_result_valid[owned_slot] = 1;
                        }
                        return 1;
                    }
                    j = j + 1;
                }
            } else if decl.type == ASTNodeType.AST_UNION_DECL && decl.union_decl_methods != null {
                var k: i32 = 0;
                while k < decl.union_decl_method_count {
                    if decl.union_decl_methods[k] == fn_decl {
                        if owned_slot >= 0 && owned_slot < CHECKER_LOOKUP_RESULT_CACHE_SIZE {
                            g_lookup_owned_method_result_keys[owned_slot] = fn_decl;
                            g_lookup_owned_method_result_values[owned_slot] = 1;
                            g_lookup_owned_method_result_valid[owned_slot] = 1;
                        }
                        return 1;
                    }
                    k = k + 1;
                }
            } else if decl.type == ASTNodeType.AST_METHOD_BLOCK && decl.method_block_methods != null {
                var m: i32 = 0;
                while m < decl.method_block_method_count {
                    if decl.method_block_methods[m] == fn_decl {
                        if owned_slot >= 0 && owned_slot < CHECKER_LOOKUP_RESULT_CACHE_SIZE {
                            g_lookup_owned_method_result_keys[owned_slot] = fn_decl;
                            g_lookup_owned_method_result_values[owned_slot] = 1;
                            g_lookup_owned_method_result_valid[owned_slot] = 1;
                        }
                        return 1;
                    }
                    m = m + 1;
                }
            }
        }
        i = i + 1;
    }
    if owned_slot >= 0 && owned_slot < CHECKER_LOOKUP_RESULT_CACHE_SIZE {
        g_lookup_owned_method_result_keys[owned_slot] = fn_decl;
        g_lookup_owned_method_result_values[owned_slot] = 0;
        g_lookup_owned_method_result_valid[owned_slot] = 1;
    }
    return 0;
}

fn checker_fn_decl_owner_type_name(checker: &TypeChecker, fn_decl: &ASTNode, out_is_union: &i32) &byte {
    if checker == null || fn_decl == null || fn_decl.type != ASTNodeType.AST_FN_DECL ||
        checker.program_node == null || checker.program_node.type != ASTNodeType.AST_PROGRAM {
        return null;
    }
    if out_is_union != null {
        out_is_union[0] = 0;
    }
    ensure_program_lookup_caches(checker.program_node);
    const owner_slot: i32 = lookup_node_result_cache_slot(fn_decl);
    if owner_slot >= 0 && owner_slot < CHECKER_LOOKUP_RESULT_CACHE_SIZE &&
        g_lookup_owner_type_result_valid[owner_slot] != 0 &&
        g_lookup_owner_type_result_keys[owner_slot] == fn_decl {
        if out_is_union != null {
            out_is_union[0] = g_lookup_owner_type_result_is_union[owner_slot];
        }
        return g_lookup_owner_type_result_names[owner_slot];
    }
    var i: i32 = 0;
    while i < checker.program_node.program_decl_count {
        const decl: &ASTNode = checker.program_node.program_decls[i];
        if decl != null {
            if decl.type == ASTNodeType.AST_STRUCT_DECL && decl.struct_decl_methods != null {
                var j: i32 = 0;
                while j < decl.struct_decl_method_count {
                    if decl.struct_decl_methods[j] == fn_decl {
                        lookup_owner_type_cache_store(owner_slot, fn_decl, decl.struct_decl_name, 0);
                        return decl.struct_decl_name;
                    }
                    j = j + 1;
                }
            } else if decl.type == ASTNodeType.AST_UNION_DECL && decl.union_decl_methods != null {
                var k: i32 = 0;
                while k < decl.union_decl_method_count {
                    if decl.union_decl_methods[k] == fn_decl {
                        if out_is_union != null {
                            out_is_union[0] = 1;
                        }
                        lookup_owner_type_cache_store(owner_slot, fn_decl, decl.union_decl_name, 1);
                        return decl.union_decl_name;
                    }
                    k = k + 1;
                }
            } else if decl.type == ASTNodeType.AST_METHOD_BLOCK && decl.method_block_methods != null {
                var m: i32 = 0;
                while m < decl.method_block_method_count {
                    if decl.method_block_methods[m] == fn_decl {
                        if decl.method_block_union_name != null {
                            if out_is_union != null {
                                out_is_union[0] = 1;
                            }
                            lookup_owner_type_cache_store(owner_slot, fn_decl, decl.method_block_union_name, 1);
                            return decl.method_block_union_name;
                        }
                        lookup_owner_type_cache_store(owner_slot, fn_decl, decl.method_block_struct_name, 0);
                        return decl.method_block_struct_name;
                    }
                    m = m + 1;
                }
            }
        }
        i = i + 1;
    }
    lookup_owner_type_cache_store(owner_slot, fn_decl, null, 0);
    return null;
}

fn checker_async_fn_graph_key(checker: &TypeChecker, fn_decl: &ASTNode) &byte {
    if checker == null || fn_decl == null || fn_decl.type != ASTNodeType.AST_FN_DECL ||
        fn_decl.fn_decl_name == null {
        return null;
    }
    var owner_is_union: i32 = 0;
    const owner_name: &byte = checker_fn_decl_owner_type_name(checker, fn_decl, &owner_is_union);
    if owner_name != null {
        const buf: &byte = compiler_arena_alloc(checker.arena, 512) as &byte;
        if buf != null {
            snprintf(buf as *byte, 512, "%s::%s" as *byte, owner_name as *byte, fn_decl.fn_decl_name as *byte);
            return buf;
        }
    }
    if checker.program_node != null && checker.program_node.type == ASTNodeType.AST_PROGRAM {
        var i: i32 = 0;
        while i < checker.program_node.program_decl_count {
            const decl: &ASTNode = checker.program_node.program_decls[i];
            if decl != null && decl.type == ASTNodeType.AST_INTERFACE_DECL &&
                decl.interface_decl_name != null &&
                decl.interface_decl_method_sigs != null {
                var j: i32 = 0;
                while j < decl.interface_decl_method_sig_count {
                    if decl.interface_decl_method_sigs[j] == fn_decl {
                        const ibuf: &byte = compiler_arena_alloc(checker.arena, 512) as &byte;
                        if ibuf != null {
                            snprintf(ibuf as *byte, 512, "iface:%s::%s" as *byte,
                                decl.interface_decl_name as *byte, fn_decl.fn_decl_name as *byte);
                            return ibuf;
                        }
                    }
                    j = j + 1;
                }
            }
            i = i + 1;
        }
    }
    return fn_decl.fn_decl_name;
}

// ===== drop 方法校验 =====

// 校验 drop 方法签名（结构体）
fn check_drop_method_signature(checker: &TypeChecker, fn_decl: &ASTNode, struct_name: &byte) i32 {
    if checker == null || fn_decl == null || fn_decl.type != ASTNodeType.AST_FN_DECL || struct_name == null {
        return 1;
    }
    if fn_decl.fn_decl_param_count != 1 || fn_decl.fn_decl_params == null {
        checker_report_error(checker, fn_decl, "drop 方法必须恰好有一个参数 self: T（按值）" as *byte);
        return 0;
    }
    const param: &ASTNode = fn_decl.fn_decl_params[0];
    if param == null || param.type != ASTNodeType.AST_VAR_DECL || param.var_decl_name == null ||
        str_equals(param.var_decl_name, "self" as *byte) == 0 {
        checker_report_error(checker, fn_decl, "drop 方法第一个参数必须名为 self" as *byte);
        return 0;
    }
    const param_type: &ASTNode = param.var_decl_type;
    if param_type == null {
        checker_report_error(checker, fn_decl, "drop 方法 self 必须为按值类型 T，不能为指针" as *byte);
        return 0;
    }
    if param_type.type == ASTNodeType.AST_TYPE_POINTER {
        checker_report_error(checker, fn_decl, "drop 方法 self 必须为按值类型 T（不能为 &Self、*Self 或指针）" as *byte);
        return 0;
    }
    if param_type.type != ASTNodeType.AST_TYPE_NAMED || param_type.type_named_name == null ||
        str_equals(param_type.type_named_name, struct_name) == 0 {
        checker_report_error(checker, fn_decl, "drop 方法 self 类型必须为该结构体类型（按值）" as *byte);
        return 0;
    }
    const ret: &ASTNode = fn_decl.fn_decl_return_type;
    if ret == null || ret.type != ASTNodeType.AST_TYPE_NAMED || ret.type_named_name == null ||
        str_equals(ret.type_named_name, "void" as *byte) == 0 {
        checker_report_error(checker, fn_decl, "drop 方法返回类型必须为 void" as *byte);
        return 0;
    }
    return 1;
}

// 校验 drop 方法签名（联合体）
fn check_drop_method_signature_union(checker: &TypeChecker, fn_decl: &ASTNode, union_name: &byte) i32 {
    if checker == null || fn_decl == null || fn_decl.type != ASTNodeType.AST_FN_DECL || union_name == null {
        return 1;
    }
    if fn_decl.fn_decl_param_count != 1 || fn_decl.fn_decl_params == null {
        checker_report_error(checker, fn_decl, "drop 方法必须恰好有一个参数 self: T（按值）" as *byte);
        return 0;
    }
    const param: &ASTNode = fn_decl.fn_decl_params[0];
    if param == null || param.type != ASTNodeType.AST_VAR_DECL || param.var_decl_name == null ||
        str_equals(param.var_decl_name, "self" as *byte) == 0 {
        checker_report_error(checker, fn_decl, "drop 方法第一个参数必须名为 self" as *byte);
        return 0;
    }
    const param_type: &ASTNode = param.var_decl_type;
    if param_type == null || param_type.type == ASTNodeType.AST_TYPE_POINTER {
        checker_report_error(checker, fn_decl, "drop 方法 self 必须为按值类型 T（不能为指针）" as *byte);
        return 0;
    }
    if param_type.type != ASTNodeType.AST_TYPE_NAMED || param_type.type_named_name == null ||
        str_equals(param_type.type_named_name, union_name) == 0 {
        checker_report_error(checker, fn_decl, "drop 方法 self 类型必须为该联合体类型（按值）" as *byte);
        return 0;
    }
    const ret: &ASTNode = fn_decl.fn_decl_return_type;
    if ret == null || ret.type != ASTNodeType.AST_TYPE_NAMED || ret.type_named_name == null ||
        str_equals(ret.type_named_name, "void" as *byte) == 0 {
        checker_report_error(checker, fn_decl, "drop 方法返回类型必须为 void" as *byte);
        return 0;
    }
    return 1;
}

// 校验方法的 self 参数必须为 &T
fn check_method_self_param(checker: &TypeChecker, fn_decl: &ASTNode) i32 {
    if checker == null || fn_decl == null || fn_decl.type != ASTNodeType.AST_FN_DECL {
        return 1;
    }
    if fn_decl.fn_decl_param_count < 1 || fn_decl.fn_decl_params == null {
        return 1;
    }
    const param: &ASTNode = fn_decl.fn_decl_params[0];
    if param == null || param.type != ASTNodeType.AST_VAR_DECL {
        return 1;
    }
    const param_type: &ASTNode = param.var_decl_type;
    if param_type == null || param_type.type != ASTNodeType.AST_TYPE_POINTER {
        checker_report_error(checker, fn_decl, "实例方法首参必须为 &Self，静态方法请省略 receiver 参数" as *byte);
        return 0;
    }
    if param_type.type_pointer_is_ffi_pointer != 0 {
        checker_report_error(checker, fn_decl, "方法 self 必须为 &T，不能为 *T（*T 仅用于 FFI）" as *byte);
        return 0;
    }
    if param_type.type_pointer_pointed_type == null ||
        param_type.type_pointer_pointed_type.type != ASTNodeType.AST_TYPE_NAMED ||
        param_type.type_pointer_pointed_type.type_named_name == null ||
        str_equals(param_type.type_pointer_pointed_type.type_named_name, "Self" as *byte) == 0 {
        checker_report_error(checker, fn_decl, "实例方法首参必须为 &Self" as *byte);
        return 0;
    }
    return 1;
}

fn check_method_self_param_for_owner(checker: &TypeChecker, fn_decl: &ASTNode, owner_name: &byte) i32 {
    if checker == null || fn_decl == null || fn_decl.type != ASTNodeType.AST_FN_DECL || owner_name == null {
        return 1;
    }
    if fn_decl.fn_decl_param_count < 1 || fn_decl.fn_decl_params == null {
        return 1;
    }
    const param: &ASTNode = fn_decl.fn_decl_params[0];
    if param == null || param.type != ASTNodeType.AST_VAR_DECL || param.var_decl_type == null {
        return 1;
    }
    const param_type: &ASTNode = param.var_decl_type;
    if param_type.type != ASTNodeType.AST_TYPE_POINTER {
        return 1;
    }
    if param_type.type_pointer_is_ffi_pointer != 0 {
        const pointed_ffi: &ASTNode = param_type.type_pointer_pointed_type;
        if pointed_ffi != null && pointed_ffi.type == ASTNodeType.AST_TYPE_NAMED && pointed_ffi.type_named_name != null &&
            (str_equals(pointed_ffi.type_named_name, "Self" as *byte) != 0 ||
             str_equals(pointed_ffi.type_named_name, owner_name) != 0) {
            checker_report_error(checker, fn_decl, "实例方法 receiver 必须为 &Self 或 &该类型，不能为 *T（*T 仅用于 FFI）" as *byte);
            return 0;
        }
        return 1;
    }
    if fn_decl_has_receiver_for_owner(fn_decl, owner_name) != 0 {
        return 1;
    }
    const pointed: &ASTNode = param_type.type_pointer_pointed_type;
    if pointed != null && pointed.type == ASTNodeType.AST_TYPE_NAMED && pointed.type_named_name != null &&
        (str_equals(pointed.type_named_name, "Self" as *byte) != 0 ||
         str_equals(pointed.type_named_name, owner_name) != 0) {
        checker_report_error(checker, fn_decl, "实例方法 receiver 必须为 &Self 或 &该类型" as *byte);
        return 0;
    }
    return 1;
}

fn check_interface_method_self_param(checker: &TypeChecker, fn_decl: &ASTNode) i32 {
    if checker == null || fn_decl == null || fn_decl.type != ASTNodeType.AST_FN_DECL {
        return 1;
    }
    if fn_decl_has_interface_receiver(fn_decl) == 0 {
        checker_report_error(checker, fn_decl, "接口方法的首参必须为 &Self；静态方法不能出现在 interface 中" as *byte);
        return 0;
    }
    return check_method_self_param(checker, fn_decl);
}

// ===== 接口实现检查 =====

// 检查结构体是否实现某接口
// interface_name 为声明中的名称（如 "Future"）；struct 的接口列表可能带泛型（如 "Future<T>"），按基名匹配
fn struct_implements_interface(checker: &TypeChecker, struct_name: &byte, interface_name: &byte) i32 {
    if checker == null || checker.program_node == null || struct_name == null || interface_name == null {
        return 0;
    }
    const struct_decl: &ASTNode = find_struct_decl_from_program(checker.program_node, struct_name);
    if struct_decl == null || struct_decl.struct_decl_interface_names == null {
        return 0;
    }
    var i: i32 = 0;
    while i < struct_decl.struct_decl_interface_count {
        const decl_iface: &byte = struct_decl.struct_decl_interface_names[i];
        if decl_iface != null {
            if str_equals(decl_iface, interface_name) != 0 {
                return 1;
            }
            // 泛型接口名如 "Future<T>" 与声明名 "Future" 匹配：基名相同且 decl 以 '<' 继续
            const inlen_tmp: !i32 = strlen(interface_name as *byte) as! i32;
            const dlen_tmp: !i32 = strlen(decl_iface as *byte) as! i32;
            const inlen: i32 = inlen_tmp.value;
            const dlen: i32 = dlen_tmp.value;
            const decl_ptr: *byte = decl_iface as *byte;
            if dlen > inlen && strncmp(decl_iface as *byte, interface_name as *byte, inlen) == 0 &&
                decl_ptr[inlen] == 60 {
                return 1;
            }
        }
        i = i + 1;
    }
    return 0;
}
