// checker/symbols.uya - 符号表操作和工具函数
// 从 checker/main.uya 拆分

// ===== 哈希函数 =====

// 哈希函数（djb2算法，用于字符串哈希）
// 注意：Uya Mini 不支持位运算符 <<，使用乘法代替
fn hash_string(str: &byte) i32 {
    // 使用 u32 避免有符号整数溢出 UB
    var hash: u32 = 5381;
    var i: i32 = 0;
    while str[i] != 0 {
        const c: u8 = str[i] as u8;
        hash = ((hash * 32) + hash) + (c as u32); // hash * 33 + c (等价于 hash << 5 + hash)
        i = i + 1;
    }
    return hash as i32; // 返回时转换为 i32，保持 API 兼容
}

// ===== 初始化函数 =====

// 初始化 TypeChecker
fn checker_init(checker: &TypeChecker, arena: &CompilerArena, default_filename: &byte) i32 {
    if checker == null || arena == null {
        return -1;
    }
    
    checker.arena = arena;
    
    // 初始化符号表（所有槽位设为null）
    var i: i32 = 0;
    while i < SYMBOL_TABLE_SIZE {
        checker.symbol_table.slots[i] = null;
        i = i + 1;
    }
    checker.symbol_table.count = 0;
    
    // 初始化函数表（所有槽位设为null）
    i = 0;
    while i < FUNCTION_TABLE_SIZE {
        checker.function_table.slots[i] = null;
        i = i + 1;
    }
    checker.function_table.count = 0;
    
    // 初始化模块表（所有槽位设为null）
    i = 0;
    while i < MODULE_TABLE_SIZE {
        checker.module_table.slots[i] = null;
        i = i + 1;
    }
    checker.module_table.count = 0;
    
    // 初始化导入表（所有槽位设为null）
    i = 0;
    while i < IMPORT_TABLE_SIZE {
        checker.import_table.slots[i] = null;
        i = i + 1;
    }
    checker.import_table.count = 0;

    // 初始化字符串池（所有桶设为null）
    i = 0;
    while i < STRING_POOL_SIZE {
        checker.string_pool.buckets[i] = null;
        i = i + 1;
    }
    checker.string_pool.count = 0;

    // 初始化作用域链表头数组
    i = 0;
    while i < @len(checker.scope_heads) {
        checker.scope_heads[i] = null;
        i = i + 1;
    }
    i = 0;
    while i < @len(checker.async_call_edge_from) {
        checker.async_call_edge_from[i] = null;
        checker.async_call_edge_to[i] = null;
        i = i + 1;
    }
    checker.async_call_edge_count = 0;
    i = 0;
    while i < @len(checker.fn_call_edge_from) {
        checker.fn_call_edge_from[i] = null;
        checker.fn_call_edge_to[i] = null;
        i = i + 1;
    }
    checker.fn_call_edge_count = 0;
    i = 0;
    while i < @len(checker.fn_root_decls) {
        checker.fn_root_decls[i] = null;
        i = i + 1;
    }
    checker.fn_root_count = 0;
    i = 0;
    while i < @len(checker.reachable_fn_decls) {
        checker.reachable_fn_decls[i] = null;
        i = i + 1;
    }
    checker.reachable_fn_decl_count = 0;
    i = 0;
    while i < @len(checker.reachability_visit_cache) {
        checker.reachability_visit_cache[i] = null;
        i = i + 1;
    }
    checker.reachability_visit_count = 0;

    checker.scope_level = 0;
    checker.loop_depth = 0;
    checker.program_node = null;
    checker.error_count = 0;
    checker.last_reported_error_filename = null;
    checker.last_reported_error_message = null;
    checker.last_reported_error_line = 0;
    checker.last_reported_error_column = 0;
    checker.default_filename = default_filename;
    checker.current_return_type.kind = TypeKind.TYPE_VOID;
    checker.in_function = 0;
    checker.in_defer_or_errdefer = 0;
    checker.current_function_decl = null;
    checker.current_self_type_name = null;
    checker.current_self_is_union = 0;
    checker.error_name_count = 0;
    
    // 初始化错误集（所有槽位设为null）
    for 0..@len(checker.error_names) |i| {
        checker.error_names[i] = null;
    }
    
    checker.moved_count = 0;
    checker.project_root_dir = null;
    checker.uya_root_dir = null;
    
    // 初始化泛型相关字段
    checker.current_type_params = null;
    checker.current_type_param_count = 0;
    checker.mono_instance_count = 0;
    
    // 初始化约束系统
    for 0..@len(checker.constraint_var_names) |i| {
        checker.constraint_var_names[i] = null;
        checker.constraint_ops[i] = 0;
        checker.constraint_values[i] = 0;
    }
    checker.constraint_count = 0;
    
    // 初始化指针非空状态跟踪
    for 0..@len(checker.pointer_nonnull_names) |i| {
        checker.pointer_nonnull_names[i] = null;
    }
    checker.pointer_nonnull_count = 0;
    
    // 初始化可能为空的指针跟踪
    for 0..@len(checker.pointer_nullable_names) |i| {
        checker.pointer_nullable_names[i] = null;
    }
    checker.pointer_nullable_count = 0;
    
    // 与 uya CLI 默认一致；compile_files 会按参数覆盖
    checker.enable_safety_proof = 1;
    checker.container_mode = 0;  // 默认 kernel 模式（允许 @asm/extern）

    // 证明超时机制：默认限制 1000 步
    checker.proof_step_limit = 1000;
    checker.proof_step_count = 0;
    checker.suppress_codegen_diagnostics = 0;
    
    return 0;
}

fn checker_find_reachable_fn_decl_by_name(checker: &TypeChecker, name: &byte) &ASTNode {
    if checker == null || name == null || checker.program_node == null ||
        checker.program_node.type != ASTNodeType.AST_PROGRAM {
        return null;
    }
    var i: i32 = 0;
    while i < checker.program_node.program_decl_count {
        const decl: &ASTNode = checker.program_node.program_decls[i];
        if decl != null && decl.type == ASTNodeType.AST_FN_DECL && decl.fn_decl_name != null &&
            str_equals(decl.fn_decl_name, name) != 0 && decl.fn_decl_body != null {
            return decl;
        }
        i = i + 1;
    }
    i = 0;
    while i < checker.program_node.program_decl_count {
        const decl: &ASTNode = checker.program_node.program_decls[i];
        if decl != null && decl.type == ASTNodeType.AST_FN_DECL && decl.fn_decl_name != null &&
            str_equals(decl.fn_decl_name, name) != 0 {
            return decl;
        }
        i = i + 1;
    }
    return null;
}

fn checker_canonicalize_fn_decl(checker: &TypeChecker, fn_decl: &ASTNode) &ASTNode {
    if checker == null || fn_decl == null || fn_decl.type != ASTNodeType.AST_FN_DECL ||
        fn_decl.fn_decl_name == null || checker.program_node == null ||
        checker.program_node.type != ASTNodeType.AST_PROGRAM {
        return fn_decl;
    }
    var fn_has_body: i32 = 0;
    if fn_decl.fn_decl_body != null {
        fn_has_body = 1;
    }
    var i: i32 = 0;
    while i < checker.program_node.program_decl_count {
        const decl: &ASTNode = checker.program_node.program_decls[i];
        if decl != null && decl.type == ASTNodeType.AST_FN_DECL && decl.fn_decl_name != null &&
            str_equals(decl.fn_decl_name, fn_decl.fn_decl_name) != 0 &&
            decl.fn_decl_is_extern == fn_decl.fn_decl_is_extern {
            var decl_has_body: i32 = 0;
            if decl.fn_decl_body != null {
                decl_has_body = 1;
            }
            if decl_has_body == fn_has_body {
                return decl;
            }
        }
        i = i + 1;
    }
    i = 0;
    while i < checker.program_node.program_decl_count {
        const decl: &ASTNode = checker.program_node.program_decls[i];
        if decl != null && decl.type == ASTNodeType.AST_FN_DECL && decl.fn_decl_name != null &&
            str_equals(decl.fn_decl_name, fn_decl.fn_decl_name) != 0 {
            return decl;
        }
        i = i + 1;
    }
    return fn_decl;
}

fn checker_fn_root_decl_at(checker: &TypeChecker, idx: i32) &ASTNode {
    if checker == null {
        return null;
    }
    if idx >= 0 && idx < MAX_FN_ROOTS {
        return checker.fn_root_decls[idx];
    }
    return null;
}

fn checker_fn_root_decl_set(checker: &TypeChecker, idx: i32, value: &ASTNode) void {
    if checker == null {
        return;
    }
    if idx >= 0 && idx < MAX_FN_ROOTS {
        checker.fn_root_decls[idx] = value;
    }
}

fn checker_scope_head_at(checker: &TypeChecker, idx: i32) &Symbol {
    if checker == null {
        return null;
    }
    if idx >= 0 && idx < 64 {
        return checker.scope_heads[idx];
    }
    return null;
}

fn checker_scope_head_set(checker: &TypeChecker, idx: i32, value: &Symbol) void {
    if checker == null {
        return;
    }
    if idx >= 0 && idx < 64 {
        checker.scope_heads[idx] = value;
    }
}

fn checker_symbol_slot_at(checker: &TypeChecker, idx: i32) &Symbol {
    if checker == null {
        return null;
    }
    if idx >= 0 && idx < SYMBOL_TABLE_SIZE {
        return checker.symbol_table.slots[idx];
    }
    return null;
}

fn checker_symbol_slot_set(checker: &TypeChecker, idx: i32, value: &Symbol) void {
    if checker == null {
        return;
    }
    if idx >= 0 && idx < SYMBOL_TABLE_SIZE {
        checker.symbol_table.slots[idx] = value;
    }
}

fn checker_function_slot_at(checker: &TypeChecker, idx: i32) &FunctionSignature {
    if checker == null {
        return null;
    }
    if idx >= 0 && idx < FUNCTION_TABLE_SIZE {
        return checker.function_table.slots[idx];
    }
    return null;
}

fn checker_function_slot_set(checker: &TypeChecker, idx: i32, value: &FunctionSignature) void {
    if checker == null {
        return;
    }
    if idx >= 0 && idx < FUNCTION_TABLE_SIZE {
        checker.function_table.slots[idx] = value;
    }
}

fn checker_add_function_root_decl(checker: &TypeChecker, fn_decl: &ASTNode) i32 {
    const canonical_fn_decl: &ASTNode = checker_canonicalize_fn_decl(checker, fn_decl);
    if checker == null || canonical_fn_decl == null || canonical_fn_decl.type != ASTNodeType.AST_FN_DECL {
        return 0;
    }
    var i: i32 = 0;
    while i < checker.fn_root_count {
        if checker_fn_root_decl_at(checker, i) == canonical_fn_decl {
            return 1;
        }
        i = i + 1;
    }
    if checker.fn_root_count >= MAX_FN_ROOTS {
        checker_report_error(checker, canonical_fn_decl, "顶层函数 root 容量已满" as *byte);
        return 0;
    }
    const root_idx: i32 = checker.fn_root_count;
    if root_idx < 0 || root_idx >= @len(checker.fn_root_decls) {
        return 0;
    }
    checker_fn_root_decl_set(checker, root_idx, canonical_fn_decl);
    checker.fn_root_count = root_idx + 1;
    return 1;
}

fn checker_add_function_root_by_name(checker: &TypeChecker, name: &byte) i32 {
    const fn_decl: &ASTNode = checker_find_reachable_fn_decl_by_name(checker, name);
    if fn_decl == null {
        return 0;
    }
    return checker_add_function_root_decl(checker, fn_decl);
}

fn checker_add_function_edge(checker: &TypeChecker, from_decl: &ASTNode, to_decl: &ASTNode) i32 {
    const canonical_from_decl: &ASTNode = checker_canonicalize_fn_decl(checker, from_decl);
    const canonical_to_decl: &ASTNode = checker_canonicalize_fn_decl(checker, to_decl);
    if checker == null || canonical_from_decl == null || canonical_to_decl == null ||
        canonical_from_decl.type != ASTNodeType.AST_FN_DECL || canonical_to_decl.type != ASTNodeType.AST_FN_DECL {
        return 0;
    }
    var i: i32 = 0;
    while i < checker.fn_call_edge_count {
        if checker.fn_call_edge_from[i] == canonical_from_decl && checker.fn_call_edge_to[i] == canonical_to_decl {
            return 1;
        }
        i = i + 1;
    }
    if checker.fn_call_edge_count >= MAX_FN_CALL_EDGES {
        checker_report_error(checker, canonical_from_decl, "顶层函数 call edge 容量已满" as *byte);
        return 0;
    }
    const edge_idx: i32 = checker.fn_call_edge_count;
    if edge_idx >= 0 && edge_idx < @len(checker.fn_call_edge_from) && edge_idx < @len(checker.fn_call_edge_to) {
        checker.fn_call_edge_from[edge_idx] = canonical_from_decl;
        checker.fn_call_edge_to[edge_idx] = canonical_to_decl;
        checker.fn_call_edge_count = edge_idx + 1;
        return 1;
    }
    return 0;
}

fn checker_mark_reachability_node_visited(checker: &TypeChecker, node: &ASTNode) i32 {
    if checker == null || node == null {
        return 0;
    }
    if checker.reachability_visit_count >= MAX_REACHABILITY_VISIT_SLOTS {
        return 1;
    }
    const node_hash: usize = (@usize_from_ptr(node as &void) / 8 as usize);
    var slot: i32 = (node_hash & MAX_REACHABILITY_VISIT_MASK) as i32;
    var probe: i32 = 0;
    while probe < MAX_REACHABILITY_VISIT_SLOTS {
        const entry: &ASTNode = checker.reachability_visit_cache[slot];
        if entry == node {
            return 0;
        }
        if entry == null {
            checker.reachability_visit_cache[slot] = node;
            checker.reachability_visit_count = checker.reachability_visit_count + 1;
            return 1;
        }
        slot = (slot + 1) & (MAX_REACHABILITY_VISIT_SLOTS - 1);
        probe = probe + 1;
    }
    return 1;
}

fn checker_reset_reachability_visit_cache(checker: &TypeChecker) void {
    if checker == null {
        return;
    }
    var i: i32 = 0;
    while i < @len(checker.reachability_visit_cache) {
        checker.reachability_visit_cache[i] = null;
        i = i + 1;
    }
    checker.reachability_visit_count = 0;
}

fn checker_is_function_reachable(checker: &TypeChecker, fn_decl: &ASTNode) i32 {
    if checker == null || fn_decl == null || fn_decl.type != ASTNodeType.AST_FN_DECL {
        return 0;
    }
    var i: i32 = 0;
    while i < checker.reachable_fn_decl_count {
        if checker.reachable_fn_decls[i] == fn_decl {
            return 1;
        }
        i = i + 1;
    }
    return 0;
}

fn checker_compute_function_reachability(checker: &TypeChecker) void {
    if checker == null {
        return;
    }
    checker.reachable_fn_decl_count = 0;
    var queue: [&ASTNode: MAX_REACHABLE_FN_DECLS] = [];
    var head: i32 = 0;
    var tail: i32 = 0;
    var i: i32 = 0;
    while i < checker.fn_root_count {
        const root_decl: &ASTNode = checker_fn_root_decl_at(checker, i);
        if root_decl != null && checker_is_function_reachable(checker, root_decl) == 0 {
            if checker.reachable_fn_decl_count >= MAX_REACHABLE_FN_DECLS {
                checker_report_error(checker, root_decl, "顶层函数 reachable 集合已满" as *byte);
                return;
            }
            const reachable_idx: i32 = checker.reachable_fn_decl_count;
            if reachable_idx < 0 || reachable_idx >= @len(checker.reachable_fn_decls) {
                return;
            }
            checker.reachable_fn_decls[reachable_idx] = root_decl;
            checker.reachable_fn_decl_count = reachable_idx + 1;
            if tail >= MAX_REACHABLE_FN_DECLS {
                checker_report_error(checker, root_decl, "顶层函数 reachable 队列已满" as *byte);
                return;
            }
            queue[tail] = root_decl;
            tail = tail + 1;
        }
        i = i + 1;
    }

    while head < tail {
        const from_decl: &ASTNode = queue[head];
        head = head + 1;
        i = 0;
        while i < checker.fn_call_edge_count {
            if checker.fn_call_edge_from[i] == from_decl {
                const to_decl: &ASTNode = checker.fn_call_edge_to[i];
                if to_decl != null && checker_is_function_reachable(checker, to_decl) == 0 {
                    if checker.reachable_fn_decl_count >= MAX_REACHABLE_FN_DECLS {
                        checker_report_error(checker, to_decl, "顶层函数 reachable 集合已满" as *byte);
                        return;
                    }
                    const reachable_idx2: i32 = checker.reachable_fn_decl_count;
                    if reachable_idx2 < 0 || reachable_idx2 >= @len(checker.reachable_fn_decls) {
                        return;
                    }
                    checker.reachable_fn_decls[reachable_idx2] = to_decl;
                    checker.reachable_fn_decl_count = reachable_idx2 + 1;
                    if tail >= MAX_REACHABLE_FN_DECLS {
                        checker_report_error(checker, to_decl, "顶层函数 reachable 队列已满" as *byte);
                        return;
                    }
                    queue[tail] = to_decl;
                    tail = tail + 1;
                }
            }
            i = i + 1;
        }
    }
}

// 获取错误计数
fn checker_get_error_count(checker: &TypeChecker) i32 {
    if checker == null {
        return 0;
    }
    return checker.error_count;
}

// ===== 符号表操作 =====

// 符号表查找函数（支持作用域查找，返回最内层匹配的符号）
// 优化：使用作用域链表，从当前作用域向外查找
fn symbol_table_lookup(checker: &TypeChecker, name: &byte) &Symbol {
    if checker == null || name == null {
        return null;
    }

    // 从当前作用域开始向外查找
    var scope: i32 = checker.scope_level;
    while scope >= 0 {
        const scope_idx: i32 = scope;
        if scope_idx < 0 {
            break;
        }
        if scope_idx >= @len(checker.scope_heads) {
            scope = scope - 1;
            continue;
        }
        var symbol: &Symbol = checker_scope_head_at(checker, scope_idx);
        while symbol != null {
            // 使用优化的 str_equals（先比较指针）
            if str_equals(symbol.name, name) != 0 {
                return symbol;  // 找到最内层匹配
            }
            symbol = symbol.next_in_scope;
        }
        scope = scope - 1;
    }

    return null;
}

// 符号表插入函数（使用开放寻址的哈希表）
// 同时将符号添加到当前作用域的链表
fn symbol_table_insert(checker: &TypeChecker, symbol: &Symbol) i32 {
    if checker == null || symbol == null || symbol.name == null {
        return -1;
    }
    
    const existing: &Symbol = symbol_table_lookup(checker, symbol.name);
    if existing != null && existing.scope_level == symbol.scope_level {
        return -1;
    }
    
    const hash: i32 = hash_string(symbol.name);
    var index: i32 = hash % SYMBOL_TABLE_SIZE;
    if index < 0 {
        index = index + SYMBOL_TABLE_SIZE;
    }
    
    var i: i32 = 0;
    while i < SYMBOL_TABLE_SIZE {
        const slot: i32 = (index + i) % SYMBOL_TABLE_SIZE;
        const slot_idx: i32 = slot;
        if slot_idx < 0 {
            i = i + 1;
            continue;
        }
        if slot_idx >= @len(checker.symbol_table.slots) {
            i = i + 1;
            continue;
        }
        
        if checker_symbol_slot_at(checker, slot_idx) == null {
            checker_symbol_slot_set(checker, slot_idx, symbol);
            checker.symbol_table.count = checker.symbol_table.count + 1;

            // 添加到当前作用域的链表头部
            const scope: i32 = symbol.scope_level;
            if scope >= 0 {
                if scope < @len(checker.scope_heads) {
                    symbol.next_in_scope = checker_scope_head_at(checker, scope);
                    checker_scope_head_set(checker, scope, symbol);
                }
            }

            return 0;
        }
        i = i + 1;
    }
    
    return -1;
}

// ===== 函数表操作 =====

// 函数表查找函数
fn function_table_lookup(checker: &TypeChecker, name: &byte) &FunctionSignature {
    if checker == null || name == null {
        return null;
    }
    
    const hash: i32 = hash_string(name);
    var index: i32 = hash % FUNCTION_TABLE_SIZE;
    if index < 0 {
        index = index + FUNCTION_TABLE_SIZE;
    }
    
    var i: i32 = 0;
    while i < FUNCTION_TABLE_SIZE {
        const slot: i32 = (index + i) % FUNCTION_TABLE_SIZE;
        const slot_idx: i32 = slot;
        if slot_idx < 0 {
            i = i + 1;
            continue;
        }
        if slot_idx >= @len(checker.function_table.slots) {
            i = i + 1;
            continue;
        }
        const sig: &FunctionSignature = checker_function_slot_at(checker, slot_idx);
        
        if sig == null {
            i = i + 1;
            continue;
        }
        
        var matched: i32 = 1;
        var j: i32 = 0;
        while matched != 0 {
            const c1: byte = sig.name[j] as byte;
            const c2: byte = name[j] as byte;
            if c1 != c2 {
                matched = 0;
            } else if c1 == 0 {
                if c2 != 0 {
                    matched = 0;
                }
                break;
            }
            j = j + 1;
        }
        
        if matched != 0 {
            return sig;
        }
        
        i = i + 1;
    }
    
    return null;
}

// 函数表插入函数（使用开放寻址的哈希表）
fn function_table_insert(checker: &TypeChecker, sig: &FunctionSignature) i32 {
    if checker == null || sig == null || sig.name == null {
        return -1;
    }
    
    const hash: i32 = hash_string(sig.name);
    var index: i32 = hash % FUNCTION_TABLE_SIZE;
    if index < 0 {
        index = index + FUNCTION_TABLE_SIZE;
    }
    
    var i: i32 = 0;
    while i < FUNCTION_TABLE_SIZE {
        const slot: i32 = (index + i) % FUNCTION_TABLE_SIZE;
        const slot_idx: i32 = slot;
        if slot_idx < 0 {
            i = i + 1;
            continue;
        }
        if slot_idx >= @len(checker.function_table.slots) {
            i = i + 1;
            continue;
        }
        const existing: &FunctionSignature = checker_function_slot_at(checker, slot_idx);
        
        if existing == null {
            checker_function_slot_set(checker, slot_idx, sig);
            checker.function_table.count = checker.function_table.count + 1;
            return 0;
        }
        
        var matched: i32 = 1;
        var j: i32 = 0;
        while matched != 0 {
            const c1: byte = existing.name[j] as byte;
            const c2: byte = sig.name[j] as byte;
            if c1 != c2 {
                matched = 0;
            } else if c1 == 0 {
                if c2 != 0 {
                    matched = 0;
                }
                break;
            }
            j = j + 1;
        }
        
        if matched != 0 {
            if existing.is_extern != 0 && sig.is_extern != 0 {
                if existing.param_count == sig.param_count &&
                    type_equals(existing.return_type, sig.return_type) != 0 &&
                    existing.is_varargs == sig.is_varargs {
                    return 0;
                } else {
                    return -1;
                }
            } else if existing.is_extern == 0 && sig.is_extern == 0 {
                return -1;
            } else {
                if existing.is_extern != 0 {
                    checker_function_slot_set(checker, slot_idx, sig);
                    return 0;
                } else {
                    return 0;
                }
            }
        }
        
        i = i + 1;
    }
    
    return -1;
}

// ===== 作用域管理 =====

// 进入作用域
fn checker_enter_scope(checker: &TypeChecker) void {
    if checker != null {
        checker.scope_level = checker.scope_level + 1;
    }
}

// 退出作用域
// 优化：使用作用域链表快速清理，避免遍历整个符号表
fn checker_exit_scope(checker: &TypeChecker) void {
    if checker == null || checker.scope_level <= 0 {
        return;
    }
    
    const current_scope: i32 = checker.scope_level;

    // 使用作用域链表遍历当前作用域的所有符号
    if current_scope >= 0 {
        const scope_idx: i32 = current_scope;
        if scope_idx < 0 {
            return;
        }
        if scope_idx >= @len(checker.scope_heads) {
            return;
        }
        var symbol: &Symbol = checker_scope_head_at(checker, scope_idx);
        while symbol != null {
            // 从哈希表中移除符号
            const hash: i32 = hash_string(symbol.name);
            var index: i32 = hash % SYMBOL_TABLE_SIZE;
            if index < 0 {
                index = index + SYMBOL_TABLE_SIZE;
            }
            
            var i: i32 = 0;
            while i < SYMBOL_TABLE_SIZE {
                const slot: i32 = (index + i) % SYMBOL_TABLE_SIZE;
                if checker_symbol_slot_at(checker, slot) == symbol {
                    checker_symbol_slot_set(checker, slot, null);
                    checker.symbol_table.count = checker.symbol_table.count - 1;
                    break;
                }
                if checker_symbol_slot_at(checker, slot) == null {
                    break;
                }
                i = i + 1;
            }
            
            const next: &Symbol = symbol.next_in_scope;
            symbol.next_in_scope = null;
            symbol = next;
        }
        checker_scope_head_set(checker, scope_idx, null);
    }
    
    checker.scope_level = checker.scope_level - 1;
}

// ===== 字符串工具 =====

// 字符串比较辅助函数（Uya 没有 strcmp）
// 优化：先比较指针，相同则直接返回
fn str_equals(s1: &byte, s2: &byte) i32 {
    if s1 == null && s2 == null {
        return 1;
    }
    if s1 == null || s2 == null {
        return 0;
    }
    // 快速路径：指针相同，字符串必定相同
    if s1 == s2 {
        return 1;
    }
    var i: i32 = 0;
    while true {
        const c1: byte = s1[i] as byte;
        const c2: byte = s2[i] as byte;
        if c1 != c2 {
            return 0;
        }
        if c1 == 0 {
            return 1;
        }
        i = i + 1;
    }
    return 0;
}

// ===== 字符串池（String Interning）=====

// 字符串池：查找或插入字符串
// 如果字符串已存在，返回现有指针；否则创建新条目
fn string_pool_intern(pool: &StringPool, arena: &CompilerArena, str: &byte) &byte {
    if pool == null || arena == null || str == null {
        return str;
    }

    const hash: i32 = hash_string(str);
    const bucket_idx: i32 = hash % STRING_POOL_SIZE;
    if bucket_idx < 0 {
        return str;
    }
    if bucket_idx >= STRING_POOL_SIZE {
        return str;
    }

    // 查找现有条目
    var entry: &StringPoolEntry = pool.buckets[bucket_idx];
    while entry != null {
        // 快速检查：哈希值相同才比较字符串
        if entry.hash == hash && entry.str != null {
            // 指针比较：如果字符串已在池中
            if entry.str == str {
                return entry.str;
            }
            // 字符串比较
            if str_equals(entry.str, str) != 0 {
                return entry.str;  // 返回已存在的字符串指针
            }
        }
        entry = entry.next;
    }

    // 创建新条目
    const n: usize = strlen(str as *byte) + 1;
    const new_str: &byte = compiler_arena_alloc(arena, n) as &byte;
    if new_str == null {
        return str;
    }
    memcpy(new_str as *void, str as *void, n);

    const new_entry: &StringPoolEntry = compiler_arena_alloc(arena, @size_of(StringPoolEntry) as usize) as &StringPoolEntry;
    if new_entry == null {
        return new_str;
    }
    new_entry.str = new_str;
    new_entry.hash = hash;
    new_entry.next = pool.buckets[bucket_idx];
    pool.buckets[bucket_idx] = new_entry;
    pool.count = pool.count + 1;

    return new_str;
}

// 从 Arena 复制字符串（不使用字符串池）
fn checker_arena_strdup(arena: &CompilerArena, src: &byte) &byte {
    if arena == null || src == null {
        return null;
    }
    const n: usize = strlen(src as *byte) + 1;
    const result: &byte = compiler_arena_alloc(arena, n) as &byte;
    if result == null {
        return null;
    }
    memcpy(result as *void, src as *void, n);
    return result;
}

// 从 Arena 复制字符串（使用字符串池，优化版本）
// 如果字符串已存在，返回现有指针；否则创建新条目
fn checker_intern_strdup(checker: &TypeChecker, src: &byte) &byte {
    if checker == null || src == null {
        return null;
    }
    return string_pool_intern(&checker.string_pool, checker.arena, src);
}

// ===== 移动语义 =====

// 已移动集合检查
fn moved_set_contains(checker: &TypeChecker, name: &byte) i32 {
    if checker == null || name == null {
        return 0;
    }
    var i: i32 = 0;
    const count: i32 = checker.moved_count;
    while i < count {
        if i < MAX_MOVED_NAMES {
            const name_ptr: &byte = checker.moved_names[i];
            if name_ptr != null && str_equals(name_ptr, name) != 0 {
                return 1;
            }
        }
        i = i + 1;
    }
    return 0;
}

// 检查是否有活跃指针指向变量
// 优化：只遍历当前作用域及内层作用域的符号
fn has_active_pointer_to(checker: &TypeChecker, var_name: &byte) i32 {
    if checker == null || var_name == null {
        return 0;
    }
    // 遍历所有作用域的符号
    var scope: i32 = checker.scope_level;
    while scope >= 0 {
        if scope < @len(checker.scope_heads) {
            var s: &Symbol = checker_scope_head_at(checker, scope);
            while s != null {
                if s.pointee_of != null && str_equals(s.pointee_of, var_name) != 0 {
                    return 1;
                }
                s = s.next_in_scope;
            }
        }
        scope = scope - 1;
    }
    return 0;
}

// 标记变量已移动
fn checker_mark_moved(checker: &TypeChecker, node: &ASTNode, var_name: &byte, struct_name: &byte) void {
    if checker == null || var_name == null || struct_name == null {
        return;
    }
    // 不标记 match 等引入的绑定变量（无 decl_node），避免误报「变量已被移动」
    const sym: &Symbol = symbol_table_lookup(checker, var_name);
    if sym != null && sym.decl_node == null {
        return;
    }
    var err_node: &ASTNode = node;
    if node == null {
        err_node = checker.current_function_decl;
    }
    if has_active_pointer_to(checker, var_name) != 0 {
        checker_report_error(checker, err_node, "变量存在活跃指针，不能移动" as *byte);
        return;
    }
    if checker.loop_depth > 0 {
        checker_report_error(checker, err_node, "循环中的变量不能移动" as *byte);
        return;
    }
    if checker.moved_count >= MAX_MOVED_NAMES {
        return;
    }
    const idx: i32 = checker.moved_count;
    const copy: &byte = checker_intern_strdup(checker, var_name);
    if copy != null {
        if idx >= 0 && idx < MAX_MOVED_NAMES {
            checker.moved_names[idx] = copy;
        }
        checker.moved_count = idx + 1;
    }
    // 写回 VAR_DECL 的 was_moved
    if sym != null && sym.decl_node != null && sym.decl_node.type == ASTNodeType.AST_VAR_DECL {
        sym.decl_node.var_decl_was_moved = 1;
    }
}

// 标记调用参数已移动
fn checker_mark_moved_call_args(checker: &TypeChecker, node: &ASTNode) void {
    if checker == null || node == null || node.type != ASTNodeType.AST_CALL_EXPR {
        return;
    }
    const callee: &ASTNode = node.call_expr_callee;
    const n: i32 = node.call_expr_arg_count;
    const args: & & ASTNode = node.call_expr_args;
    if args == null {
        return;
    }
    if callee.type == ASTNodeType.AST_MEMBER_ACCESS {
        var owner_is_union: i32 = 0;
        const owner_name: &byte = checker_type_namespace_owner_name(checker, callee.member_access_object, &owner_is_union);
        if owner_name != null {
            var static_method: &ASTNode = null;
            var instance_method: &ASTNode = null;
            if owner_is_union != 0 {
                static_method = find_static_method_in_union(checker.program_node, owner_name, callee.member_access_field_name);
                instance_method = find_instance_method_in_union(checker.program_node, owner_name, callee.member_access_field_name);
            } else {
                static_method = find_static_method_in_struct(checker.program_node, owner_name, callee.member_access_field_name);
                instance_method = find_instance_method_in_struct(checker.program_node, owner_name, callee.member_access_field_name);
            }
            if static_method != null && static_method.type == ASTNodeType.AST_FN_DECL && static_method.fn_decl_params != null {
                var i_static: i32 = 0;
                while i_static < n && i_static < static_method.fn_decl_param_count {
                    const arg_static: &ASTNode = args[i_static];
                    if arg_static != null && arg_static.type == ASTNodeType.AST_IDENTIFIER {
                        const param_static: &ASTNode = static_method.fn_decl_params[i_static];
                        if param_static != null && param_static.type == ASTNodeType.AST_VAR_DECL && param_static.var_decl_type != null {
                            const pt_static: Type = type_from_ast(checker, param_static.var_decl_type);
                            if pt_static.kind == TypeKind.TYPE_STRUCT && pt_static.struct_name != null {
                                checker_mark_moved(checker, arg_static, arg_static.identifier_name, pt_static.struct_name);
                            }
                        }
                    }
                    i_static = i_static + 1;
                }
                return;
            }
            if instance_method != null && instance_method.type == ASTNodeType.AST_FN_DECL && instance_method.fn_decl_params != null {
                var i_inst: i32 = 1;
                while i_inst < n && i_inst < instance_method.fn_decl_param_count {
                    const arg_inst: &ASTNode = args[i_inst];
                    if arg_inst != null && arg_inst.type == ASTNodeType.AST_IDENTIFIER {
                        const param_inst: &ASTNode = instance_method.fn_decl_params[i_inst];
                        if param_inst != null && param_inst.type == ASTNodeType.AST_VAR_DECL && param_inst.var_decl_type != null {
                            const pt_inst: Type = type_from_ast(checker, param_inst.var_decl_type);
                            if pt_inst.kind == TypeKind.TYPE_STRUCT && pt_inst.struct_name != null {
                                checker_mark_moved(checker, arg_inst, arg_inst.identifier_name, pt_inst.struct_name);
                            }
                        }
                    }
                    i_inst = i_inst + 1;
                }
                return;
            }
        }
        var object_type: Type = checker_infer_type(checker, callee.member_access_object);
        if object_type.kind == TypeKind.TYPE_POINTER && object_type.pointer_to != null {
            object_type = object_type.pointer_to[0];
        }
        if object_type.kind == TypeKind.TYPE_STRUCT && object_type.struct_name != null && checker.program_node != null {
            const m: &ASTNode = find_instance_method_in_struct(checker.program_node, object_type.struct_name, callee.member_access_field_name);
            if m != null && m.type == ASTNodeType.AST_FN_DECL && m.fn_decl_params != null {
                var i: i32 = 0;
                while i < n && i + 1 < m.fn_decl_param_count {
                    const arg: &ASTNode = args[i];
                    if arg != null && arg.type == ASTNodeType.AST_IDENTIFIER {
                        const param: &ASTNode = m.fn_decl_params[i + 1];
                        if param != null && param.type == ASTNodeType.AST_VAR_DECL && param.var_decl_type != null {
                            const pt: Type = type_from_ast(checker, param.var_decl_type);
                            if pt.kind == TypeKind.TYPE_STRUCT && pt.struct_name != null {
                                checker_mark_moved(checker, arg, arg.identifier_name, pt.struct_name);
                            }
                        }
                    }
                    i = i + 1;
                }
            }
        }
        return;
    }
    if callee.type != ASTNodeType.AST_IDENTIFIER {
        return;
    }
    const sig: &FunctionSignature = function_table_lookup(checker, callee.identifier_name);
    if sig == null || sig.param_types == null {
        return;
    }
    var i: i32 = 0;
    while i < n && i < sig.param_count {
        if args[i] != null && args[i].type == ASTNodeType.AST_IDENTIFIER &&
            sig.param_types[i].kind == TypeKind.TYPE_STRUCT && sig.param_types[i].struct_name != null {
            checker_mark_moved(checker, args[i], args[i].identifier_name, sig.param_types[i].struct_name);
        }
        i = i + 1;
    }
}

// ===== 错误ID管理 =====

// hash(error_name)，0 保留；djb2 算法
fn hash_error_name(name: &byte) u32 {
    var h: u32 = 5381;
    var i: i32 = 0;
    while name[i] != 0 {
        const c: u32 = (name[i] as byte) as u32;
        h = ((h * 32) + h) + c;
        i = i + 1;
    }
    if h == 0 { return 1; }
    return h;
}

// 获取或添加错误 ID
fn get_or_add_error_id(checker: &TypeChecker, name: &byte, node: &ASTNode) u32 {
    if checker == null || name == null {
        return 0;
    }
    const h: u32 = hash_error_name(name);
    var i: i32 = 0;
    const count: i32 = checker.error_name_count;
    while i < count {
        if i < MAX_ERROR_NAMES {
            const err_name: &byte = checker.error_names[i];
            const err_hash: u32 = checker.error_hashes[i];
            if err_name != null && str_equals(err_name, name) != 0 {
                return err_hash;
            }
            if err_hash == h && err_name != null && str_equals(err_name, name) == 0 {
                checker_report_error(checker, node, "error_id 冲突: 请重命名其一" as *byte);
                return 0;
            }
        }
        i = i + 1;
    }
    if checker.error_name_count >= MAX_ERROR_NAMES {
        return 0;
    }
    const idx: i32 = checker.error_name_count;
    const copy: &byte = checker_intern_strdup(checker, name);
    if copy == null {
        return 0;
    }
    if idx >= 0 && idx < MAX_ERROR_NAMES {
        checker.error_names[idx] = copy;
        checker.error_hashes[idx] = h;
    }
    checker.error_name_count = idx + 1;
    return h;
}
