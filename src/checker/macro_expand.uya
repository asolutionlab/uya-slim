// checker/macro_expand.uya - 宏展开函数
// 从 main.uya 拆分
// 包含：宏声明查找、参数绑定、AST 节点创建、宏求值、AST 深拷贝、宏输出提取


// ===== 宏展开相关函数 =====

// 从程序节点查找宏声明
fn find_macro_decl_from_program(program: &ASTNode, macro_name: &byte) &ASTNode {
    if program == null || program.type != ASTNodeType.AST_PROGRAM || macro_name == null {
        return null;
    }
    
    var i: i32 = 0;
    while i < program.program_decl_count {
        const decl: &ASTNode = program.program_decls[i];
        if decl != null && decl.type == ASTNodeType.AST_MACRO_DECL {
            if decl.macro_decl_name != null && 
               str_equals(decl.macro_decl_name, macro_name) != 0 {
                return decl;
            }
        }
        i = i + 1;
    }
    return null;
}

// 宏参数绑定结构体
struct MacroParamBinding {
    param_name: &byte,   // 参数名
    arg_ast: &ASTNode,   // 实参 AST 节点
}

struct HygieneCopyState {
    scope_names: [&byte: 256],
    scope_renamed_names: [&byte: 256],
    scope_entry_count: i32,
    scope_starts: [i32: 64],
    scope_depth: i32,
}

// 宏展开上下文
struct MacroExpandContext {
    bindings: &MacroParamBinding,  // 参数绑定数组
    binding_count: i32,            // 绑定数量
    arena: &CompilerArena,                 // Arena 分配器
    checker: &TypeChecker,         // 类型检查器（用于报告错误）
    hygiene_enabled: i32,          // 是否启用卫生重命名
    hygiene_expansion_id: i32,     // 本次宏展开的唯一编号
    hygiene_next_local_id: i32,    // 本次展开内下一个局部绑定编号
}

var macro_hygiene_expansion_counter: i32 = 0;

// 在绑定中查找参数
fn find_param_binding(ctx: &MacroExpandContext, name: &byte) &ASTNode {
    if ctx == null || ctx.bindings == null || name == null {
        return null;
    }
    var i: i32 = 0;
    while i < ctx.binding_count {
        if ctx.bindings[i].param_name != null && strcmp(ctx.bindings[i].param_name as *byte, name as *byte) == 0 {
            return ctx.bindings[i].arg_ast;
        }
        i = i + 1;
    }
    return null;
}

// 创建数字字面量 AST 节点
fn create_number_literal(value: i64, arena: &CompilerArena, line: i32, column: i32) &ASTNode {
    const node: &ASTNode = ast_new_node(ASTNodeType.AST_NUMBER, line, column, arena, null);
    if node == null {
        return null;
    }
    node.number_value = value as i32;
    node.number_value_i64 = value;
    return node;
}

// 创建布尔字面量 AST 节点
fn create_bool_literal(value: i32, arena: &CompilerArena, line: i32, column: i32) &ASTNode {
    const node: &ASTNode = ast_new_node(ASTNodeType.AST_BOOL, line, column, arena, null);
    if node == null {
        return null;
    }
    if value != 0 {
        node.bool_literal_value = 1;
    } else {
        node.bool_literal_value = 0;
    }
    return node;
}

// 创建字符串字面量 AST 节点
fn create_string_literal(value: &byte, arena: &CompilerArena, line: i32, column: i32) &ASTNode {
    const node: &ASTNode = ast_new_node(ASTNodeType.AST_STRING, line, column, arena, null);
    if node == null {
        return null;
    }
    node.string_literal_value = value as *byte;
    return node;
}

// 创建 null 字面量 AST 节点（用于指针字段占位）
fn create_null_identifier(arena: &CompilerArena, line: i32, column: i32) &ASTNode {
    const node: &ASTNode = ast_new_node(ASTNodeType.AST_IDENTIFIER, line, column, arena, null);
    if node == null {
        return null;
    }
    node.identifier_name = ("null" as *byte) as &byte;
    return node;
}

// 创建带类型转换的字符串字面量 AST 节点（string as *i8）；value 为 null 时返回 null 字面量
fn create_string_as_ptr(value: &byte, arena: &CompilerArena, line: i32, column: i32) &ASTNode {
    if value == null {
        return create_null_identifier(arena, line, column);
    }
    const str_node: &ASTNode = create_string_literal(value, arena, line, column);
    if str_node == null {
        return null;
    }
    
    // 创建目标类型 *i8
    const target_type: &ASTNode = ast_new_node(ASTNodeType.AST_TYPE_POINTER, line, column, arena, null);
    if target_type == null {
        return str_node;  // 回退到原始字符串
    }
    target_type.type_pointer_is_ffi_pointer = 1;  // *i8 是 FFI 指针
    
    const i8_type: &ASTNode = ast_new_node(ASTNodeType.AST_TYPE_NAMED, line, column, arena, null);
    if i8_type == null {
        return str_node;
    }
    i8_type.type_named_name = ("i8" as *byte) as &byte;
    target_type.type_pointer_pointed_type = i8_type;
    
    // 创建类型转换表达式
    const cast_node: &ASTNode = ast_new_node(ASTNodeType.AST_CAST_EXPR, line, column, arena, null);
    if cast_node == null {
        return str_node;
    }
    cast_node.cast_expr_expr = str_node;
    cast_node.cast_expr_target_type = target_type;
    cast_node.cast_expr_is_force_cast = 0;
    
    return cast_node;
}

// 获取类型名称字符串
fn get_type_name_from_ast(type_node: &ASTNode, arena: &CompilerArena) &byte {
    if type_node == null {
        return ("unknown" as *byte) as &byte;
    }
    
    if type_node.type == ASTNodeType.AST_TYPE_NAMED {
        if type_node.type_named_name != null {
            return type_node.type_named_name as &byte;
        }
        return ("unknown" as *byte) as &byte;
    } else if type_node.type == ASTNodeType.AST_IDENTIFIER {
        if type_node.identifier_name != null {
            return type_node.identifier_name as &byte;
        }
        return ("unknown" as *byte) as &byte;
    } else if type_node.type == ASTNodeType.AST_TYPE_POINTER {
        const inner: &byte = get_type_name_from_ast(type_node.type_pointer_pointed_type, arena);
        const inner_len: i32 = strlen(inner as *byte);
        const buf: &byte = compiler_arena_alloc(arena, (inner_len + 3) as u64) as &byte;
        if buf != null {
            buf[0] = 38 as i8;  // '&' 字符的 ASCII 码
            memcpy((buf + 1) as *void, inner as *void, inner_len as u64);
            const idx: i32 = inner_len + 1;
            if idx >= 0 && idx < 1000000 {
                buf[idx] = 0 as i8;
            }
            return buf;
        }
        return ("&?" as *byte) as &byte;
    } else if type_node.type == ASTNodeType.AST_TYPE_ARRAY {
        const inner: &byte = get_type_name_from_ast(type_node.type_array_element_type, arena);
        const inner_len: i32 = strlen(inner as *byte);
        const buf: &byte = compiler_arena_alloc(arena, (inner_len + 16) as u64) as &byte;
        if buf != null {
            sprintf(buf as *byte, "[%s: ?]" as *byte, inner);
            return buf;
        }
        return ("[?]" as *byte) as &byte;
    } else if type_node.type == ASTNodeType.AST_TYPE_SLICE {
        const inner: &byte = get_type_name_from_ast(type_node.type_slice_element_type, arena);
        const inner_len: i32 = strlen(inner as *byte);
        const buf: &byte = compiler_arena_alloc(arena, (inner_len + 8) as u64) as &byte;
        if buf != null {
            sprintf(buf as *byte, "&[%s]" as *byte, inner);
            return buf;
        }
        return ("&[?]" as *byte) as &byte;
    }
    
    return ("unknown" as *byte) as &byte;
}

// 获取类型大小（编译时）
fn get_type_size_from_name(name: &byte) i32 {
    if name == null {
        return 0;
    }
    const name_ptr: *byte = name as *byte;
    if strcmp(name_ptr, "i8" as *byte) == 0 || strcmp(name_ptr, "u8" as *byte) == 0 || 
       strcmp(name_ptr, "byte" as *byte) == 0 || strcmp(name_ptr, "bool" as *byte) == 0 {
        return 1;
    }
    if strcmp(name_ptr, "i16" as *byte) == 0 || strcmp(name_ptr, "u16" as *byte) == 0 {
        return 2;
    }
    if strcmp(name_ptr, "i32" as *byte) == 0 || strcmp(name_ptr, "u32" as *byte) == 0 || strcmp(name_ptr, "f32" as *byte) == 0 {
        return 4;
    }
    if strcmp(name_ptr, "i64" as *byte) == 0 || strcmp(name_ptr, "u64" as *byte) == 0 || 
       strcmp(name_ptr, "f64" as *byte) == 0 || strcmp(name_ptr, "usize" as *byte) == 0 {
        return 8;
    }
    if strcmp(name_ptr, "void" as *byte) == 0 {
        return 0;
    }
    // 指针大小（假设 64 位）
    if name[0] == 38 as i8 || name[0] == 42 as i8 {  // '&' = 38, '*' = 42
        return 8;
    }
    return 0; // 未知类型
}

// 创建 TypeInfo 结构体字面量 AST 节点
// checker 非 null 时，对结构体类型会填充 field_count 与 fields（用于宏内泛型序列化等）
fn create_type_info_struct(type_node: &ASTNode, arena: &CompilerArena, line: i32, column: i32, checker: &TypeChecker) &ASTNode {
    if type_node == null || arena == null {
        return null;
    }
    
    const type_name: &byte = get_type_name_from_ast(type_node, arena);
    const type_size: i32 = get_type_size_from_name(type_name);
    var type_align: i32 = type_size;
    if type_align <= 0 {
        type_align = 1;
    }
    if type_align > 8 {
        type_align = 8;
    }
    
    // 确定类型种类和布尔标志
    var is_integer: i32 = 0;
    var is_float: i32 = 0;
    var is_bool: i32 = 0;
    var is_pointer: i32 = 0;
    var is_array: i32 = 0;
    var is_void: i32 = 0;
    var kind: i32 = 0; // 0=unknown, 1=integer, 2=float, 3=bool, 4=pointer, 5=array, 6=struct, 7=void
    var type_id: i32 = 16;
    
    const type_name_ptr: *byte = type_name as *byte;
    if type_name != null {
        if strcmp(type_name_ptr, "i8" as *byte) == 0 || strcmp(type_name_ptr, "i16" as *byte) == 0 || 
           strcmp(type_name_ptr, "i32" as *byte) == 0 || strcmp(type_name_ptr, "i64" as *byte) == 0 ||
           strcmp(type_name_ptr, "u8" as *byte) == 0 || strcmp(type_name_ptr, "u16" as *byte) == 0 ||
           strcmp(type_name_ptr, "u32" as *byte) == 0 || strcmp(type_name_ptr, "u64" as *byte) == 0 ||
           strcmp(type_name_ptr, "usize" as *byte) == 0 || strcmp(type_name_ptr, "byte" as *byte) == 0 {
            is_integer = 1;
            kind = 1;
            if strcmp(type_name_ptr, "i8" as *byte) == 0 { type_id = 0; }
            else if strcmp(type_name_ptr, "i16" as *byte) == 0 { type_id = 1; }
            else if strcmp(type_name_ptr, "i32" as *byte) == 0 { type_id = 2; }
            else if strcmp(type_name_ptr, "i64" as *byte) == 0 { type_id = 3; }
            else if strcmp(type_name_ptr, "u8" as *byte) == 0 { type_id = 4; }
            else if strcmp(type_name_ptr, "u16" as *byte) == 0 { type_id = 5; }
            else if strcmp(type_name_ptr, "u32" as *byte) == 0 { type_id = 6; }
            else if strcmp(type_name_ptr, "usize" as *byte) == 0 { type_id = 7; }
            else if strcmp(type_name_ptr, "u64" as *byte) == 0 { type_id = 8; }
            else if strcmp(type_name_ptr, "byte" as *byte) == 0 { type_id = 10; }
        } else if strcmp(type_name_ptr, "f32" as *byte) == 0 || strcmp(type_name_ptr, "f64" as *byte) == 0 {
            is_float = 1;
            kind = 2;
            if strcmp(type_name_ptr, "f32" as *byte) == 0 { type_id = 11; }
            else { type_id = 12; }
        } else if strcmp(type_name_ptr, "bool" as *byte) == 0 {
            is_bool = 1;
            kind = 3;
            type_id = 9;
        } else if type_name[0] == 38 as i8 || type_name[0] == 42 as i8 {  // '&' = 38, '*' = 42
            is_pointer = 1;
            kind = 4;
            type_id = 18;
        } else if type_name[0] == 91 as i8 {  // '[' = 91
            is_array = 1;
            kind = 5;
            type_id = 19;
        } else if strcmp(type_name_ptr, "void" as *byte) == 0 {
            is_void = 1;
            kind = 7;
            type_id = 13;
        } else {
            // 可能是结构体，kind = 6
            kind = 6;
            type_id = 16;
        }
    }
    
    // 创建结构体初始化 AST 节点
    const struct_init: &ASTNode = ast_new_node(ASTNodeType.AST_STRUCT_INIT, line, column, arena, null);
    if struct_init == null {
        return null;
    }
    
    // 分配字段数组（最多 13：11 个基础 + field_count + fields）
    const field_count_max: i32 = 13;
    var field_count: i32 = 11;
    const field_names: &(&byte) = compiler_arena_alloc(arena, (8 * field_count_max) as u64) as &(&byte);
    const field_values: &(&ASTNode) = compiler_arena_alloc(arena, (8 * field_count_max) as u64) as &(&ASTNode);
    if field_names == null || field_values == null {
        return null;
    }
    
    // 设置基础字段
    field_names[0] = ("name" as *byte) as &byte;
    field_values[0] = create_string_as_ptr(type_name, arena, line, column);
    
    field_names[1] = ("size" as *byte) as &byte;
    field_values[1] = create_number_literal(type_size as i64, arena, line, column);
    
    field_names[2] = ("align" as *byte) as &byte;
    field_values[2] = create_number_literal(type_align as i64, arena, line, column);
    
    field_names[3] = ("kind" as *byte) as &byte;
    field_values[3] = create_number_literal(kind as i64, arena, line, column);
    
    field_names[4] = ("type_id" as *byte) as &byte;
    field_values[4] = create_number_literal(type_id as i64, arena, line, column);
    
    field_names[5] = ("is_integer" as *byte) as &byte;
    field_values[5] = create_bool_literal(is_integer, arena, line, column);
    
    field_names[6] = ("is_float" as *byte) as &byte;
    field_values[6] = create_bool_literal(is_float, arena, line, column);
    
    field_names[7] = ("is_bool" as *byte) as &byte;
    field_values[7] = create_bool_literal(is_bool, arena, line, column);
    
    field_names[8] = ("is_pointer" as *byte) as &byte;
    field_values[8] = create_bool_literal(is_pointer, arena, line, column);
    
    field_names[9] = ("is_array" as *byte) as &byte;
    field_values[9] = create_bool_literal(is_array, arena, line, column);
    
    field_names[10] = ("is_void" as *byte) as &byte;
    field_values[10] = create_bool_literal(is_void, arena, line, column);
    
    var n_fields: i32 = 0;
    var struct_decl: &ASTNode = null;
    if kind == 6 && checker != null && checker.program_node != null && type_name != null {
        struct_decl = find_struct_decl_from_program(checker.program_node, type_name);
        if struct_decl != null && struct_decl.struct_decl_fields != null && struct_decl.struct_decl_field_count > 0 {
            n_fields = struct_decl.struct_decl_field_count;
            if n_fields > 64 {
                n_fields = 64;
            }
        }
    }
    const MAX_FIELDS: i32 = 64;
    const elements: &(&ASTNode) = compiler_arena_alloc(arena, (8 * MAX_FIELDS) as u64) as &(&ASTNode);
    if elements != null {
        var ei: i32 = 0;
        while ei < MAX_FIELDS {
            var fi_init: &ASTNode = ast_new_node(ASTNodeType.AST_STRUCT_INIT, line, column, arena, null);
            if fi_init != null {
                const fn_arr: &(&byte) = compiler_arena_alloc(arena, 16) as &(&byte);
                const fv_arr: &(&ASTNode) = compiler_arena_alloc(arena, 16) as &(&ASTNode);
                if fn_arr != null && fv_arr != null {
                    fn_arr[0] = ("name" as *byte) as &byte;
                    fn_arr[1] = ("type_name" as *byte) as &byte;
                    if struct_decl != null && ei < n_fields {
                        const field_node: &ASTNode = struct_decl.struct_decl_fields[ei];
                        if field_node != null && field_node.type == ASTNodeType.AST_VAR_DECL {
                            fv_arr[0] = create_string_as_ptr(field_node.var_decl_name, arena, line, column);
                            fv_arr[1] = create_string_as_ptr(get_type_name_from_ast(field_node.var_decl_type, arena), arena, line, column);
                        } else {
                            fv_arr[0] = create_null_identifier(arena, line, column);
                            fv_arr[1] = create_null_identifier(arena, line, column);
                        }
                    } else {
                        fv_arr[0] = create_null_identifier(arena, line, column);
                        fv_arr[1] = create_null_identifier(arena, line, column);
                    }
                    fi_init.struct_init_struct_name = ("FieldInfo" as *byte) as &byte;
                    fi_init.struct_init_field_names = fn_arr;
                    fi_init.struct_init_field_values = fv_arr;
                    fi_init.struct_init_field_count = 2;
                }
            }
            elements[ei] = fi_init;
            ei = ei + 1;
        }
        const arr_lit: &ASTNode = ast_new_node(ASTNodeType.AST_ARRAY_LITERAL, line, column, arena, null);
        if arr_lit != null {
            arr_lit.array_literal_elements = elements;
            arr_lit.array_literal_element_count = MAX_FIELDS;
            arr_lit.array_literal_repeat_count_expr = null;
            field_names[11] = ("field_count" as *byte) as &byte;
            field_values[11] = create_number_literal(n_fields as i64, arena, line, column);
            field_names[12] = ("fields" as *byte) as &byte;
            field_values[12] = arr_lit;
            field_count = 13;
        }
    }
    
    struct_init.struct_init_struct_name = ("TypeInfo" as *byte) as &byte;
    struct_init.struct_init_field_names = field_names;
    struct_init.struct_init_field_values = field_values;
    struct_init.struct_init_field_count = field_count;
    
    return struct_init;
}

// 将字符串复制到 arena，返回指向 arena 内副本的指针（用于宏展开期持久化；与 parser 的 arena_strdup 重名故加前缀）
fn macro_arena_strdup(arena: &CompilerArena, src: &byte) &byte {
    if src == null || arena == null {
        return null;
    }
    const len: i32 = strlen(src as *byte);
    const buf: &byte = compiler_arena_alloc(arena, (len + 1) as u64) as &byte;
    if buf == null {
        return null;
    }
    memcpy(buf as *void, src as *void, (len + 1) as u64);
    return buf;
}

fn macro_i64_to_string(arena: &CompilerArena, value: i64) &byte {
    if arena == null {
        return null;
    }
    var tmp: [byte: 32] = [];
    var digit_count: i32 = 0;
    var is_negative: i32 = 0;
    var magnitude: u64 = 0;
    if value < 0 {
        is_negative = 1;
        magnitude = (0 as u64) - (value as u64);
    } else {
        magnitude = value as u64;
    }
    if magnitude == 0 {
        tmp[0] = 48;
        digit_count = 1;
    } else {
        while magnitude > 0 && digit_count < 31 {
            if digit_count >= 0 && digit_count < @len(tmp) {
                const digit: u64 = magnitude % (10 as u64);
                tmp[digit_count] = (digit + (48 as u64)) as byte;
                magnitude = magnitude / (10 as u64);
                digit_count = digit_count + 1;
            }
        }
    }
    const total_len: i32 = digit_count + is_negative;
    const buf: &byte = compiler_arena_alloc(arena, (total_len + 1) as u64) as &byte;
    if buf == null {
        return null;
    }
    var out_pos: i32 = 0;
    if is_negative != 0 {
        buf[0] = 45;
        out_pos = 1;
    }
    var i: i32 = digit_count - 1;
    while i >= 0 {
        const digit_idx: i32 = i;
        if digit_idx < 0 {
            break;
        }
        if digit_idx >= @len(tmp) {
            i = i - 1;
            continue;
        }
        if out_pos >= 0 && out_pos < 1000000 {
            buf[out_pos] = macro_tmp_digit_at(tmp, digit_idx);
        }
        out_pos = out_pos + 1;
        i = i - 1;
    }
    buf[out_pos] = 0;
    return buf;
}

fn macro_tmp_digit_at(tmp: [byte: 32], idx: i32) byte {
    if idx < 0 {
        return 0 as byte;
    }
    if idx >= 32 {
        return 0 as byte;
    }
    return tmp[idx];
}

fn macro_concat2(arena: &CompilerArena, a: &byte, b: &byte) &byte {
    if arena == null || a == null || b == null {
        return null;
    }
    const len_a: i32 = strlen(a as *byte);
    const len_b: i32 = strlen(b as *byte);
    const buf: &byte = compiler_arena_alloc(arena, (len_a + len_b + 1) as u64) as &byte;
    if buf == null {
        return null;
    }
    memcpy(buf as *void, a as *void, len_a as u64);
    memcpy((buf + len_a) as *void, b as *void, (len_b + 1) as u64);
    return buf;
}

fn macro_concat3(arena: &CompilerArena, a: &byte, b: &byte, c: &byte) &byte {
    if arena == null || a == null || b == null || c == null {
        return null;
    }
    const ab: &byte = macro_concat2(arena, a, b);
    if ab == null {
        return null;
    }
    return macro_concat2(arena, ab, c);
}

fn macro_append_bytes(dst: &byte, pos: &i32, src: &byte) void {
    if dst == null || pos == null || src == null {
        return;
    }
    const len: i32 = strlen(src as *byte);
    memcpy((dst + pos[0]) as *void, src as *void, len as u64);
    pos[0] = pos[0] + len;
    const p: i32 = pos[0];
    if p >= 0 && p < 1000000 {
        dst[p] = 0;
    }
}

// 从 AST 节点提取字符串字面量指针（支持 AST_STRING 或 AST_CAST_EXPR 包装的字符串）
fn get_string_literal_from_ast(node: &ASTNode) &byte {
    if node == null {
        return null;
    }
    if node.type == ASTNodeType.AST_STRING {
        return (node.string_literal_value as *byte) as &byte;
    }
    if node.type == ASTNodeType.AST_CAST_EXPR && node.cast_expr_expr != null &&
       node.cast_expr_expr.type == ASTNodeType.AST_STRING {
        return (node.cast_expr_expr.string_literal_value as *byte) as &byte;
    }
    return null;
}

// 二元操作符 TokenType 转源码字符串（用于 @mc_source 序列化）
fn binary_op_to_source_string(op: i32) &byte {
    const t_tmp: !TokenType = op as! TokenType;
    const t: TokenType = t_tmp.value;
    if t == TokenType.TOKEN_PLUS { return (" + " as *byte) as &byte; }
    if t == TokenType.TOKEN_MINUS { return (" - " as *byte) as &byte; }
    if t == TokenType.TOKEN_ASTERISK { return (" * " as *byte) as &byte; }
    if t == TokenType.TOKEN_SLASH { return (" / " as *byte) as &byte; }
    if t == TokenType.TOKEN_PERCENT { return (" % " as *byte) as &byte; }
    if t == TokenType.TOKEN_EQUAL { return (" == " as *byte) as &byte; }
    if t == TokenType.TOKEN_NOT_EQUAL { return (" != " as *byte) as &byte; }
    if t == TokenType.TOKEN_LESS { return (" < " as *byte) as &byte; }
    if t == TokenType.TOKEN_GREATER { return (" > " as *byte) as &byte; }
    if t == TokenType.TOKEN_LESS_EQUAL { return (" <= " as *byte) as &byte; }
    if t == TokenType.TOKEN_GREATER_EQUAL { return (" >= " as *byte) as &byte; }
    if t == TokenType.TOKEN_LOGICAL_AND { return (" && " as *byte) as &byte; }
    if t == TokenType.TOKEN_LOGICAL_OR { return (" || " as *byte) as &byte; }
    if t == TokenType.TOKEN_AMPERSAND { return (" & " as *byte) as &byte; }
    if t == TokenType.TOKEN_PIPE { return (" | " as *byte) as &byte; }
    if t == TokenType.TOKEN_CARET { return (" ^ " as *byte) as &byte; }
    if t == TokenType.TOKEN_LSHIFT { return (" << " as *byte) as &byte; }
    if t == TokenType.TOKEN_RSHIFT { return (" >> " as *byte) as &byte; }
    return (" + " as *byte) as &byte;
}

// 一元操作符 TokenType 转源码字符串
fn unary_op_to_source_string(op: i32) &byte {
    const t_tmp: !TokenType = op as! TokenType;
    const t: TokenType = t_tmp.value;
    if t == TokenType.TOKEN_MINUS { return ("-" as *byte) as &byte; }
    if t == TokenType.TOKEN_EXCLAMATION { return ("!" as *byte) as &byte; }
    if t == TokenType.TOKEN_TILDE { return ("~" as *byte) as &byte; }
    if t == TokenType.TOKEN_AMPERSAND { return ("&" as *byte) as &byte; }
    if t == TokenType.TOKEN_ASTERISK { return ("*" as *byte) as &byte; }
    return ("" as *byte) as &byte;
}

// 类型节点转源码字符串（仅支持简单类型名、指针）
fn type_to_source_string(type_node: &ASTNode, arena: &CompilerArena) &byte {
    if type_node == null || arena == null {
        return null;
    }
    if type_node.type == ASTNodeType.AST_TYPE_NAMED && type_node.type_named_name != null {
        return macro_arena_strdup(arena, (type_node.type_named_name as *byte) as &byte);
    }
    if type_node.type == ASTNodeType.AST_TYPE_POINTER && type_node.type_pointer_pointed_type != null {
        const inner: &byte = type_to_source_string(type_node.type_pointer_pointed_type, arena);
        if inner == null {
            return null;
        }
        const inner_len: i32 = strlen(inner as *byte);
        const buf: &byte = compiler_arena_alloc(arena, (inner_len + 3) as u64) as &byte;
        if buf == null {
            return null;
        }
        buf[0] = 42 as i8;
        memcpy((buf + 1) as *void, inner as *void, (inner_len + 1) as u64);
        return buf;
    }
    return null;
}

// 将表达式 AST 序列化为源码形式字符串，写入 arena 并返回指针；不支持的类型返回 null
fn ast_expr_to_source_string(node: &ASTNode, arena: &CompilerArena, filename: &byte) &byte {
    if node == null || arena == null {
        return null;
    }
    if node.type == ASTNodeType.AST_IDENTIFIER {
        if node.identifier_name == null {
            return null;
        }
        return macro_arena_strdup(arena, (node.identifier_name as *byte) as &byte);
    }
    if node.type == ASTNodeType.AST_NUMBER {
        return macro_i64_to_string(arena, node.number_value_i64);
    }
    if node.type == ASTNodeType.AST_FLOAT {
        const buf: &byte = compiler_arena_alloc(arena, 32) as &byte;
        if buf == null {
            return null;
        }
        sprintf(buf as *byte, "%g" as *byte, node.float_literal_value);
        return buf;
    }
    if node.type == ASTNodeType.AST_BOOL {
        if node.bool_literal_value != 0 {
            return macro_arena_strdup(arena, ("true" as *byte) as &byte);
        } else {
            return macro_arena_strdup(arena, ("false" as *byte) as &byte);
        }
    }
    if node.type == ASTNodeType.AST_STRING {
        if node.string_literal_value == null {
            return macro_arena_strdup(arena, ("\"\"" as *byte) as &byte);
        }
        const raw: &byte = (node.string_literal_value as *byte) as &byte;
        const len: i32 = strlen(raw as *byte);
        const buf: &byte = compiler_arena_alloc(arena, (len + 3) as u64) as &byte;
        if buf == null {
            return null;
        }
        buf[0] = 34 as i8;
        memcpy((buf + 1) as *void, raw as *void, (len + 1) as u64);
        const idx1: i32 = len + 1;
        const idx2: i32 = len + 2;
        if idx1 >= 0 && idx1 < 1000000 {
            buf[idx1] = 34 as i8;
        }
        if idx2 >= 0 && idx2 < 1000000 {
            buf[idx2] = 0 as i8;
        }
        return buf;
    }
    if node.type == ASTNodeType.AST_BINARY_EXPR {
        const left: &byte = ast_expr_to_source_string(node.binary_expr_left, arena, filename);
        const right: &byte = ast_expr_to_source_string(node.binary_expr_right, arena, filename);
        const op_s: &byte = binary_op_to_source_string(node.binary_expr_op);
        if left == null || right == null || op_s == null {
            return null;
        }
        return macro_concat3(arena, left, op_s, right);
    }
    if node.type == ASTNodeType.AST_UNARY_EXPR {
        const op_s: &byte = unary_op_to_source_string(node.unary_expr_op);
        const operand_s: &byte = ast_expr_to_source_string(node.unary_expr_operand, arena, filename);
        if op_s == null || operand_s == null {
            return null;
        }
        return macro_concat2(arena, op_s, operand_s);
    }
    if node.type == ASTNodeType.AST_MEMBER_ACCESS {
        const obj: &byte = ast_expr_to_source_string(node.member_access_object, arena, filename);
        if obj == null || node.member_access_field_name == null {
            return null;
        }
        return macro_concat3(arena, obj, ("." as *byte) as &byte, node.member_access_field_name);
    }
    if node.type == ASTNodeType.AST_ARRAY_ACCESS {
        const arr: &byte = ast_expr_to_source_string(node.array_access_array, arena, filename);
        const idx: &byte = ast_expr_to_source_string(node.array_access_index, arena, filename);
        if arr == null || idx == null {
            return null;
        }
        const arr_open: &byte = macro_concat2(arena, arr, ("[" as *byte) as &byte);
        if arr_open == null {
            return null;
        }
        const mid: &byte = macro_concat2(arena, arr_open, idx);
        if mid == null {
            return null;
        }
        return macro_concat2(arena, mid, ("]" as *byte) as &byte);
    }
    if node.type == ASTNodeType.AST_CAST_EXPR {
        const expr_s: &byte = ast_expr_to_source_string(node.cast_expr_expr, arena, filename);
        const type_s: &byte = type_to_source_string(node.cast_expr_target_type, arena);
        if expr_s == null || type_s == null {
            return null;
        }
        return macro_concat3(arena, expr_s, (" as " as *byte) as &byte, type_s);
    }
    if node.type == ASTNodeType.AST_CALL_EXPR {
        const callee: &byte = ast_expr_to_source_string(node.call_expr_callee, arena, filename);
        if callee == null {
            return null;
        }
        var parts_len: i32 = strlen(callee as *byte) + 2;
        var i: i32 = 0;
        while i < node.call_expr_arg_count {
            if node.call_expr_args != null {
                const arg: &byte = ast_expr_to_source_string(node.call_expr_args[i], arena, filename);
                if arg != null {
                    parts_len = parts_len + strlen(arg as *byte) + 2;
                }
            }
            i = i + 1;
        }
        const buf: &byte = compiler_arena_alloc(arena, (parts_len + 1) as u64) as &byte;
        if buf == null {
            return null;
        }
        var pos: i32 = 0;
        macro_append_bytes(buf, &pos, callee);
        buf[pos] = 40 as i8;
        pos = pos + 1;
        buf[pos] = 0;
        i = 0;
        while i < node.call_expr_arg_count {
            if node.call_expr_args != null {
                const arg: &byte = ast_expr_to_source_string(node.call_expr_args[i], arena, filename);
                if arg != null {
                    if i > 0 {
                        buf[pos] = 44 as i8;
                        pos = pos + 1;
                        buf[pos] = 32 as i8;
                        pos = pos + 1;
                        buf[pos] = 0;
                    }
                    macro_append_bytes(buf, &pos, arg);
                }
            }
            i = i + 1;
        }
        buf[pos] = 41 as i8;
        pos = pos + 1;
        buf[pos] = 0;
        return buf;
    }
    if node.type == ASTNodeType.AST_TYPE_NAMED {
        if node.type_named_name != null {
            return macro_arena_strdup(arena, (node.type_named_name as *byte) as &byte);
        }
        return null;
    }
    return null;
}

// 检查结构体字面量是否为 TypeInfo（与 create_type_info_struct 生成的名字一致）
fn is_typeinfo_struct_init(node: &ASTNode) i32 {
    if node == null || node.type != ASTNodeType.AST_STRUCT_INIT {
        return 0;
    }
    if node.struct_init_struct_name == null {
        return 0;
    }
    if strcmp(node.struct_init_struct_name as *byte, "TypeInfo" as *byte) != 0 {
        return 0;
    }
    return 1;
}

// 从 TypeInfo 结构体字面量 AST 中读取 field_count；非 TypeInfo 或格式不符返回 -1
fn get_typeinfo_field_count_from_ast(type_info_ast: &ASTNode) i32 {
    if type_info_ast == null || is_typeinfo_struct_init(type_info_ast) == 0 {
        return -1;
    }
    if type_info_ast.struct_init_field_names == null || type_info_ast.struct_init_field_values == null {
        return -1;
    }
    var i: i32 = 0;
    while i < type_info_ast.struct_init_field_count {
        if type_info_ast.struct_init_field_names[i] != null &&
           strcmp(type_info_ast.struct_init_field_names[i] as *byte, "field_count" as *byte) == 0 {
            const val: &ASTNode = type_info_ast.struct_init_field_values[i];
            if val != null && val.type == ASTNodeType.AST_NUMBER {
                return val.number_value_i64 as i32;
            }
            return -1;
        }
        i = i + 1;
    }
    return -1;
}

// 从 TypeInfo 结构体字面量 AST 中读取第 index 个 FieldInfo 的 name 和 type_name，复制到 arena 并通过 out_name、out_type_name 返回；成功返回 1，失败返回 0
fn get_typeinfo_field_name_type_from_ast(type_info_ast: &ASTNode, index: i32, arena: &CompilerArena, out_name: &(&byte), out_type_name: &(&byte)) i32 {
    if type_info_ast == null || arena == null || out_name == null || out_type_name == null {
        return 0;
    }
    if is_typeinfo_struct_init(type_info_ast) == 0 {
        return 0;
    }
    if type_info_ast.struct_init_field_names == null || type_info_ast.struct_init_field_values == null {
        return 0;
    }
    var fields_idx: i32 = -1;
    var i: i32 = 0;
    while i < type_info_ast.struct_init_field_count {
        if type_info_ast.struct_init_field_names[i] != null &&
           strcmp(type_info_ast.struct_init_field_names[i] as *byte, "fields" as *byte) == 0 {
            fields_idx = i;
            break;
        }
        i = i + 1;
    }
    if fields_idx < 0 {
        return 0;
    }
    const fields_val: &ASTNode = type_info_ast.struct_init_field_values[fields_idx];
    if fields_val == null || fields_val.type != ASTNodeType.AST_ARRAY_LITERAL {
        return 0;
    }
    if fields_val.array_literal_elements == null || index < 0 || index >= fields_val.array_literal_element_count {
        return 0;
    }
    const field_info: &ASTNode = fields_val.array_literal_elements[index];
    if field_info == null || field_info.type != ASTNodeType.AST_STRUCT_INIT {
        return 0;
    }
    if field_info.struct_init_field_names == null || field_info.struct_init_field_values == null {
        return 0;
    }
    var name_idx: i32 = -1;
    var type_name_idx: i32 = -1;
    i = 0;
    while i < field_info.struct_init_field_count {
        if field_info.struct_init_field_names[i] != null {
            if strcmp(field_info.struct_init_field_names[i] as *byte, "name" as *byte) == 0 {
                name_idx = i;
            } else if strcmp(field_info.struct_init_field_names[i] as *byte, "type_name" as *byte) == 0 {
                type_name_idx = i;
            }
        }
        i = i + 1;
    }
    if name_idx < 0 || type_name_idx < 0 {
        return 0;
    }
    const name_src: &byte = get_string_literal_from_ast(field_info.struct_init_field_values[name_idx]);
    const type_name_src: &byte = get_string_literal_from_ast(field_info.struct_init_field_values[type_name_idx]);
    if name_src == null || type_name_src == null {
        return 0;
    }
    const name_copied: &byte = macro_arena_strdup(arena, name_src);
    const type_name_copied: &byte = macro_arena_strdup(arena, type_name_src);
    if name_copied == null || type_name_copied == null {
        return 0;
    }
    *out_name = name_copied;
    *out_type_name = type_name_copied;
    return 1;
}

// 从字符串创建标识符 AST 节点（name_ptr 须指向 arena 内已持久化的字符串）
fn create_identifier_from_string(name_ptr: &byte, arena: &CompilerArena, line: i32, column: i32) &ASTNode {
    if name_ptr == null || arena == null {
        return null;
    }
    const node: &ASTNode = ast_new_node(ASTNodeType.AST_IDENTIFIER, line, column, arena, null);
    if node == null {
        return null;
    }
    node.identifier_name = name_ptr;
    return node;
}

// 从类型名字符串创建 AST_TYPE_NAMED 节点（type_name_ptr 须指向 arena 内已持久化的字符串；仅简单类型名）
fn create_type_named_from_string(type_name_ptr: &byte, arena: &CompilerArena, line: i32, column: i32) &ASTNode {
    if type_name_ptr == null || arena == null {
        return null;
    }
    const node: &ASTNode = ast_new_node(ASTNodeType.AST_TYPE_NAMED, line, column, arena, null);
    if node == null {
        return null;
    }
    node.type_named_name = type_name_ptr;
    return node;
}

fn macro_ctx_has_hygiene(ctx: &MacroExpandContext) i32 {
    if ctx == null {
        return 0;
    }
    return ctx.hygiene_enabled;
}

fn next_macro_hygiene_expansion_id() i32 {
    const expansion_id: i32 = macro_hygiene_expansion_counter;
    macro_hygiene_expansion_counter = macro_hygiene_expansion_counter + 1;
    return expansion_id;
}

fn hygiene_scope_start_at(state: &HygieneCopyState, idx: i32) i32 {
    if state == null {
        return 0;
    }
    if idx >= 0 && idx < 64 {
        return state.scope_starts[idx];
    }
    return 0;
}

fn hygiene_scope_start_set(state: &HygieneCopyState, idx: i32, value: i32) void {
    if state == null {
        return;
    }
    if idx >= 0 && idx < 64 {
        state.scope_starts[idx] = value;
    }
}

fn hygiene_scope_name_at(state: &HygieneCopyState, idx: i32) &byte {
    if state == null {
        return null;
    }
    if idx >= 0 && idx < 256 {
        return state.scope_names[idx];
    }
    return null;
}

fn hygiene_scope_name_set(state: &HygieneCopyState, idx: i32, value: &byte) void {
    if state == null {
        return;
    }
    if idx >= 0 && idx < 256 {
        state.scope_names[idx] = value;
    }
}

fn hygiene_scope_renamed_name_at(state: &HygieneCopyState, idx: i32) &byte {
    if state == null {
        return null;
    }
    if idx >= 0 && idx < 256 {
        return state.scope_renamed_names[idx];
    }
    return null;
}

fn hygiene_scope_renamed_name_set(state: &HygieneCopyState, idx: i32, value: &byte) void {
    if state == null {
        return;
    }
    if idx >= 0 && idx < 256 {
        state.scope_renamed_names[idx] = value;
    }
}

fn hygiene_enter_scope(state: &HygieneCopyState) void {
    if state == null {
        return;
    }
    const d: i32 = state.scope_depth;
    if d < 0 {
        return;
    }
    if d >= @len(state.scope_starts) {
        return;
    }
    hygiene_scope_start_set(state, d, state.scope_entry_count);
    state.scope_depth = d + 1;
}

fn hygiene_exit_scope(state: &HygieneCopyState) void {
    if state == null || state.scope_depth <= 0 {
        return;
    }
    state.scope_depth = state.scope_depth - 1;
    const d: i32 = state.scope_depth;
    if d < 0 {
        return;
    }
    if d >= @len(state.scope_starts) {
        return;
    }
    state.scope_entry_count = hygiene_scope_start_at(state, d);
}

fn hygiene_add_binding(state: &HygieneCopyState, original_name: &byte, renamed_name: &byte) void {
    if state == null || original_name == null || renamed_name == null {
        return;
    }
    const ec: i32 = state.scope_entry_count;
    if ec < 0 {
        return;
    }
    if ec >= @len(state.scope_names) {
        return;
    }
    if ec >= @len(state.scope_renamed_names) {
        return;
    }
    hygiene_scope_name_set(state, ec, original_name);
    hygiene_scope_renamed_name_set(state, ec, renamed_name);
    state.scope_entry_count = ec + 1;
}

fn hygiene_lookup_binding(state: &HygieneCopyState, name: &byte) &byte {
    if state == null || name == null {
        return null;
    }
    var i: i32 = state.scope_entry_count - 1;
    while i >= 0 {
        const entry_idx: i32 = i;
        if entry_idx < 0 {
            i = i - 1;
            continue;
        }
        if entry_idx >= @len(state.scope_names) {
            i = i - 1;
            continue;
        }
        if entry_idx >= @len(state.scope_renamed_names) {
            i = i - 1;
            continue;
        }
        const original_name: &byte = hygiene_scope_name_at(state, entry_idx);
        if original_name != null && strcmp(original_name as *byte, name as *byte) == 0 {
            return hygiene_scope_renamed_name_at(state, entry_idx);
        }
        i = i - 1;
    }
    return null;
}

fn create_hygiene_name(ctx: &MacroExpandContext, original_name: &byte) &byte {
    if ctx == null || ctx.arena == null || original_name == null {
        return original_name;
    }
    const local_id: i32 = ctx.hygiene_next_local_id;
    ctx.hygiene_next_local_id = ctx.hygiene_next_local_id + 1;
    const name_len: i32 = strlen(original_name as *byte);
    const buf_len: i32 = name_len + 48;
    const buf: &byte = compiler_arena_alloc(ctx.arena, buf_len as u64) as &byte;
    if buf == null {
        return original_name;
    }
    snprintf(buf as *byte, buf_len, "%s__hyg_%d_%d" as *byte, original_name as *byte, ctx.hygiene_expansion_id, local_id);
    return buf;
}

fn init_hygiene_copy_state(state: &HygieneCopyState) void {
    if state == null {
        return;
    }
    state.scope_entry_count = 0;
    state.scope_depth = 0;
}

fn deep_copy_ast_internal(node: &ASTNode, ctx: &MacroExpandContext, filename: &byte, state: &HygieneCopyState, loop_var_name: &byte, current_name: &byte, current_type_name: &byte, enable_field_subst: i32) &ASTNode {
    if node == null || ctx == null || ctx.arena == null {
        return null;
    }

    if enable_field_subst != 0 && node.type == ASTNodeType.AST_MEMBER_ACCESS && node.member_access_object != null &&
       node.member_access_object.type == ASTNodeType.AST_IDENTIFIER &&
       node.member_access_object.identifier_name != null && loop_var_name != null &&
       node.member_access_field_name != null {
        if strcmp(node.member_access_object.identifier_name as *byte, loop_var_name as *byte) == 0 {
            if strcmp(node.member_access_field_name as *byte, "name" as *byte) == 0 && current_name != null {
                return create_identifier_from_string(current_name, ctx.arena, node.line, node.column);
            }
            if strcmp(node.member_access_field_name as *byte, "type_name" as *byte) == 0 && current_type_name != null {
                return create_type_named_from_string(current_type_name, ctx.arena, node.line, node.column);
            }
        }
    }

    if node.type == ASTNodeType.AST_IDENTIFIER && node.identifier_name != null {
        if macro_ctx_has_hygiene(ctx) != 0 {
            const renamed_name: &byte = hygiene_lookup_binding(state, node.identifier_name);
            if renamed_name != null {
                return create_identifier_from_string(renamed_name, ctx.arena, node.line, node.column);
            }
        }
        const arg: &ASTNode = find_param_binding(ctx, node.identifier_name);
        if arg != null {
            var no_param_ctx: MacroExpandContext = MacroExpandContext{
                bindings: null,
                binding_count: 0,
                arena: ctx.arena,
                checker: ctx.checker,
                hygiene_enabled: 0,
                hygiene_expansion_id: ctx.hygiene_expansion_id,
                hygiene_next_local_id: ctx.hygiene_next_local_id
            };
            var no_param_state: HygieneCopyState = HygieneCopyState{
                scope_names: [],
                scope_renamed_names: [],
                scope_entry_count: 0,
                scope_starts: [],
                scope_depth: 0
            };
            init_hygiene_copy_state(&no_param_state);
            return deep_copy_ast_internal(arg, &no_param_ctx, filename, &no_param_state, loop_var_name, current_name, current_type_name, enable_field_subst);
        }
    }

    const copy: &ASTNode = ast_new_node(node.type, node.line, node.column, ctx.arena, filename);
    if copy == null {
        return null;
    }

    if node.type == ASTNodeType.AST_NUMBER {
        copy.number_value = node.number_value;
        copy.number_value_i64 = node.number_value_i64;
    } else if node.type == ASTNodeType.AST_FLOAT {
        copy.float_literal_value = node.float_literal_value;
    } else if node.type == ASTNodeType.AST_BOOL {
        copy.bool_literal_value = node.bool_literal_value;
    } else if node.type == ASTNodeType.AST_STRING {
        copy.string_literal_value = node.string_literal_value;
    } else if node.type == ASTNodeType.AST_EMBED || node.type == ASTNodeType.AST_EMBED_DIR {
        copy.embed_path_literal = node.embed_path_literal;
        copy.embed_resolved_path = node.embed_resolved_path;
        copy.embed_data = node.embed_data;
        copy.embed_size = node.embed_size;
        copy.embed_dir_paths = node.embed_dir_paths;
        copy.embed_dir_resolved_paths = node.embed_dir_resolved_paths;
        copy.embed_dir_data = node.embed_dir_data;
        copy.embed_dir_sizes = node.embed_dir_sizes;
        copy.embed_dir_entry_count = node.embed_dir_entry_count;
    } else if node.type == ASTNodeType.AST_C_IMPORT_DECL {
        copy.c_import_path_literal = node.c_import_path_literal;
        copy.c_import_resolved_path = node.c_import_resolved_path;
        copy.c_import_cflags_literal = node.c_import_cflags_literal;
        copy.c_import_ldflags_literal = node.c_import_ldflags_literal;
        copy.c_import_cflags_normalized = node.c_import_cflags_normalized;
        copy.c_import_ldflags_normalized = node.c_import_ldflags_normalized;
        copy.c_import_expanded_paths = node.c_import_expanded_paths;
        copy.c_import_expanded_rel_paths = node.c_import_expanded_rel_paths;
        copy.c_import_expanded_count = node.c_import_expanded_count;
    } else if node.type == ASTNodeType.AST_CHAR {
        copy.char_literal_value = node.char_literal_value;
    } else if node.type == ASTNodeType.AST_INT_LIMIT {
        copy.int_limit_is_max = node.int_limit_is_max;
        copy.int_limit_resolved_kind = node.int_limit_resolved_kind;
    } else if node.type == ASTNodeType.AST_IDENTIFIER {
        copy.identifier_name = node.identifier_name;
    } else if node.type == ASTNodeType.AST_BINARY_EXPR {
        copy.binary_expr_op = node.binary_expr_op;
        copy.binary_expr_left = deep_copy_ast_internal(node.binary_expr_left, ctx, filename, state, loop_var_name, current_name, current_type_name, enable_field_subst);
        copy.binary_expr_right = deep_copy_ast_internal(node.binary_expr_right, ctx, filename, state, loop_var_name, current_name, current_type_name, enable_field_subst);
    } else if node.type == ASTNodeType.AST_UNARY_EXPR {
        copy.unary_expr_op = node.unary_expr_op;
        copy.unary_expr_operand = deep_copy_ast_internal(node.unary_expr_operand, ctx, filename, state, loop_var_name, current_name, current_type_name, enable_field_subst);
    } else if node.type == ASTNodeType.AST_CALL_EXPR {
        copy.call_expr_callee = deep_copy_ast_internal(node.call_expr_callee, ctx, filename, state, loop_var_name, current_name, current_type_name, enable_field_subst);
        copy.call_expr_arg_count = node.call_expr_arg_count;
        if node.call_expr_args != null && node.call_expr_arg_count > 0 {
            copy.call_expr_args = compiler_arena_alloc(ctx.arena, @size_of(&ASTNode) * node.call_expr_arg_count) as & & ASTNode;
            if copy.call_expr_args != null {
                var i: i32 = 0;
                while i < node.call_expr_arg_count {
                    copy.call_expr_args[i] = deep_copy_ast_internal(node.call_expr_args[i], ctx, filename, state, loop_var_name, current_name, current_type_name, enable_field_subst);
                    i = i + 1;
                }
            }
        }
    } else if node.type == ASTNodeType.AST_MEMBER_ACCESS {
        copy.member_access_object = deep_copy_ast_internal(node.member_access_object, ctx, filename, state, loop_var_name, current_name, current_type_name, enable_field_subst);
        copy.member_access_field_name = node.member_access_field_name;
        copy.member_access_is_module_access = node.member_access_is_module_access;
        copy.member_access_module_name = node.member_access_module_name;
    } else if node.type == ASTNodeType.AST_ARRAY_ACCESS {
        copy.array_access_array = deep_copy_ast_internal(node.array_access_array, ctx, filename, state, loop_var_name, current_name, current_type_name, enable_field_subst);
        copy.array_access_index = deep_copy_ast_internal(node.array_access_index, ctx, filename, state, loop_var_name, current_name, current_type_name, enable_field_subst);
    } else if node.type == ASTNodeType.AST_SLICE_EXPR {
        copy.slice_expr_base = deep_copy_ast_internal(node.slice_expr_base, ctx, filename, state, loop_var_name, current_name, current_type_name, enable_field_subst);
        copy.slice_expr_start_expr = deep_copy_ast_internal(node.slice_expr_start_expr, ctx, filename, state, loop_var_name, current_name, current_type_name, enable_field_subst);
        copy.slice_expr_len_expr = deep_copy_ast_internal(node.slice_expr_len_expr, ctx, filename, state, loop_var_name, current_name, current_type_name, enable_field_subst);
    } else if node.type == ASTNodeType.AST_MC_INTERP {
        const operand: &ASTNode = node.mc_interp_operand;
        if operand != null && operand.type == ASTNodeType.AST_IDENTIFIER && operand.identifier_name != null {
            const arg2: &ASTNode = find_param_binding(ctx, operand.identifier_name);
            if arg2 != null {
                var no_param_ctx2: MacroExpandContext = MacroExpandContext{
                    bindings: null,
                    binding_count: 0,
                    arena: ctx.arena,
                    checker: ctx.checker,
                    hygiene_enabled: 0,
                    hygiene_expansion_id: ctx.hygiene_expansion_id,
                    hygiene_next_local_id: ctx.hygiene_next_local_id
                };
                var no_param_state2: HygieneCopyState = HygieneCopyState{
                    scope_names: [],
                    scope_renamed_names: [],
                    scope_entry_count: 0,
                    scope_starts: [],
                    scope_depth: 0
                };
                init_hygiene_copy_state(&no_param_state2);
                return deep_copy_ast_internal(arg2, &no_param_ctx2, filename, &no_param_state2, loop_var_name, current_name, current_type_name, enable_field_subst);
            }
        }
        copy.mc_interp_operand = deep_copy_ast_internal(operand, ctx, filename, state, loop_var_name, current_name, current_type_name, enable_field_subst);
    } else if node.type == ASTNodeType.AST_BLOCK {
        copy.block_stmt_count = node.block_stmt_count;
        if node.block_stmts != null && node.block_stmt_count > 0 {
            copy.block_stmts = compiler_arena_alloc(ctx.arena, @size_of(&ASTNode) * node.block_stmt_count) as & & ASTNode;
            if copy.block_stmts != null {
                hygiene_enter_scope(state);
                var i: i32 = 0;
                while i < node.block_stmt_count {
                    copy.block_stmts[i] = deep_copy_ast_internal(node.block_stmts[i], ctx, filename, state, loop_var_name, current_name, current_type_name, enable_field_subst);
                    i = i + 1;
                }
                hygiene_exit_scope(state);
            }
        }
    } else if node.type == ASTNodeType.AST_IF_STMT {
        copy.if_stmt_condition = deep_copy_ast_internal(node.if_stmt_condition, ctx, filename, state, loop_var_name, current_name, current_type_name, enable_field_subst);
        copy.if_stmt_then_branch = deep_copy_ast_internal(node.if_stmt_then_branch, ctx, filename, state, loop_var_name, current_name, current_type_name, enable_field_subst);
        copy.if_stmt_else_branch = deep_copy_ast_internal(node.if_stmt_else_branch, ctx, filename, state, loop_var_name, current_name, current_type_name, enable_field_subst);
    } else if node.type == ASTNodeType.AST_WHILE_STMT {
        copy.while_stmt_condition = deep_copy_ast_internal(node.while_stmt_condition, ctx, filename, state, loop_var_name, current_name, current_type_name, enable_field_subst);
        copy.while_stmt_body = deep_copy_ast_internal(node.while_stmt_body, ctx, filename, state, loop_var_name, current_name, current_type_name, enable_field_subst);
    } else if node.type == ASTNodeType.AST_FOR_STMT {
        var renamed_loop_name: &byte = node.for_stmt_var_name;
        copy.for_stmt_array = deep_copy_ast_internal(node.for_stmt_array, ctx, filename, state, loop_var_name, current_name, current_type_name, enable_field_subst);
        copy.for_stmt_is_range = node.for_stmt_is_range;
        copy.for_stmt_range_start = deep_copy_ast_internal(node.for_stmt_range_start, ctx, filename, state, loop_var_name, current_name, current_type_name, enable_field_subst);
        copy.for_stmt_range_end = deep_copy_ast_internal(node.for_stmt_range_end, ctx, filename, state, loop_var_name, current_name, current_type_name, enable_field_subst);
        copy.for_stmt_is_ref = node.for_stmt_is_ref;
        if macro_ctx_has_hygiene(ctx) != 0 && node.for_stmt_var_name != null {
            renamed_loop_name = create_hygiene_name(ctx, node.for_stmt_var_name);
        }
        copy.for_stmt_var_name = renamed_loop_name;
        hygiene_enter_scope(state);
        if macro_ctx_has_hygiene(ctx) != 0 && node.for_stmt_var_name != null && renamed_loop_name != null {
            hygiene_add_binding(state, node.for_stmt_var_name, renamed_loop_name);
        }
        copy.for_stmt_body = deep_copy_ast_internal(node.for_stmt_body, ctx, filename, state, loop_var_name, current_name, current_type_name, enable_field_subst);
        hygiene_exit_scope(state);
    } else if node.type == ASTNodeType.AST_RETURN_STMT {
        copy.return_stmt_expr = deep_copy_ast_internal(node.return_stmt_expr, ctx, filename, state, loop_var_name, current_name, current_type_name, enable_field_subst);
    } else if node.type == ASTNodeType.AST_VAR_DECL {
        var renamed_var_name: &byte = node.var_decl_name;
        copy.var_decl_type = deep_copy_ast_internal(node.var_decl_type, ctx, filename, state, loop_var_name, current_name, current_type_name, enable_field_subst);
        copy.var_decl_init = deep_copy_ast_internal(node.var_decl_init, ctx, filename, state, loop_var_name, current_name, current_type_name, enable_field_subst);
        copy.var_decl_is_const = node.var_decl_is_const;
        if macro_ctx_has_hygiene(ctx) != 0 && node.var_decl_name != null &&
           strcmp(node.var_decl_name as *byte, "self" as *byte) != 0 {
            renamed_var_name = create_hygiene_name(ctx, node.var_decl_name);
        }
        copy.var_decl_name = renamed_var_name;
        if macro_ctx_has_hygiene(ctx) != 0 && node.var_decl_name != null && renamed_var_name != null &&
           strcmp(node.var_decl_name as *byte, "self" as *byte) != 0 {
            hygiene_add_binding(state, node.var_decl_name, renamed_var_name);
        }
    } else if node.type == ASTNodeType.AST_ASSIGN {
        copy.assign_dest = deep_copy_ast_internal(node.assign_dest, ctx, filename, state, loop_var_name, current_name, current_type_name, enable_field_subst);
        copy.assign_src = deep_copy_ast_internal(node.assign_src, ctx, filename, state, loop_var_name, current_name, current_type_name, enable_field_subst);
    } else if node.type == ASTNodeType.AST_TYPE_NAMED {
        if node.type_named_name != null {
            const arg3: &ASTNode = find_param_binding(ctx, node.type_named_name);
            if arg3 != null {
                var no_param_ctx3: MacroExpandContext = MacroExpandContext{
                    bindings: null,
                    binding_count: 0,
                    arena: ctx.arena,
                    checker: ctx.checker,
                    hygiene_enabled: 0,
                    hygiene_expansion_id: ctx.hygiene_expansion_id,
                    hygiene_next_local_id: ctx.hygiene_next_local_id
                };
                var no_param_state3: HygieneCopyState = HygieneCopyState{
                    scope_names: [],
                    scope_renamed_names: [],
                    scope_entry_count: 0,
                    scope_starts: [],
                    scope_depth: 0
                };
                init_hygiene_copy_state(&no_param_state3);
                return deep_copy_ast_internal(arg3, &no_param_ctx3, filename, &no_param_state3, loop_var_name, current_name, current_type_name, enable_field_subst);
            }
        }
        copy.type_named_name = node.type_named_name;
    } else if node.type == ASTNodeType.AST_TYPE_POINTER {
        copy.type_pointer_pointed_type = deep_copy_ast_internal(node.type_pointer_pointed_type, ctx, filename, state, loop_var_name, current_name, current_type_name, enable_field_subst);
        copy.type_pointer_is_ffi_pointer = node.type_pointer_is_ffi_pointer;
    } else if node.type == ASTNodeType.AST_TYPE_ARRAY {
        copy.type_array_element_type = deep_copy_ast_internal(node.type_array_element_type, ctx, filename, state, loop_var_name, current_name, current_type_name, enable_field_subst);
        copy.type_array_size_expr = deep_copy_ast_internal(node.type_array_size_expr, ctx, filename, state, loop_var_name, current_name, current_type_name, enable_field_subst);
    } else if node.type == ASTNodeType.AST_TYPE_SLICE {
        copy.type_slice_element_type = deep_copy_ast_internal(node.type_slice_element_type, ctx, filename, state, loop_var_name, current_name, current_type_name, enable_field_subst);
        copy.type_slice_size_expr = deep_copy_ast_internal(node.type_slice_size_expr, ctx, filename, state, loop_var_name, current_name, current_type_name, enable_field_subst);
        copy.type_slice_element_const = node.type_slice_element_const;
    } else if node.type == ASTNodeType.AST_CAST_EXPR {
        copy.cast_expr_expr = deep_copy_ast_internal(node.cast_expr_expr, ctx, filename, state, loop_var_name, current_name, current_type_name, enable_field_subst);
        copy.cast_expr_target_type = deep_copy_ast_internal(node.cast_expr_target_type, ctx, filename, state, loop_var_name, current_name, current_type_name, enable_field_subst);
        copy.cast_expr_is_force_cast = node.cast_expr_is_force_cast;
    } else if node.type == ASTNodeType.AST_FN_DECL {
        copy.fn_decl_name = node.fn_decl_name;
        copy.fn_decl_return_type = deep_copy_ast_internal(node.fn_decl_return_type, ctx, filename, state, loop_var_name, current_name, current_type_name, enable_field_subst);
        copy.fn_decl_param_count = node.fn_decl_param_count;
        copy.fn_decl_is_varargs = node.fn_decl_is_varargs;
        copy.fn_decl_is_export = node.fn_decl_is_export;
        hygiene_enter_scope(state);
        if node.fn_decl_params != null && node.fn_decl_param_count > 0 {
            copy.fn_decl_params = compiler_arena_alloc(ctx.arena, @size_of(&ASTNode) * node.fn_decl_param_count) as & & ASTNode;
            if copy.fn_decl_params != null {
                var i: i32 = 0;
                while i < node.fn_decl_param_count {
                    copy.fn_decl_params[i] = deep_copy_ast_internal(node.fn_decl_params[i], ctx, filename, state, loop_var_name, current_name, current_type_name, enable_field_subst);
                    i = i + 1;
                }
            }
        }
        copy.fn_decl_body = deep_copy_ast_internal(node.fn_decl_body, ctx, filename, state, loop_var_name, current_name, current_type_name, enable_field_subst);
        hygiene_exit_scope(state);
    } else if node.type == ASTNodeType.AST_TRY_EXPR {
        copy.try_expr_operand = deep_copy_ast_internal(node.try_expr_operand, ctx, filename, state, loop_var_name, current_name, current_type_name, enable_field_subst);
    } else if node.type == ASTNodeType.AST_CATCH_EXPR {
        var renamed_err_name: &byte = node.catch_expr_err_name;
        copy.catch_expr_operand = deep_copy_ast_internal(node.catch_expr_operand, ctx, filename, state, loop_var_name, current_name, current_type_name, enable_field_subst);
        if macro_ctx_has_hygiene(ctx) != 0 && node.catch_expr_err_name != null {
            renamed_err_name = create_hygiene_name(ctx, node.catch_expr_err_name);
        }
        copy.catch_expr_err_name = renamed_err_name;
        hygiene_enter_scope(state);
        if macro_ctx_has_hygiene(ctx) != 0 && node.catch_expr_err_name != null && renamed_err_name != null {
            hygiene_add_binding(state, node.catch_expr_err_name, renamed_err_name);
        }
        copy.catch_expr_catch_block = deep_copy_ast_internal(node.catch_expr_catch_block, ctx, filename, state, loop_var_name, current_name, current_type_name, enable_field_subst);
        hygiene_exit_scope(state);
    } else if node.type == ASTNodeType.AST_MC_EVAL {
        var success: i32 = 0;
        const value: i64 = macro_eval_expr(node.mc_eval_operand, ctx, &success);
        if success != 0 {
            const num: &ASTNode = create_number_literal(value, ctx.arena, node.line, node.column);
            if num != null {
                return num;
            }
        }
        copy.mc_eval_operand = deep_copy_ast_internal(node.mc_eval_operand, ctx, filename, state, loop_var_name, current_name, current_type_name, enable_field_subst);
    } else if node.type == ASTNodeType.AST_MC_CODE {
        if node.mc_code_operand != null && node.mc_code_operand.type == ASTNodeType.AST_MC_AST &&
           node.mc_code_operand.mc_ast_operand != null {
            const expanded_code: &ASTNode = deep_copy_ast_internal(node.mc_code_operand.mc_ast_operand, ctx, filename, state, loop_var_name, current_name, current_type_name, enable_field_subst);
            if expanded_code != null {
                return expanded_code;
            }
        }
        copy.mc_code_operand = deep_copy_ast_internal(node.mc_code_operand, ctx, filename, state, loop_var_name, current_name, current_type_name, enable_field_subst);
    } else if node.type == ASTNodeType.AST_MC_AST {
        copy.mc_ast_operand = deep_copy_ast_internal(node.mc_ast_operand, ctx, filename, state, loop_var_name, current_name, current_type_name, enable_field_subst);
    } else if node.type == ASTNodeType.AST_MC_TYPE {
        const operand2: &ASTNode = node.mc_type_operand;
        if operand2 != null {
            const resolved_operand: &ASTNode = deep_copy_ast_internal(operand2, ctx, filename, state, loop_var_name, current_name, current_type_name, enable_field_subst);
            var actual_operand: &ASTNode = operand2;
            if resolved_operand != null {
                actual_operand = resolved_operand;
            }
            const type_info: &ASTNode = create_type_info_struct(actual_operand, ctx.arena, node.line, node.column, ctx.checker);
            if type_info != null {
                return type_info;
            }
        }
        copy.mc_type_operand = deep_copy_ast_internal(node.mc_type_operand, ctx, filename, state, loop_var_name, current_name, current_type_name, enable_field_subst);
    } else if node.type == ASTNodeType.AST_MC_SOURCE {
        const operand3: &ASTNode = node.mc_source_operand;
        if operand3 != null {
            const resolved: &ASTNode = deep_copy_ast_internal(operand3, ctx, filename, state, loop_var_name, current_name, current_type_name, enable_field_subst);
            if resolved != null {
                const src_str: &byte = ast_expr_to_source_string(resolved, ctx.arena, filename);
                if src_str != null {
                    return create_string_literal(src_str, ctx.arena, node.line, node.column);
                }
            }
        }
        copy.mc_source_operand = deep_copy_ast_internal(node.mc_source_operand, ctx, filename, state, loop_var_name, current_name, current_type_name, enable_field_subst);
    } else if node.type == ASTNodeType.AST_ERROR_ID {
        copy.error_id_operand = deep_copy_ast_internal(node.error_id_operand, ctx, filename, state, loop_var_name, current_name, current_type_name, enable_field_subst);
    } else if node.type == ASTNodeType.AST_STRUCT_INIT {
        copy.struct_init_struct_name = node.struct_init_struct_name;
        copy.struct_init_field_count = node.struct_init_field_count;
        if node.struct_init_field_names != null && node.struct_init_field_values != null && node.struct_init_field_count > 0 {
            copy.struct_init_field_names = compiler_arena_alloc(ctx.arena, 8 * node.struct_init_field_count) as &(&byte);
            copy.struct_init_field_values = compiler_arena_alloc(ctx.arena, 8 * node.struct_init_field_count) as &(&ASTNode);
            if copy.struct_init_field_names != null && copy.struct_init_field_values != null {
                var i: i32 = 0;
                while i < node.struct_init_field_count {
                    copy.struct_init_field_names[i] = node.struct_init_field_names[i];
                    copy.struct_init_field_values[i] = deep_copy_ast_internal(node.struct_init_field_values[i], ctx, filename, state, loop_var_name, current_name, current_type_name, enable_field_subst);
                    i = i + 1;
                }
            }
        }
    } else if node.type == ASTNodeType.AST_SIZEOF {
        // 宏展开深拷贝须保留 target，否则 gen_sizeof_expr 见 null 会退化为 sizeof(int)，导致 assert_eq(@size_of(f64),8) 等静默错误
        copy.sizeof_expr_target = deep_copy_ast_internal(node.sizeof_expr_target, ctx, filename, state, loop_var_name, current_name, current_type_name, enable_field_subst);
        copy.sizeof_expr_is_type = node.sizeof_expr_is_type;
    } else if node.type == ASTNodeType.AST_ALIGNOF {
        copy.alignof_expr_target = deep_copy_ast_internal(node.alignof_expr_target, ctx, filename, state, loop_var_name, current_name, current_type_name, enable_field_subst);
        copy.alignof_expr_is_type = node.alignof_expr_is_type;
    } else if node.type == ASTNodeType.AST_LEN {
        copy.len_expr_array = deep_copy_ast_internal(node.len_expr_array, ctx, filename, state, loop_var_name, current_name, current_type_name, enable_field_subst);
    } else if node.type == ASTNodeType.AST_ERROR_VALUE {
        copy.error_value_name = node.error_value_name;
    }

    return copy;
}

// 带 field.name / field.type_name 替换的深拷贝（用于 for info.fields 每轮 body）
// 当 node 为 member_access(identifier(loop_var_name), "name") 时返回 identifier(current_name)；
// 为 member_access(identifier(loop_var_name), "type_name") 时返回 type_named(current_type_name)。
fn deep_copy_ast_with_field_subst(node: &ASTNode, ctx: &MacroExpandContext, filename: &byte, loop_var_name: &byte, current_name: &byte, current_type_name: &byte) &ASTNode {
    var state: HygieneCopyState = HygieneCopyState{
        scope_names: [],
        scope_renamed_names: [],
        scope_entry_count: 0,
        scope_starts: [],
        scope_depth: 0
    };
    init_hygiene_copy_state(&state);
    return deep_copy_ast_internal(node, ctx, filename, &state, loop_var_name, current_name, current_type_name, 1);
}

// 若 for 语句为「for info.fields |var|」且 info 绑定到 TypeInfo，则展开为块并返回新块；否则返回 null（不展开）。
fn expand_for_over_typeinfo_fields_once(for_stmt: &ASTNode, ctx: &MacroExpandContext, filename: &byte) &ASTNode {
    if for_stmt == null || for_stmt.type != ASTNodeType.AST_FOR_STMT || ctx == null || ctx.arena == null {
        return null;
    }
    if for_stmt.for_stmt_array == null || for_stmt.for_stmt_array.type != ASTNodeType.AST_MEMBER_ACCESS {
        return null;
    }
    const obj: &ASTNode = for_stmt.for_stmt_array.member_access_object;
    if obj == null || obj.type != ASTNodeType.AST_IDENTIFIER || obj.identifier_name == null {
        return null;
    }
    if for_stmt.for_stmt_array.member_access_field_name == null ||
       strcmp(for_stmt.for_stmt_array.member_access_field_name as *byte, "fields" as *byte) != 0 {
        return null;
    }
    const bound: &ASTNode = find_param_binding(ctx, obj.identifier_name);
    if bound == null || is_typeinfo_struct_init(bound) == 0 {
        return null;
    }
    const n: i32 = get_typeinfo_field_count_from_ast(bound);
    if n < 0 {
        return null;
    }
    if for_stmt.for_stmt_body == null {
        return null;
    }
    const loop_var: &byte = for_stmt.for_stmt_var_name;
    if loop_var == null {
        return null;
    }
    const block: &ASTNode = ast_new_node(ASTNodeType.AST_BLOCK, for_stmt.line, for_stmt.column, ctx.arena, filename);
    if block == null {
        return null;
    }
    block.block_stmt_count = n;
    block.block_stmts = compiler_arena_alloc(ctx.arena, @size_of(&ASTNode) * n) as & & ASTNode;
    if block.block_stmts == null {
        return null;
    }
    var i: i32 = 0;
    while i < n {
        var out_name: &byte = null;
        var out_type: &byte = null;
        if get_typeinfo_field_name_type_from_ast(bound, i, ctx.arena, &out_name, &out_type) == 0 {
            return null;
        }
        const body_i: &ASTNode = deep_copy_ast_with_field_subst(for_stmt.for_stmt_body, ctx, filename, loop_var, out_name, out_type);
        if body_i == null {
            return null;
        }
        block.block_stmts[i] = body_i;
        i = i + 1;
    }
    return block;
}

// 对宏体做一次「for over TypeInfo.fields」展开（仅顶层）：将每个可展开的 for 替换为块，返回新 body 供后续查找输出使用。
fn expand_body_for_over_typeinfo_fields(body: &ASTNode, ctx: &MacroExpandContext, filename: &byte) &ASTNode {
    if body == null || body.type != ASTNodeType.AST_BLOCK || ctx == null || ctx.arena == null {
        return body;
    }
    const n: i32 = body.block_stmt_count;
    if n <= 0 || body.block_stmts == null {
        return body;
    }
    const new_stmts: &(&ASTNode) = compiler_arena_alloc(ctx.arena, @size_of(&ASTNode) * n) as & & ASTNode;
    if new_stmts == null {
        return body;
    }
    var changed: i32 = 0;
    var i: i32 = 0;
    while i < n {
        const stmt: &ASTNode = body.block_stmts[i];
        if stmt != null && stmt.type == ASTNodeType.AST_FOR_STMT {
            const expanded: &ASTNode = expand_for_over_typeinfo_fields_once(stmt, ctx, filename);
            if expanded != null {
                new_stmts[i] = expanded;
                changed = 1;
            } else {
                new_stmts[i] = stmt;
            }
        } else {
            new_stmts[i] = stmt;
        }
        i = i + 1;
    }
    if changed == 0 {
        return body;
    }
    const new_block: &ASTNode = ast_new_node(ASTNodeType.AST_BLOCK, body.line, body.column, ctx.arena, filename);
    if new_block == null {
        return body;
    }
    new_block.block_stmt_count = n;
    new_block.block_stmts = new_stmts;
    return new_block;
}

// 编译时求值表达式（用于 @mc_eval）
// 返回求值结果，通过 success 参数返回是否成功
fn macro_eval_expr(expr: &ASTNode, ctx: &MacroExpandContext, success: &i32) i64 {
    *success = 0;
    if expr == null {
        return 0;
    }
    
    // 如果是标识符，检查是否是宏参数
    if expr.type == ASTNodeType.AST_IDENTIFIER && expr.identifier_name != null {
        const arg: &ASTNode = find_param_binding(ctx, expr.identifier_name);
        if arg != null {
            return macro_eval_expr(arg, ctx, success);
        }
        // 不是宏参数，无法求值
        return 0;
    }
    
    if expr.type == ASTNodeType.AST_NUMBER {
        *success = 1;
        return expr.number_value_i64;
    } else if expr.type == ASTNodeType.AST_BOOL {
        *success = 1;
        if expr.bool_literal_value != 0 {
            return 1;
        } else {
            return 0;
        }
    } else if expr.type == ASTNodeType.AST_BINARY_EXPR {
        var left_ok: i32 = 0;
        var right_ok: i32 = 0;
        const left: i64 = macro_eval_expr(expr.binary_expr_left, ctx, &left_ok);
        const right: i64 = macro_eval_expr(expr.binary_expr_right, ctx, &right_ok);
        if left_ok == 0 || right_ok == 0 {
            return 0;
        }
        *success = 1;
        const op_tmp: !TokenType = expr.binary_expr_op as! TokenType;
        const op: TokenType = op_tmp.value;
        if op == TokenType.TOKEN_PLUS {
            return left + right;
        } else if op == TokenType.TOKEN_MINUS {
            return left - right;
        } else if op == TokenType.TOKEN_ASTERISK {
            return left * right;
        } else if op == TokenType.TOKEN_SLASH {
            if right != 0 {
                return left / right;
            } else {
                return 0;
            }
        } else if op == TokenType.TOKEN_PERCENT {
            if right != 0 {
                return left % right;
            } else {
                return 0;
            }
        } else if op == TokenType.TOKEN_LESS {
            if left < right { return 1; } else { return 0; }
        } else if op == TokenType.TOKEN_GREATER {
            if left > right { return 1; } else { return 0; }
        } else if op == TokenType.TOKEN_LESS_EQUAL {
            if left <= right { return 1; } else { return 0; }
        } else if op == TokenType.TOKEN_GREATER_EQUAL {
            if left >= right { return 1; } else { return 0; }
        } else if op == TokenType.TOKEN_EQUAL {
            if left == right { return 1; } else { return 0; }
        } else if op == TokenType.TOKEN_NOT_EQUAL {
            if left != right { return 1; } else { return 0; }
        } else if op == TokenType.TOKEN_LOGICAL_AND {
            if left != 0 && right != 0 { return 1; } else { return 0; }
        } else if op == TokenType.TOKEN_LOGICAL_OR {
            if left != 0 || right != 0 { return 1; } else { return 0; }
        } else {
            *success = 0;
            return 0;
        }
    } else if expr.type == ASTNodeType.AST_UNARY_EXPR {
        var operand_ok: i32 = 0;
        const operand: i64 = macro_eval_expr(expr.unary_expr_operand, ctx, &operand_ok);
        if operand_ok == 0 {
            return 0;
        }
        *success = 1;
        const op_tmp: !TokenType = expr.unary_expr_op as! TokenType;
        const op: TokenType = op_tmp.value;
        if op == TokenType.TOKEN_MINUS {
            return 0 - operand;
        } else if op == TokenType.TOKEN_EXCLAMATION {
            if operand != 0 { return 0; } else { return 1; }
        } else {
            *success = 0;
            return 0;
        }
    }
    
    return 0;
}

// 深拷贝 AST 节点（支持参数替换）
fn deep_copy_ast_with_params(node: &ASTNode, ctx: &MacroExpandContext, filename: &byte) &ASTNode {
    var state: HygieneCopyState = HygieneCopyState{
        scope_names: [],
        scope_renamed_names: [],
        scope_entry_count: 0,
        scope_starts: [],
        scope_depth: 0
    };
    init_hygiene_copy_state(&state);
    return deep_copy_ast_internal(node, ctx, filename, &state, null, null, null, 0);
}

// 深拷贝 AST 节点（简化版本，仅支持基本节点类型）
fn deep_copy_ast_simple(node: &ASTNode, arena: &CompilerArena, filename: &byte) &ASTNode {
    if node == null || arena == null {
        return null;
    }
    
    const copy: &ASTNode = ast_new_node(node.type, node.line, node.column, arena, filename);
    if copy == null {
        return null;
    }
    
    // 根据节点类型复制数据
    if node.type == ASTNodeType.AST_NUMBER {
        copy.number_value = node.number_value;
        copy.number_value_i64 = node.number_value_i64;
    } else if node.type == ASTNodeType.AST_FLOAT {
        copy.float_literal_value = node.float_literal_value;
    } else if node.type == ASTNodeType.AST_BOOL {
        copy.bool_literal_value = node.bool_literal_value;
    } else if node.type == ASTNodeType.AST_STRING {
        copy.string_literal_value = node.string_literal_value;
    } else if node.type == ASTNodeType.AST_EMBED || node.type == ASTNodeType.AST_EMBED_DIR {
        copy.embed_path_literal = node.embed_path_literal;
        copy.embed_resolved_path = node.embed_resolved_path;
        copy.embed_data = node.embed_data;
        copy.embed_size = node.embed_size;
        copy.embed_dir_paths = node.embed_dir_paths;
        copy.embed_dir_resolved_paths = node.embed_dir_resolved_paths;
        copy.embed_dir_data = node.embed_dir_data;
        copy.embed_dir_sizes = node.embed_dir_sizes;
        copy.embed_dir_entry_count = node.embed_dir_entry_count;
    } else if node.type == ASTNodeType.AST_CHAR {
        copy.char_literal_value = node.char_literal_value;
    } else if node.type == ASTNodeType.AST_INT_LIMIT {
        copy.int_limit_is_max = node.int_limit_is_max;
        copy.int_limit_resolved_kind = node.int_limit_resolved_kind;
    } else if node.type == ASTNodeType.AST_IDENTIFIER {
        copy.identifier_name = node.identifier_name;
    } else if node.type == ASTNodeType.AST_BINARY_EXPR {
        copy.binary_expr_op = node.binary_expr_op;
        copy.binary_expr_left = deep_copy_ast_simple(node.binary_expr_left, arena, filename);
        copy.binary_expr_right = deep_copy_ast_simple(node.binary_expr_right, arena, filename);
    } else if node.type == ASTNodeType.AST_UNARY_EXPR {
        copy.unary_expr_op = node.unary_expr_op;
        copy.unary_expr_operand = deep_copy_ast_simple(node.unary_expr_operand, arena, filename);
    } else if node.type == ASTNodeType.AST_CALL_EXPR {
        copy.call_expr_callee = deep_copy_ast_simple(node.call_expr_callee, arena, filename);
        copy.call_expr_arg_count = node.call_expr_arg_count;
        if node.call_expr_args != null && node.call_expr_arg_count > 0 {
            copy.call_expr_args = compiler_arena_alloc(arena, @size_of(&ASTNode) * node.call_expr_arg_count) as & & ASTNode;
            if copy.call_expr_args != null {
                var i: i32 = 0;
                while i < node.call_expr_arg_count {
                    copy.call_expr_args[i] = deep_copy_ast_simple(node.call_expr_args[i], arena, filename);
                    i = i + 1;
                }
            }
        }
    } else if node.type == ASTNodeType.AST_MEMBER_ACCESS {
        copy.member_access_object = deep_copy_ast_simple(node.member_access_object, arena, filename);
        copy.member_access_field_name = node.member_access_field_name;
        copy.member_access_is_module_access = node.member_access_is_module_access;
        copy.member_access_module_name = node.member_access_module_name;
    } else if node.type == ASTNodeType.AST_ARRAY_ACCESS {
        copy.array_access_array = deep_copy_ast_simple(node.array_access_array, arena, filename);
        copy.array_access_index = deep_copy_ast_simple(node.array_access_index, arena, filename);
    } else if node.type == ASTNodeType.AST_SLICE_EXPR {
        copy.slice_expr_base = deep_copy_ast_simple(node.slice_expr_base, arena, filename);
        copy.slice_expr_start_expr = deep_copy_ast_simple(node.slice_expr_start_expr, arena, filename);
        copy.slice_expr_len_expr = deep_copy_ast_simple(node.slice_expr_len_expr, arena, filename);
    }
    // 其他类型暂时只复制基本信息
    
    return copy;
}

// 从宏体提取输出表达式（支持参数替换）
fn extract_macro_output_with_params(body: &ASTNode, ctx: &MacroExpandContext, filename: &byte, return_tag: &byte) &ASTNode {
    if body == null || body.type != ASTNodeType.AST_BLOCK || ctx == null {
        return null;
    }
    
    // 处理宏体中的 const 声明（如 const x = @mc_eval(...)）
    // 建立局部变量绑定
    var local_bindings: [MacroParamBinding: 64] = [];
    var local_binding_count: i32 = 0;
    
    var j: i32 = 0;
    while j < body.block_stmt_count {
        const s: &ASTNode = body.block_stmts[j];
        if s != null && s.type == ASTNodeType.AST_VAR_DECL && s.var_decl_is_const != 0 &&
            s.var_decl_name != null && s.var_decl_init != null {
            const init: &ASTNode = s.var_decl_init;
            
            // 处理 @mc_eval
            if init.type == ASTNodeType.AST_MC_EVAL {
                var success: i32 = 0;
                const value: i64 = macro_eval_expr(init.mc_eval_operand, ctx, &success);
                if success != 0 && local_binding_count < @len(local_bindings) {
                    const num: &ASTNode = create_number_literal(value, ctx.arena, init.line, init.column);
                    if num != null {
                        local_bindings[local_binding_count].param_name = s.var_decl_name;
                        local_bindings[local_binding_count].arg_ast = num;
                        local_binding_count = local_binding_count + 1;
                    }
                }
            }

            // 处理 @mc_type
            if init.type == ASTNodeType.AST_MC_TYPE && local_binding_count < @len(local_bindings) {
                const operand: &ASTNode = init.mc_type_operand;
                if operand != null {
                    // 先对操作数进行参数替换
                    const resolved_operand: &ASTNode = deep_copy_ast_with_params(operand, ctx, filename);
                    var actual_operand: &ASTNode = operand;
                    if resolved_operand != null {
                        actual_operand = resolved_operand;
                    }
                    // 创建 TypeInfo 结构体
                    const type_info: &ASTNode = create_type_info_struct(actual_operand, ctx.arena, init.line, init.column, ctx.checker);
                    if type_info != null {
                        local_bindings[local_binding_count].param_name = s.var_decl_name;
                        local_bindings[local_binding_count].arg_ast = type_info;
                        local_binding_count = local_binding_count + 1;
                    }
                }
            }
        }
        
        // 处理 @mc_error
        if s != null && s.type == ASTNodeType.AST_MC_ERROR {
            if ctx.checker != null {
                var msg: &byte = ("宏编译时错误" as *byte) as &byte;
                if s.mc_error_operand != null && s.mc_error_operand.type == ASTNodeType.AST_STRING &&
                    s.mc_error_operand.string_literal_value != null {
                    msg = s.mc_error_operand.string_literal_value;
                }
                checker_report_error(ctx.checker, s, msg);
            }
            return null;  // 返回 null 表示错误
        }
        
        j = j + 1;
    }
    
    // 创建合并的上下文（包含宏参数和局部变量）
    var merged_ctx: MacroExpandContext = *ctx;
    const MAX_LOCAL_BINDINGS: i32 = 64;
    if local_binding_count > 0 {
        const total_bindings: i32 = ctx.binding_count + local_binding_count;
        const all_bindings: &MacroParamBinding = compiler_arena_alloc(ctx.arena, @size_of(MacroParamBinding) * total_bindings) as &MacroParamBinding;
        if all_bindings != null {
            var k: i32 = 0;
            while k < ctx.binding_count {
                all_bindings[k] = ctx.bindings[k];
                k = k + 1;
            }
            k = 0;
            for 0..local_binding_count |kidx| {
                if kidx < MAX_LOCAL_BINDINGS {
                    const src_idx: i32 = kidx;
                    const dst_idx: i32 = ctx.binding_count + kidx;
                    // 动态分配的数组，运行时边界检查
                    const total: i32 = total_bindings;
                    if dst_idx >= 0 && dst_idx < total && src_idx >= 0 && src_idx < MAX_LOCAL_BINDINGS {
                        all_bindings[dst_idx] = local_bindings[src_idx];
                    }
                }
            }
            merged_ctx.bindings = all_bindings;
            merged_ctx.binding_count = total_bindings;
        }
    }
    
    // 编译期 for over TypeInfo.fields 展开（仅顶层）：将可展开的 for 替换为块
    const body_to_use: &ASTNode = expand_body_for_over_typeinfo_fields(body, &merged_ctx, filename);
    
    // 遍历宏体语句，查找输出节点
    var i: i32 = body_to_use.block_stmt_count - 1;
    while i >= 0 {
        const stmt: &ASTNode = body_to_use.block_stmts[i];
        if stmt == null {
            i = i - 1;
            continue;
        }
        
        // 处理 @mc_code(@mc_ast(expr)) 模式
        if stmt.type == ASTNodeType.AST_MC_CODE && stmt.mc_code_operand != null {
            const mc_code_arg: &ASTNode = stmt.mc_code_operand;
            if mc_code_arg.type == ASTNodeType.AST_MC_AST && mc_code_arg.mc_ast_operand != null {
                // 返回 @mc_ast 的参数的深拷贝（带参数替换）
                var result: &ASTNode = deep_copy_ast_with_params(mc_code_arg.mc_ast_operand, &merged_ctx, filename);
                
                // 对于 type 返回类型，如果结果是标识符，转换为类型节点
                if return_tag != null && strcmp(return_tag as *byte, "type" as *byte) == 0 &&
                    result != null && result.type == ASTNodeType.AST_IDENTIFIER && result.identifier_name != null {
                    const type_node: &ASTNode = ast_new_node(ASTNodeType.AST_TYPE_NAMED, result.line, result.column, merged_ctx.arena, filename);
                    if type_node != null {
                        type_node.type_named_name = result.identifier_name;
                        result = type_node;
                    }
                }
                
                return result;
            }
        }
        
        // 语法糖：expr 返回类型 - 最后一个表达式自动作为输出
        if return_tag != null && strcmp(return_tag as *byte, "expr" as *byte) == 0 {
            // 跳过变量声明语句
            if stmt.type == ASTNodeType.AST_VAR_DECL {
                i = i - 1;
                continue;
            }
            // 跳过控制流语句
            if stmt.type == ASTNodeType.AST_IF_STMT || stmt.type == ASTNodeType.AST_WHILE_STMT ||
                stmt.type == ASTNodeType.AST_FOR_STMT || stmt.type == ASTNodeType.AST_RETURN_STMT ||
                stmt.type == ASTNodeType.AST_BREAK_STMT || stmt.type == ASTNodeType.AST_CONTINUE_STMT ||
                stmt.type == ASTNodeType.AST_BLOCK {
                i = i - 1;
                continue;
            }
            // 处理 @mc_type：展开为 TypeInfo 结构体
            if stmt.type == ASTNodeType.AST_MC_TYPE {
                const operand: &ASTNode = stmt.mc_type_operand;
                if operand != null {
                    const resolved_operand: &ASTNode = deep_copy_ast_with_params(operand, &merged_ctx, filename);
                    var actual_operand: &ASTNode = operand;
                    if resolved_operand != null {
                        actual_operand = resolved_operand;
                    }
                    const type_info: &ASTNode = create_type_info_struct(actual_operand, merged_ctx.arena, stmt.line, stmt.column, merged_ctx.checker);
                    if type_info != null {
                        return type_info;
                    }
                }
            }
            // 对于表达式节点，直接作为输出（含 @mc_source(expr)，展开为字符串字面量）
            // 解析器将 "expr;" 存为表达式节点本身，故需包含 CAST_EXPR、TRY_EXPR、ERROR_VALUE 等
            if stmt.type == ASTNodeType.AST_NUMBER || stmt.type == ASTNodeType.AST_BOOL ||
                stmt.type == ASTNodeType.AST_STRING || stmt.type == ASTNodeType.AST_IDENTIFIER ||
                stmt.type == ASTNodeType.AST_BINARY_EXPR || stmt.type == ASTNodeType.AST_UNARY_EXPR ||
                stmt.type == ASTNodeType.AST_CALL_EXPR || stmt.type == ASTNodeType.AST_MEMBER_ACCESS ||
                stmt.type == ASTNodeType.AST_ARRAY_ACCESS || stmt.type == ASTNodeType.AST_STRUCT_INIT ||
                stmt.type == ASTNodeType.AST_ARRAY_LITERAL || stmt.type == ASTNodeType.AST_MC_INTERP ||
                stmt.type == ASTNodeType.AST_MC_SOURCE || stmt.type == ASTNodeType.AST_CAST_EXPR ||
                stmt.type == ASTNodeType.AST_TRY_EXPR || stmt.type == ASTNodeType.AST_ERROR_VALUE {
                return deep_copy_ast_with_params(stmt, &merged_ctx, filename);
            }
            // expr 单语句回退：块内仅一条语句且非 var_decl/控制流 时，作为表达式输出（便于占位如 error.X as !usize）
            if return_tag != null && strcmp(return_tag as *byte, "expr" as *byte) == 0 &&
               body_to_use.block_stmt_count == 1 && stmt.type != ASTNodeType.AST_VAR_DECL &&
               stmt.type != ASTNodeType.AST_IF_STMT && stmt.type != ASTNodeType.AST_WHILE_STMT &&
               stmt.type != ASTNodeType.AST_FOR_STMT && stmt.type != ASTNodeType.AST_RETURN_STMT &&
               stmt.type != ASTNodeType.AST_BREAK_STMT && stmt.type != ASTNodeType.AST_CONTINUE_STMT &&
               stmt.type != ASTNodeType.AST_BLOCK {
                return deep_copy_ast_with_params(stmt, &merged_ctx, filename);
            }
        }
        
        // 语法糖：stmt 返回类型 - 最后一个语句自动作为输出
        if return_tag != null && strcmp(return_tag as *byte, "stmt" as *byte) == 0 {
            // 跳过变量声明语句
            if stmt.type == ASTNodeType.AST_VAR_DECL {
                i = i - 1;
                continue;
            }
            return deep_copy_ast_with_params(stmt, &merged_ctx, filename);
        }
        
        // 语法糖：struct 返回类型 - 方法定义作为输出
        if return_tag != null && strcmp(return_tag as *byte, "struct" as *byte) == 0 {
            // 跳过变量声明语句
            if stmt.type == ASTNodeType.AST_VAR_DECL {
                i = i - 1;
                continue;
            }
            return deep_copy_ast_with_params(stmt, &merged_ctx, filename);
        }
        
        // 语法糖：type 返回类型 - 标识符自动转换为类型节点
        if return_tag != null && strcmp(return_tag as *byte, "type" as *byte) == 0 {
            // 跳过变量声明语句
            if stmt.type == ASTNodeType.AST_VAR_DECL {
                i = i - 1;
                continue;
            }
            var result: &ASTNode = deep_copy_ast_with_params(stmt, &merged_ctx, filename);
            // 如果结果是标识符，转换为类型节点
            if result != null && result.type == ASTNodeType.AST_IDENTIFIER && result.identifier_name != null {
                const type_node: &ASTNode = ast_new_node(ASTNodeType.AST_TYPE_NAMED, result.line, result.column, merged_ctx.arena, filename);
                if type_node != null {
                    type_node.type_named_name = result.identifier_name;
                    result = type_node;
                }
            }
            return result;
        }
        
        i = i - 1;
    }
    
    return null;
}

// 从宏体提取输出表达式（简化版本，仅支持 @mc_code(@mc_ast(expr))）
fn extract_macro_output_simple(body: &ASTNode, arena: &CompilerArena, filename: &byte) &ASTNode {
    if body == null || body.type != ASTNodeType.AST_BLOCK {
        return null;
    }
    
    // 遍历宏体语句，查找 @mc_code 节点
    var i: i32 = body.block_stmt_count - 1;
    while i >= 0 {
        const stmt: &ASTNode = body.block_stmts[i];
        if stmt == null {
            i = i - 1;
            continue;
        }
        
        // 处理 @mc_code(@mc_ast(expr)) 模式
        if stmt.type == ASTNodeType.AST_MC_CODE && stmt.mc_code_operand != null {
            const mc_code_arg: &ASTNode = stmt.mc_code_operand;
            if mc_code_arg.type == ASTNodeType.AST_MC_AST && mc_code_arg.mc_ast_operand != null {
                // 返回 @mc_ast 的参数的深拷贝
                return deep_copy_ast_simple(mc_code_arg.mc_ast_operand, arena, filename);
            }
        }
        
        i = i - 1;
    }
    
    return null;
}

// 深拷贝 AST 并将类型形参标识符替换为对应的类型实参节点（供 codegen 生成单态函数体前使用）。
export fn deep_copy_ast_substitute_type_params(node: &ASTNode, type_params: &TypeParam, type_param_count: i32, type_args: & & ASTNode, type_arg_count: i32, arena: &CompilerArena, filename: &byte) &ASTNode {
    if node == null || arena == null {
        return null;
    }
    if node.type == ASTNodeType.AST_IDENTIFIER && node.identifier_name != null && type_params != null && type_args != null {
        var i: i32 = 0;
        while i < type_param_count && i < type_arg_count {
            if type_params[i].name != null && strcmp(type_params[i].name as *byte, node.identifier_name as *byte) == 0 {
                return type_args[i];
            }
            i = i + 1;
        }
    }
    const copy: &ASTNode = ast_new_node(node.type, node.line, node.column, arena, filename);
    if copy == null { return null; }
    if node.type == ASTNodeType.AST_NUMBER {
        copy.number_value = node.number_value;
        copy.number_value_i64 = node.number_value_i64;
    } else if node.type == ASTNodeType.AST_IDENTIFIER {
        copy.identifier_name = node.identifier_name;
    } else if node.type == ASTNodeType.AST_BLOCK && node.block_stmts != null && node.block_stmt_count > 0 {
        copy.block_stmt_count = node.block_stmt_count;
        copy.block_stmts = compiler_arena_alloc(arena, (@size_of(&ASTNode) * node.block_stmt_count) as u64) as &(&ASTNode);
        if copy.block_stmts != null {
            var j: i32 = 0;
            while j < node.block_stmt_count {
                copy.block_stmts[j] = deep_copy_ast_substitute_type_params(node.block_stmts[j], type_params, type_param_count, type_args, type_arg_count, arena, filename);
                j = j + 1;
            }
        }
    } else if node.type == ASTNodeType.AST_CALL_EXPR {
        copy.call_expr_callee = deep_copy_ast_substitute_type_params(node.call_expr_callee, type_params, type_param_count, type_args, type_arg_count, arena, filename);
        copy.call_expr_arg_count = node.call_expr_arg_count;
        copy.call_expr_has_ellipsis_forward = node.call_expr_has_ellipsis_forward;
        copy.call_expr_type_args = null;
        copy.call_expr_type_arg_count = 0;
        if node.call_expr_args != null && node.call_expr_arg_count > 0 {
            copy.call_expr_args = compiler_arena_alloc(arena, (@size_of(&ASTNode) * node.call_expr_arg_count) as u64) as &(&ASTNode);
            if copy.call_expr_args != null {
                var j: i32 = 0;
                while j < node.call_expr_arg_count {
                    copy.call_expr_args[j] = deep_copy_ast_substitute_type_params(node.call_expr_args[j], type_params, type_param_count, type_args, type_arg_count, arena, filename);
                    j = j + 1;
                }
            }
        }
    } else if node.type == ASTNodeType.AST_TRY_EXPR && node.try_expr_operand != null {
        copy.try_expr_operand = deep_copy_ast_substitute_type_params(node.try_expr_operand, type_params, type_param_count, type_args, type_arg_count, arena, filename);
    } else if node.type == ASTNodeType.AST_UNARY_EXPR && node.unary_expr_operand != null {
        copy.unary_expr_op = node.unary_expr_op;
        copy.unary_expr_operand = deep_copy_ast_substitute_type_params(node.unary_expr_operand, type_params, type_param_count, type_args, type_arg_count, arena, filename);
    } else if node.type == ASTNodeType.AST_BINARY_EXPR && node.binary_expr_left != null && node.binary_expr_right != null {
        copy.binary_expr_op = node.binary_expr_op;
        copy.binary_expr_left = deep_copy_ast_substitute_type_params(node.binary_expr_left, type_params, type_param_count, type_args, type_arg_count, arena, filename);
        copy.binary_expr_right = deep_copy_ast_substitute_type_params(node.binary_expr_right, type_params, type_param_count, type_args, type_arg_count, arena, filename);
    } else if node.type == ASTNodeType.AST_MEMBER_ACCESS && node.member_access_object != null {
        copy.member_access_object = deep_copy_ast_substitute_type_params(node.member_access_object, type_params, type_param_count, type_args, type_arg_count, arena, filename);
        copy.member_access_field_name = node.member_access_field_name;
        copy.member_access_is_module_access = node.member_access_is_module_access;
        copy.member_access_module_name = node.member_access_module_name;
    } else if node.type == ASTNodeType.AST_ARRAY_ACCESS && node.array_access_array != null && node.array_access_index != null {
        copy.array_access_array = deep_copy_ast_substitute_type_params(node.array_access_array, type_params, type_param_count, type_args, type_arg_count, arena, filename);
        copy.array_access_index = deep_copy_ast_substitute_type_params(node.array_access_index, type_params, type_param_count, type_args, type_arg_count, arena, filename);
    } else if node.type == ASTNodeType.AST_TYPE_NAMED && node.type_named_name != null {
        copy.type_named_name = node.type_named_name;
        if node.type_named_type_args != null && node.type_named_type_arg_count > 0 {
            copy.type_named_type_arg_count = node.type_named_type_arg_count;
            copy.type_named_type_args = compiler_arena_alloc(arena, (@size_of(&ASTNode) * node.type_named_type_arg_count) as u64) as &(&ASTNode);
            if copy.type_named_type_args != null {
                var j: i32 = 0;
                while j < node.type_named_type_arg_count {
                    copy.type_named_type_args[j] = deep_copy_ast_substitute_type_params(node.type_named_type_args[j], type_params, type_param_count, type_args, type_arg_count, arena, filename);
                    j = j + 1;
                }
            }
        }
    } else if node.type == ASTNodeType.AST_TYPE_ERROR_UNION && node.type_error_union_payload_type != null {
        copy.type_error_union_payload_type = deep_copy_ast_substitute_type_params(node.type_error_union_payload_type, type_params, type_param_count, type_args, type_arg_count, arena, filename);
    } else if node.type == ASTNodeType.AST_STRUCT_INIT && node.struct_init_struct_name != null {
        copy.struct_init_struct_name = node.struct_init_struct_name;
        copy.struct_init_field_count = node.struct_init_field_count;
        if node.struct_init_type_args != null && node.struct_init_type_arg_count > 0 {
            copy.struct_init_type_arg_count = node.struct_init_type_arg_count;
            copy.struct_init_type_args = compiler_arena_alloc(arena, (@size_of(&ASTNode) * node.struct_init_type_arg_count) as u64) as &(&ASTNode);
            if copy.struct_init_type_args != null {
                var tj: i32 = 0;
                while tj < node.struct_init_type_arg_count {
                    copy.struct_init_type_args[tj] = deep_copy_ast_substitute_type_params(node.struct_init_type_args[tj], type_params, type_param_count, type_args, type_arg_count, arena, filename);
                    tj = tj + 1;
                }
            }
        }
        if node.struct_init_field_count > 0 && node.struct_init_field_names != null && node.struct_init_field_values != null {
            copy.struct_init_field_names = compiler_arena_alloc(arena, (@size_of(&byte) * node.struct_init_field_count) as u64) as &(&byte);
            copy.struct_init_field_values = compiler_arena_alloc(arena, (@size_of(&ASTNode) * node.struct_init_field_count) as u64) as &(&ASTNode);
            if copy.struct_init_field_names != null && copy.struct_init_field_values != null {
                var fj: i32 = 0;
                while fj < node.struct_init_field_count {
                    copy.struct_init_field_names[fj] = node.struct_init_field_names[fj];
                    copy.struct_init_field_values[fj] = deep_copy_ast_substitute_type_params(node.struct_init_field_values[fj], type_params, type_param_count, type_args, type_arg_count, arena, filename);
                    fj = fj + 1;
                }
            }
        }
    } else if node.type == ASTNodeType.AST_VAR_DECL {
        copy.var_decl_name = node.var_decl_name;
        copy.var_decl_is_const = node.var_decl_is_const;
        if node.var_decl_type != null {
            copy.var_decl_type = deep_copy_ast_substitute_type_params(node.var_decl_type, type_params, type_param_count, type_args, type_arg_count, arena, filename);
        }
        if node.var_decl_init != null {
            copy.var_decl_init = deep_copy_ast_substitute_type_params(node.var_decl_init, type_params, type_param_count, type_args, type_arg_count, arena, filename);
        }
    } else if node.type == ASTNodeType.AST_IF_STMT {
        if node.if_stmt_condition != null { copy.if_stmt_condition = deep_copy_ast_substitute_type_params(node.if_stmt_condition, type_params, type_param_count, type_args, type_arg_count, arena, filename); }
        if node.if_stmt_then_branch != null { copy.if_stmt_then_branch = deep_copy_ast_substitute_type_params(node.if_stmt_then_branch, type_params, type_param_count, type_args, type_arg_count, arena, filename); }
        if node.if_stmt_else_branch != null { copy.if_stmt_else_branch = deep_copy_ast_substitute_type_params(node.if_stmt_else_branch, type_params, type_param_count, type_args, type_arg_count, arena, filename); }
    } else if node.type == ASTNodeType.AST_RETURN_STMT && node.return_stmt_expr != null {
        copy.return_stmt_expr = deep_copy_ast_substitute_type_params(node.return_stmt_expr, type_params, type_param_count, type_args, type_arg_count, arena, filename);
    } else if node.type == ASTNodeType.AST_SLICE_EXPR && node.slice_expr_base != null && node.slice_expr_start_expr != null && node.slice_expr_len_expr != null {
        copy.slice_expr_base = deep_copy_ast_substitute_type_params(node.slice_expr_base, type_params, type_param_count, type_args, type_arg_count, arena, filename);
        copy.slice_expr_start_expr = deep_copy_ast_substitute_type_params(node.slice_expr_start_expr, type_params, type_param_count, type_args, type_arg_count, arena, filename);
        copy.slice_expr_len_expr = deep_copy_ast_substitute_type_params(node.slice_expr_len_expr, type_params, type_param_count, type_args, type_arg_count, arena, filename);
    } else if node.type == ASTNodeType.AST_CAST_EXPR && node.cast_expr_expr != null && node.cast_expr_target_type != null {
        copy.cast_expr_expr = deep_copy_ast_substitute_type_params(node.cast_expr_expr, type_params, type_param_count, type_args, type_arg_count, arena, filename);
        copy.cast_expr_target_type = deep_copy_ast_substitute_type_params(node.cast_expr_target_type, type_params, type_param_count, type_args, type_arg_count, arena, filename);
        copy.cast_expr_is_force_cast = node.cast_expr_is_force_cast;
    } else if node.type == ASTNodeType.AST_NUMBER || node.type == ASTNodeType.AST_FLOAT || node.type == ASTNodeType.AST_BOOL || node.type == ASTNodeType.AST_STRING || node.type == ASTNodeType.AST_CHAR || node.type == ASTNodeType.AST_EMBED || node.type == ASTNodeType.AST_EMBED_DIR {
        if node.type == ASTNodeType.AST_NUMBER { copy.number_value = node.number_value; copy.number_value_i64 = node.number_value_i64; }
        else if node.type == ASTNodeType.AST_FLOAT { copy.float_literal_value = node.float_literal_value; }
        else if node.type == ASTNodeType.AST_BOOL { copy.bool_literal_value = node.bool_literal_value; }
        else if node.type == ASTNodeType.AST_STRING { copy.string_literal_value = node.string_literal_value; }
        else if node.type == ASTNodeType.AST_EMBED || node.type == ASTNodeType.AST_EMBED_DIR {
            copy.embed_path_literal = node.embed_path_literal;
            copy.embed_resolved_path = node.embed_resolved_path;
            copy.embed_data = node.embed_data;
            copy.embed_size = node.embed_size;
            copy.embed_dir_paths = node.embed_dir_paths;
            copy.embed_dir_resolved_paths = node.embed_dir_resolved_paths;
            copy.embed_dir_data = node.embed_dir_data;
            copy.embed_dir_sizes = node.embed_dir_sizes;
            copy.embed_dir_entry_count = node.embed_dir_entry_count;
        }
        else if node.type == ASTNodeType.AST_CHAR { copy.char_literal_value = node.char_literal_value; }
    } else {
        return deep_copy_ast_simple(node, arena, filename);
    }
    return copy;
}

// 为单态化函数体做类型形参替换并展开宏，返回新 body 供 codegen 使用。
export fn prepare_mono_body_expand_macros(checker: &TypeChecker, body: &ASTNode, type_params: &TypeParam, type_param_count: i32, type_args: & & ASTNode, type_arg_count: i32) &ASTNode {
    if checker == null || body == null || checker.arena == null {
        return null;
    }
    const copied: &ASTNode = deep_copy_ast_substitute_type_params(body, type_params, type_param_count, type_args, type_arg_count, checker.arena, body.filename);
    if copied == null { return null; }
    var ptr: &ASTNode = copied;
    expand_macros_in_node_simple(checker, &ptr);
    return ptr;
}

// 递归计算 encode 块中“字段部分”的语句数（不含 var_w/init/open_brace/close_brace/if_expr）
fn count_encode_field_stmts(checker: &TypeChecker, struct_decl: &ASTNode) i32 {
    if checker == null || struct_decl == null || struct_decl.struct_decl_fields == null { return 0; }
    var total: i32 = 0;
    var fi: i32 = 0;
    const n: i32 = struct_decl.struct_decl_field_count;
    while fi < n {
        const field_node: &ASTNode = struct_decl.struct_decl_fields[fi];
        if field_node == null || field_node.type != ASTNodeType.AST_VAR_DECL || field_node.var_decl_name == null {
            fi = fi + 1;
            continue;
        }
        if fi > 0 { total = total + 1; }
        total = total + 2;
        fi = fi + 1;
    }
    return total;
}

fn build_json_write_byte_stmt(addr_w: &ASTNode, byte_value: i64, arena: &CompilerArena, line: i32, column: i32, filename: &byte) &ASTNode {
    if addr_w == null || arena == null { return null; }
    const s_json_write_byte: &byte = macro_arena_strdup(arena, ("json_write_byte" as *byte) as &byte);
    if s_json_write_byte == null { return null; }
    const args: &(&ASTNode) = compiler_arena_alloc(arena, (2 * 8) as u64) as &(&ASTNode);
    if args == null { return null; }
    args[0] = addr_w;
    args[1] = create_number_literal(byte_value, arena, line, column);
    const call_stmt: &ASTNode = ast_new_node(ASTNodeType.AST_CALL_EXPR, line, column, arena, filename);
    if call_stmt == null { return null; }
    call_stmt.call_expr_callee = create_identifier_from_string(s_json_write_byte, arena, line, column);
    call_stmt.call_expr_args = args;
    call_stmt.call_expr_arg_count = 2;
    call_stmt.call_expr_has_ellipsis_forward = 0;
    call_stmt.call_expr_type_args = null;
    call_stmt.call_expr_type_arg_count = 0;
    return call_stmt;
}

fn build_json_write_key_stmt(addr_w: &ASTNode, key_name: &byte, arena: &CompilerArena, line: i32, column: i32, filename: &byte) &ASTNode {
    if addr_w == null || key_name == null || arena == null { return null; }
    const s_json_write_key: &byte = macro_arena_strdup(arena, ("json_write_key" as *byte) as &byte);
    if s_json_write_key == null { return null; }
    const key_args: &(&ASTNode) = compiler_arena_alloc(arena, (3 * 8) as u64) as &(&ASTNode);
    if key_args == null { return null; }
    key_args[0] = addr_w;
    key_args[1] = create_string_literal(key_name, arena, line, column);
    key_args[2] = create_number_literal((strlen(key_name as *byte)) as i64, arena, line, column);
    const call_key: &ASTNode = ast_new_node(ASTNodeType.AST_CALL_EXPR, line, column, arena, filename);
    if call_key == null { return null; }
    call_key.call_expr_callee = create_identifier_from_string(s_json_write_key, arena, line, column);
    call_key.call_expr_args = key_args;
    call_key.call_expr_arg_count = 3;
    call_key.call_expr_has_ellipsis_forward = 0;
    call_key.call_expr_type_args = null;
    call_key.call_expr_type_arg_count = 0;
    return call_key;
}

fn build_json_write_scalar_stmt(type_name: &byte, value_expr: &ASTNode, addr_w: &ASTNode, arena: &CompilerArena, line: i32, column: i32, filename: &byte) &ASTNode {
    if type_name == null || value_expr == null || addr_w == null || arena == null { return null; }
    const s_json_write_i64: &byte = macro_arena_strdup(arena, ("json_write_i64" as *byte) as &byte);
    const s_json_write_str_view: &byte = macro_arena_strdup(arena, ("json_write_str_view" as *byte) as &byte);
    const s_json_write_bool: &byte = macro_arena_strdup(arena, ("json_write_bool" as *byte) as &byte);
    const s_json_write_f64: &byte = macro_arena_strdup(arena, ("json_write_f64" as *byte) as &byte);
    if s_json_write_i64 == null || s_json_write_str_view == null || s_json_write_bool == null || s_json_write_f64 == null { return null; }
    const write_args: &(&ASTNode) = compiler_arena_alloc(arena, (2 * 8) as u64) as &(&ASTNode);
    if write_args == null { return null; }
    write_args[0] = addr_w;
    write_args[1] = value_expr;
    var write_callee: &byte = s_json_write_i64;
    if strcmp(type_name as *byte, "JsonStrView" as *byte) == 0 { write_callee = s_json_write_str_view; }
    else if strcmp(type_name as *byte, "bool" as *byte) == 0 { write_callee = s_json_write_bool; }
    else if strcmp(type_name as *byte, "f64" as *byte) == 0 { write_callee = s_json_write_f64; }
    const call_write: &ASTNode = ast_new_node(ASTNodeType.AST_CALL_EXPR, line, column, arena, filename);
    if call_write == null { return null; }
    call_write.call_expr_callee = create_identifier_from_string(write_callee, arena, line, column);
    call_write.call_expr_args = write_args;
    call_write.call_expr_arg_count = 2;
    call_write.call_expr_has_ellipsis_forward = 0;
    call_write.call_expr_type_args = null;
    call_write.call_expr_type_arg_count = 0;
    return call_write;
}

fn build_json_write_value_stmt(checker: &TypeChecker, type_node: &ASTNode, value_expr: &ASTNode, addr_w: &ASTNode, name_hint: &byte, line: i32, column: i32, filename: &byte) &ASTNode {
    if checker == null || checker.arena == null || type_node == null || value_expr == null || addr_w == null {
        return null;
    }
    const arena: &CompilerArena = checker.arena;
    var safe_name_hint: &byte = name_hint;
    if safe_name_hint == null {
        safe_name_hint = ("value" as *byte) as &byte;
    }

    if type_node.type == ASTNodeType.AST_TYPE_ARRAY {
        var arr_size: i32 = 0;
        if type_node.type_array_size_expr != null {
            arr_size = checker_eval_const_expr(checker, type_node.type_array_size_expr);
        }
        if arr_size < 0 { arr_size = 0; }
        const elem_type: &ASTNode = type_node.type_array_element_type;
        if elem_type == null { return null; }

        var loop_name_buf: [byte: 80] = [];
        snprintf(&loop_name_buf[0] as *byte, 80, "%s_i" as *byte, safe_name_hint as *byte);
        const loop_var_name: &byte = macro_arena_strdup(arena, &loop_name_buf[0]);
        if loop_var_name == null { return null; }

        var child_hint_buf: [byte: 80] = [];
        snprintf(&child_hint_buf[0] as *byte, 80, "%s_elem" as *byte, safe_name_hint as *byte);
        const child_hint: &byte = macro_arena_strdup(arena, &child_hint_buf[0]);
        if child_hint == null { return null; }

        const cond_left: &ASTNode = create_identifier_from_string(loop_var_name, arena, line, column);
        if cond_left == null { return null; }
        const comma_cond: &ASTNode = ast_new_node(ASTNodeType.AST_BINARY_EXPR, line, column, arena, filename);
        if comma_cond == null { return null; }
        comma_cond.binary_expr_op = (TokenType.TOKEN_GREATER) as i32;
        comma_cond.binary_expr_left = cond_left;
        comma_cond.binary_expr_right = create_number_literal(0, arena, line, column);

        const comma_stmt: &ASTNode = build_json_write_byte_stmt(addr_w, 44, arena, line, column, filename);
        if comma_stmt == null { return null; }
        const if_comma: &ASTNode = ast_new_node(ASTNodeType.AST_IF_STMT, line, column, arena, filename);
        if if_comma == null { return null; }
        if_comma.if_stmt_condition = comma_cond;
        if_comma.if_stmt_then_branch = comma_stmt;
        if_comma.if_stmt_else_branch = null;

        const elem_index: &ASTNode = create_identifier_from_string(loop_var_name, arena, line, column);
        if elem_index == null { return null; }
        const elem_expr: &ASTNode = ast_new_node(ASTNodeType.AST_ARRAY_ACCESS, line, column, arena, filename);
        if elem_expr == null { return null; }
        elem_expr.array_access_array = value_expr;
        elem_expr.array_access_index = elem_index;

        const elem_stmt: &ASTNode = build_json_write_value_stmt(checker, elem_type, elem_expr, addr_w, child_hint, line, column, filename);
        if elem_stmt == null { return null; }

        const loop_body_stmts: &(&ASTNode) = compiler_arena_alloc(arena, (@size_of(&ASTNode) * 2) as u64) as &(&ASTNode);
        if loop_body_stmts == null { return null; }
        loop_body_stmts[0] = if_comma;
        loop_body_stmts[1] = elem_stmt;
        const loop_body: &ASTNode = ast_new_node(ASTNodeType.AST_BLOCK, line, column, arena, filename);
        if loop_body == null { return null; }
        loop_body.block_stmts = loop_body_stmts;
        loop_body.block_stmt_count = 2;

        const range_zero: &ASTNode = create_number_literal(0, arena, line, column);
        if range_zero == null { return null; }
        range_zero.literal_suffix = 9;
        const range_end: &ASTNode = create_number_literal(arr_size as i64, arena, line, column);
        if range_end == null { return null; }
        range_end.literal_suffix = 9;
        const array_for: &ASTNode = ast_new_node(ASTNodeType.AST_FOR_STMT, line, column, arena, filename);
        if array_for == null { return null; }
        array_for.for_stmt_is_range = 1;
        array_for.for_stmt_array = null;
        array_for.for_stmt_range_start = range_zero;
        array_for.for_stmt_range_end = range_end;
        array_for.for_stmt_var_name = loop_var_name;
        array_for.for_stmt_is_ref = 0;
        array_for.for_stmt_body = loop_body;

        const block_stmts: &(&ASTNode) = compiler_arena_alloc(arena, (@size_of(&ASTNode) * 3) as u64) as &(&ASTNode);
        if block_stmts == null { return null; }
        block_stmts[0] = build_json_write_byte_stmt(addr_w, 91, arena, line, column, filename);
        block_stmts[1] = array_for;
        block_stmts[2] = build_json_write_byte_stmt(addr_w, 93, arena, line, column, filename);
        if block_stmts[0] == null || block_stmts[2] == null { return null; }
        const array_block: &ASTNode = ast_new_node(ASTNodeType.AST_BLOCK, line, column, arena, filename);
        if array_block == null { return null; }
        array_block.block_stmts = block_stmts;
        array_block.block_stmt_count = 3;
        return array_block;
    }

    if type_node.type == ASTNodeType.AST_TYPE_SLICE {
        const elem_type: &ASTNode = type_node.type_slice_element_type;
        if elem_type == null { return null; }
        const s_len: &byte = macro_arena_strdup(arena, ("len" as *byte) as &byte);
        const s_ptr: &byte = macro_arena_strdup(arena, ("ptr" as *byte) as &byte);
        if s_len == null || s_ptr == null { return null; }

        var loop_name_buf: [byte: 80] = [];
        snprintf(&loop_name_buf[0] as *byte, 80, "%s_i" as *byte, safe_name_hint as *byte);
        const loop_var_name: &byte = macro_arena_strdup(arena, &loop_name_buf[0]);
        if loop_var_name == null { return null; }

        var child_hint_buf: [byte: 80] = [];
        snprintf(&child_hint_buf[0] as *byte, 80, "%s_elem" as *byte, safe_name_hint as *byte);
        const child_hint: &byte = macro_arena_strdup(arena, &child_hint_buf[0]);
        if child_hint == null { return null; }

        const slice_len: &ASTNode = ast_new_node(ASTNodeType.AST_MEMBER_ACCESS, line, column, arena, filename);
        if slice_len == null { return null; }
        slice_len.member_access_object = value_expr;
        slice_len.member_access_field_name = s_len;
        slice_len.member_access_is_module_access = 0;
        slice_len.member_access_module_name = null;

        const slice_ptr: &ASTNode = ast_new_node(ASTNodeType.AST_MEMBER_ACCESS, line, column, arena, filename);
        if slice_ptr == null { return null; }
        slice_ptr.member_access_object = value_expr;
        slice_ptr.member_access_field_name = s_ptr;
        slice_ptr.member_access_is_module_access = 0;
        slice_ptr.member_access_module_name = null;

        const cond_left: &ASTNode = create_identifier_from_string(loop_var_name, arena, line, column);
        if cond_left == null { return null; }
        const comma_cond: &ASTNode = ast_new_node(ASTNodeType.AST_BINARY_EXPR, line, column, arena, filename);
        if comma_cond == null { return null; }
        comma_cond.binary_expr_op = (TokenType.TOKEN_GREATER) as i32;
        comma_cond.binary_expr_left = cond_left;
        comma_cond.binary_expr_right = create_number_literal(0, arena, line, column);

        const comma_stmt: &ASTNode = build_json_write_byte_stmt(addr_w, 44, arena, line, column, filename);
        if comma_stmt == null { return null; }
        const if_comma: &ASTNode = ast_new_node(ASTNodeType.AST_IF_STMT, line, column, arena, filename);
        if if_comma == null { return null; }
        if_comma.if_stmt_condition = comma_cond;
        if_comma.if_stmt_then_branch = comma_stmt;
        if_comma.if_stmt_else_branch = null;

        const elem_index: &ASTNode = create_identifier_from_string(loop_var_name, arena, line, column);
        if elem_index == null { return null; }
        const elem_expr: &ASTNode = ast_new_node(ASTNodeType.AST_ARRAY_ACCESS, line, column, arena, filename);
        if elem_expr == null { return null; }
        elem_expr.array_access_array = slice_ptr;
        elem_expr.array_access_index = elem_index;

        const elem_stmt: &ASTNode = build_json_write_value_stmt(checker, elem_type, elem_expr, addr_w, child_hint, line, column, filename);
        if elem_stmt == null { return null; }

        const loop_body_stmts: &(&ASTNode) = compiler_arena_alloc(arena, (@size_of(&ASTNode) * 2) as u64) as &(&ASTNode);
        if loop_body_stmts == null { return null; }
        loop_body_stmts[0] = if_comma;
        loop_body_stmts[1] = elem_stmt;
        const loop_body: &ASTNode = ast_new_node(ASTNodeType.AST_BLOCK, line, column, arena, filename);
        if loop_body == null { return null; }
        loop_body.block_stmts = loop_body_stmts;
        loop_body.block_stmt_count = 2;

        const range_zero: &ASTNode = create_number_literal(0, arena, line, column);
        if range_zero == null { return null; }
        range_zero.literal_suffix = 9;
        const slice_for: &ASTNode = ast_new_node(ASTNodeType.AST_FOR_STMT, line, column, arena, filename);
        if slice_for == null { return null; }
        slice_for.for_stmt_is_range = 1;
        slice_for.for_stmt_array = null;
        slice_for.for_stmt_range_start = range_zero;
        slice_for.for_stmt_range_end = slice_len;
        slice_for.for_stmt_var_name = loop_var_name;
        slice_for.for_stmt_is_ref = 0;
        slice_for.for_stmt_body = loop_body;

        const block_stmts: &(&ASTNode) = compiler_arena_alloc(arena, (@size_of(&ASTNode) * 3) as u64) as &(&ASTNode);
        if block_stmts == null { return null; }
        block_stmts[0] = build_json_write_byte_stmt(addr_w, 91, arena, line, column, filename);
        block_stmts[1] = slice_for;
        block_stmts[2] = build_json_write_byte_stmt(addr_w, 93, arena, line, column, filename);
        if block_stmts[0] == null || block_stmts[2] == null { return null; }
        const slice_block: &ASTNode = ast_new_node(ASTNodeType.AST_BLOCK, line, column, arena, filename);
        if slice_block == null { return null; }
        slice_block.block_stmts = block_stmts;
        slice_block.block_stmt_count = 3;
        return slice_block;
    }

    const type_name: &byte = get_type_name_from_ast(type_node, arena);
    if type_name == null { return null; }
    const inner_decl: &ASTNode = find_struct_decl_from_program(checker.program_node, type_name);
    var is_json_str_view: i32 = 0;
    if strcmp(type_name as *byte, "JsonStrView" as *byte) == 0 { is_json_str_view = 1; }
    if inner_decl != null && inner_decl.struct_decl_fields != null && inner_decl.struct_decl_field_count > 0 && is_json_str_view == 0 {
        const stmt_count: i32 = 2 + count_encode_field_stmts(checker, inner_decl);
        const stmts: &(&ASTNode) = compiler_arena_alloc(arena, (@size_of(&ASTNode) * stmt_count) as u64) as &(&ASTNode);
        if stmts == null { return null; }
        var idx: i32 = 0;
        stmts[idx] = build_json_write_byte_stmt(addr_w, 123, arena, line, column, filename);
        if stmts[idx] == null { return null; }
        idx = idx + 1;
        var fi: i32 = 0;
        while fi < inner_decl.struct_decl_field_count {
            const inner_field: &ASTNode = inner_decl.struct_decl_fields[fi];
            if inner_field == null || inner_field.type != ASTNodeType.AST_VAR_DECL || inner_field.var_decl_name == null {
                fi = fi + 1;
                continue;
            }
            const ifname: &byte = inner_field.var_decl_name as &byte;
            if fi > 0 {
                stmts[idx] = build_json_write_byte_stmt(addr_w, 44, arena, line, column, filename);
                if stmts[idx] == null { return null; }
                idx = idx + 1;
            }
            stmts[idx] = build_json_write_key_stmt(addr_w, ifname, arena, line, column, filename);
            if stmts[idx] == null { return null; }
            idx = idx + 1;

            const inner_member: &ASTNode = ast_new_node(ASTNodeType.AST_MEMBER_ACCESS, line, column, arena, filename);
            if inner_member == null { return null; }
            inner_member.member_access_object = value_expr;
            inner_member.member_access_field_name = macro_arena_strdup(arena, ifname);
            inner_member.member_access_is_module_access = 0;
            inner_member.member_access_module_name = null;

            var child_hint_buf: [byte: 120] = [];
            snprintf(&child_hint_buf[0] as *byte, 120, "%s_%s" as *byte, safe_name_hint as *byte, ifname as *byte);
            const child_hint: &byte = macro_arena_strdup(arena, &child_hint_buf[0]);
            if child_hint == null { return null; }

            stmts[idx] = build_json_write_value_stmt(checker, inner_field.var_decl_type, inner_member, addr_w, child_hint, line, column, filename);
            if stmts[idx] == null { return null; }
            idx = idx + 1;
            fi = fi + 1;
        }
        stmts[idx] = build_json_write_byte_stmt(addr_w, 125, arena, line, column, filename);
        if stmts[idx] == null { return null; }
        idx = idx + 1;
        const nested_block: &ASTNode = ast_new_node(ASTNodeType.AST_BLOCK, line, column, arena, filename);
        if nested_block == null { return null; }
        nested_block.block_stmts = stmts;
        nested_block.block_stmt_count = idx;
        return nested_block;
    }

    return build_json_write_scalar_stmt(type_name, value_expr, addr_w, arena, line, column, filename);
}

// 为 encode_to_to_json!(T, value, buf, cap) 按结构体 T 生成编码块 AST（!usize）。
// 要求：type_arg 为 AST_TYPE_NAMED，T 为程序中的结构体名。
fn build_encode_to_to_json_block(checker: &TypeChecker, type_arg: &ASTNode, value_arg: &ASTNode, buf_arg: &ASTNode, cap_arg: &ASTNode, line: i32, column: i32, filename: &byte) &ASTNode {
    if checker == null || type_arg == null || type_arg.type != ASTNodeType.AST_TYPE_NAMED || type_arg.type_named_name == null ||
       value_arg == null || buf_arg == null || cap_arg == null || checker.arena == null {
        return null;
    }
    const arena: &CompilerArena = checker.arena;
    const type_name: &byte = type_arg.type_named_name as &byte;
    const struct_decl: &ASTNode = find_struct_decl_from_program(checker.program_node, type_name);
    if struct_decl == null || struct_decl.struct_decl_fields == null || struct_decl.struct_decl_field_count <= 0 {
        return null;
    }
    const n_fields: i32 = struct_decl.struct_decl_field_count;
    const line_off: i32 = 0;
    const col_off: i32 = 0;

    const s_w: &byte = macro_arena_strdup(arena, ("w" as *byte) as &byte);
    const s_buf: &byte = macro_arena_strdup(arena, ("buf" as *byte) as &byte);
    const s_cap: &byte = macro_arena_strdup(arena, ("cap" as *byte) as &byte);
    const s_JsonWriter: &byte = macro_arena_strdup(arena, ("JsonWriter" as *byte) as &byte);
    const s_json_writer_init: &byte = macro_arena_strdup(arena, ("json_writer_init" as *byte) as &byte);
    const s_overflow: &byte = macro_arena_strdup(arena, ("overflow" as *byte) as &byte);
    const s_used: &byte = macro_arena_strdup(arena, ("used" as *byte) as &byte);
    const s_BufferTooSmall: &byte = macro_arena_strdup(arena, ("BufferTooSmall" as *byte) as &byte);
    if s_w == null || s_JsonWriter == null || s_json_writer_init == null || s_overflow == null || s_used == null || s_BufferTooSmall == null {
        return null;
    }

    const id_w: &ASTNode = create_identifier_from_string(s_w, arena, line + line_off, column + col_off);
    if id_w == null { return null; }

    const unary_addr_tmp: !i32 = (TokenType.TOKEN_AMPERSAND) as! i32;
    const unary_addr: i32 = unary_addr_tmp.value;
    const addr_w: &ASTNode = ast_new_node(ASTNodeType.AST_UNARY_EXPR, line + line_off, column + col_off, arena, filename);
    if addr_w == null { return null; }
    addr_w.unary_expr_op = unary_addr;
    addr_w.unary_expr_operand = id_w;

    const json_writer_init_args: &(&ASTNode) = compiler_arena_alloc(arena, (3 * 8) as u64) as &(&ASTNode);
    if json_writer_init_args == null { return null; }
    json_writer_init_args[0] = addr_w;
    json_writer_init_args[1] = buf_arg;
    json_writer_init_args[2] = cap_arg;
    const call_init: &ASTNode = ast_new_node(ASTNodeType.AST_CALL_EXPR, line + line_off, column + col_off, arena, filename);
    if call_init == null { return null; }
    call_init.call_expr_callee = create_identifier_from_string(s_json_writer_init, arena, line + line_off, column + col_off);
    call_init.call_expr_args = json_writer_init_args;
    call_init.call_expr_arg_count = 3;
    call_init.call_expr_has_ellipsis_forward = 0;
    call_init.call_expr_type_args = null;
    call_init.call_expr_type_arg_count = 0;

    const fn_names_json: &(&byte) = compiler_arena_alloc(arena, (4 * 8) as u64) as &(&byte);
    const fn_vals_json: &(&ASTNode) = compiler_arena_alloc(arena, (4 * 8) as u64) as &(&ASTNode);
    if fn_names_json == null || fn_vals_json == null { return null; }
    fn_names_json[0] = s_buf;
    fn_vals_json[0] = buf_arg;
    fn_names_json[1] = s_cap;
    fn_vals_json[1] = cap_arg;
    fn_names_json[2] = s_used;
    fn_vals_json[2] = create_number_literal(0, arena, line + line_off, column + col_off);
    fn_names_json[3] = s_overflow;
    fn_vals_json[3] = create_bool_literal(0, arena, line + line_off, column + col_off);
    const struct_init_w: &ASTNode = ast_new_node(ASTNodeType.AST_STRUCT_INIT, line + line_off, column + col_off, arena, filename);
    if struct_init_w == null { return null; }
    struct_init_w.struct_init_struct_name = s_JsonWriter;
    struct_init_w.struct_init_field_names = fn_names_json;
    struct_init_w.struct_init_field_values = fn_vals_json;
    struct_init_w.struct_init_field_count = 4;
    struct_init_w.struct_init_type_args = null;
    struct_init_w.struct_init_type_arg_count = 0;

    const type_json_writer: &ASTNode = create_type_named_from_string(s_JsonWriter, arena, line + line_off, column + col_off);
    if type_json_writer == null { return null; }
    const var_w: &ASTNode = ast_new_node(ASTNodeType.AST_VAR_DECL, line + line_off, column + col_off, arena, filename);
    if var_w == null { return null; }
    var_w.var_decl_name = s_w;
    var_w.var_decl_type = type_json_writer;
    var_w.var_decl_init = struct_init_w;
    var_w.var_decl_is_const = 0;

    const open_brace: &ASTNode = build_json_write_byte_stmt(addr_w, 123, arena, line + line_off, column + col_off, filename);
    if open_brace == null { return null; }
    const close_brace: &ASTNode = build_json_write_byte_stmt(addr_w, 125, arena, line + line_off, column + col_off, filename);
    if close_brace == null { return null; }

    const value_deref: &ASTNode = ast_new_node(ASTNodeType.AST_ARRAY_ACCESS, line + line_off, column + col_off, arena, filename);
    if value_deref == null { return null; }
    value_deref.array_access_array = value_arg;
    value_deref.array_access_index = create_number_literal(0, arena, line + line_off, column + col_off);

    const field_stmts: i32 = count_encode_field_stmts(checker, struct_decl);
    const stmt_count: i32 = 5 + field_stmts;
    const stmts: &(&ASTNode) = compiler_arena_alloc(arena, (@size_of(&ASTNode) * stmt_count) as u64) as &(&ASTNode);
    if stmts == null { return null; }
    var idx: i32 = 0;
    stmts[idx] = var_w;
    idx = idx + 1;
    stmts[idx] = call_init;
    idx = idx + 1;
    stmts[idx] = open_brace;
    idx = idx + 1;

    var fi: i32 = 0;
    while fi < n_fields {
        const field_node: &ASTNode = struct_decl.struct_decl_fields[fi];
        if field_node == null || field_node.type != ASTNodeType.AST_VAR_DECL || field_node.var_decl_name == null {
            fi = fi + 1;
            continue;
        }
        if fi > 0 {
            stmts[idx] = build_json_write_byte_stmt(addr_w, 44, arena, line + line_off, column + col_off, filename);
            if stmts[idx] == null { fi = fi + 1; continue; }
            idx = idx + 1;
        }
        const fname: &byte = field_node.var_decl_name as &byte;
        stmts[idx] = build_json_write_key_stmt(addr_w, fname, arena, line + line_off, column + col_off, filename);
        if stmts[idx] == null { fi = fi + 1; continue; }
        idx = idx + 1;

        const member_acc: &ASTNode = ast_new_node(ASTNodeType.AST_MEMBER_ACCESS, line + line_off, column + col_off, arena, filename);
        if member_acc == null { fi = fi + 1; continue; }
        member_acc.member_access_object = value_deref;
        member_acc.member_access_field_name = macro_arena_strdup(arena, fname);
        member_acc.member_access_is_module_access = 0;
        member_acc.member_access_module_name = null;

        stmts[idx] = build_json_write_value_stmt(checker, field_node.var_decl_type, member_acc, addr_w, fname, line + line_off, column + col_off, filename);
        if stmts[idx] == null { fi = fi + 1; continue; }
        idx = idx + 1;
        fi = fi + 1;
    }

    stmts[idx] = close_brace;
    idx = idx + 1;

    const cond_overflow: &ASTNode = ast_new_node(ASTNodeType.AST_MEMBER_ACCESS, line + line_off, column + col_off, arena, filename);
    if cond_overflow == null { return null; }
    cond_overflow.member_access_object = id_w;
    cond_overflow.member_access_field_name = s_overflow;
    cond_overflow.member_access_is_module_access = 0;
    cond_overflow.member_access_module_name = null;
    const err_val: &ASTNode = ast_new_node(ASTNodeType.AST_ERROR_VALUE, line + line_off, column + col_off, arena, filename);
    if err_val == null { return null; }
    err_val.error_value_name = s_BufferTooSmall;
    const expr_used: &ASTNode = ast_new_node(ASTNodeType.AST_MEMBER_ACCESS, line + line_off, column + col_off, arena, filename);
    if expr_used == null { return null; }
    expr_used.member_access_object = id_w;
    expr_used.member_access_field_name = s_used;
    expr_used.member_access_is_module_access = 0;
    expr_used.member_access_module_name = null;
    const if_expr: &ASTNode = ast_new_node(ASTNodeType.AST_IF_STMT, line + line_off, column + col_off, arena, filename);
    if if_expr == null { return null; }
    if_expr.if_stmt_condition = cond_overflow;
    if_expr.if_stmt_then_branch = err_val;
    if_expr.if_stmt_else_branch = expr_used;
    stmts[idx] = if_expr;
    idx = idx + 1;

    const block: &ASTNode = ast_new_node(ASTNodeType.AST_BLOCK, line, column, arena, filename);
    if block == null { return null; }
    block.block_stmts = stmts;
    block.block_stmt_count = idx;
    return block;
}

fn build_decode_json_value_expr(checker: &TypeChecker, type_node: &ASTNode, value_expr: &ASTNode, name_hint: &byte, line: i32, column: i32, filename: &byte) &ASTNode {
    if checker == null || checker.arena == null || type_node == null || value_expr == null {
        return null;
    }
    const arena: &CompilerArena = checker.arena;
    const unary_amp_tmp: !i32 = (TokenType.TOKEN_AMPERSAND) as! i32;
    const unary_amp: i32 = unary_amp_tmp.value;
    var safe_name_hint: &byte = name_hint;
    if safe_name_hint == null {
        safe_name_hint = ("value" as *byte) as &byte;
    }

    const s_json_expect_i64: &byte = macro_arena_strdup(arena, ("json_expect_i64" as *byte) as &byte);
    const s_json_expect_str: &byte = macro_arena_strdup(arena, ("json_expect_str" as *byte) as &byte);
    const s_json_expect_bool: &byte = macro_arena_strdup(arena, ("json_expect_bool" as *byte) as &byte);
    const s_json_expect_f64: &byte = macro_arena_strdup(arena, ("json_expect_f64" as *byte) as &byte);
    const s_arena_alloc: &byte = macro_arena_strdup(arena, ("arena_alloc" as *byte) as &byte);
    const s_ar: &byte = macro_arena_strdup(arena, ("ar" as *byte) as &byte);
    const s_items: &byte = macro_arena_strdup(arena, ("items" as *byte) as &byte);
    const s_len: &byte = macro_arena_strdup(arena, ("len" as *byte) as &byte);
    const s_usize: &byte = macro_arena_strdup(arena, ("usize" as *byte) as &byte);
    const s_WrongType: &byte = macro_arena_strdup(arena, ("WrongType" as *byte) as &byte);
    const s_obj: &byte = macro_arena_strdup(arena, ("obj" as *byte) as &byte);
    const s_arr: &byte = macro_arena_strdup(arena, ("arr" as *byte) as &byte);
    if s_json_expect_i64 == null || s_json_expect_str == null || s_json_expect_bool == null || s_json_expect_f64 == null ||
       s_items == null || s_len == null || s_usize == null || s_WrongType == null || s_obj == null || s_arr == null {
        return null;
    }

    if type_node.type == ASTNodeType.AST_TYPE_ARRAY {
        var arr_size: i32 = 0;
        if type_node.type_array_size_expr != null {
            arr_size = checker_eval_const_expr(checker, type_node.type_array_size_expr);
        }
        if arr_size < 0 { arr_size = 0; }
        const elem_type: &ASTNode = type_node.type_array_element_type;
        if elem_type == null { return null; }

        var name_buf: [byte: 120] = [];
        snprintf(&name_buf[0] as *byte, 120, "%s_arr_json" as *byte, safe_name_hint as *byte);
        const arr_match_name: &byte = macro_arena_strdup(arena, &name_buf[0]);
        if arr_match_name == null { return null; }
        snprintf(&name_buf[0] as *byte, 120, "%s_arr_tmp" as *byte, safe_name_hint as *byte);
        const arr_var_name: &byte = macro_arena_strdup(arena, &name_buf[0]);
        if arr_var_name == null { return null; }
        snprintf(&name_buf[0] as *byte, 120, "%s_i" as *byte, safe_name_hint as *byte);
        const loop_var_name: &byte = macro_arena_strdup(arena, &name_buf[0]);
        if loop_var_name == null { return null; }
        snprintf(&name_buf[0] as *byte, 120, "%s_elem" as *byte, safe_name_hint as *byte);
        const child_hint: &byte = macro_arena_strdup(arena, &name_buf[0]);
        if child_hint == null { return null; }

        const id_a: &ASTNode = create_identifier_from_string(arr_match_name, arena, line, column);
        if id_a == null { return null; }
        const a_len: &ASTNode = ast_new_node(ASTNodeType.AST_MEMBER_ACCESS, line, column, arena, filename);
        if a_len == null { return null; }
        a_len.member_access_object = id_a;
        a_len.member_access_field_name = s_len;
        a_len.member_access_is_module_access = 0;
        a_len.member_access_module_name = null;
        const len_cmp: &ASTNode = create_number_literal(arr_size as i64, arena, line, column);
        if len_cmp == null { return null; }
        const bin_neq: &ASTNode = ast_new_node(ASTNodeType.AST_BINARY_EXPR, line, column, arena, filename);
        if bin_neq == null { return null; }
        bin_neq.binary_expr_op = (TokenType.TOKEN_NOT_EQUAL) as i32;
        bin_neq.binary_expr_left = a_len;
        bin_neq.binary_expr_right = len_cmp;
        const err_wrong: &ASTNode = ast_new_node(ASTNodeType.AST_ERROR_VALUE, line, column, arena, filename);
        if err_wrong == null { return null; }
        err_wrong.error_value_name = s_WrongType;
        const return_err: &ASTNode = ast_new_node(ASTNodeType.AST_RETURN_STMT, line, column, arena, filename);
        if return_err == null { return null; }
        return_err.return_stmt_expr = err_wrong;
        const if_stmt: &ASTNode = ast_new_node(ASTNodeType.AST_IF_STMT, line, column, arena, filename);
        if if_stmt == null { return null; }
        if_stmt.if_stmt_condition = bin_neq;
        if_stmt.if_stmt_then_branch = return_err;
        if_stmt.if_stmt_else_branch = null;

        const empty_init: &ASTNode = ast_new_node(ASTNodeType.AST_ARRAY_LITERAL, line, column, arena, filename);
        if empty_init == null { return null; }
        empty_init.array_literal_element_count = 0;
        empty_init.array_literal_elements = null;
        const var_arr: &ASTNode = ast_new_node(ASTNodeType.AST_VAR_DECL, line, column, arena, filename);
        if var_arr == null { return null; }
        var_arr.var_decl_name = arr_var_name;
        var_arr.var_decl_type = type_node;
        var_arr.var_decl_init = empty_init;
        var_arr.var_decl_is_const = 0;

        const a_items: &ASTNode = ast_new_node(ASTNodeType.AST_MEMBER_ACCESS, line, column, arena, filename);
        if a_items == null { return null; }
        a_items.member_access_object = create_identifier_from_string(arr_match_name, arena, line, column);
        a_items.member_access_field_name = s_items;
        a_items.member_access_is_module_access = 0;
        a_items.member_access_module_name = null;
        const items_i: &ASTNode = ast_new_node(ASTNodeType.AST_ARRAY_ACCESS, line, column, arena, filename);
        if items_i == null { return null; }
        items_i.array_access_array = a_items;
        items_i.array_access_index = create_identifier_from_string(loop_var_name, arena, line, column);
        if items_i.array_access_index == null { return null; }
        const elem_decode: &ASTNode = build_decode_json_value_expr(checker, elem_type, items_i, child_hint, line, column, filename);
        if elem_decode == null { return null; }
        const arr_access: &ASTNode = ast_new_node(ASTNodeType.AST_ARRAY_ACCESS, line, column, arena, filename);
        if arr_access == null { return null; }
        arr_access.array_access_array = create_identifier_from_string(arr_var_name, arena, line, column);
        arr_access.array_access_index = create_identifier_from_string(loop_var_name, arena, line, column);
        if arr_access.array_access_array == null || arr_access.array_access_index == null { return null; }
        const assign_elem: &ASTNode = ast_new_node(ASTNodeType.AST_ASSIGN, line, column, arena, filename);
        if assign_elem == null { return null; }
        assign_elem.assign_dest = arr_access;
        assign_elem.assign_src = elem_decode;
        const loop_body_stmts: &(&ASTNode) = compiler_arena_alloc(arena, (@size_of(&ASTNode) * 1) as u64) as &(&ASTNode);
        if loop_body_stmts == null { return null; }
        loop_body_stmts[0] = assign_elem;
        const loop_body: &ASTNode = ast_new_node(ASTNodeType.AST_BLOCK, line, column, arena, filename);
        if loop_body == null { return null; }
        loop_body.block_stmts = loop_body_stmts;
        loop_body.block_stmt_count = 1;

        const range_zero: &ASTNode = create_number_literal(0, arena, line, column);
        if range_zero == null { return null; }
        range_zero.literal_suffix = 9;
        const range_end: &ASTNode = create_number_literal(arr_size as i64, arena, line, column);
        if range_end == null { return null; }
        range_end.literal_suffix = 9;
        const arr_for: &ASTNode = ast_new_node(ASTNodeType.AST_FOR_STMT, line, column, arena, filename);
        if arr_for == null { return null; }
        arr_for.for_stmt_is_range = 1;
        arr_for.for_stmt_array = null;
        arr_for.for_stmt_range_start = range_zero;
        arr_for.for_stmt_range_end = range_end;
        arr_for.for_stmt_var_name = loop_var_name;
        arr_for.for_stmt_is_ref = 0;
        arr_for.for_stmt_body = loop_body;

        const arr_stmts: &(&ASTNode) = compiler_arena_alloc(arena, (@size_of(&ASTNode) * 4) as u64) as &(&ASTNode);
        if arr_stmts == null { return null; }
        arr_stmts[0] = if_stmt;
        arr_stmts[1] = var_arr;
        arr_stmts[2] = arr_for;
        arr_stmts[3] = create_identifier_from_string(arr_var_name, arena, line, column);
        if arr_stmts[3] == null { return null; }
        const arr_block: &ASTNode = ast_new_node(ASTNodeType.AST_BLOCK, line, column, arena, filename);
        if arr_block == null { return null; }
        arr_block.block_stmts = arr_stmts;
        arr_block.block_stmt_count = 4;

        const arms_arr: &ASTMatchArm = compiler_arena_alloc(arena, (2 * @size_of(ASTMatchArm)) as u64) as &ASTMatchArm;
        if arms_arr == null { return null; }
        arms_arr[0].kind = MatchPatternKind.MATCH_PAT_UNION;
        arms_arr[0].variant_name = s_arr;
        arms_arr[0].var_name = arr_match_name;
        arms_arr[0].result_expr = arr_block;
        arms_arr[0].result_is_block = 1;
        arms_arr[1].kind = MatchPatternKind.MATCH_PAT_ELSE;
        const err_arr: &ASTNode = ast_new_node(ASTNodeType.AST_ERROR_VALUE, line, column, arena, filename);
        if err_arr == null { return null; }
        err_arr.error_value_name = s_WrongType;
        arms_arr[1].result_expr = err_arr;
        const match_arr: &ASTNode = ast_new_node(ASTNodeType.AST_MATCH_EXPR, line, column, arena, filename);
        if match_arr == null { return null; }
        match_arr.match_expr_expr = value_expr;
        match_arr.match_expr_arms = arms_arr;
        match_arr.match_expr_arm_count = 2;
        const try_arr: &ASTNode = ast_new_node(ASTNodeType.AST_TRY_EXPR, line, column, arena, filename);
        if try_arr == null { return null; }
        try_arr.try_expr_operand = match_arr;
        return try_arr;
    }

    if type_node.type == ASTNodeType.AST_TYPE_SLICE {
        const elem_type: &ASTNode = type_node.type_slice_element_type;
        if elem_type == null || s_arena_alloc == null || s_ar == null { return null; }

        var name_buf: [byte: 120] = [];
        snprintf(&name_buf[0] as *byte, 120, "%s_arr_json" as *byte, safe_name_hint as *byte);
        const arr_match_name: &byte = macro_arena_strdup(arena, &name_buf[0]);
        if arr_match_name == null { return null; }
        snprintf(&name_buf[0] as *byte, 120, "%s_ptr" as *byte, safe_name_hint as *byte);
        const ptr_var_name: &byte = macro_arena_strdup(arena, &name_buf[0]);
        if ptr_var_name == null { return null; }
        snprintf(&name_buf[0] as *byte, 120, "%s_slice" as *byte, safe_name_hint as *byte);
        const slice_var_name: &byte = macro_arena_strdup(arena, &name_buf[0]);
        if slice_var_name == null { return null; }
        snprintf(&name_buf[0] as *byte, 120, "%s_i" as *byte, safe_name_hint as *byte);
        const loop_var_name: &byte = macro_arena_strdup(arena, &name_buf[0]);
        if loop_var_name == null { return null; }
        snprintf(&name_buf[0] as *byte, 120, "%s_elem" as *byte, safe_name_hint as *byte);
        const child_hint: &byte = macro_arena_strdup(arena, &name_buf[0]);
        if child_hint == null { return null; }

        const a_len: &ASTNode = ast_new_node(ASTNodeType.AST_MEMBER_ACCESS, line, column, arena, filename);
        if a_len == null { return null; }
        a_len.member_access_object = create_identifier_from_string(arr_match_name, arena, line, column);
        a_len.member_access_field_name = s_len;
        a_len.member_access_is_module_access = 0;
        a_len.member_access_module_name = null;
        if a_len.member_access_object == null { return null; }

        const sizeof_target: &ASTNode = deep_copy_ast_substitute_type_params(elem_type, null, 0, null, 0, arena, filename);
        if sizeof_target == null { return null; }
        const sizeof_expr: &ASTNode = ast_new_node(ASTNodeType.AST_SIZEOF, line, column, arena, filename);
        if sizeof_expr == null { return null; }
        sizeof_expr.sizeof_expr_target = sizeof_target;
        sizeof_expr.sizeof_expr_is_type = 1;
        const type_usize_size: &ASTNode = create_type_named_from_string(s_usize, arena, line, column);
        if type_usize_size == null { return null; }
        const sizeof_as_usize: &ASTNode = ast_new_node(ASTNodeType.AST_CAST_EXPR, line, column, arena, filename);
        if sizeof_as_usize == null { return null; }
        sizeof_as_usize.cast_expr_expr = sizeof_expr;
        sizeof_as_usize.cast_expr_target_type = type_usize_size;
        sizeof_as_usize.cast_expr_is_force_cast = 0;
        const bytes_expr: &ASTNode = ast_new_node(ASTNodeType.AST_BINARY_EXPR, line, column, arena, filename);
        if bytes_expr == null { return null; }
        bytes_expr.binary_expr_op = (TokenType.TOKEN_ASTERISK) as i32;
        bytes_expr.binary_expr_left = a_len;
        bytes_expr.binary_expr_right = sizeof_as_usize;

        const alloc_args: &(&ASTNode) = compiler_arena_alloc(arena, (2 * 8) as u64) as &(&ASTNode);
        if alloc_args == null { return null; }
        alloc_args[0] = create_identifier_from_string(s_ar, arena, line, column);
        alloc_args[1] = bytes_expr;
        if alloc_args[0] == null { return null; }
        const call_alloc: &ASTNode = ast_new_node(ASTNodeType.AST_CALL_EXPR, line, column, arena, filename);
        if call_alloc == null { return null; }
        call_alloc.call_expr_callee = create_identifier_from_string(s_arena_alloc, arena, line, column);
        call_alloc.call_expr_args = alloc_args;
        call_alloc.call_expr_arg_count = 2;
        call_alloc.call_expr_has_ellipsis_forward = 0;
        call_alloc.call_expr_type_args = null;
        call_alloc.call_expr_type_arg_count = 0;

        const ptr_elem_type: &ASTNode = deep_copy_ast_substitute_type_params(elem_type, null, 0, null, 0, arena, filename);
        if ptr_elem_type == null { return null; }
        const ptr_type: &ASTNode = ast_new_node(ASTNodeType.AST_TYPE_POINTER, line, column, arena, filename);
        if ptr_type == null { return null; }
        ptr_type.type_pointer_is_ffi_pointer = 0;
        ptr_type.type_pointer_pointed_type = ptr_elem_type;
        const alloc_cast: &ASTNode = ast_new_node(ASTNodeType.AST_CAST_EXPR, line, column, arena, filename);
        if alloc_cast == null { return null; }
        alloc_cast.cast_expr_expr = call_alloc;
        alloc_cast.cast_expr_target_type = ptr_type;
        alloc_cast.cast_expr_is_force_cast = 0;
        const var_ptr: &ASTNode = ast_new_node(ASTNodeType.AST_VAR_DECL, line, column, arena, filename);
        if var_ptr == null { return null; }
        var_ptr.var_decl_name = ptr_var_name;
        var_ptr.var_decl_type = ptr_type;
        var_ptr.var_decl_init = alloc_cast;
        var_ptr.var_decl_is_const = 1;

        const a_items: &ASTNode = ast_new_node(ASTNodeType.AST_MEMBER_ACCESS, line, column, arena, filename);
        if a_items == null { return null; }
        a_items.member_access_object = create_identifier_from_string(arr_match_name, arena, line, column);
        a_items.member_access_field_name = s_items;
        a_items.member_access_is_module_access = 0;
        a_items.member_access_module_name = null;
        if a_items.member_access_object == null { return null; }
        const items_i: &ASTNode = ast_new_node(ASTNodeType.AST_ARRAY_ACCESS, line, column, arena, filename);
        if items_i == null { return null; }
        items_i.array_access_array = a_items;
        items_i.array_access_index = create_identifier_from_string(loop_var_name, arena, line, column);
        if items_i.array_access_index == null { return null; }
        const elem_decode: &ASTNode = build_decode_json_value_expr(checker, elem_type, items_i, child_hint, line, column, filename);
        if elem_decode == null { return null; }
        const ptr_i: &ASTNode = ast_new_node(ASTNodeType.AST_ARRAY_ACCESS, line, column, arena, filename);
        if ptr_i == null { return null; }
        ptr_i.array_access_array = create_identifier_from_string(ptr_var_name, arena, line, column);
        ptr_i.array_access_index = create_identifier_from_string(loop_var_name, arena, line, column);
        if ptr_i.array_access_array == null || ptr_i.array_access_index == null { return null; }
        const assign_elem: &ASTNode = ast_new_node(ASTNodeType.AST_ASSIGN, line, column, arena, filename);
        if assign_elem == null { return null; }
        assign_elem.assign_dest = ptr_i;
        assign_elem.assign_src = elem_decode;
        const loop_body_stmts: &(&ASTNode) = compiler_arena_alloc(arena, (@size_of(&ASTNode) * 1) as u64) as &(&ASTNode);
        if loop_body_stmts == null { return null; }
        loop_body_stmts[0] = assign_elem;
        const loop_body: &ASTNode = ast_new_node(ASTNodeType.AST_BLOCK, line, column, arena, filename);
        if loop_body == null { return null; }
        loop_body.block_stmts = loop_body_stmts;
        loop_body.block_stmt_count = 1;

        const range_zero: &ASTNode = create_number_literal(0, arena, line, column);
        if range_zero == null { return null; }
        range_zero.literal_suffix = 9;
        const a_len_for: &ASTNode = ast_new_node(ASTNodeType.AST_MEMBER_ACCESS, line, column, arena, filename);
        if a_len_for == null { return null; }
        a_len_for.member_access_object = create_identifier_from_string(arr_match_name, arena, line, column);
        a_len_for.member_access_field_name = s_len;
        a_len_for.member_access_is_module_access = 0;
        a_len_for.member_access_module_name = null;
        if a_len_for.member_access_object == null { return null; }
        const slice_for: &ASTNode = ast_new_node(ASTNodeType.AST_FOR_STMT, line, column, arena, filename);
        if slice_for == null { return null; }
        slice_for.for_stmt_is_range = 1;
        slice_for.for_stmt_array = null;
        slice_for.for_stmt_range_start = range_zero;
        slice_for.for_stmt_range_end = a_len_for;
        slice_for.for_stmt_var_name = loop_var_name;
        slice_for.for_stmt_is_ref = 0;
        slice_for.for_stmt_body = loop_body;

        const slice_start_zero: &ASTNode = create_number_literal(0, arena, line, column);
        if slice_start_zero == null { return null; }
        slice_start_zero.literal_suffix = 9;
        const a_len_slice: &ASTNode = ast_new_node(ASTNodeType.AST_MEMBER_ACCESS, line, column, arena, filename);
        if a_len_slice == null { return null; }
        a_len_slice.member_access_object = create_identifier_from_string(arr_match_name, arena, line, column);
        a_len_slice.member_access_field_name = s_len;
        a_len_slice.member_access_is_module_access = 0;
        a_len_slice.member_access_module_name = null;
        if a_len_slice.member_access_object == null { return null; }
        const slice_expr: &ASTNode = ast_new_node(ASTNodeType.AST_SLICE_EXPR, line, column, arena, filename);
        if slice_expr == null { return null; }
        slice_expr.slice_expr_base = create_identifier_from_string(ptr_var_name, arena, line, column);
        slice_expr.slice_expr_start_expr = slice_start_zero;
        slice_expr.slice_expr_len_expr = a_len_slice;
        if slice_expr.slice_expr_base == null { return null; }
        const addr_slice_expr: &ASTNode = ast_new_node(ASTNodeType.AST_UNARY_EXPR, line, column, arena, filename);
        if addr_slice_expr == null { return null; }
        addr_slice_expr.unary_expr_op = unary_amp;
        addr_slice_expr.unary_expr_operand = slice_expr;
        const var_slice: &ASTNode = ast_new_node(ASTNodeType.AST_VAR_DECL, line, column, arena, filename);
        if var_slice == null { return null; }
        var_slice.var_decl_name = slice_var_name;
        var_slice.var_decl_type = type_node;
        var_slice.var_decl_init = addr_slice_expr;
        var_slice.var_decl_is_const = 1;

        const slice_stmts: &(&ASTNode) = compiler_arena_alloc(arena, (@size_of(&ASTNode) * 4) as u64) as &(&ASTNode);
        if slice_stmts == null { return null; }
        slice_stmts[0] = var_ptr;
        slice_stmts[1] = slice_for;
        slice_stmts[2] = var_slice;
        slice_stmts[3] = create_identifier_from_string(slice_var_name, arena, line, column);
        if slice_stmts[3] == null { return null; }
        const slice_block: &ASTNode = ast_new_node(ASTNodeType.AST_BLOCK, line, column, arena, filename);
        if slice_block == null { return null; }
        slice_block.block_stmts = slice_stmts;
        slice_block.block_stmt_count = 4;

        const arms_slice: &ASTMatchArm = compiler_arena_alloc(arena, (2 * @size_of(ASTMatchArm)) as u64) as &ASTMatchArm;
        if arms_slice == null { return null; }
        arms_slice[0].kind = MatchPatternKind.MATCH_PAT_UNION;
        arms_slice[0].variant_name = s_arr;
        arms_slice[0].var_name = arr_match_name;
        arms_slice[0].result_expr = slice_block;
        arms_slice[0].result_is_block = 1;
        arms_slice[1].kind = MatchPatternKind.MATCH_PAT_ELSE;
        const err_slice: &ASTNode = ast_new_node(ASTNodeType.AST_ERROR_VALUE, line, column, arena, filename);
        if err_slice == null { return null; }
        err_slice.error_value_name = s_WrongType;
        arms_slice[1].result_expr = err_slice;
        const match_slice: &ASTNode = ast_new_node(ASTNodeType.AST_MATCH_EXPR, line, column, arena, filename);
        if match_slice == null { return null; }
        match_slice.match_expr_expr = value_expr;
        match_slice.match_expr_arms = arms_slice;
        match_slice.match_expr_arm_count = 2;
        const try_slice: &ASTNode = ast_new_node(ASTNodeType.AST_TRY_EXPR, line, column, arena, filename);
        if try_slice == null { return null; }
        try_slice.try_expr_operand = match_slice;
        return try_slice;
    }

    const type_name: &byte = get_type_name_from_ast(type_node, arena);
    if type_name == null { return null; }
    const inner_decl: &ASTNode = find_struct_decl_from_program(checker.program_node, type_name);
    var is_json_str_view: i32 = 0;
    if strcmp(type_name as *byte, "JsonStrView" as *byte) == 0 { is_json_str_view = 1; }
    if inner_decl != null && inner_decl.struct_decl_fields != null && inner_decl.struct_decl_field_count > 0 && is_json_str_view == 0 {
        var obj_name_buf: [byte: 120] = [];
        snprintf(&obj_name_buf[0] as *byte, 120, "o_%s" as *byte, safe_name_hint as *byte);
        const o_inner_name: &byte = macro_arena_strdup(arena, &obj_name_buf[0]);
        if o_inner_name == null { return null; }
        const nested_block: &ASTNode = build_decode_struct_expr(checker, inner_decl, type_name, o_inner_name, line, column, filename);
        if nested_block == null { return null; }
        const arms_nested: &ASTMatchArm = compiler_arena_alloc(arena, (2 * @size_of(ASTMatchArm)) as u64) as &ASTMatchArm;
        if arms_nested == null { return null; }
        arms_nested[0].kind = MatchPatternKind.MATCH_PAT_UNION;
        arms_nested[0].variant_name = s_obj;
        arms_nested[0].var_name = o_inner_name;
        arms_nested[0].result_expr = nested_block;
        arms_nested[0].result_is_block = 1;
        arms_nested[1].kind = MatchPatternKind.MATCH_PAT_ELSE;
        const err_nested: &ASTNode = ast_new_node(ASTNodeType.AST_ERROR_VALUE, line, column, arena, filename);
        if err_nested == null { return null; }
        err_nested.error_value_name = s_WrongType;
        arms_nested[1].result_expr = err_nested;
        const match_nested: &ASTNode = ast_new_node(ASTNodeType.AST_MATCH_EXPR, line, column, arena, filename);
        if match_nested == null { return null; }
        match_nested.match_expr_expr = value_expr;
        match_nested.match_expr_arms = arms_nested;
        match_nested.match_expr_arm_count = 2;
        const try_nested: &ASTNode = ast_new_node(ASTNodeType.AST_TRY_EXPR, line, column, arena, filename);
        if try_nested == null { return null; }
        try_nested.try_expr_operand = match_nested;
        return try_nested;
    }

    const addr_value: &ASTNode = ast_new_node(ASTNodeType.AST_UNARY_EXPR, line, column, arena, filename);
    if addr_value == null { return null; }
    addr_value.unary_expr_operand = value_expr;
    addr_value.unary_expr_op = unary_amp;
    var expect_callee: &byte = s_json_expect_i64;
    if strcmp(type_name as *byte, "JsonStrView" as *byte) == 0 { expect_callee = s_json_expect_str; }
    else if strcmp(type_name as *byte, "bool" as *byte) == 0 { expect_callee = s_json_expect_bool; }
    else if strcmp(type_name as *byte, "f64" as *byte) == 0 { expect_callee = s_json_expect_f64; }
    const expect_args: &(&ASTNode) = compiler_arena_alloc(arena, (1 * 8) as u64) as &(&ASTNode);
    if expect_args == null { return null; }
    expect_args[0] = addr_value;
    const call_expect: &ASTNode = ast_new_node(ASTNodeType.AST_CALL_EXPR, line, column, arena, filename);
    if call_expect == null { return null; }
    call_expect.call_expr_callee = create_identifier_from_string(expect_callee, arena, line, column);
    call_expect.call_expr_args = expect_args;
    call_expect.call_expr_arg_count = 1;
    call_expect.call_expr_has_ellipsis_forward = 0;
    call_expect.call_expr_type_args = null;
    call_expect.call_expr_type_arg_count = 0;
    const try_expect: &ASTNode = ast_new_node(ASTNodeType.AST_TRY_EXPR, line, column, arena, filename);
    if try_expect == null { return null; }
    try_expect.try_expr_operand = call_expect;
    return try_expect;
}

// 从 JsonObject 变量（obj_var_name，如 "o"）解码出结构体，返回块表达式（语句 + 末尾 struct init）。
// 支持标量、嵌套结构体、定长数组 [T: N]（元素为 i64/f64/bool/JsonStrView）。
fn build_decode_struct_expr(checker: &TypeChecker, struct_decl: &ASTNode, type_name: &byte, obj_var_name: &byte, line: i32, column: i32, filename: &byte) &ASTNode {
    if checker == null || struct_decl == null || struct_decl.struct_decl_fields == null || struct_decl.struct_decl_field_count <= 0 || checker.arena == null {
        return null;
    }
    const arena: &CompilerArena = checker.arena;
    const line_off: i32 = 0;
    const col_off: i32 = 0;
    const n_fields: i32 = struct_decl.struct_decl_field_count;
    const unary_amp_tmp: !i32 = (TokenType.TOKEN_AMPERSAND) as! i32;
    const unary_amp: i32 = unary_amp_tmp.value;

    const s_json_object_find_index: &byte = macro_arena_strdup(arena, ("json_object_find_index" as *byte) as &byte);
    const s_json_expect_i64: &byte = macro_arena_strdup(arena, ("json_expect_i64" as *byte) as &byte);
    const s_json_expect_str: &byte = macro_arena_strdup(arena, ("json_expect_str" as *byte) as &byte);
    const s_json_expect_bool: &byte = macro_arena_strdup(arena, ("json_expect_bool" as *byte) as &byte);
    const s_json_expect_f64: &byte = macro_arena_strdup(arena, ("json_expect_f64" as *byte) as &byte);
    const s_arena_alloc: &byte = macro_arena_strdup(arena, ("arena_alloc" as *byte) as &byte);
    const s_ar: &byte = macro_arena_strdup(arena, ("ar" as *byte) as &byte);
    const s_pairs: &byte = macro_arena_strdup(arena, ("pairs" as *byte) as &byte);
    const s_value: &byte = macro_arena_strdup(arena, ("value" as *byte) as &byte);
    const s_usize: &byte = macro_arena_strdup(arena, ("usize" as *byte) as &byte);
