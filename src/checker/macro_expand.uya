            if var_arr == null { fi = fi + 1; continue; }
            var_arr.var_decl_name = val_var_name;
            var_arr.var_decl_type = field_type_node;
            var_arr.var_decl_init = empty_init;
            var_arr.var_decl_is_const = 0;
            arr_stmts[arr_idx] = var_arr;
            arr_idx = arr_idx + 1;
            var ai: i32 = 0;
            while ai < arr_size {
                const a_items: &ASTNode = ast_new_node(ASTNodeType.AST_MEMBER_ACCESS, line + line_off, column + col_off, arena, filename);
                if a_items == null { fi = fi + 1; continue; }
                a_items.member_access_object = id_a;
                a_items.member_access_field_name = s_items;
                a_items.member_access_is_module_access = 0;
                a_items.member_access_module_name = null;
                const items_i: &ASTNode = ast_new_node(ASTNodeType.AST_ARRAY_ACCESS, line + line_off, column + col_off, arena, filename);
                if items_i == null { fi = fi + 1; continue; }
                items_i.array_access_array = a_items;
                items_i.array_access_index = create_number_literal(ai as i64, arena, line + line_off, column + col_off);
                const elem_decode: &ASTNode = build_decode_json_value_expr(checker, elem_type, items_i, val_var_name, line + line_off, column + col_off, filename);
                if elem_decode == null { fi = fi + 1; continue; }
                const id_arr_var: &ASTNode = create_identifier_from_string(val_var_name, arena, line + line_off, column + col_off);
                if id_arr_var == null { fi = fi + 1; continue; }
                const arr_i_node: &ASTNode = create_number_literal(ai as i64, arena, line + line_off, column + col_off);
                if arr_i_node == null { fi = fi + 1; continue; }
                const arr_access: &ASTNode = ast_new_node(ASTNodeType.AST_ARRAY_ACCESS, line + line_off, column + col_off, arena, filename);
                if arr_access == null { fi = fi + 1; continue; }
                arr_access.array_access_array = id_arr_var;
                arr_access.array_access_index = arr_i_node;
                const assign_elem: &ASTNode = ast_new_node(ASTNodeType.AST_ASSIGN, line + line_off, column + col_off, arena, filename);
                if assign_elem == null { fi = fi + 1; continue; }
                assign_elem.assign_dest = arr_access;
                assign_elem.assign_src = elem_decode;
                arr_stmts[arr_idx] = assign_elem;
                arr_idx = arr_idx + 1;
                ai = ai + 1;
            }
            const id_arr_final: &ASTNode = create_identifier_from_string(val_var_name, arena, line + line_off, column + col_off);
            if id_arr_final == null { fi = fi + 1; continue; }
            arr_stmts[arr_idx] = id_arr_final;
            arr_idx = arr_idx + 1;
            const arr_block: &ASTNode = ast_new_node(ASTNodeType.AST_BLOCK, line + line_off, column + col_off, arena, filename);
            if arr_block == null { return null; }
            arr_block.block_stmts = arr_stmts;
            arr_block.block_stmt_count = arr_idx;
            const arms_arr: &ASTMatchArm = compiler_arena_alloc(arena, (2 * @size_of(ASTMatchArm)) as u64) as &ASTMatchArm;
            if arms_arr == null { fi = fi + 1; continue; }
            arms_arr[0].kind = MatchPatternKind.MATCH_PAT_UNION;
            arms_arr[0].variant_name = macro_arena_strdup(arena, ("arr" as *byte) as &byte);
            arms_arr[0].var_name = s_a;
            arms_arr[0].result_expr = arr_block;
            arms_arr[0].result_is_block = 1;
            arms_arr[1].kind = MatchPatternKind.MATCH_PAT_ELSE;
            const err_arr: &ASTNode = ast_new_node(ASTNodeType.AST_ERROR_VALUE, line + line_off, column + col_off, arena, filename);
            if err_arr != null { err_arr.error_value_name = s_WrongType; }
            arms_arr[1].result_expr = err_arr;
            const match_arr: &ASTNode = ast_new_node(ASTNodeType.AST_MATCH_EXPR, line + line_off, column + col_off, arena, filename);
            if match_arr == null { fi = fi + 1; continue; }
            match_arr.match_expr_expr = pairs_idx_value;
            match_arr.match_expr_arms = arms_arr;
            match_arr.match_expr_arm_count = 2;
            init_expr = ast_new_node(ASTNodeType.AST_TRY_EXPR, line + line_off, column + col_off, arena, filename);
            if init_expr != null { init_expr.try_expr_operand = match_arr; }
        } else {
            const inner_decl: &ASTNode = find_struct_decl_from_program(checker.program_node, ftype);
            var is_json_str_view: i32 = 0;
            if strcmp(ftype as *byte, "JsonStrView" as *byte) == 0 { is_json_str_view = 1; }
            if inner_decl != null && inner_decl.struct_decl_fields != null && inner_decl.struct_decl_field_count > 0 && is_json_str_view == 0 {
                snprintf(&name_buf[0] as *byte, 40, "o_%s" as *byte, fname as *byte);
                const o_inner_name: &byte = macro_arena_strdup(arena, &name_buf[0]);
                if o_inner_name == null { fi = fi + 1; continue; }
                const nested_block: &ASTNode = build_decode_struct_expr(checker, inner_decl, ftype, o_inner_name, line + line_off, column + col_off, filename);
                if nested_block == null { fi = fi + 1; continue; }
                const arms_nested: &ASTMatchArm = compiler_arena_alloc(arena, (2 * @size_of(ASTMatchArm)) as u64) as &ASTMatchArm;
                if arms_nested == null { fi = fi + 1; continue; }
                arms_nested[0].kind = MatchPatternKind.MATCH_PAT_UNION;
                arms_nested[0].variant_name = s_obj;
                arms_nested[0].var_name = o_inner_name;
                arms_nested[0].result_expr = nested_block;
                arms_nested[0].result_is_block = 1;
                arms_nested[1].kind = MatchPatternKind.MATCH_PAT_ELSE;
                const err_nested: &ASTNode = ast_new_node(ASTNodeType.AST_ERROR_VALUE, line + line_off, column + col_off, arena, filename);
                if err_nested != null { err_nested.error_value_name = s_WrongType; }
                arms_nested[1].result_expr = err_nested;
                const match_nested: &ASTNode = ast_new_node(ASTNodeType.AST_MATCH_EXPR, line + line_off, column + col_off, arena, filename);
                if match_nested == null { fi = fi + 1; continue; }
                match_nested.match_expr_expr = pairs_idx_value;
                match_nested.match_expr_arms = arms_nested;
                match_nested.match_expr_arm_count = 2;
                init_expr = ast_new_node(ASTNodeType.AST_TRY_EXPR, line + line_off, column + col_off, arena, filename);
                if init_expr != null { init_expr.try_expr_operand = match_nested; }
            } else {
                var expect_callee: &byte = s_json_expect_i64;
                if strcmp(ftype as *byte, "JsonStrView" as *byte) == 0 { expect_callee = s_json_expect_str; }
                else if strcmp(ftype as *byte, "bool" as *byte) == 0 { expect_callee = s_json_expect_bool; }
                else if strcmp(ftype as *byte, "f64" as *byte) == 0 { expect_callee = s_json_expect_f64; }
                const expect_args: &(&ASTNode) = compiler_arena_alloc(arena, (1 * 8) as u64) as &(&ASTNode);
                if expect_args == null { fi = fi + 1; continue; }
                expect_args[0] = addr_value;
                const call_expect: &ASTNode = ast_new_node(ASTNodeType.AST_CALL_EXPR, line + line_off, column + col_off, arena, filename);
                if call_expect == null { fi = fi + 1; continue; }
                call_expect.call_expr_callee = create_identifier_from_string(expect_callee, arena, line + line_off, column + col_off);
                call_expect.call_expr_args = expect_args;
                call_expect.call_expr_arg_count = 1;
                call_expect.call_expr_has_ellipsis_forward = 0;
                call_expect.call_expr_type_args = null;
                call_expect.call_expr_type_arg_count = 0;
                init_expr = ast_new_node(ASTNodeType.AST_TRY_EXPR, line + line_off, column + col_off, arena, filename);
                if init_expr != null { init_expr.try_expr_operand = call_expect; }
            }
        }
        if init_expr == null { fi = fi + 1; continue; }
        const var_val: &ASTNode = ast_new_node(ASTNodeType.AST_VAR_DECL, line + line_off, column + col_off, arena, filename);
        if var_val == null { fi = fi + 1; continue; }
        var_val.var_decl_name = val_var_name;
        var_val.var_decl_type = field_type_node;
        var_val.var_decl_init = init_expr;
        var_val.var_decl_is_const = 1;
        inner_stmts[inner_idx] = var_val;
        inner_idx = inner_idx + 1;
        field_names[field_val_idx] = fname;
        const id_val: &ASTNode = create_identifier_from_string(val_var_name, arena, line + line_off, column + col_off);
        if id_val == null { fi = fi + 1; continue; }
        field_values[field_val_idx] = id_val;
        field_val_idx = field_val_idx + 1;
        fi = fi + 1;
    }
    const struct_init: &ASTNode = ast_new_node(ASTNodeType.AST_STRUCT_INIT, line + line_off, column + col_off, arena, filename);
    if struct_init == null { return null; }
    struct_init.struct_init_struct_name = type_name;
    struct_init.struct_init_field_names = field_names;
    struct_init.struct_init_field_values = field_values;
    struct_init.struct_init_field_count = field_val_idx;
    struct_init.struct_init_type_args = null;
    struct_init.struct_init_type_arg_count = 0;
    inner_stmts[inner_idx] = struct_init;
    inner_idx = inner_idx + 1;
    const inner_block: &ASTNode = ast_new_node(ASTNodeType.AST_BLOCK, line + line_off, column + col_off, arena, filename);
    if inner_block == null { return null; }
    inner_block.block_stmts = inner_stmts;
    inner_block.block_stmt_count = inner_idx;
    return inner_block;
}

// 为 from_json<T> 单态体生成完整 body AST：const v = try parse(ar, buffer.ptr, buffer.len); return match v[0] { .obj(o) => {...}; else => error.NotAnObject }。
// type_arg 为 AST_TYPE_NAMED（结构体名）；支持标量、切片、嵌套结构体、定长数组。
export fn build_from_json_reflect_body(checker: &TypeChecker, type_arg: &ASTNode, line: i32, column: i32, filename: &byte) &ASTNode {
    if checker == null || type_arg == null || type_arg.type != ASTNodeType.AST_TYPE_NAMED || type_arg.type_named_name == null || checker.arena == null {
        return null;
    }
    const arena: &CompilerArena = checker.arena;
    const type_name: &byte = type_arg.type_named_name as &byte;
    const struct_decl: &ASTNode = find_struct_decl_from_program(checker.program_node, type_name);
    if struct_decl == null || struct_decl.struct_decl_fields == null || struct_decl.struct_decl_field_count <= 0 {
        return null;
    }
    const line_off: i32 = 0;
    const col_off: i32 = 0;
    const n_fields: i32 = struct_decl.struct_decl_field_count;

    const s_parse: &byte = macro_arena_strdup(arena, ("parse" as *byte) as &byte);
    const s_ar: &byte = macro_arena_strdup(arena, ("ar" as *byte) as &byte);
    const s_buffer: &byte = macro_arena_strdup(arena, ("buffer" as *byte) as &byte);
    const s_v: &byte = macro_arena_strdup(arena, ("v" as *byte) as &byte);
    const s_o: &byte = macro_arena_strdup(arena, ("o" as *byte) as &byte);
    const s_obj: &byte = macro_arena_strdup(arena, ("obj" as *byte) as &byte);
    const s_JsonValue: &byte = macro_arena_strdup(arena, ("JsonValue" as *byte) as &byte);
    const s_json_object_find_index: &byte = macro_arena_strdup(arena, ("json_object_find_index" as *byte) as &byte);
    const s_json_expect_i64: &byte = macro_arena_strdup(arena, ("json_expect_i64" as *byte) as &byte);
    const s_json_expect_str: &byte = macro_arena_strdup(arena, ("json_expect_str" as *byte) as &byte);
    const s_json_expect_bool: &byte = macro_arena_strdup(arena, ("json_expect_bool" as *byte) as &byte);
    const s_json_expect_f64: &byte = macro_arena_strdup(arena, ("json_expect_f64" as *byte) as &byte);
    const s_NotAnObject: &byte = macro_arena_strdup(arena, ("NotAnObject" as *byte) as &byte);
    const s_ptr: &byte = macro_arena_strdup(arena, ("ptr" as *byte) as &byte);
    const s_len: &byte = macro_arena_strdup(arena, ("len" as *byte) as &byte);
    const s_pairs: &byte = macro_arena_strdup(arena, ("pairs" as *byte) as &byte);
    const s_value: &byte = macro_arena_strdup(arena, ("value" as *byte) as &byte);
    const s_usize: &byte = macro_arena_strdup(arena, ("usize" as *byte) as &byte);
    if s_parse == null || s_ar == null || s_buffer == null || s_v == null || s_o == null || s_JsonValue == null || s_json_object_find_index == null {
        return null;
    }

    const id_ar: &ASTNode = create_identifier_from_string(s_ar, arena, line + line_off, column + col_off);
    const id_buffer: &ASTNode = create_identifier_from_string(s_buffer, arena, line + line_off, column + col_off);
    if id_ar == null || id_buffer == null { return null; }
    const buf_ptr: &ASTNode = ast_new_node(ASTNodeType.AST_MEMBER_ACCESS, line + line_off, column + col_off, arena, filename);
    if buf_ptr == null { return null; }
    buf_ptr.member_access_object = id_buffer;
    buf_ptr.member_access_field_name = s_ptr;
    buf_ptr.member_access_is_module_access = 0;
    buf_ptr.member_access_module_name = null;
    const buf_len: &ASTNode = ast_new_node(ASTNodeType.AST_MEMBER_ACCESS, line + line_off, column + col_off, arena, filename);
    if buf_len == null { return null; }
    buf_len.member_access_object = id_buffer;
    buf_len.member_access_field_name = s_len;
    buf_len.member_access_is_module_access = 0;
    buf_len.member_access_module_name = null;
    const parse_args: &(&ASTNode) = compiler_arena_alloc(arena, (3 * 8) as u64) as &(&ASTNode);
    if parse_args == null { return null; }
    parse_args[0] = id_ar;
    parse_args[1] = buf_ptr;
    parse_args[2] = buf_len;
    const call_parse: &ASTNode = ast_new_node(ASTNodeType.AST_CALL_EXPR, line + line_off, column + col_off, arena, filename);
    if call_parse == null { return null; }
    call_parse.call_expr_callee = create_identifier_from_string(s_parse, arena, line + line_off, column + col_off);
    call_parse.call_expr_args = parse_args;
    call_parse.call_expr_arg_count = 3;
    call_parse.call_expr_has_ellipsis_forward = 0;
    call_parse.call_expr_type_args = null;
    call_parse.call_expr_type_arg_count = 0;
    const try_parse: &ASTNode = ast_new_node(ASTNodeType.AST_TRY_EXPR, line + line_off, column + col_off, arena, filename);
    if try_parse == null { return null; }
    try_parse.try_expr_operand = call_parse;
    const type_json_value: &ASTNode = create_type_named_from_string(s_JsonValue, arena, line + line_off, column + col_off);
    if type_json_value == null { return null; }
    const var_v: &ASTNode = ast_new_node(ASTNodeType.AST_VAR_DECL, line + line_off, column + col_off, arena, filename);
    if var_v == null { return null; }
    var_v.var_decl_name = s_v;
    var_v.var_decl_type = type_json_value;
    var_v.var_decl_init = try_parse;
    var_v.var_decl_is_const = 1;

    const id_v: &ASTNode = create_identifier_from_string(s_v, arena, line + line_off, column + col_off);
    if id_v == null { return null; }

    const inner_block: &ASTNode = build_decode_struct_expr(checker, struct_decl, type_name, s_o, line + line_off, column + col_off, filename);
    if inner_block == null { return null; }

    const arms: &ASTMatchArm = compiler_arena_alloc(arena, (2 * @size_of(ASTMatchArm)) as u64) as &ASTMatchArm;
    if arms == null { return null; }
    arms[0].kind = MatchPatternKind.MATCH_PAT_UNION;
    arms[0].literal_expr = null;
    arms[0].literal_int_value = 0;
    arms[0].literal_is_bool = 0;
    arms[0].enum_name = null;
    arms[0].variant_name = s_obj;
    arms[0].error_name = null;
    arms[0].var_name = s_o;
    arms[0].result_expr = inner_block;
    arms[0].result_is_block = 1;
    arms[1].kind = MatchPatternKind.MATCH_PAT_ELSE;
    arms[1].literal_expr = null;
    arms[1].literal_int_value = 0;
    arms[1].literal_is_bool = 0;
    arms[1].enum_name = null;
    arms[1].variant_name = null;
    arms[1].error_name = null;
    arms[1].var_name = null;
    arms[1].result_is_block = 0;
    const err_node: &ASTNode = ast_new_node(ASTNodeType.AST_ERROR_VALUE, line + line_off, column + col_off, arena, filename);
    if err_node == null { return null; }
    err_node.error_value_name = s_NotAnObject;
    arms[1].result_expr = err_node;

    const match_expr: &ASTNode = ast_new_node(ASTNodeType.AST_MATCH_EXPR, line + line_off, column + col_off, arena, filename);
    if match_expr == null { return null; }
    match_expr.match_expr_expr = id_v;
    match_expr.match_expr_arms = arms;
    match_expr.match_expr_arm_count = 2;
    const return_stmt: &ASTNode = ast_new_node(ASTNodeType.AST_RETURN_STMT, line + line_off, column + col_off, arena, filename);
    if return_stmt == null { return null; }
    return_stmt.return_stmt_expr = match_expr;

    const outer_stmts: &(&ASTNode) = compiler_arena_alloc(arena, (3 * 8) as u64) as &(&ASTNode);
    if outer_stmts == null { return null; }
    outer_stmts[0] = var_v;
    outer_stmts[1] = return_stmt;
    const outer_block: &ASTNode = ast_new_node(ASTNodeType.AST_BLOCK, line, column, arena, filename);
    if outer_block == null { return null; }
    outer_block.block_stmts = outer_stmts;
    outer_block.block_stmt_count = 2;
    return outer_block;
}

// 递归展开宏调用（简化版本）
fn expand_macros_in_node_simple(checker: &TypeChecker, node_ptr: & & ASTNode) void {
    if checker == null || node_ptr == null || *node_ptr == null {
        return;
    }
    
    const node: &ASTNode = *node_ptr;
    
    // 如果是函数调用，检查是否为宏调用
    if node.type == ASTNodeType.AST_CALL_EXPR {
        const callee: &ASTNode = node.call_expr_callee;
        if callee != null && callee.type == ASTNodeType.AST_IDENTIFIER && 
           callee.identifier_name != null {
            const name: &byte = callee.identifier_name;
            // 从程序节点查找宏声明
            const macro_decl: &ASTNode = find_macro_decl_from_program(checker.program_node, name);
            if macro_decl != null {
                const param_count: i32 = macro_decl.macro_decl_param_count;
                const arg_count: i32 = node.call_expr_arg_count;
                var filename: &byte = null;
                if node.filename != null {
                    filename = node.filename;
                }
                if strcmp(name as *byte, "encode_to_to_json" as *byte) == 0 && arg_count >= 4 &&
                   node.call_expr_args != null && node.call_expr_args[0] != null &&
                   node.call_expr_args[0].type == ASTNodeType.AST_TYPE_NAMED {
                    const block_node: &ASTNode = build_encode_to_to_json_block(checker,
                        node.call_expr_args[0], node.call_expr_args[1], node.call_expr_args[2], node.call_expr_args[3],
                        node.line, node.column, filename);
                    if block_node != null {
                        var expanded_ptr: &ASTNode = block_node;
                        expand_macros_in_node_simple(checker, &expanded_ptr);
                        *node_ptr = expanded_ptr;
                        return;
                    }
                }
                // 首参为类型形参（AST_IDENTIFIER）时不展开，保留调用供单态体在 prepare_mono_body_expand_macros 中展开
                if strcmp(name as *byte, "encode_to_to_json" as *byte) == 0 && arg_count >= 4 &&
                   node.call_expr_args != null && node.call_expr_args[0] != null &&
                   node.call_expr_args[0].type == ASTNodeType.AST_IDENTIFIER {
                    // 不替换，继续递归子节点
                } else {
                // 获取宏体
                const body: &ASTNode = macro_decl.macro_decl_body;
                if body != null {
                    // 构建参数绑定
                    var ctx: MacroExpandContext = MacroExpandContext{
                        bindings: null,
                        binding_count: 0,
                        arena: checker.arena,
                        checker: checker,
                        hygiene_enabled: 1,
                        hygiene_expansion_id: next_macro_hygiene_expansion_id(),
                        hygiene_next_local_id: 0
                    };
                    
                    if param_count > 0 && arg_count > 0 {
                        // 分配绑定数组
                        const bindings: &MacroParamBinding = compiler_arena_alloc(checker.arena, @size_of(MacroParamBinding) * param_count) as &MacroParamBinding;
                        if bindings != null {
                            var binding_count: i32 = 0;
                            var i: i32 = 0;
                            while i < param_count && i < arg_count {
                                const param: &ASTNode = macro_decl.macro_decl_params[i];
                                if param != null && param.var_decl_name != null {
                                    bindings[binding_count].param_name = param.var_decl_name;
                                    bindings[binding_count].arg_ast = node.call_expr_args[i];
                                    binding_count = binding_count + 1;
                                }
                                i = i + 1;
                            }
                            ctx.bindings = bindings;
                            ctx.binding_count = binding_count;
                        }
                    }
                    
                    // 获取返回标签
                    const return_tag: &byte = macro_decl.macro_decl_return_tag;
                    
                    const expanded: &ASTNode = extract_macro_output_with_params(body, &ctx, filename, return_tag);
                    if expanded != null {
                        // 递归展开结果中可能存在的宏调用
                        var expanded_ptr: &ASTNode = expanded;
                        expand_macros_in_node_simple(checker, &expanded_ptr);
                        // 替换原节点
                        *node_ptr = expanded_ptr;
                        return;
                    }
                }
                }
            }
        }
    }
    
    // 递归处理子节点
    if node.type == ASTNodeType.AST_PROGRAM {
        var i: i32 = 0;
        while i < node.program_decl_count {
            expand_macros_in_node_simple(checker, &node.program_decls[i]);
            i = i + 1;
        }
    } else if node.type == ASTNodeType.AST_BLOCK {
        if node.block_stmts != null {
            var i: i32 = 0;
            while i < node.block_stmt_count {
                expand_macros_in_node_simple(checker, &node.block_stmts[i]);
                i = i + 1;
            }
        }
    } else if node.type == ASTNodeType.AST_BINARY_EXPR {
        expand_macros_in_node_simple(checker, &node.binary_expr_left);
        expand_macros_in_node_simple(checker, &node.binary_expr_right);
    } else if node.type == ASTNodeType.AST_UNARY_EXPR {
        expand_macros_in_node_simple(checker, &node.unary_expr_operand);
    } else if node.type == ASTNodeType.AST_CALL_EXPR {
        expand_macros_in_node_simple(checker, &node.call_expr_callee);
        if node.call_expr_args != null {
            var i: i32 = 0;
            while i < node.call_expr_arg_count {
                expand_macros_in_node_simple(checker, &node.call_expr_args[i]);
                i = i + 1;
            }
        }
    } else if node.type == ASTNodeType.AST_VAR_DECL {
        expand_macros_in_node_simple(checker, &node.var_decl_type);
        expand_macros_in_node_simple(checker, &node.var_decl_init);
    } else if node.type == ASTNodeType.AST_IF_STMT {
        expand_macros_in_node_simple(checker, &node.if_stmt_condition);
        expand_macros_in_node_simple(checker, &node.if_stmt_then_branch);
        expand_macros_in_node_simple(checker, &node.if_stmt_else_branch);
    } else if node.type == ASTNodeType.AST_WHILE_STMT {
        expand_macros_in_node_simple(checker, &node.while_stmt_condition);
        expand_macros_in_node_simple(checker, &node.while_stmt_body);
    } else if node.type == ASTNodeType.AST_FOR_STMT {
        expand_macros_in_node_simple(checker, &node.for_stmt_array);
        expand_macros_in_node_simple(checker, &node.for_stmt_range_start);
        expand_macros_in_node_simple(checker, &node.for_stmt_range_end);
        expand_macros_in_node_simple(checker, &node.for_stmt_body);
    } else if node.type == ASTNodeType.AST_RETURN_STMT {
        expand_macros_in_node_simple(checker, &node.return_stmt_expr);
    } else if node.type == ASTNodeType.AST_FN_DECL {
        expand_macros_in_node_simple(checker, &node.fn_decl_return_type);
        if node.fn_decl_params != null {
            var i: i32 = 0;
            while i < node.fn_decl_param_count {
                expand_macros_in_node_simple(checker, &node.fn_decl_params[i]);
                i = i + 1;
            }
        }
        expand_macros_in_node_simple(checker, &node.fn_decl_body);
    } else if node.type == ASTNodeType.AST_STRUCT_DECL {
        if node.struct_decl_fields != null {
            var i: i32 = 0;
            while i < node.struct_decl_field_count {
                expand_macros_in_node_simple(checker, &node.struct_decl_fields[i]);
                i = i + 1;
            }
        }
    } else if node.type == ASTNodeType.AST_METHOD_BLOCK {
        // 在方法块中展开 struct 返回类型的宏调用
        if node.method_block_methods != null {
            var i: i32 = 0;
            while i < node.method_block_method_count {
                const method_ptr: & & ASTNode = &node.method_block_methods[i];
                const method: &ASTNode = *method_ptr;
                // 如果是宏调用（AST_CALL_EXPR），展开为方法定义
                if method != null && method.type == ASTNodeType.AST_CALL_EXPR {
                    const callee: &ASTNode = method.call_expr_callee;
                    if callee != null && callee.type == ASTNodeType.AST_IDENTIFIER && callee.identifier_name != null {
                        const name: &byte = callee.identifier_name;
                        const macro_decl: &ASTNode = find_macro_decl_from_program(checker.program_node, name);
                        if macro_decl != null {
                            const return_tag: &byte = macro_decl.macro_decl_return_tag;
                            if return_tag != null && strcmp(return_tag as *byte, "struct" as *byte) == 0 {
                                // struct 返回类型的宏，展开为方法定义
                                const param_count: i32 = macro_decl.macro_decl_param_count;
                                const arg_count: i32 = method.call_expr_arg_count;
                                
                                // 建立参数绑定
                                var ctx: MacroExpandContext = MacroExpandContext{
                                    bindings: null,
                                    binding_count: 0,
                                    arena: checker.arena,
                                    checker: checker,
                                    hygiene_enabled: 1,
                                    hygiene_expansion_id: next_macro_hygiene_expansion_id(),
                                    hygiene_next_local_id: 0
                                };
                                
                                if param_count > 0 && arg_count > 0 {
                                    const bindings: &MacroParamBinding = compiler_arena_alloc(checker.arena, @size_of(MacroParamBinding) * param_count) as &MacroParamBinding;
                                    if bindings != null {
                                        var binding_count: i32 = 0;
                                        var j: i32 = 0;
                                        while j < param_count && j < arg_count {
                                            const param: &ASTNode = macro_decl.macro_decl_params[j];
                                            if param != null && param.var_decl_name != null {
                                                bindings[binding_count].param_name = param.var_decl_name;
                                                bindings[binding_count].arg_ast = method.call_expr_args[j];
                                                binding_count = binding_count + 1;
                                            }
                                            j = j + 1;
                                        }
                                        ctx.bindings = bindings;
                                        ctx.binding_count = binding_count;
                                    }
                                }
                                
                                // 展开宏体
                                const body: &ASTNode = macro_decl.macro_decl_body;
                                var filename: &byte = null;
                                if method.filename != null {
                                    filename = method.filename;
                                }
                                
                                const expanded: &ASTNode = extract_macro_output_with_params(body, &ctx, filename, return_tag);
                                if expanded != null {
                                    // 递归展开结果中可能存在的宏调用
                                    var expanded_ptr: &ASTNode = expanded;
                                    expand_macros_in_node_simple(checker, &expanded_ptr);
                                    *method_ptr = expanded_ptr;
                                }
                            }
                        }
                    }
                } else {
                    expand_macros_in_node_simple(checker, method_ptr);
                }
                i = i + 1;
            }
        }
    } else if node.type == ASTNodeType.AST_MEMBER_ACCESS {
        expand_macros_in_node_simple(checker, &node.member_access_object);
    } else if node.type == ASTNodeType.AST_ARRAY_ACCESS {
        expand_macros_in_node_simple(checker, &node.array_access_array);
        expand_macros_in_node_simple(checker, &node.array_access_index);
    } else if node.type == ASTNodeType.AST_CAST_EXPR {
        expand_macros_in_node_simple(checker, &node.cast_expr_expr);
        expand_macros_in_node_simple(checker, &node.cast_expr_target_type);
    } else if node.type == ASTNodeType.AST_STRUCT_INIT {
        if node.struct_init_field_values != null {
            var i: i32 = 0;
            while i < node.struct_init_field_count {
                expand_macros_in_node_simple(checker, &node.struct_init_field_values[i]);
                i = i + 1;
            }
        }
    } else if node.type == ASTNodeType.AST_ARRAY_LITERAL {
        if node.array_literal_elements != null {
            var i: i32 = 0;
            while i < node.array_literal_element_count {
                expand_macros_in_node_simple(checker, &node.array_literal_elements[i]);
                i = i + 1;
            }
        }
        expand_macros_in_node_simple(checker, &node.array_literal_repeat_count_expr);
    } else if node.type == ASTNodeType.AST_ASSIGN {
        expand_macros_in_node_simple(checker, &node.assign_dest);
        expand_macros_in_node_simple(checker, &node.assign_src);
    } else if node.type == ASTNodeType.AST_DEFER_STMT || node.type == ASTNodeType.AST_ERRDEFER_STMT {
        expand_macros_in_node_simple(checker, &node.defer_stmt_body);
    } else if node.type == ASTNodeType.AST_SIZEOF || node.type == ASTNodeType.AST_ALIGNOF {
        expand_macros_in_node_simple(checker, &node.sizeof_expr_target);
    } else if node.type == ASTNodeType.AST_LEN {
        expand_macros_in_node_simple(checker, &node.len_expr_array);
    } else if node.type == ASTNodeType.AST_TEST_STMT {
        // 测试语句：展开测试体中的宏
        expand_macros_in_node_simple(checker, &node.test_stmt_body);
    } else if node.type == ASTNodeType.AST_CATCH_EXPR {
        // catch 表达式：展开操作数和 catch 块中的宏
        expand_macros_in_node_simple(checker, &node.catch_expr_operand);
        expand_macros_in_node_simple(checker, &node.catch_expr_catch_block);
    } else if node.type == ASTNodeType.AST_TRY_EXPR {
        // try 表达式：展开操作数中的宏
        expand_macros_in_node_simple(checker, &node.try_expr_operand);
    } else if node.type == ASTNodeType.AST_MATCH_EXPR {
        // match 表达式：展开匹配表达式和各个分支
        expand_macros_in_node_simple(checker, &node.match_expr_expr);
        if node.match_expr_arms != null {
            var i: i32 = 0;
            while i < node.match_expr_arm_count {
                expand_macros_in_node_simple(checker, &node.match_expr_arms[i].result_expr);
                i = i + 1;
            }
        }
    }
    // 其他节点类型暂不处理
}
