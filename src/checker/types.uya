// checker/types.uya - 类型定义
// 从 checker.uya 拆分

use libc.atoi;
use std.string.strlen;
use libc.Stat;
use libc.stat;
use std.runtime.ptr_diff;
use std.string.strcat;
use std.string.strcpy;
use std.string.strrchr;
use std.mem.memcpy;

// ===== 常量定义 =====

const MAX_ERROR_NAMES: i32 = 256;
const MAX_MOVED_NAMES: i32 = 128;
const MAX_MONO_INSTANCES: i32 = 512;
const MAX_UNION_VARIANTS: i32 = 32;
const MAX_INTERFACE_METHODS: i32 = 128;
const MAX_INTERFACE_STACK: i32 = 64;
const MAX_BASE_NAME_LEN: i32 = 256;
const MAX_MONO_NAME_LEN: i32 = 256;
const MAX_MONO_NAME_LIMIT: i32 = 250;
const MAX_POINTER_NAMES: i32 = 32;
const MAX_CONSTRAINTS: i32 = 64;
const MAX_ASYNC_CALL_EDGES: i32 = 512;
const MAX_FN_CALL_EDGES: i32 = 16384;
const MAX_FN_ROOTS: i32 = 1024;
const MAX_REACHABLE_FN_DECLS: i32 = 4096;
const MAX_REACHABILITY_VISIT_SLOTS: i32 = 262144;
const MAX_REACHABILITY_VISIT_MASK: usize = 262143;

const SYMBOL_TABLE_SIZE: i32 = 32768;
const FUNCTION_TABLE_SIZE: i32 = 4096;
const MODULE_TABLE_SIZE: i32 = 256;
const IMPORT_TABLE_SIZE: i32 = 512;
const STRING_POOL_SIZE: i32 = 16384;  // 字符串池大小

// ===== 类型枚举 =====

enum TypeKind {
    TYPE_I8,
    TYPE_I16,
    TYPE_I32,
    TYPE_I64,
    TYPE_U8,
    TYPE_U16,
    TYPE_U32,
    TYPE_USIZE,
    TYPE_U64,
    TYPE_BOOL,
    TYPE_BYTE,
    TYPE_F32,
    TYPE_F64,
    TYPE_VOID,
    TYPE_ENUM,
    TYPE_INTERFACE,
    TYPE_STRUCT,
    TYPE_UNION,
    TYPE_POINTER,
    TYPE_ARRAY,
    TYPE_SLICE,
    TYPE_TUPLE,
    TYPE_ERROR_UNION,
    TYPE_ERROR,
    TYPE_INT_LIMIT,
    TYPE_ATOMIC,
    TYPE_VECTOR,
    TYPE_MASK,
    TYPE_GENERIC_PARAM,
    // @asm 寄存器类型
    TYPE_ASM_REG,          // 通用寄存器（编译器自动分配）
    TYPE_ASM_REG_X64,      // x86-64 通用寄存器
    TYPE_ASM_REG_X86,      // x86 通用寄存器
    TYPE_ASM_REG_ARM64,    // ARM64 通用寄存器
    TYPE_ASM_REG_RISCV,    // RISC-V 通用寄存器
    // @asm SIMD 寄存器类型
    TYPE_ASM_REG_X64_XMM,  // x86-64 SSE (128-bit)
    TYPE_ASM_REG_X64_YMM,  // x86-64 AVX/AVX2 (256-bit)
    TYPE_ASM_REG_X64_ZMM,  // x86-64 AVX-512 (512-bit)
    TYPE_ASM_REG_ARM64_V,  // ARM64 NEON (128-bit)
    TYPE_ASM_REG_RISCV_V,  // RISC-V V 扩展 (可变长度向量)
    TYPE_ASM_REG_RISCV_F,  // RISC-V F 扩展 (单精度浮点)
    TYPE_ASM_REG_RISCV_D,  // RISC-V D 扩展 (双精度浮点)
    // @asm 内存操作类型
    TYPE_ASM_MEM,          // 内存操作数
    // va_list 内置类型
    TYPE_VA_LIST,          // 可变参数列表类型（平台相关大小）
}

// ===== 类型数据辅助结构体（阶段四：Union 化重构）=====

// 指针类型数据
struct PointerData {
    pointee: &Type,
    is_ffi: i32,
}

// 数组类型数据
struct ArrayData {
    element: &Type,
    size: i32,
}

// 切片类型数据
struct SliceData {
    element: &Type,
    len: i32,
}

// 元组类型数据
struct TupleData {
    elements: &Type,
    count: i32,
}

// 错误联合类型数据
struct ErrorUnionData {
    payload: &Type,
    error_id: u32,
}

// 原子类型数据
struct AtomicData {
    inner: &Type,
}

// 泛型参数数据
struct GenericParamData {
    name: &byte,
}

// 结构体泛型数据
struct StructGenericData {
    name: &byte,
    type_args: &Type,
    type_arg_count: i32,
}

// 类型数据联合体（Tagged Union，类型安全）
// 注意：虽然有额外的标签开销，但提供类型安全
// Type.kind 字段用于区分类型，可以视为冗余但无害
union TypeData {
    named: &byte,                 // TYPE_ENUM, TYPE_STRUCT, TYPE_UNION, TYPE_INTERFACE 的名称
    pointer: PointerData,         // TYPE_POINTER
    array: ArrayData,             // TYPE_ARRAY
    slice: SliceData,             // TYPE_SLICE
    tuple: TupleData,             // TYPE_TUPLE
    error_union: ErrorUnionData,  // TYPE_ERROR_UNION
    atomic_data: AtomicData,      // TYPE_ATOMIC (atomic 是关键字)
    generic_param: GenericParamData, // TYPE_GENERIC_PARAM
    struct_generic: StructGenericData, // TYPE_STRUCT 带泛型参数
}

// ===== 类型结构 =====

struct Type {
    kind: TypeKind,
    data: TypeData,  // 新增：union 类型数据
    // === 以下为过渡期保留的旧字段（迁移完成后移除）===
    // @deprecated: 使用 data 访问
    enum_name: &byte,
    interface_name: &byte,
    interface_type_args: &Type,
    interface_type_arg_count: i32,
    struct_name: &byte,
    union_name: &byte,
    pointer_to: &Type,
    is_ffi_pointer: i32,
    element_type: &Type,
    array_size: i32,
    slice_element_type: &Type,
    slice_len: i32,
    slice_element_is_const: i32,
    tuple_element_types: &Type,
    tuple_count: i32,
    error_union_payload_type: &Type,
    error_error_id: u32,
    atomic_inner_type: &Type,
    generic_param_name: &byte,
    struct_type_args: &Type,
    struct_type_arg_count: i32,
    union_type_args: &Type,
    union_type_arg_count: i32,
}

struct Symbol {
    name: &byte,
    type: Type,
    is_const: i32,
    is_initialized: i32,
    scope_level: i32,
    line: i32,
    column: i32,
    pointee_of: &byte,
    decl_node: &ASTNode,
    next_in_scope: &Symbol,  // 同一作用域的下一个符号（用于快速遍历）
    pointer_known_length: i32,  // 指针已知长度（如 *byte = "ab" 为 3），-1 表示未知；用于 --safety-proof 时下标边界证明
    pointer_length_param: &byte,  // 若为函数参数且与下一参数成 (ptr, len) 对，则为 len 参数名，否则 null；有此时允许 ptr[i] 作长度证明
}

struct FunctionSignature {
    name: &byte,
    param_types: &Type,
    param_count: i32,
    return_type: Type,
    is_extern: i32,
    is_varargs: i32,
    line: i32,
    column: i32,
}

struct SymbolTable {
    slots: [&Symbol: SYMBOL_TABLE_SIZE],
    count: i32,
}

struct FunctionTable {
    slots: [&FunctionSignature: FUNCTION_TABLE_SIZE],
    count: i32,
}

struct ExportedItem {
    name: &byte,
    decl_node: &ASTNode,
    module_name: &byte,
    item_type: i32,
}

struct ModuleDependency {
    target_module: &byte,
    use_stmt_node: &ASTNode,
}

struct ModuleInfo {
    module_name: &byte,
    filename: &byte,
    exports: &ExportedItem,
    export_count: i32,
    dependencies: &ModuleDependency,
    dependency_count: i32,
}

struct ModuleTable {
    slots: [&ModuleInfo: MODULE_TABLE_SIZE],
    count: i32,
}

struct ImportedItem {
    local_name: &byte,
    original_name: &byte,
    module_name: &byte,
    item_type: i32,
}

struct ImportTable {
    slots: [&ImportedItem: IMPORT_TABLE_SIZE],
    count: i32,
}

// 字符串池条目
struct StringPoolEntry {
    str: &byte,           // 字符串指针
    hash: i32,            // 哈希值（用于快速比较）
    next: &StringPoolEntry, // 链表下一个（哈希冲突时）
}

// 字符串池（用于字符串 intern）
struct StringPool {
    buckets: [&StringPoolEntry: STRING_POOL_SIZE],  // 哈希桶
    count: i32,
}

struct MonoInstance {
    generic_name: &byte,
    type_args: &Type,
    type_arg_nodes: & & ASTNode,
    type_arg_count: i32,
    is_function: i32,
}

struct TypeChecker {
    arena: &CompilerArena,
    symbol_table: SymbolTable,
    function_table: FunctionTable,
    module_table: ModuleTable,
    import_table: ImportTable,
    string_pool: StringPool,  // 字符串池
    scope_level: i32,
    loop_depth: i32,
    program_node: &ASTNode,
    error_count: i32,
    last_reported_error_filename: &byte,
    last_reported_error_message: &byte,
    last_reported_error_line: i32,
    last_reported_error_column: i32,
    default_filename: &byte,
    current_return_type: Type,
    in_function: i32,
    in_defer_or_errdefer: i32,
    current_function_decl: &ASTNode,
    current_self_type_name: &byte,
    current_self_is_union: i32,
    suppress_codegen_diagnostics: i32,
    error_names: [&byte: 256],
    error_hashes: [u32: 256],
    error_name_count: i32,
    moved_names: [&byte: 128],
    moved_count: i32,
    project_root_dir: &byte,
    uya_root_dir: &byte,
    current_type_params: &TypeParam,
    current_type_param_count: i32,
    mono_instances: [MonoInstance: 512],
    mono_instance_count: i32,
    constraint_var_names: [&byte: 64],
    constraint_ops: [i32: 64],
    constraint_values: [i32: 64],
    constraint_count: i32,
    pointer_nonnull_names: [&byte: 32],
    pointer_nonnull_count: i32,
    pointer_nullable_names: [&byte: 32],
    pointer_nullable_count: i32,
    enable_safety_proof: i32,
    container_mode: i32,        // 1 = microapp 模式: 禁止 @asm/extern
    proof_step_limit: i32,
    proof_step_count: i32,
    // 作用域链表头数组：每个作用域的符号链表头
    // 用于快速遍历当前作用域的符号，避免遍历整个符号表
    scope_heads: [&Symbol: 64],  // 支持最多 64 层嵌套作用域
    // 异步函数调用图（用于在完整状态机大小计算前先检测 async 调用环）
    async_call_edge_from: [&byte: MAX_ASYNC_CALL_EDGES],
    async_call_edge_to: [&byte: MAX_ASYNC_CALL_EDGES],
    async_call_edge_count: i32,
    // 顶层函数可达性（由 checker 收集，codegen 只消费结果）
    fn_call_edge_from: [&ASTNode: MAX_FN_CALL_EDGES],
    fn_call_edge_to: [&ASTNode: MAX_FN_CALL_EDGES],
    fn_call_edge_count: i32,
    fn_root_decls: [&ASTNode: MAX_FN_ROOTS],
    fn_root_count: i32,
    reachable_fn_decls: [&ASTNode: MAX_REACHABLE_FN_DECLS],
    reachable_fn_decl_count: i32,
    reachability_visit_count: i32,
    reachability_visit_cache: [&ASTNode: MAX_REACHABILITY_VISIT_SLOTS],
    async_frame_metas: [AsyncFrameMeta: MAX_ASYNC_FRAME_METAS],
    async_frame_meta_count: i32,
}
