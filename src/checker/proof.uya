// checker/proof.uya - 安全证明和错误报告
// 从 checker/main.uya 拆分

// ===== 错误报告状态 =====

var last_checker_error_message: &byte = null;
// 将动态/栈上格式化的错误文案拷入此处，供 get_last_checker_error() 与后续打印使用（避免悬空指针）
var last_checker_error_storage: [byte: 512] = [];
var reported_error_vars: [&byte: 32] = [];
var reported_error_sizes: [i32: 32] = [];
var reported_error_count: i32 = 0;

// ===== 重复错误检测 =====

// 检查是否已报告过相同的错误
fn was_error_reported(var_name: &byte, array_size: i32) i32 {
    var i: i32 = 0;
    while i < reported_error_count {
        if i < @len(reported_error_vars) {
            if reported_error_vars[i] != null && var_name != null {
                if strcmp(reported_error_vars[i] as *byte, var_name as *byte) == 0 {
                    if reported_error_sizes[i] == array_size {
                        return 1;
                    }
                }
            }
        }
        i = i + 1;
    }
    return 0;
}

// 记录已报告的错误
fn mark_error_reported(var_name: &byte, array_size: i32) void {
    if reported_error_count < 0 || reported_error_count >= @len(reported_error_vars) {
        return;
    }
    if was_error_reported(var_name, array_size) != 0 {
        return;
    }
    // 证明：reported_error_count 在 [0, 32) 范围内
    if reported_error_count >= 0 && reported_error_count < @len(reported_error_vars) {
        reported_error_vars[reported_error_count] = var_name;
        reported_error_sizes[reported_error_count] = array_size;
        reported_error_count = reported_error_count + 1;
    }
}

fn get_last_checker_error() &byte {
    return last_checker_error_message;
}

// ===== 溢出检测常量 =====

const I32_MAX: i32 = @max;
const I32_MIN: i32 = @min;

// ===== 溢出检测函数 =====

// 检测 i32 加法溢出
fn check_i32_add_overflow(left: i32, right: i32) i32 {
    if left > 0 && right > 0 {
        if left > I32_MAX - right {
            return 1;
        }
    }
    if left < 0 && right < 0 {
        if left < I32_MIN - right {
            return 1;
        }
    }
    return 0;
}

// 检测 i32 减法溢出
fn check_i32_sub_overflow(left: i32, right: i32) i32 {
    if left >= 0 && right < 0 {
        if left > I32_MAX + right {
            return 1;
        }
    }
    if left < 0 && right > 0 {
        if left < I32_MIN + right {
            return 1;
        }
    }
    return 0;
}

// 检测 i32 乘法溢出
fn check_i32_mul_overflow(left: i32, right: i32) i32 {
    if left == 0 || right == 0 {
        return 0;
    }
    if left == I32_MIN && right == -1 {
        return 1;
    }
    if right == I32_MIN && left == -1 {
        return 1;
    }
    
    if left > 0 && right > 0 {
        if left > I32_MAX / right {
            return 1;
        }
    }
    if left < 0 && right < 0 {
        if -left > I32_MAX / -right {
            return 1;
        }
    }
    if left > 0 && right < 0 {
        if right < I32_MIN / left {
            return 1;
        }
    }
    if left < 0 && right > 0 {
        if left < I32_MIN / right {
            return 1;
        }
    }
    return 0;
}

// 检测 i32 一元负溢出
fn check_i32_neg_overflow(val: i32) i32 {
    if val == I32_MIN {
        return 1;
    }
    return 0;
}

// ===== 常量表达式求值 =====

// 评估编译时常量表达式
fn checker_eval_const_expr(checker: &TypeChecker, expr: &ASTNode) i32 {
    if expr == null || checker == null {
        return -1;
    }
    if expr.type == ASTNodeType.AST_NUMBER {
        return expr.number_value as i32;
    } else if expr.type == ASTNodeType.AST_BOOL {
        return expr.bool_literal_value;
    } else if expr.type == ASTNodeType.AST_CHAR {
        return expr.char_literal_value;
    } else if expr.type == ASTNodeType.AST_IDENTIFIER {
        const symbol: &Symbol = symbol_table_lookup(checker, expr.identifier_name);
        if symbol != null && symbol.is_const != 0 && symbol.decl_node != null {
            const decl: &ASTNode = symbol.decl_node;
            if decl.type == ASTNodeType.AST_VAR_DECL && decl.var_decl_init != null {
                return checker_eval_const_expr(checker, decl.var_decl_init);
            }
            // export const x: T = v; 解析为 AST_EXTERN_VAR_DECL（非 C extern）
            if decl.type == ASTNodeType.AST_EXTERN_VAR_DECL && decl.extern_var_decl_init_expr != null &&
                decl.extern_var_decl_is_extern == 0 {
                return checker_eval_const_expr(checker, decl.extern_var_decl_init_expr);
            }
        }
        
        if checker.program_node == null {
            return -1;
        }
        const program: &ASTNode = checker.program_node;
        if program.type != ASTNodeType.AST_PROGRAM {
            return -1;
        }
        var i: i32 = 0;
        while i < program.program_decl_count {
            const decl: &ASTNode = program.program_decls[i];
            if decl != null && decl.type == ASTNodeType.AST_VAR_DECL &&
               decl.var_decl_name != null &&
               strcmp(decl.var_decl_name as *byte, expr.identifier_name as *byte) == 0 &&
               decl.var_decl_is_const != 0 {
                const init: &ASTNode = decl.var_decl_init;
                if init != null {
                    return checker_eval_const_expr(checker, init);
                }
                return -1;
            }
            if decl != null && decl.type == ASTNodeType.AST_EXTERN_VAR_DECL &&
               decl.extern_var_decl_name != null &&
               strcmp(decl.extern_var_decl_name as *byte, expr.identifier_name as *byte) == 0 &&
               decl.extern_var_decl_is_const != 0 {
                const init_ex: &ASTNode = decl.extern_var_decl_init_expr;
                if init_ex != null {
                    return checker_eval_const_expr(checker, init_ex);
                }
                return -1;
            }
            i = i + 1;
        }
        return -1;
    } else if expr.type == ASTNodeType.AST_MEMBER_ACCESS {
        var base_expr: &ASTNode = expr.member_access_object;
        if base_expr != null && base_expr.type == ASTNodeType.AST_IDENTIFIER && base_expr.identifier_name != null {
            const symbol: &Symbol = symbol_table_lookup(checker, base_expr.identifier_name);
            if symbol != null && symbol.is_const != 0 && symbol.decl_node != null {
                const sdn: &ASTNode = symbol.decl_node;
                if sdn.type == ASTNodeType.AST_VAR_DECL && sdn.var_decl_init != null {
                    base_expr = sdn.var_decl_init;
                } else if sdn.type == ASTNodeType.AST_EXTERN_VAR_DECL && sdn.extern_var_decl_init_expr != null &&
                    sdn.extern_var_decl_is_extern == 0 {
                    base_expr = sdn.extern_var_decl_init_expr;
                }
            }
        }
        if base_expr != null && base_expr.type == ASTNodeType.AST_MC_TYPE {
            const info_struct: &ASTNode = create_type_info_struct(base_expr.mc_type_operand, checker.arena, expr.line, expr.column, checker);
            if info_struct != null {
                base_expr = info_struct;
            }
        }
        if base_expr != null && base_expr.type == ASTNodeType.AST_STRUCT_INIT &&
            base_expr.struct_init_field_names != null && base_expr.struct_init_field_values != null &&
            expr.member_access_field_name != null {
            var fi: i32 = 0;
            while fi < base_expr.struct_init_field_count {
                if base_expr.struct_init_field_names[fi] != null &&
                    strcmp(base_expr.struct_init_field_names[fi] as *byte, expr.member_access_field_name as *byte) == 0 {
                    const field_value: &ASTNode = base_expr.struct_init_field_values[fi];
                    if field_value != null {
                        return checker_eval_const_expr(checker, field_value);
                    }
                    return -1;
                }
                fi = fi + 1;
            }
        }
        return -1;
    } else if expr.type == ASTNodeType.AST_BINARY_EXPR {
        const left_val: i32 = checker_eval_const_expr(checker, expr.binary_expr_left);
        const right_val: i32 = checker_eval_const_expr(checker, expr.binary_expr_right);
        if left_val == -1 || right_val == -1 {
            return -1;
        }
        const op_tmp: !TokenType = expr.binary_expr_op as! TokenType;
        const op: TokenType = op_tmp.value;
        if op == TokenType.TOKEN_PLUS {
            if check_i32_add_overflow(left_val, right_val) != 0 {
                checker_report_error(checker, expr, "常量表达式溢出: 加法结果超出 i32 范围" as *byte);
                return -1;
            }
            return left_val + right_val;
        } else if op == TokenType.TOKEN_MINUS {
            if check_i32_sub_overflow(left_val, right_val) != 0 {
                checker_report_error(checker, expr, "常量表达式溢出: 减法结果超出 i32 范围" as *byte);
                return -1;
            }
            return left_val - right_val;
        } else if op == TokenType.TOKEN_ASTERISK {
            if check_i32_mul_overflow(left_val, right_val) != 0 {
                checker_report_error(checker, expr, "常量表达式溢出: 乘法结果超出 i32 范围" as *byte);
                return -1;
            }
            return left_val * right_val;
        } else if op == TokenType.TOKEN_SLASH {
            if right_val == 0 {
                checker_report_error(checker, expr, "常量表达式除零错误" as *byte);
                return -1;
            }
            return left_val / right_val;
        } else if op == TokenType.TOKEN_PERCENT {
            if right_val == 0 {
                checker_report_error(checker, expr, "常量表达式模零错误" as *byte);
                return -1;
            }
            return left_val % right_val;
        } else if op == TokenType.TOKEN_LESS {
            if left_val < right_val { return 1; } else { return 0; }
        } else if op == TokenType.TOKEN_GREATER {
            if left_val > right_val { return 1; } else { return 0; }
        } else if op == TokenType.TOKEN_LESS_EQUAL {
            if left_val <= right_val { return 1; } else { return 0; }
        } else if op == TokenType.TOKEN_GREATER_EQUAL {
            if left_val >= right_val { return 1; } else { return 0; }
        } else if op == TokenType.TOKEN_EQUAL {
            if left_val == right_val { return 1; } else { return 0; }
        } else if op == TokenType.TOKEN_NOT_EQUAL {
            if left_val != right_val { return 1; } else { return 0; }
        } else if op == TokenType.TOKEN_LOGICAL_AND {
            if left_val != 0 && right_val != 0 { return 1; } else { return 0; }
        } else if op == TokenType.TOKEN_LOGICAL_OR {
            if left_val != 0 || right_val != 0 { return 1; } else { return 0; }
        } else {
            return -1;
        }
    } else if expr.type == ASTNodeType.AST_UNARY_EXPR {
        const operand_val: i32 = checker_eval_const_expr(checker, expr.unary_expr_operand);
        if operand_val == -1 {
            return -1;
        }
        const op_tmp: !TokenType = expr.unary_expr_op as! TokenType;
        const op: TokenType = op_tmp.value;
        if op == TokenType.TOKEN_PLUS {
            return operand_val;
        } else if op == TokenType.TOKEN_MINUS {
            if check_i32_neg_overflow(operand_val) != 0 {
                checker_report_error(checker, expr, "常量表达式溢出: 一元负运算超出 i32 范围" as *byte);
                return -1;
            }
            return -operand_val;
        } else {
            return -1;
        }
    } else if expr.type == ASTNodeType.AST_LEN {
        const array_expr: &ASTNode = expr.len_expr_array;
        if array_expr == null {
            return -1;
        }
        const array_type: Type = checker_infer_type(checker, array_expr);
        if array_type.kind == TypeKind.TYPE_ARRAY {
            return array_type.array_size;
        }
        return -1;
    } else if expr.type == ASTNodeType.AST_SIZEOF {
        const target: &ASTNode = expr.sizeof_expr_target;
        if target == null { return -1; }
        var t: Type = checker_infer_type(checker, target);
        if expr.sizeof_expr_is_type != 0 {
            if target.type == ASTNodeType.AST_TYPE_FRAME {
                const frame_size: i32 = get_async_frame_size_bytes(checker, target);
                if frame_size > 0 {
                    return frame_size;
                }
            }
            t = type_from_ast(checker, target);
        }
        return get_type_size_bytes(&t);
    } else if expr.type == ASTNodeType.AST_ALIGNOF {
        const target: &ASTNode = expr.alignof_expr_target;
        if target == null { return -1; }
        var t: Type = checker_infer_type(checker, target);
        if expr.alignof_expr_is_type != 0 {
            t = type_from_ast(checker, target);
        }
        return get_type_align_bytes(&t);
    } else if expr.type == ASTNodeType.AST_CAST_EXPR {
        const inner_expr: &ASTNode = expr.cast_expr_expr;
        if inner_expr == null {
            return -1;
        }
        return checker_eval_const_expr(checker, inner_expr);
    } else {
        return -1;
    }
}

// 根据 Type 计算字节大小（用于 @size_of 常量求值，仅支持基础类型和数组）
fn get_type_size_bytes(t: &Type) i32 {
    if t == null {
        return -1;
    }
    if t.kind == TypeKind.TYPE_I8 || t.kind == TypeKind.TYPE_U8 || t.kind == TypeKind.TYPE_BOOL || t.kind == TypeKind.TYPE_BYTE {
        return 1;
    }
    if t.kind == TypeKind.TYPE_I16 || t.kind == TypeKind.TYPE_U16 {
        return 2;
    }
    if t.kind == TypeKind.TYPE_I32 || t.kind == TypeKind.TYPE_U32 || t.kind == TypeKind.TYPE_F32 {
        return 4;
    }
    if t.kind == TypeKind.TYPE_I64 || t.kind == TypeKind.TYPE_U64 || t.kind == TypeKind.TYPE_F64 || t.kind == TypeKind.TYPE_USIZE || t.kind == TypeKind.TYPE_POINTER {
        return 8;
    }
    if t.kind == TypeKind.TYPE_ARRAY && t.array_size >= 0 {
        const elem_size: i32 = get_type_size_bytes(t.element_type);
        if elem_size > 0 && t.array_size <= 0x7FFFFFFF / elem_size {
            return elem_size * t.array_size;
        }
    }
    return -1;
}

// 获取 @frame(async_fn) 的帧大小（字节），用于 @size_of(@frame(...)) 常量求值
fn get_async_frame_size_bytes(checker: &TypeChecker, type_node: &ASTNode) i32 {
    if checker == null || type_node == null || type_node.type != ASTNodeType.AST_TYPE_FRAME {
        return -1;
    }
    const operand: &ASTNode = type_node.type_frame_operand;
    if operand == null || operand.type != ASTNodeType.AST_IDENTIFIER || operand.identifier_name == null {
        return -1;
    }
    const fd: &ASTNode = find_fn_decl_from_program(checker.program_node, operand.identifier_name);
    if fd == null || fd.fn_decl_is_async == 0 {
        return -1;
    }
    const meta: &AsyncFrameMeta = checker_async_frame_meta_for_fn(checker, fd);
    if meta == null || meta.frame_size == 0 {
        return -1;
    }
    if meta.frame_size > 2147483647 as usize {
        return -1;
    }
    return meta.frame_size as i32;
}

// 根据 Type 计算对齐（字节），仅支持基础类型
fn get_type_align_bytes(t: &Type) i32 {
    const sz: i32 = get_type_size_bytes(t);
    if sz <= 0 {
        return -1;
    }
    if sz <= 1 {
        return 1;
    }
    if sz <= 2 {
        return 2;
    }
    if sz <= 4 {
        return 4;
    }
    return 8;
}

// 在 block 内查找变量/const 的声明节点（用于 @len 等获取类型）
fn find_decl_in_block(block: &ASTNode, name: &byte) &ASTNode {
    if block == null || block.type != ASTNodeType.AST_BLOCK || block.block_stmts == null || name == null {
        return null;
    }
    var i: i32 = 0;
    while i < block.block_stmt_count {
        const stmt: &ASTNode = block.block_stmts[i];
        if stmt != null && stmt.type == ASTNodeType.AST_VAR_DECL && stmt.var_decl_name != null &&
           strcmp(stmt.var_decl_name as *byte, name as *byte) == 0 {
            return stmt;
        }
        i = i + 1;
    }
    return null;
}

// 在 block 内查找 const 变量的初始化表达式（用于优化阶段，符号表已 pop）
export fn find_const_init_in_block(block: &ASTNode, name: &byte) &ASTNode {
    if block == null || block.type != ASTNodeType.AST_BLOCK || block.block_stmts == null || name == null {
        return null;
    }
    var i: i32 = 0;
    while i < block.block_stmt_count {
        const stmt: &ASTNode = block.block_stmts[i];
        if stmt != null && stmt.type == ASTNodeType.AST_VAR_DECL && stmt.var_decl_is_const != 0 &&
           stmt.var_decl_name != null && strcmp(stmt.var_decl_name as *byte, name as *byte) == 0 &&
           stmt.var_decl_init != null {
            return stmt.var_decl_init;
        }
        i = i + 1;
    }
    return null;
}

// 带 block 上下文的常量求值（优化阶段用，可解析块内局部 const）
export fn checker_eval_const_expr_in_block(checker: &TypeChecker, expr: &ASTNode, block: &ASTNode) i32 {
    if expr == null || checker == null {
        return -1;
    }
    if expr.type == ASTNodeType.AST_NUMBER {
        return expr.number_value as i32;
    } else if expr.type == ASTNodeType.AST_CHAR {
        return expr.char_literal_value;
    } else if expr.type == ASTNodeType.AST_IDENTIFIER {
        const symbol: &Symbol = symbol_table_lookup(checker, expr.identifier_name);
        if symbol != null && symbol.is_const != 0 && symbol.decl_node != null {
            const decl: &ASTNode = symbol.decl_node;
            if decl.type == ASTNodeType.AST_VAR_DECL && decl.var_decl_init != null {
                return checker_eval_const_expr_in_block(checker, decl.var_decl_init, block);
            }
        }
        if block != null {
            const init: &ASTNode = find_const_init_in_block(block, expr.identifier_name);
            if init != null {
                return checker_eval_const_expr_in_block(checker, init, block);
            }
        }
        if checker.program_node == null {
            return -1;
        }
        const program: &ASTNode = checker.program_node;
        if program.type != ASTNodeType.AST_PROGRAM {
            return -1;
        }
        var i: i32 = 0;
        while i < program.program_decl_count {
            const decl: &ASTNode = program.program_decls[i];
            if decl != null && decl.type == ASTNodeType.AST_VAR_DECL &&
               decl.var_decl_name != null &&
               strcmp(decl.var_decl_name as *byte, expr.identifier_name as *byte) == 0 &&
               decl.var_decl_is_const != 0 {
                const init: &ASTNode = decl.var_decl_init;
                if init != null {
                    return checker_eval_const_expr_in_block(checker, init, block);
                }
                return -1;
            }
            i = i + 1;
        }
        return -1;
    } else if expr.type == ASTNodeType.AST_BINARY_EXPR {
        const left_val: i32 = checker_eval_const_expr_in_block(checker, expr.binary_expr_left, block);
        const right_val: i32 = checker_eval_const_expr_in_block(checker, expr.binary_expr_right, block);
        if left_val == -1 || right_val == -1 {
            return -1;
        }
        const op_tmp: !TokenType = expr.binary_expr_op as! TokenType;
        const op: TokenType = op_tmp.value;
        if op == TokenType.TOKEN_PLUS {
            if check_i32_add_overflow(left_val, right_val) != 0 { return -1; }
            return left_val + right_val;
        } else if op == TokenType.TOKEN_MINUS {
            if check_i32_sub_overflow(left_val, right_val) != 0 { return -1; }
            return left_val - right_val;
        } else if op == TokenType.TOKEN_ASTERISK {
            if check_i32_mul_overflow(left_val, right_val) != 0 { return -1; }
            return left_val * right_val;
        } else if op == TokenType.TOKEN_SLASH {
            if right_val == 0 { return -1; }
            return left_val / right_val;
        } else if op == TokenType.TOKEN_PERCENT {
            if right_val == 0 { return -1; }
            return left_val % right_val;
        } else if op == TokenType.TOKEN_LESS {
            if left_val < right_val { return 1; } else { return 0; }
        } else if op == TokenType.TOKEN_GREATER {
            if left_val > right_val { return 1; } else { return 0; }
        } else if op == TokenType.TOKEN_LESS_EQUAL {
            if left_val <= right_val { return 1; } else { return 0; }
        } else if op == TokenType.TOKEN_GREATER_EQUAL {
            if left_val >= right_val { return 1; } else { return 0; }
        } else if op == TokenType.TOKEN_EQUAL {
            if left_val == right_val { return 1; } else { return 0; }
        } else if op == TokenType.TOKEN_NOT_EQUAL {
            if left_val != right_val { return 1; } else { return 0; }
        } else if op == TokenType.TOKEN_LOGICAL_AND {
            if left_val != 0 && right_val != 0 { return 1; } else { return 0; }
        } else if op == TokenType.TOKEN_LOGICAL_OR {
            if left_val != 0 || right_val != 0 { return 1; } else { return 0; }
        } else {
            return -1;
        }
    } else if expr.type == ASTNodeType.AST_UNARY_EXPR {
        const operand_val: i32 = checker_eval_const_expr_in_block(checker, expr.unary_expr_operand, block);
        if operand_val == -1 { return -1; }
        const op_tmp: !TokenType = expr.unary_expr_op as! TokenType;
        const op: TokenType = op_tmp.value;
        if op == TokenType.TOKEN_PLUS { return operand_val; }
        else if op == TokenType.TOKEN_MINUS {
            if check_i32_neg_overflow(operand_val) != 0 { return -1; }
            return -operand_val;
        } else { return -1; }
    } else if expr.type == ASTNodeType.AST_LEN {
        const array_expr: &ASTNode = expr.len_expr_array;
        if array_expr == null { return -1; }
        var array_type: Type = checker_infer_type(checker, array_expr);
        if array_type.kind == TypeKind.TYPE_ARRAY {
            return array_type.array_size;
        }
        if block != null && array_expr.type == ASTNodeType.AST_IDENTIFIER && array_expr.identifier_name != null {
            const decl: &ASTNode = find_decl_in_block(block, array_expr.identifier_name);
            if decl != null && decl.var_decl_type != null {
                array_type = type_from_ast(checker, decl.var_decl_type);
                if array_type.kind == TypeKind.TYPE_ARRAY {
                    return array_type.array_size;
                }
            }
        }
        return -1;
    } else if expr.type == ASTNodeType.AST_SIZEOF {
        const target: &ASTNode = expr.sizeof_expr_target;
        if target == null { return -1; }
        var t: Type = checker_infer_type(checker, target);
        if expr.sizeof_expr_is_type != 0 {
            if target.type == ASTNodeType.AST_TYPE_FRAME {
                const frame_size: i32 = get_async_frame_size_bytes(checker, target);
                if frame_size > 0 {
                    return frame_size;
                }
            }
            t = type_from_ast(checker, target);
        }
        return get_type_size_bytes(&t);
    } else if expr.type == ASTNodeType.AST_ALIGNOF {
        const target: &ASTNode = expr.alignof_expr_target;
        if target == null { return -1; }
        var t: Type = checker_infer_type(checker, target);
        if expr.alignof_expr_is_type != 0 {
            t = type_from_ast(checker, target);
        }
        return get_type_align_bytes(&t);
    } else if expr.type == ASTNodeType.AST_CAST_EXPR {
        const inner_expr: &ASTNode = expr.cast_expr_expr;
        if inner_expr == null { return -1; }
        return checker_eval_const_expr_in_block(checker, inner_expr, block);
    } else {
        return -1;
    }
}

// ===== 错误报告函数 =====

enum CheckerNoteKind {
    NOTE_DECLARATION,
    NOTE_SUGGESTION,
}

struct CheckerNote {
    node: &ASTNode,
    message: &byte,
    kind: CheckerNoteKind,
}

// 辅助：输出单个 note
fn checker_print_note(checker: &TypeChecker, note: &CheckerNote) void {
    if checker == null || note == null || note.message == null || libc.stderr == null {
        return;
    }
    var filename: &byte = "(unknown)" as *byte;
    if note.node != null && note.node.filename != null {
        filename = note.node.filename;
    } else if checker.default_filename != null {
        filename = checker.default_filename;
    }
    var kind_str: &byte = "附注" as *byte;
    if note.kind == CheckerNoteKind.NOTE_SUGGESTION {
        kind_str = "建议" as *byte;
    }
    if note.node != null {
        fprintf(libc.stderr, "%s:(%d:%d): %s: %s\n" as *byte, filename, note.node.line, note.node.column, kind_str, note.message as *byte);
    } else {
        fprintf(libc.stderr, "%s: %s: %s\n" as *byte, filename, kind_str, note.message as *byte);
    }
}

// 报告类型检查错误，附带 note 列表
fn checker_report_error_with_notes(checker: &TypeChecker, node: &ASTNode, message: &byte, notes: &CheckerNote, note_count: i32) void {
    if checker != null {
        last_checker_error_message = stash_checker_error_message(message);
        checker.error_count = checker.error_count + 1;
        if libc.stderr != null && message != null {
            var filename: &byte = "(unknown)" as *byte;
            if node != null && node.filename != null {
                filename = node.filename;
            } else if checker.default_filename != null {
                filename = checker.default_filename;
            }
            const out_msg: &byte = last_checker_error_message;
            if node != null {
                fprintf(libc.stderr, "%s:(%d:%d): 错误: %s\n" as *byte, filename, node.line, node.column, out_msg as *byte);
            } else {
                fprintf(libc.stderr, "%s: 错误: %s\n" as *byte, filename, out_msg as *byte);
            }
            var i: i32 = 0;
            while i < note_count {
                checker_print_note(checker, &notes[i]);
                i = i + 1;
            }
        }
    }
}

// 报告类型检查错误，附带单个 note
fn checker_report_error_with_note(checker: &TypeChecker, node: &ASTNode, message: &byte, note_node: &ASTNode, note_message: &byte, note_kind: i32) void {
    var note: CheckerNote = CheckerNote{};
    note.node = note_node;
    note.message = note_message;
    note.kind = note_kind;
    checker_report_error_with_notes(checker, node, message, &note, 1);
}

// 把 message 拷入 last_checker_error_storage，返回稳定指针（message 为 null 则返回 null）
fn stash_checker_error_message(message: &byte) &byte {
    if message == null {
        return null;
    }
    var i: i32 = 0;
    while i < 511 {
        const c: byte = message[i];
        if c == 0 as byte {
            break;
        }
        last_checker_error_storage[i] = c;
        i = i + 1;
    }
    if i >= 0 && i < 512 {
        last_checker_error_storage[i] = 0 as byte;
    }
    return &last_checker_error_storage[0] as &byte;
}

// 报告类型检查错误
fn checker_report_error(checker: &TypeChecker, node: &ASTNode, message: &byte) void {
    if checker != null {
        last_checker_error_message = stash_checker_error_message(message);
        checker.error_count = checker.error_count + 1;
        if libc.stderr != null && message != null {
            var filename: &byte = "(unknown)" as *byte;
            if node != null && node.filename != null {
                filename = node.filename;
            } else if checker.default_filename != null {
                filename = checker.default_filename;
            }
            const out_msg: &byte = last_checker_error_message;
            if node != null {
                fprintf(libc.stderr, "%s:(%d:%d): 错误: %s\n" as *byte, filename, node.line, node.column, out_msg as *byte);
            } else {
                fprintf(libc.stderr, "%s: 错误: %s\n" as *byte, filename, out_msg as *byte);
            }
        }
    }
}

// 报告「变量已被移动」错误，并指出具体变量名
fn checker_report_error_moved(checker: &TypeChecker, node: &ASTNode, var_name: &byte) void {
    if checker != null {
        last_checker_error_message = "变量已被移动，不能再次使用" as *byte;
        checker.error_count = checker.error_count + 1;
        if libc.stderr != null {
            var filename: &byte = "(unknown)" as *byte;
            if node != null && node.filename != null {
                filename = node.filename;
            } else if checker.default_filename != null {
                filename = checker.default_filename;
            }
            if node != null {
                if var_name != null && var_name[0] != 0 {
                    fprintf(libc.stderr, "%s:(%d:%d): 错误: 变量 '%s' 已被移动，不能再次使用\n" as *byte, filename, node.line, node.column, var_name as *byte);
                } else {
                    fprintf(libc.stderr, "%s:(%d:%d): 错误: 变量已被移动，不能再次使用\n" as *byte, filename, node.line, node.column);
                }
            } else {
                if var_name != null && var_name[0] != 0 {
                    fprintf(libc.stderr, "%s: 错误: 变量 '%s' 已被移动，不能再次使用\n" as *byte, filename, var_name as *byte);
                } else {
                    fprintf(libc.stderr, "%s: 错误: 变量已被移动，不能再次使用\n" as *byte, filename);
                }
            }
        }
    }
}

// 报告证明失败错误（扩展版本）
fn checker_report_error_ex(checker: &TypeChecker, node: &ASTNode, error_type: &byte, var_name: &byte, size: i32) void {
    if checker != null {
        if was_error_reported(var_name, size) != 0 {
            return;
        }
        
        checker.error_count = checker.error_count + 1;
        if libc.stderr != null {
            var filename: &byte = "(unknown)" as *byte;
            if node != null && node.filename != null {
                filename = node.filename;
            } else if checker.default_filename != null {
                filename = checker.default_filename;
            }
            if node != null {
                fprintf(libc.stderr, "%s:(%d:%d): 错误: %s\n" as *byte, filename, node.line, node.column, error_type as *byte);
            } else {
                fprintf(libc.stderr, "%s: 错误: %s\n" as *byte, filename, error_type as *byte);
            }
            if var_name != null {
                fprintf(libc.stderr, "  变量: %s, 数组大小: %d\n" as *byte, var_name as *byte, size);
            }
            fprintf(libc.stderr, "  建议: 添加边界检查 (如 if %s >= 0 && %s < %d)\n" as *byte, 
                var_name as *byte, var_name as *byte, size);
        }
        mark_error_reported(var_name, size);
        last_checker_error_message = error_type;
    }
}

// ===== 证明步骤管理 =====

// 证明步数递增和超限检查
fn checker_proof_step(checker: &TypeChecker, node: &ASTNode) i32 {
    if checker == null {
        return 0;
    }
    checker.proof_step_count = checker.proof_step_count + 1;
    if checker.proof_step_count > checker.proof_step_limit {
        checker_report_error(checker, node, "证明超时：证明步数超过限制，请简化代码或添加显式检查" as *byte);
        return 0;
    }
    return 1;
}

// 重置证明步数计数器
fn checker_reset_proof_steps(checker: &TypeChecker) void {
    if checker != null {
        checker.proof_step_count = 0;
        for 0..@len(checker.constraint_var_names) |i| {
            checker.constraint_var_names[i] = null;
            checker.constraint_ops[i] = 0;
            checker.constraint_values[i] = 0;
        }
        checker.constraint_count = 0;
        for 0..@len(checker.pointer_nonnull_names) |i| {
            checker.pointer_nonnull_names[i] = null;
        }
        checker.pointer_nonnull_count = 0;
    }
}

// ===== P1: 越界访问检测（编译期静态分析） =====

// 越界访问风险等级
export enum BoundsCheckRisk {
    BOUNDS_SAFE,        // 已证明安全
    BOUNDS_WARNING,     // 可能越界（需要警告）
    BOUNDS_ERROR        // 确定越界
}

// 越界访问检测结果
export struct BoundsCheckResult {
    risk: i32,          // BoundsCheckRisk 值
    index_value: i32,   // 索引值（常量时有效）
    array_size: i32,    // 数组大小
    message: &byte      // 错误/警告消息
}

// 检测数组访问是否可能越界（常量索引检测）
export fn check_array_bounds_const(checker: &TypeChecker, array_expr: &ASTNode, index_expr: &ASTNode) BoundsCheckResult {
    var result: BoundsCheckResult = BoundsCheckResult{
        risk: BoundsCheckRisk.BOUNDS_SAFE as i32,
        index_value: -1,
        array_size: 0,
        message: null
    };
    
    if checker == null || array_expr == null || index_expr == null {
        return result;
    }
    
    // 获取数组类型和大小
    const array_type: Type = checker_infer_type(checker, array_expr);
    if array_type.kind != TypeKind.TYPE_ARRAY {
        return result;
    }
    result.array_size = array_type.array_size;
    
    // 检查索引是否为常量
    if is_constant_expression(checker, index_expr) != 0 {
        const index_value: i32 = checker_eval_const_expr(checker, index_expr);
        result.index_value = index_value;
        
        if index_value < 0 || index_value >= result.array_size {
            result.risk = BoundsCheckRisk.BOUNDS_ERROR as i32;
            result.message = "数组索引越界：索引值超出数组边界" as &byte;
        } else {
            result.risk = BoundsCheckRisk.BOUNDS_SAFE as i32;
        }
    }
    
    return result;
}

// 检测指针算术是否可能越界
export fn check_pointer_arithmetic_bounds(checker: &TypeChecker, ptr_expr: &ASTNode, offset_expr: &ASTNode, base_size: i32) BoundsCheckResult {
    var result: BoundsCheckResult = BoundsCheckResult{
        risk: BoundsCheckRisk.BOUNDS_SAFE as i32,
        index_value: -1,
        array_size: base_size,
        message: null
    };
    
    if checker == null || ptr_expr == null || offset_expr == null {
        return result;
    }
    
    // 检查偏移是否为常量
    if is_constant_expression(checker, offset_expr) != 0 {
        const offset_value: i32 = checker_eval_const_expr(checker, offset_expr);
        result.index_value = offset_value;
        
        // 如果知道数组大小，检查是否越界
        if base_size > 0 {
            if offset_value < 0 || offset_value >= base_size {
                result.risk = BoundsCheckRisk.BOUNDS_WARNING as i32;
                result.message = "指针算术可能越界：偏移超出已知边界" as &byte;
            }
        }
        
        // 负偏移需要特别关注
        if offset_value < 0 {
            result.risk = BoundsCheckRisk.BOUNDS_WARNING as i32;
            result.message = "指针算术：负偏移需要证明安全" as &byte;
        }
    }
    
    return result;
}

// 检测切片边界是否可能越界
export fn check_slice_bounds(checker: &TypeChecker, array_expr: &ASTNode, start_expr: &ASTNode, len_expr: &ASTNode) BoundsCheckResult {
    var result: BoundsCheckResult = BoundsCheckResult{
        risk: BoundsCheckRisk.BOUNDS_SAFE as i32,
        index_value: -1,
        array_size: 0,
        message: null
    };
    
    if checker == null || array_expr == null {
        return result;
    }
    
    // 字符串字面量：与 [byte:strlen+1] 一致（含结尾 0），供编译期切片边界检查
    if array_expr.type == ASTNodeType.AST_STRING && array_expr.string_literal_value != null {
        const sl_tmp: !i32 = strlen(array_expr.string_literal_value as *byte) as! i32;
        const sl: i32 = sl_tmp.value;
        result.array_size = sl + 1;
    } else {
        const array_type: Type = checker_infer_type(checker, array_expr);
        if array_type.kind != TypeKind.TYPE_ARRAY {
            return result;
        }
        result.array_size = array_type.array_size;
    }
    
    // 检查起始位置
    if start_expr != null && is_constant_expression(checker, start_expr) != 0 {
        const start_value: i32 = checker_eval_const_expr(checker, start_expr);
        
        // 处理负数索引
        var actual_start: i32 = start_value;
        if start_value < 0 {
            actual_start = result.array_size + start_value;
        }
        
        if actual_start < 0 || actual_start > result.array_size {
            result.risk = BoundsCheckRisk.BOUNDS_ERROR as i32;
            result.message = "切片起始位置越界" as &byte;
            return result;
        }
    }
    
    // 检查长度
    if len_expr != null && is_constant_expression(checker, len_expr) != 0 {
        const len_value: i32 = checker_eval_const_expr(checker, len_expr);
        
        if len_value < 0 {
            result.risk = BoundsCheckRisk.BOUNDS_ERROR as i32;
            result.message = "切片长度不能为负数" as &byte;
            return result;
        }
        
        if start_expr != null && is_constant_expression(checker, start_expr) != 0 {
            const start_value: i32 = checker_eval_const_expr(checker, start_expr);
            var actual_start: i32 = start_value;
            if start_value < 0 {
                actual_start = result.array_size + start_value;
            }
            
            if actual_start + len_value > result.array_size {
                result.risk = BoundsCheckRisk.BOUNDS_ERROR as i32;
                result.message = "切片结束位置越界" as &byte;
                return result;
            }
        }
    }
    
    return result;
}

// 全程序越界访问检测 Pass
export fn bounds_check_pass(checker: &TypeChecker, node: &ASTNode) void {
    if node == null || checker == null {
        return;
    }
    
    // 处理程序顶层
    if node.type == ASTNodeType.AST_PROGRAM && node.program_decls != null {
        var i: i32 = 0;
        while i < node.program_decl_count {
            bounds_check_pass(checker, node.program_decls[i]);
            i = i + 1;
        }
        return;
    }
    
    // 检测数组访问
    if node.type == ASTNodeType.AST_ARRAY_ACCESS {
        const result: BoundsCheckResult = check_array_bounds_const(checker, node.array_access_array, node.array_access_index);
        
        if result.risk == BoundsCheckRisk.BOUNDS_ERROR as i32 {
            checker_report_error(checker, node, result.message);
        } else if result.risk == BoundsCheckRisk.BOUNDS_WARNING as i32 && result.message != null {
            // 警告级别，仅输出提示
            if libc.stderr != null {
                fprintf(libc.stderr, "%s:(%d:%d): 警告: %s\n" as *byte, 
                    node.filename as *byte, node.line, node.column, result.message as *byte);
            }
        }
    }
    
    // 检测切片操作
    if node.type == ASTNodeType.AST_SLICE_EXPR {
        const result: BoundsCheckResult = check_slice_bounds(checker, node.slice_expr_base, node.slice_expr_start_expr, node.slice_expr_len_expr);
        
        if result.risk == BoundsCheckRisk.BOUNDS_ERROR as i32 {
            checker_report_error(checker, node, result.message);
        }
    }
    
    // 递归处理子节点
    if node.type == ASTNodeType.AST_BINARY_EXPR {
        bounds_check_pass(checker, node.binary_expr_left);
        bounds_check_pass(checker, node.binary_expr_right);
    } else if node.type == ASTNodeType.AST_UNARY_EXPR {
        bounds_check_pass(checker, node.unary_expr_operand);
    } else if node.type == ASTNodeType.AST_CALL_EXPR {
        if node.call_expr_args != null {
            var i: i32 = 0;
            while i < node.call_expr_arg_count {
                bounds_check_pass(checker, node.call_expr_args[i]);
                i = i + 1;
            }
        }
    } else if node.type == ASTNodeType.AST_MEMBER_ACCESS {
        bounds_check_pass(checker, node.member_access_object);
    } else if node.type == ASTNodeType.AST_ARRAY_ACCESS {
        bounds_check_pass(checker, node.array_access_array);
        bounds_check_pass(checker, node.array_access_index);
    } else if node.type == ASTNodeType.AST_VAR_DECL && node.var_decl_init != null {
        bounds_check_pass(checker, node.var_decl_init);
    } else if node.type == ASTNodeType.AST_IF_STMT {
        bounds_check_pass(checker, node.if_stmt_condition);
        if node.if_stmt_then_branch != null {
            bounds_check_pass(checker, node.if_stmt_then_branch);
        }
        if node.if_stmt_else_branch != null {
            bounds_check_pass(checker, node.if_stmt_else_branch);
        }
    } else if node.type == ASTNodeType.AST_WHILE_STMT {
        bounds_check_pass(checker, node.while_stmt_condition);
        if node.while_stmt_body != null {
            bounds_check_pass(checker, node.while_stmt_body);
        }
    } else if node.type == ASTNodeType.AST_FOR_STMT {
        if node.for_stmt_array != null {
            bounds_check_pass(checker, node.for_stmt_array);
        }
        if node.for_stmt_body != null {
            bounds_check_pass(checker, node.for_stmt_body);
        }
    } else if node.type == ASTNodeType.AST_BLOCK && node.block_stmts != null {
        var i: i32 = 0;
        while i < node.block_stmt_count {
            bounds_check_pass(checker, node.block_stmts[i]);
            i = i + 1;
        }
    } else if node.type == ASTNodeType.AST_FN_DECL && node.fn_decl_body != null {
        bounds_check_pass(checker, node.fn_decl_body);
    } else if node.type == ASTNodeType.AST_RETURN_STMT && node.return_stmt_expr != null {
        bounds_check_pass(checker, node.return_stmt_expr);
    } else if node.type == ASTNodeType.AST_SLICE_EXPR {
        if node.slice_expr_base != null {
            bounds_check_pass(checker, node.slice_expr_base);
        }
        if node.slice_expr_start_expr != null {
            bounds_check_pass(checker, node.slice_expr_start_expr);
        }
        if node.slice_expr_len_expr != null {
            bounds_check_pass(checker, node.slice_expr_len_expr);
        }
    }
}

// ============================================================
// 编译期状态机大小计算（用于 @async_fn 验证）
// ============================================================

// 扩展类型字节大小计算：支持 struct/union/interface/error_union/atomic/slice
// - 返回计算出的字节数（>= 0）
// - 返回 -1 表示大小未知（复杂嵌套结构、多态接口等）
// program_node：用于查找 struct/union 定义；checker：从 AST 字段解析 Type 时需要
fn get_type_size_bytes_v2(checker: &TypeChecker, t: &Type, program_node: &ASTNode) i32 {
    if t == null {
        return -1;
    }
    // 基础标量类型
    if t.kind == TypeKind.TYPE_I8 || t.kind == TypeKind.TYPE_U8 || t.kind == TypeKind.TYPE_BOOL || t.kind == TypeKind.TYPE_BYTE {
        return 1;
    }
    if t.kind == TypeKind.TYPE_I16 || t.kind == TypeKind.TYPE_U16 {
        return 2;
    }
    if t.kind == TypeKind.TYPE_I32 || t.kind == TypeKind.TYPE_U32 || t.kind == TypeKind.TYPE_F32 {
        return 4;
    }
    if t.kind == TypeKind.TYPE_I64 || t.kind == TypeKind.TYPE_U64 || t.kind == TypeKind.TYPE_F64 || t.kind == TypeKind.TYPE_USIZE {
        return 8;
    }
    // 指针：64 位平台 8 字节
    if t.kind == TypeKind.TYPE_POINTER {
        return 8;
    }
    // 原子类型：内部类型大小
    if t.kind == TypeKind.TYPE_ATOMIC {
        const inner: &Type = type_get_atomic_inner(t);
        if inner != null {
            return get_type_size_bytes_v2(checker, inner, program_node);
        }
        return -1;
    }
    // 固定大小数组
    if t.kind == TypeKind.TYPE_ARRAY {
        const elem_sz: i32 = get_type_size_bytes_v2(checker, t.element_type, program_node);
        if elem_sz > 0 && t.array_size > 0 && t.array_size <= 0x7FFFFFFF / elem_sz {
            return elem_sz * t.array_size;
        }
        return -1;
    }
    // 切片：ptr + len（16 字节）
    if t.kind == TypeKind.TYPE_SLICE {
        return 16;
    }
    // 元组：递归求和
    if t.kind == TypeKind.TYPE_TUPLE && t.tuple_count > 0 && t.tuple_element_types != null {
        var total: i32 = 0;
        var i: i32 = 0;
        while i < t.tuple_count {
            const ft: &Type = &t.tuple_element_types[i];
            const fs: i32 = get_type_size_bytes_v2(checker, ft, program_node);
            if fs < 0 {
                return -1;
            }
            total = total + fs;
            i = i + 1;
        }
        return total;
    }
    // 错误联合：payload 大小（error_id 占 4 字节，i32 对齐）
    if t.kind == TypeKind.TYPE_ERROR_UNION {
        const payload: &Type = type_get_error_payload(t);
        if payload != null {
            const ps: i32 = get_type_size_bytes_v2(checker, payload, program_node);
            if ps < 0 {
                return -1;
            }
            // 对齐到 4 字节边界
            if ps < 4 {
                return 4;
            }
            return ps;
        }
        return 4;
    }
    // 命名 struct：查找字段定义
    if t.kind == TypeKind.TYPE_STRUCT && t.struct_name != null && program_node != null {
        const decl: &ASTNode = find_struct_decl_from_program(program_node, t.struct_name as *byte);
        if decl != null && decl.struct_decl_fields != null && decl.struct_decl_field_count > 0 {
            return compute_struct_size(checker, decl, program_node);
        }
        return -1;
    }
    // 命名 union：最大字段大小
    if t.kind == TypeKind.TYPE_UNION && t.union_name != null && program_node != null {
        const decl: &ASTNode = find_struct_decl_from_program(program_node, t.union_name as *byte);
        if decl != null && decl.struct_decl_fields != null && decl.struct_decl_field_count > 0 {
            return compute_union_size(checker, decl, program_node);
        }
        return -1;
    }
    // 接口：vtable ptr + data ptr（16 字节）
    if t.kind == TypeKind.TYPE_INTERFACE {
        return 16;
    }
    // vararg、vector、mask 等未知大小
    return -1;
}

// 计算 struct 总字节大小（字段求和），返回 -1 表示含未知大小字段
fn compute_struct_size(checker: &TypeChecker, decl: &ASTNode, program_node: &ASTNode) i32 {
    if decl == null || decl.struct_decl_field_count <= 0 || decl.struct_decl_fields == null {
        return 0;
    }
    var total: i32 = 0;
    var i: i32 = 0;
    while i < decl.struct_decl_field_count {
        const field: &ASTNode = decl.struct_decl_fields[i];
        if field == null || field.type != ASTNodeType.AST_VAR_DECL || field.var_decl_type == null {
            i = i + 1;
            continue;
        }
        const ft: Type = type_from_ast(checker, field.var_decl_type);
        const fs: i32 = get_type_size_bytes_v2(checker, &ft, program_node);
        if fs < 0 {
            return -1;
        }
        total = total + fs;
        i = i + 1;
    }
    return total;
}

// 计算 union 最大字段字节大小，返回 -1 表示含未知大小字段
fn compute_union_size(checker: &TypeChecker, decl: &ASTNode, program_node: &ASTNode) i32 {
    if decl == null || decl.struct_decl_field_count <= 0 || decl.struct_decl_fields == null {
        return 0;
    }
    var max_sz: i32 = 0;
    var i: i32 = 0;
    while i < decl.struct_decl_field_count {
        const field: &ASTNode = decl.struct_decl_fields[i];
        if field == null || field.type != ASTNodeType.AST_VAR_DECL || field.var_decl_type == null {
            i = i + 1;
            continue;
        }
        const ft: Type = type_from_ast(checker, field.var_decl_type);
        const fs: i32 = get_type_size_bytes_v2(checker, &ft, program_node);
        if fs < 0 {
            return -1;
        }
        if fs > max_sz {
            max_sz = fs;
        }
        i = i + 1;
    }
    return max_sz;
}

// 计算 @async_fn 状态机近似字节大小。
// 返回值：
//   >= 0  : 计算出的近似字节数
//   -1    : 含未知大小字段，只能用堆分配
//   -2    : 检测到错误（参数类型无法解析等）
//
// 状态机布局：
//   1. state (i32)                         = 4 字节
//   2. [条件] _uya_await_storage (Future<T>)  ≈ Future 内部 payload 大小
//   3. await_fut (interface Future<T>)      = 16 字节（vtable + data）
//   4. [条件] _uya_total + _uya_read_n      = 16 字节（两个 size_t）
//   5. 每 await 一个 _uya_bind_<name>       = await_bind_types 各字段大小之和
//   6. 每 captured param 一个字段           = 各参数类型大小之和
fn compute_async_state_machine_size(
    checker: &TypeChecker,
    fn_decl: &ASTNode,
    await_count: i32,
    await_bind_types: [&ASTNode: 32],
    has_await_loop: i32,
    program_node: &ASTNode
) i32 {
    if fn_decl == null {
        return -2;
    }
    // 1. state
    var total: i32 = 4;
    // 2. _uya_await_storage（仅在 await_operand_is_err_future 时存在）
    //    该字段大小取决于 Future<T> 的 payload，即 error_union 负载大小。
    //    保守估计：如果任意 await 的绑定类型含 Future 或无法计算，用 16 估算。
    var has_future_storage: i32 = 0;
    var ai: i32 = 0;
    while ai < await_count && ai < 32 {
        const bind_type_node: &ASTNode = await_bind_types[ai];
        if bind_type_node != null {
            const bt: Type = type_from_ast(checker, bind_type_node);
            if bt.kind == TypeKind.TYPE_STRUCT {
                const bn: &byte = type_get_struct_name(&bt);
                if bn != null && strlen(bn as *byte) >= 6 &&
                    strncmp(bn as *byte, "Future" as *byte, 6) == 0 {
                    has_future_storage = 1;
                }
            }
        }
        ai = ai + 1;
    }
    if has_future_storage != 0 {
        // 保守估计 await_fut interface 大小
        total = total + 16;
    }
    // 3. await_fut interface
    total = total + 16;
    // 4. 循环内 await 的 total/read_n
    if has_await_loop != 0 {
        total = total + 16;
    }
    // 5. await 绑定变量
    ai = 0;
    while ai < await_count && ai < 32 {
        const bind_type_node: &ASTNode = await_bind_types[ai];
        if bind_type_node != null {
            const bt: Type = type_from_ast(checker, bind_type_node);
            const bs: i32 = get_type_size_bytes_v2(checker, &bt, program_node);
            if bs < 0 {
                return -1;
            }
            total = total + bs;
        }
        ai = ai + 1;
    }
    // 6. 捕获的参数
    const param_count: i32 = fn_decl.fn_decl_param_count;
    const params: & &ASTNode = fn_decl.fn_decl_params;
    var pi: i32 = 0;
    while pi < param_count && pi < 16 {
        const param: &ASTNode = params[pi];
        if param != null && param.type == ASTNodeType.AST_VAR_DECL && param.var_decl_type != null {
            const pt: Type = type_from_ast(checker, param.var_decl_type);
            const ps: i32 = get_type_size_bytes_v2(checker, &pt, program_node);
            if ps < 0 {
                return -1;
            }
            total = total + ps;
        }
        pi = pi + 1;
    }
    return total;
}

// ============================================================
// @async_fn 状态机转换正确性验证
// 验证内容：
// 1. @await 不出现在 return 之后的 unreachable 代码中
// 2. @await 不出现在循环条件表达式中（while/for 条件里 await 会导致每次重试重新获取）
// 3. 每个 @await 绑定变量只赋值一次（状态机单程假设）
// 4. 函数最后必须是 return 语句（不能有悬空控制流）
// 5. @await 在 try 表达式内部（必须配合 try）
// ============================================================

// 递归收集状态机信息并验证（使用 if/else if 链）
fn validate_async_body(
    checker: &TypeChecker,
    node: &ASTNode,
    in_try: i32,
    seen_return: &i32,
    errors: &i32
) void {
    if node == null || errors == null { return; }

    if node.type == ASTNodeType.AST_BLOCK {
        if node.block_stmts != null {
            var i: i32 = 0;
            while i < node.block_stmt_count {
                validate_async_body(checker, node.block_stmts[i], in_try, seen_return, errors);
                i = i + 1;
            }
        }
    } else if node.type == ASTNodeType.AST_RETURN_STMT {
        if seen_return != null {
            *seen_return = 1;
        }
    } else if node.type == ASTNodeType.AST_TRY_EXPR {
        validate_async_body(checker, node.try_expr_operand, 1, seen_return, errors);
    } else if node.type == ASTNodeType.AST_AWAIT_EXPR {
        // 注意：@await 不在 try 内的检查已由 checker_check_node -> check_call.uya 处理
        // 这里只检查 return 之后的 unreachable await
        if seen_return != null && *seen_return != 0 {
            *errors = *errors + 1;
        }
    } else if node.type == ASTNodeType.AST_IF_STMT {
        // if 分支：分别追踪，然后合并
        // 若两个分支都 return，则 if 之后的代码 unreachable
        var then_seen: i32 = 0;
        var else_seen: i32 = 0;
        if node.if_stmt_then_branch != null {
            validate_async_body(checker, node.if_stmt_then_branch, in_try, &then_seen, errors);
        }
        if node.if_stmt_else_branch != null {
            validate_async_body(checker, node.if_stmt_else_branch, in_try, &else_seen, errors);
        }
        // 合并：只有两个分支都 return，if 之后的代码才 unreachable
        if seen_return != null {
            if then_seen != 0 && else_seen != 0 {
                *seen_return = 1;
            }
        }
    } else if node.type == ASTNodeType.AST_WHILE_STMT {
        if node.while_stmt_condition != null {
            if has_await_in_expr(node.while_stmt_condition) != 0 {
                *errors = *errors + 1;
            }
        }
        if node.while_stmt_body != null {
            var while_seen: i32 = 0;
            validate_async_body(checker, node.while_stmt_body, in_try, &while_seen, errors);
        }
    } else if node.type == ASTNodeType.AST_FOR_STMT {
        if node.for_stmt_range_start != null && has_await_in_expr(node.for_stmt_range_start) != 0 {
            *errors = *errors + 1;
        }
        if node.for_stmt_range_end != null && has_await_in_expr(node.for_stmt_range_end) != 0 {
            *errors = *errors + 1;
        }
        if node.for_stmt_body != null {
            var for_seen: i32 = 0;
            validate_async_body(checker, node.for_stmt_body, in_try, &for_seen, errors);
        }
    } else if node.type == ASTNodeType.AST_VAR_DECL {
        validate_async_body(checker, node.var_decl_init, in_try, seen_return, errors);
    } else if node.type == ASTNodeType.AST_ASSIGN {
        validate_async_body(checker, node.assign_dest, in_try, seen_return, errors);
        validate_async_body(checker, node.assign_src, in_try, seen_return, errors);
    } else {
        // 其他节点类型（字面量、标识符、运算符等）：不包含可执行代码，无需处理
    }
}

// 检查表达式中是否包含 @await（用于条件表达式检测）
fn has_await_in_expr(node: &ASTNode) i32 {
    if node == null { return 0; }
    if node.type == ASTNodeType.AST_AWAIT_EXPR { return 1; }
    if node.type == ASTNodeType.AST_TRY_EXPR && node.try_expr_operand != null {
        return has_await_in_expr(node.try_expr_operand);
    }
    // 仅对有子节点的表达式节点递归
    if node.type == ASTNodeType.AST_BLOCK && node.block_stmts != null {
        var i: i32 = 0;
        while i < node.block_stmt_count {
            if has_await_in_expr(node.block_stmts[i]) != 0 { return 1; }
            i = i + 1;
        }
    }
    if node.type == ASTNodeType.AST_CALL_EXPR && node.call_expr_args != null {
        var i: i32 = 0;
        while i < node.call_expr_arg_count {
            if has_await_in_expr(node.call_expr_args[i]) != 0 { return 1; }
            i = i + 1;
        }
    }
    if node.type == ASTNodeType.AST_VAR_DECL && node.var_decl_init != null {
        return has_await_in_expr(node.var_decl_init);
    }
    if node.type == ASTNodeType.AST_ASSIGN {
        if has_await_in_expr(node.assign_src) != 0 { return 1; }
        return has_await_in_expr(node.assign_dest);
    }
    if node.type == ASTNodeType.AST_IF_STMT {
        if has_await_in_expr(node.if_stmt_condition) != 0 { return 1; }
        if has_await_in_expr(node.if_stmt_then_branch) != 0 { return 1; }
        return has_await_in_expr(node.if_stmt_else_branch);
    }
    if node.type == ASTNodeType.AST_WHILE_STMT {
        if has_await_in_expr(node.while_stmt_condition) != 0 { return 1; }
        return has_await_in_expr(node.while_stmt_body);
    }
    if node.type == ASTNodeType.AST_FOR_STMT {
        if has_await_in_expr(node.for_stmt_range_start) != 0 { return 1; }
        if has_await_in_expr(node.for_stmt_range_end) != 0 { return 1; }
        if has_await_in_expr(node.for_stmt_array) != 0 { return 1; }
        return has_await_in_expr(node.for_stmt_body);
    }
    if node.type == ASTNodeType.AST_RETURN_STMT {
        return has_await_in_expr(node.return_stmt_expr);
    }
    if node.type == ASTNodeType.AST_BINARY_EXPR {
        if has_await_in_expr(node.binary_expr_left) != 0 { return 1; }
        return has_await_in_expr(node.binary_expr_right);
    }
    if node.type == ASTNodeType.AST_UNARY_EXPR {
        return has_await_in_expr(node.unary_expr_operand);
    }
    if node.type == ASTNodeType.AST_MEMBER_ACCESS {
        return has_await_in_expr(node.member_access_object);
    }
    if node.type == ASTNodeType.AST_ARRAY_ACCESS {
        if has_await_in_expr(node.array_access_array) != 0 { return 1; }
        return has_await_in_expr(node.array_access_index);
    }
    if node.type == ASTNodeType.AST_CAST_EXPR {
        return has_await_in_expr(node.cast_expr_expr);
    }
    return 0;
}

// 验证 @async_fn 函数体状态机结构正确性
// 在 checker 阶段调用，errors > 0 表示有错误
fn validate_async_function(checker: &TypeChecker, fn_node: &ASTNode) i32 {
    if fn_node == null || fn_node.fn_decl_body == null { return 0; }
    var errors: i32 = 0;
    var seen_return: i32 = 0;
    validate_async_body(checker, fn_node.fn_decl_body, 0, &seen_return, &errors);
    return errors;
}
