// ===== 错误联合类型访问器 =====

// 获取错误联合负载类型
fn type_get_error_payload(t: &Type) &Type {
    if t == null || t.kind != TypeKind.TYPE_ERROR_UNION {
        return null as &Type;
    }
    match t.data {
        .error_union(eu) => { return eu.payload; },
        else => { return null as &Type; },
    }
}

// 获取错误 ID
fn type_get_error_id(t: &Type) u32 {
    if t == null || t.kind != TypeKind.TYPE_ERROR_UNION {
        return 0;
    }
    match t.data {
        .error_union(eu) => { return eu.error_id; },
        else => { return 0; },
    }
}

// ===== 原子类型访问器 =====

// 获取原子内部类型
fn type_get_atomic_inner(t: &Type) &Type {
    if t == null || t.kind != TypeKind.TYPE_ATOMIC {
        return null as &Type;
    }
    match t.data {
        .atomic_data(a) => { return a.inner; },
        else => { return null as &Type; },
    }
}

// ===== 泛型参数访问器 =====

// 获取泛型参数名称
fn type_get_generic_param_name(t: &Type) &byte {
    if t == null || t.kind != TypeKind.TYPE_GENERIC_PARAM {
        return null as &byte;
    }
    match t.data {
        .generic_param(gp) => { return gp.name; },
        else => { return null as &byte; },
    }
}

// ===== 结构体泛型访问器 =====

// 获取结构体类型参数
fn type_get_struct_type_args(t: &Type) &Type {
    if t == null || t.kind != TypeKind.TYPE_STRUCT {
        return null as &Type;
    }
    match t.data {
        .struct_generic(sg) => { return sg.type_args; },
        else => { return null as &Type; },
    }
}

// 获取结构体类型参数数量
fn type_get_struct_type_arg_count(t: &Type) i32 {
    if t == null || t.kind != TypeKind.TYPE_STRUCT {
        return 0;
    }
    match t.data {
        .struct_generic(sg) => { return sg.type_arg_count; },
        else => { return 0; },
    }
}

// ===== 类型设置器函数（用于构造函数）=====

// 设置命名类型名称
fn type_set_name(t: &Type, name: &byte) void {
    if t == null {
        return;
    }
    t.data = TypeData.named(name);
}

// 设置指针类型数据
fn type_set_pointer(t: &Type, pointee: &Type, is_ffi: i32) void {
    if t == null {
        return;
    }
    var pd: PointerData = PointerData{
        pointee: pointee,
        is_ffi: is_ffi,
    };
    t.data = TypeData.pointer(pd);
}

// 设置数组类型数据
fn type_set_array(t: &Type, element: &Type, size: i32) void {
    if t == null {
        return;
    }
    var ad: ArrayData = ArrayData{
        element: element,
        size: size,
    };
    t.data = TypeData.array(ad);
}

// 设置切片类型数据
fn type_set_slice(t: &Type, element: &Type, len: i32) void {
    if t == null {
        return;
    }
    var sd: SliceData = SliceData{
        element: element,
        len: len,
    };
    t.data = TypeData.slice(sd);
}

// 设置元组类型数据
fn type_set_tuple(t: &Type, elements: &Type, count: i32) void {
    if t == null {
        return;
    }
    var td: TupleData = TupleData{
        elements: elements,
        count: count,
    };
    t.data = TypeData.tuple(td);
}

// 设置错误联合类型数据
fn type_set_error_union(t: &Type, payload: &Type, error_id: u32) void {
    if t == null {
        return;
    }
    var eud: ErrorUnionData = ErrorUnionData{
        payload: payload,
        error_id: error_id,
    };
    t.data = TypeData.error_union(eud);
}

// 设置原子类型数据
fn type_set_atomic(t: &Type, inner: &Type) void {
    if t == null {
        return;
    }
    var ad: AtomicData = AtomicData{
        inner: inner,
    };
    t.data = TypeData.atomic_data(ad);
}

// 设置泛型参数数据
fn type_set_generic_param(t: &Type, name: &byte) void {
    if t == null {
        return;
    }
    var gpd: GenericParamData = GenericParamData{
        name: name,
    };
    t.data = TypeData.generic_param(gpd);
}

// 设置结构体泛型数据
fn type_set_struct_generic(t: &Type, name: &byte, type_args: &Type, type_arg_count: i32) void {
    if t == null {
        return;
    }
    var sgd: StructGenericData = StructGenericData{
        name: name,
        type_args: type_args,
        type_arg_count: type_arg_count,
    };
    t.data = TypeData.struct_generic(sgd);
}
