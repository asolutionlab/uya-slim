// checker/type_accessors.uya - 类型访问器函数
// 阶段四：Union 化重构 - 封装对 Type 字段的访问
// 提供统一的访问接口，便于渐进式迁移

// ===== 命名类型访问器 =====

// 获取命名类型的名称（enum/struct/union/interface）
// 返回类型名称，失败返回 null
fn type_get_name(t: &Type) &byte {
    if t == null {
        return null as &byte;
    }
    
    match t.kind {
        TypeKind.TYPE_ENUM => {
            match t.data {
                .named(name) => { return name; },
                else => {
                    if t.enum_name != null {
                        return t.enum_name;
                    }
                    return null as &byte;
                },
            }
        },
        TypeKind.TYPE_STRUCT => {
            match t.data {
                .named(name) => { return name; },
                .struct_generic(sg) => { return sg.name; },
                else => {
                    if t.struct_name != null {
                        return t.struct_name;
                    }
                    return null as &byte;
                },
            }
        },
        TypeKind.TYPE_UNION => {
            match t.data {
                .named(name) => { return name; },
                else => {
                    if t.union_name != null {
                        return t.union_name;
                    }
                    return null as &byte;
                },
            }
        },
        TypeKind.TYPE_INTERFACE => {
            match t.data {
                .named(name) => { return name; },
                else => {
                    if t.interface_name != null {
                        return t.interface_name;
                    }
                    return null as &byte;
                },
            }
        },
        else => { return null as &byte; },
    }
}

// 获取枚举类型名称
fn type_get_enum_name(t: &Type) &byte {
    if t == null || t.kind != TypeKind.TYPE_ENUM {
        return null as &byte;
    }
    match t.data {
        .named(name) => { return name; },
        else => {
            if t.enum_name != null {
                return t.enum_name;
            }
            return null as &byte;
        },
    }
}

// 获取结构体类型名称
fn type_get_struct_name(t: &Type) &byte {
    if t == null || t.kind != TypeKind.TYPE_STRUCT {
        return null as &byte;
    }
    match t.data {
        .named(name) => { return name; },
        .struct_generic(sg) => { return sg.name; },
        else => {
            if t.struct_name != null {
                return t.struct_name;
            }
            return null as &byte;
        },
    }
}

// 获取联合体类型名称
fn type_get_union_name(t: &Type) &byte {
    if t == null || t.kind != TypeKind.TYPE_UNION {
        return null as &byte;
    }
    match t.data {
        .named(name) => { return name; },
        else => {
            if t.union_name != null {
                return t.union_name;
            }
            return null as &byte;
        },
    }
}

// 获取接口类型名称
fn type_get_interface_name(t: &Type) &byte {
    if t == null || t.kind != TypeKind.TYPE_INTERFACE {
        return null as &byte;
    }
    match t.data {
        .named(name) => { return name; },
        else => {
            if t.interface_name != null {
                return t.interface_name;
            }
            return null as &byte;
        },
    }
}

// ===== 指针类型访问器 =====

// 获取指针目标类型
fn type_get_pointer_to(t: &Type) &Type {
    if t == null || t.kind != TypeKind.TYPE_POINTER {
        return null as &Type;
    }
    match t.data {
        .pointer(p) => { return p.pointee; },
        else => { return null as &Type; },
    }
}

// 检查是否为 FFI 指针
fn type_is_ffi_pointer(t: &Type) i32 {
    if t == null || t.kind != TypeKind.TYPE_POINTER {
        return 0;
    }
    match t.data {
        .pointer(p) => { return p.is_ffi; },
        else => { return 0; },
    }
}

// ===== 数组类型访问器 =====

// 获取数组元素类型
fn type_get_array_element(t: &Type) &Type {
    if t == null || t.kind != TypeKind.TYPE_ARRAY {
        return null as &Type;
    }
    match t.data {
        .array(arr) => { return arr.element; },
        else => { return null as &Type; },
    }
}

// 获取数组大小
fn type_get_array_size(t: &Type) i32 {
    if t == null || t.kind != TypeKind.TYPE_ARRAY {
        return 0;
    }
    match t.data {
        .array(arr) => { return arr.size; },
        else => { return 0; },
    }
}

